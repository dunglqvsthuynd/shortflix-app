{"1":[[141,287,"Happy five-year anniversary, honey."],[392,575,"In high school, he was everything."],[617,750,"Warm, kind,"],[784,950,"the guy every girl dreamed of."],[1001,1105,"But after we married..."],[1105,1292,"Did you hear me, sweetheart?"],[1359,1576,"That perfect man disappeared."],[1643,1885,"I said, happy anniversary."],[2139,2235,"How could you expect me"],[2235,2352,"to be happy today?"],[2352,2460,"It's the anniversary of"],[2460,2560,"our daughter's death."],[2744,2815,"Remember?"],[2848,2944,"When you were screwing"],[2944,3044,"your secretary,"],[3090,3324,"and you neglected her and let her die?"],[3345,3465,"That was an accident."],[3824,3937,"Hey, I have to go,"],[3987,4083,"but here's a lollipop."],[4108,4208,"You stay here, okay?"],[5893,5972,"Daddy."],[6181,6239,"Daddy."],[6485,6623,"The man I loved is dead."],[6669,6802,"What stands in front of me now"],[6852,6952,"is a monster."],[7011,7069,"Hey!"],[7511,7657,"You belong to the man"],[7657,7774,"who's standing in front of you"],[7774,7828,"right now."],[7903,8083,"I want a divorce."],[8266,8500,"Divorce is not an option!"],[8500,8666,"Even when you die, Esther,"],[8666,8850,"your ashes belong to me."],[8867,9054,"I will never let you go."],[9334,9380,"No."],[9413,9467,"Please,"],[9488,9580,"please let go of me."],[10839,10885,"No."],[10981,11069,"Our daughter is dead,"],[11069,11156,"so what?"],[11240,11353,"We can just have another one."],[11578,11728,"I can't live like this anymore."],[12537,12641,"Bitch, you tryed to fucking"],[12641,12787,"kill me now over a child?"],[12829,12954,"I'll send you to hell with her."],[13588,13659,"Esther."],[13809,13934,"Esther, please help me."],[14481,14635,"On our fifth anniversary,"],[14689,14777,"my husband died."],[14923,15056,"And I murdered him."],[16232,16424,"I never meant to kill him, but..."],[16474,16637,"everything happened too fast."],[16708,16800,"Now I'm scared,"],[16837,17033,"lost, and I don't know what to do next."],[19406,19506,"Happy anniversary, I'm,"],[19569,19661,"I'm sorry I'm late."],[20216,20257,"No."],[20257,20320,"No, no way."],[20320,20357,"He can't,"],[20357,20449,"he can't be alive."],[20449,20603,"I, I buried him myself."]],"2":[[33,125,"I'm sorry I'm late."],[308,392,"I bought your favorite dress"],[392,475,"from CMS."],[546,688,"I spent five times the price on it."],[688,788,"Limited edition."],[884,955,"Why don't you go try it on?"],[1526,1643,"How are you here right now?"],[1772,1881,"Who are you?"],[1931,2022,"You know who I am. I'm,"],[2160,2235,"I'm your husband."],[2356,2502,"Was my month-long business trip"],[2502,2652,"that long that you forgot about me?"],[2660,2702,"Come here."],[2702,2744,"No."],[2831,2977,"No, no, you can't be Carl."],[3086,3165,"Esther..."],[3174,3203,"What?"],[3324,3374,"What's wrong?"],[3374,3482,"Why do you look so nervous?"],[3712,3807,"Okay, you're dead."],[3995,4124,"You can't be here."],[4225,4287,"Dead?"],[4412,4483,"What do you mean dead?"],[4596,4675,"Look at me, do I..."],[4742,4859,"Do I look dead to you?"],[5759,5809,"Come here."],[6110,6256,"Maybe you had a nightmare about it."],[6348,6464,"Just a little too tired."],[6886,7061,"Mom gave us this as a wedding gift."],[7265,7399,"If I smashed that last night,"],[7399,7553,"how is it on the shelf again?"],[7674,7749,"The evidence."],[8120,8191,"It's gone."]],"3":[[54,133,"Look, I know you've been"],[133,321,"feeling overwhelmed."],[321,496,"So I invited some friends over tonight."],[588,709,"Our fifth-year anniversary."],[709,921,"I, I think it'll be nice"],[921,1038,"if you blow off some steam."],[1080,1172,"No, no, no."],[1172,1238,"It can't be."],[1280,1422,"How is he still alive?"],[1476,1705,"Was last night really just a nightmare?"],[1730,1776,"Wait."],[1889,1964,"Where is his..."],[2043,2127,"Where's your wedding ring?"],[2414,2540,"You're not Carl."],[3178,3261,"It's right here."],[3395,3470,"I washed my hands,"],[3470,3561,"and I must have forgotten"],[3561,3653,"to put it back on."],[3687,3762,"There, see?"],[3987,4141,"Hey, don't overthink it, okay?"],[4283,4416,"Okay, why don't you go try that dress on,"],[4416,4521,"and you will be the most"],[4521,4667,"radiant woman tonight."],[4921,5050,"I'll be done with my meeting soon."],[5388,5467,"It's been five years"],[5467,5547,"since we got married,"],[5547,5718,"and he's never talked to me like that."],[5789,5910,"He forgot every promise"],[5910,6047,"he made to me in high school."],[6172,6335,"But after I killed him..."],[6464,6556,"Why does it feel like"],[6556,6715,"the Carl I know is back?"],[6765,6810,"No."],[6919,7011,"No, that's impossible."],[7011,7186,"I buried him myself in the backyard."],[7469,7636,"Okay, Carl's body is still here."],[7716,7862,"That means what happened last night"],[7862,7974,"wasn't a nightmare."],[8049,8112,"That man..."],[8279,8391,"isn't Carl."],[8491,8767,"So, who was the man I saw this morning?"]],"4":[[633,884,"An anniversary party for Esther?"],[917,1017,"What a joke."],[1046,1213,"Carl never cared about her,"],[1213,1368,"especially after he met me."],[1664,1747,"Poor thing."],[1793,1997,"Everything you ever had, Esther,"],[2064,2206,"will end up being mine."],[4074,4279,"Long time no see, Esther."],[4304,4521,"Happy anniversary to you and Carl."],[4567,4629,"Get out."],[4708,4825,"You are not welcome here."],[4896,5009,"Your husband invited me."],[5117,5205,"Do you know why?"],[5288,5367,"He said I'm,"],[5367,5509,"I'm better in bed than you."],[6051,6131,"Looks like no one's here"],[6131,6206,"to save you now."],[6327,6485,"High school's over, Esther."],[6548,6627,"Don't believe me?"],[7207,7286,"Watch this."],[7907,7978,"Ow!"],[8108,8183,"Watch out!"]],"5":[[87,150,"Watch out!"],[1159,1263,"Why would he save me?"],[1526,1634,"Esther's coming!"],[2039,2181,"That's never gonna happen, right?"],[2369,2444,"Esther, watch out!"],[3933,4066,"Is this really the same guy"],[4066,4200,"who used to hit me all the time?"],[4291,4458,"He's like the Carl I used to love"],[4458,4554,"back in high school."],[4667,4813,"Carl Lewis, you..."],[4875,4984,"You're not seriously"],[4984,5150,"defending this, this bitch!"],[5150,5238,"You watch your mouth."],[5238,5405,"You will not speak to my wife like that."],[5422,5568,"If you want to keep your job tomorrow"],[5568,5697,"as my assistant,"],[5722,5818,"you will stop talking."],[5843,5943,"What is wrong with you?"],[5943,6026,"You, you're acting like"],[6026,6189,"a totally different person today."],[6189,6339,"Are you feeling okay?"],[6398,6514,"Are you stressed at work?"],[6577,6619,"You know,"],[6619,6785,"you could come back to my place"],[6785,6956,"and I could help you relax."],[7044,7132,"What are you doing, Sharon?"],[7132,7211,"I am married."],[7223,7286,"And if you don't stop,"],[7286,7411,"I'm gonna have to ask you to leave."],[7536,7665,"No, you're not Carl."],[7803,7874,"The Carl I know"],[7874,8049,"would never treat me like this."],[8099,8153,"Leave."],[8208,8304,"Before I make you."],[8508,8662,"I'll find out who you really are."],[8817,8942,"And then I'll expose you."],[9734,9797,"What's..."],[9872,9939,"that?"],[9955,10051,"What the hell?"],[10260,10343,"Don't touch that!"],[10464,10748,"Carl, this is the shirt I gave you."],[10902,11040,"Why is there blood on it?"],[11165,11277,"What did you do to him?"],[11340,11482,"You killed him, didn't you?"]],"6":[[58,379,"Carl does seem kind of different tonight."],[400,521,"I heard their daughter died"],[521,613,"because of him."],[654,754,"And Esther hasn't been"],[754,909,"mentally stable since then."],[925,1113,"She probably just snapped, killed him,"],[1146,1267,"and hired a double."],[1334,1426,"That's insane."],[1443,1572,"Is he Carl's doppelgänger"],[1572,1651,"or something?"],[1651,1776,"They look exactly the same."],[1881,2027,"You lost your mind, Sharon?"],[2131,2239,"I'm standing right here."],[2252,2423,"Stop acting."],[2444,2577,"I know him better than anyone."],[2585,2719,"One look is enough."],[2719,2798,"You're not him."],[2823,2957,"You really think you know me"],[2957,3144,"better than my wife of five years?"],[3311,3411,"Right, Esther?"],[3453,3507,"Please."],[3507,3645,"Esther doesn't know anything."],[3666,3803,"For the past five years,"],[3803,3912,"he spent more nights with me"],[3912,4091,"than he ever has with you."],[4116,4316,"Did you know that he was with me"],[4316,4512,"two hours before your wedding?"],[4512,4658,"Hey, enough, Sharon!"],[4817,5025,"You killed him, didn't you?"],[5059,5142,"You couldn't have him,"],[5142,5359,"so you brought in some replacement."],[5438,5538,"I killed him,"],[5572,5759,"but I'm not even sure if I really did."],[5839,5943,"I have to stay calm"],[5943,6085,"until I know who this Carl is."],[6106,6335,"No one can notice anything strange."],[6335,6498,"I don't know what you're talking about."],[6569,6710,"My husband is right here."],[6769,6898,"Then why did you act so scared"],[6898,7048,"when I reached down for that cloth?"],[7082,7228,"What are you hiding, Esther?"],[7269,7407,"We're not hiding anything, okay?"],[7407,7595,"My wife hated that shirt you got me,"],[7595,7674,"and so did I."],[7724,7807,"So we got rid of it."],[7816,7991,"Nothing is wrong with that."],[8037,8095,"Oh, really?"],[8249,8312,"Let's see."],[8508,8566,"Wait, no!"]],"7":[[29,83,"Wait, no!"],[496,567,"No way."],[696,784,"Carl's body..."],[863,925,"is gone."],[1013,1063,"See?"],[1130,1197,"I told you."],[1322,1447,"Well, if you really are Carl,"],[1455,1601,"then why are you acting this way?"],[1630,1780,"Yesterday you told me you love me,"],[1780,1935,"and you told me you were leaving Esther."],[2018,2139,"I tell women like you"],[2139,2273,"anything they want to hear."],[2306,2339,"Alright?"],[2339,2435,"Don't flatter yourself."],[2435,2556,"You are not special."],[2598,2644,"No."],[2744,2844,"No, you're lying."],[2852,2911,"Sharon."],[2965,3053,"Know your place."],[3128,3240,"It's time for you to leave."],[3240,3345,"Don't let me say it twice."],[3449,3645,"This isn't over, Esther."],[4375,4483,"Alright, apologies."],[4567,4667,"Everyone, my assistant"],[4667,4900,"has been feeling unstable lately."],[4971,5088,"I think it's best we call it a night,"],[5088,5134,"yeah?"],[5868,6014,"You moved the body, didn't you?"]],"8":[[83,191,"Where is he?"],[225,400,"Esther, what are you talking about?"],[417,521,"No, who the hell are you?"],[521,650,"My husband is dead!"],[650,809,"I am the one who buried him!"],[834,1088,"I know that losing our daughter"],[1096,1247,"shattered you, okay?"],[1247,1351,"And I know you've been"],[1351,1438,"under a lot of stress,"],[1438,1576,"but you are seeing things"],[1576,1659,"that aren't there."],[1931,2027,"It's okay. Come here."],[2060,2122,"Come here."],[2231,2318,"You're safe now."],[2352,2569,"Why does it feel so familiar,"],[2569,2740,"and yet so wrong?"],[2819,3094,"If Carl's alive, who did I bury?"],[3353,3490,"How about you go get some rest?"],[3586,3724,"Okay, we have the big meeting"],[3762,3832,"at the Maple Group"],[3832,3912,"with the board tomorrow,"],[3912,4129,"and, you don't want the vultures"],[4129,4254,"seeing you like this, right?"],[5839,5930,"Let's get started."],[6840,6940,"Mrs. Lewis,"],[6994,7248,"after discussing it with Mr. Lewis"],[7282,7444,"and the rest of the board,"],[7557,7778,"we've decided it might be best"],[7778,8012,"if you take a temporary leave"],[8078,8233,"from your role as CEO."]],"9":[[154,229,"If you're gonna suspend me,"],[229,316,"at least tell me why."],[567,825,"Your oversight these past few months"],[825,959,"has, has cost this company"],[959,1217,"hundreds of millions of dollars."],[1234,1438,"And considering everything"],[1438,1530,"you've been through,"],[1568,1718,"the board has decided"],[1718,1885,"to show you mercy."],[2002,2114,"You really think I don't know"],[2114,2223,"where the missing funds went?"],[2406,2585,"I trusted you and Carl."],[2711,2790,"That's how you managed"],[2790,2952,"to move the money behind my back."],[2952,3165,"Mrs. Lewis, you're his wife."],[3228,3365,"Why would he conspire with me?"],[3365,3495,"I'm just his assistant."],[3516,3649,"Well then why is his assistant"],[3649,3778,"giving me this news?"],[3862,4016,"Uh, stop playing dumb."],[4016,4162,"I know what you two are doing."],[4200,4425,"Mrs. Lewis, maybe you should"],[4425,4554,"step aside for a while."],[4596,4725,"You couldn't handle your husband,"],[4725,4842,"or protect your daughter,"],[4842,4921,"and now the company's"],[4921,5000,"taking a hit."],[5025,5125,"At this point,"],[5159,5338,"we just don't have the reason"],[5351,5472,"to trust you anymore."],[5501,5547,"You used to be"],[5547,5643,"one of the sharpest people"],[5643,5797,"in this business, Mrs. Lewis."],[5830,5972,"But ever since you got married,"],[5972,6035,"you've given up"],[6035,6139,"control of your shares"],[6139,6302,"and everything has gone downhill."],[6335,6610,"Mrs. Lewis, I think it'd be best"],[6631,6723,"for you to go home."],[6769,6894,"Be a housewife."],[6969,7082,"Honestly, Sharon would be"],[7082,7228,"a far better CEO."],[7361,7474,"It's funny to call"],[7474,7595,"a homewrecker competent."],[7678,7803,"Let me be clear."],[7841,7982,"As long as I am alive,"],[7982,8195,"I am not giving up my company."],[8395,8575,"Homewrecker or not,"],[8596,8708,"I'm the one that wins."],[8737,8821,"And I should probably"],[8821,8913,"mention that"],[8913,9054,"Mr. Lewis has decided"],[9054,9334,"to give me 50% of the shares."],[9392,9530,"As one of the largest shareholders"],[9530,9630,"of this company,"],[9688,9947,"your company is now mine."]],"10":[[12,266,"Your company is now mine."],[304,479,"And this little show today,"],[508,692,"it was all his idea."],[792,963,"He's still that monster."],[1080,1234,"Security, could you please"],[1234,1397,"come escort Mrs. Lewis out?"],[1747,1789,"What?"],[1789,1839,"No, no."],[1839,1935,"Hey, let me go!"],[1935,2022,"Let me go!"],[2444,2489,"Hey!"],[2640,2819,"No one touches my wife!"],[3595,3695,"Regarding this motion"],[3695,3933,"to suspend Esther as CEO,"],[3970,4104,"I'm withdrawing it immediately."],[4141,4204,"What?"],[4287,4366,"You heard me."],[4458,4646,"Anyone else have a problem with that?"],[4733,5067,"Carl, this is not what we discussed."],[5209,5455,"I am now the largest board member."],[5455,5580,"Nobody outranks me."],[5651,5901,"You said you were going to give me"],[5901,6056,"50% of the shares."],[6085,6189,"I never said that."],[6210,6343,"In fact, I will be transferring"],[6343,6598,"all of my shares, to Esther."],[6598,6752,"He's saving me again?"],[6752,6956,"She is, and always will be,"],[6956,7119,"the CEO of Maple Group."],[7269,7390,"Ms. White, that is not your seat."],[7507,7678,"Carl, what is wrong with you?"],[7761,7916,"You've been acting totally strange"],[7916,8028,"since last night."],[8128,8191,"Security."],[8437,8479,"Hey."],[9063,9221,"The Carl I know would never"],[9250,9376,"do something like this for me."],[9405,9655,"Now I say, that my wife"],[9676,9809,"will remain in charge,"],[9809,9930,"effective immediately."],[10014,10206,"We'll also begin an internal audit,"],[10206,10368,"starting with every transaction"],[10368,10539,"between myself and Ms. White."],[10593,10727,"Who is this man?"],[10760,10948,"What does he want from all of this?"]],"11":[[25,200,"Now, if there aren't any objections,"],[200,300,"why don't we wrap this up?"],[1326,1384,"Esther."],[1493,1630,"I promise to make this up to you."],[1693,1801,"I will protect you,"],[1830,1947,"like I always should have."],[2302,2410,"I don't believe you."],[3178,3282,"I'll make you believe."],[3424,3532,"What is wrong with him?"],[3532,3653,"Why was he defending me?"],[4775,4896,"I need to talk with you right now."],[5588,5672,"I'm pregnant."],[5759,5847,"And it's your baby."],[5905,6018,"Is this seriously"],[6018,6072,"how you're gonna"],[6072,6172,"treat your new family?"],[6519,6698,"We'll get it taken care of, alright?"],[7236,7457,"But the only child I will ever claim"],[7457,7528,"is Esther's."]],"12":[[79,187,"Two days ago,"],[208,367,"you said you would leave her"],[367,492,"if I ever got pregnant."],[554,671,"And now you're acting like"],[671,825,"a totally different person."],[825,980,"What the hell happened?"],[980,1071,"People change."],[1167,1288,"You killed my daughter."],[1288,1409,"You stole from the company."],[1409,1505,"That is enough"],[1505,1655,"to get you locked up behind bars"],[1655,1785,"for the rest of your life."],[1860,2010,"So it wasn't a nightmare."],[2052,2139,"It was real."],[2160,2356,"Okay, you're putting on a show,"],[2406,2527,"for everyone, huh?"],[2548,2886,"You know, you used to be so careful."],[2902,3015,"If you hadn't said anything,"],[3057,3148,"I never would've thought"],[3148,3274,"to delete that dashcam footage"],[3274,3328,"of you leaving"],[3328,3457,"your daughter choking"],[3486,3611,"in the car to be with me?"],[4062,4129,"Daddy."],[4270,4350,"Daddy."],[4654,4833,"They planned it from the start."],[4892,4971,"All of it."],[5188,5376,"So now, you're pretending to be"],[5376,5547,"the perfect husband"],[5584,5739,"to save your reputation,"],[5793,5976,"get rid of that little wife of yours,"],[5976,6177,"and give me the company,"],[6202,6318,"like you promised."],[6393,6564,"Oh I know you too well, Carl."],[6660,6785,"He didn't die that night."],[6823,6898,"He just came back"],[6898,7023,"to finish what he started,"],[7023,7169,"to take all my shares."]],"13":[[1722,1814,"Esther, please wait, just let me-"],[1814,2006,"No, don't! I have heard enough!"],[2527,2631,"Esther. Esther."],[2652,2773,"No, I heard everything."],[2827,3019,"You and that bitch killed my daughter."],[3061,3144,"You've only been nice to me"],[3144,3199,"the last couple of days"],[3199,3286,"to cover that up."],[3286,3382,"Esther, calm down."],[3382,3516,"I am not gonna calm down!"],[3712,3837,"That night wasn't a nightmare."],[3837,3920,"That was real."],[3974,4091,"And I wish it stayed that way."],[4091,4241,"I wish you stayed dead."],[4241,4350,"Shh! Just calm down."],[4508,4629,"Don't tell me what to do."],[4767,4946,"I have nothing to hide unlike you."],[5584,5630,"Sign."],[5780,5889,"This really isn't the time"],[5889,5951,"to talk about..."],[5951,6047,"If you're not gonna sign,"],[6047,6172,"I'm gonna call the cops right now"],[6172,6314,"and tell them everything you did."]],"14":[[558,700,"I'd like to report my husband,"],[700,763,"Carl Lewis,"],[763,938,"for child abuse, domestic violence,"],[938,1042,"and homicide."],[1292,1518,"Trust me, the police can't help you."],[1589,1693,"Your threats don't"],[1693,1797,"work on me anymore."],[1797,1864,"Threat?"],[1968,2081,"I'm not trying to threaten you."],[2114,2181,"Look, I know you don't"],[2181,2277,"fully understand,"],[2277,2373,"and it's complicated,"],[2373,2540,"but trust me, I'm trying to protect you."],[2540,2615,"Trust you?"],[2706,2794,"Are you kidding?"],[2823,3011,"The guy that I loved back in high school"],[3011,3119,"died years ago."],[3148,3386,"You, are a liar who cheated on me"],[3386,3486,"with his assistant,"],[3507,3645,"stole from my company,"],[3645,3807,"and killed my daughter."],[3820,3870,"Come here."],[3912,4008,"Don't touch me!"],[4592,4708,"I'm not who you think I am."],[4871,4938,"Oh, really?"],[5221,5367,"Okay, then who are you?"],[5417,5513,"His ghost?"],[5551,5689,"His long-lost twin?"],[5722,5868,"My God, your lies are just"],[5868,5980,"as pathetic as you are."],[6168,6231,"Please."],[6335,6464,"Just give me one chance."],[6519,6594,"I swear,"],[6594,6765,"I won't let anybody hurt you again."],[6802,6844,"Okay?"],[6990,7123,"You made that same promise to me"],[7123,7219,"back in high school."],[7303,7382,"And now you're the one"],[7382,7482,"I need protection from."],[8641,8775,"Officers, that was fast."],[8775,8879,"I just called."],[9505,9680,"Ms. Lewis, we recovered a body"],[9680,9759,"from the river."],[9759,9909,"Based on the evidence we found,"],[10010,10114,"unfortunately we believed it to be"],[10114,10185,"your husband."],[10468,10543,"Carl Lewis."]],"15":[[16,112,"Estimated time of death"],[112,308,"is 72 hours ago."],[446,521,"It's impossible,"],[521,696,"my husband is standing right here."],[800,850,"Yeah, there's been"],[850,938,"some type of mistake."],[938,1076,"I am Carl Lewis."],[1776,1889,"No, that can't be right."],[1926,2010,"This is all just,"],[2077,2218,"some big misunderstanding."],[2273,2339,"You guys can go-"],[2339,2439,"Not so fast."],[2448,2565,"Look, be that as it may,"],[2565,2686,"procedure is procedure."],[2752,2823,"And we need the both of you"],[2823,2886,"to come with us,"],[2907,2948,"right now."],[3599,3778,"Carl Lewis's body?"],[3795,3949,"Then who the hell is that guy?"],[3983,4145,"Is he a dupe?"],[4145,4225,"I have to know"],[4225,4316,"why Carl suddenly"],[4316,4421,"has a change of heart."],[4525,4658,"Esther won't get him back."],[4704,4833,"Carl's mine."],[5326,5463,"We collected a DNA sample"],[5463,5543,"from the body."],[5647,5814,"But there's no record for Mr. Lewis..."],[5901,5997,"I'm sorry, excuse me."],[6068,6202,"Of the victim on record."],[6289,6435,"And his father, Victor Lewis,"],[6489,6573,"has refused to provide"],[6573,6656,"a DNA sample."],[6760,6861,"Wait, my father refused"],[6861,6956,"a DNA sample?"],[7027,7173,"If this guy under the blanket"],[7173,7269,"really is Carl,"],[7315,7482,"then who is standing next to me?"],[7628,7720,"The body was severely damaged"],[7720,7782,"by water."],[8003,8145,"Please, brace yourself."],[8458,8541,"Um, I'm ready."]],"16":[[734,813,"Oh my God."],[813,896,"Oh, come here."],[1192,1355,"Mrs. Lewis, do you recognize anything?"],[1397,1593,"No, it's completely unrecognizable."],[2223,2348,"These were found on the victim."],[2652,2706,"That's the"],[2706,2857,"C.N. limited edition underwear"],[2857,2948,"I gave him."],[3053,3186,"That's Carl's underwear."],[3224,3378,"Ms. Lewis, you seem nervous."],[3378,3516,"No, no, uh..."],[3570,3657,"My, my husband had a,"],[3657,3762,"had a pair like that."],[3787,3887,"That pair of underwear"],[3887,4045,"doesn't prove anything."],[4087,4225,"You can find that brand anywhere."],[4225,4362,"Why so defensive, Mr. Lewis?"],[4412,4487,"Wouldn't you be?"],[4525,4683,"You are forcing my wife"],[4683,4758,"to relive a nightmare"],[4758,4959,"based off a corpse you think is me!"],[5255,5305,"Alright."],[5413,5505,"You're both free to go."],[5559,5626,"We'll contact you"],[5626,5734,"if we find anything new."],[5822,5897,"Let's go home."],[5943,5985,"Alright?"],[5985,6076,"Yes, come here."],[6093,6227,"This is my opportunity to prove"],[6227,6393,"that this man is not the real Carl!"],[6410,6473,"Officer."],[6690,6790,"That's Carl's underwear."],[6823,6902,"I can prove it."]],"17":[[16,95,"I can prove it."],[162,271,"Sharon, what the hell are you doing?"],[450,671,"Officer, that is a limited edition"],[671,729,"pair of underwear"],[729,809,"that I bought Carl."],[809,921,"I know it anywhere."],[984,1188,"There's none other like it in the state."],[1188,1234,"Sharon!"],[1234,1309,"Let her speak."],[1455,1701,"He's been acting strange for two days."],[1701,1822,"And I found blood-stained"],[1822,1956,"clothes in their backyard."],[2035,2085,"I..."],[2106,2281,"I think the real Carl is dead."],[2281,2364,"Hey, do you have any proof?"],[2410,2469,"Because if you don't,"],[2469,2606,"I could sue you for slander."],[2606,2798,"The underwear is proof."],[3040,3098,"Sir,"],[3165,3274,"we found Carl Lewis's prints"],[3274,3353,"in the database."],[3395,3424,"Good."],[3449,3486,"Good."],[3486,3653,"Let's do a fingerprint scan."],[3983,4283,"If you really are Carl, then prove it."],[4629,4704,"Yeah, why not?"],[5017,5142,"If the fingerprints match,"],[5142,5246,"then that night was really"],[5246,5347,"just a nightmare."],[5384,5467,"But if they don't,"],[5576,5701,"I'm the prime suspect."],[7607,7732,"No way."]],"18":[[771,925,"No way."],[950,1130,"It's a perfect match, isn't it?"],[1226,1388,"Can you confirm my identity now?"],[1639,1755,"That's impossible."],[1814,1951,"You did something to the system,"],[1951,2010,"didn't you?"],[2031,2118,"Look, Sharon."],[2168,2264,"I know you're pregnant"],[2264,2402,"and desperate to find a father."],[2444,2531,"But my rejection"],[2531,2623,"doesn't make me dead."],[2731,2890,"The Carl you love never existed."],[2890,3023,"It was all in your fucking head."],[3257,3315,"Are we done now?"],[3378,3470,"Can I take my wife home?"],[3749,3828,"You're free to go."],[4129,4325,"No. Something's wrong."],[4354,4529,"No one knows Carl better than I do."],[4562,4746,"I'll find proof you're not him."],[4950,5042,"Esther, slow down."],[5213,5372,"Earlier when we argued, you said,"],[5372,5530,"I'm not who you think I am."],[5730,5834,"What did you mean by that?"]],"19":[[95,204,"What I meant was,"],[325,513,"I've really messed up."],[529,671,"But I don't want to be that guy anymore."],[825,996,"Why are you looking at me like that?"],[1084,1146,"Like what?"],[1213,1401,"you haven't seen me."],[1401,1493,"That's how I always"],[1580,1722,"should have looked at you, Esther."],[1868,1997,"It's called love."],[2298,2489,"I will never let you go!"],[2711,2761,"No."],[2969,3115,"So if you really were Carl,"],[3224,3386,"you'll pin me right here,"],[3420,3582,"force my legs apart,"],[3641,3720,"take me rough,"],[3720,3908,"and claim me like your trophy."],[3995,4166,"Not tell me that you love me."],[4245,4479,"So stop pretending to be that monster"],[4496,4675,"and tell me who you are."],[4750,4846,"I already told you."],[4946,5038,"I'll respect you."],[5176,5276,"I'll cherish you."],[5434,5568,"And I will only touch you"],[5568,5676,"when you want me to."],[5822,5905,"If he really was"],[5905,6106,"an abusive, cheating monster,"],[6172,6331,"why do I want his hands on me?"],[6485,6569,"His warmth."],[6694,6777,"His breath."],[6936,7040,"Not like this."],[7144,7290,"Not when you don't fully trust me yet."],[7782,7874,"Why were your fingerprints"],[7874,7982,"in the police database?"],[8366,8462,"Esther's always acting,"],[8462,8550,"damn princess,"],[8550,8662,"but I bet she's filthy"],[8662,8758,"when she wants to be."],[8792,8908,"Graduation night, bro."],[8908,9075,"We need to see how wild she really is."],[9075,9104,"Yeah."],[9993,10118,"Oh my God, someone's bleeding!"],[10130,10243,"Call the cops!"],[10372,10548,"That's not Carl, right?"],[10839,11011,"What's taking Carl so long."],[11140,11273,"I got in a fight a while back,"],[11273,11461,"and I ended up at the police station."],[11490,11565,"That's what happened."],[12299,12358,"Hello?"],[12591,12700,"What, he wants to see me?"],[12871,12971,"Yeah I'll be right over."],[13250,13380,"My father wants to see me."],[13467,13659,"You know, if I was really an imposter,"],[13730,13842,"do you think I would step foot"],[13842,13922,"in front of that man?"]],"20":[[742,800,"Mr. Lewis,"],[800,942,"your father is waiting for you."],[2644,2773,"Long time no see, Dad."],[2911,2977,"You're here."],[3549,3657,"You know, we took this photograph"],[3657,3753,"ten years ago."],[3928,4041,"I guess we never got around"],[4041,4158,"to taking new ones, huh?"],[4258,4396,"Maybe I'm just overthinking."],[4433,4562,"Maybe he is Carl."],[4600,4742,"His father recognized him."],[5159,5221,"You..."],[5417,5459,"You-"],[6001,6222,"Some things are better left unsaid."],[6243,6377,"Won't you agree, Dad?"]],"21":[[621,721,"Well, it looks like my wife"],[721,813,"is still mad at me."],[892,980,"Of course I am."],[1126,1230,"You killed my daughter."],[1330,1376,"Okay, look,"],[1376,1463,"that makes sense."],[1463,1568,"After everything that's happened,"],[1568,1643,"I, I get it."],[1801,1851,"Esther."],[2143,2227,"Can we start over?"],[2381,2544,"Please, just give me another chance."],[2686,2727,"Wait."],[2752,2865,"That mole."],[3107,3157,"Hi."],[3215,3290,"Uh, for Esther?"],[3353,3453,"I'm here for the internship."],[3632,3728,"Hey, I'm Carl Lewis,"],[3749,3862,"also here for the internship."],[4454,4504,"Carl?"],[4608,4675,"Esther?"],[4767,4929,"Oh my gosh!"],[4988,5046,"Hi!"],[5234,5401,"I've missed you so much."],[5434,5530,"Wait, where have you been"],[5530,5613,"all these years?"],[5647,5793,"I mean, why did you disappear"],[5793,5930,"after the graduation party?"],[5985,6085,"After all these years, like,"],[6085,6252,"why didn't you ever try to contact me?"],[6373,6452,"Gosh, I..."],[6614,6773,"You really haven't changed a bit."],[7127,7211,"Wait, didn't you..."],[7282,7424,"used to have a mole under your eye?"],[7507,7570,"Oh yeah, I know."],[7570,7707,"It got big and gross."],[7707,7795,"I got it removed."],[7795,7862,"Oh."],[7907,7945,"Well..."],[8070,8191,"It's really good to have you back."],[8262,8316,"You, too."],[8921,8975,"I thought you said"],[8975,9104,"you had your mole removed."]],"22":[[283,362,"You clearly haven't been"],[362,446,"paying attention."],[446,492,"I, uh..."],[546,667,"I fell asleep on my desk"],[667,759,"during a business trip"],[759,934,"and, poked myself with a pen."],[934,996,"It's a scar."],[1009,1126,"Okay, stop lying."],[1163,1263,"Why are you pretending"],[1263,1334,"to be Carl?"],[1334,1405,"I'm not lying."],[1405,1551,"I, I am Carl, okay?"],[1551,1764,"I'm the one who sacrificed myself"],[1764,1843,"protecting you from"],[1843,1997,"even a bucket of black paint, okay?"],[1997,2056,"It's me."],[2097,2160,"You know what?"],[2214,2348,"I'll go ask your father myself."],[2377,2452,"He'll know something's off"],[2452,2544,"with you right away."],[3728,3795,"Esther."],[3949,4012,"Victor."],[4112,4149,"Did you,"],[4187,4341,"did you notice anything strange"],[4341,4433,"with Carl just now?"],[4554,4625,"There's,"],[4625,4842,"there's nothing wrong with my son."],[4888,5030,"You're overthinking it."],[5088,5167,"Why didn't you go down"],[5167,5246,"to the police station"],[5246,5392,"when they asked for a DNA sample?"],[5480,5647,"They found Carl's body."],[5805,5951,"My son is standing right there."],[5951,6068,"He is alive."],[6068,6218,"There's no need for any tests."],[6243,6352,"Victor, I really think..."],[6389,6519,"Look, Esther,"],[6519,6748,"I know you've had a hard time"],[6777,6873,"since you lost your daughter."],[6931,7048,"But it's time to move on."],[7082,7144,"You and Carl"],[7144,7428,"can have a, a new life together."],[7786,7941,"Why is Victor covering for him?"],[8008,8099,"Am I losing my mind"],[8099,8262,"or are they both hiding something?"],[8350,8454,"If he's Carl,"],[8500,8733,"why does he feel like someone else?"],[8754,8896,"Why do I want to be near him,"],[8946,9017,"trust him?"],[9017,9225,"Why am I drawn to him like this?"],[9305,9471,"I hope he isn't the Carl I married,"],[9526,9672,"even if it means I'll be arrested"],[9672,9743,"for murder."],[9813,9955,"There's only one way to find out."],[10026,10139,"If I can get his fingerprints"],[10139,10281,"from the company contracts,"],[10368,10518,"I'll know who he really is."]],"23":[[479,650,"If I can just get him to hold this,"],[704,825,"I'll have his fingerprints."],[846,946,"That's all I'm after."],[1017,1109,"Nothing else."],[1989,2060,"What happened?"],[2131,2210,"Esther, you have been"],[2210,2318,"staying in the guest room"],[2318,2414,"since I got back."],[2540,2819,"I just wanted to apologize for earlier."],[2940,3040,"I overreacted."],[3244,3294,"But,"],[3407,3528,"maybe your father's right."],[3670,3799,"Maybe it's time we move on."],[5075,5146,"You..."],[5259,5376,"You don't have anything,"],[5451,5572,"to apologize for."],[5605,5709,"Yeah, I should be the one"],[5709,5834,"apologizing to you."],[6368,6589,"Is this really the Carl that I used to know?"],[7069,7144,"You have been"],[7248,7298,"through enough"],[7298,7369,"because of me."],[7611,7670,"Come here."],[7695,7857,"If this is the real Carl,"],[7857,8062,"then how could he change overnight?"],[8354,8437,"Let me go."]],"24":[[254,316,"You're not him."],[383,437,"You're not him."],[437,538,"He never held me like that."],[538,658,"He only ever hurt me."],[792,846,"Hey."],[934,1051,"It's okay, calm down, I..."],[1947,2160,"The nightmare is over, okay?"],[2256,2335,"I am here."],[2640,2702,"Come here."],[3908,4045,"You're not him, are you?"]],"25":[[187,325,"You're not him, are you?"],[946,1026,"Okay, Carl?"],[1088,1230,"Carl, there's people outside."],[1230,1317,"They're gonna see."],[1451,1501,"Good."],[1547,1672,"I want them to see what you look like"],[1672,1768,"when I fuck you."],[1826,1960,"Okay, Carl, look,"],[1960,2089,"I don't think that this is..."],[2089,2231,"This is not a good idea."],[2560,2660,"Again, Esther."],[2727,2781,"Moan!"],[3870,3941,"That's my girl."],[4859,4934,"Look at us."],[4971,5209,"I want you to watch how you're mine."],[5242,5292,"All of you."],[5292,5376,"Only mine."],[5397,5451,"Alright?"],[5955,6060,"I know you're not."],[7607,7716,"Are you sure?"],[7770,7866,"Are you ready for this?"],[8016,8116,"Do you want me?"],[8174,8249,"The real me?"],[8516,8629,"Will you turn out the lights?"]],"26":[[829,967,"This was the face of the man"],[967,1080,"I fell in love with."],[1126,1280,"The face that became a nightmare"],[1280,1397,"after we got married."],[1397,1634,"But after I buried that monster myself,"],[1689,1876,"suddenly the man I loved is back."],[2952,3136,"Are you the man who came back for me,"],[3148,3336,"or the monster who ruined my life?"],[4054,4245,"Either way, I'll know soon enough."],[5543,5651,"Run a fingerprint test."],[5830,5939,"Compare this"],[6168,6285,"to the one on this contract."],[6389,6502,"I want the results right away."],[6752,6819,"There's something else"],[6819,6919,"you might wanna know, boss."],[6986,7048,"What is it?"],[7094,7215,"Mr. Lewis just"],[7215,7307,"transferred the money"],[7307,7419,"he moved with Ms. White"],[7419,7586,"back into the company accounts."],[7695,7803,"Why would he do that?"],[7820,7991,"Perhaps he believes the audit"],[7991,8149,"might expose their connection."],[8220,8350,"Could this be another trap?"],[8450,8558,"Is he in the office right now?"],[8746,8850,"Okay, I need to see him."]],"27":[[1572,1776,"I know Carl better than anyone."],[1801,1968,"Let's see who you really are."],[3987,4054,"We..."],[4116,4208,"haven't really had fun in here"],[4208,4308,"in a while, have we?"],[4400,4525,"My office"],[4608,4742,"is not for your entertainment,"],[4742,4821,"Sharon."],[4884,5305,"Look, I'm sorry that I used my pregnancy"],[5305,5376,"to threaten you."],[5376,5572,"And I'm sorry that I caused"],[5572,5718,"such a scene at the party."],[5747,5876,"I shouldn't have thought"],[5876,5951,"you were dead."],[6172,6231,"Come on."],[6327,6477,"We spent so much time"],[6477,6635,"trying to get that woman out of here."],[6765,6819,"Don't tell me you're"],[6819,6969,"having second thoughts now."],[7265,7361,"There is no we."],[7394,7478,"There is you,"],[7499,7628,"and there is me and Esther."],[7628,7695,"That is it."]],"28":[[29,75,"Here."],[75,108,"Don't-"],[108,175,"I got it!"],[967,1142,"There's nothing on his chest."],[3128,3269,"He's not Carl."],[3716,3891,"I saw Sharon in there again."],[3949,4158,"I saw her carrying a bottle of wine."],[4158,4216,"Oh."],[4400,4529,"It looks like a celebration."],[4546,4592,"Yeah."],[4642,4713,"I don't even think"],[4713,4879,"she's wearing much under that coat."],[4904,5021,"Poor Mrs. Lewis,"],[5021,5163,"she's running this whole company,"],[5163,5271,"and then her husband's"],[5271,5367,"just cheating on her,"],[5367,5484,"right under her nose."],[6235,6352,"Carl, open this door!"]],"29":[[116,241,"Carl, open this door!"],[1443,1626,"Oh, perfect timing."],[1651,1743,"You're here now."],[1780,1860,"Your husband and I"],[1860,1981,"were just getting started."],[2093,2239,"Are you gonna explain this?"],[2498,2577,"Don't listen to her."],[2615,2669,"Okay?"],[2731,2882,"Sharon, you're fired."],[2907,3061,"Pack up all your shit and get out."],[3073,3182,"This isn't Carl."],[3199,3395,"The real Carl's probably dead."],[3415,3524,"I'll find the evidence."],[3524,3807,"And when I do, you'll both pay for it."],[3832,3895,"Sure."],[4016,4070,"Whatever."],[4754,4838,"Keep up the act."],[4884,4971,"Soon everyone will know"],[4971,5050,"who you really are."],[6097,6177,"What was that?"],[6222,6364,"What were you two even celebrating?"],[6402,6548,"You recovered the missing funds,"],[6548,6673,"and you fired Sharon."],[6673,6723,"Why?"],[6798,6952,"Are you protecting her?"],[6969,7052,"Please don't listen to"],[7052,7161,"a word she says, okay?"],[7161,7278,"She's fucking crazy."],[7586,7682,"I have good news."],[7711,7774,"Yeah."],[8008,8199,"I closed the Lagos Chase and Co. deal."],[8233,8379,"Cash flow is stabilized."],[8404,8546,"I returned the missing funds,"],[8579,8708,"and I finalized the IPO."],[8842,8996,"Hey, it was just approved."],[9125,9246,"Lagos Chase and Co.?"],[9426,9580,"But they're the top ten financial firm"],[9580,9630,"in the country."],[9630,9747,"Why would they want to work with us?"],[9872,9947,"Because of you."],[9989,10264,"You are the top female CEO."],[10297,10377,"He heard about you."],[10493,10694,"The CEO signed on specifically"],[10694,10785,"because it is you."],[11298,11390,"The Carl I knew couldn't"],[11390,11553,"even close a small client."],[11611,11753,"So if he's not Carl,"],[11778,11916,"why is he helping me?"]],"30":[[2164,2227,"Who's there?"],[2314,2485,"Hey, it was probably just"],[2485,2623,"some kids messing around."],[2765,2923,"God, you're so tense."],[3011,3107,"Do you want me to help you unwind?"],[3123,3240,"No, no, no, no, no, no, no."],[3257,3457,"Someone is following me."],[3457,3549,"Relax."],[3566,3687,"You're, you're overthinking."],[3687,3799,"No one is following you."],[3824,3962,"You don't even have enemies."],[3999,4079,"I can hear them."],[4158,4254,"Someone's watching us."],[4270,4316,"Look."],[4358,4437,"I installed"],[4458,4546,"private cameras at the house"],[4546,4633,"and at the business, alright?"],[4633,4754,"I'm gonna give you the login."],[4808,4879,"You're gonna watch it."],[4879,4979,"If you see anything strange,"],[4979,5059,"you let me know."],[5059,5105,"Got it?"],[5167,5284,"I got it, boss."],[5776,5989,"Carl wasn't paranoid after all."],[6039,6222,"If I can access those cameras,"],[6252,6398,"maybe I'll find something."],[7061,7257,"September 21st."],[7340,7549,"The day Carl got back from his trip."],[8546,8629,"Oh my God."],[8812,8958,"You really did kill Carl."]],"31":[[955,1105,"Hey, Carl. I..."],[1176,1376,"I know things have been a little tense"],[1376,1463,"between us, but..."],[1551,1885,"I really think you'll forgive me"],[2039,2227,"once you see these photos."],[2765,2911,"To the success of our company,"],[2973,3069,"and us."],[3203,3290,"I don't get it."],[3365,3499,"Why are you doing this?"],[3532,3757,"Why are you helping me?"],[3812,3945,"Do I really need a reason"],[3945,4024,"to help my wife?"],[4191,4304,"The man that I married"],[4304,4421,"would never help me."],[4542,4633,"He hurt me."],[4658,4733,"He lied."],[4750,4854,"He used me."],[4921,5017,"So if you really are him,"],[5017,5130,"then I have every reason"],[5130,5242,"to believe this is a setup."],[5242,5376,"And if you're not, then..."],[5455,5597,"Then who the hell are you?"]],"32":[[1530,1672,"Hey, Carl. I..."],[1697,1889,"I know things have been a little tense"],[1889,1976,"between us, but"],[1976,2227,"I really think you'll forgive me"],[2256,2427,"once you see these photos."],[2560,2631,"I, uh..."],[2815,2952,"I have to take care of something."],[3061,3140,"Of course."],[3190,3282,"The IPO,"],[3282,3390,"the missing funds,"],[3390,3474,"firing Sharon,"],[3528,3699,"it's all part of his plan."],[3757,3933,"Just another scheme to take me down."],[4104,4158,"Hey."],[4433,4500,"Trust me."],[4617,4662,"Okay?"],[4662,4775,"You will know everything"],[4817,4896,"soon enough."],[4984,5046,"I promise."]],"33":[[120,254,"I want to trust you."],[533,613,"But I can't."],[850,917,"Not yet."],[1226,1355,"But I really want to."],[1393,1622,"I want you to be that man again, Carl."],[1676,1830,"The Carl that I fell in love with."],[1881,2027,"Please, be that man again."],[2214,2473,"I will do everything it takes"],[2473,2577,"to win you back, okay?"],[2577,2965,"I am never, never gonna give up on us."],[4850,4921,"Carl?"],[5163,5230,"Is that you?"]],"34":[[241,496,"Wow, are you back from the dead,"],[496,688,"or is this just someone"],[688,796,"pretending to be you?"],[950,1017,"I have no idea"],[1017,1109,"what you're talking about."],[2260,2377,"That blood-stained shirt"],[2377,2515,"I found in your backyard,"],[2573,2765,"that was Carl's shirt, right?"],[3190,3282,"And that body"],[3282,3428,"the police found in the river,"],[3428,3661,"that was the real Carl, isn't it?"],[3661,3749,"Look, I don't have time"],[3749,3828,"for your, your"],[3828,4008,"conspiracy theories, Sharon."],[4091,4200,"Then why are you here?"],[4337,4446,"Because you want me?"],[4600,4700,"Or because you're afraid"],[4700,4913,"I'll turn that video over to the police"],[4950,5096,"and get your little wife arrested?"]],"35":[[283,500,"If you so much as touch Esther,"],[500,563,"you will spend"],[563,721,"the rest of your life regretting it."],[996,1138,"You really did replace Carl."],[1201,1313,"Because the Carl I knew"],[1313,1443,"only choked me in bed."],[1443,1551,"Guess the Carl you knew"],[1551,1668,"didn't have standards."],[1689,1755,"Because I would never"],[1755,1847,"get my hands dirty"],[1847,1931,"for people like you."],[2398,2523,"Look, I don't care."],[2652,2886,"I just want to know who you belong to."],[2982,3036,"Her?"],[3115,3165,"Or me?"],[3303,3503,"Because this baby inside me"],[3503,3678,"still needs a father."],[3774,3887,"Divorce Esther,"],[3966,4049,"be with me,"],[4087,4175,"and I will forget"],[4175,4379,"all about that little video."],[4546,4713,"But make the wrong choice..."]],"36":[[0,154,"But make the wrong choice..."],[154,375,"You really think some edited clip"],[375,487,"is enough to threaten me?"],[571,788,"I don't make wrong choices."],[817,925,"You were just a fling."],[925,1021,"That's it."],[1042,1272,"And even if you were the last woman"],[1272,1418,"standing on earth,"],[1418,1555,"I still wouldn't want you."],[1931,2093,"The only woman I've ever loved"],[2093,2160,"is Esther."],[2331,2439,"You'll see what I did for her."],[2502,2556,"Lewis!"],[2577,2635,"Mr. Lewis!"],[2660,2790,"Just last month, Maple Group"],[2790,2957,"was on the verge of bankruptcy."],[2986,3107,"Now you've pulled off a miracle"],[3107,3244,"and landed a deal with"],[3244,3349,"Lagos Chase and Co?"],[3390,3528,"Congratulations, Mr. Lewis."],[3528,3657,"There have also been rumors online"],[3657,3799,"about tension in your marriage."],[3799,3858,"Can you address"],[3858,3999,"whether these rumors are true?"],[3999,4187,"I will only ever love my wife."],[4316,4408,"Three weeks from now,"],[4408,4475,"we will be holding"],[4475,4621,"an IPO press conference here."],[4646,4750,"I hope to see you all there."],[4771,4829,"Thank you."],[4942,5009,"Mr. Lewis!"]],"37":[[508,633,"Now when a man truly,"],[654,838,"and I mean truly loves a woman,"],[950,1059,"he would do whatever it takes"],[1059,1159,"to watch her shine."],[1230,1430,"Whatever this was between us,"],[1488,1564,"it was dirty"],[1584,1726,"and it was hidden for a reason."],[1726,1785,"Right?"],[1835,1922,"I used you,"],[2006,2143,"letting you walk away on your own"],[2143,2293,"was the nicest thing I could have done."],[2310,2464,"But don't get deluded enough"],[2464,2610,"to think you were ever a choice."],[2781,3061,"I swear I will ruin your IPO conference"],[3061,3240,"and I will make sure everybody knows"],[3240,3420,"who you really are."],[3603,3670,"Do it."],[4671,4904,"You haven't seen this one yet."],[5013,5209,"Look how much he's enjoying himself."],[6056,6252,"You won't get away with this, Esther."]],"38":[[1355,1468,"Daddy. Daddy."],[2711,2794,"Daddy."],[5030,5176,"God damn you, Carl."],[5538,5655,"You're gonna pay for this."],[6172,6231,"Esther?"],[6456,6527,"Oh, Esther."],[6619,6669,"Hey, hey."],[7586,7678,"Come on, Esther. Come on."],[7678,7807,"Let's get you off the ground, come on."],[7870,7920,"Ready?"],[7962,8053,"One, two, three, up."]],"39":[[2356,2648,"Like I said, our daughter died,"],[2648,2756,"so what?"],[2852,2969,"We can have another one,"],[3015,3299,"and he will be just like me."]],"40":[[212,291,"Don't touch me."],[533,638,"You're a monster."],[896,992,"And I know where you were."],[992,1076,"You were with her."],[1076,1209,"I can smell her on you."],[1368,1501,"You and that bitch,"],[1501,1630,"you killed my daughter."],[1630,1743,"Listen to me, Esther."],[1780,1935,"I can't tell you everything right now,"],[1997,2118,"okay, but trust me,"],[2118,2214,"when the time is right-"],[2214,2335,"You mean after the IPO"],[2335,2402,"when you dumped me"],[2402,2535,"and crawl back to Sharon?"],[2590,2640,"What?"],[2748,2857,"No, of course not."],[2973,3169,"Esther, I love you."],[3169,3311,"You're lying again."],[3490,3716,"You don't care if I live or if I die."],[3716,3828,"God, you're probably hoping"],[3828,4029,"that I drop dead right now"],[4029,4183,"so you can have my house,"],[4183,4346,"my shares, everything."],[4537,4721,"Why do you keep doing this to me?"],[5025,5188,"Okay, if hurting me gives you"],[5188,5401,"some sort of sick pleasure, then..."],[5630,5714,"Well then, fine."],[5714,5809,"Hey, hey! Esther."]],"41":[[87,145,"Esther."],[204,275,"Don't do it."],[296,350,"Don't..."],[425,763,"If you really hate me that much,"],[1718,1860,"then take my heart instead."],[2056,2093,"Do it."],[2093,2193,"If it'll make you feel better."],[2473,2635,"Don't think that I won't kill you."],[2635,2794,"I swear to God, I will kill you."],[2957,3032,"Then do it."],[3244,3303,"Go on."],[3403,3595,"I have always been yours"],[3595,3732,"to love or to kill."],[5155,5242,"I can't."],[5451,5505,"Come here."],[5568,5618,"No."],[5784,6097,"Okay, I hate myself for loving you."],[6227,6377,"You are a monster."],[6377,6448,"I should kill you."],[6448,6573,"I want to kill you."],[6844,6906,"God, no."],[6906,7052,"Okay, what is wrong with me?"],[7240,7449,"Why do I keep falling for you"],[7540,7703,"even when you destroy me?"]],"42":[[1764,2002,"The kiss, the passion, the thirst,"],[2060,2260,"they all feel so familiar."],[2302,2448,"How could a devil and an angel"],[2448,2573,"share the same face?"],[3403,3570,"Is he the evil who gave me hell,"],[3570,3691,"or the guardian angel"],[3691,3782,"pulling me from it?"],[4767,4892,"All I know is..."],[4892,5117,"I want to belong to him entirely."],[5155,5271,"Only him."],[6181,6314,"Make me yours, Carl."],[6377,6464,"Only yours."]],"43":[[821,905,"I can't believe"],[905,1059,"I gave myself to him again."],[1559,1609,"Esther."],[1726,1843,"Esther, what's wrong?"],[1881,1951,"What's wrong?"],[2031,2093,"Okay, you know what?"],[2093,2218,"I saw the footage."],[2264,2423,"You killed our daughter."],[2581,2777,"I am never gonna believe another word"],[2777,2852,"out of your mouth."],[2852,3028,"Once this IPO is done, we are over."],[3503,3641,"Once everything's settled,"],[3641,3774,"I will tell you the truth."],[4479,4633,"Look, I'll play the part for the press,"],[4633,4850,"but after this is done, we're over."],[5050,5167,"And you can have your shares."]],"44":[[704,930,"Congratulations on the IPO, Mrs. Lewis."],[959,1021,"You've been through"],[1021,1109,"a very difficult year."],[1109,1205,"How are you doing?"],[1234,1355,"There's been a lot of speculations"],[1355,1422,"about your marriage,"],[1422,1559,"about a possible affair."],[1559,1676,"Can you address those rumors?"],[1676,1739,"Of course."],[1868,2118,"I have always been loyal to my wife."],[2173,2285,"And as for our daughter,"],[2494,2606,"we're getting through it together."],[2669,2748,"There have been reports"],[2748,2815,"that the police have"],[2815,2961,"questioned you both recently."],[3003,3140,"Should shareholders be worried?"],[3144,3207,"Of course not."],[3207,3311,"That was just a small accident"],[3311,3453,"and there's nothing to worry about."],[3478,3582,"Oh, really?"],[3691,3887,"An accident?"],[4371,4529,"If you call killing someone"],[4529,4596,"an accident,"],[4596,4679,"then sure."],[4725,4817,"Isn't that right,"],[4817,5138,"Mrs. Lewis and... Carl?"]],"45":[[275,437,"Wait, isn't that Sharon White,"],[479,629,"the woman rumored to be involved"],[629,742,"with Mr. Lewis?"],[754,842,"That's me."],[892,1117,"But Mr. Lewis's biggest crime"],[1117,1226,"isn't cheating."],[1301,1438,"It's covering up murder"],[1480,1659,"for his wife, Esther."],[1972,2085,"This video shows"],[2085,2298,"Mrs. Lewis killing someone"],[2298,2452,"and burying the body."],[2481,2573,"Watch closely."],[2594,2748,"You'll see who's really crazy."],[3199,3390,"Look, I don't care."],[3457,3641,"I just want to know who you belong to."],[3661,3720,"Her?"],[3720,3799,"Or me?"],[3807,4145,"Because this baby still needs a father."],[4187,4287,"Divorce Esther,"],[4312,4396,"be with me,"],[4421,4558,"and I'll forget about that video."],[4729,4854,"You recorded me?"],[4909,4979,"Why not?"],[5096,5259,"You are shameless enough to say it."],[5259,5447,"I am shameless enough to share it."],[5634,5739,"You asshole!"],[5797,5918,"I know you killed Carl!"],[5947,6089,"Yeah, keep up this nonsense."],[6139,6277,"Maybe if you act crazy enough,"],[6277,6389,"you'll get a lighter sentence."],[6539,6619,"What, what do you mean?"],[6619,6806,"Ms. White, you're under arrest"],[6865,6956,"for child endangerment"],[6956,7048,"and embezzlement."],[7286,7369,"This isn't over."],[7403,7503,"You'll pay for what you did,"],[7503,7578,"both of you!"],[7578,7645,"Come with us."],[7795,7974,"Apologies for the interruption."],[8112,8195,"Shall we continue?"],[8291,8412,"I was wrong about him."],[8475,8554,"He's innocent."],[8621,8737,"He's not Carl."],[8842,8996,"He came here to protect me."],[9088,9209,"Then who is he?"],[9263,9442,"And why is he doing all of this?"]],"46":[[925,1017,"Sorry. One second."],[1288,1430,"The fingerprint results are back."],[1597,1689,"They're not the same person."],[2056,2114,"Thanks."],[2152,2214,"Good luck boss."],[2285,2423,"So I wasn't crazy?"],[2506,2665,"He really isn't Carl after all?"],[2723,2844,"Uh, excuse us?"],[2911,3028,"Can I talk to you a second?"],[3453,3532,"Let me guess."],[3611,3745,"You want a divorce."],[3816,3937,"No, I'm not here for that."],[3983,4087,"Oh, so you regret it."],[4112,4212,"You found out I'm clean"],[4212,4312,"and now you want to apologize."],[4312,4371,"How's this?"],[4437,4550,"If you give me a kiss,"],[4571,4654,"I might forgive you."],[4738,4900,"I know you're not Carl."],[5317,5480,"Just tell me the truth."],[5655,5793,"Who are you?"],[5980,6193,"I just cleaned up your entire mess."],[6239,6352,"A thank you would be nice."],[6352,6489,"I'm serious."],[6489,6573,"So am I."],[6614,6664,"What's happening?"],[6756,6835,"Are they okay?"],[6911,7040,"Whoever you say you are,"],[7040,7152,"I will believe you."],[7349,7532,"You, you would?"],[7636,7770,"I believe what I see."],[7899,8087,"And what I see before me is the man"],[8087,8233,"that I am meant to be with."],[8412,8604,"I see somebody who protects me"],[8604,8829,"and, and cares about my happiness."],[9129,9242,"I trust you."],[10201,10306,"Esther, I..."],[10472,10606,"I have to tell you something."],[11398,11432,"Yeah."],[11478,11532,"Hello."],[11778,11840,"Stay there."],[11840,11899,"I'm coming."],[12078,12145,"I gotta go."],[12203,12274,"Don't go anywhere."],[12274,12358,"I'll be right back."],[12545,12579,"Wait."],[15031,15127,"You miss me, Carl?"],[15194,15256,"You're alive."]],"47":[[37,120,"You miss me, Carl?"],[187,254,"You're alive."],[387,467,"What's the matter, brother?"],[467,579,"Looks like you've seen a ghost."],[825,938,"Did you prefer me dead?"],[955,1038,"Honestly, yeah."],[1084,1180,"I do wish you were dead"],[1180,1309,"after what you did to Esther."],[1343,1438,"You fucking deserve it."],[1438,1514,"Oh my God, you are"],[1514,1647,"still the same old Carl."],[1689,1893,"You're always Esther's protector,"],[1893,2006,"her savior."],[2106,2198,"Why don't you tell me something?"],[2252,2335,"How did it feel?"],[2481,2656,"Watching the woman that you love"],[2715,2865,"beg me for mercy."],[2994,3169,"Don't test my fucking limit, Killian."],[3169,3286,"I can kill you right now."],[3286,3420,"Everybody already thinks you're dead."],[3457,3561,"Yeah, go ahead."],[3599,3712,"But before you do that,"],[4049,4162,"why don't you take a look at this?"],[4316,4454,"Remember the family you're from,"],[4508,4575,"brother."],[4658,4729,"Getting a hitman,"],[4729,4867,"oh, that was nothing for me."],[4896,5013,"See these little barrels,"],[5050,5150,"tied to Esther?"],[5305,5422,"If anything happens to me,"],[5442,5580,"you know what's gonna happen to her."],[6006,6076,"That's better."],[6285,6502,"You know you're not gonna last, Carl."],[6656,6865,"You're too soft to pull the trigger."],[6931,7019,"And soft men,"],[7019,7178,"they don't last in the Lewis family."],[7211,7269,"You know that."],[7586,7732,"So enjoy being Carl while you can."],[7753,7791,"Alright?"],[7791,7912,"Beause, I'm gonna"],[7912,8016,"take everything from you."],[8083,8208,"I'm gonna take your name."],[8229,8354,"I'm gonna take your company."],[8375,8546,"I'm gonna take your fucking life."],[8604,8704,"And as for Esther..."],[9234,9371,"Man, you are gonna love"],[9371,9471,"what I have planned for her."]],"48":[[50,100,"Thanks."],[371,450,"Hey, we need to leave,"],[450,517,"it's not safe here."],[517,592,"Come on. - What's going on?"],[600,675,"Hey, no, stop."],[809,880,"I'm not leaving"],[880,1013,"until you tell me what is happening."],[1176,1222,"Fine."],[2248,2606,"Son, I don't have much time."],[2831,2877,"Come-"],[2877,3044,"Ah, ah, ah, ah..."],[3349,3453,"My father's first,"],[3470,3578,"and then I'll explain everything."],[3578,3628,"Come on."],[4154,4208,"Well, let's hope"],[4208,4283,"he doesn't hate you enough"],[4283,4379,"to let you die."],[4642,4700,"You know, Dad,"],[4700,4925,"I used to be the son that you adored."],[5038,5180,"But ever since I died,"],[5338,5501,"you protected that bastard."],[5534,5618,"Yeah, you helped him"],[5618,5759,"cover everything up."],[5780,5834,"So..."],[6110,6243,"Don't blame me"],[6293,6481,"for whatever I'm about to do next."]],"49":[[1322,1405,"Wait here, okay?"],[5718,5843,"Did you really think"],[5901,6031,"that I was coming to save you?"]],"50":[[375,542,"Oh, what's the matter, Dad?"],[558,704,"You finally regret everything"],[704,817,"you did all those years ago?"],[909,1092,"Did you ever imagine that when you died,"],[1092,1184,"it wouldn't be Killian"],[1184,1280,"standing next to you,"],[1280,1472,"but your bastard son standing over you?"],[1914,2035,"Why didn't you go to the police?"],[2156,2331,"It's because you were scared, isn't it?"],[2464,2706,"You thought I actually killed him,"],[2736,2915,"so you were afraid that you'd be next."],[3319,3395,"Carl."],[3887,3978,"You know all those years ago"],[3978,4049,"when you brought me"],[4049,4162,"into that operating room?"],[4195,4329,"I reached out to you."],[4366,4466,"Just like this."],[4621,4867,"You never looked back."],[4909,5038,"To you, I was just..."],[5130,5259,"Killian's backup."],[5317,5409,"Someone to take the fall"],[5409,5572,"so your perfect son wouldn't have to."],[5805,5993,"You're just a bastard."]],"51":[[20,133,"Exactly."],[154,412,"And that is why you carved my face up"],[412,642,"when I was six to look more like him."],[642,821,"And then when I turned 15,"],[821,880,"you sent him"],[880,1055,"to some fancy private school."],[1055,1288,"Meanwhile, everyone called me an orphan"],[1288,1518,"because I couldn't even afford lunch."],[1568,1810,"Then the day that you named him"],[1810,1964,"heir to the family empire,"],[1981,2127,"I became his shadow."],[2202,2502,"I became his shield to any danger"],[2502,2573,"that would come his way"],[2573,2660,"because I had to"],[2660,2794,"fucking take it head on."],[3424,3595,"He was the only one that mattered."],[3611,3828,"I never mattered to you."],[5480,5597,"You want to know the truth?"],[5655,5747,"Go to the study."],[5747,5847,"Everything you're looking for"],[5847,5914,"is in there."]],"52":[[913,1009,"You see that album?"],[1071,1188,"That's my gift to you."],[1267,1326,"Enjoy."],[2944,3086,"Carl had a brother?"],[3557,3607,"Wait."],[3641,3820,"Why are there only photos of Carl?"],[4308,4408,"That's the year I met him."],[4483,4662,"How could he have been in New York?"]],"53":[[279,375,"Dude, stop."],[375,467,"If the teacher catches us,"],[467,525,"we're dead."],[571,642,"Who cares?"],[642,763,"She's not gonna say anything."],[2022,2102,"Who the hell are you?"],[2348,2431,"Get lost!"],[4041,4095,"Hi."],[4191,4283,"I'm Carl."],[4396,4475,"What's your name?"],[4842,5034,"Christmas of '14."],[5267,5388,"Thanksgiving of '15,"],[5388,5563,"Carl was there, but..."],[5584,5672,"He was with me."],[5905,5968,"Who's the guy"],[5968,6085,"in all these pictures then?"],[7490,7636,"What's yours is mine."],[7682,7811,"Your girl belongs to me."],[9438,9584,"Oh, my period's late."],[9617,9793,"Could I be pregnant?"]],"54":[[275,479,"Oh shit, I really am pregnant."],[855,925,"Okay, I don't even know"],[925,1013,"who the father is."],[1067,1259,"Is it... Carl?"],[1755,1889,"But the other Carl..."],[2477,2585,"Okay, okay, okay."],[3094,3203,"This is Esther Lewis."],[3203,3253,"Mrs. Lewis,"],[3253,3407,"we've confirmed the body's identity."],[3561,3641,"Who was it?"],[3757,3862,"Our apologies."],[3945,4099,"The body wasn't Carl Lewis."],[4200,4383,"Please give our regards to Mr. Lewis."],[4800,4942,"Okay, so the body wasn't Carl's."],[4979,5113,"Okay, but then who was it?"],[5171,5259,"Where did he go?"],[5388,5467,"Esther, you in there?"],[5718,5780,"Carl?"],[5930,5993,"What's going on?"],[6727,6810,"You miss me,"],[6998,7090,"my dear wife?"]],"55":[[145,221,"It's you."],[275,354,"You're alive."],[396,471,"Of course I am."],[546,642,"Who else would it be?"],[900,1076,"What's the matter, my darling wife?"],[1163,1343,"Are you disappointed that I'm not dead?"],[2419,2494,"You're pregnant."],[2615,2702,"Is it mine?"],[2740,2836,"Of course it is."],[2882,3011,"It has nothing to do with you."],[3011,3186,"It has everything to do with me!"],[3211,3286,"Because of you,"],[3286,3449,"I can't have kids anymore."],[3511,3632,"So if it's mine,"],[3661,3849,"maybe I'll let it slide."],[3870,4024,"But if it's his, I'll make sure"],[4024,4175,"you lose it like the last one."],[4279,4404,"Oh, you can't have kids?"],[4475,4529,"Good."],[4567,4671,"You deserve that."],[5034,5155,"You watch your mouth, Esther."],[5167,5313,"Don't test me!"]],"56":[[1192,1247,"Hey."],[1280,1330,"Shh."],[2248,2327,"Well, well, well,"],[2327,2464,"look who decided to show up."],[2485,2627,"You remember this place, right?"],[2940,3032,"Carl, what is this?"],[3065,3111,"Hey."],[3144,3340,"I am your husband."],[3340,3499,"How dare you speak to another man"],[3499,3682,"when I'm sitting directly next to you!"],[3849,3933,"You touch her again,"],[3933,4074,"I'll break your fucking hand!"],[4320,4466,"Oh, please don't. Don't hurt him!"],[4466,4567,"Relax."],[4604,4742,"I'm just talking to my family."],[4804,4859,"Right?"],[4934,5055,"Hey, thanks for looking after my wife"],[5055,5117,"while I was gone."],[5213,5271,"But, uh..."],[5359,5476,"I think I'll take her back now."],[5647,5751,"Oh, you have been"],[5751,5876,"dying to know the truth,"],[5876,5972,"haven't you, darling?"],[6081,6197,"Fine, I'll tell you."],[6235,6331,"Maybe..."],[6468,6581,"Maybe I'll let him live."],[6898,6973,"Or, no,"],[6973,7115,"or perhaps he's gone too far."],[7115,7278,"And if I don't kill him,"],[7303,7494,"then he'll replace me soon enough, so..."],[7565,7640,"Replace you?"],[7711,7811,"What are you so afraid of?"],[7903,7953,"Killian, you know,"],[7953,8062,"I'm starting to think"],[8099,8204,"that you were the backup"],[8204,8291,"this entire time."],[8412,8529,"Watch your mouth, brother."],[8621,8783,"I swear to God, if you kill him,"],[8783,8958,"I will die right here."],[9209,9275,"Hey."],[9321,9396,"It's okay."],[9676,9776,"Let's play a game."],[9797,9872,"The winner"],[9968,10060,"leaves alive."],[10289,10460,"Oh, it'll be a fair game, I promise."],[10477,10598,"And you're not in the position"],[10598,10752,"to be bargaining, buddy."],[10844,10935,"If I was you,"],[10981,11173,"I would be begging for my life."],[12433,12525,"You sure about that?"]],"57":[[383,579,"Brother, you know I don't walk"],[579,704,"unprepared into a trap."],[817,946,"Now let's see who's faster."],[992,1055,"Me,"],[1109,1163,"or your men?"],[1551,1618,"Stand down."],[2152,2206,"Fine."],[3299,3407,"Now what kind of game is it?"],[3607,3745,"You wanted to know the truth."],[3828,3878,"Right?"],[3953,4104,"Well in the Lewis family,"],[4104,4233,"the truth always comes with a price,"],[4233,4304,"you know that."],[5138,5213,"Russian roulette."],[5301,5397,"Six chambers."],[5668,5743,"One bullet."],[6143,6222,"We take turns."],[6356,6548,"Before each shot, we ask a question"],[6548,6673,"and we answer truthfully."],[6740,6798,"You in?"],[7240,7328,"You're scared."],[7369,7570,"How pathetic, brother."],[7570,7682,"Especially in front of the woman"],[7682,7778,"that you claim to love."],[7816,7870,"Carl."],[7920,8033,"Carl, please don't do this."],[8091,8145,"It's okay."],[9025,9113,"First question."],[9192,9305,"The body in the morgue."],[9305,9471,"If it wasn't you, then who was it?"],[10005,10060,"No!"]],"58":[[216,308,"First question."],[371,471,"The body in the morgue."],[508,667,"If it wasn't you, then who was it?"],[838,955,"Carl, please don't do this."],[1355,1405,"No!"],[2097,2193,"Hey, it's your turn."],[2260,2323,"Answer."],[2552,2665,"It was just a random guy."],[2811,2932,"But he was wearing your clothes."],[2957,3048,"Yeah, he drove by me"],[3048,3157,"and thought I needed help."],[3186,3299,"So I killed him,"],[3353,3495,"put my clothes on his body,"],[3507,3636,"and I dumped him in the river."],[3795,3916,"You are a monster,"],[3953,4033,"and I should have left you"],[4033,4137,"buried in the yard."],[4245,4295,"You're the one"],[4295,4421,"who buried the body that night?"],[5284,5330,"Yeah."],[5459,5605,"I got rid of everything that night."],[5605,5697,"All the evidence."],[5722,5885,"Even that shattered champagne bottle."],[6197,6268,"I found it in your bag."],[6268,6343,"It had your fingerprints"],[6343,6414,"all over it."],[6414,6510,"But then when I came back,"],[6610,6673,"he was gone."],[7962,8074,"Don't pretend like you did it"],[8074,8158,"out of kindness."],[8179,8208,"Okay?"],[8208,8387,"You only did it to protect Esther."],[8429,8621,"I know that for three months"],[8621,8704,"you tailed me."],[8875,8983,"What was the plan gonna be, Carl?"],[9059,9205,"Are you gonna fucking kill me, huh?"]],"59":[[0,120,"What was the plan gonna be, Carl?"],[191,337,"Are you gonna fucking kill me, huh?"],[392,554,"So after you were rescued,"],[592,696,"you found some poor guy"],[696,800,"and used him to cover up"],[800,880,"your own death?"],[980,1201,"You are still as sharp as ever, brother."],[1201,1422,"It only took you one month, one month,"],[1422,1630,"to steal my company and my wife."],[1964,2410,"So, the baby she's carrying, is it mine?"],[2844,2944,"You know the rules."],[3044,3178,"Truth comes with a price."],[3524,3670,"If he thinks the baby's his,"],[3670,3778,"he might let Carl go."],[3799,4037,"If he knows it's Carl's, he'll kill him."],[4771,5013,"Please, let the bullet end this."],[5030,5230,"Let it tear straight through his head."]],"60":[[183,300,"If he thinks the baby's his,"],[300,421,"he might let Carl go."],[462,717,"If he knows it's Carl's, he'll kill him."],[754,950,"Please, let the bullet end this."],[950,1155,"Let it tear straight through his head."],[2018,2114,"Now you answer me."],[2114,2239,"Whose child is it?"],[2289,2389,"Of course it's mine."],[2723,2848,"Hey, weren't you watching that night?"],[3115,3211,"How do you know?"],[3257,3407,"You always think you're ahead of me,"],[3407,3524,"but you never are."],[3599,3745,"I think Killian is still alive."],[3791,3853,"Now he's gonna come back"],[3853,3978,"for Esther anytime,"],[3978,4141,"so keep this place under surveillance."],[4617,4704,"So it is true."],[4763,4850,"The child's yours?"],[4954,5025,"That is it."],[5059,5146,"No more games."],[5167,5434,"You are gonna die right here, right now!"],[5459,5576,"You are still the same"],[5576,5672,"pathetic coward."],[5672,5784,"You never disappoint me."],[5985,6147,"You shut the fuck up!"]],"61":[[41,221,"You shut the fuck up!"],[2131,2256,"Why do you hate me so much, man?"],[2256,2364,"I was just your shadow."],[2364,2515,"Why wouldn't I fucking hate you?"],[2560,2744,"I have lived under your shadow"],[2744,2940,"my entire fucking life."],[3115,3174,"You were supposed to be"],[3174,3265,"my body double."],[3340,3516,"And now I'm your fucking body double!"],[3611,3912,"The only woman I have ever loved"],[3912,3995,"is Esther."],[4112,4275,"And she never looked at me"],[4275,4412,"the same way that she looks at you."],[4475,4617,"From the moment I met Esther,"],[4617,4729,"it was only her."],[4729,4850,"It was always her."],[5655,5893,"You're just a fucking bastard, Carl."],[5910,6018,"Everything you have,"],[6018,6093,"your clothes,"],[6093,6181,"your education,"],[6181,6306,"all that shit,"],[6352,6473,"is stuff I didn't want!"],[6473,6606,"They're all hand-me-downs!"],[6690,6827,"You know, at first I just wanted to"],[6827,7036,"fucking embarrass you at graduation."],[7073,7203,"And then I found out"],[7203,7286,"that you were gonna"],[7286,7444,"fucking propose to Esther."],[7749,7899,"You were gonna propose to me?"]],"62":[[0,166,"You were gonna propose to me?"],[200,283,"Then why did you leave"],[283,404,"without saying anything?"],[754,950,"Because he got arrested for fighting"],[950,1038,"because of you."],[1138,1334,"So I tracked him down, followed him,"],[1380,1526,"and attacked him from behind."],[1639,1743,"Then I never saw him again,"],[1743,1893,"so I thought he was gone for good."],[1976,2081,"Look, I was lucky, okay?"],[2081,2281,"Someone passing by found me,"],[2281,2373,"and he saved my life."],[2456,2619,"But why didn't you come back to me?"],[2819,2890,"Esther."],[3420,3520,"I lost my sight."],[3557,3595,"Okay?"],[3595,3766,"I knew that you would never"],[3766,3828,"give up on me,"],[3828,3978,"and I didn't want to hold you back."],[4104,4279,"I just recovered like three months ago."],[4316,4350,"Okay?"],[4350,4475,"It was right around the same time"],[4475,4646,"that I saw the news about your daughter"],[4713,4838,"and what your husband"],[4929,5030,"was doing to you."],[5167,5263,"And I knew"],[5263,5405,"that I had to come back for you."],[5705,5772,"Are you getting"],[5772,5860,"second thoughts now?"],[5951,6001,"Huh?"],[6110,6310,"I spent five years"],[6310,6406,"pretending to be the man"],[6406,6648,"that I hated most to make you love me,"],[6648,6752,"and you never did!"],[6760,6986,"You'll never be Carl, asshole."],[6998,7161,"I spent five fucking years"],[7161,7319,"giving you everything I had!"],[7390,7499,"What else do you want from me?"],[7499,7607,"You're not him!"],[7653,7807,"You are a monster!"],[7807,8003,"No one is ever gonna love you!"],[8266,8358,"Kill him now!"],[9017,9084,"You wanna see"],[9125,9275,"what a real monster looks like?"],[9463,9672,"How about I take your wife"],[9672,9772,"right in front of you?"],[9826,9964,"Give you a little farewell present"],[9964,10051,"before you die."],[10051,10214,"No, you stay away from me!"]],"63":[[120,262,"No, you stay away from me!"],[1664,1839,"I'm afraid you've lost again, Killian."],[1881,1993,"But I'm not surprised."],[2181,2256,"Then shoot me."],[2364,2489,"I'm the only one who has the keys"],[2489,2606,"to this place anyways."],[2606,2731,"You might have spent 18 years"],[2731,2790,"down here."],[2790,2969,"But I studied every detail"],[2969,3040,"of this place!"],[3040,3236,"Every detail of your life"],[3236,3370,"to pretend to be you!"],[3507,3599,"I'm afraid I'll have to"],[3599,3749,"disappoint you again, Killian."],[4546,4592,"Dad..."],[4671,4721,"Dad?"]],"64":[[321,371,"Dad..."],[446,504,"Dad?"],[675,759,"You thought"],[813,996,"I would kill my dad out of hate?"],[1080,1197,"Why wouldn't you?"],[1226,1359,"He used Mom's love"],[1359,1501,"to make a clone of me"],[1501,1609,"and left her bleeding out"],[1609,1722,"in the delivery room!"],[1943,2118,"While I was out living my life,"],[2181,2318,"he kept you locked in here"],[2318,2460,"like a fucking animal."],[2861,3082,"God, you've always been way too soft."],[3136,3203,"Killian..."],[3278,3353,"Stop."],[3482,3682,"You can't win this."],[3741,3903,"Why are you even defending him, Dad?"],[3903,4074,"He's a fucking bastard!"],[4091,4212,"Is that really all I am to you?"]],"65":[[8,158,"Why are you even defending him, Dad?"],[158,321,"He's a fucking bastard!"],[321,458,"Is that really all I am to you?"],[629,788,"While you were out messing around"],[788,846,"all those years,"],[846,992,"I was busy building a company."],[1109,1205,"How do you think Esther's company"],[1205,1276,"went public?"],[1580,1743,"Lagos Chase and Co, that was you?"],[1743,1843,"What do you think?"],[1864,1943,"I was the one"],[1972,2072,"paying for Dad's treatment"],[2072,2181,"that entire time."],[2181,2281,"You were too busy"],[2281,2385,"screwing your assistant"],[2385,2610,"and assaulting your wife to even notice!"],[2610,2756,"Why was it always"],[2756,2902,"so fucking easy for you"],[2902,3065,"to get everything that I never could?"],[3649,3703,"There's only room"],[3703,3791,"for one of us, brother."],[4312,4396,"No!"],[4441,4533,"Ow!"],[4633,4700,"Dad, Dad."],[4775,4888,"No, no, no, no, no."],[5201,5330,"No, no."],[5451,5501,"Carl..."],[5622,5701,"I'm sorry."],[5793,5851,"I..."],[5880,6031,"I used your mother's love"],[6031,6147,"for my own gain."],[6189,6264,"I'm sorry."],[6377,6664,"Maybe this is my way of making it right."]],"66":[[734,896,"Why can't I ever fucking beat you?"],[1659,1755,"Killian Lewis."],[1793,1889,"You're under arrest"],[1947,2131,"for assault, child neglect,"],[2131,2239,"and kidnapping."],[2681,2786,"Hey, I got a man down."],[2786,2927,"Let's get a stretcher out here ASAP."],[3019,3136,"You called the fucking cops?"],[3203,3328,"You knew this would happen."],[3357,3449,"I already told you."],[3524,3732,"I can predict every move you make."],[3912,4037,"This isn't fucking over!"],[4070,4225,"You hear me? This isn't fucking over!"],[4471,4517,"Hey."],[4604,4650,"It's you."],[4650,4713,"It's really you."],[5860,5955,"Oh my God."],[6101,6177,"Does it hurt?"],[6293,6343,"No."],[6343,6410,"Okay."],[6493,6589,"Let's just go home."],[6664,6760,"I can take care of it."]],"67":[[567,642,"Does it hurt?"],[784,842,"No."],[1368,1447,"All I feel"],[1622,1680,"is you."],[2469,2548,"That touch,"],[2569,2731,"I've missed it so much."],[2756,2882,"No one else has ever"],[2882,3007,"made me feel like this."],[3053,3128,"Only him."],[3749,3824,"Close your eyes."],[4116,4191,"Feel me."],[4266,4479,"You know that this is me."],[5217,5280,"Yes."],[5384,5505,"I know it's you, Carl."],[5701,5847,"And I won't get it wrong again."]],"68":[[175,429,"After reviewing all testimony"],[429,529,"and evidence,"],[529,825,"this court finds that Esther Lewis"],[1126,1309,"acted in self-defense."],[1539,1730,"Therefore, she is acquitted."],[1822,1918,"No sentence."],[2990,3153,"As for the co-defendant,"],[3153,3265,"Killian Lewis,"],[3328,3415,"for the charge of"],[3415,3674,"premeditated murder of Amy Lewis,"],[3791,3941,"you are found..."],[4095,4183,"guilty"],[4183,4325,"and sentenced to death."],[4829,5000,"And Sharon White,"],[5000,5226,"30 years in federal prison."],[7027,7186,"It's finally over."]],"69":[[325,421,"Hey, birthday girl."],[650,742,"Hi, Carl."],[934,1088,"It's me, the real Carl."],[1284,1393,"After all these years,"],[1393,1509,"you're still the only person"],[1509,1572,"that remembers"],[1572,1697,"I love strawberry cake."],[1876,1972,"Why don't you take a bite?"],[2602,2681,"I've always wished"],[2681,2815,"I could find my wedding ring in it"],[2815,2882,"one day."],[3407,3453,"What's wrong?"],[3453,3528,"You don't like it?"],[4362,4567,"You remembered my silly little wish."],[5255,5313,"Esther,"],[5743,5830,"will you marry me?"],[7611,7845,"I love you so much."],[8888,9079,"Wait, wait, be careful, our baby."],[9104,9159,"Hey."],[9225,9321,"Don't you worry."],[13526,13617,"I told you, brother."],[13676,13763,"This isn't over."]]}