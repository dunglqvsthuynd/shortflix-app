,[8153,8295,"Daniel the doormat."],[8304,8445,"Daniel the doormat."],[8462,8587,"Enough! - Daniel the..."],[8587,8721,"You little shit!"]],"40":[[0,87,"Enough!"],[87,208,"Just enough!"],[254,337,"Sabrina?"],[379,492,"What's gotten into you?"],[550,667,"Don't tell me you are actually"],[667,813,"heartbroken over that man."],[875,934,"Whoa,"],[942,1142,"what's, what's going on in here?"],[1142,1288,"This room feels really tense."],[1301,1505,"Mom just yelled at me for no reason."],[1522,1668,"I was just making fun of Daniel."],[1676,1726,"No."],[1772,1864,"I yelled at you because"],[1864,2010,"you’re making fun of your father."],[2039,2189,"And if you keep talking like that,"],[2189,2327,"I'm going to put you in a time-out."],[2356,2506,"It's time that you stop acting"],[2506,2690,"like a spoiled little brat!"],[3040,3090,"Babe,"],[3153,3261,"are you really going to get mad"],[3261,3370,"at Jaxon? For what?"],[3370,3524,"Making fun of that fucking loser?"],[3545,3599,"Really?"],[3603,3666,"Loser?"],[3682,3745,"Yeah."],[3757,3883,"You haven't had a job"],[3883,4054,"in over a year, Preston."],[4091,4254,"And you've been mooching off of me"],[4270,4416,"and ordering my staff around"],[4416,4567,"like you're their boss."]],"41":[[166,300,"That's really, really low."],[346,533,"Especially after everything I've done"],[533,642,"to help you with your brand."],[642,759,"I've been keeping it from collapsing"],[759,834,"in the last year."],[896,946,"Come on, we’re,"],[946,1080,"we're America's Power Couple."],[1080,1209,"To be a power couple,"],[1209,1363,"you both have to have power."],[1418,1518,"Face it, Preston."],[1564,1714,"You're using me to hide the fact"],[1714,1839,"that you're washed up."],[1868,2097,"And, you're a fucking thief!"],[2131,2289,"Yeah, I know you're bankrupt."],[2289,2431,"You've been stealing from me"],[2431,2531,"all year long."],[2565,2711,"I could have you arrested,"],[2736,2815,"but I haven't."],[2844,2927,"Because you know what?"],[2957,3098,"Honestly, I pity you."],[3115,3219,"It's not like that."],[3261,3465,"Okay? Look, I was just merging things"],[3465,3578,"like couples do."],[3632,3824,"I want to marry you. We're, we're a legacy."],[3824,3978,"Hollywood fucking royalty."],[3978,4083,"When's my birthday?"],[4158,4204,"Huh?"],[4229,4421,"And what kind of flowers do I like?"],[4421,4542,"What's my favorite color?"],[4542,4650,"My favorite song?"],[4671,4792,"Oh, what's my favorite"],[4792,4892,"goddamn movie?"],[4925,5013,"Oh, oh wait."],[5042,5234,"What's my fucking middle name?"],[5255,5501,"You don't give a shit about me."],[5530,5618,"You don't love me."],[5618,5776,"You don't even know me!"],[5814,5997,"This isn't a relationship."],[6006,6239,"This is a publicity stunt!"],[6272,6343,"And you know what?"],[6364,6452,"I'm done!"],[6485,6573,"Get out!"],[6606,6790,"I don't want to ever see you again."],[6823,6906,"We're over."]],"42":[[0,83,"We're over."],[108,196,"What, no, babe, babe,"],[196,237,"come on."],[237,283,"Please."],[312,392,"Please, I love you."],[392,417,"Just,"],[442,554,"just think about it."],[588,642,"Think of the press,"],[642,763,"what this will look like."],[804,963,"If I have to call my security,"],[1001,1209,"all of this will get a lot uglier."],[1209,1297,"Get out"],[1359,1426,"now!"],[1476,1572,"Just give me your hand, come on."],[1572,1622,"No."],[1710,1872,"I'm so alone, Daniel."],[2031,2164,"Nobody sees the real me."],[2164,2285,"I see you, Sabrina."],[2385,2506,"I see all of you."],[2615,2669,"And you're never going to"],[2669,2756,"be alone again."],[2907,3132,"He truly knew me,"],[3236,3357,"he loved me."],[3440,3553,"Every flaw,"],[3586,3707,"every fear."],[3753,3878,"Contract or not,"],[3928,4145,"he truly loved me."],[4145,4362,"I saved you from social suicide."],[4362,4454,"Saved me?"],[4529,4671,"You don't even know how ironic"],[4671,4750,"that is."],[4808,4871,"Daniel"],[4871,5000,"saved me from the ledge."],[5000,5230,"And he saved me from you."],[5326,5447,"Security!"]],"43":[[66,162,"Security!"],[171,316,"Come on, just, let's talk about this."],[329,387,"No."],[471,504,"God,"],[525,583,"Celeste,"],[588,688,"do something!"],[721,809,"Sabrina!"],[867,988,"Come on, Sabrina!"],[1055,1238,"Was that really necessary?"],[1255,1447,"I mean, he still is a Hollywood A-lister"],[1472,1634,"and People's Sexiest Man Alive."],[1634,1776,"Is that all you care about?"],[1822,2018,"The fame, the headlines,"],[2018,2127,"the brand deals?"],[2168,2243,"God!"],[2289,2506,"You're supposed to be my mother first,"],[2506,2569,"not some"],[2569,2744,"money-grubbing manager."],[2744,2973,"Sabrina, you are being dramatic."],[3028,3236,"Of course I care about you."],[3303,3395,"I love you."],[3461,3557,"Then prove it."],[3611,3712,"If you ever want me"],[3712,3824,"in front of a camera again,"],[3824,4041,"then you will help me get Daniel back."]],"44":[[713,850,"You'll have to forgive me, Mr. Lee."],[850,900,"I'm..."],[963,1105,"kind of in shock right now."],[1130,1217,"In film school,"],[1267,1463,"we were literally told to watch every single"],[1463,1605,"film that you ever produced."],[1664,1785,"I mean, you know this."],[1810,1881,"You're a legend."],[1943,2056,"Appreciate it, Daniel."],[2097,2227,"Alright, let me cut to the chase."],[2243,2373,"You're a powerhouse sitting idle"],[2373,2489,"in the wrong country."],[2506,2598,"I appreciate the compliment,"],[2598,2702,"but I mean, I'm doing alright."],[2702,2865,"I got projects- - Come on."],[2882,2932,"You're built for"],[2932,3103,"billion-dollar franchises,"],[3103,3219,"Hollywood blockbusters."],[3240,3365,"The one that gets made in LA,"],[3365,3461,"not London."],[3461,3595,"That's where you belong."],[3712,3862,"To be honest, I already did LA."],[3937,4054,"It didn't really end well."],[4074,4154,"Let me guess,"],[4170,4233,"a girl?"],[4275,4479,"If by a girl, he means"],[4479,4604,"Hollywood royalty,"],[4604,4742,"Sabrina Donovan."],[4792,4938,"You don't walk away from a gift like yours"],[4938,5071,"over some heartbreak."],[5092,5246,"You can become a household name,"],[5259,5417,"and I can get you there."],[5488,5618,"You're giving me a lot to think about."],[5618,5697,"Three-picture deal."],[5743,5910,"Two hundred million dollar budget each."],[5910,6106,"Creative control and final cut approval."],[6143,6243,"I don't know what to say."],[6243,6348,"Just say yes."],[6348,6448,"You have my number."],[6510,6619,"Just don't keep me waiting."],[6748,6861,"Just remember, Daniel,"],[6861,6998,"you can't run away from the past."],[7027,7240,"You have to face it and tell it to fuck off."],[8370,8608,"Hey, it's been a while."],[8654,8762,"Can we talk?"]],"45":[[0,120,"Daniel, can you give us a hint"],[120,241,"about your first movie"],[241,371,"with Crazy Maple Studio?"],[383,433,"Of course."],[433,554,"Uh, it's about a man"],[554,688,"who gets fucked over by America's"],[688,925,"sweetheart and comes out on top."],[938,1113,"Is this a personal story?"],[1138,1222,"Will we get a hint"],[1222,1447,"at who the mystery woman is?"],[1447,1559,"Oh..."],[1735,1847,"She knows who she is."],[1864,1918,"Um,"],[1985,2068,"I'll leave it at that."],[2335,2523,"You arrogant little shit!"],[2594,2652,"I told you,"],[2652,2752,"if you ever set foot"],[2752,2865,"in this fucking country,"],[2865,2998,"I would unleash a world of hell."],[3511,3636,"It's Celeste Donovan."],[3661,3753,"I need a favor."],[3782,3874,"I need you to track down"],[3874,3987,"Daniel Johnson to find out where"],[3987,4124,"he'll be around eight o'clock tonight."],[4204,4325,"Thank you."],[4387,4537,"It's time for a little reunion"],[4537,4725,"with Hollywood's newest hot shot."],[4829,5009,"Mom, what are you doing?"]],"46":[[120,196,"Did you just break"],[196,308,"my TV?"],[346,467,"Can you give us a name for your"],[467,592,"upcoming film?"],[675,796,"You know I'm not supposed to do that."],[850,971,"You've been so kind though, um,"],[996,1076,"it's called..."],[1109,1255,"You Drive Me Crazy."],[1484,1568,"He's back."],[1705,1830,"Why didn't you tell me?"],[1897,1968,"Honey,"],[1993,2164,"I don't want you spiraling again."],[2164,2256,"I'm not a fragile"],[2256,2389,"little girl anymore."],[2452,2594,"I need to get on that movie."],[2594,2736,"Absolutely not."],[2781,2836,"You're not working"],[2836,2936,"for your ex-husband."],[2936,3082,"If you don't get me an audition,"],[3082,3190,"then I will get a manager"],[3190,3257,"who will."],[3269,3486,"Honey, I'm just looking out for you."],[3503,3682,"He still loves me."],[3807,3928,"He has to."],[4024,4087,"I just need to"],[4087,4191,"talk to him."],[4225,4425,"Let him go."]],"47":[[0,79,"Mom?"],[200,258,"Honey, I..."],[425,554,"You know I just want"],[554,721,"what's best for you, right?"],[738,838,"I just don't want to see"],[838,984,"my little girl hurt again."],[1184,1284,"I love you."],[1393,1488,"I love you too."],[1993,2097,"Oh, this is, umm,"],[2160,2264,"it's another movie deal."],[2264,2427,"I'll, I'll tell you about it after."],[2469,2540,"Okay."],[3958,4058,"Did you get his location?"],[4154,4266,"The Oaks,"],[4266,4362,"8:00 P.M."],[4462,4604,"After I'm done with him,"],[4604,4758,"Daniel Johnson won't just be"],[4758,4896,"blacklisted by Hollywood."],[4929,5188,"He'll be erased from Sabrina's life forever."],[6064,6210,"She's not protecting me."],[6264,6414,"She's protecting her business."],[6443,6594,"And I'm just a pawn."],[6656,6810,"But if she wants a scandal,"],[6810,6906,"she'll get one."]],"48":[[0,187,"So nice having you back."],[258,412,"And I don't just mean from the UK."],[437,575,"Yeah, it's been a rough couple years,"],[575,638,"hasn’t it?"],[654,729,"Couple?"],[821,996,"Daniel, it was ten years of you"],[996,1184,"slaving away for those people."],[1184,1334,"If you can even call them that."],[1334,1451,"But you're healthy now."],[1451,1576,"And I'm at the top of my career."],[1664,1714,"I mean, yeah,"],[1714,1976,"there was a time that I loved Sabrina, but"],[2002,2147,"I really thought I could make it work."],[2185,2339,"The marriage, the kids."],[2394,2485,"I mean, we really tried."],[2535,2673,"I thought I could make a go for it, but"],[2673,2727,"umm..."],[2927,2986,"It's over."],[3053,3103,"It's over."],[3148,3336,"I mean, let her chase whatever fantasy"],[3336,3536,"she thinks Preston Eastwood can offer."],[4291,4354,"Oh."],[4404,4475,"You haven't heard?"],[4625,4708,"She dumped him."],[4754,4900,"It was all over People Magazine."],[4929,5100,"She ended it when his star faded."],[5309,5455,"My God, what?"],[6001,6076,"Daniel!"]],"49":[[116,187,"Stop!"],[938,1071,"Sabrina, what are you doing here?"],[1130,1238,"I'm here to help you."],[1313,1397,"Sabrina,"],[1468,1564,"you're making a scene."],[1564,1659,"Let's go home."],[1689,1730,"Sabrina?"],[1730,1851,"How could you? - What?"],[1851,2052,"I, I just came to ask Daniel"],[2052,2152,"if he'd let you audition,"],[2152,2260,"but he said no."],[2289,2444,"I begged and pleaded."],[2444,2569,"Stop lying!"],[2606,2798,"I saw you bribe the waiter"],[2798,2957,"to drug Daniel's drink."],[3019,3228,"And I'll bet you called the paparazzi too"],[3228,3424,"to catch him drugged out of his mind"],[3424,3536,"and ruin him."],[3557,3641,"Oh my God."],[3674,3774,"You're disgusting."],[3774,3949,"I'm a manager, Daniel."],[3949,4041,"Not anymore."],[4116,4254,"When did you become such a"],[4283,4537,"conniving, scheming snake?"],[4550,4637,"I don't even know"],[4637,4804,"who you are anymore."],[4909,5025,"I'm your mother."],[5105,5321,"I only want what's best for you."],[5351,5497,"What's best for me?"],[5718,5860,"You've been controlling my life"],[5860,5972,"ever since you knew you could"],[5972,6106,"profit from it."],[6185,6385,"That all ends today."],[6648,6706,"You're fired."]],"50":[[0,79,"You're fired."],[200,258,"No."],[475,529,"No."],[930,984,"No."],[1117,1217,"You can't do this to me."],[1217,1359,"Please, please, sweetie,"],[1359,1530,"I have dedicated my life to you."],[1530,1722,"You dedicated your life to money"],[1764,1889,"and to fame."],[2043,2248,"I was just who you used to get to it."],[2264,2402,"You think you can survive"],[2402,2560,"on sheer talent?"],[2560,2727,"There's a thousand girls more talented"],[2727,2894,"than you waiting for their shot."],[2911,3023,"I made you!"],[3053,3207,"You'd be nothing without me!"],[3528,3699,"I think she'll do just fine."],[4304,4412,"We're done here, Mom."],[4542,4646,"If you want any chance"],[4646,4800,"to be in Jaxon's life"],[4838,4934,"or in mine,"],[5030,5134,"you'll leave now."],[5251,5359,"Without another word."],[6398,6539,"I have something to say."]],"51":[[95,271,"I'm sorry, Daniel."],[337,513,"I'm sorry I took you for granted"],[529,629,"all of those years."],[650,829,"I'm sorry I let my mom"],[867,1084,"manipulate and use you."],[1130,1355,"I'm sorry I brought Preston"],[1355,1455,"into our home"],[1455,1743,"and poisoned our son towards you."],[1985,2122,"Apologize to your father."],[2206,2318,"Do I have to?"],[2377,2552,"Who raised you?"],[2627,2761,"Cared for you?"],[2894,3140,"Packed your lunches when I was on set?"],[3219,3390,"Laid with you when you had nightmares?"],[3390,3566,"And coddled you when you were sick?"],[3620,3695,"He did."],[3766,3874,"He loved you."],[3895,4070,"But you treated him like he was nothing."],[4087,4175,"I was wrong."],[4241,4295,"Jaxon,"],[4354,4558,"he gave us ten years of his life"],[4558,4675,"and we abused it."],[4758,4988,"And now there is nothing we can do"],[4988,5075,"to take that back."],[5196,5288,"I'm sorry, Dad."],[5622,5714,"It's going be okay, son."],[5789,5864,"I still love you."],[5955,6001,"Okay."],[6081,6222,"Come on, Jaxon. Let's go."],[6869,6981,"I'm sorry, Daniel."],[7140,7236,"For everything."]],"52":[[462,529,"I know that"],[529,625,"look, Daniel."],[658,738,"You're thinking of"],[738,859,"going back to them."],[1138,1192,"I just didn't know"],[1192,1284,"it would be this hard."],[1317,1430,"They hurt you,"],[1463,1543,"Daniel."],[1639,1797,"They tore you to pieces"],[1797,1947,"and then just expected you"],[1947,2072,"to come running back."],[2306,2427,"People can change,"],[2577,2681,"but that doesn't change"],[2681,2773,"the past."],[3140,3274,"And the Oscar goes to..."],[3328,3420,"Daniel Johnson,"],[3420,3549,"for his original screenplay,"],[3586,3657,"Loving Her."],[3837,3870,"Daniel!"],[3899,3933,"Daniel!"],[3995,4029,"Daniel!"],[4066,4120,"Talk to us!"],[4120,4187,"Here Daniel!"],[4187,4350,"Daniel is true that the script"],[4350,4416,"that won you Oscars"],[4416,4554,"for both writing and directing,"],[4554,4742,"sat on shelf for ten years?"],[4758,4821,"Yes."],[4854,4900,"I'll admit,"],[4900,5050,"I got a little sidelined, but, um,"],[5142,5280,"I think I found my way back."],[5388,5430,"But,"],[5438,5572,"okay, I'll tell you this."],[5584,5634,"Um."],[5768,5818,"I don't think"],[5818,6018,"you can truly love someone else"],[6060,6143,"until..."],[6272,6393,"you love yourself."],[6723,6831,"Way to go, Dad!"],[8587,8679,"Thank you so much for"],[8679,8808,"considering me for this part."],[8863,8913,"Thank you."],[8933,9021,"We'll keep in touch."],[9684,9801,"How many more do we have today?"],[9801,9914,"Forty, sir."],[9914,9976,"Jesus."],[9993,10080,"Danny-boy,"],[10110,10206,"how we looking?"],[10239,10331,"Still digging."],[10352,10422,"Um,"],[10447,10589,"no one's cracked the lead yet."],[10731,10852,"I mean, this film"],[10852,11023,"lives or dies with a female lead."],[11052,11140,"All right, here's the deal."],[11165,11265,"The studio's on my ass,"],[11265,11448,"looking to lock in the lead today."],[11553,11636,"Today?"],[11669,11790,"Are you fucking kidding me?"],[11790,11903,"That's why I love you, man,"],[11903,12024,"cool under pressure."],[12057,12216,"This movie is going to blow"],[12216,12345,"the roof off."],[12654,12737,"Oh my God, alright, just"],[12737,12867,"bring in the next one."],[12946,13063,"That would be,"],[13146,13267,"Emily Blake."],[13517,13596,"Emily."]],"53":[[179,287,"That was amazing, seriously."],[346,400,"Emily,"],[471,558,"amazing as always."],[725,834,"You flew in all the way from"],[834,925,"London for this?"],[975,1051,"Please."],[1109,1201,"I wasn't going to miss a shot"],[1201,1292,"to audition for the great"],[1292,1405,"Daniel Johnson."],[1551,1689,"How's LA treating you?"],[1718,1797,"Oh my God."],[1839,2052,"Less tea, but way more traffic."],[2122,2181,"But I am..."],[2327,2423,"I'm glad to be back."],[2456,2615,"Well, it's no English countryside."],[2631,2681,"Yeah."],[2681,2877,"But it suits you."],[3044,3161,"You definitely belong here."],[3253,3315,"Thank you."],[3449,3553,"I do miss you, though."],[3641,3720,"It was fun,"],[3774,3853,"playing the part."],[3928,4012,"British starlet,"],[4074,4162,"American director."],[4320,4412,"I kept waiting for us"],[4412,4562,"to become something real."]],"54":[[0,83,"Waiting for us"],[83,204,"to become something real."],[262,367,"I'm sorry, Emily."],[521,734,"Just cast me and we'll call it even."],[809,1046,"You, you were amazing, as always."],[1096,1188,"It's just,"],[1376,1543,"it's just not quite what I'm looking for."],[1701,1830,"I never was, was I?"],[1935,2014,"Anyways,"],[2102,2193,"got a few more auditions"],[2193,2268,"while I'm in town."],[2402,2494,"Maybe I'll see you around?"],[2585,2623,"Yeah."],[3812,3953,"Get me a coffee and you know what?"],[3953,4091,"Go get one for yourself, too."],[4291,4433,"And be generous with the sugar!"],[5009,5084,"Oh my God."],[5146,5246,"What am I gonna do?"],[5880,5989,"That was quick."],[6936,7036,"What are you doing here?"],[7244,7357,"I came to audition."]],"55":[[50,171,"Did you pick any representation?"],[187,250,"No."],[358,538,"I fired my manager, remember?"],[650,800,"I'm starting fresh."],[829,955,"Right, um..."],[1188,1259,"Hi."],[1355,1476,"I'm Sabrina Donovan."],[1801,1914,"Don't let me go!"],[1914,1976,"I got you."],[2039,2135,"I'll never let you go."],[2414,2498,"Are you okay?"],[2519,2560,"Yeah."],[2577,2694,"It's an old wound, that um..."],[2873,2965,"never really healed."],[3190,3299,"I understand."],[3641,3724,"Daniel Johnson."],[3949,4054,"Nice to meet you."],[4287,4341,"Please."],[5150,5246,"Whenever you're ready."]]}