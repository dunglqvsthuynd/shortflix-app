permission."],[1484,1568,"There is an Uber"],[1568,1718,"waiting for you outside"],[1718,1843,"to take you to the airport."],[1947,2031,"Get out of Hollywood."],[2118,2339,"In fact, get out of the country."],[2431,2623,"If I so much as see your name"],[2623,2731,"next to my daughter's"],[2731,2815,"in a tabloid,"],[2857,3057,"I will make your life a living hell."],[4458,4625,"Don't worry about it, just drive."],[5922,6131,"I used to ache for her approval."],[6222,6348,"Now I just want to breathe"],[6348,6464,"without her shadow."]],"26":[[58,125,"Seriously?"],[208,275,"Just lay down."],[308,446,"I know, why’d he do..."],[579,746,"I'm going to go call the doctor, okay?"],[1013,1092,"What are you doing?"],[1092,1197,"I thought you were hurt."],[1242,1343,"I think I'll pull through."],[2052,2173,"Preston, what are you doing?"],[2202,2352,"What I've always wanted to."],[2435,2594,"Come on, I know you want this."],[2594,2756,"I see the way you look at me."],[2798,2915,"Now that Daniel's gone,"],[2973,3098,"we have the house to ourselves."],[3161,3440,"I can finally have you in this bedroom."],[4400,4491,"What am I doing?"],[4558,4696,"Daniel is still injured."],[4767,4850,"He should be home."],[5146,5205,"Sabrina?"]],"27":[[796,859,"Preston,"],[921,975,"get off."],[1055,1092,"What?"],[1138,1322,"Babe, we can finally, come on."],[1322,1455,"I said get off!"],[1509,1551,"What?"],[1555,1705,"I need to go take care of Daniel."],[1705,1868,"No, forget about him."],[1881,1943,"Look,"],[2006,2143,"I love Jaxon"],[2143,2252,"and I'm ready to be the man"],[2252,2344,"that you've always wanted."],[2435,2590,"I'm ready to be a dad"],[2627,2715,"to that little boy."],[2769,2861,"I mean, come on."],[2865,3086,"Sabrina, your son, your mother,"],[3140,3319,"even Daniel is pushing us together."],[3365,3424,"What?"],[3520,3586,"Look,"],[3620,3749,"he's already moved on."],[3870,3933,"No."],[4020,4087,"No."],[4145,4241,"What have I done?"],[4325,4416,"Where is he?"],[4446,4550,"What about me?"],[4571,4804,"You had your chance ten years ago."],[4871,5055,"I need to go take care of my husband."]],"28":[[66,141,"Hello?"],[183,254,"Excuse me."],[325,408,"Excuse me."],[446,625,"Hi, have you seen my husband?"],[729,921,"Please, he was the one bleeding out."],[946,1076,"I saw him stumble outside"],[1076,1146,"holding his head"],[1146,1326,"after he spoke to some older woman."],[1326,1459,"He didn't come back in, though."],[1714,1818,"Oh no."],[1885,2043,"Come on, Daniel, where are you?"],[2106,2252,"I’m sorry, but the number you are"],[2252,2452,"trying to reach is no longer in service."],[2506,2652,"Please try again later."],[2740,2831,"What have I done?"],[3891,4137,"Come on, Daniel, answer me."],[4717,4850,"He's not gone."],[4879,5100,"I know Daniel wouldn't leave me."],[5905,6164,"He loves me too much to abandon me"],[6164,6289,"when I need him the most."],[6352,6410,"No."],[6685,6815,"It's not possible."],[6873,7019,"He will be back."],[7203,7269,"No."]],"29":[[337,454,"Voids all assets."],[546,729,"Claims zero custody over Jaxon."],[792,980,"Waives all spousal support."],[1092,1284,"No, no, he can't leave me."],[1351,1476,"He can't do this to me."],[1509,1639,"I won't sign off on it."],[2581,2635,"No."],[2777,2852,"All this time,"],[2965,3119,"he was going to leave me?"]],"30":[[62,179,"It can't be."],[425,471,"it's not a-"],[479,613,"Honestly, it doesn't matter."],[613,775,"My mom will look it over anyways."],[859,971,"He loves me."],[1055,1238,"He loves Jaxon."],[1292,1447,"He wouldn't just leave us."],[1447,1568,"We're his family."],[1647,1793,"After all these years,"],[1793,1951,"everything we've been through?"],[4179,4266,"I got you."],[4300,4483,"Don't let me go!"],[4529,4754,"Was I ever really paying attention?"],[5150,5230,"Daniel."],[5280,5376,"No, it's Mom."],[5376,5492,"Is everything okay?"],[5492,5613,"You sound panicked. - Mom."],[5814,5930,"Mom."],[5968,6081,"Daniel,"],[6114,6260,"he just left us."],[6410,6531,"Do you know where he is?"],[6635,6731,"We have to find him."],[6731,6890,"We can check the hospital or the..."],[6952,7094,"Oh, honey,"],[7127,7223,"it's over."],[7257,7407,"Daniel's not coming back."],[7490,7570,"You knew?"],[7632,7753,"I'll come over in the morning"],[7753,7878,"and explain everything."]],"31":[[638,771,"I'm hungry!"],[846,1001,"Dad, breakfast should be"],[1001,1117,"ready by now!"],[1230,1313,"Jaxon,"],[1547,1680,"I have something to tell you."],[1897,1956,"Your dad,"],[2193,2260,"your dad,"],[2410,2494,"he's left us."],[2627,2798,"I'm sorry, but he's not coming back."],[2844,3028,"Yay, he's gone, he's gone!"],[3165,3261,"Why would you say that?"],[3311,3432,"He was so embarrassing."],[3453,3578,"Even Mr. Eastwood-"],[3578,3699,"Mr. Eastwood?"],[3812,3928,"What did Preston say?"],[3958,4149,"He said a pathetic pussy like that"],[4170,4346,"should stick to scrubbing toilets"],[4362,4483,"than raising a young man."]],"32":[[8,175,"He was so lame and boring."],[221,333,"Now he's gone."],[375,583,"Mr. Eastwood is way cooler."],[613,738,"He can be my new dad."],[775,834,"Jaxon,"],[909,1021,"you have a dad"],[1021,1263,"and he's cared for you for seven years."],[1292,1438,"Yeah, but I hate him!"],[2114,2181,"Hello?"],[2235,2356,"Do you have any news about Daniel?"],[2377,2565,"Mrs. Donovan, it's your accountant."],[2585,2769,"I noticed a few unusual transfers."],[2819,2936,"I'm sorry, I don't have the time."],[2957,3140,"Large sums have been wired to"],[3140,3328,"someone named Preston Eastwood,"],[3328,3507,"was that done with your approval?"],[3507,3549,"No."],[3578,3695,"But I'm not surprised."],[3762,3849,"Flag his name."],[3903,4041,"I want him frozen and cut off."],[4279,4333,"Jaxon,"],[4371,4475,"I don't want to ever hear you"],[4475,4596,"say Preston's name again."],[4658,4704,"Okay?"],[4763,4917,"He's not the man you think he is."],[4963,5130,"Your father, the one who raised you"],[5130,5309,"and cared about you, is out there."],[5330,5538,"And we need to find him at all costs."]],"33":[[37,141,"What kind of a coward"],[141,296,"abandons his family?"],[371,487,"It's despicable."],[521,688,"I can't do this anymore."],[796,925,"Cancel everything."],[975,1172,"The interviews and the red carpets."],[1234,1380,"I don't want to be seen."],[1438,1568,"I can't pretend."],[1655,1822,"I just want him back."],[1830,1960,"Oh, honey."],[2027,2193,"It's time to let him go."],[2268,2431,"You don't love him anyway."],[2540,2690,"Think about what Preston would do"],[2690,2777,"for your career."],[3090,3157,"What?"],[3190,3403,"How could you say something like that?"],[3428,3582,"Of course I love Daniel."],[3682,3895,"He cares for me, he sees me,"],[3895,4124,"he was there for me when Preston"],[4124,4295,"dropped me like I was nothing."],[4337,4579,"But Daniel is a pathetic nobody."],[4700,4846,"Daniel's my husband,"],[4875,5013,"and the father of my son."],[5042,5146,"Yeah, some husband."],[5180,5251,"Abandoning you"],[5251,5363,"without a moment's notice,"],[5363,5492,"wanting nothing to do with his child"],[5492,5626,"just because a contract ended?"],[5705,5776,"Contract?"],[5918,6039,"What contract?"]],"34":[[275,387,"What are you talking about?"],[517,688,"Forget it, forget it, forget it."],[713,855,"Just pretend I didn't say anything."],[884,1021,"When I caught you and Daniel"],[1021,1188,"at the restaurant the other day,"],[1205,1380,"you said that he was going on a trip."],[1430,1609,"Is there something you're not telling me?"],[1647,1872,"Please, I just want the truth."],[1943,1993,"Mom."],[2110,2168,"Fine."],[2268,2402,"I will tell you the truth."],[2481,2652,"But promise me you won't get mad."],[2898,3090,"I'll tell you the truth, Sabrina."],[3249,3503,"But know it was all for your own good."]],"35":[[79,208,"When Preston left you,"],[208,333,"you were distraught."],[404,554,"I had to save you."],[604,775,"She's lost without you, Daniel."],[963,1105,"You've always been there for her."],[1155,1292,"From film school to now."],[1347,1434