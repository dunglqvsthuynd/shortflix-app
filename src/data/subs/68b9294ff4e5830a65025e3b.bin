{"1":[[16,150,"And the Oscar goes to..."],[204,296,"Daniel Johnson,"],[296,425,"for his original screenplay,"],[462,533,"Loving Her."],[809,1063,"That loser actually won an Oscar?"],[1109,1259,"Who knew the house hubby had it in him."],[1272,1418,"I'm an industry joke now."],[1418,1463,"Talk to us."],[1488,1530,"Daniel."],[1547,1626,"Daniel is it true"],[1626,1776,"that the script that won you Oscars,"],[1776,1918,"for both writing and directing,"],[1918,2110,"sat on a shelf for ten years?"],[2118,2206,"Wow, you did your homework?"],[2210,2264,"Yes,"],[2264,2402,"I got sidelined for a little bit,"],[2414,2631,"but I think I found my way back."],[2698,2806,"Um, I will tell you this."],[2806,2882,"I don't think you can"],[2882,3011,"truly love others"],[3028,3111,"until..."],[3211,3299,"you truly love yourself."],[3395,3528,"Daniel really did it."],[3553,3699,"The one standing by his side"],[3728,3837,"isn't me anymore."],[3920,4037,"You think you can divorce"],[4037,4170,"America's sweetheart?"],[4220,4254,"You're nothing"],[4254,4362,"but a fucking house-husband,"],[4362,4429,"Daniel."],[4512,4633,"Our contract expired."],[4733,4800,"I'm only telling you"],[4800,4917,"because you're her manager."],[4921,5075,"If you try and divorce my daughter,"],[5109,5230,"you will end up with nothing."],[5271,5392,"The mansion, the money."],[5417,5597,"Even your own son will belong to her."],[5889,6022,"I'll always love my son."],[6035,6126,"But he's a bully,"],[6126,6227,"and he learned it from the best"],[6227,6318,"in the business,"],[6331,6423,"his grandmother."],[6431,6585,"You used to worship Sabrina."],[6619,6698,"What happened?"],[6740,6869,"That was a long time ago."],[6927,7027,"America's Sweetheart,"],[7027,7219,"Sabrina Donovan, attempts suicide."],[7278,7424,"All for her co-star, and Hollywood's"],[7424,7565,"Golden boy, Preston Eastwood."],[7640,7703,"But her career"],[7703,7845,"is hanging by a thread."],[7866,7995,"I need to get those paparazzi"],[7995,8083,"off her back."],[8191,8320,"You've always loved her, Daniel."],[8375,8475,"I've seen it."],[8508,8650,"She needs that now."],[8733,8808,"Stay."],[8842,8946,"Marry her."],[9021,9113,"Love her,"],[9192,9300,"so that she doesn't face"],[9300,9380,"the world alone."],[9401,9522,"I might not have been Sabrina's"],[9522,9597,"first love."],[9609,9730,"But I would be her last,"],[9751,9872,"and I'd cherish her like"],[9872,9993,"no other man would."],[10110,10214,"If Preston Eastwood's"],[10214,10306,"really back,"],[10306,10447,"then maybe the last ten years"],[10447,10556,"meant more to me,"],[10581,10744,"then they ever did to her."],[10744,10860,"This was the last straw."],[11111,11177,"Mom."],[11177,11252,"Daniel."],[11394,11494,"What's going on?"]],"2":[[91,183,"What's going on?"],[233,358,"Honey,"],[437,596,"I was just telling Daniel"],[596,792,"he needs to stop dressing like a bum."],[846,971,"If the paparazzi catch him"],[971,1113,"next to you, ugh."],[1167,1242,"But I need to go."],[1255,1313,"I have an appointment"],[1313,1401,"with your stylist."],[1651,1747,"Think about it, Daniel."],[2135,2318,"Once Sabrina signs the divorce petition,"],[2318,2535,"the 30 day waiting period starts."],[2535,2690,"And then I will be free."],[2794,2973,"Sabrina, we, we need to talk."],[3023,3111,"Can't I wait?"],[3111,3319,"I'm seriously so spent."],[3374,3503,"I had the photo shoot"],[3503,3795,"and fitting and cocktails with girls."],[3812,3941,"I saw Preston was there."],[4108,4258,"I mean, he got us our first movie deal"],[4258,4358,"right out of college."],[4358,4479,"I mean, we owe him."],[4537,4579,"Yeah,"],[4587,4721,"and then he cheated on you"],[4721,4946,"and I'm the one who picked up the pieces."],[4946,5034,"I'm starving."],[5046,5138,"When are we eating?"],[5196,5338,"Lunch is on the stove."],[5376,5463,"But first,"],[5476,5609,"your mother and I need to talk."],[5634,5693,"No!"],[5718,5855,"I want to eat now!"],[6915,7027,"You always know the spot."],[7127,7261,"He doesn't listen. - Daniel,"],[7286,7353,"please."],[7403,7553,"I’ve had a migraine all day"],[7553,7674,"from the flashing bulbs"],[7674,7891,"at that God-awful Vanity Fair shoot."],[8145,8262,"I've got something I need to tell you."],[8283,8345,"I'll make it quick."],[8383,8521,"This isn't easy, but, I-"],[8521,8725,"Ew! What is this?"],[8750,8854,"It's mom's vegetable"],[8854,8975,"and quinoa stew. - I don't want"],[8975,9038,"healthy food!"],[9038,9171,"I want chicken nuggets!"],[9171,9355,"Chicken nuggets! Chicken nuggets!"],[9446,9588,"You can't have that every day."],[9588,9713,"It's not healthy for you."],[9726,9834,"But I want them."],[9909,10251,"Jaxon, when I say no, I mean no."],[10264,10368,"You suck!"],[10389,10556,"I want chicken nuggets!"],[10556,10698,"Give me chicken nuggets!"],[11436,11532,"I waited."],[11586,11778,"I gave it everything I had."],[11840,11924,"But it takes two"],[11924,12028,"to make a marriage work."],[12066,12233,"My self-absorbed wife"],[12233,12379,"would rather be with the man"],[12379,12583,"that almost ruined her life than me."],[12633,12708,"Enough."],[12708,12883,"Just, enough."],[13288,13496,"I want a divorce."]],"3":[[25,229,"I want a divorce."],[613,729,"Sabrina, did you hear me?"],[863,930,"Huh?"],[1071,1222,"I want"],[1351,1384,"a di-"],[1384,1522,"I want chicken nuggets!"],[1559,1735,"Give me chicken nuggets!"],[1735,1906,"Jaxon, honey,"],[1935,2139,"you need to listen to your father, okay?"],[2168,2306,"Now go upstairs, get cleaned up."],[2306,2431,"We'll get you some real food."],[2911,2986,"Seriously?"],[3048,3174,"Your only job is to take care"],[3174,3294,"of the house and the family."],[3357,3507,"I mean, it's not that hard."],[3603,3699,"What is this?"],[3782,3874,"Another contract?"],[3949,4058,"How big is the role?"],[4170,4250,"Who's directing?"],[4304,4400,"It's not a- - Whatever,"],[4400,4550,"my mom will look over it anyways."],[4629,4763,"Hard to believe I can't even get her"],[4763,4884,"to care about this."],[4892,4963,"Honestly,"],[5009,5226,"I am really at my capacity."],[5226,5355,"I have that red carpet event"],[5355,5417,"coming up,"],[5463,5638,"and I really need you to pull your weight."],[5739,5822,"Pull my weight?"],[5851,5951,"Yeah, you get it."],[6001,6047,"Come here."],[6243,6310,"Love you."],[6339,6531,"I've devoted myself to this family for"],[6531,6694,"ten long years."],[6694,6840,"If that wasn’t enough,"],[6840,7011,"then this is the only option."],[7011,7194,"Just wait until she realizes what"],[7194,7369,"life's like without me."]],"4":[[558,663,"The movie is greenlit"],[663,796,"and the studio wants you to direct."],[796,875,"We need you on a plane"],[875,984,"to Australia tomorrow."],[1009,1272,"I can't. My wife needs me here in LA."],[1330,1472,"After all I've sacrificed,"],[1526,1826,"my scripts, my career, my future."],[1893,2031,"All pushed aside."],[2152,2285,"At least there was one good thing"],[2285,2385,"to come from this."],[2410,2573,"I was able to use the money Celeste"],[2573,2773,"gave me to save my mother's life."],[2777,2886,"Hey Mom, how you doing?"],[2898,3011,"I’m good, dear."],[3123,3294,"I just noticed that you transferred"],[3294,3478,"more money to my account."],[3507,3578,"Do you need more?"],[3578,3657,"No, no, no, no,"],[3657,3891,"you've already done so much."],[3908,4016,"I'm just trying to help."],[4054,4112,"I know,"],[4158,4300,"but I never wanted my cancer"],[4300,4412,"to be your battle."],[4512,4696,"I can't thank you enough"],[4696,4921,"for everything that you've done, but"],[5017,5209,"it's time you lived your life."],[5271,5376,"I am, Mom."],[5480,5647,"And I promise,"],[5705,5768,"very soon,"],[6010,6143,"everything's going to change."],[6202,6331,"That's wonderful, dear."],[6348,6423,"You deserve more"],[6423,6539,"than what they put you through."],[6594,6752,"Everyone come quick, come quick!"],[6827,6948,"I got to go. Love you."],[7282,7374,"What is it, Mom?"],[7390,7528,"Someone very special decided"],[7528,7649,"to pay us a visit."],[7649,7811,"Our favorite leading man."],[7878,7932,"Come on."],[8512,8621,"Preston Eastwood,"],[8658,8837,"the man that broke my wife's heart"],[8950,9146,"and is stealing it back again."]],"5":[[8,120,"Preston Eastwood."],[150,246,"The man that broke"],[246,367,"my wife's heart."],[959,1026,"All right."],[1026,1067,"Cut!"],[1076,1176,"That's a wrap, everyone."],[1205,1326,"Thank you."],[1376,1505,"We got her start on the set of"],[1505,1597,"Breaking the Ice."],[1693,1872,"Sabrina was a rising star."],[1935,2047,"I was just the director's"],[2047,2168,"assistant."],[2352,2406,"Our future's"],[2406,2489,"ahead of us."],[2694,2761,"If only she didn't"],[2761,2882,"fall for Hollywood's"],[2882,3048,"golden asshole."],[6072,6222,"You destroyed me,"],[6297,6414,"Preston."],[6456,6573,"There's nothing left."],[7849,7912,"Sabrina!"],[7912,7970,"Don't!"],[8112,8204,"Stay back."],[8262,8354,"I mean it."],[8387,8475,"Sabrina,"],[8529,8650,"don't do this."],[8754,8821,"Just."],[9059,9180,"Just give me your hand."],[10331,10368,"No!"],[10381,10443,"Ah!"],[10573,10689,"Daniel!"],[10723,10802,"I got you."],[10835,10910,"No!"],[10940,11081,"Don't let me go!"],[11140,11261,"I will never let you go."],[11824,11982,"I'm so alone, Daniel."],[12149,12278,"Nobody sees the real me."],[12278,12399,"I see you, Sabrina."],[12499,12620,"I see all of you."],[12729,12775,"And you're never"],[12775,12875,"going to be alone again."]],"6":[[166,271,"Good to see you!"],[308,450,"Oh my gosh, how long has it been?"],[450,642,"Oh, too long. - Look at you!"],[734,846,"I'm so glad you could make it"],[846,930,"to my little slice"],[930,1021,"in the Hollywood Hills."],[1021,1142,"Oh my God, of course, babe."],[1159,1251,"Thank you for letting me stay here"],[1251,1363,"for a little bit. Are you kidding?"],[1363,1459,"Oh, Daniel,"],[1472,1589,"Preston's going to stay with us"],[1589,1793,"for a bit, but you don’t mind, right?"],[1793,1964,"Oh, there he is!"],[1989,2085,"The assistant."],[2085,2210,"I'll tell you what, there's no one"],[2210,2423,"who grabs coffee quite like this guy."],[2477,2581,"How did someone like you"],[2581,2798,"end up with a blonde bombshell"],[2798,2923,"like my Sabrina?"],[2923,2982,"Stop."],[3073,3174,"I can't believe my wife"],[3174,3278,"would invite the ex"],[3278,3470,"she tried to kill herself over"],[3499,3595,"into our home."],[3657,3845,"Sabrina, I don't remember"],[3849,3987,"agreeing to having him stay over."],[3987,4062,"Daniel,"],[4104,4204,"don't embarrass me."],[4225,4312,"No, it's fine."],[4341,4579,"Whoa, you played Bret Steele"],[4608,4792,"in your action spy movie?"],[4792,4909,"He's not just tough,"],[4909,5088,"he's Bret Steele tough."],[5088,5180,"You a fan, kiddo?"],[5205,5276,"My friends are,"],[5276,5417,"but my dad doesn't let me watch it."],[5417,5580,"He doesn't let me do anything."],[5580,5689,"Well now that I'm here,"],[5689,5914,"we'll be able to bend some of Dad's rules."],[5914,6026,"What do you say, huh?"],[6076,6139,"Yeah."],[6139,6231,"Sabrina,"],[6310,6452,"I think it's time he leaves."],[6573,6635,"It's fine."],[6690,6760,"It's fine."],[6844,6969,"Just relax, okay?"],[7032,7123,"Be nice."],[7916,8053,"Some people never change,"],[8124,8304,"but once our divorce is finalized,"],[8350,8483,"I won't be there to save her"],[8483,8625,"when he breaks her heart again."]],"7":[[58,204,"Yeah, it's nice,"],[208,316,"but this mansion is still the"],[316,425,"second most stunning thing"],[425,504,"on this hill."],[1230,1351,"Oh, careful."],[1401,1488,"You alright?"],[1710,1851,"I'm still starving."],[1876,2010,"Make me some food!"],[2031,2093,"Jaxon,"],[2093,2264,"there's leftover stew in the fridge."],[2273,2352,"Stew?"],[2523,2656,"What is this, a soup kitchen?"],[2656,2794,"I told you a hundred times,"],[2794,2957,"I want chicken nuggets!"],[2957,3044,"Daniel,"],[3044,3169,"if the kid wants nuggets,"],[3169,3261,"just give him nuggets."],[3261,3390,"I'm trying to teach my son"],[3440,3511,"how to be grateful"],[3511,3620,"for what he already has."],[3649,3712,"Daniel,"],[3787,3928,"I'm a billionaire."],[3953,4024,"Babe,"],[4062,4145,"for real?"],[4158,4225,"Yeah,"],[4266,4366,"my makeup line"],[4366,4529,"took me all the way to the top!"],[4579,4738,"Donovan Cosmetics."],[4763,4875,"I'm rich."],[4967,5038,"Which means"],[5071,5267,"we don't have to be grateful."],[5338,5442,"I mean, that's just something"],[5442,5563,"poor people tell themselves"],[5563,5751,"so that they're happy with nothing."],[5751,5872,"Daniel, that was always your problem."],[5872,6031,"You're so caught up on the morals."],[6076,6156,"You realize that's why no one"],[6156,6335,"bought your scripts? They were so dull."],[6377,6485,"Please, Mr. Eastwood,"],[6485,6690,"my dad won't let me have anything."],[6715,6844,"Well lucky for you,"],[6865,7107,"Uncle Preston is a little bit of a rebel."],[7107,7282,"So, how about"],[7303,7490,"we go to an exclusive restaurant?"],[7515,7607,"My treat."],[7703,7753,"You want to go?"],[7761,7866,"What? - Yeah."],[7891,8024,"You don't have to do that."],[8024,8108,"I don't mind."],[8133,8270,"Well if you insist,"],[8291,8412,"I mean, I'm already dressed."],[8633,8683,"Okay."],[8821,8992,"Oh, and I would invite you, Daniel,"],[8992,9255,"but there's a little bit of dress code, so."],[9255,9309,"Anyways,"],[9355,9463,"come on, baby, let's go."],[9547,9605,"Thanks."],[9605,9655,"It looks great, I got you."],[9655,9772,"Oh, thanks. - There we go."],[9847,9880,"Oh,"],[9993,10118,"there's Paps."],[10193,10318,"You don't have to come, Daniel."],[10339,10552,"Last time, I promise."],[10823,11036,"You're right. It is the last time."],[11202,11257,"Hey, guys."],[11440,11511,"This is Jaxon. - Hi."],[11557,11615,"Jaxon."],[12220,12370,"Well, did you use your brain"],[12370,12479,"or are you following through"],[12479,12566,"on the divorce?"],[12604,12691,"Contract's signed."],[12867,12937,"It's over."]],"8":[[8,154,"Why don't you meet me at the Oaks"],[154,287,"to finalize the paperwork?"],[375,492,"I hope you're ready to go on"],[492,629,"without a penny to your name."],[750,875,"After ten years of heartbreak,"],[875,1046,"I don't care if I walk away with nothing."],[2831,2982,"Why would Celeste invite me here?"],[3044,3136,"She must have known"],[3136,3236,"this is where they were going"],[3236,3294,"for dinner."],[3549,3628,"Sabrina Donovan?"],[3691,3782,"I could scream."],[3782,3941,"I'm literally obsessed with you."],[3970,4062,"Preston Eastwood?"],[4062,4250,"I haven't seen the two of you together"],[4250,4362,"since Breaking the Ice."],[4371,4437,"OMG."],[4437,4575,"I used to always replay that scene"],[4575,4637,"where you guys kissed"],[4637,4713,"at the hockey rink."],[4717,4825,"A scene that I wrote,"],[4825,4954,"uncredited, of course."],[4963,5113,"Even my success is shadowed"],[5113,5209,"by her fame."],[5209,5359,"Wait, are you two dating?"],[5384,5584,"Oh, well, actually- - This is totally"],[5584,5668,"a date."],[5722,5830,"All these years,"],[5830,5964,"I couldn't even be seen"],[5964,6060,"with her in public."],[6506,6573,"Do you mind just"],[6573,6706,"giving me a little space?"],[6765,6936,"You're not really a part of my brand."],[6961,7044,"Your brand?"],[7102,7269,"It's just, it's not a good look for me."],[7328,7453,"You get it, right?"],[8279,8433,"So, you two are a thing?"],[8466,8533,"Well, I..."],[8554,8629,"It's okay, babe."],[8629,8804,"We don’t have to lie to our biggest fans."]],"9":[[66,200,"This is so going viral."],[208,321,"I can't believe you guys are dating."],[367,558,"It looks like more than dating."],[621,713,"Is this your son?"],[729,875,"I wish I was his son."],[880,946,"Jaxon,"],[1009,1092,"don't be silly."],[1121,1267,"You have a dad and he's-"],[1267,1359,"A sissy."],[1368,1534,"That's what all the boys at school say."],[1576,1847,"He does girly stuff like cook and clean."],[1914,2131,"But Preston is awesome."],[2173,2323,"He's an action spy."],[2339,2464,"I wish he was my dad."],[2640,2840,"My own son doesn't respect me."],[2894,2990,"But we'll see if Preston"],[2990,3107,"is the type of dad he wants"],[3107,3190,"when he comes home"],[3190,3382,"coked-out from a Hollywood afterparty"],[3382,3490,"with a call girl."],[3511,3578,"It's okay, buddy."],[3603,3762,"Every spy needs a partner in crime."],[3828,3949,"If you want me around,"],[4024,4083,"I'm in."],[4104,4283,"That is if Mom's cool with it."],[4354,4466,"Preston, I don't know."],[4466,4629,"Daniel, he, you know, he’s..."],[4729,4842,"Preston, what are you doing?"],[5125,5188,"Come on,"],[5209,5317,"let's give them a show."],[6831,7082,"Now that's a Hollywood couple."],[7319,7436,"I told you this divorce"],[7436,7520,"was a mistake."],[7557,7749,"Sabrina will end up on top"],[7749,7991,"and you will end up with nothing."],[8216,8283,"Daniel!"]],"10":[[41,212,"You know, it's probably for the best."],[250,358,"From the sound of it,"],[387,496,"your own son doesn't even"],[496,608,"want to be around you."],[642,759,"Daniel, he's here?"],[817,909,"Did he see us?"],[925,1038,"Is he looking over here?"],[1038,1146,"Oh fuck, that’s not good."],[1159,1280,"I was just doing that for publicity."],[1280,1447,"I didn't mean for him to see us."],[1480,1618,"Actually, it was perfect timing."],[1626,1776,"Once that loser's out of the picture,"],[1776,2002,"Sabrina and her money are all mine."],[2031,2198,"Who cares about him, Mommy?"],[2218,2381,"Now you can be with Mr. Preston."],[2381,2464,"Jaxon, enough."],[2677,2786,"What do I do?"],[2823,2986,"Well, that's it then."],[3048,3182,"Now I need to handle Sabrina."],[3182,3299,"I need to leverage her relationship"],[3299,3374,"with Preston"],[3449,3549,"with the tabloids."],[3549,3661,"I'm sure you'll spin the story"],[3661,3753,"to whatever suits you."],[3903,3995,"You're really good at that."],[4045,4099,"Ooh,"],[4133,4350,"I have a parting gift for you."],[4429,4592,"A one-way ticket"],[4642,4813,"so you can get as far away"],[4813,4992,"from this family as possible."],[4992,5155,"I know the contract is over,"],[5155,5388,"but if I see one stitch of bad press"],[5388,5476,"about the Donovans,"],[5555,5655,"I will come after you"],[5655,5784,"with everything I got."],[5818,5985,"Daniel loves me. He has to understand."],[5985,6097,"This is Hollywood,"],[6097,6222,"it's just part of the job!"],[6418,6610,"Daniel, I can explain."],[7148,7278,"Daniel, what is this?"]],"11":[[4,70,"I can't let her"],[70,162,"create a public scene."],[196,312,"All it takes is one"],[312,442,"article to get her canceled."],[479,642,"Are you going somewhere?"],[725,792,"Honey."],[834,971,"Oh, what a coincidence."],[1005,1134,"We were just meeting here"],[1142,1284,"to discuss a vacation."],[1326,1443,"Isn't that right, Daniel?"],[1484,1547,"A vacation?"],[1576,1639,"Finally,"],[1664,1751,"you're paying attention."],[1860,1910,"Yeah."],[1985,2118,"I'm going to leave in a few days."],[2152,2327,"Well, thanks for telling your wife."],[2385,2452,"What are we supposed to do"],[2452,2535,"without you?"],[2540,2656,"Without me cooking and cleaning?"],[2690,2769,"That's not what I meant."],[2781,2857,"Whoa."],[2890,2969,"Looks like there's"],[2969,3032,"a little bit of drama"],[3032,3103,"going on over here."],[3119,3190,"It's fine."],[3224,3324,"Daniel's just decided"],[3324,3465,"to abandon us for a bit."],[3511,3657,"Just like any good husband would."],[3666,3832,"Okay, I see."],[3849,3953,"Is it me?"],[3987,4154,"It's my presence hurting your ego?"],[4179,4362,"I wouldn't put jealousy past him."],[4387,4437,"I always knew you were"],[4437,4546,"the self-loathing type."],[4600,4671,"You know what?"],[4704,4775,"Maybe I should go."],[4779,4846,"I don't want to get between"],[4846,4913,"the two of you."],[4950,5067,"No, please stay,"],[5067,5184,"I want you to live with us"],[5184,5305,"forever and ever."],[5430,5492,"No, you know what?"],[5538,5609,"I'll go."],[5714,5751,"I mean clearly"],[5751,5855,"she wants you."],[5880,5976,"Willing to dance to his tune."],[5997,6031,"Daniel."],[6035,6156,"Wait."],[6260,6381,"I will never let you go."],[6435,6652,"He won't leave, he promised."],[6702,6877,"It doesn't have to be like this."],[6911,7011,"We could pull up a chair"],[7011,7086,"and we can-"],[7219,7323,"I'm going to go back."],[7607,7703,"Daniel!"]],"12":[[316,483,"The bed’s in here. - This is..."],[521,583,"Yeah."],[629,754,"Shh, shh, shh, shh."],[821,921,"Oh!"],[1009,1184,"Oh good, you're up."],[1226,1276,"Um,"],[1292,1472,"after dinner, we went to an A-lister"],[1472,1601,"party in Bel Air."],[1751,1814,"It was fun."],[1943,2081,"What, don't look at me like that."],[2081,2281,"I'm allowed to have a little bit of fun."],[2377,2452,"Anyways,"],[2464,2640,"Preston had a few too many drinks"],[2640,2727,"to be alone."],[2748,2802,"A little bit."],[2802,2932,"Oh, lucky for him."],[2957,3090,"He's got his girl to take care of him"],[3090,3182,"when he's drunk."],[3274,3353,"Daniel,"],[3353,3482,"whatever you saw at the restaurant,"],[3482,3578,"it's not like that."],[3661,3753,"Listen man, I,"],[3866,3995,"I've had every opportunity"],[3995,4083,"to sleep with her"],[4083,4216,"and nothing happened."],[4216,4337,"You can trust me."],[4483,4708,"Preston, I think you're too drunk."],[4738,4850,"You need to lie down."],[4871,4938,"Alright."],[5100,5171,"Hey"],[5209,5380,"Daniel, seriously, listen man,"],[5380,5543,"I, I, when you're gone,"],[5543,5780,"I promise I will take the best care"],[5818,5964,"of your son and your wife."],[5964,6193,"I'm going to be the best"],[6193,6289,"man of the house."],[6356,6431,"Just ignore him,"],[6431,6585,"he doesn't know what he's saying."],[6614,6748,"No, I actually think he’s the only one"],[6748,6936,"speaking exactly what's on his mind."],[6948,7044,"Daniel, you don’t have to be"],[7044,7148,"so jealous."],[7161,7232,"Jealous?"],[7415,7603,"My God, you still don't get it, do you?"],[7728,7836,"Whatever, I'm going to bed."],[8162,8245,"You know,"],[