76,"Oh, I hope so."],[5276,5380,"I really hope so."],[5380,5505,"He's way cooler"],[5505,5709,"than my old, boring real dad."],[5751,5822,"Speaking of,"],[5822,5964,"I don't think we've ever met"],[5964,6051,"your real dad."],[6101,6256,"Yeah, he usually stays at home"],[6256,6377,"doing chores like a maid."],[6998,7123,"What are you doing here?"],[7127,7286,"You never come to these things!"],[7336,7478,"Well, that's got to be the husband."],[7674,7878,"Get lost! You'll embarrass us!"],[7878,8078,"Jaxon, do not talk to me like that."],[8078,8162,"I'm your father."],[8195,8375,"I wish you never were my dad!"],[8696,8779,"Is there a problem?"]],"22":[[0,95,"Oh my God."],[141,229,"That's Preston Eastwood."],[296,387,"How could Sabrina"],[387,600,"choose this flop over Preston?"],[613,700,"If there was a problem,"],[742,846,"that's none of your business."],[871,1030,"I wish Preston was my dad."],[1038,1101,"You're a pathetic loser."],[1101,1188,"You're a pathetic loser."],[1201,1334,"Zip it, Jaxon."],[1376,1530,"You should probably listen to your kid"],[1530,1639,"and head out because"],[1710,1864,"you're starting to make a scene."],[1906,2031,"I'm just here to talk to Celeste."],[2031,2143,"That's not what I see."],[2239,2427,"You showed up uninvited,"],[2444,2560,"in street rags,"],[2581,2723,"abused Sabrina's kid"],[2723,2977,"and picked a fight with an A-lister."],[3073,3190,"That's the kind of story"],[3190,3349,"the press would devour."],[3390,3453,"Doesn't take much"],[3453,3582,"to be canceled these days."],[3649,3862,"And then they would praise Sabrina"],[3862,4033,"for divorcing your sorry ass."],[4104,4229,"This was all a stunt, wasn’t it?"],[4354,4471,"You are revolting."],[4496,4596,"No wonder Sabrina turned out"],[4596,4667,"the way she did."],[4729,4783,"Hey,"],[4946,5080,"why don't you watch your mouth?"],[5113,5288,"Trash like him is always forgetting"],[5288,5422,"their place in the world."],[5467,5659,"Yeah, maybe I should teach him a lesson."],[5680,