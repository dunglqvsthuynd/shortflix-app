{"1":[[751,1003,"They say first love is always unforgettable."],[1132,1267,"Whether it ends in love..."],[1432,1511,"or hate."],[2951,3035,"Tessa."],[3123,3232,"Will you marry me?"],[3347,3428,"Yes."],[6720,6935,"Why am I still dreaming about that liar?"],[8031,8092,"Crap!"],[8323,8456,"It's been three years now."],[8484,8623,"And I have a new fiancée."],[8692,8815,"And as for Asher, I..."],[8884,9040,"doubt we'll ever see each other again."],[11031,11107,"Tessa,"],[11156,11284,"my uncle's here today."],[11351,11492,"He's the head of the Wilson family."],[11640,11759,"The Wilson family?"],[11800,12043,"But aren't they the biggest gangsters in town?"],[12176,12368,"They've ditched all that shady stuff."],[12451,12556,"It's just business now."],[12679,12735,"Don't worry."],[12815,12884,"You'll be great."],[12963,13080,"My uncle will like you."],[13568,13668,"Uncle Asher."],[13712,13856,"This is my fiancée,"],[13856,13928,"Tessa."],[14019,14091,"Tessa."],[14200,14375,"This is my uncle Asher."],[14408,14687,"The man who I admire the most."],[15291,15387,"Asher?"]],"2":[[260,459,"My fiancee's uncle is Asher?"],[516,683,"I didn't even know he was a Wilson."],[951,1027,"Tessa..."],[1259,1391,"It's been a long time, right?"],[1467,1632,"I don't know what you're talking about."],[2012,2219,"I've missed you so much this past three years."],[2535,2703,"You left without saying goodbye."],[2860,3000,"I waited for you."],[3123,3278,"And I didn't even know that my first love"],[3278,3375,"was a Wilson."],[3456,3535,"I'm sorry."],[3600,3811,"I've been trying to get away from the Wilson family."],[3860,3935,"Trust me."],[4024,4152,"It doesn't matter anymore,"],[4152,4225,"does it?"],[4271,4443,"I'm your nephew's fiancée."],[4492,4700,"Let's go back to pretending we don't know each other."],[5911,5992,"Tessa."],[6071,6179,"I won't lose you again."],[6256,6352,"Not this time."],[6456,6564,"You gonna be mine forever."],[6820,6876,"Hey."],[6940,7015,"Where are you?"],[7015,7100,"Are you all right?"],[7148,7300,"My uncle's been waiting to see you."],[7468,7568,"What happened to your earring?"]],"3":[[283,356,"I, uh..."],[491,704,"I think I lost it somewhere."],[771,856,"Austin, I..."],[856,975,"I feel a bit sick."],[975,1056,"Can we just go home?"],[1319,1380,"Sure."],[1488,1559,"Thank you."],[2467,2544,"Here we are."],[2667,2900,"Didn't think this was how the night would end."],[3051,3119,"I'm sorry."],[3543,3611,"Don't worry."],[4184,4275,"Go get some rest."],[5939,6147,"Useless idiot."],[6300,6531,"Can't even play her part right."],[6764,7076,"As if I'd fall for a piece of trash like her."],[7259,7531,"When I finally get my shares,"],[7679,7976,"she's the first thing I'll be getting rid of."],[9056,9123,"Jenny,"],[9251,9351,"where are you?"],[9471,9559,"I miss you."],[9613,9722,"Already?"],[9740,9885,"Needy, ain't it?"],[9885,10115,"It's only been a few days."],[10115,10231,"What can I say?"],[10284,10500,"I just can't stop"],[10500,10704,"thinking about the last time we were together."],[10792,10892,"Yeah?"],[11135,11235,"Yeah, baby."],[11264,11371,"Come over."],[11371,11540,"I'll text you the address."],[12891,13047,"Our biggest shareholder"],[13087,13231,"is arriving in a minute."],[13300,13575,"I don't want a single mistake"],[13575,13659,"from anyone."],[13668,13728,"Got it?"],[14719,14815,"That earring..."],[14900,15003,"I have to get it back..."],[15231,15328,"Mr. Wilson."],[15919,16015,"It's an honor"],[16015,16239,"for us to have you visit our hospital."],[16315,16384,"Please."],[16384,16532,"Come this way, let me find someone"],[16532,16624,"to give you a tour."],[16643,16743,"Asher Wilsons!"],[16775,17012,"The biggest shareholder in our hospital now."],[18471,18540,"No need."],[18624,18708,"I want her."]],"4":[[243,352,"Quick, Tessa."],[383,591,"Don't keep Mr. Wilson waiting."],[620,880,"Mr. Wilson, please follow me this way."],[1839,2000,"What the hell are you doing here?"],[2035,2128,"I told you."],[2180,2292,"We're over."],[4475,4611,"Your family's in trouble."],[4635,4828,"And you need the Sinclairs' money."],[4875,4992,"Break up with Austin."],[4992,5211,"Money isn't a problem, I can handle it."],[5239,5320,"I just want you."],[5488,5588,"Seriously?"],[5664,5864,"You think that's the reason I'm not with you?"],[5879,5979,"You know,"],[6003,6243,"it might have started as a business deal."],[6332,6420,"But now,"],[6520,6707,"Austin and I, we love each other."],[6900,6971,"Do you love him?"],[7015,7064,"I do."],[7168,7348,"He remembers things about me."],[7404,7576,"He knows how I like my coffee."],[7659,7812,"And he makes me happy."],[7868,8051,"Do you know how long it took me"],[8051,8231,"to smile again after you left me?"],[8251,8356,"Six months."],[8512,8740,"Austin was the first one to make me laugh."],[8771,8928,"But most importantly..."],[8992,9171,"I don't love you anymore."],[9284,9431,"Get off me!"],[9484,9607,"You're saying all those things."],[9735,10035,"But your body and heart doesn't say that."],[10243,10315,"Tessa?"],[10335,10412,"Austin?"],[10484,10600,"What is he doing here?"],[10979,11215,"Are you afraid of them to hear us?"],[11371,11500,"Let go of me!"],[11540,11676,"You're fucking insane!"],[12420,12515,"Tessa? Are you in there?"]],"5":[[360,455,"Mr. Sinclair."],[632,675,"Mark."],[843,932,"Is Uncle Asher around?"],[980,1108,"If you're looking for Miss Tessa,"],[1151,1311,"she's showing Mr. Wilson around."],[1416,1532,"Why don't we wait over there?"],[3424,3543,"Tessa, I'm sorry."],[3684,3788,"l didn't mean to."],[3871,4071,"You've ruined my life once."],[4292,4371,"Don't do it again."],[5067,5160,"Austin!"],[5400,5584,"Darling, where have you been?"],[5584,5771,"I've been looking all over for you."],[5928,5969,"Wait."],[6135,6286,"Why is your neck red?"],[6332,6400,"I..."],[6508,6675,"I think it's a bug bite..."],[6868,7135,"Yeah, well, come on."],[7220,7371,"We're going to my family's house tonight."],[7456,7556,"Don't tell me you forgot."],[7600,7692,"I'm sorry."],[7900,7957,"Let's go."]],"6":[[356,536,"You've ruined my life once."],[640,755,"Don't do it again."],[1064,1140,"Mark,"],[1232,1459,"give 3% of my shares"],[1532,1591,"to Austin."],[1660,1919,"I don't want Tessa"],[1971,2112,"to marry a loser."],[2207,2351,"Sir, are you serious?"],[2419,2600,"Are you really giving up on Tessa?"],[2623,2716,"Why don't you tell her"],[2751,2939,"what you went through to get back to her?"],[3960,4071,"Well, well,"],[4071,4256,"Young Mr. Wilson."],[4535,4707,"I heard you want to break away"],[4707,4867,"from the Wilson family."],[4892,5103,"And live like a regular person."],[5179,5303,"What a pipe dream!"],[5500,5632,"You can't escape this."],[5652,5803,"You can't escape us."],[6035,6135,"Fuck you!"],[8012,8168,"What, did you...?"],[8340,8492,"Your father has his way."],[8515,8751,"He left a message, by the way."],[8751,8851,"He said,"],[8871,9176,"if you still have that thoughts, that girl..."],[9287,9431,"What are you going to do to her?"],[9607,9779,"She doesn't need all hurt fingers,"],[9800,9884,"does she?"],[9928,10151,"Or... we turn her"],[10248,10351,"into a whore?"],[10451,10523,"A junkie..."],[10600,10859,"We've got a hundred ways to..."],[10907,11004,"break her."],[11192,11287,"So choose."],[11371,11604,"Us or the girl?"],[11879,12023,"You..."],[12033,12101,"Huh?"],[12179,12340,"I choose the family."],[12587,12664,"Good answer."],[13575,13736,"I'm sorry, Tessa."],[14503,14600,"It doesn't matter."],[14803,14959,"She deserves to be happy,"],[15128,15307,"even though the guy who makes her happy"],[15307,15426,"is not me."],[16084,16168,"It's working."],[16331,16491,"Asher's beginning to see you"],[16491,16663,"as a step up."],[16703,16884,"And a responsible person."],[16952,17391,"He said he's giving you 3% of the company shares."],[17575,17636,"Really?"],[17831,17900,"Well, that's great."],[18012,18143,"Now I can just dump Tessa."],[18363,18491,"Are you stupid or what?"],[18584,18684,"Of course not!"],[18759,18959,"You have to marry Tessa."],[19056,19347,"You have to treat her well,"],[19408,19552,"to get more shares."],[19700,19928,"You need to win Asher over."],[20136,20200,"Damn it."],[20263,20447,"Still have to marry that dumb hick."],[20812,20984,"Hey, who's the fault is that?"],[21084,21128,"Huh?"],[21236,21480,"You blew all the money they sent on what?"],[21512,21640,"Cars, drinks,"],[21684,21968,"club, idiotic selfish things."],[22203,22352,"Now they don't trust us."],[22400,22787,"Asher has the power in the world."],[22800,23036,"We need to be on his good side."],[23184,23368,"Whatever \"price\""],[23387,23575,"we pay for Tessa,"],[23603,23791,"nothing is compared"],[23815,24112,"to what we'll receive from Asher."],[24259,24580,"Don't blow this opportunity for us."],[25452,25616,"Just be patient."],[25731,26019,"And get more shares."],[26224,26472,"Once you're married,"],[26524,26716,"we will find an excuse."],[26880,27192,"And then you divorce her."]],"7":[[712,816,"Sorry, babe."],[911,1027,"Didn't mean to keep you waiting."],[1100,1251,"What did your mom want to talk about?"],[1556,1664,"Oh, um..."],[1792,1923,"That's a surprise."],[2103,2244,"You'll find out later."],[2355,2503,"Don't tease me like that."],[2607,2671,"Don't worry."],[2751,2856,"I'll make sure you're the"],[2856,3000,"happiest bride in the world."],[3207,3403,"Oh, Uncle Asher."],[3579,3792,"I heard you're going to be coming to my wedding."],[3900,4103,"Could you help us officiate?"],[4211,4279,"Yes."],[4447,4600,"I wish you guys a long"],[4664,4824,"and happy marriage."],[5588,5732,"Thank you, Uncle Asher."],[5800,6000,"Tessa and I will be very happy."],[6279,6400,"It's my pleasure."],[6443,6559,"Let's drink."],[7956,8107,"It's pouring outside."],[8135,8464,"And Austin got to drunk again."],[8523,8604,"Don't worry."],[8700,8807,"I'll take her home."],[9371,9515,"I don't think that's necessary."],[9607,9723,"Come with me."]],"8":[[612,687,"We are here."],[1340,1500,"Why keep staring at me?"],[1548,1639,"What do you want?"],[1903,2071,"Nothing! I just gonna go."],[2800,2967,"This is the last time I bring you home."],[3176,3303,"I won't bother you again."],[3352,3435,"I promise."],[3800,3860,"Tessa."],[3975,4084,"Will you marry me?"],[4203,4260,"Yes."],[4484,4615,"Three years ago,"],[4852,4975,"I wanted to marry you."],[5524,5664,"I wanted a life with you."],[6015,6160,"We ended up like this because of you."],[6347,6500,"You just destroyed everything."],[9800,9887,"Darling."],[9928,10064,"You look so beautiful."],[11956,12048,"I'm sorry."],[12107,12240,"I have to take this."]],"9":[[148,248,"Jenny."],[400,687,"I told you not to call me today."],[716,980,"But baby, I miss you..."],[1032,1108,"Besides,"],[1108,1340,"haven't you always wanted to try something"],[1464,1556,"scandalous?"],[1823,2003,"And what is more scandalous"],[2003,2332,"than having an affair at your own wedding?"],[4403,4500,"You look gorgeous."],[4575,4679,"Thanks."],[4735,5000,"Um, I wanted to ask you about"],[5028,5143,"that jewelry."],[5184,5232,"Is it..."],[5460,5524,"Mr. Wilson,"],[5524,5615,"Miss Carter,"],[5615,5711,"we can't find the groom."],[5743,5900,"His phone's off and..."],[5900,6075,"he's nowhere to be seen!"],[6092,6179,"What?"],[6207,6315,"He was just here."],[6360,6423,"Were something happen?"],[6423,6543,"Do we have to find him?"],[6576,6656,"Don't worry."],[6679,6851,"We still have 30 minutes to ceremony."],[6915,6976,"We're gonna find him."],[7287,7487,"Austin? Austin!"],[7487,7587,"Where are you?"],[7828,7943,"We only have 30 minutes."],[7943,8128,"Oh, yeah, Jenny."],[8156,8264,"Right there..."],[8264,8368,"That voice..."],[8407,8492,"Austin?"],[9451,9556,"What are you doing?"]],"10":[[379,475,"What are you doing?"],[927,1011,"Tessa."],[1091,1175,"I..."],[1203,1340,"How could you do this to me?"],[1488,1628,"It's our wedding day."],[2055,2187,"Tessa, it's..."],[2223,2323,"It's not what it looks like."],[2323,2428,"I can explain."],[2687,2900,"Baby, don't lie to her."],[2923,3123,"We've been doing this for years."],[3203,3528,"Honey, did you really think he loves you?"],[3656,3803,"It's just a business arrangement."],[3824,3900,"Jenny!"],[4111,4211,"Austin, is it true?"],[4360,4500,"You never loved me?"],[4567,4800,"All of those years, all of those stories..."],[4932,5032,"Was it all a lie?"],[5064,5224,"No, no, Tessa."],[5224,5379,"Don't listen to her. She's lying."],[5511,5615,"Let go of me."],[5679,5828,"You disgust me."],[5852,5975,"I'm calling off the wedding."],[6000,6071,"What?"],[6120,6379,"You can't do that."],[6379,6484,"Let go of me."],[6815,6943,"I said,"],[7012,7100,"you can't do that."],[7204,7415,"What about our families?"],[7456,7679,"What about the business?"],[7815,8079,"I can't marry someone who doesn't love me!"],[8143,8264,"You're pathetic."],[8928,9187,"I told you to think about this."],[9220,9476,"You had better keep your mouth shut!"],[9668,9851,"Your family needs my money."],[9876,10031,"So if you don't,"],[10071,10323,"your family will lose everything!"],[10423,10579,"Poor little bride."],[10604,10751,"Did you really think"],[10751,10951,"Prince Charming existed?"],[11028,11279,"It's just a silly fairy tale."],[11500,11631,"Get your hands off her!"]],"11":[[704,767,"Tessa."],[767,848,"Are you okay?"],[924,1048,"Uncle Asher, I..."],[1067,1100,"I..."],[1119,1303,"How dare you treat her like this?"],[1367,1619,"Uncle Asher, it's just a misunderstanding."],[1651,1767,"Misunderstanding?"],[1970,2083,"I heard everything."],[2200,2319,"Cheat on her?"],[2460,2580,"You hit her!"],[2623,2783,"You totally disgrace."],[2828,2919,"From now on,"],[3012,3243,"you've lost all your shares in the company."],[3264,3407,"Uncle Asher..."],[3420,3515,"Don't touch me!"],[3571,3635,"Please."],[3664,3728,"Just..."],[3939,4000,"Tessa."],[4032,4084,"Tessa."],[4139,4364,"We've been together for three years."],[4407,4539,"You believe me, don't you?"],[4556,4607,"Just quick."],[4647,4884,"Tell Uncle Asher that you were wrong."],[4939,5164,"Tell him that this is all just a misunderstanding."],[5179,5252,"Please."],[5547,5715,"I never want to see you again."],[5979,6052,"Tessa."],[6851,6920,"Don't worry."],[7000,7228,"I'll make sure you're the happiest bride in the world."],[7335,7459,"It was all a lie."],[7600,7800,"My entire life... I was just a tool."],[7859,8000,"First for my family,"],[8035,8131,"then for Austin."],[8264,8451,"Has anyone ever really loved me?"],[8604,8800,"How could I be so stupid?"],[9323,9384,"Tessa."],[9592,9687,"Don't blame yourself."],[9807,9907,"It's not your fault."],[10084,10151,"Leave him."],[10212,10312,"Stay with me."],[10368,10512,"Come back to me, I promise."],[10523,10700,"I won't let anything happen to you."]],"12":[[800,872,"Tessa!"],[1000,1148,"Tessa, Tessa."],[1264,1335,"Tessa!"],[2471,2803,"It was emotional shock and exhaustion."],[2860,2971,"She's stable now."],[3012,3144,"But she still need to rest."],[3200,3267,"All right,"],[3311,3375,"thanks, doc."],[5164,5371,"Tessa almost married that asshole!"],[5403,5632,"I was going to step back to try and"],[5684,5824,"let her be happy."],[5920,6160,"What an idiot I was..."],[6904,6956,"Tessa,"],[7043,7156,"you're awake."],[7256,7343,"Are you okay?"],[7423,7493,"Asher?"],[8212,8300,"For a second,"],[8300,8500,"I felt we were back three years ago."],[8620,8743,"Before I was abandoned."],[8831,9020,"Before I was cheated on my wedding day."],[9202,9323,"I thought it was all a nightmare"],[9323,9481,"and I could just wake up."],[9607,9720,"But next, you..."],[9820,9892,"Tessa..."],[10007,10079,"Sorry."],[10307,10448,"Please go. I want to be alone."],[10635,10720,"Alright."],[13743,13868,"Mark,"],[14015,14247,"cut all the funding"],[14331,14652,"from the Wilsons to the Sinclairs."],[14675,14868,"I am gonna break Austin."],[14900,15071,"He's gonna go bankrupt."]],"13":[[187,287,"Miss Tessa."],[356,571,"You've recovered remarkably fast."],[620,819,"And you can be discharged now."],[916,1016,"Thank you, Doctor."],[1760,1987,"Thank you, Asher, for everything."],[2232,2376,"I think I should go now."],[2539,2619,"Are you sure?"],[2855,3083,"Your family still needs Austin's money."],[3135,3352,"Probably they want you to get back to him."],[3456,3560,"Or maybe you..."],[3675,3811,"Do you want to get back to him?"],[3828,3952,"No! I would never."],[4200,4360,"My parents wouldn't do that to me."],[4535,4639,"At least my mom..."],[4764,4900,"She always at my side."],[5020,5088,"Yeah."],[5215,5324,"We hope so."],[7604,7804,"Mom, Dad, I..."],[8143,8335,"You run away from your wedding."],[8384,8648,"How dare you bring this disgrace to us."],[8707,8928,"What if Austin cuts off his investments?"],[8979,9087,"Luckily,"],[9179,9428,"he agreed graciously to forgive you."],[9456,9687,"So, you will apologize to him."],[9712,9848,"And tomorrow you'll marry him."],[9935,10000,"What?"],[10120,10215,"Dad, no."],[10300,10420,"He cheated on me."],[10420,10540,"He tried to strangle me."],[10540,10728,"Yeah, you must have driven him to it."],[10928,10992,"Mom?"],[11168,11287,"Say something."],[11823,11892,"Kid,"],[11968,12092,"maybe you should have tried harder to"],[12092,12184,"keep him happy."],[12635,12692,"No!"],[12735,12800,"No!"],[12925,13004,"Come on!"],[13028,13075,"No!"],[13480,13612,"You think too much."],[13636,13771,"When you have your children,"],[13784,14019,"you will stop thinking these naive and"],[14019,14131,"childish thoughts."],[14143,14247,"What are you doing?"]],"14":[[8,187,"Naive and childish thoughts!"],[200,279,"What are you doing?"],[744,940,"You're not going anywhere until"],[940,1075,"Austin shows up."],[1151,1216,"Dad?"],[1280,1391,"Dad, please!"],[1459,1572,"Mom! Dad!"],[1572,1660,"Let me out!"],[1919,2012,"What are you doing?"],[2012,2151,"She must learn."],[2160,2380,"You cannot afford to lose that deal."],[2419,2465,"But..."],[2503,2564,"Honey,"],[2603,2735,"you go downstairs."],[2771,3000,"I'll wait here until Austin comes to pick her up."],[3328,3415,"Austin?"],[3456,3615,"Yeah, I found my daughter."],[3732,3835,"Yeah, she's home."],[3920,4056,"Can you come to pick her up?"],[4111,4400,"She's being a little difficult."],[4456,4611,"Yes, we'll be waiting here for you."],[4692,4800,"No, no way."],[4815,4939,"I can't stay here."],[4988,5100,"I have to find a way out."],[6000,6135,"I can do this."],[6356,6459,"Do this."],[6835,6951,"Yes, Austin."],[7068,7307,"Ah, she's just being emotional."],[7343,7440,"Don't worry."],[7540,7620,"Yes."],[7676,7743,"No problem."],[7804,7892,"Who is take..."],[8092,8212,"Mr. Wilson!"],[8243,8364,"What brings you here?"],[8392,8648,"Have you come to pick up Tessa?"],[8648,8776,"You'll bring her to Austin."],[8792,8887,"Not for him."],[8935,9068,"I'm come here to take Tessa."],[9228,9300,"Where is she?"],[9371,9535,"Oh, I'll bring you right to her!"],[9931,10004,"Tessa!"],[10151,10279,"What are you doing?"],[10304,10384,"Asher?"],[10428,10540,"What's he doing here?"],[10551,10620,"Tessa!"],[10676,10743,"Tessa!"]],"15":[[20,76,"Tessa!"],[775,864,"Are you alright?"],[1267,1427,"Oh my god, Mr. Wilson."],[1488,1567,"Are you okay?"],[1593,1658,"Yep."],[1692,1771,"Tessa,"],[1787,1887,"what the heck?"],[1907,2071,"Are you trying to kill us all?"],[2200,2280,"I'm sorry."],[2432,2519,"Are you hurt?"],[2667,2744,"I'm okay."],[2803,2951,"He's got a thing for Tessa."],[2980,3200,"Asher is way more powerful than"],[3200,3343,"Austin will ever be."],[3471,3660,"Mr. Wilson, I'm so sorry."],[3684,3835,"This is really Tessa's fault."],[3900,3984,"Are you hurt?"],[4024,4243,"I could not sleep if you were."],[4292,4420,"So explain to me,"],[4435,4560,"why your daughter"],[4620,4843,"is climbing on the railing"],[5028,5132,"and falling?"],[5159,5236,"Um..."],[5256,5324,"Yeah."],[5447,5520,"Tessa."],[5588,5788,"Tessa, you explain to Mr. Wilson"],[5788,5967,"what you are doing."],[6003,6139,"Don't forget the family."],[6431,6515,"I'm sorry."],[6579,6684,"It was an accident."],[7207,7451,"Mr. Wilson, this is all Tessa's fault."],[7504,7592,"I'm sorry."],[7692,7812,"I think it'd be best if"],[7812,7987,"Tessa would take you to the hospital now"],[7987,8059,"for check-up."],[8100,8187,"If you're okay..."],[8551,8784,"Yeah, I agree."],[8804,9043,"I think we should take you to the hospital."],[9228,9315,"Alright."],[9864,10112,"Guess Austin is not needed anymore."]],"16":[[400,500,"Where are we going?"],[540,700,"This isn't the way to the hospital."],[736,882,"You think your dad just want us"],[882,1000,"to go to the hospital?"],[1316,1467,"He just sent me a text."],[1712,1776,"Check."],[3588,3671,"I was right."],[3711,3779,"Wasn't I?"],[3847,3915,"Stop."],[3992,4200,"They're trying to sell you to my nephew."],[4224,4456,"You might know they're trying to sell you to me."],[4484,4656,"Okay, then you're right!"],[4671,4779,"Are you happy about it?"],[4880,5027,"My family doesn't love me."],[5027,5104,"You left me."],[5104,5267,"My fiance cheated on me."],[5367,5475,"Nobody loves me."],[5532,5611,"I've had enough."],[5628,5739,"I fucking had enough!"],[5875,5939,"Tessa."],[6020,6075,"Tessa."],[6476,6631,"Don't leave yourself like that."],[6731,6804,"Okay?"],[6900,6976,"You're amazing."],[7112,7228,"They don't deserve you."],[7340,7431,"Stay with me."],[7512,7771,"I promise I am gonna protect you."],[7876,8092,"No one is gonna hurt you when you are with me."],[8264,8392,"What do you want from me?"],[8535,8687,"I just want you to be happy."]],"17":[[1135,1219,"This..."],[1275,1443,"This is exactly my style."],[1543,1683,"He remembered what I like?"],[2187,2264,"Do you like it?"],[2507,2607,"I made this for you."],[2987,3144,"What do you want from me?"],[3224,3367,"I just want you to be happy."],[3615,3739,"Even my own family"],[3739,3971,"only wants to use me to gain something."],[4071,4152,"Take some rest."],[4588,4652,"Wait."],[4720,4800,"Come back."],[5503,5592,"Take off your shirt."],[5615,5739,"Let me check you wounds."],[6103,6200,"I'm not hurting."],[6256,6375,"Every time you lie, you cough."],[6375,6468,"No, take it off."],[7143,7248,"Where's your first aid kit?"],[7382,7460,"There."],[8950,9071,"Oh my God."],[9212,9279,"Gunshots?"],[9328,9420,"Knife wounds?"],[9464,9587,"Asher, what really happened?"],[10040,10192,"Are you worried about me, Tessa?"],[10279,10428,"You need to take care of yourself."],[10900,11048,"I wasn't thinking that far."],[11276,11464,"Just didn't want you to get hurt."]],"18":[[283,352,"Do you like it?"],[428,532,"I made this for you."],[659,791,"I wasn't thinking that far."],[1003,1200,"Just didn't want you to get hurt."],[1432,1511,"Asher..."],[1572,1719,"Can I trust you again?"],[2155,2244,"Oops..."],[2244,2423,"Why's that pile of trash on the floor?"],[2492,2612,"The jilted bride,"],[2612,2812,"the laughing stock of the whole city!"],[2819,3023,"Some people think they can catch a rich man."],[3035,3264,"But they're just toys to be discarded."],[3775,3900,"Hey, tell us,"],[3911,4111,"what's it like to see your fiancé"],[4111,4332,"screwing someone else on your wedding day?"],[5260,5415,"I think maybe you should tell us"],[5415,5552,"what it feels like to screw"],[5571,5803,"older men to climb the corporate ladder."],[5900,5967,"What?"],[5988,6167,"How the hell did you know?"],[6300,6468,"You fucking bitch!"],[6720,6840,"I wouldn't do that"],[6876,6987,"if I were you."]],"19":[[0,132,"I wouldn't do that"],[163,283,"if I were you."],[616,716,"Mr. Wilson,"],[716,972,"we're just joking around, just nurse humor."],[983,1111,"I saw everything."],[1367,1503,"You guys are bullying her."],[1832,1923,"You're fired!"],[1944,2116,"No, Mr. Wilson."],[2123,2192,"Please!"],[2212,2267,"Please!"],[2707,2867,"Please, no! No!"],[3080,3183,"What about you two?"],[3271,3400,"You guys have nothing to do?"],[3467,3632,"Leave your job!"],[4256,4432,"This hospital is frustrating."],[4635,4807,"I mean, not you."],[4924,5000,"Are you okay?"],[5211,5400,"I have something have to tell you."],[6267,6375,"Thank you."],[6831,6923,"Tessa."],[8000,8143,"It's a public space,"],[8200,8292,"not here."],[8359,8484,"No one's gonna come back."],[10200,10343,"I'll pick you up later."],[10459,10600,"And I have a surprise for you."],[10700,10800,"A surprise?"],[10823,11004,"Yeah. You'll see."],[11112,11176,"Take care."]],"20":[[1156,1224,"Asher?"],[2483,2728,"Why are you behaving like you're committing a crime?"],[3007,3196,"Everybody knows I was engaged to Austin."],[3356,3567,"They'll see us, and it's just going to be a mess."],[3639,3807,"Don't mention that bastard."],[4028,4128,"So..."],[4211,4311,"Why are you here?"],[4339,4507,"Is there anything you need?"],[4760,4828,"Yeah."],[4939,5007,"I mean..."],[5100,5203,"I was just hoping"],[5235,5371,"to have a dinner with you."],[5539,5660,"It would be an honor for me."],[6384,6443,"Wait."],[6523,6635,"Is this a date?"],[8343,8568,"How did you know those are my favorite foods?"],[8668,8735,"Try it."],[8840,9059,"Let's see if all my practice paid off."],[9248,9456,"Wait, did you cook all of these?"],[9507,9568,"Yes."],[13100,13187,"Tessa."],[13475,13808,"These past three years were pretty hard."],[14059,14256,"I kept thinking about this moment."],[14375,14463,"That's why"],[14500,14700,"I wanted to make you a surprise."],[14840,14987,"Make you feel like some..."],[15024,15108,"excitement?"],[15108,15168,"Maybe?"],[15428,15512,"Tessa?"],[15643,15703,"Tessa."],[16003,16087,"Look at me."],[16343,16456,"I promise you."],[16659,16819,"No one is gonna tear us apart."],[17491,17615,"You're so cute."]],"21":[[387,567,"Come on."],[736,859,"Here are some painkillers."],[1032,1111,"Thank you."],[2219,2264,"I don't know why"],[2264,2551,"I've been feeling so bad lately."],[2564,2667,"In which way?"],[2739,2839,"I mean,"],[2839,3000,"just the headaches"],[3000,3077,"and the nausea."],[3324,3464,"You went out of your way"],[3464,3656,"to create this romantic dinner,"],[3656,3820,"and I just ruined it."],[3852,3932,"Don't say that."],[4756,4888,"Just being with you,"],[4892,5100,"doesn't matter what you do,"],[5107,5288,"for me is enough."],[6252,6396,"Deliver this file"],[6396,6500,"to this address."],[6512,6576,"It's urgent,"],[6576,6723,"and you're the only one free."],[6851,6985,"This is not my job."],[7081,7242,"Well, today it's yours."],[7304,7405,"Get it done."],[8787,8868,"Hello."],[8935,9043,"Hello, darling."],[9128,9279,"Long time no see."]],"22":[[235,379,"Where are you going?"],[451,663,"We haven't even had a chance to catch up."],[779,927,"Austin, what are you doing?"],[1029,1196,"I couldn't find you after the wedding."],[1332,1440,"Even your dad"],[1440,1575,"wouldn't return my calls."],[1807,2080,"I make a small mistake"],[2080,2219,"and because of you,"],[2335,2507,"I lose all my uncle's shares!"],[2571,2707,"And you must"],[2726,2912,"help me get that money back."],[3076,3176,"I'm never gonna"],[3176,3260,"get back with you."],[3260,3311,"Let me go!"],[3403,3567,"You can act tough"],[3571,3732,"all you want."],[3764,3896,"But when you're pregnant"],[3896,3988,"with my child,"],[4128,4328,"then there's nothing you can do."],[4328,4564,"I will own you."],[4647,4728,"Asher!"],[4943,5164,"Don't use my uncle's name"],[5164,5292,"to try to scare me."],[5292,5600,"You are a pathetic nobody!"],[5679,5864,"And I should've despised you."],[5864,6132,"Even my uncle couldn't even"],[6132,6267,"take a second glance at you!"]],"23":[[32,108,"Tessa!"],[148,204,"Tessa,"],[204,268,"are you okay?"],[440,571,"I was so scared."],[779,924,"What the fuck?"],[1051,1424,"Asher Wilson, stealing my fiancée?"],[2416,2548,"You don't get to have"],[2548,2669,"what you don't appreciate."],[2732,2900,"I knew her before you two."],[2955,3060,"What do you mean?"],[3132,3303,"Think about that in the prison."],[3364,3411,"Guys!"],[3530,3654,"I'll kill both of you."],[3666,3788,"You'll regret this!"],[4252,4447,"Tessa! Tessa!"],[5179,5384,"Tessa almost married that asshole."],[5443,5664,"I was going to step back to try and..."],[5724,5884,"let her be happy."],[5964,6164,"What an idiot I was."],[7843,8031,"Asher, darling!"],[8059,8176,"Guess who's back?"],[8187,8448,"Tina Thomson! Your first love."],[8464,8512,"What?"]],"24":[[32,139,"What?"],[139,327,"Who told you she's my first love?"],[348,583,"Come on, don't be shy."],[583,859,"I know you've been waiting for her all these years."],[891,1191,"She's the reason you joined the army, after all."],[1267,1448,"Mom, you are talking nonsense."],[1508,1800,"Ain't a single word that you say is true, alright?"],[1819,2192,"Really? What's the harm in meeting her?"],[2228,2371,"She's a good girl"],[2371,2564,"and you two grew up together."],[2576,2692,"You'll like her."],[2692,2987,"You haven't had a girlfriend in so long."],[2987,3151,"I'm worried about you..."],[3203,3407,"Mom, I already have a girlfriend."],[3460,3743,"What? Hey, don't try to lie to me!"],[4532,4700,"Tessa! Tessa!"],[4700,4847,"Wake up!"],[5520,5675,"I had a terrible dream..."],[5700,5790,"Don't be scared."],[5900,6000,"I'm here."],[6035,6300,"Please don't leave me. Stay with me."],[6339,6456,"I won't leave you."],[6571,6871,"I'll stay here as long as you want me to stay."],[6920,7098,"I wish you never left."],[7864,8035,"I know it's hard to forget"],[8035,8223,"all these three years that passed."],[8271,8540,"But please, let's make an effort."],[8623,8740,"I promise,"],[8820,8971,"I will never leave you again."],[9204,9579,"Tessa, I hope you never find out what I've done."],[10643,10704,"Hello?"],[10851,10951,"Who is this?"],[10987,11104,"Where is my son?"]],"25":[[24,184,"Oh my god. I'm talking to Asher's mom."],[184,343,"What do I respond?"],[343,583,"Um, actually..."],[824,1100,"Mom, I told you last night."],[1224,1319,"I have a girlfriend."],[1411,1664,"What? You really have a girlfriend?"],[1707,1839,"Are you home right now?"],[1839,1944,"I'm coming over!"],[2107,2300,"Your mom, she is coming now?"],[2360,2580,"Um, what should I wear?"],[2623,2776,"What's she gonna think about me?"],[2819,3023,"Asher, I don't think I can meet your mom."],[3023,3267,"She, um... What if she hates me?"],[3388,3484,"She'll love you."],[3584,3803,"Just be yourself, alright?"],[4371,4592,"Even though I haven't met Mrs. Wilson,"],[4639,4879,"does she know I'm Austin's ex-fiancée?"],[5239,5600,"Mom, this is my girlfriend, Tessa."],[5811,5975,"Hello, Mrs. Wilson."],[6220,6364,"My son"],[6428,6576,"finally has a girlfriend."],[6640,6720,"Here."],[6851,6976,"Take this."],[7092,7215,"I can't accept..."],[7328,7400,"Yes."],[7520,7668,"From the moment I saw her,"],[7704,7923,"I just got these warm feelings,"],[7956,8156,"as though we had already met."],[8331,8400,"Wait."],[8523,8835,"Your face looks familiar."],[8985,9156,"Have we met before?"],[9300,9415,"Maybe..."],[9487,9679,"at an engagement party?"]],"26":[[76,416,"I- I don't think so."],[548,620,"Well."],[687,875,"It doesn't matter. It's not important."],[948,1235,"You must have just one of those faces."],[1564,1633,"If she finds out"],[1633,1736,"that I am Austin's ex-fiancée,"],[1736,1855,"she is gonna hate me."],[1890,1978,"Don't worry about that."],[2014,2119,"I'll handle everything"],[2183,2276,"while you love me."],[3467,3700,"She is a lovely nurse."],[3735,3929,"And Tina, I have never seen him"],[3929,4200,"like this with anybody, not even you."],[4652,4792,"How wonderful for him."],[4967,5111,"Which family is she from?"],[5175,5243,"A Cabot?"],[5303,5592,"Oh, I was so excited I forgot to ask."],[5660,5775,"But it doesn't matter."],[5811,6056,"As long as they love each other,"],[6092,6207,"that's enough."],[6239,6435,"It doesn't matter who she is."],[6443,6600,"Asher is mine."],[6628,6787,"He's always been mine."],[6820,7059,"This nobody will learn her place."],[7812,7960,"He's been so busy lately,"],[7960,8119,"we haven't seen each other much."],[8228,8364,"I want to surprise him."],[8651,8740,"Can I help you?"],[8771,8931,"I'm here to see Asher Wilson."],[9043,9164,"Do you have an appointment?"],[9164,9307,"If not, I can't let you in."],[9564,9820,"Ms. Thomson! Good morning!"],[9984,10271,"I'm sorry. I forgot to make an appointment."],[10328,10376,"May I go up?"],[10400,10492,"Of course!"]],"27":[[20,82,"Wait, wait, wait."],[82,339,"How does she get to go up without an appointment?"],[375,483,"Are you kidding me?"],[500,655,"Do you know who she is?"],[700,843,"Tina Thomson!"],[856,1027,"Asher's childhood sweetheart."],[1027,1222,"Everyone knows they're going to get married."],[1319,1383,"Married?"],[1644,1867,"Don't spread rumors about uncertain things."],[1935,2183,"I guarantee it. It's going to happen."],[2255,2335,"So..."],[2567,2628,"You are..."],[2676,2771,"I'm Tessa."],[2851,2980,"Tessa Carter."],[3092,3224,"I'm Asher's girlfriend."],[3388,3620,"Oh wow, another delusional one."],[3652,3971,"You don't expect me believing that, do you?"],[4152,4203,"Oh!"],[4432,4599,"Asher's mother mentioned that before."],[4732,4884,"Let me take you to his office."],[4932,5032,"I know the way."],[6542,6771,"He should be back from his meeting soon."],[6807,7023,"So, make yourself comfortable."],[7115,7328,"She seems to know where everything is."],[7384,7543,"Auntie said,"],[7543,7790,"Asher needs someone who understands his world."],[7835,8015,"It's a lot of pressure, you know?"],[8115,8248,"It's not for everyone."],[8423,8743,"Especially useless women"],[8768,9012,"who know nothing but how to cook."]],"28":[[208,324,"What are you talking about?"],[360,471,"I mean,"],[548,748,"not just every girl"],[748,1059,"gets to call herself Asher's girlfriend."],[1127,1300,"He might keep you for fun."],[1380,1543,"But wife material?"],[1639,1716,"Please."],[1728,1903,"You know nothing about me."],[1948,2112,"And you know nothing about Asher."],[2167,2328,"He would never do this to me!"],[2351,2500,"Oh my god."],[2516,2800,"Another delusional fantasist."],[4347,4547,"Asher, darling!"],[4600,4735,"I brought you a visitor."],[5339,5579,"Tessa, what are you doing here?"],[5992,6152,"So you brought lunch for us."],[6548,6600,"Tina,"],[6759,6879,"here's the contract."],[6907,7104,"There's every single detail here,"],[7131,7200,"all right?"],[7284,7407,"Mark is gonna handle it for you."],[7407,7535,"But Asher,"],[7612,7807,"I thought we would discuss the final points."],[7904,7964,"Mark."],[8492,8576,"Handle it."],[8635,8784,"Miss Thompson, come with me, please."]],"29":[[339,640,"Wow, this is better than a five star hotel."],[891,983,"I'm glad you like it."],[1411,1739,"Um, can I ask you something?"],[1767,1839,"Sure."],[1871,2171,"It's about Tina and you."],[2192,2292,"The receptionist said"],[2292,2471,"that you two are getting married."],[2544,2723,"Tina and I, we have nothing."],[2864,3247,"Our family, all the time, try to keep us together."],[3324,3543,"But I don't love her. Trust me."],[3575,3729,"She just seems so familiar"],[3729,3888,"with all of your preferences."],[3907,4000,"Are you jealous?"],[4047,4107,"No!"],[4143,4339,"See, don't be jealous."],[4400,4528,"I'm all yours."],[4592,4688,"I love you."],[4747,5003,"By the way, you can't leave."],[5047,5367,"Today, we're gonna bring you to a special place."],[5552,5652,"Where are we going?"],[5732,5884,"You'll see later."],[5884,5984,"It's a surprise."],[6692,6823,"Where are you taking me?"],[6943,7015,"Just wait."]],"30":[[1100,1240,"This is for me?"],[1516,1680,"Asher, this is amazing."],[1855,1960,"Thank you."],[2564,2651,"Tessa."],[2792,2948,"I know I hurt you before."],[3062,3193,"But trust me,"],[3193,3312,"during these three years,"],[3312,3471,"I couldn't sleep well."],[3739,3960,"I still have your side on my bed."],[4284,4420,"Couldn't forget you for..."],[4532,4635,"any second."],[5967,6100,"Will you still marry me?"],[6471,6671,"Asher, when I saw you again, I..."],[6804,6964,"I didn't think I can trust you."],[7023,7176,"I thought that Asher I knew..."],[7276,7451,"It's just a facade."],[7556,7700,"But the more time I spend with you,"],[7700,7923,"the more I know that..."],[8028,8140,"you're the man I love."],[8240,8343,"So yes, I'll..."],[8379,8479,"I'll marry you."],[8887,8971,"Give me your hand."],[12900,12984,"Austin."],[13047,13359,"I've been through hell to bail you out, so please!"],[13403,13584,"That bastard..."],[13584,13896,"He thinks he can take everything from me."],[13963,14231,"My fiance, my reputation."],[14291,14619,"He'll pay, they both will!"],[15428,15528,"Slut!"],[15615,15731,"What did you just say?"],[15847,16003,"Don't play innocent, Tessa."],[16003,16109,"Everyone knows here"],[16109,16279,"that you were using the poor Austin"],[16279,16456,"to get closer to Asher."],[16484,16611,"What are you talking about?"]],"31":[[24,76,"Sir,"],[139,296,"the stock is down 15%."],[356,520,"The board is calling an emergency meeting,"],[555,691,"saying it's a moral crisis."],[728,891,"Austin's been spending rumors"],[891,1034,"saying you murdered your father"],[1056,1148,"to seize power."],[1183,1267,"Block all the news!"],[1327,1467,"Don't let Tessa knows about that."],[1516,1596,"Of course, sir."],[1948,1992,"Mom."],[2080,2176,"What are you guys doing here?"],[2248,2451,"Have you lost your mind?"],[2576,2855,"Marrying your nephew's ex-fiancée."],[2919,3160,"You've made our family a laughing stock."],[3324,3503,"Break up with her immediately."],[3524,3624,"Austin cheated on her."],[3671,3779,"They never get married."],[3824,3907,"They broke up."],[4011,4128,"We were together since then."],[4220,4396,"You two shouldn't be together anyway."],[4467,4567,"How do you know"],[4684,4971,"that she didn't just get close to Austin"],[4971,5067,"to get to you?"],[5196,5239,"Auntie."],[5388,5464,"Don't be angry."],[5520,5600,"Maybe"],[5660,5764,"there is a way to fix this?"],[5896,5988,"We could announce"],[6035,6200,"that I'm his real fiancée"],[6275,6442,"just to satiate the press."],[6442,6559,"A temporary solution."],[6623,6835,"Now that is a good idea."],[6892,6995,"Absolutely not."],[7271,7428,"I'm just trying to help."],[7468,7595,"I care about you, Asher."],[7604,7768,"I don't need anyone's help."],[7876,8056,"I don't need a fake fiancée."]],"32":[[0,167,"I did everything for Tessa."],[239,324,"She's my meaning."],[360,528,"You stubborn fool!"],[628,800,"You spent three years"],[835,1000,"to get control of the Wilson Group."],[1040,1343,"And now you want to throw it all away."],[1372,1603,"I did everything for Tessa."],[1648,1748,"Without this,"],[1807,1912,"not a single thing"],[1983,2096,"has meaning."],[2807,3092,"Asher is be blindsided by that"],[3151,3288,"shaming bitch!"],[3488,3575,"Auntie."],[3624,3871,"Asher won't listen to anyone else right now."],[4020,4160,"But"],[4256,4471,"maybe we can fix this from a different angle."],[4764,4807,"Yes,"],[4896,4952,"don't worry."],[5000,5124,"You buy as much as they sell."],[5564,5620,"Asher?"],[6075,6147,"What's wrong?"],[6275,6328,"Can't sleep?"],[6435,6471,"Asher,"],[6507,6640,"how bad is the situation?"],[6843,6943,"There's no problem."],[7015,7100,"I've just heard it."],[7195,7276,"Don't you trust me?"],[7964,8056,"Everything's gonna be alright."],[8423,8512,"I promise."],[8607,8664,"Alright?"],[10300,10448,"But things didn't resolve quickly."],[10528,10787,"Asher is incredibly busy and I hardly see him."],[10892,11007,"I can handle the gossip,"],[11035,11284,"but what I can't handle is what this might do to him."],[12068,12179,"No, this isn't true."],[12287,12384,"It has to be a lie."],[12771,12875,"Tessa, we need to talk."]],"33":[[187,339,"I'm sure you've seen the news."],[567,700,"That story about Tina and Asher?"],[843,916,"That's not true."],[1259,1372,"Have a look at these numbers."],[1475,1623,"Asher's company stock."],[1776,1923,"The sharp drop"],[1951,2216,"is when you announced your engagement"],[2319,2432,"and the rise"],[2432,2632,"is after the news of Tina came out."],[2732,2860,"The entire market,"],[2903,2987,"his family,"],[3019,3060,"and..."],[3112,3356,"The entire world prefers her,"],[3588,3747,"and Tina can help him."],[3796,4026,"Her family, her connections,"],[4096,4238,"they are an asset."],[4271,4503,"Whereas you, my dear, are a liability."],[4564,4664,"And yes,"],[4724,4852,"you make Asher"],[4903,5103,"happy and that has value."],[5300,5588,"That won't solve our problems."],[5703,5888,"Are you asking me to break up with him?"],[6060,6175,"Asher's father"],[6220,6364,"was terrifying."],[6443,6551,"And Asher"],[6643,6879,"made a lot of enemies when he"],[6931,7059,"cleaned up the Wilson Group."],[7123,7251,"So please,"],[7292,7423,"don't be the reason"],[7468,7656,"that he loses everything"],[7864,8059,"that he has worked so hard for."],[8168,8228,"If I do it..."],[8464,8568,"if I leave him,"],[8715,8820,"will he be saved?"],[8979,9123,"Will this crisis be over?"],[9351,9451,"You have my word."],[9715,9856,"Okay, I..."],[10179,10284,"I will do it."],[10321,10371,"Mm."],[10420,10535,"I'll break up with him."]],"34":[[628,811,"Babe."],[811,975,"I brought you this."],[1707,1823,"Tessa, what's going on?"],[1896,2137,"I'm sure we're done. I'm leaving."],[2244,2432,"It has to be my mom."],[2580,2770,"Did she force you into this?"],[2770,3027,"Force me? No."],[3137,3233,"She paid me."],[3367,3524,"And I happily accept it."],[3724,3815,"I can start somewhere new."],[3863,3967,"No, this isn't true."],[4032,4179,"No, no, no, no, no."],[4215,4319,"I don't believe you."],[4403,4507,"I think you're lying to me."],[4535,4640,"Believe what you want."],[4715,4871,"I never loved you."],[5335,5388,"What did you say?"],[5484,5535,"I am-"],[5635,5715,"I used you"],[5715,5769,"I used you"],[5790,5967,"to get away from Austin and my family."],[6147,6260,"But being with you caused me"],[6260,6388,"more pain than anything else!"],[6784,6835,"I'm done."],[6979,7043,"I'm done pretending."],[7392,7495,"I never loved you."],[7751,7771,"Yeah?"],[7879,8200,"Then look at my eyes and say it."],[8568,8648,"You can't."],[8748,8815,"You won't."],[8931,9131,"I have to make him hate me."],[9171,9397,"This is the only way to end all of this mess."],[9620,9776,"I never loved you."],[9935,10090,"Not even for a second."],[10228,10318,"What did you say?"],[10679,10787,"Don't touch me!"]],"35":[[0,241,"Don't ever touch me again!"],[300,416,"You hate me that much?"],[500,704,"You don't know what it's like to"],[704,820,"pretend that you love somebody?"],[950,1095,"Every single hug,"],[1095,1423,"every kiss, makes me sick to my stomach."],[2080,2209,"We're done."],[2274,2442,"Go back to your perfect life,"],[2570,2825,"and don't ever call me again."],[4110,4250,"She's lying to me."],[4367,4486,"She has to be lying."],[4525,4895,"I'm so sorry, Asher. So sorry..."],[5412,5779,"Oh, the great pretender get dumped again."],[5779,6012,"Some people are just born to be abandoned."],[6012,6116,"If I were her,"],[6145,6420,"I'll be too ashamed to show my face here."],[6691,6826,"Who do you think you are?"],[6861,6943,"Your sugar daddy"],[6943,7134,"is not around here anymore to save you."],[7691,7862,"What are you doing?"],[7916,8091,"How dare you mock me like that!"]],"36":[[948,1067,"What's going on here?"],[1067,1264,"Miss Thomson, what brings you here?"],[1291,1408,"I'm helping Asher"],[1408,1524,"to handle a few things."],[1588,1683,"He's been so busy."],[1744,1944,"You and Mr. Wilson are so close."],[2128,2203,"Tessa?"],[2339,2392,"Are you sick?"],[2467,2635,"I think I saw you gagging just now."],[3155,3307,"I think I have a cold."],[3432,3611,"Anyway, there's somewhere I have to be, so..."],[3964,4200,"Oh! My bracelet is missing!"],[4200,4439,"It's a family heirloom! Oh no!"],[4524,4632,"When did you last see it?"],[4671,4820,"Right before she showed up!"],[4860,5063,"Now you're saying that I stole your bracelet."],[5092,5271,"That's ridiculous."],[5303,5466,"Why are you so defensive?"],[5492,5639,"If you have nothing to hide,"],[5739,5935,"let us look in your box."],[6164,6275,"Enjoy."]],"37":[[70,195,"There it is!"],[254,379,"I knew it!"],[420,526,"You're a thief!"],[712,789,"I..."],[862,1083,"Somebody else put it in the box, but I..."],[1125,1191,"Calm down."],[1321,1412,"Listen,"],[1491,1705,"if you needed money,"],[1705,1859,"you should have just asked."],[1910,2087,"Stealing is not the answer."],[2208,2362,"But I didn't steal anything!"],[2391,2554,"Go and check the security footage."],[2600,2762,"Oh no!"],[2762,3054,"The security cameras are broken!"],[3100,3265,"I'm calling the police!"],[3462,3650,"It was you, wasn't it?"],[3650,3887,"You put the bracelet in my box."],[3966,4179,"Do you have any evidence?"],[4233,4429,"The security cameras here are broken."],[4491,4658,"We had enough of you acting here."],[4658,4845,"Anyone else here?"],[5187,5354,"You shameless!"],[5354,5625,"You probably stole from others too!"],[5625,5747,"Take off your clothes!"],[5757,5970,"We need to be sure that there is nothing!"],[6025,6212,"This is ridiculous!"],[6212,6375,"Miss Thomson,"],[6395,6582,"you can't let them bully me like this!"],[6600,6758,"Tessa,"],[6795,7058,"Lily's request is reasonable."],[7058,7254,"Especially after what you did."],[7369,7483,"Don't worry."],[7529,7745,"They'll let you go once they're finished checking."],[7816,7881,"What?"],[7966,8163,"No! Get off me! No!"],[8816,9020,"This is what you get"],[9020,9212,"for trying to steal my man."]],"38":[[25,133,"Get away from me!"],[135,191,"No!"],[252,321,"No!"],[341,408,"Let her go!"],[620,708,"Asher!"],[900,1129,"What are you doing here?"],[1129,1391,"Weren't you supposed to be in the meeting?"],[1550,1733,"I thought I made myself clear."],[1808,2054,"If I would catch any bullies here,"],[2237,2579,"you will be blacklisted from the Wilson Group."],[2633,2870,"Mr. Wilson, we weren't bullying her."],[2912,3062,"We caught Tessa stealing."],[3104,3245,"My bracelet was in the box."],[3400,3466,"Mark."],[3633,3754,"Check the security cameras."],[3866,4025,"The cameras here are broken."],[4108,4220,"After the last incident,"],[4475,4745,"I bought a backup."],[4800,4931,"So we can check the footage."],[4975,5095,"If you don't tell me the truth,"],[5095,5223,"we can check the footage."],[5279,5450,"And this can become a criminal matter."],[5545,5700,"We're going to give you five seconds"],[5700,5813,"to tell me the truth."],[5912,5941,"Five."],[6283,6312,"Four."],[6820,6845,"Three."],[6908,7148,"I'm sorry! I'm sorry, I'm so sorry."],[7175,7407,"It's... it must have been a mistake."],[7470,7575,"The... the bracelet..."],[7575,7778,"the bracelet must've fallen into her box."],[7816,7897,"Mistake?"],[7925,7982,"Yeah."],[8153,8264,"Doesn't matter anymore."],[8404,8474,"I'm out of here."],[8770,8968,"She never wants to see me again."]],"39":[[300,383,"You know what?"],[430,548,"Doesn't matter."],[648,724,"I'm out of here."],[1319,1419,"Asher."],[1671,1800,"You look terrible."],[2135,2264,"Don't let her get to you."],[2419,2555,"She's not worthy."],[2900,3019,"Don't touch me."],[3151,3264,"I'm warning you."],[3367,3652,"Stop to play these little games."],[3792,3932,"What are you talking about?"],[4020,4139,"I don't understand."],[5039,5200,"This footage shows"],[5247,5507,"you spoke with that nurse two days ago."],[5603,5788,"You did all these things"],[5788,5935,"just to humiliate Tessa."],[6220,6415,"I don't understand what you are talking about."],[6528,6659,"That was a private matter."],[6748,6820,"Doesn't matter."],[7043,7279,"Stop to tell people that you are my fiancée."],[7359,7476,"You mean nothing to me."],[7823,7907,"Asher."],[7971,8223,"I'll prove that we belong together."],[9143,9248,"The nausea..."],[9328,9431,"The exhaustion..."],[9615,9723,"Could I be pregnant?"]],"40":[[184,312,"Please not now."],[360,540,"Not when everything's falling apart."],[775,851,"Pregnant?"],[924,1011,"I'm pregnant."],[1064,1186,"What do I do? I..."],[1190,1283,"I can't tell Asher"],[1283,1480,"if he's just getting his life back and..."],[1480,1744,"baby, especially a scandal baby would destroy him."],[2060,2123,"Tessa."],[2223,2360,"You look terrible."],[2360,2476,"Are you okay?"],[2476,2651,"What were you doing in the bathroom so long?"],[2864,2967,"I am cleaning my mind."],[3051,3164,"I'm just tired."],[3425,3556,"No, Mom! No!"],[3603,3764,"Tessa Carter!"],[3803,3947,"What is this?"],[3947,4052,"Are you pregnant?"],[4079,4215,"Is it Asher's baby?"],[4415,4520,"Please don't ask."],[4767,4875,"Mom, where are you going?"],[5015,5180,"Asher needs to take responsibility"],[5180,5267,"for his baby."],[5367,5667,"No, I can't be a burden to him."],[5715,5903,"I can raise this baby myself."],[5932,6120,"Raise this baby yourself?"],[6167,6252,"Tessa."],[6300,6448,"Once your father finds out,"],[6448,6600,"he's going to use this baby to get"],[6600,6784,"back into business with the Wilsons."],[6871,6992,"He'll never leave you be."],[7004,7135,"I'm gonna go to London."],[7264,7406,"I'm gonna start over somewhere"],[7406,7545,"where nobody knows me."],[7764,7887,"Mom, please."],[7959,8148,"I've never asked you for anything."],[8207,8400,"I can't stay here anymore."],[8515,8787,"Everything just reminds me of him."],[8868,8992,"Mom, please."],[9012,9135,"Don't tell anybody."],[9407,9479,"Please."]],"41":[[2389,2498,"Goodbye, Asher."],[2606,2761,"I hope you find someone who can"],[2761,2911,"make you happier than I ever could."],[3369,3446,"Sir."],[3446,3582,"The arrangements are complete."],[3582,3677,"The shareholders will"],[3677,3791,"be silenced soon enough."],[4016,4141,"Make sure that shareholders"],[4141,4329,"don't get any funny ideas."],[4496,4721,"Cornered dogs bite."],[4888,4963,"Tessa,"],[4967,5117,"I don't believe you"],[5117,5338,"would ever do this to me."],[5409,5492,"This scandal"],[5492,5659,"will be over soon."],[5743,5855,"I will find out you again."],[5872,6072,"By the way, how is Tessa going?"],[6089,6356,"Ever since Miss Tessa resigned,"],[6373,6519,"she's been staying in her house,"],[6556,6694,"hasn't stepped out once."],[6694,6810,"Can't wait to see her."],[6977,7176,"I want her in my arms again."],[7340,7486,"Hello, Mr. Wilson,"],[7486,7624,"this is Tessa's mother."],[7624,7701,"I have something"],[7701,7803,"I want to ask you."],[7887,8053,"Please answer me seriously."],[8070,8204,"Mr. Wilson,"],[8208,8304,"do you love Tessa?"],[8450,8529,"Yes."],[8700,8792,"I love Tessa."],[8954,9113,"More than anything in this world."],[9280,9392,"More than everything."],[9755,9826,"It's been a while"],[9830,9959,"that we don't talk,"],[9959,10055,"is she okay?"],[10185,10260,"Mom?"],[10370,10498,"She's at the airport."],[10498,10710,"She's about to leave for London."],[10764,10825,"What?"]],"42":[[216,559,"...447 to London is now boarding."],[717,1013,"...447 to London is now boarding."],[1493,1589,"I just want to hear"],[1589,1810,"his voice one last time."],[2882,2961,"Tessa."],[3015,3147,"Mr. Wilson, I..."],[3166,3277,"Listen to me,"],[3277,3449,"stay where you are."],[3457,3620,"I'm going to pick you up,"],[3620,3691,"alright?"],[3749,3828,"Hey."],[3887,4029,"How did you know?"],[4045,4204,"Your mom told me everything."],[4204,4358,"I know about your baby,"],[4358,4437,"alright?"],[4437,4579,"We can go home together."],[4717,4808,"Asher, I can't."],[5080,5263,"I will be a burden to you."],[5321,5423,"You have to meet somebody"],[5423,5526,"who's on your level."],[5618,5697,"No, Tessa,"],[5726,5885,"you're not a burden to me."],[5889,6022,"You're the best thing I ever had."],[6068,6151,"Trust me."],[6247,6297,"I'm coming,"],[6352,6431,"alright?"],[6498,6598,"I love you."],[6677,6731,"Asher!"]],"43":[[492,585,"A car accident..."],[592,696,"Asher Wilson,"],[696,838,"is he here?"],[842,934,"Over there."],[1005,1426,"I looked that he just came out of the OR."],[1426,1683,"Okay, thank you."],[1772,1864,"No, no."],[2085,2164,"No."],[2339,2574,"Why did you have to take him away from me?"],[2590,2802,"I didn't even have the chance to tell him."],[3749,3832,"Tessa."],[3966,4099,"Why are you sitting on the ground?"],[4158,4260,"Asher!"],[4356,4443,"Asher..."],[4671,4825,"I thought I lost you."],[4909,5009,"Are you okay?"],[5059,5134,"Yes."],[5209,5452,"The doctor said I was lucky."],[5576,5751,"It's just a superficial wound."],[6222,6302,"Mom?"],[7002,7086,"Mrs. Wilson."]],"44":[[41,112,"Mom."],[157,354,"doesn't matter what you say or do,"],[392,588,"I won't leave Tessa this time."],[633,750,"I love her,"],[821,1017,"and I'm gonna stay with her forever,"],[1055,1184,"in this life and the next."],[1480,1578,"Mrs. Wilson, I..."],[1643,1768,"I'm sorry."],[1810,1981,"I can't leave Asher."],[2135,2260,"When I almost lost him,"],[2377,2515,"I had so much pain."],[2515,2773,"I wanted to rip my heart out of my chest."],[2861,3015,"I can't go through this again."],[3244,3570,"I didn't come here to make you break up."],[3753,4012,"I just came to know if you're okay, Asher."],[4091,4254,"And now I realize that"],[4300,4491,"you mean so much to each other..."],[4521,4742,"I was only trying to protect my son."],[4938,5050,"And in the meantime,"],[5255,5484,"it seems I almost ruined his life."],[6840,7015,"I can't say I forgive you."],[7015,7136,"It'll take time."],[7357,7468,"But I believe you're gonna be"],[7468,7665,"a wonderful grandmother."],[7770,7863,"What?"],[7974,8204,"Oh my goodness."],[8204,8341,"A grandmother?"],[8470,8779,"I can't believe I almost ruined my own happiness."],[9455,9667,"This isn't over."],[9734,10068,"I'll make sure they never have their happy ending."],[10181,10319,"I'm thinking it's"],[10456,10660,"time for a change of leadership."],[10735,10840,"Austin,"],[10840,11006,"you're not even supposed to be here."]],"45":[[25,158,"Even if Asher"],[166,316,"is embroiled in a scandal,"],[321,504,"you'll never be the CEO!"],[592,746,"I propose that I can."],[809,896,"You?"],[905,1059,"Don't even think about it."],[1284,1409,"Asher."],[1680,1864,"You're supposed to be in a hospital."],[2114,2223,"Hey, what the hell?"],[2223,2318,"Let go of me!"],[2627,2715,"Well, well."],[2831,3007,"Seems that"],[3007,3186,"there's a lot of tension here, right?"],[3461,3651,"Have you guys made any decision yet?"],[3651,3691,"You?"],[3770,3903,"You shouldn't even be here."],[3978,4091,"Shareholders,"],[4091,4204,"he's unfit to lead."],[4254,4400,"He has a point."],[4404,4521,"The scandal"],[4521,4654,"has been a disaster."],[4679,4779,"Oh yeah,"],[4808,4938,"let's talk about disaster,"],[4938,5038,"Mr. Bennet."],[5122,5264,"What about your"],[5280,5499,"undercover accounts in Panama,"],[5551,5751,"undeclared?"],[5751,5889,"And you, Mr. Lee."],[5922,6068,"What about your"],[6068,6222,"little adventures"],[6264,6510,"that you do in the condo"],[6552,6652,"for your mistress."],[6702,6973,"So there's anyone else here"],[6977,7182,"who want to share any opinion?"],[7365,7457,"Say it."],[7545,7628,"I do."],[7657,7899,"You stole my fiancée."],[9572,9680,"Cheating on your fiancée"],[9759,9914,"on your wedding night."],[9914,10118,"This proves you are not a man."],[10172,10318,"You'll regret this decision."],[10335,10564,"You'll wish you never laid eyes on Tessa!"],[11448,11603,"If it wasn't for her,"],[11711,11932,"I wouldn't be like this."],[12354,12441,"Let's talk."]],"46":[[12,116,"Oh."],[137,271,"-I'm feeling here. -Mm-hmm."],[375,509,"Oh, she's moving."],[829,1005,"Can't wait our baby to be born."],[1167,1247,"Me too."],[1655,1847,"You're always taking such good care of me."],[2243,2414,"Sacrificing yourself,"],[2494,2615,"going to the company,"],[2615,2736,"planning the wedding."],[2890,3011,"You must be exhausted."],[3132,3357,"Don't worry about me. Wait a week."],[3490,3591,"I have a business trip."],[3766,3973,"You are gonna be alone for a week."],[4087,4187,"Me and the baby,"],[4187,4275,"we're gonna miss you."],[4304,4408,"Oh, yeah?"],[5684,5764,"Not now."],[5937,6044,"Do you know?"],[6044,6249,"This business trip is not a bad idea."],[6339,6585,"So at least I am gonna be free of temptation."],[7247,7366,"Look at this one."],[7760,7893,"Three days and..."],[7914,8033,"four more to go."]],"47":[[8,106,"No, that..."],[106,208,"That can't be him!"],[208,358,"That can't be..."],[367,533,"Substitute?"],[2156,2285,"This is absurd."],[4029,4265,"No, this... this can't be true."],[4396,4635,"He's just probably in a meeting or something."],[4635,4773,"He's gonna call me later."],[10860,10957,"Whoever it is,"],[10957,11183,"they know Asher's schedule too well."],[11233,11378,"I can't let Asher get dragged"],[11378,11520,"into another scandal."],[11520,11744,"I have to find out who is behind this."]],"48":[[2590,2656,"You said"],[2656,2740,"his plane wasn't supposed"],[2740,2935,"to land for another three hours."],[3107,3190,"Who knows?"],[3328,3437,"But this time should be enough for you"],[3437,3570,"to deal with this bitch."],[3624,3699,"Right?"],[4683,4758,"Hmm."],[5013,5146,"Good morning."],[5146,5226,"Sleeping beauty."],[5347,5472,"Where are we?"],[5655,5730,"What do you want?"],[5897,6031,"What do I want?"],[6172,6485,"I want a life"],[6485,6681,"that I deserve."],[6698,6931,"The one that you ruined."],[7219,7394,"So those text messages..."],[7472,7615,"It was just all a lie."],[7807,7995,"Oh please."],[8074,8325,"As if I could write something that melodramatic."],[8325,8397,"That was all written"],[8397,8495,"by Tina Thompson."],[8495,8541,"Oh,"],[8571,8750,"except for the bit"],[8750,9021,"about Asher killing his father..."],[9088,9180,"I told her that one."],[9438,9534,"I don't trust you."],[9609,9718,"You're lying."],[9805,9914,"Lying?"],[10009,10085,"Hmm."],[10181,10285,"You don't know"],[10285,10502,"how terrifying that man is."],[10614,10694,"Did you know"],[10698,10844,"that his father died"],[10844,10981,"by falling from an apartment building"],[10981,11127,"that Asher owned"],[11127,11319,"since he was eighteen."],[11344,11511,"The police said he just"],[11565,11732,"fell from the penthouse."],[11881,12162,"But who should have direct access"],[12162,12312,"to that building?"],[12320,12429,"The only person,"],[12429,12771,"oh, but Uncle Asher."],[12954,13184,"Such a terrible person."],[13184,13313,"And yet somehow,"],[13338,13488,"he's devoted to you."],[13488,13617,"What did you do, huh?"],[13730,13863,"Did you drug him?"],[14059,14285,"Did you use your body?"],[14435,14581,"Doesn't matter."],[14581,14685,"You know,"],[14764,14898,"I've always wondered"],[15040,15219,"what a pregnant woman"],[15219,15415,"tastes like."]],"49":[[558,734,"Oh."],[775,996,"You're not going anywhere."],[1000,1163,"And you know,"],[1217,1518,"the chase is half the fun."],[1739,1881,"I've been waiting a long time"],[1889,2085,"for this, Tessa."],[2168,2235,"Let her go!"],[2235,2377,"One more step"],[2377,2468,"and she dies."],[2644,2715,"Austin,"],[2715,2948,"this is between you and I."],[2948,3128,"Release her."],[3140,3253,"Let her go?"],[3265,3490,"You think I'm stupid?"],[3490,3599,"If I let her go,"],[3599,3770,"your bodyguards will just come in here"],[3770,3941,"and kill me."],[3941,4074,"So what do you want?"],[4241,4350,"Let her go!"],[4379,4508,"I'll give you anything."],[4746,5055,"How about you kill yourself?"],[5100,5258,"No! Asher, no."],[5258,5392,"No, no!"],[5438,5597,"You know, Uncle Asher,"],[5601,5826,"I always used to look up to you"],[6014,6290,"until I realize that you're just rotten"],[6290,6427,"like the rest of us."],[6431,6589,"Deal? Hmm."],[6770,6907,"Take this knife and kill yourself."],[6907,7002,"Give it to me."],[7019,7098,"No!"],[7148,7238,"Give it to me!"],[7311,7628,"Asher, no! No, please no!"]],"50":[[844,1014,"No! No!"],[1697,1760,"Asher."],[1760,1901,"Why did you do this?"],[1951,2143,"I told you not to do stuff like this."],[2243,2364,"It just saved me."],[2585,2869,"Two years ago, I didn't have any hope of my life."],[3002,3182,"I wanted to start a new beginning."],[3253,3332,"I love you, Tessa."],[3578,3753,"Asher..."],[3753,3910,"No. No, no, no!"],[3910,4037,"Asher, please wake up."],[4037,4270,"Wake up. Please. No..."],[4358,4496,"No..."],[4558,4796,"Please wake up. Please."],[6631,6719,"Don't cry."],[6861,6952,"You okay?"],[7203,7323,"You almost died."],[7531,7661,"It's all my fault."],[7735,8058,"No, it's not your fault."],[8241,8558,"It's Tina and Austin's fault."],[8654,8750,"And they're gonna spend their"],[8750,8975,"whole life in the prison."],[9292,9405,"You know,"],[9405,9601,"the Wilson family"],[9805,10051,"used to be involved in a lot of crimes, right?"],[10247,10435,"These past three years,"],[10493,10839,"my dad grabbed me,"],[10981,11353,"let all the guys to beat me up,"],[11353,11699,"and used you against me."],[11974,12199,"In order to protect you..."],[12199,12391,"because I want to protect you."],[12412,12520,"That's why."],[12591,12712,"But I always loved you."],[12800,12927,"Why'd you promise this shadow"],[12927,13125,"we would not talk about it for three years?"],[14251,14422,"Tessa,"],[14422,14564,"before I met you,"],[14577,14714,"my life was a mess."],[14785,14898,"Everything was crazy."],[14939,15173,"I always thought I couldn't be happy,"],[15231,15486,"thought I didn't deserve to be happy."],[15486,15636,"But you gave me a reason,"],[15636,15770,"a reason to keep going."],[15770,15999,"So I promise to protect you"],[15999,16145,"and love you"],[16295,16487,"for the rest of my life."],[16520,16766,"You showed me what it means to be cherished."],[16908,17067,"I promise that"],[17108,17308,"I promise to give you a home,"],[17354,17488,"to make you a partner."],[17559,17755,"I will always love you unconditionally."],[20741,20862,"I love you."]]}