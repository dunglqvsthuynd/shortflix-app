3,"Mom, what the hell?"],[658,763,"How could you splash that shit"],[763,850,"all over them?"],[850,996,"She's always been like this!"],[1071,1197,"A vulgar shrew!"],[1284,1388,"Your dirty secret,"],[1426,1493,"tomorrow, it's gonna"],[1493,1605,"hit the front headlines."],[1618,1705,"And you deserve it."],[1722,1910,"Not only are you an adulterer,"],[1910,2068,"but you stole the stocks"],[2068,2160,"that rightfully belonged"],[2160,2335,"to myself and Olivia."],[2385,2494,"Then you come here"],[2531,2815,"to ruin the Nobel Prize ceremony."],[2844,3011,"I'll testify on Dad's behalf."],[3032,3161,"You're a cheater and a thief."],[3199,3424,"You're really screwed up now, Ms. Roy."],[3445,3553,"The negative press"],[3595,3766,"is gonna absolutely ruin"],[3803,3912,"Roy Publishing House."]],"54":[[50,175,"Oh, Jonathan."],[304,604,"You have deluded even yourself."],[642,700,"You forget that"],[700,834,"everything you possess"],[834,984,"is built on lies."],[984,1080,"Stop fighting, Anne."],[1172,1343,"You don't have any evidence."],[1397,1530,"You can't take me down"],[1530,1672,"with your empty accusations."],[1685,1780,"That's where you're wrong,"],[1780,1864,"dear husband."],[1901,2039,"I do have evidence."],[2052,2160,"And I'm going to show it"],[2160,2302,"to everyone right now."],[2877,3036,"Inside this box"],[3036,3203,"are the original manuscripts"],[3203,3486,"for all of my novels."],[3541,3607,"Oh my god."],[3624,3766,"The original manuscripts?"],[3816,3945,"If she's telling the truth,"],[3945,4129,"this is huge news."],[4191,4241,"No."],[4258,4433,"No, she, you, you're lying."],[4433,4500,"You're lying."],[4596,4775,"I burned your manuscripts."],[4775,4913,"I burned every single page"],[4913,4996,"in that entire house."],[4996,5063,"I know."],[5063,5150,"You have nothing."]],"55":[[20,229,"Johnny, what did you just say?"],[337,525,"I said, I said, there, there are no,"],[525,658,"there's no such thing"],[658,754,"as original manuscripts."],[754,942,"See, you're forging evidence now"],[942,1030,"and I'm gonna sue you."],[1030,1101,"That's right."],[1101,1222,"They must be forged."],[1238,1438,"Stop lying, Ms. Roy."],[1480,1664,"Are you sure you burned everything?"],[1710,1906,"What if a few pages were left for me?"],[1956,2018,"Right, Ken?"],[2089,2147,"No."],[2243,2298,"No way."],[2298,2335,"No."],[2335,2373,"We were there."],[2373,2427,"You were all there."],[2427,2506,"We burned everything."],[2506,2594,"You saw."],[2706,2744,"Don't-"],[2886,2961,"Shut up."],[2986,3082,"You fucking idiot."],[3219,3290,"Jonathan."],[3365,3507,"What's really going on here?"],[3591,3820,"Did she really write all the novels?"],[3820,4041,"Don't listen to that delusional nonsense."],[4041,4245,"She's taking shots in the dark."],[4308,4371,"Yeah."],[4371,4483,"What's in that box?"],[4483,4587,"Cookie recipes?"],[4608,4792,"I know you're trying to use it as evidence."],[4792,4946,"But we won't fool that easily."],[4988,5184,"That box is probably empty"],[5184,5276,"for all we know."],[5276,5467,"Since you all still doubt me,"],[5480,5693,"why don't I open it and show everyone?"]],"56":[[291,379,"What are those?"],[425,604,"Little scraps from your silly little"],[604,734,"crafting projects?"],[1042,1201,"I told you I didn't save anything."],[1355,1655,"We lived with my mother for 25 years."],[1668,1789,"She's just a desperate"],[1789,1931,"delusional housewife"],[1931,2135,"trying to pass off my father's talent"],[2135,2243,"as her own."],[2281,2344,"That's right."],[2344,2477,"How could a housewife"],[2477,2677,"write masterpieces like Mr. Asher?"],[2702,2861,"And she almost fooled us all."],[2861,3094,"Looks like she's all bark and no bite."],[3336,3520,"You've crashed my award ceremony."],[3553,3724,"You slandered my reputation"],[3724,3887,"and you don't have a shred of evidence."],[3920,3983,"All you've got"],[3983,4124,"are your empty accusations."],[4191,4346,"So don't blame me"],[4346,4558,"for sending you straight to jail."],[4979,5067,"Security!"],[5159,5334,"Get this woman!"],[5534,5597,"Wait!"]],"57":[[33,112,"Wait, wait, wait!"],[162,337,"This is part of the manuscript"],[337,479,"of The Burning Bush!"],[1101,1213,"It looks like written on"],[1213,1351,"all these scraps of papers"],[1351,1580,"are parts of the original manuscripts"],[1597,1747,"from all of Mr. Asher's"],[1747,1926,"award-winning novels."],[2010,2081,"Oh my god."],[2110,2285,"Is she actually the real author"],[2285,2385,"of those books?"],[2406,2573,"What a plot twist."],[2619,2686,"Johnny."],[2802,3061,"Please explain those manuscript scraps."],[3486,3620,"Those are my manuscript scraps."],[3728,3878,"I, you know, have this funny habit"],[3878,3999,"where I take notes"],[3999,4116,"whenever inspiration strikes."]],"58":[[66,145,"That's right."],[196,362,"Those are my Dad's manuscripts."],[371,658,"His writing style is unconventional."],[1121,1197,"Jonathan."],[1234,1301,"Since you admit"],[1301,1534,"that these are the original manuscripts,"],[1547,1739,"we can determine the true author"],[1755,1922,"through a handwriting analysis."],[1939,2072,"I have nothing to hide."],[2122,2439,"And I would relish the opportunity"],[2439,2535,"to prove you wrong."],[2535,2694,"But everybody knows"],[2756,2977,"that takes a forensic expert."],[3007,3169,"No fraud would agree to that."],[3303,3574,"Mom, you're grasping at straws."],[3574,3666,"Just let it go."],[3962,4175,"Hurry up and throw her out!"],[4241,4575,"Actually, we have a forensic"],[4575,4817,"handwriting expert here."],[4817,4979,"One of our honored guests."],[5021,5180,"Perhaps they could do"],[5180,5309,"the handwriting comparison."]],"59":[[442,558,"The results of the restoration"],[558,629,"just came in."],[654,792,"It looks like we were able to find"],[792,892,"what you were looking for."],[2060,2122,"Yeah."],[2168,2268,"That's great."],[2285,2344,"Thank you."],[2377,2498,"I gotta run. Thank you so much."],[4842,5013,"The results of the restoration"],[5017,5130,"just came out."],[5163,5205,"Good."],[5205,5271,"I'll be waiting."],[5296,5497,"Well, I hope that was your little lover"],[5497,5626,"rushing over to help you."],[5626,5826,"If so, it'll be easier to put you both in jail."],[5830,5905,"Are you so sure"],[5905,6056,"that I'm the one getting arrested?"],[6081,6210,"Oh, stop bluffing."]],"60":[[0,150,"Stop bluffing, Mom."],[216,392,"Soon, you'll have nothing"],[392,467,"to laugh about."],[467,667,"Those little scraps of paper"],[667,871,"don't prove anything."],[909,1101,"You brought this upon yourself, Anne."],[1101,1326,"You used to have a luxurious life"],[1326,1434,"being taken care of."],[1463,1739,"But your stubborn, jealous little heart"],[1739,1960,"has cost you everything."],[1985,2202,"You used to have a sweet husband,"],[2202,2565,"a loving family, big house, nice car."],[2635,2731,"I could go on."],[2769,2965,"You were even the heiress"],[2965,3240,"to an elite publishing company."],[3240,3453,"Roy Publishing was at its peak"],[3478,3791,"when Mr. Asher was set to become CEO."],[3845,3941,"But now,"],[4054,4124,"You're stock."],[4479,4717,"Both professionally and personally."],[5176,5426,"The results of the handwriting analysis"],[5426,5497,"are out."]],"61":[[0,216,"According to this analysis,"],[216,404,"the handwriting on the manuscripts"],[404,517,"of The Burning Bush"],[517,775,"and the other 16 novels"],[775,934,"all belong to"],[1192,1292,"Anne Roy."],[1822,1968,"You only burned the manuscripts"],[1968,2097,"that I had recompiled."],[2122,2268,"The originals were written"],[2268,2473,"over the course of 25 years,"],[2473,2610,"whenever and wherever"],[2610,2731,"I could find a Moment."],[2756,2936,"All while I served this family"],[2936,3123,"as a dedicated wife and mother."],[3453,3545,"Oh, my god."],[3545,3691,"This is so exciting."],[3691,3828,"I think I'm having a heart attack."],[3874,3995,"This proves nothing."],[4162,4287,"Anyone could have copied"],[4287,4350,"Dad's books down"],[4350,4466,"on sticky notes."]],"62":[[0,112,"Those manuscripts"],[112,258,"were written on receipts,"],[258,504,"greeting cards, newspaper margins."],[575,779,"All of them clearly dated,"],[779,875,"spanning the course"],[875,1051,"of two and a half decades."],[1363,1438,"Johnny,"],[1455,1605,"you can't let her do this."],[1605,1722,"You have to explain."],[2202,2339,"Don't oversell yourself."],[2339,2494,"All those menial house tasks"],[2494,2640,"you did back home,"],[2756,2836,"they're just like you,"],[3057,3132,"worthless."],[4058,4208,"I'll be there as soon as I can, Anne."]],"63":[[1255,1472,"Oh, Anne,"],[1472,1589,"look at you."],[1589,1864,"You're so emotionally unstable"],[1931,2068,"that you're gonna cry over"],[2068,2223,"a bunch of scraps of paper."],[2289,2385,"You are a"],[2385,2623,"stay-at-home housewife!"],[2623,2798,"You've had nothing but time"],[2798,2911,"to sit and doodle"],[2919,3073,"and copy down my manuscripts."],[3073,3203,"What, you think this proves anything?"],[3203,3253,"You could have been"],[3253,3386,"just copying my novels"],[3386,3541,"before they're even published."],[3566,3695,"He has a point."],[3695,3908,"Anne must have secretly"],[3908,3958,"copied down"],[3958,4083,"Jonathan's manuscript."]],"64":[[0,283,"Mom is clearly crazy obsessed with Dad."],[283,450,"Emphasis on the crazy."],[450,633,"She probably copied down his manuscript"],[633,750,"whenever she had time."],[771,884,"I've seen her do it"],[884,1013,"with my own two eyes."],[1105,1284,"Oh, that's what it was."],[1305,1438,"Everything makes sense now."],[1459,1643,"What a psychotic woman."],[1689,1818,"She's trying to ruin him"],[1818,1976,"because she can't have him."],[2444,2527,"Do you hear that, Anne?"],[2644,2806,"And you thought you were so clever."],[3069,3332,"Now get down on your knees."],[3382,3649,"Polish my shoes until they sparkle."],[3724,4016,"You made your mess, housewife."],[4237,4329,"Clean it up."],[4612,4738,"You have no idea"],[4738,4929,"how badly you'll regret this."],[4929,5021,"Anne, hold on."],[5071,5167,"I'm almost there."]],"65":[[20,283,"Everything I've ever wanted."],[333,429,"I've achieved."],[483,546,"Money."],[583,700,"Prestige."],[729,884,"A fantastic lover."],[925,1030,"I've got it all."],[1067,1159,"You're the one"],[1201,1380,"who should be regretting"],[1401,1522,"her choices."],[1605,1814,"You have nothing."],[1964,2248,"Mom, you can't blame anyone"],[2248,2339,"but yourself."],[2398,2656,"You chose to be a housewife."],[2694,2802,"And you should have chosen"],[2802,2890,"to spend more time"],[2890,3065,"trying to keep your husband's attention."],[3282,3349,"You're right."],[3445,3582,"I did choose this."],[3641,3737,"And I don't regret"],[3737,3853,"being a stay-at-home Mom."],[3933,4141,"Nothing gave me more pleasure"],[4141,4304,"than making sure that my family"],[4325,4583,"was loved and cared for."]],"66":[[87,225,"Now that I'm Chairwoman again,"],[296,462,"I'll nurture Roy Publishing"],[462,575,"in much the same way."],[613,692,"I am going to"],[692,846,"reorganize this company,"],[880,1030,"establish better standards,"],[1030,1159,"and make sure to blacklist"],[1159,1284,"toxic people"],[1284,1434,"like the Ashers."],[1626,1701,"Ah, come on."],[1714,1814,"Stop dreaming, Anne."],[1851,1989,"The writing's on the wall."],[2027,2268,"Roy Publishing House is done for."],[2310,2427,"Let me get this right."],[2460,2606,"You think the industry should trust"],[2606,2865,"a homeless, jobless,"],[2865,3069,"divorce failure of a housewife"],[3069,3303,"to establish better standards?"],[3420,3511,"You couldn't even"],[3511,3703,"keep your own house in order."],[3762,3995,"They'll trust Anne Roy."],[4079,4183,"They'll trust the heiress"],[4183,4295,"of the Roy empire"],[4295,4441,"and the true author"],[4441,4650,"of this company's best-selling books."],[4662,4925,"And your delusion's long enough."],[5000,5192,"Go spout your crazy"],[5192,5317,"nonsense elsewhere."],[5317,5480,"Security, what are you waiting for?"],[5689,5793,"Don't touch her."]],"67":[[33,116,"Sorry I'm late."],[250,300,"No."],[329,433,"You're right on time."],[1105,1180,"Oh, good."],[1192,1297,"Now a little lover boy"],[1297,1430,"has finally arrived."],[1497,1647,"We can send the two lovebirds"],[1647,1839,"to the police station together."],[1972,2152,"Well, you are right to assume that"],[2206,2356,"someone's going to jail tonight."],[2356,2581,"Oh, Mr. Harper."],[2665,2790,"I know you just arrived"],[2790,2952,"so you probably haven't heard."],[2998,3311,"But you two are done for."],[3311,3570,"Once news of your filthy affair gets out,"],[3591,3778,"the board members will kick you both"],[3778,3874,"out of the company."],[3941,4124,"Then Mr. Asher will be asked"],[4124,4475,"to take over as CEO."]],"68":[[70,200,"That's a pretty good plan you got there."],[246,383,"Except for one little hiccup."],[400,517,"Anne predicted everything"],[517,617,"you were going to do one step"],[617,734,"ahead the whole time."],[754,984,"She even planned a little surprise"],[984,1151,"for this exact occasion."],[1505,1614,"This here is a report"],[1614,1768,"from a forensic trace analyst."],[1818,1997,"We recovered some shards"],[1997,2106,"of a burnt manuscript"],[2106,2323,"from the Asher family fireplace."],[2373,2527,"And it confirms that all elements"],[2527,2615,"in the burnt writing"],[2648,2711,"and the results"],[2711,2827,"confirm the handwriting"],[2827,2948,"and all the papers in there"],[2948,3257,"were that of Ms. Anne Roy."]],"69":[[0,137,"That's impossible!"],[175,275,"Those ashy scraps?"],[275,421,"You can't test those."],[442,538,"They're worthless."],[604,750,"Jonathan, that's not all, hold on."],[821,1059,"We also recovered deleted footage"],[1059,1188,"from your security cameras"],[1188,1267,"in your house."],[1334,1501,"It showed you throwing"],[1501,1609,"all the manuscripts"],[1609,1780,"in the fire clearly."],[1864,2164,"Johnny, you never did that, right?"],[2227,2373,"The results must be forged!"],[2439,2515,"That's impossible."],[2548,2748,"No, no, no, no, no, no."],[2777,2940,"These have been forged."],[2957,3219,"This is ridiculous."],[3219,3395,"How low can you go, Mom?"],[3395,3524,"Outright forgery."],[3524,3649,"You're trying to trick us."],[3666,3812,"You two are frauds."],[3862,4049,"Only an idiot would be convinced"],[4049,4216,"by some trumped up report."],[4270,4371,"Rip it up all you want."],[4371,4713,"That's just one of, like, many, many copies."],[4771,4888,"It's time, Henry."],[4942,5105,"Time to crush their hopes."],[5221,5338,"It will be my pleasure."],[5655,5722,"Ewan,"],[5768,5851,"would you release the news"],[5851,5997,"of Jonathan's scandal, please?"],[5997,6064,"I'm on it."]],"70":[[16,237,"Oh, stop bluffing, you fool!"],[271,362,"How far do you think"],[362,504,"your fake news is gonna get?"],[504,629,"You know how high up"],[629,767,"my friends are in the media?"],[938,1201,"It won't get past their desk."],[1526,1576,"Don't."],[2565,2794,"All of our media contacts"],[2794,2923,"have cut ties with us."],[2990,3165,"They're releasing headlines that say"],[3165,3269,"you used a ghostwriter"],[3269,3382,"on the front page!"],[3616,3720,"Ladies and gentlemen,"],[3720,3899,"I've just received official word."],[3899,4062,"After reviewing the evidence"],[4062,4220,"provided by Ms. Roy,"],[4291,4471,"the Nobel Prize jury"],[4471,4587,"has reason to believe"],[4587,4833,"that all of Mr. Asher's novels"],[4833,5005,"were ghostwritten by her."]],"71":[[20,137,"They have subsequently"],[137,504,"decided to revoke Mr. Asher's award."],[617,946,"Additionally, he is banned"],[963,1297,"from Nobel consideration for life."],[1605,1739,"Oh my God!"],[1739,1935,"No, you can't do this!"],[2160,2256,"This can't be happening."],[2364,2610,"His career is down the drain now,"],[2610,2815,"and he's offended the most prestigious"],[2815,2932,"publishing house."],[2932,3103,"Jonathan Asher and his family"],[3103,3286,"are absolutely done for."],[3336,3636,"All 16 books you publish on your own"],[3699,3787,"were written by her?"]],"72":[[50,95,"Huh?"],[137,442,"Of 16 books, did you write a single one?"],[508,658,"I wrote the acknowledgements."],[934,1101,"You wrote the acknowledgements."],[1451,1539,"You liar!"],[1609,1751,"You ruined my life!"],[1839,2018,"You told me you wrote"],[2018,2177,"every single one of those books."],[2485,2623,"How could I have believed"],[2623,2723,"a fraud like you?"],[2823,2890,"Dad."],[3015,3136,"What are we going to do now?"],[3169,3336,"My business is going to go bust."],[3336,3490,"The debt collectors are going to kill me."],[3570,3774,"No, darling, please."],[3774,3933,"Do not worry about your safety."],[3970,4120,"I've already filed a lawsuit."],[4154,4304,"Given this new evidence,"],[4304,4571,"you'll all be living in complete safety"],[4583,4692,"very soon"],[4875,5034,"behind prison bars."],[5276,5334,"Anne."],[5476,5622,"You've always been so nice."],[5647,5672,"Wait."],[5672,5801,"You're such a kind person."],[5801,5922,"You wouldn't really do this to us, right?"],[5926,6085,"Get your filthy hands off her."]],"73":[[175,300,"Don't sue us."],[412,608,"I was bewitched by this vixen."],[888,1009,"I always loved you."],[1317,1480,"You can save your fake affection."],[1539,1668,"It disgusts me."],[1789,1976,"Please give me another chance."],[2039,2168,"If you go through with this,"],[2168,2314,"you'll ruin my life."],[2456,2690,"You ruined your life all by yourself."],[2711,2857,"I didn't need to help you with that."],[3244,3319,"Please."],[3345,3457,"I'm begging you."]],"74":[[208,312,"You thought that"],[312,471,"you were destroying my work."],[538,717,"But what you really destroyed"],[717,867,"was the last shred of affection"],[867,1009,"that I had for this family."],[1276,1459,"I wrote my manuscripts"],[1459,1659,"while making your meals."],[1730,1951,"While changing our daughter's diapers."],[2014,2198,"While making our house a home."],[2298,2410,"Every single word"],[2410,2519,"that I put down on that page"],[2519,2727,"is a testament to what I have done"],[2727,2865,"for this family."],[2986,3428,"Every page, every book, every accolade"],[3428,3745,"belongs to me, Anne Roy!"],[3924,4066,"And you are just the parasites"],[4066,4233,"who feasted off my blood, sweat,"],[4233,4312,"and tears."],[4337,4571,"Please, I'm begging you."],[4934,5075,"You can repent in jail."]],"75":[[266,392,"No, thanks to you."],[392,579,"I'm thinking about maybe a promotion"],[579,663,"in your future."],[988,1151,"I'm a Nobel Prize winning author."],[1172,1309,"I'll ghostwrite you a novel."],[1330,1438,"I'll do anything you want."],[1438,1689,"for food or a place to sleep."],[1822,1989,"Anything you want, just please-"],[1989,2206,"Please don't, don't, don't hurt me."],[2218,2298,"Jonathan?"],[2298,2356,"I'll leave."],[2373,2448,"I'll leave."]],"76":[[1985,2047,"Henry."],[2293,2448,"Sorry, I didn't mean to scare you."],[2590,2719,"Well, I spoke to the agent."],[2731,2907,"It seems as though Olivia and Jonathan"],[2907,3115,"had a massive falling out."],[3174,3411,"Jonathan sold this house."],[3449,3812,"And Olivia fled to Mexico."],[4066,4183,"Guess they couldn't do so well"],[4183,4295,"without you after all."],[4362,4508,"It's no longer my concern."],[5409,5522,"I love that sofa."],[5647,5814,"I used to lie there when I would write."],[5989,6185,"And that dining room table, oh."],[6335,6477,"No matter how many times I bumped it,"],[6477,6602,"whatever I spilled on it,"],[6610,6760,"it would just wipe right up."],[7036,7094,"Did you know that"],[7094,7203,"I designed the kitchen?"],[7319,7386,"You did?"],[7386,7469,"I did not know that."],[7499,7574,"Impressive."],[7620,7770,"I used to love cooking in there."],[7882,8012,"Do you ever want to cook in there again?"]],"77":[[4,95,"Didn't you say"],[95,225,"that the house has a buyer?"],[387,462,"I don't understand"],[462,525,"how can I cook"],[525,633,"in someone else's kitchen?"],[779,846,"I'm the buyer."],[1130,1267,"I bought the house for you."],[1418,1526,"After all the love and time"],[1526,1664,"you put in this home, only,"],[1751,1876,"only you deserve to have it."],[2056,2139,"Henry, that,"],[2394,2577,"I can't accept that kind of gift."],[2577,2652,"It's too much."],[2694,2823,"Hold on, because there's more."],[2857,3078,"Anne, in this life,"],[3078,3190,"I will never let you down."],[3382,3799,"I'll be loyal to you and our family,"],[3899,3983,"and I'll be an amazing"],[3983,4083,"husband to you."],[4216,4291,"Anne Roy,"],[4650,4729,"will you marry me?"],[4967,5084,"I don't know what to say."],[5463,5543,"Say yes."],[5597,5672,"Yes."],[5814,5876,"Yes."]]}