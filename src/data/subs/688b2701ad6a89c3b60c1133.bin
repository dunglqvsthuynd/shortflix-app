{"1":[[162,342,"For 25 years, I was"],[342,475,"my husband's ghostwriter."],[525,629,"I helped him become a"],[629,750,"bestselling author."],[792,905,"But while I wrote"],[905,1026,"page after page,"],[1105,1234,"he betrayed me."],[1301,1380,"He was having"],[1380,1518,"an affair with another woman."],[1547,1697,"And how did I find out?"],[1697,1851,"A kiss cam that caught them"],[1851,1939,"at a concert."],[1981,2181,"He humiliated me"],[2181,2310,"in front of the whole world."],[2385,2660,"25 years of marriage"],[2761,2840,"gone."],[2882,3003,"Just like that."],[3357,3395,"Have fun"],[3395,3524,"at the Reelplay concert."],[3532,3657,"I wish I could join you."],[3699,3812,"Especially since tonight's"],[3812,3933,"our anniversary."],[3966,4012,"Hm."],[4129,4225,"It's a work thing, honey."],[4250,4337,"Besides,"],[4391,4508,"you don't even like their music."],[4537,4642,"Oh, actually, I do like-"],[4642,4792,"Honey, I gotta go."],[4792,4863,"Can't wait for dinner."],[4863,5021,"Make me, uh, something"],[5021,5142,"delicious."],[5188,5309,"Okay, honey."],[6539,6740,"Anne, Jonathan's new book"],[6785,6906,"is a masterpiece."],[6923,7069,"If I were to guess, I'd say you"],[7069,7173,"probably had a"],[7173,7336,"pretty heavy part in writing the book."],[7357,7449,"Least he could do was give you"],[7449,7528,"some credit, right?"],[7545,7661,"Henry, you know I don't like"],[7661,7741,"the spotlight."],[7761,7899,"Plus, Jonathan's my husband."],[7932,8020,"What's mine is his"],[8020,8137,"and vice versa."],[8166,8266,"I've already prepared everything"],[8266,8441,"for Jonathan to take over as CEO."],[8487,8600,"Anne, Roy Publishing is your"],[8600,8679,"family business."],[8679,8733,"I'm just"],[8733,8879,"looking over it on your behalf."],[8900,9046,"We'll talk about this later."],[9071,9163,"Got to run, Henry."],[9163,9267,"Have to call Jonathan to see"],[9267,9363,"what time he's coming home."],[10694,10777,"That's weird."],[10777,10940,"The concert should be over by now."],[11436,11524,"Don't you want to answer your"],[11524,11599,"wife's call?"],[11653,11840,"She's so annoying."],[11853,11982,"She cannot go a single day"],[11982,12095,"without calling to"],[12095,12354,"blab about some unimportant shit."],[12379,12499,"Hang on, baby."],[12625,12746,"Yes, honey?"],[12783,12971,"I just wanted to know"],[12971,13075,"if you'd be back soon."],[13075,13188,"Dinner's almost ready."],[13188,13229,"Okay."],[13229,13346,"Yes, I will be right"],[13346,13467,"home, honey."],[13634,13697,"All right."],[13897,14076,"When was the last time you fucked"],[14076,14197,"your wife, Jonathan?"],[14205,14493,"It has been years."],[14522,14702,"I can't stand her body anymore."],[14731,14852,"Especially"],[14910,14964,"now that I have"],[14964,15073,"someone like you."],[15073,15194,"You better be telling the truth."],[15227,15273,"Oh,"],[15298,15390,"I swear on my life"],[15423,15507,"that you"],[15532,15707,"are the only woman I want."],[15995,16082,"Fuck!"],[16207,16295,"Okay,"],[16324,16466,"either they are having an affair"],[16466,16624,"or just really, really shy."],[16629,16695,"Okay, I gotta..."],[16695,16783,"Baby, I'm gonna go."],[16783,16816,"I, uh,"],[16833,16904,"I'm gonna catch you later."],[16912,16962,"Okay..."],[17046,17192,"But you better divorce her soon."],[17242,17363,"I'm sick of this."],[17392,17467,"Olivia."],[17467,17559,"I need you to hurry home."],[17559,17671,"I need you to cover me in front of mom"],[17671,17796,"in case something goes wrong. No,"],[17796,17913,"I'm gonna explain when I get home."],[17913,18022,"Just hurry home."]],"2":[[287,392,"Hi, honey."],[392,508,"You're back."],[508,629,"And just in time."],[629,746,"Dinner's ready."],[784,875,"How was the concert?"],[875,971,"Was it fun?"],[971,992,"No."],[992,1046,"Not really."],[1046,1167,"You know how these work things are."],[1267,1322,"Well, maybe"],[1322,1443,"next time I should join you."],[1443,1564,"Then it'll be more fun."],[1593,1659,"Oh, come on,"],[1659,1780,"let me have your coat."],[2452,2502,"Oh,"],[2581,2694,"Olivia called."],[2694,2811,"She said she'll be back soon."],[3015,3073,"Oh my God."],[3073,3119,"Wait."],[3119,3278,"That looks just like famous author"],[3278,3399,"Jonathan Asher."],[3445,3503,"No way."],[3503,3599,"Isn't he married?"],[3599,3716,"Who's he with?"],[3762,3883,"Oh, shit."],[3903,4024,"Honey, did you hear me?"],[4179,4200,"Huh?"],[4200,4245,"What-"],[4316,4362,"I'm sorry, honey."],[4362,4425,"What, what did you say?"],[4425,4504,"Olivia and Ken."],[4508,4542,"They're going to be"],[4542,4658,"joining us for dinner."],[4671,4767,"Okay that's great, honey."],[6827,6890,"He may not"],[6890,6977,"have taken me to that"],[6977,7098,"Reelplay concert,"],[7127,7215,"but he got me this"],[7215,7336,"beautiful necklace."],[7369,7453,"I've chosen"],[7453,7578,"a good man to marry."],[7928,8008,"Hey, Dad."],[8045,8153,"It's the big silver"],[8153,8320,"anniversary today, right?"],[8320,8479,"25 years of marriage."],[8479,8529,"Wow."],[8537,8591,"Don't you think"],[8591,8742,"our amazing little housewife"],[8742,8867,"deserves a little something?"],[8933,9042,"Yes, of course."],[9205,9538,"Anne, my angel, whatever you do,"],[9597,9838,"do not forget you're not just my wife."],[10014,10101,"You're my whole life."],[10535,10627,"Thank you, my love."],[10673,10785,"Hurry up and open it, mom."]],"3":[[91,162,"A pen."],[225,291,"Do you remember"],[291,417,"the last award ceremony"],[417,492,"I attended?"],[508,667,"I couldn't stop thinking about"],[667,888,"how much you've done for this family."],[905,1184,"So I picked up this pen in my hotel bed."],[1201,1322,"And I wrote about"],[1322,1497,"how much I missed you all night long."],[1522,1580,"Wow."],[1634,1885,"Dad, you're such a romantic."],[1885,2027,"I noticed you write"],[2027,2193,"the same acknowledgment"],[2193,2506,"in every book to my most beloved Anne."],[2548,2623,"Without you,"],[2623,2777,"none of this would be possible."],[2806,2919,"You are my muse."],[3023,3161,"Everyone writes acknowledgments."],[3161,3207,"It's no big deal."],[3244,3453,"What you need to learn, Ken,"],[3453,3599,"is that for a good wife,"],[3599,3841,"love is much more valuable"],[3841,3908,"than jewelry."],[3958,4266,"Price, insignificant."],[4279,4433,"You better not learn that from my Dad."],[4475,4775,"Look, I'm not some simple housewife"],[4775,4917,"that's going to be satisfied"],[4917,5105,"with a hotel pen and a love note."],[5105,5255,"I'm a career woman."],[5255,5351,"And career women"],[5351,5568,"appreciate investment pieces."],[6101,6197,"What's wrong with your mother?"],[6197,6389,"She's just being dramatic."],[6435,6660,"Look, after all, she's only a housewife."],[6898,7253,"Dad, uh, allow me to raise a glass to you."],[7323,7440,"Ever since you invited me"],[7440,7528,"to be your guest"],[7528,7657,"at your awards ceremony,"],[7657,7841,"I actually have a contract"],[7841,8037,"at a Fortune 500 company!"],[8037,8191,"Let me also congratulate you,"],[8191,8433,"Mr. Asher, to the next CEO"],[8445,8591,"of Roy Publishing House."],[9096,9188,"No, maybe he got"],[9188,9321,"that necklace for Olivia."],[9388,9476,"I shouldn't be so quick"],[9476,9592,"to jump to conclusions."],[9788,9976,"Anne, is it just me, or does this"],[9976,10097,"look kind of like your husband?"],[10831,10948,"Is Jonathan"],[10960,11069,"cheating on me?"],[13730,13855,"Lilianne."],[13888,14130,"My muse, happy anniversary."],[14130,14226,"Every book I write"],[14226,14410,"is a declaration of my love for you."],[14447,14672,"You deserve only the finest gold and gems"],[14672,14839,"to adorn your precious body."],[14960,15048,"Lilianne."],[15223,15432,"Lili-Anne."],[15465,15653,"To my most beloved, Anne."],[15774,15936,"He was never talking about me."],[15982,16103,"Who is this woman?"],[16111,16337,"How could you use the book that I wrote"],[16337,16537,"to proclaim your love for another woman?"],[17363,17413,"Oh, come on."],[17413,17530,"What is wrong with you, woman?"],[17530,17625,"Is this the work"],[17625,17771,"you've been so busy with?"],[17834,18043,"Who the hell is Lilianne?"]],"4":[[16,141,"Did you go through my things?"],[154,312,"This is an invasion of my privacy."],[312,375,"Oh, you're really going to"],[375,496,"turn this back around on me"],[496,550,"when you are the one"],[550,608,"who brought evidence"],[608,684,"of your affair"],[684,763,"into our home?"],[763,863,"Lilianne and I"],[863,1046,"are professional acquaintances."],[1063,1217,"We discuss art and literature."],[1217,1347,"Every book I write"],[1363,1609,"is a declaration of my love for you."],[1647,1735,"I shall ensure that"],[1735,1951,"only the finest gold and gems"],[1951,2147,"adorn your precious body."],[2147,2298,"That is a literary reference."],[2298,2356,"That is something"],[2356,2435,"you would not understand."],[2435,2527,"I suppose you're going to tell me"],[2527,2644,"that she finds it necessary"],[2644,2756,"to discuss your work"],[2756,2907,"dressed in lace lingerie?"],[2907,3111,"How unbelievable you are."],[3132,3278,"And you're ruining our anniversary."],[3278,3440,"and I am not going to sit here"],[3440,3657,"and listen to your insane accusations."],[3703,3841,"I'll be in my study."],[4208,4291,"No, you don't! No, you don't!"],[4291,4387,"You are going to stand there"],[4387,4450,"and you are going to"],[4450,4550,"explain everything to me."],[4550,4662,"Mom, calm down."],[4662,4879,"This is all a big misunderstanding."],[4909,5125,"Okay, Lilianne is a good person."],[5125,5180,"Her and Dad"],[5180,5342,"have a professional relationship."],[5430,5513,"You know her?"],[5572,5668,"You're going to defend"],[5668,5764,"some other woman?"],[5764,6076,"Mom, Lilianne is an literary agent"],[6076,6181,"at Roy Publishing House."],[6181,6293,"Her and Dad work together."],[6293,6393,"It's her job."],[6406,6493,"Look, I get it."],[6493,6623,"You've been a stay-at-home mom"],[6623,6744,"my whole life."],[6760,6869,"Obviously, you don't know"],[6869,7011,"how the publishing world works."],[7015,7107,"Wait a second."],[7344,7482,"How long have you known about them?"],[7766,7891,"Olivia, you're my daughter."],[7916,8170,"I carried you inside of me for 9 months."],[8179,8333,"I gave up everything for you."],[8350,8470,"And as thanks you've been"],[8470,8566,"helping your father"],[8566,8687,"hide his affair from me-"],[8687,8767,"Let it go!"],[8842,8921,"Clearly you watch too"],[8921,9025,"many soap operas"],[9025,9104,"and they filled your head"],[9104,9221,"with crazy ideas."],[9246,9426,"My own baby calling me crazy."],[9780,9909,"Is that what you think too?"],[9943,10110,"That I'm just some silly housewife"],[10110,10276,"with my head full of conspiracies?"],[10276,10389,"That I would stir up trouble"],[10389,10468,"for no reason?"],[10468,10652,"Well, it does seem like"],[10652,10894,"that's what ruined our anniversary."],[10894,11148,"So, darling, maybe you should"],[11148,11273,"stick to the housework."],[11319,11448,"Let us deal with the thinking."],[11507,11669,"Stick to the housework?"],[11720,11815,"As if I haven't given up"],[11815,11957,"25 years of my life"],[11957,12049,"for the both of you."],[12066,12383,"To keep you happy and healthy and fed."],[12383,12525,"Did those pants fold themselves"],[12525,12675,"and jump on into your drawer?"],[12679,12900,"Did those shoes shine themselves?"],[12983,13384,"Three meals a day for 25 years!"],[13442,13680,"These hands have been soaked"],[13680,14001,"in detergent and grease and filth."],[14009,14122,"Every day you two come home"],[14122,14218,"and you kick up your feet"],[14218,14297,"just knowing everything"],[14297,14385,"will be cared for."],[14397,14572,"That I have taken care of"],[14572,14689,"every little detail."],[14735,14814,"But for me?"],[14906,15065,"For the past 25 years"],[15065,15261,"I have worked around the clock"],[15261,15423,"like a goddamn maid!"],[15565,15724,"Have I ever gotten a break?"],[15724,15794,"Ever?"]],"5":[[62,196,"So first you're mad"],[229,433,"about some imaginary affair."],[483,613,"Then you're mad about"],[613,742,"how you have chosen"],[742,1009,"to spend your life."],[1026,1096,"You're a stay-at-home"],[1096,1180,"mom, Anne."],[1255,1347,"A housewife."],[1359,1438,"Cooking,"],[1438,1522,"cleaning,"],[1543,1626,"raising the kids,"],[1626,1705,"that's the job."],[1705,1797,"That's what you're supposed to do."],[1797,1872,"What do you want us to give you,"],[1872,1931,"a medal?"],[2047,2114,"You're right."],[2143,2289,"I did choose this life."],[2293,2435,"And I have done my best"],[2435,2631,"to live up to my duties as a wife."],[2648,2736,"So shouldn't you"],[2736,2836,"live up to your duties"],[2836,2923,"as a husband?"],[2998,3090,"At the very least"],[3090,3199,"you should be faithful"],[3199,3265,"in your marriage."],[3265,3415,"The one that should be faithful is the one"],[3415,3570,"who depends on the other's paycheck."],[3745,3820,"My god."],[3912,3970,"How could you"],[3970,4141,"say something so hurtful?"],[4216,4333,"You want to embarrass yourself?"],[4466,4550,"In front of your daughter?"],[4629,4721,"Her husband?"],[4775,4984,"For 25 years,"],[4984,5092,"I have been"],[5280,5426,"working my ass off,"],[5455,5613,"while you have been sitting here"],[5613,5826,"indulging in a life of luxury."],[5826,5930,"You should be grateful."],[5964,6076,"Between the two of us,"],[6076,6264,"who should really be grateful?"],[6281,6402,"Have you forgotten"],[6427,6552,"who helped take you"],[6552,6677,"from a nameless writer"],[6677,6831,"to a best-selling author?"],[6831,6894,"Mom."],[6940,7111,"I think you need to calm down."],[7111,7211,"Oh, I'm calm."],[7323,7411,"Your father is the one"],[7411,7545,"who needs to watch himself."],[7545,7665,"Are you threatening me?"],[7736,7874,"I'm reminding you"],[7916,8045,"I'm the one who wrote"],[8045,8179,"all of those books."],[8408,8500,"What? Are you gonna go out there,"],[8566,8629,"tell the whole world"],[8629,8746,"you wrote my collected works?"],[8746,8896,"Who is going to believe"],[8946,9050,"a housewife?"],[9079,9246,"Especially one that's gone mad,"],[9246,9346,"which you clearly have."],[9363,9538,"I'll just show them my manuscripts."],[9555,9755,"All of them in my handwriting"],[9772,9959,"for all of your novels."],[9980,10068,"Manuscripts?"],[10097,10218,"God, I bet that's something"],[10218,10314,"you keep locked up,"],[10314,10427,"safe and sound, huh?"],[10477,10573,"God forbid something"],[10573,10694,"should happen to the manuscripts."],[10844,10894,"You..."],[10994,11169,"No, no, no, no, no, no."],[11807,12082,"No, no, no, no, no, no."],[12312,12545,"You burned my manuscripts!"],[12641,12875,"I put 25 years of my heart into those."],[12875,13100,"It wasn't Dad, mom."],[13238,13309,"It was me."],[13375,13667,"And if you go and say anything,"],[13692,13897,"I'm going to go and tell the press."],[13905,14072,"That you're a liar."],[14185,14539,"Dad is about to become the CEO"],[14539,14710,"of Roy Publishing House."],[14710,14848,"And if anything happens"],[14848,14977,"to his reputation,"],[14977,15181,"all of our contracts will be canceled."],[15219,15436,"And our entire family will take the hit."],[15469,15640,"So this is all about"],[15657,15857,"your father becoming CEO."],[15899,16011,"Wake up, mom."],[16041,16174,"This is the real world."],[16174,16307,"Not some soap opera."],[16307,16449,"Why can't you just act like"],[16449,16604,"any other housewife"],[16604,16750,"and pretend it didn't happen?"],[16791,16971,"So why don't you just go"],[16971,17121,"and buy some clothes,"],[17137,17300,"and get your fucking nails done?"],[17342,17492,"What are you trying to achieve"],[17492,17655,"by causing a scene like this?"],[18126,18289,"I want a divorce."]],"6":[[29,258,"I want a divorce."],[271,350,"I don't want to be part"],[350,550,"of this traitorous family anymore."],[608,821,"I'm drawing up the divorce papers."],[821,896,"Soon you'll see"],[896,1084,"who really provided for this family."],[1163,1213,"Mom!"],[1213,1297,"Okay, let her go."],[1576,1651,"Go ahead!"],[1651,1801,"See what the real world's all about."],[1801,1889,"In two weeks' time,"],[1943,2060,"she's going to be back here."],[2089,2256,"Begging me to take her back."],[2306,2369,"Oh."],[2369,2627,"I left some belongings"],[2627,2752,"in your suitcase."],[2852,2957,"What do they look like?"],[2973,3165,"Oh, they're red as flames."],[3457,3595,"Soft to the touch."],[3632,3820,"You need to hurry up over here"],[3820,3928,"and collect them."],[3962,4179,"I'll only step foot in your house"],[4179,4333,"once I become your wife."],[4366,4487,"It will be soon, honey."],[4517,4650,"How about little sneak preview"],[4650,4746,"in the meantime?"],[5230,5501,"Oh my God!"],[5501,5751,"Baby, you look incredible."],[5751,5922,"Here's an advance"],[5922,6068,"for all that you promised me."],[6131,6314,"Lilianne."],[6331,6477,"My goddess."],[6510,6685,"My muse."]],"7":[[1101,1180,"Ms. Roy."],[1292,1534,"Mr. Henry's office is over here."],[1618,1680,"Thank you."],[1918,1989,"Babe."],[2031,2097,"Where'd you go?"],[2235,2444,"I just saw your wife"],[2444,2598,"walk into the CEO's office."],[2598,2652,"Could she be"],[2652,2802,"trying to report our relationship?"],[2882,2919,"What?"],[3232,3307,"Anne."],[3357,3495,"What a pleasant surprise."],[3574,3645,"What's going on?"],[3678,3782,"Henry, I came here today"],[3782,3953,"to ask you to stay on as CEO."],[4029,4116,"You've led this company"],[4116,4204,"to become what it is."],[4204,4341,"There's no reason for you to leave."],[4387,4483,"Yeah, but without"],[4483,4604,"your father's mentorship,"],[4633,4788,"I never would have come this far."],[4829,5021,"I promised him that I would look after you."],[5030,5176,"Roy has always been meant to be"],[5176,5259,"your company."],[5267,5367,"Henry, I knew I could"],[5367,5463,"put my faith in you."],[5530,5580,"Thank you,"],[5580,5764,"but now it's time"],[5764,5935,"to return to its rightful owner."],[5955,6039,"And per your request,"],[6039,6164,"I was just getting ready"],[6164,6327,"to call Jonathan to talk to him"],[6327,6468,"about taking over as CEO."],[6831,7040,"The other reason I came here today"],[7057,7240,"was to tell you to revoke that offer."],[7278,7428,"Jon and I are getting divorced."]],"8":[[20,171,"He's been cheating on me"],[241,387,"for God knows how long."],[425,558,"With another Anne."],[558,650,"Lilianne."],[679,855,"His real muse, apparently."],[909,988,"Asshole!"],[1026,1172,"I've been giving him special treatment"],[1172,1259,"because of you."],[1305,1455,"How dare he disrespect you?"],[1493,1568,"You know what?"],[1672,1839,"I'm gonna fire that asshole right now."],[1847,1989,"And that idiot Lilianne."],[2218,2327,"Listen, listen."],[2469,2527,"Calm down."],[2698,2756,"Fine."],[2927,3094,"Listen, I don't want you to fire him."],[3094,3165,"Why not?"],[3349,3465,"You still have feelings for him?"],[3474,3645,"We were married for 25 years."],[3645,3699,"I mean,"],[3745,3895,"we've weathered so much together."],[3995,4062,"Actually,"],[4175,4258,"Henry, go ahead"],[4258,4458,"and announce his position as CEO."],[4458,4617,"But I will be adding one condition."],[5150,5321,"This plan will hold control over him."],[5764,5880,"Olivia, there's no need"],[5880,6001,"to be so nervous."],[6001,6177,"Maybe your Mom went to the CEO"],[6177,6314,"to beg for a job."],[6314,6356,"No!"],[6356,6489,"She's definitely gonna bring up"],[6489,6581,"the ghostwriting issue."],[6606,6710,"Then Dad's reputation"],[6710,6781,"is gonna be ruined"],[6781,6965,"and my contracts are gonna be canceled."],[6977,7186,"If I have to drag her back here myself,"],[7203,7261,"I will."],[7328,7428,"Darling, listen."],[7449,7545,"Do not worry."],[7624,7757,"Lili's keeping an eye on her."],[7774,7982,"Now, if Anne tries to expose me,"],[7999,8141,"we are going to go to the press."],[8170,8470,"Tell them it was her having the affair."],[8470,8575,"And now she's trying to"],[8575,8696,"slander my reputation"],[8696,8863,"and steal half my assets."],[8904,8988,"Great idea, Dad."],[9009,9125,"That way, her public image"],[9125,9217,"will be ruined"],[9217,9359,"and nobody will believe Mom."],[9405,9663,"A housewife wants to bring me down."],[9743,9922,"Anne, I'm gonna show you"],[9955,10143,"that the real world is not"],[10143,10306,"as simple as you think it is."]],"9":[[75,125,"Henry."],[200,250,"Hm?"],[312,446,"Am I being too harsh on them?"],[458,671,"Jonathan and I were together for so long."],[692,838,"He must care about me still,"],[838,1001,"even just a little bit, right?"],[1026,1134,"Are you getting cold feet?"],[1155,1205,"No."],[1209,1272,"I, um,"],[1317,1451,"if Jonathan were to"],[1497,1597,"have a change of heart"],[1597,1847,"and show me that he still cares,"],[1951,2106,"I might give him another chance."],[2122,2306,"Anne, do not give in so easily."],[2306,2364,"You've done everything"],[2364,2439,"for your family."],[2506,2594,"But please, it's time"],[2594,2831,"that you put yourself first for once."],[2890,2940,"Yeah."],[3028,3103,"Thanks, Henry."],[3153,3324,"You're the best friend a girl could ask for."],[3349,3457,"Actually, I'm the worst."],[3516,3724,"I should have checked in on you"],[3724,3837,"a long time ago."],[3870,4033,"I chose this life,"],[4033,4262,"so I need to face those consequences."],[4304,4441,"Let's do like we talked about."],[4525,4617,"I'll keep you updated."],[4646,4692,"Okay."],[4871,5025,"Anne, you're too nice."],[5663,5772,"Mr. Harper."],[5834,5964,"Wasn't the woman who just left"],[5964,6072,"Mr. Asher's wife?"],[6097,6177,"Mrs. Villanova."],[6252,6381,"Isn't it still work hours?"],[6448,6623,"Go back and set up a meeting with HR."],[6669,6748,"I'm going to be calling"],[6748,6819,"Jonathan Asher"],[6819,6902,"and giving him notice"],[6902,7052,"about his position in this company."],[7082,7178,"Mr. Harper."],[7232,7478,"Jonathan is our best-selling author."],[7561,7711,"You can't destroy his career"],[7711,7891,"over some one-sided statement."],[7907,8062,"What one-sided statement"],[8062,8145,"are you talking about?"],[8208,8262,"Hmm?"],[8400,8516,"I'm going to be calling him"],[8516,8583,"to tell him"],[8583,8742,"he'll be the next CEO of this company."],[8850,8921,"Would you call that"],[8975,9129,"destroying his career?"],[9221,9346,"Oh my god!"],[9430,9697,"What an incredibly wise decision."],[9889,10043,"Why are you so happy about this?"],[10076,10247,"Are you and Mr. Asher that close?"],[10335,10435,"I..."],[10489,10748,"I'm a really big fan of his."],[10798,11211,"So, naturally, I'm really happy for him."],[11294,11473,"You don't even know who the real author"],[11473,11657,"you're fangirling over is."],[11669,11778,"I need you to hurry up"],[11799,11945,"and make that meeting with HR."],[11986,12166,"I'm going to inform Jonathan personally."],[12791,12879,"Hello, my darling."],[12929,13242,"Johnny, I have amazing news."],[13275,13671,"You're about to become the CEO."]],"10":[[216,321,"What did you just say?"],[429,558,"Roy Publishing House"],[558,792,"is hiring me as CEO!"],[829,892,"Yes!"],[942,1080,"I'm absolutely sure."],[1109,1213,"I'm about to prep your meeting"],[1213,1276,"with HR."],[1347,1526,"Henry has full faith in you."],[1572,1751,"Anne's nonsense went to one ear,"],[1793,1901,"and out the other."],[2231,2369,"I hope you still remember"],[2369,2494,"the promise you made."],[2531,2748,"Once you become the CEO,"],[2769,3144,"then I'll become the new Mrs. Asher."],[3169,3286,"Uh, yes."],[3286,3457,"I never go back on my word, my darling."],[3511,3666,"Well, then you better hurry up"],[3666,3812,"and clear out Anne's drawers."],[3878,4099,"Because I've got a lot of lingerie"],[4099,4179,"to put in them."],[4554,4746,"Your wish is my command."],[5580,5784,"Anne, everything's been prepared."],[5784,5989,"I'll await your instructions."],[6110,6189,"Thank you, Henry."],[6581,6660,"Jonathan,"],[6748,6894,"we built this house together"],[6894,6990,"from the ground up."],[7069,7123,"We've been through"],[7123,7236,"thick and thin together"],[7236,7365,"for 25 years."],[7457,7653,"Do you really want to demolish it all?"],[7724,7903,"You said I was your life."],[8003,8066,"But then,"],[8128,8220,"you turned around"],[8220,8362,"and embraced another woman."],[8450,8604,"Was everything a lie?"],[8821,9013,"I'm willing to sacrifice everything"],[9013,9104,"for my family."],[9146,9363,"But I will not tolerate betrayal."],[9438,9688,"Today, I will tell you the whole truth."],[9768,9993,"It will be your very last chance."],[11578,11715,"What's the meaning of this?"],[12141,12212,"Jonathan?"],[12303,12454,"It's exactly what you wanted, Anne."],[12545,12650,"We're getting a divorce."],[13588,13705,"Are you sure about this?"]],"11":[[16,279,"Oh, I've already signed the papers."],[529,629,"So I was willing to"],[629,779,"try and save our marriage."],[804,975,"But you've already written it off."],[1013,1096,"Henry, go ahead"],[1096,1292,"and announce his position as CEO."],[1330,1514,"But I will be adding one condition."],[1543,1735,"I'll be taking over as Chairwoman again."],[1785,2052,"Therefore, any hiring that's done,"],[2052,2327,"such as CEO, will require my approval."],[2423,2602,"Are you in such a hurry to kick me out?"],[2852,2923,"What a shame."],[3061,3148,"I was thinking about"],[3148,3286,"giving you all a second chance."],[3286,3415,"Oh, stop bluffing."],[3428,3553,"The truth is, you could come in here,"],[3553,3641,"you could crawl,"],[3716,3791,"beg me."],[3899,4045,"I'd never let you back in this house."],[4099,4270,"Mom, it's one thing to"],[4270,4387,"throw a tantrum at home."],[4416,4537,"But it's a different thing entirely"],[4537,4692,"to cause a scene at the company."],[4758,4900,"Dad is a public figure."],[4900,5100,"You almost destroyed his career."],[5100,5184,"And you think he's going to be"],[5184,5317,"willing to reconcile?"],[5338,5513,"Exactly, Anne."],[5543,5626,"You shouldn't have tried"],[5626,5805,"to expose Mr. Asher"],[5805,5955,"for using a ghostwriter."],[5989,6093,"He might have let you stay"],[6093,6264,"and write more books for him."],[6473,6552,"Jonathan,"],[6639,6781,"you know deep down inside"],[6781,6844,"that without me,"],[6844,6998,"you will never write another word."],[7173,7294,"Do you really think"],[7357,7499,"that I need to rely on writing"],[7499,7570,"for a living?"],[7628,7786,"Soon the entire company"],[7786,7874,"will be mine."],[7895,7970,"So you really think"],[7970,8099,"that you'll be unstoppable"],[8099,8208,"once you're CEO?"],[8262,8387,"Is that why you're in such a hurry"],[8387,8479,"to get rid of me?"],[8525,8666,"The faithful wife"],[8683,8846,"who stood by your side"],[8846,8983,"through thick and thin."],[9063,9367,"And trade me in for some shiny new toy?"],[9413,9588,"What or who I play with"],[9638,9743,"is none of your business."],[9822,9955,"I have kept a roof"],[9980,10126,"over your head for years."],[10126,10360,"I can forgive your ungratefulness."],[10410,10681,"But I cannot forgive you"],[10681,10823,"stabbing me in the back"],[10823,10944,"during the most pivotal moment"],[10944,11048,"of my career."],[11090,11186,"I mean, how am I supposed to stay"],[11186,11398,"with such a vile woman by my side?"],[11432,11615,"What on earth are you talking about?"],[11657,11891,"I have never stabbed you in the back."],[11920,12120,"Without me, you would still be"],[12120,12299,"an unpublished wannabe"],[12299,12508,"and not the next CEO of Roy Publishing."],[12558,12700,"Your storytelling skills"],[12700,12929,"have really gone down the drain."],[12954,13092,"Mom, you should really stop"],[13092,13229,"with this soap opera shit."],[13229,13367,"Like, what's next?"],[13367,13434,"You're going to tell us"],[13434,13551,"you're a wealthy heiress?"],[13667,13730,"You need to stop"],[13730,13855,"saying this idiotic stuff"],[13855,13930,"or people are going to think"],[13930,13997,"you're a joke."],[14109,14193,"That's right."],[14339,14456,"I'm a joke."],[14552,14785,"A joke for being so blind."],[14827,15019,"For choosing a selfish,"],[15052,15119,"brute of a man"],[15119,15244,"to be my husband like him,"],[15336,15532,"for having a thankless daughter"],[15532,15607,"like you,"],[15628,15719,"for having a pushover"],[15719,15815,"for a son-in-law."],[15874,15986,"You're right, Olivia."],[16091,16187,"How could I have spent"],[16187,16341,"25 years of my life"],[16341,16629,"catering to you ungrateful liars?"],[16695,16837,"I must have been delusional."],[17179,17321,"I'll sign the divorce papers."],[17442,17496,"From now on,"],[17496,17680,"I have no connection to this family."],[19048,19102,"Wait!"]],"12":[[91,212,"Whoa, what are you doing?"],[233,383,"You can't just get a divorce like that."],[563,675,"This is a"],[675,796,"supplemental document."],[829,1034,"You must agree to its terms."],[1080,1255,"Dad's assets aren't pocket change."],[1255,1388,"You can't just take half."],[1426,1601,"Especially since they'll eventually"],[1601,1651,"come to me."],[1801,2060,"How can you be so cold?"],[2152,2268,"First you're kicking me out,"],[2268,2335,"and now you want me"],[2335,2456,"to leave empty-handed?"],[2573,2844,"Olivia, you're my daughter."],[2923,3065,"Don't you have any sympathy for me?"],[3094,3228,"I'm not like you, Mom."],[3274,3403,"I'm a career woman."],[3482,3586,"Don't take it personally."],[3707,3841,"She always was too emotional."],[3966,4133,"Why does everyone in this family"],[4133,4241,"look down on me?"],[4325,4441,"I've taken care of you well"],[4441,4567,"for 25 years."],[4571,4675,"I've given you everything"],[4675,4721,"that I had."],[4721,4929,"Mom, you didn't do shit for 25 years."],[4971,5063,"So what?"],[5067,5226,"You cooked us a few meals."],[5288,5455,"You didn't earn a single cent"],[5455,5563,"for this family."],[5663,5780,"Dad was the one"],[5818,6089,"who consistently worked and slaved,"],[6089,6260,"and earned every penny"],[6260,6406,"that was put into this house."],[6498,6581,"Not you."],[6715,6861,"Did you ever stop to think about"],[6861,7027,"why Roy Publishing House"],[7027,7178,"gave your father a chance?"],[7211,7332,"Why they groomed him"],[7332,7511,"for all of these years?"],[7553,7657,"Well, obviously,"],[7686,7907,"because Dad is incredibly talented."],[8045,8237,"Dad is about to become the CEO"],[8254,8408,"of Roy Publishing House."],[8470,8591,"He'll have stocks"],[8616,8929,"worth tens of millions of dollars."],[8971,9146,"And if he even gave half"],[9175,9346,"to a housewife like you,"],[9513,9622,"he may as well throw"],[9622,9768,"all that money in the fire."],[10539,10814,"Jonathan, is this the way you feel too?"],[10906,11056,"That you earned everything"],[11056,11177,"for this family?"],[11277,11411,"I had nothing to do with it?"],[11478,11732,"I want to hear you say it yourself."],[11824,11886,"You"],[12012,12283,"haven't contributed anything."],[12408,12487,"I'll tell you what."],[12570,12696,"I'll give you a little bit of alimony"],[12696,12821,"once we get the divorce settled."],[12933,12975,"But,"],[13192,13338,"as far as what's in this house,"],[13484,13621,"you don't get anything."],[14172,14476,"Oh my, what a generous offer."],[14618,14773,"Roy Publishing House"],[14773,14960,"gave you everything,"],[15048,15223,"made you a best-selling author,"],[15265,15565,"gave you this huge house, a fancy car."],[15623,15699,"And you're still saying that"],[15699,15920,"it had nothing to do with me."],[16153,16266,"Fine, give me that paper."],[16503,16620,"I'll sign whatever you want."],[18722,18860,"Anne, I knew this would happen."],[18914,19006,"I'll be there soon."],[19094,19160,"Jonathan,"],[19198,19269,"Olivia,"],[19290,19348,"Ken."],[19377,19515,"The way you've treated me today"],[19515,19657,"has destroyed any love"],[19657,19836,"that I still had left for this family."],[19882,20161,"But you also destroyed"],[20161,20295,"your futures."],[20412,20541,"Oh, boo-hoo."],[20541,20637,"Here you go again"],[20637,20795,"with the soap opera stuff."],[20808,20945,"I think we're done here."],[20945,21062,"Hurry up and leave."],[21809,21896,"Oh."],[21942,22159,"Now that must be the CEO right now."]],"13":[[41,162,"God, I bet Henry's"],[162,291,"coming in person to announce"],[291,421,"the transfer of power."],[446,542,"That old son of a gun,"],[542,696,"he's never got any patience, does he?"],[725,784,"See?"],[821,980,"The CEO himself"],[980,1163,"came in person to notify us."],[1201,1388,"Well, since the CEO"],[1388,1685,"is coming with such good news,"],[1705,1810,"I suppose you better hurry"],[1810,1901,"and let him in."],[1968,2093,"Come quick, Mr. Asher."],[2093,2260,"I think it's for you."],[5025,5201,"So you're Lilianne."],[5259,5409,"I'm sorry, have we met?"],[5451,5501,"No."],[5584,5843,"But I've seen your noteworthy photos."],[5901,5968,"Lili."],[6051,6156,"Well, what brings you here?"],[6193,6360,"Yeah, Lili, we weren't expecting you"],[6360,6427,"to stop by."],[6481,6669,"Well, of course I had to come by"],[6669,6802,"and celebrate with you all."],[6902,7090,"Congratulations on becoming"],[7090,7344,"the CEO of the Roy publishing house."],[7490,7595,"Oh my god."],[7615,7732,"Congrats, Dad."],[7791,7953,"You've come at just the right time, Lili."],[7953,8291,"Mr. Asher is now finally divorced."],[8316,8483,"You and Dad were meant to be."],[8512,8633,"It's a stroke of fate."],[8692,8800,"Is this true?"],[8942,9042,"It's true honey."],[9092,9234,"I finally severed all ties"],[9234,9388,"with that miserable old shrew."],[9438,9684,"Then we have two things to celebrate."],[9763,10110,"We can keep the festivities going."],[10652,10915,"Well, that is the best gift"],[10915,11040,"any man can get."],[11182,11353,"Lili, from now on,"],[11386,11561,"you're a member of the family."],[11653,11782,"You should just move in already."],[11907,12016,"Yes, we've already emptied"],[12016,12116,"all the drawers for you."],[12233,12283,"Don't you think"],[12283,12520,"we're all celebrating a bit prematurely?"],[12591,12733,"Jonathan, do you really think"],[12733,12833,"that you're CEO now"],[12833,12954,"just because your mistress"],[12954,13146,"brought you some cheap champagne?"]],"14":[[16,120,"That's enough, Anne."],[120,191,"I've already told you,"],[212,371,"Lili is not just some mistress."],[496,571,"Oh, that's right."],[571,759,"She's a literary agent."],[875,988,"So I'm sure that she's here"],[988,1172,"on official business."],[1714,1847,"I think we all know"],[1847,2164,"what kind of work she does."],[2406,2506,"Jealous hag!"],[2731,2944,"Don't worry, Mr. Asher."],[3048,3174,"Let her say what she wants."],[3228,3457,"I am here on official business."],[3507,3795,"And the truth always prevails."],[3812,3883,"That's right."],[3883,3953,"Yeah."],[3974,4099,"You're just a junior agent"],[4099,4241,"at Roy Publishing, aren't you?"],[4258,4391,"Are you even qualified"],[4391,4537,"to make this kind of announcement"],[4537,4683,"because I was under the impression"],[4683,4984,"that Henry Harper, the CEO,"],[5013,5096,"was the only one"],[5096,5213,"with that kind of authority."],[5317,5480,"You stupid housewife!"],[5543,5705,"You don't understand"],[5739,5893,"what happens in the professional world."],[5964,6235,"The CEO is a very busy man."],[6310,6456,"And so I am entrusted"],[6498,6623,"to deliver this announcement."],[6785,6973,"Did he really entrust you"],[6973,7069,"with this announcement?"],[7069,7132,"Well then,"],[7215,7340,"why don't we just go ahead"],[7340,7515,"and give him a call to confirm?"]],"15":[[196,250,"Mom,"],[271,433,"stop embarrassing yourself."],[454,604,"Why would a housewife like you"],[604,759,"have the CEO's number?"],[796,963,"Roy Publishing House has"],[963,1163,"tens of thousands of employees."],[1163,1301,"Do you really expect the CEO"],[1301,1418,"to do everything himself?"],[1493,1810,"Sweet Lilianne is one of his top agents."],[1839,2022,"And she absolutely has the authority"],[2022,2164,"to come here and notify us."],[2181,2373,"I wasn't talking to you."],[2477,2577,"You're just starting off."],[2577,2711,"You only have a few clients,"],[2711,2794,"don't you, dear?"],[2823,2907,"What do you know about"],[2907,2969,"how an elite"],[2969,3111,"publishing company works?"],[3186,3336,"I know more than you do."],[3403,3586,"What do you think real work is?"],[3624,3791,"Going out and buying groceries,"],[3791,3916,"or doing the laundry?"],[4016,4200,"Please, just stop, Mom."],[4200,4325,"You're embarrassing yourself."],[4362,4596,"Be gentler to your mother, Olivia."],[4679,4875,"Oh, Anne."],[4925,5038,"I completely understand"],[5038,5146,"where you're coming from."],[5201,5334,"You've been in the house for"],[5413,5513,"so long."],[5563,5734,"Of course, you're a little ignorant."],[5860,6135,"I really do take pity on you."],[6172,6348,"But now it's time for someone"],[6348,6493,"more worthy"],[6581,6719,"to take over as woman of the house."],[6815,7015,"I'm lucky to have found one."],[7240,7486,"Dad, I'm so happy for you two."],[7524,7657,"With your reputation"],[7657,7816,"and Lili's business acumen,"],[7866,8041,"you guys are a match made in heaven."],[8533,8600,"Johnny."],[8637,8721,"It's the CEO."],[8783,8892,"He must be checking in to see"],[8892,9013,"if you've heard the good news yet."],[9104,9225,"Hurry up, answer it."],[9250,9376,"Yeah, and put it on speaker"],[9376,9522,"so someone can hear"],[9522,9693,"what the CEO really has to say."],[9880,9951,"Hello,"],[10010,10060,"Mr. Harper?"],[10060,10172,"Yeah, I told you to convene"],[10172,10268,"a meeting with HR."],[10297,10385,"Where the hell did you run off to,"],[10385,10447,"you idiot?"]],"16":[[208,262,"Hi."],[312,379,"Mr. Harper,"],[379,554,"I'm at Mr. Asher's house right now."],[554,754,"I told you to set up a meeting with HR."],[775,930,"Did you skip out on work hours?"],[955,1151,"Didn't you say to inform Mr. Asher?"],[1197,1380,"I told you I would personally"],[1380,1447,"inform him."],[1476,1689,"You are just an agent."],[1730,1847,"What right do you have"],[1847,1981,"doing my job for me?"],[2056,2131,"I'm sorry."],[2177,2231,"Mr. Harper,"],[2231,2419,"I just thought I'd take the initiative."],[2477,2556,"I'll be there soon."],[2623,2740,"Stay right where you are."],[2815,2902,"Yes, sir."],[3641,3691,"Lili?"],[3883,3937,"What's wrong?"],[3983,4108,"Yeah, the CEO"],[4108,4237,"didn't sound too happy."],[4404,4475,"Nothing's wrong."],[4550,4725,"I was just in such a rush"],[4725,4838,"to share the good news,"],[4838,5130,"I completely forgot"],[5171,5330,"that Mr. Harper actually wanted"],[5330,5509,"to personally tell you."],[5559,5684,"So, he's actually on his way-"],[5684,5784,"Whoa, whoa."],[5818,5968,"The CEO is personally"],[5968,6118,"coming to my house"],[6118,6335,"to announce me as his successor?"],[6393,6548,"But it's like I said,"],[6573,6710,"you didn't have that authority."],[6765,6944,"If the CEO is coming here"],[6944,7144,"to congratulate Dad personally,"],[7219,7365,"I think he respects him."],[7399,7545,"Of course he does."],[7570,7811,"Your father is a best-selling author"],[7811,8008,"and renowned in the industry."],[8078,8258,"It's only fitting that he succeeds"],[8258,8358,"as the next CEO."],[8450,8687,"Oh, my, my, my."],[8796,8946,"I think you're all mistaken."],[8996,9230,"You see, the CEO is only coming here"],[9250,9388,"because the Chairwoman"],[9409,9509,"asked him to."],[9530,9613,"Jonathan's appointment"],[9613,9705,"as CEO?"],[9788,9876,"Well, ultimately,"],[9876,10039,"that decision lies with her."],[10155,10276,"What Chairwoman?"],[10301,10556,"Lili, does Roy Publishing House"],[10556,10685,"even have a Chairwoman?"],[10723,10819,"Not that I know of."],[10952,11236,"Well, who is she?"],[11261,11440,"Like she even knows."],[11494,11603,"Oh, but I do."],[11682,11899,"The Chairwoman of Roy Publishing"],[12032,12116,"is me."]],"17":[[959,1101,"Drop the act Mom."],[1126,1217,"Do you even know"],[1217,1347,"what a Chairwoman does?"],[1368,1555,"She probably asked ChatGPT."],[1776,1985,"Anne, please, you've got to stop"],[1985,2110,"flaunting your ignorance."],[2131,2193,"When we were younger,"],[2193,2310,"we called it naivete."],[2310,2406,"But now that you're old"],[2406,2556,"and washed up and haggard,"],[2594,2744,"it's just plain foolishness."],[2977,3036,"She probably read"],[3036,3161,"so many trashy novels,"],[3161,3282,"she can't even keep up"],[3282,3386,"with reality anymore."],[3440,3716,"She's stuck in her own fantasy world."],[3837,3933,"That's what it is."],[3933,4074,"She's delusional."],[4129,4379,"Okay, yeah, I can play along with that."],[4671,4863,"Greetings, Chairwoman Anne."],[5405,5568,"They're laughing at me now."],[5609,5726,"But soon they'll see."]],"18":[[25,283,"Oh, pardon me, Chairwoman Anne."],[300,404,"Are you going to reject"],[404,567,"my appointment as CEO?"],[592,742,"Are you going to strip me"],[742,909,"of everything I've ever earned?"],[942,1063,"Are you going to kick me out"],[1063,1201,"of Roy Publishing Group?"],[1718,1889,"Yes, Chairwoman Anne."],[1943,2081,"Are you going to blacklist me"],[2081,2214,"from the publishing world?"],[2243,2398,"And shatter my company?"],[2452,2540,"Are you going to make"],[2540,2748,"your ungrateful daughter"],[2748,2877,"regret everything?"],[2982,3090,"Oh no, no, no, no."],[3090,3311,"Maybe Anne wants to be treated"],[3311,3428,"like a queen."],[3449,3499,"Ooh."],[3561,3653,"In which case,"],[3803,3903,"I will be your butler,"],[3949,4120,"and we'll be your maid."],[4183,4517,"And let us atone for our sins."],[4579,4683,"Oh, and,"],[4758,4859,"well, what about me?"],[4959,5100,"What would you like me to do?"],[5184,5301,"Go ahead and laugh."],[5363,5534,"The CEO will be here soon."],[5563,5672,"He'll confirm whether or not"],[5672,5818,"I'm telling the truth."],[5834,5897,"All right."],[5951,6022,"That's enough."],[6047,6143,"Playtime's over, Anne."],[6185,6302,"Now get the hell out of here."],[6331,6489,"Or I'm going to remove you myself."],[6781,6840,"Stop!"]],"19":[[137,204,"Henry."],[204,271,"I, I-"],[271,383,"You old son of a gun,"],[383,425,"you didn't tell me"],[425,508,"you were coming over here."],[759,900,"My daughter, Olivia,"],[934,1034,"her husband, Kenneth."],[1038,1155,"And who was that woman over there"],[1155,1226,"on your floor?"],[1305,1413,"Well, that is my ex."],[1488,1564,"A silly woman."],[1584,1726,"In fact, we were just getting rid of her"],[1726,1797,"because she was trying to"],[1797,1914,"tarnish my reputation,"],[1914,2114,"let alone Roy Publishing House."],[2139,2239,"You're kicking her out?"],[2239,2377,"The whole family decided"],[2377,2502,"we support my father."],[2523,2652,"And we won't let anyone"],[2652,2777,"tarnish his good name,"],[2777,2886,"related or not."],[3724,3803,"That sounds like"],[3803,3945,"personal business to me."],[3966,4104,"I'm here to talk strictly"],[4104,4262,"about company business,"],[4262,4525,"so let's stay focused on that."],[4546,4608,"Yes."],[4654,4767,"Great idea, Henry."],[4783,4946,"Let's talk business."],[4946,5025,"No wonder you're the leader"],[5025,5167,"of the company, Mr. Harper."],[5192,5376,"Always cutting to the chase."],[5426,5505,"Jonathan,"],[5526,5793,"as CEO of Roy Publishing House,"],[5814,5935,"I've decided to step down."],[5955,6106,"I will now make my formal"],[6106,6247,"succession announcement."],[6510,6623,"I, Henry Harper,"],[6673,6873,"due to personal circumstances,"],[6898,7082,"step down as CEO"],[7082,7232,"of Roy Publishing Company."],[7265,7440,"If you are willing to secede me"],[7440,7524,"from this position,"],[7524,7653,"Mr. Asher, I'll need you"],[7653,7849,"to sign these documents."],[8078,8187,"Oh, Henry."],[8287,8362,"My friend."],[8671,8750,"Thank you"],[8779,8871,"for trusting me."],[9042,9163,"Congrats, Dad!"],[9634,9768,"Johnny, the moment"],[9768,10039,"we've been waiting for is finally here."],[10047,10185,"Thank you for coming over"],[10185,10260,"so quickly."],[10260,10322,"And for shedding"],[10322,10431,"some light on the truth."],[10497,10589,"Just now,"],[10614,10885,"someone was spreading a rumor"],[10915,11094,"that you don't have the ultimate"],[11094,11236,"decision-making power."],[11248,11444,"And that they made up some ridiculous"],[11444,11582,"Chairwoman position."],[11636,11828,"Such a trashy rumor."],[11849,12053,"In all my years at the company,"],[12053,12178,"you are the only one"],[12178,12429,"with absolute authority."],[12479,12733,"I mean, have we ever had a Chairwoman?"],[13175,13288,"25 years ago,"],[13288,13425,"the Chairwoman stepped down"],[13425,13505,"from her position"],[13530,13713,"and gave me full authority"],[13713,13822,"to this whole company."],[13863,13972,"Did you hear that, Mom?"],[14018,14264,"This is real life, not some soap opera."],[14272,14385,"Miss Chairwoman,"],[14385,14518,"it's time to wake up, Honey."],[14723,14818,"Stop laughing."]],"20":[[20,225,"Johnny, we need to be"],[225,429,"the perfect hosts to Mr. Harper"],[458,625,"and get our unwelcome guest"],[625,692,"out."],[725,963,"Yes, darling, you are correct."],[980,1059,"Mr. Harper,"],[1076,1276,"forgive us for this unsightly mess."],[1284,1488,"Ken, Olivia, get her out of here."],[1497,1701,"Mom, you need to leave."],[2110,2202,"Step away from her."],[2394,2569,"I am not done speaking."],[2631,2723,"25 years ago,"],[2723,2848,"when I took over this company,"],[2894,3036,"there was no active Chairwoman."],[3036,3274,"But as of today, as of right now,"],[3319,3499,"I am reinstating a Chairwoman"],[3557,3707,"who will have total control over the"],[3707,3837,"Roy Publishing House Company."],[3883,4045,"And you must all obey"],[4066,4195,"that Chairwoman's orders,"],[4195,4404,"including the CEO."],[4596,4688,"What?"]],"21":[[0,141,"Henry, I don't understand."],[166,296,"Why the change of plans?"],[296,358,"Where did this"],[358,521,"new Chairwoman come from?"],[533,700,"I haven't heard a thing about her."],[725,809,"Unless..."],[1338,1388,"No."],[1568,1668,"That's impossible!"],[1968,2072,"There's no way!"],[2106,2206,"This is a joke."],[2206,2410,"A terrible one at that."],[2414,2610,"Going by the looks on your faces,"],[2660,2844,"you've already guessed who it is."],[2894,2957,"That's right."],[2994,3211,"Miss Anne Roy will be reinstated"],[3211,3453,"as the Chairwoman of this company."],[3724,3803,"Madam Chairwoman."],[4767,4863,"Welcome back, Chairwoman!"]],"22":[[0,171,"Anne isn't qualified for this."],[171,316,"Wait, Anne is completely"],[316,467,"unqualified for this position."],[467,638,"Is Roy publishing a joke?"],[658,784,"Are you telling me"],[804,1067,"that the woman that was baking pies"],[1067,1180,"in the kitchen yesterday"],[1201,1413,"is a Chairwoman of a company"],[1413,1534,"worth billions?"],[1534,1739,"Oh my god, this cannot be true."],[1739,1801,"No."],[1901,2168,"Mr. Harper, there must be a mistake."],[2168,2298,"She's just a housewife"],[2298,2473,"who cooks and cleans all day."],[2510,2640,"She'll ruin the company."],[2640,2711,"Silence!"],[2756,2927,"The Roy family owns"],[2927,3065,"Roy Publishing Company."],[3090,3282,"And it's only natural that Anne,"],[3303,3511,"the sole heiress to the company,"],[3511,3636,"become the Chairwoman."],[3636,3883,"None of you have any right"],[3883,3958,"to question her."],[4029,4095,"What? - What?"],[4900,4967,"Wait."],[5017,5251,"My wife of 25 years,"],[5284,5392,"the woman who cooked"],[5392,5518,"and cleaned for me,"],[5613,5768,"is the sole heiress"],[5830,5976,"of the Roy family fortune?"],[6026,6106,"Jonathan."],[6156,6327,"I told you you'd live to regret"],[6327,6460,"the way you treated me today."]],"23":[[29,141,"Mom, how could you hide this"],[141,275,"from us for so long?"],[296,450,"We're your own flesh and blood!"],[600,696,"Were you afraid of"],[696,871,"splitting your assets with us?"],[1247,1405,"Don't use your twisted logic"],[1405,1534,"to put words in my mouth."],[1551,1735,"The only reason I hid my identity"],[1735,1993,"was to protect your father's fragile ego."],[2093,2306,"Jonathan, when I first met you,"],[2306,2402,"you were just a nameless"],[2402,2506,"aspiring writer."],[2544,2727,"But I fell in love with your passion."],[2769,2944,"We built this life together."],[2965,3157,"I supported you from the sidelines"],[3157,3261,"every step of the way"],[3261,3340,"and helped you"],[3340,3495,"reach the position you're in now."],[3516,3641,"I look forward to the day"],[3641,3945,"when I could tell you my true identity."],[3995,4091,"When you would finally"],[4091,4204,"become the CEO."],[4220,4337,"I never thought that"],[4337,4600,"you could be so cruel"],[4675,4842,"to the loyal, loving wife"],[4842,4963,"who stayed by your side"],[4963,5138,"and made you into what you are."],[5221,5472,"It took me 25 years"],[5472,5593,"to see your true nature."],[5622,5722,"I feel like a fool."],[5830,5939,"But I see it now."],[6085,6139,"Henry."],[6197,6348,"Yes, Chairwoman Roy."],[6418,6514,"What would you like me to do?"]],"24":[[104,212,"Give them their wish."],[291,433,"From this day forward,"],[433,563,"I will have no connection"],[563,658,"to the Ashers."],[713,829,"Our relationships"],[829,1009,"will remain strictly business."],[1080,1418,"Jonathan, I hereby rescind your position"],[1418,1634,"as CEO to Roy Publishing House."],[1710,1876,"It cannot be led by a fraud."],[1910,1976,"Furthermore,"],[1976,2102,"this company is canceling"],[2102,2231,"all contracts with you."],[2298,2414,"Your book contracts?"],[2448,2510,"Canceled."],[2565,2673,"Your advances,"],[2702,2765,"rescinded."],[2831,2977,"We expect full repayment."],[3028,3115,"Lilianne,"],[3115,3328,"your depraved morals do not align"],[3328,3453,"with our company values."],[3478,3578,"You built your career"],[3578,3712,"by seducing a married man."],[3791,3899,"You're fired."],[3970,4179,"In addition, my personal evaluation"],[4179,4270,"will be circulated"],[4270,4350,"throughout the industry."],[4350,4650,"You will never work in publishing again."]],"25":[[775,859,"Olivia."],[892,950,"Mom."],[1038,1159,"I'm your daughter."],[1205,1388,"From now on, you are not allowed"],[1388,1463,"to use"],[1463,1651,"Roy Publishing House's name"],[1651,1814,"for personal gain."],[1835,1968,"If you try to leverage"],[1968,2160,"our relationship for future contracts,"],[2160,2439,"I will bury your company in lawsuits."],[2439,2544,"Mom, if you cut me off,"],[2544,2702,"I'll go bankrupt within the year."],[2790,2886,"Do you really want to"],[2886,3078,"ruin your only daughter?"],[3078,3174,"Please, Anne."],[3199,3340,"Olivia is your flesh and blood."],[3378,3499,"Why are you treating her like this?"],[3499,3645,"If she wasn't my daughter,"],[3645,3778,"I would have sued her already."],[3816,4045,"Instead, I am generously"],[4045,4179,"giving her the opportunity"],[4179,4258,"to prove that"],[4258,4529,"she is the self-made businesswoman"],[4542,4654,"she proclaims to be."],[4721,5009,"Olivia, I took care of you for 25 years."],[5038,5267,"I'm not going to spoil you any longer."],[5267,5447,"Mom, you're going to ruin us!"],[5534,5584,"Dad!"],[5613,5734,"Don't just stand there!"],[5734,5809,"Fix it!"],[5830,5889,"Johnny,"],[5947,6089,"you have to tell her!"],[6131,6210,"We only had"],[6210,6348,"a professional relationship."],[6356,6527,"Please tell her to have mercy on me."]],"26":[[41,91,"Anne."],[91,262,"Don't tell me you have the audacity"],[262,417,"to keep defending your mistress."],[417,462,"What?"],[625,675,"I'm..."],[809,988,"I won't plead on their behalf, but,"],[988,1201,"Anne, I'm just hurt"],[1201,1359,"that our family has come to this."],[1393,1484,"If you had told the truth,"],[1484,1634,"it never would have gotten to this point."],[1655,1797,"I just wanted to grow old with you."],[1797,1993,"I just want to live my life with you."],[2002,2181,"You can take your fake feelings"],[2181,2273,"and shove them."],[2331,2644,"This faithful husband act, it disgusts me."],[2886,3048,"Did you forget about this little thing"],[3048,3128,"that you did?"],[3128,3190,"Hm?"],[3908,3991,"How about these?"],[3991,4037,"Hm?"],[4083,4237,"Did you forget about these?"]],"27":[[12,187,"How dare you say you love me"],[187,279,"with the same mouth"],[279,421,"that kisses your mistress?"],[425,688,"Even thinking about growing old"],[688,771,"with someone like you"],[813,975,"makes me sick."],[1001,1242,"I'll say it one last time,"],[1330,1497,"from this day forward,"],[1526,1864,"This family and I are through."],[1885,1935,"Anne."],[1935,1976,"Mom."],[1976,2056,"Mrs. Asher."],[2056,2318,"From now on, you will refer to me"],[2318,2631,"as Chairwoman or Ms. Roy."]],"28":[[183,291,"I'm done for."],[387,517,"My career in the publishing industry"],[517,642,"is completely ruined."],[729,871,"Look, baby, just-"],[871,946,"Jonathan!"],[1030,1288,"We are completely out of money"],[1368,1476,"and our careers."],[1618,1714,"What are we going to do?"],[1885,2027,"Dad, you have to help me!"],[2047,2223,"All of my contracts have been canceled."],[2235,2318,"The debt collectors"],[2318,2477,"are already banging down my door."],[2777,2844,"Dad!"],[2882,2986,"What are we going to do?"],[3057,3186,"Hurry up and think of something."],[3862,3945,"Stop."],[4020,4079,"It's alright."],[4141,4216,"Let him speak."],[4554,4604,"Anne."],[4654,4909,"We have been family for a long time."],[4996,5163,"How can you be so cruel to us?"]],"29":[[29,212,"Lilianne and I, we are co-workers."],[212,325,"We have flirted a little bit."],[325,412,"That is it."],[471,633,"Olivia is your daughter."],[663,800,"You birthed her."],[867,934,"What, you're just going to"],[934,996,"push us aside"],[996,1134,"for some silly misunderstanding?"],[1172,1322,"How can you live with yourself?"],[1343,1472,"How dare you put blame on Anne?"],[1543,1705,"She sacrificed years of her life"],[1705,1793,"taking care of you."],[1843,1947,"Now your little mistress"],[1947,1997,"and daughter"],[1997,2068,"are trying to make a plan"],[2068,2227,"to kick her out of the life she built?"],[2318,2439,"Don't you have any conscience?"],[2656,2873,"I promise you that"],[2873,3032,"if you do anything to hurt Anne,"],[3107,3349,"I will make sure that you pay."],[3420,3499,"Understand?"],[3737,3924,"Now, don't worry."],[4108,4158,"I already made sure"],[4158,4300,"the publishing house is going to drop you."],[4375,4508,"If you or the people here"],[4508,4688,"want to cause any more disturbances,"],[4688,4859,"I'll be forced to call security."]],"30":[[16,120,"We're already leaving."],[2660,2702,"Here."],[3157,3290,"Henry, did I go too far?"],[3841,3949,"Anne, you've done everything"],[3949,4012,"for them."],[4066,4279,"It's them who let you down."],[5230,5501,"To get rid of Jonathan's influence,"],[5501,5547,"I think we should have"],[5547,5630,"a board meeting"],[5647,5801,"to announce your return."],[5801,5872,"I agree."],[5872,6001,"And then you need to go public"],[6001,6072,"and let them know that"],[6072,6189,"you were his ghostwriter."],[6260,6439,"And get your copyrights back."]],"31":[[25,125,"Let me think about it."],[125,233,"Well, the Nobel Foundation"],[233,296,"already called"],[296,383,"and they said he's the frontrunner"],[383,467,"to win this year."],[467,621,"We cannot let him keep making money"],[621,759,"off false pretenses."],[759,909,"It's time to take back what's yours."],[909,963,"Henry."],[1059,1276,"I said just give me some time to think."],[1380,1505,"Anne, you're too nice."],[1505,1609,"You might give in again,"],[1609,1710,"but Jonathan won't."],[2264,2385,"What kind of a psychopath"],[2385,2577,"hides their identity for decades?"],[2581,2665,"You know what?"],[2686,2790,"I bet she did this"],[2790,2894,"just so she doesn't have to"],[2894,3044,"share her assets with us."],[3044,3178,"She was just a boring housewife"],[3178,3328,"mopping floors yesterday."],[3328,3457,"But now she's the Chairwoman"],[3457,3595,"of a top publishing company?"],[3687,3799,"This must be a joke."],[4270,4396,"Oh, God."],[4466,4542,"Hold your horses."],[4575,4617,"We can still"],[4617,4708,"turn this around."],[4717,5013,"Anne is just a housewife,"],[5013,5138,"and she's got no experience."],[5142,5305,"There's no way she can handle"],[5305,5413,"the position of Chairwoman."],[5463,5551,"Truly, the company must be"],[5551,5651,"falling apart by now."],[5801,5893,"What are you planning?"]],"32":[[104,154,"Well."],[367,517,"I've received an invitation"],[517,775,"from the Nobel Prize Foundation."],[1059,1309,"You two are looking at the future winner"],[1359,1622,"of a Nobel Prize in Literature."],[1651,1793,"And when I take the stage"],[1810,1956,"and give my acceptance speech,"],[2002,2135,"I am going to announce"],[2164,2277,"that Anne and Henry"],[2344,2569,"are having a scandalous affair."],[2606,2711,"When their reputation"],[2711,2836,"are completely destroyed,"],[2865,3019,"and the company's stocks crash,"],[3032,3157,"the board members"],[3178,3424,"are going to be begging me"],[3532,3616,"to take over."],[4533,4817,"Anne, your decision to reverse"],[4817,5013,"Jonathan's appointment to CEO"],[5013,5159,"has already affected"],[5159,5342,"this company's stocks."],[5397,5597,"We understand the Roy family"],[5597,5793,"holds the majority of shares."],[5793,6001,"But you're still responsible"],[6001,6227,"for the rest of the shareholders."],[6285,6460,"We, members of the board,"],[6560,6669,"wish for you"],[6669,6965,"to resign as Chairwoman."],[7111,7236,"You're trying to fire Anne?"],[7273,7323,"Is this because of"],[7323,7436,"Jonathan's meddling?"],[7490,7607,"Disgusting old man."],[7624,7912,"The revenue from Mr. Asher's books"],[7920,8116,"accounts for about forty percent"],[8116,8333,"of this company's profits."],[8350,8550,"Additionally, since he is poised"],[8550,8746,"to win the Nobel Prize,"],[8746,8988,"his market value is about to"],[8988,9146,"skyrocket soon."],[9192,9442,"We cannot lose a cash cow"],[9442,9642,"like Jonathan Asher."],[9672,10068,"Ms. Roy must make up for this loss."],[10502,10677,"I'll take back the copyrights."]],"33":[[287,504,"How is that possible?"],[533,688,"Who in their right mind"],[688,942,"would ever hand over a golden egg"],[942,1067,"to their ex-wife?"],[1509,1780,"I am more than just Jonathan's ex-wife."],[1839,2006,"I am Anne Roy."],[2027,2156,"I have achieved everything"],[2156,2335,"that I have ever set my mind to."],[2344,2444,"And I have done so"],[2444,2552,"without relying on Jonathan"],[2552,2665,"for a single penny."],[2823,3048,"I admire your courage."],[3069,3449,"But our trust comes with a price."],[3691,3749,"Okay."],[4404,4583,"Sign this agreement stating that"],[4592,4929,"if you do not get back the copyrights,"],[4967,5271,"all of your stock holdings"],[5271,5405,"will be turned over to us."],[5789,5960,"Anne, you can't do that."]],"34":[[888,1105,"I, Anne Roy, hereby agree"],[1105,1255,"to the terms of this agreement."],[1297,1405,"In 24 hours,"],[1405,1584,"I will take back the copyrights."],[1609,1826,"If I cannot, I shall willingly forfeit"],[1826,2002,"the entirety of my shares."],[3032,3090,"It's a deal."],[3432,3553,"We look forward to the results."],[4517,4658,"Anne, that was foolish."],[4675,4863,"Jonathan's an egotistical little man."],[4979,5050,"He'd stop at nothing"],[5050,5159,"to save his reputation."],[5192,5255,"He's never going to admit"],[5255,5372,"that you were his ghostwriter."],[5422,5472,"How are you going to"],[5472,5576,"get those copyrights back?"],[5709,5889,"I have the evidence in my possession."],[5964,6151,"And also, I have a backup plan."],[6168,6277,"That's where you come in."],[6410,6544,"Tomorrow is the Nobel Prize"],[6544,6652,"award ceremony."],[6740,6831,"I'll show Jonathan"],[6831,7007,"what a real regret looks like."]],"35":[[717,913,"I'm waiting on the lab results."],[1055,1201,"I'll be waiting to hear from you."],[4725,4838,"Jonathan Asher?"],[4950,5100,"I knew it was you."],[5184,5355,"Congratulations to the winner"],[5355,5513,"of the Nobel Prize in Literature,"],[5530,5609,"Jonathan Asher."],[5684,5764,"Well, thank you,"],[5764,5897,"but the award hasn't been assigned"],[5897,5960,"quite yet."],[5960,6047,"I'm still just a nominee."],[6047,6277,"Darling, nobody's more deserving"],[6277,6389,"of the award than you."],[6794,6877,"Oh my god."],[6927,7107,"Dad, did you propose already?"]],"36":[[137,229,"Congratulations."],[229,471,"Mr. Asher, I see you wasted no time."],[629,871,"I'm overjoyed to be marrying Jonathan."],[900,1046,"But spending a million dollars"],[1046,1092,"on her ring"],[1092,1209,"is a little over the top."],[1209,1292,"Don't you think?"],[1472,1601,"In my humble opinion,"],[1601,1826,"only a woman as beautiful as Lilianne"],[1826,1939,"is worthy of an author"],[1939,2152,"as talented as you, Jonathan."],[2248,2523,"You two really make a beautiful couple."],[2594,2665,"By the way,"],[2665,2777,"I heard you separated"],[2777,2869,"from Roy Publishing."],[2911,3023,"Maybe in the future"],[3023,3144,"we could work together?"],[3153,3253,"You can speak to me"],[3253,3407,"about any future book deals."],[3461,3695,"I'm also Jonathan's agent."],[3970,4108,"Dad, we've invited"],[4108,4250,"all of our friends in the media."],[4304,4421,"Tomorrow's front pages"],[4421,4504,"will be plastered"],[4504,4633,"with your breaking news."],[4633,4729,"Today, you will bring"],[4729,4884,"Roy Publishing House"],[4896,4984,"to its knees."],[5063,5209,"During my acceptance speech,"],[5276,5505,"I am going to announce"],[5505,5822,"the scandalous affair of Anne and Henry,"],[5843,5914,"and I'm going to"],[5914,6068,"knock those two bastards"],[6135,6268,"right off their high horse."]],"37":[[171,346,"Welcome, ladies and gentlemen."],[421,558,"Thank you for attending"],[558,821,"our prestigious award ceremony."],[880,1155,"Now, for tonight's main event,"],[1251,1388,"please join me"],[1388,1597,"in welcoming this year's recipient"],[1597,1822,"of the Nobel Prize in Literature,"],[1843,2010,"the author of the critically"],[2010,2264,"acclaimed novel The Burning Bush,"],[2435,2590,"Mr. Jonathan Asher."],[2623,2786,"Please, come to the podium."],[3528,3641,"I love you like crazy."],[3707,3858,"Every single word I wrote for you."],[4704,4808,"Excuse me."],[5138,5372,"Jonathan Asher is a fraud."]],"38":[[880,971,"Who is this woman?"],[992,1151,"What kind of person causes a scene"],[1151,1326,"at such a prestigious event?"],[1368,1589,"Oh my God, I know her."],[1630,1805,"That's Jonathan's ex-wife."],[2127,2339,"Mom, what are you doing here?"],[2339,2452,"This is the Nobel Prize"],[2452,2560,"award ceremony."],[2610,2719,"I'm warning you."],[2731,2911,"Don't start anything."],[2940,3065,"Naturally, I'm here"],[3065,3253,"at this award ceremony in my role"],[3253,3486,"as Chairwoman of Roy Publishing."],[3720,3853,"I know what she's doing."],[3874,3949,"Jonathan,"],[3958,4066,"she got all dressed up"],[4066,4187,"so she could barge in here"],[4195,4295,"to this event"],[4329,4525,"and beg for you to take her back."]],"39":[[137,237,"In all honesty,"],[271,400,"a spatula and an apron"],[429,513,"better suits you."],[571,842,"And if she thinks she can compete"],[888,1067,"with a stunner like you,"],[1151,1226,"no, no, no, no,"],[1226,1443,"she's sorely mistaken."],[1630,1956,"Babe, you are too sweet."],[2243,2435,"Oh, in case you haven't heard,"],[2435,2590,"your husband,"],[2744,2940,"oh, no, your ex-husband"],[3007,3132,"has already proposed to me."],[3420,3507,"Just days ago,"],[3507,3707,"you were begging to grow old with me"],[3707,3787,"and now you've already"],[3787,3920,"proposed to another woman?"],[4008,4124,"Talk about jumping the gun."],[4141,4262,"Now that I'm free of you,"],[4304,4487,"you filthy gold digger,"],[4533,4708,"I've decided to move on with my life."],[4767,4846,"Start a new one."],[5017,5230,"On our first day officially together,"],[5288,5384,"he gave me this"],[5384,5555,"million dollar diamond ring."],[5626,5918,"What did you get after 25 years?"],[6006,6168,"A little plastic hotel pen."],[6639,6744,"Go ahead and laugh."],[6815,6894,"Once I take back"],[6894,7019,"everything that belongs to me,"],[7019,7161,"you won't be laughing anymore."]],"40":[[200,383,"Babe, you have nothing"],[383,496,"that belongs to you anymore."],[575,825,"Your husband, your child,"],[850,1026,"the home that you put your whole life"],[1026,1159,"and soul into."],[1330,1514,"It's all mine now."],[1568,1780,"Everything that belongs to you?"],[1860,1972,"Oh, come on, Anne."],[2006,2081,"Good luck with that."],[2131,2248,"We don't owe you"],[2356,2406,"anything."],[2502,2781,"Dad is a Nobel Prize Laureate now."],[2840,3003,"Bet you're having some regrets, Mom."],[3057,3178,"But it's too late."],[3199,3324,"Even without you,"],[3324,3541,"Mr. Asher's reputation"],[3541,3691,"will let us dominate"],[3691,3816,"the publishing world."],[4008,4137,"Are you sure about that?"],[4187,4320,"Don't try to bluff, Mom."],[4341,4558,"Everyone knows Dad is the true pillar"],[4558,4704,"of Roy Publishing House."],[4704,4800,"Ever since you kicked out"],[4800,4921,"your biggest author,"],[4921,5046,"now you're going to be the laughing stock"],[5046,5217,"of the entire publishing world."]],"41":[[0,162,"Ms. Roy, you really shouldn't"],[162,291,"have gone against us."],[291,521,"Your biggest mistake was believing"],[521,596,"you were more than"],[596,859,"just a sheltered housewife."],[1101,1238,"So because I was a housewife,"],[1238,1330,"you all think it's okay"],[1330,1434,"to humiliate me?"],[1580,1714,"I mean, look around, Mom."],[1780,1860,"Everyone's here"],[1860,2018,"because they believe in Dad."],[2097,2256,"His reputation."],[2281,2389,"His prestige."],[2481,2744,"They all just want to revel in his success."],[2902,3053,"You know the company"],[3053,3182,"can't survive without him."],[3415,3632,"So you're all here to grab"],[3632,3845,"a piece of Jonathan Asher's"],[3845,4045,"glorious reputation."],[4087,4308,"Well, there's just one little problem."],[4329,4437,"It's all fake."]],"42":[[104,225,"What does she mean by that?"],[225,563,"Oh she's a lonely, vengeful"],[563,729,"ex-wife trying to bleed"],[729,875,"her ex-husband dry."],[1030,1167,"How pathetic."],[1297,1355,"I'm guessing"],[1355,1484,"that she neglected her husband"],[1484,1584,"during their marriage,"],[1601,1818,"and now that she's tossed aside,"],[1818,1947,"she's finally regretting it."],[2022,2147,"What an ignorant woman."],[2394,2631,"Jonathan, did you forget"],[2631,2831,"how your books were actually written?"],[2865,2957,"The acknowledgements"],[2957,3069,"you wrote at the front."],[3086,3236,"The acknowledgements"],[3236,3340,"were written for me."],[3390,3678,"I am Jonathan's real muse."],[3724,3933,"After he ditched his basic,"],[3933,4091,"boring housewife like you,"],[4091,4304,"now Jonathan can be inspired"],[4333,4658,"to write even better novels."]],"43":[[16,204,"His real muse?"],[237,358,"That's beautiful."],[358,458,"Did you inspire him"],[458,625,"with all of your lacy underwear?"],[984,1234,"You think you can humiliate me?"],[1267,1347,"Look at me."],[1376,1685,"I'm gorgeous, seductive,"],[1743,1976,"like a luxury purse."],[1997,2181,"You're just a filthy kitchen mat."],[2898,3136,"Jonathan, it seems that you haven't"],[3136,3353,"told your new fiancee the truth yet."],[3353,3616,"But don't worry, I can do that right now."],[3641,3958,"The truth is that that the copyrights"],[3958,4187,"to Jonathan Asher's novels"],[4233,4425,"do not belong to him."]],"44":[[137,237,"That's right."],[300,513,"The copyrights were transferred to me."],[675,767,"We wanted to make sure"],[767,984,"you didn't get one cent from royalties."],[1042,1217,"You transferred the copyrights"],[1217,1326,"to your mistress?"],[1372,1543,"I've known you for 25 years,"],[1543,1659,"and in all those 25 years,"],[1659,1793,"you were a stingy miser."],[1793,1947,"Lili's my true love."