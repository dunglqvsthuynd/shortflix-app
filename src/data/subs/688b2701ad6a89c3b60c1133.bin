then, the two have conspired"],[5980,6172,"to oust myself,"],[6243,6431,"my lovely daughter Olivia,"],[6431,6577,"out of the company"],[6577,6881,"and blacklist us from the industry!"]],"47":[[45,254,"She's Henry Harper's mistress?"],[271,392,"Betraying her husband"],[392,517,"and her daughter?"],[575,704,"How shameless."],[746,884,"I never wanted to expose you"],[884,967,"like this, Anne."],[967,1126,"Due to all of our years together."],[1163,1309,"But today you took it too far."],[1359,1488,"Coming in here,"],[1547,1755,"tarnishing my reputation."],[1810,1960,"So don't blame me"],[1981,2235,"for exposing your secret affair"],[2235,2335,"to the press."],[2335,2485,"You brought this on yourself."],[2627,2702,"Jonathan!"],[2781,2861,"How dare you"],[2861,3023,"try and twist the facts like this."],[3053,3169,"Have you no shame?"],[3269,3403,"You shouldn't have come here today."],[3470,3661,"Now the whole world knows"],[3661,3887,"you're a cheating slut."],[3899,4024,"Who's gonna believe"],[4024,4287,"your empty accusations now?"],[4341,4546,"So if I got this right,"],[4546,4725,"the CEO and Chairwoman"],[4725,4892,"of an elite publishing house"],[4904,5005,"had an affair"],[5055,5196,"and then ousted you from the company"],[5196,5355,"as revenge for uncovering it?"],[5530,5809,"This is a huge scoop."],[5868,6026,"Once the news breaks,"],[6026,6235,"Roy Publishing House's stocks"],[6235,6452,"are going to plummet."],[6544,6602,"What are you gonna"],[6602,6756,"tell the board members now?"]],"48":[[54,271,"I see you've got it all planned out."],[304,362,"You're willing to"],[362,567,"tell outright lies about me,"],[600,675,"to destroy me,"],[675,779,"and all just for money?"],[796,934,"You need to understand"],[975,1188,"that ruining you is easier"],[1188,1301,"than lifting my pen."],[1347,1551,"This is what you"],[1551,1760,"need to learn your place."],[1780,1897,"What happened to you?"],[2010,2122,"You're a monster."],[2156,2385,"Just admit that you lost, Anne."],[2519,2702,"I could destroy you right now."],[2702,2798,"But I won't."],[2798,2923,"Given our years together,"],[2923,3103,"if you can shut your mouth"],[3140,3232,"and be the subservient"],[3232,3290,"housewife"],[3290,3395,"that you once were,"],[3395,3574,"I may take it easy on you."],[4212,4387,"You, you think you're so clever?"],[4421,4558,"You disgust me."],[4767,4888,"Acclaimed guests,"],[4929,5226,"I came here today to expose a dirty lie."],[5251,5480,"All of Jonathan Asher's novels"],[5480,5597,"were actually written"],[5676,5780,"by me."],[6022,6214,"I, his wife of 25 years,"],[6214,6485,"and the true author of all of his books."]],"49":[[87,342,"This woman is crazy!"],[362,563,"Ever since I divorced her,"],[563,792,"she's been having a mental breakdown."],[792,980,"She is hallucinating"],[1009,1226,"that she wrote all my novels."],[1247,1334,"The truth is,"],[1443,1664,"she can't accept the fact that her life,"],[1768,1885,"it's amounted to nothing."],[1997,2118,"I can testify to that."],[2147,2293,"My Dad wrote all those books."],[2293,2427,"That's the absolute truth."],[2431,2502,"Exactly."],[2506,2565,"Exactly."],[2565,2694,"Mr. Asher is the author!"],[2765,2894,"Of course Jonathan wrote"],[2894,3044,"all of his own novels."],[3098,3399,"I'm the inspiration for his masterpieces."],[3449,3553,"That's right, my darling."],[3578,3812,"I wrote every single line"],[3908,3949,"for you."],[4245,4508,"Every single line was written for you?"],[4596,4721,"You're delusional!"],[4750,4859,"You lunatic!"],[4896,5067,"You don't have a shred of evidence."],[5088,5192,"Who's going to believe"],[5192,5367,"your empty accusations?"],[5367,5572,"Oh, you'd like to see the evidence?"]],"50":[[20,254,"If you can't present evidence,"],[254,483,"then this counts as defamation."],[483,721,"And I'll put you in prison."],[784,850,"Ms. Roy,"],[871,975,"you should leave."],[1046,1184,"Otherwise, we're going to"],[1184,1322,"have to teach you a lesson."],[1351,1522,"I've already said I