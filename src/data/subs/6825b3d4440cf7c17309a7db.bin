{"1":[[1121,1180,"Oh my God,"],[1180,1426,"Arianna just rolled in a wheelchair."],[1906,1960,"Derek,"],[2014,2193,"why didn't you pick up my calls?"],[2268,2427,"Ew, what is that"],[2427,2552,"homeless woman doing here?"],[2569,2752,"She's talking to Derek Davis,"],[2798,2894,"maybe he knows her."],[3023,3219,"Uh, Arianna, what are you doing here?"],[3424,3490,"Derek, please,"],[3490,3666,"I need some money for my medicine."],[3707,3787,"The car accident"],[3787,3920,"caused internal bleeding"],[3920,4033,"and I need surgery."],[4033,4175,"I can't wait any longer."],[4195,4341,"Asking my fiancé"],[4341,4487,"for money like some beggar?"],[4625,4779,"Who gave you the audacity?"],[5238,5405,"I thought we were getting married,"],[5480,5568,"so I gave you,"],[5668,5839,"I gave you all my money, Derek."],[5901,5980,"I deserved every"],[5980,6106,"penny you ever gave me."],[6122,6160,"For putting up"],[6160,6281,"with a dumb bitch like you."],[6560,6664,"Now get the fuck out of here"],[6664,6794,"before people start to notice."],[6881,6994,"You said you loved me."],[7040,7144,"You, you asked me to sign"],[7144,7269,"my father's company to you"],[7269,7369,"after he died."],[7415,7607,"You, you said you would run it with me."],[7607,7670,"And..."],[7795,7916,"How dumb can you be?"],[7953,8033,"Look at yourself,"],[8074,8224,"look how disgusting you are."],[8316,8470,"You don't deserve someone like me."],[8671,8746,"Ivy does."],[8988,9088,"I don't deserve you?"],[9167,9355,"Your father was my driver, Derek."],[9409,9592,"I paid everything for you."],[9622,9859,"Prep school, college, even,"],[9951,10155,"even that ring on her finger."],[10447,10714,"Everything you have."]],"2":[[934,1063,"I'm sick, Derek."],[1197,1359,"I think I'm dying."],[1939,2147,"Stop doing drugs, Arianna."],[2193,2306,"Heroin will kill you."],[2348,2460,"This is the last time"],[2485,2602,"I'm gonna give you money."],[2660,2786,"You need to go to rehab,"],[2865,2977,"I can't do this anymore."],[3866,4037,"No, why are you doing this?"],[4145,4295,"I gave you everything."],[4362,4496,"Now it makes sense,"],[4512,4621,"she's a crack head."],[4675,4796,"She's probably Derek's relative"],[4796,4871,"or something."],[4892,5034,"Ugh, druggies,"],[5050,5201,"always asking for money."],[5572,5726,"Since you already like this,"],[5780,5897,"I'll just tell you the truth."],[5968,6072,"The accident that left you"],[6072,6222,"paralyzed from the waist down?"],[6448,6564,"We made that happen."],[6840,6923,"If I were you,"],[7203,7349,"I would just kill myself."],[7557,7624,"At this point,"],[7624,7753,"living like a stray dog."],[9046,9092,"Wait."],[9142,9192,"Come back."],[9192,9267,"You're lying!"],[9380,9488,"No."],[9672,9801,"No, don't go."],[9847,9905,"No,"],[9976,10047,"come back."],[10047,10151,"You're lying."],[10360,10418,"Arianna?"],[10518,10589,"Is that you?"]],"3":[[100,221,"Now Hayden's here."],[271,392,"Oh my God."],[400,600,"Is, is that Hayden Scott?"],[613,817,"The heir to the largest oil company"],[817,905,"in the world?"],[909,1092,"What is he doing with that junkie?"],[1192,1259,"All of you!"],[1292,1388,"Stop recording and get the"],[1401,1497,"fuck out of my sight."],[1634,1710,"Go on, get out of here."],[1710,1751,"Get."],[2298,2381,"Arianna, hang on."],[2381,2531,"I'm taking you to the hospital, okay?"],[2631,2690,"Hayden,"],[2836,2911,"why are you here?"],[2911,2982,"I,"],[3007,3194,"I'm sorry, I ruined your suit."],[3303,3428,"I must look horrible."],[3516,3624,"Oh, I'm sorry."],[3695,3824,"I, I should have come sooner."],[3899,4004,"I, I thought you were happy,"],[4004,4133,"so I, I didn't come."],[4195,4237,"If I knew"],[4237,4358,"Derek was gonna leave you like this,"],[4358,4491,"I never would have let you go with him."],[4608,4821,"I gave everything to,"],[4871,5180,"to a man who didn't love me."],[5321,5397,"And back then,"],[5397,5597,"when my dad wanted me to marry you,"],[5655,5822,"I refused. - What?"],[5830,5989,"And I was so mean to you."],[6093,6418,"Thank you for still caring about me."],[6552,6706,"I've always loved you, Arianna."],[6852,7002,"Nothing will ever change that."],[7178,7340,"If I could turn back time,"],[7428,7749,"I would do it all different."],[8074,8174,"I'm sorry."],[8195,8333,"No, no."],[8529,8575,"No."],[8787,8925,"No, no."],[8929,9067,"No, Arianna."],[9096,9138,"No."],[9376,9430,"No."],[9592,9667,"No."],[9880,10110,"No!"],[10823,10973,"Am I dead?"],[11453,11524,"Go."],[11799,12032,"Wait, am I in P.E. class?"],[12395,12466,"Oww."],[12491,12620,"This isn't a dream."],[12871,13046,"It's my senior year of high school."]],"4":[[75,225,"Arianna, Ivy, get ready,"],[225,337,"you two are up in five."],[934,984,"Hey,"],[1063,1163,"go easy on Ivy"],[1163,1259,"when you're on the court."],[1284,1472,"She's on her period today."],[1522,1693,"Oh, and when class is over,"],[1714,1780,"go get her a soda"],[1780,1868,"from the vending machine."],[1964,2093,"This is Derek"],[2131,2314,"from senior year of high school."],[2364,2590,"I gave you everything once, Derek,"],[2656,2777,"but you betrayed me"],[2790,2911,"and left me to die."],[3044,3144,"Well, not anymore."],[3215,3328,"Not this lifetime."],[3407,3478,"Not."],[3520,3586,"Ever."],[3611,3678,"Again."],[3878,4012,"Did you go deaf or something?"],[4049,4179,"In case you're too dense"],[4179,4266,"to understand,"],[4316,4596,"lose to Ivy on purpose."],[4758,4842,"Did you hear me?"],[5167,5213,"Yeah."],[5309,5380,"I heard you."],[5476,5543,"Loud and clear."]],"5":[[212,296,"Go Ivy."],[575,642,"Look,"],[671,759,"I know you're a simp"],[759,880,"for Derek and everything,"],[905,1051,"but if you go easy on Ivy,"],[1080,1188,"I'll break your nose."],[1301,1447,"Who said I would go easy on her?"],[1455,1580,"Oh please."],[1614,1739,"The entire school knows that"],[1739,1847,"you would do anything for Derek,"],[1889,2043,"and Derek would do anything for Ivy."],[2122,2239,"The three of you have some weird"],[2239,2389,"love triangle going on."],[2485,2577,"So back then,"],[2577,2706,"everyone could see it."],[2761,2990,"I was the only one who was blind."],[3148,3278,"But I'm applying to college"],[3278,3378,"on a sports scholarship,"],[3378,3490,"so if you make me"],[3490,3632,"look bad in front of coach,"],[3749,3874,"you're officially my enemy."],[4033,4166,"Arianna, you start."],[4429,4521,"Let's go."]],"6":[[834,942,"Failed serve."],[942,1067,"Ball goes to the red team."],[1134,1292,"Arianna, I swear to God,"],[1343,1422,"I'm bad at serving,"],[1422,1559,"but I'm good with blocks."],[1634,1893,"From now on, you serve, I block."],[1926,1985,"Trust me."],[1985,2043,"Please."],[2940,3036,"Yo."],[5192,5288,"Oww,"],[5288,5409,"my nose."],[5409,5467,"Ivy."],[5488,5563,"Oww."],[5580,5634,"Ivy."],[5701,5759,"Ivy!"],[6185,6281,"Look at what you did."],[6368,6427,"Ow."],[6493,6614,"I'm never speaking to you again."],[7165,7265,"Ivy, are you okay?"],[7273,7336,"Ow."],[7520,7741,"OMG, your nose is bleeding."],[7795,7924,"You good, Ivy?"],[7945,8058,"Of course not."],[8078,8199,"Arianna broke her nose."],[8241,8383,"She deserves detention."],[8550,8754,"Sorry, I didn't know she couldn't dig."],[9059,9146,"Oww."],[9154,9263,"Don't be dramatic."],[9292,9405,"Her nose is fine."],[9405,9576,"Just take her to the nurse's office."],[9584,9676,"A game is a game."],[9676,9788,"Athletes get hurt,"],[9788,9964,"but we don't cry about it."],[10010,10193,"You, you need practice."],[10193,10368,"Why don't you stay after tomorrow,"],[10368,10468,"and I'll train you."],[10698,10810,"You know Arianna,"],[10839,10952,"I was wrong about you."],[11052,11140,"You're actually pretty dope."],[11423,11561,"Oh, oww."],[11586,11653,"Oh."]],"7":[[287,433,"A chauffeur's daughter"],[433,617,"acting like she's some big shit."],[658,809,"Derek isn't even here yet."],[884,1034,"How do you have the face"],[1063,1255,"to ride in this car every day?"],[1484,1609,"I'm the chauffeur's daughter?"],[1651,1768,"Did Derek tell you guys that?"],[1885,2031,"Derek's too nice."],[2056,2135,"If it were me,"],[2135,2335,"I would never let her ride with me."],[2410,2556,"She should take the school bus"],[2556,2736,"like the broke bitch she is."],[2940,3032,"I'm a broke bitch?"],[3094,3219,"You guys are so funny."],[5618,5663,"Drive."],[5714,5834,"But Derek isn't here yet."],[5843,5926,"Let's wait for him."],[6081,6218,"Derek can take the school bus."],[6448,6594,"This is my car, and you drive for me."],[6656,6765,"Or did you forget that?"],[6848,7002,"What's wrong with this brat today?"],[7061,7140,"She's never spoken to me"],[7140,7232,"like this before."],[7382,7428,"Arianna,"],[7428,7590,"did you and Derek have a fight?"],[7645,7836,"Derek has your best interest in mind."],[7878,7953,"You should learn to be"],[7953,8066,"more appreciative."],[8145,8312,"I don't need you to lecture me, Jeff."],[8312,8375,"Just drive."],[8508,8591,"Today she's acting like"],[8591,8721,"a completely different person."],[8779,8829,"Hmm."],[8888,8950,"Doesn't matter."],[8992,9188,"One day, all her family's wealth"],[9188,9330,"will belong to my son."],[9380,9459,"After all,"],[9459,9601,"I'm her future father-in-law."],[9634,9709,"Let's see how long"],[9709,9872,"she can keep up this arrogance."],[9984,10085,"Are you leaving or what?"],[10181,10256,"Oh wait, Arianna, look."],[10447,10539,"Derek and Ivy are here."],[11382,11465,"Very well."]],"8":[[454,617,"Arianna, what are you doing?"],[671,721,"Didn't you say"],[721,867,"you never want to speak to me again?"],[896,975,"So why are you trying to"],[975,1105,"get into my car?"],[1522,1685,"Arianna's insane."],[1743,1939,"That's obviously Derek's car."],[2010,2214,"Derek, kick her out already."],[2477,2690,"Arianna, I was gonna forgive you,"],[2736,2911,"but you're pissing me off right now."],[2952,3040,"Forgive me?"],[3048,3182,"Why would I need your forgiveness?"],[3253,3499,"Arianna, how can you be so rude?"],[3520,3616,"I mean, just because Derek"],[3616,3745,"lets you ride in his car,"],[3745,3945,"doesn't mean his car is yours."],[4004,4137,"Yeah, so true."],[4191,4283,"Did you hear that, Derek?"],[4320,4529,"Just because I let you ride in my car,"],[4529,4729,"doesn't mean the car is yours."],[4925,5121,"What are you waiting for, Derek?"],[5180,5309,"You're just gonna let her walk"],[5309,5409,"all over you?"],[5572,5743,"Why is Derek not doing anything?"],[5851,5989,"If I don't get in this car,"],[5989,6081,"people will start"],[6081,6206,"questioning my identity."],[6235,6327,"They'll find out I'm nothing"],[6327,6439,"but the chauffer's son."],[6531,6731,"That can't happen."]],"9":[[179,479,"Oh my God, that is so funny."],[479,563,"Look at her getting"],[563,729,"kicked out of the car."],[734,913,"Got what she deserved."],[959,1013,"Drive."],[2410,2469,"Dad,"],[2560,2711,"my driver just left without me."],[2806,2952,"Can you please tell him to come back?"],[3107,3169,"Thanks, Dad."],[3278,3415,"Oh my God."],[3465,3645,"Stop pretending to be rich."],[3678,3828,"It's so embarrassing."],[3895,4066,"The car's not coming back."],[4104,4149,"Oh trust me,"],[4149,4325,"I don't have to pretend to be rich."],[4354,4491,"And the car is coming back."],[4529,4758,"She's so delulu."],[4771,4863,"As if."],[4900,5021,"If the car comes back,"],[5021,5176,"I'll eat my own foot."],[7323,7528,"Miss Taylor, please."],[7528,7603,"Get in the car."]],"10":[[29,183,"Wait, what's happening?"],[212,325,"Ivy, why is your"],[325,492,"boyfriend's driver doing that?"],[596,671,"Oh my God,"],[717,888,"was Arianna telling the truth?"],[925,1092,"It's actually her car?"],[1234,1301,"Derek?"],[1397,1480,"Say something."],[1555,1710,"Why are we just standing here?"],[2364,2435,"Miss Taylor,"],[2435,2585,"I know you're mad at Derek,"],[2631,2815,"but you didn't need to call your father."],[2915,3053,"Can we still take Derek home?"],[3107,3148,"No."],[3165,3232,"We can't."],[3282,3353,"Derek and Ivy"],[3353,3520,"are no longer welcome in my car."],[3616,3745,"I don't want to see them near it"],[3774,3849,"ever again."],[3878,3945,"Now drive."],[4041,4095,"Miss Taylor."],[4120,4195,"You know, Jeff,"],[4195,4320,"if you hate your job so much,"],[4320,4400,"you should just quit."],[4658,4717,"I'm sorry."],[4792,4888,"We're leaving now."],[5484,5676,"Don't piss me off this time, Arianna."],[5676,5809,"I won't forgive you easily."]],"11":[[66,129,"My home."],[275,379,"I'm really back."],[1997,2052,"No."],[2177,2310,"No, no."],[2769,2911,"Your dad wanted me to drop this off."],[3766,3820,"Arianna?"],[4041,4220,"Miss Taylor, the food is ready."],[4266,4346,"Do we need to wait"],[4346,4475,"for Derek to come back?"],[4500,4579,"No."],[4629,4725,"And moving forward,"],[4725,4842,"Derek's no longer welcome"],[4842,4954,"at my dinner table."],[5013,5113,"Miss Taylor."],[5150,5321,"You've finally come to your senses."],[5321,5380,"Oh."],[5455,5513,"It's okay, Jane."],[5513,5601,"I know what you mean."],[5780,5905,"You've never invited me"],[5905,5993,"for dinner before."],[6060,6168,"I thought you hated me."],[6185,6314,"I don't hate you, Hayden."],[6373,6435,"You literally have"],[6435,6569,"my phone number blocked,"],[6569,6635,"Arianna."],[6635,6756,"Is this some sort of prank? Like-"],[6756,6819,"Is this some sort of prank? Like-"],[6906,7019,"Oh, shoot."],[7019,7232,"That's right, in my past life,"],[7232,7432,"I was always so mean to Hayden"],[7440,7599,"because Derek disliked him."],[7649,7816,"Hayden beat Derek in everything,"],[7824,7978,"even the science competition."],[8016,8274,"Look, I'm sorry about the past."],[8320,8450,"I can't explain it right now"],[8458,8717,"but trust me, I'm a changed woman."],[9084,9134,"Arianna,"],[9134,9209,"what the hell are you doing"],[9209,9284,"with this prick?"]],"12":[[37,145,"What's going on here?"],[216,358,"You invited him to dinner?"],[404,513,"And you started without me?"],[579,646,"I'm leaving."],[658,742,"You two have fun."],[750,800,"No."],[850,921,"Please, wait,"],[1288,1368,"stay for dinner."],[1601,1718,"Hayden's my guest,"],[1718,1847,"why should we wait for you?"],[1897,2022,"I see what's happening here."],[2060,2218,"You're just trying to make me jealous."],[2243,2356,"Seriously Arianna,"],[2373,2489,"that's really immature."],[2519,2619,"Make you jealous?"],[2702,2827,"You're delusional Derek."],[2873,2990,"And your girlfriend Ivy,"],[2990,3078,"so go be with her"],[3078,3244,"and stop hanging around my house."],[3265,3357,"I live here too."],[3370,3532,"Yeah, because your dad's my chauffeur"],[3532,3695,"and he lives in the servant quarters,"],[3695,3795,"so go be with him."],[4041,4154,"Seriously Arianna,"],[4154,4266,"you're making me mad."],[4304,4396,"Cry me a river."],[4429,4512,"Now can you go?"],[4537,4633,"We're in the middle of dinner"],[4633,4746,"and you're interrupting."],[5000,5046,"You!"],[5055,5230,"You, you're gonna regret this."],[5572,5622,"Ow."],[6448,6652,"By the way, my dad"],[6702,6861,"transferred me to your school."],[6944,7094,"I'm not trying to stalk you or anything."],[7094,7248,"It was just, just my parents' idea"],[7248,7419,"and I figured it wouldn't hurt."],[7678,7841,"I'm so happy to hear that."],[8116,8254,"Welcome to Maple Valley High."]],"13":[[921,980,"Move."],[1088,1201,"You've got some nerve."],[1255,1343,"Yesterday, you just"],[1376,1530,"left Derek and Ivy behind"],[1530,1680,"and drove off in a car."],[1710,1847,"How shameless can you be?"],[1881,1964,"It's my car."],[1985,2085,"I have every right to decide"],[2085,2164,"who rides in it."],[2210,2289,"Why do you care?"],[2344,2414,"Who even are you?"],[2448,2540,"Your car?"],[2585,2723,"You're trying to tell me that"],[2736,2936,"Rolls Royce belongs to your family?"],[2998,3082,"Obviously."],[3132,3244,"What a joke."],[3340,3574,"You're just the maid's daughter."],[3628,3774,"Oh, a maid's daughter."],[3812,3899,"Did Derek tell you that?"],[3941,4166,"Your whole family works for Derek."],[4341,4500,"Our school is elite,"],[4546,4704,"poor people like you"],[4717,4934,"just don't belong here with us."],[4954,5113,"Have you ever stopped to think"],[5113,5288,"that maybe he was the one who was-"],[5288,5388,"Emmy, just go to your seat."],[5655,5826,"Derek, I'm sticking up for you."],[5872,6010,"Why are you being so mean to me?"],[6047,6318,"Oh Derek, everyone is so confused."],[6423,6544,"Don't you think it's time"],[6552,6810,"to explain your real identity?"]],"14":[[45,141,"Arianna, that's enough."],[191,296,"Class is about to start,"],[354,487,"and I don't have time to waste on it."],[575,629,"Derek,"],[629,863,"I've got all the time in the world"],[863,1042,"to play this game with you."],[1534,1655,"Derek, what's going on?"],[1685,1856,"You said she's just the maid's daughter."],[1906,1964,"Why are you letting her"],[1964,2102,"disrespect you like that?"],[2177,2289,"Everyone's starting to think"],[2289,2460,"that Arianna's the real rich girl."],[2635,2781,"Don't worry about what they think."],[2815,3019,"My dad's close with Arianna's family."],[3073,3207,"He told me to look out for her."],[3249,3524,"I just can't ignore that, right?"],[3603,3787,"Oh, I see."],[3916,4020,"Derek's always buying me"],[4020,4120,"expensive gifts."],[4124,4195,"There's no way"],[4195,4312,"he's not the real deal."],[4383,4425,"Right?"],[4979,5050,"Arianna,"],[5100,5221,"I saw you texting that prick"],[5221,5301,"Hayden earlier."],[5338,5447,"Don't think for a second"],[5447,5597,"that using him to make me jealous"],[5597,5684,"is gonna work."],[5718,5901,"It will only disgust me more."],[6335,6377,"Oh,"],[6389,6481,"and you're late on this"],[6481,6539,"month's payment."],[6715,6777,"Venmo me."]],"15":[[25,158,"If you're so disgusted by me,"],[158,258,"then why are you asking me"],[258,300,"for money?"],[429,496,"Oh, right."],[517,583,"You need money to"],[583,742,"pretend you're rich for Ivy."],[809,988,"I earned that money tutoring you."],[1021,1192,"Derek, you barely taught me anything."],[1213,1343,"My grades have actually lowered"],[1343,1488,"since you started tutoring me."],[1726,1860,"So I guess you're fired."],[2039,2218,"It's not my fault you're stupid."],[2256,2448,"If I don't tutor you, no one will."],[2477,2573,"Oh trust me,"],[2573,2706,"I already have a new tutor."],[2927,3044,"Hayden, remember?"],[3053,3132,"The guy who beat you"],[3132,3253,"in every competition."],[4074,4129,"Derek,"],[4129,4241,"what were you arguing about"],[4241,4287,"with her?"],[4371,4521,"What's going on with you two lately?"],[4562,4658,"Don't worry about her."],[4658,4788,"She's just trying to get my attention"],[4788,4875,"on purpose."],[5017,5084,"By the way,"],[5121,5296,"it's your birthday this weekend."],[5342,5426,"Are we gonna have your party"],[5426,5568,"at your parents' hotel like last year?"],[5672,5747,"It's just,"],[5822,5901,"you know,"],[5980,6181,"I don't have a suitable dress"],[6239,6343,"or purse,"],[6389,6560,"I'm afraid I'll embarrass you."],[6664,6765,"Don't worry, Ivy."],[6794,6886,"I'll buy you the most"],[6886,7123,"expensive dress and purse."],[7236,7349,"You're the best, Derek."],[7511,7590,"I get it now."],[7603,7720,"Last year's birthday"],[7720,7891,"was entirely arranged by Arianna,"],[7937,8066,"and she mentioned a few days ago"],[8066,8195,"that everything was already planned"],[8195,8274,"for this year."],[8350,8495,"It seems like her recent behavior"],[8495,8587,"has been deliberate."],[8662,8775,"She's trying to surprise me"],[8775,8871,"on my birthday."]],"16":[[4,204,"This Saturday is my birthday."],[233,316,"Everyone will be coming"],[316,450,"to the Maple Hotel."],[788,888,"Party's on me,"],[917,1096,"do whatever you want."],[1134,1334,"I'll cover everything."],[1393,1559,"Oh my God, the Maple Hotel?"],[1601,1801,"That's the most luxurious hotel"],[1801,1910,"in Maple Valley?"],[1910,2147,"Derek, you're seriously next level."],[2198,2285,"You didn't know?"],[2335,2681,"The hotel is owned by Derek's family."],[2740,2919,"Last year's party was there too."],[2948,3140,"It was so dope."],[3436,3495,"Look."],[3953,4008,"Yeah."],[4045,4250,"Emmy, I'm so jealous of you."],[4250,4421,"It's such an honor to be invited"],[4421,4575,"to Derek's birthday."],[4596,4683,"We're so lucky"],[4683,4846,"to have Derek as our classmate."],[4896,5046,"Last year's photos got me"],[5046,5251,"so many likes."],[5280,5342,"This year,"],[5409,5638,"I'm definitely gonna post even more"],[5638,5739,"on my social media."],[6698,6790,"Thanks Derek."],[6823,6961,"You're the coolest."],[6961,7190,"Derek, should we invite Arianna?"],[7257,7319,"Her?"],[7399,7486,"Even if we don't,"],[7486,7632,"she'll come crawling anyways."],[7716,7778,"True."],[7778,7991,"She never misses your birthdays."],[8045,8116,"Arianna,"],[8116,8312,"you've been causing a scene for days,"],[8400,8541,"all for my birthday, huh?"],[8596,8804,"Well, I'm gonna teach you a lesson"],[8804,8896,"at the party."],[8938,9171,"Let's see if you dare act up after this."]],"17":[[446,542,"Hayden's so"],[542,721,"good at explaining things."],[855,1005,"How did I not see how amazing"],[1005,1126,"Hayden was before?"],[2010,2060,"Hello?"],[2139,2256,"Earth to Arianna?"],[2344,2444,"Am I boring you?"],[2460,2548,"No, no."],[2569,2781,"I'm sorry, I'm just really bad at math."],[2819,2961,"Nobody's bad at math,"],[2961,3015,"we just have to"],[3015,3132,"find your learning style."],[3153,3244,"Okay, um."],[5046,5138,"Arianna, did you have someone"],[5138,5255,"throw my stuff out again?"],[5472,5605,"What's he doing here again?"]],"18":[[33,237,"I told you this morning, you're fired."],[258,454,"You have no right to be in my house."],[496,613,"What are you even doing here?"],[700,804,"Arianna, do you think"],[804,942,"humiliating me is fun?"],[1009,1096,"Don't think I don't know"],[1096,1201,"what's going on here."],[1251,1368,"I have a lesson to finish."],[1409,1526,"Don't disturb us."],[1568,1722,"Honestly seeing you annoys me."],[1889,2010,"At the birthday party,"],[2027,2185,"I'll make you regret this."],[2202,2360,"I'll make you beg for my forgiveness"],[2360,2498,"in front of everyone."],[2823,2944,"Sorry about that,"],[2965,3053,"shall we continue?"],[3123,3319,"Um, it's getting pretty late."],[3319,3470,"Maybe I should head out."],[3503,3599,"Leaving already?"],[3599,3645,"I-"],[3666,3741,"Oh, Hayden."],[4412,4508,"Before you go,"],[4612,4738,"are you free Saturday?"],[4800,4904,"I was thinking of going to"],[4904,5025,"the Maple Hotel restaurant"],[5025,5100,"for dinner."],[5176,5296,"Will you come with me?"],[5338,5392,"I miss it,"],[5392,5568,"I haven't been there in so long."],[5601,5714,"Has it been that long?"],[5768,5843,"I feel like you and Derek"],[5843,5935,"were just there last week."],[5935,5989,"It seems like"],[5989,6110,"you take him there all the time."],[6168,6260,"How do you know that?"],[6352,6423,"Because I,"],[6498,6589,"own the hotel."],[6644,6806,"I can see the RSVP list,"],[6856,7019,"but that makes me seem creepy."],[7048,7190,"Because I love their food too."],[7332,7499,"I've seen you guys there a few times."],[7536,7695,"So will you come with me or not?"],[7724,7862,"Of course I wanna come."],[7903,7987,"Then it's settled."],[8074,8170,"See you Saturday."]],"19":[[2352,2519,"Arianna,"],[2602,2756,"Derek hasn't spoken to you"],[2756,2890,"in days at school."],[2898,3098,"And now, on his birthday,"],[3123,3311,"you actually have the nerve"],[3311,3411,"to show up?"],[3474,3574,"It's his birthday today?"],[3632,3745,"I totally forgot."],[3757,3820,"I'm actually here"],[3820,3924,"to meet with a friend."],[4049,4137,"In my last life,"],[4137,4312,"I spent over a million dollars"],[4312,4379,"throwing Derek"],[4379,4542,"a lavish birthday party here."],[4604,4713,"Just as I was about to"],[4713,4829,"confess my feelings,"],[4829,5009,"he kissed Ivy in front of everyone"],[5009,5117,"and kicked me out."],[5226,5305,"This time,"],[5330,5480,"I'm going to give him a birthday"],[5480,5597,"he'll never forget."],[6331,6498,"Don't think showing up at my birthday"],[6498,6635,"is gonna make me forgive you."],[6681,6827,"Arianna, I'm still mad at you."],[6886,7132,"And just because you're wearing"],[7132,7303,"the same dress as Ivy,"],[7349,7419,"doesn't mean"],[7419,7557,"I'm gonna give you a chance."],[7695,7832,"Derek, don't flatter yourself."],[7887,8016,"I'm not here for your birthday."]],"20":[[29,129,"What are you talking about?"],[183,300,"Then why are you here"],[300,429,"dressed like that?"],[462,554,"Arianna,"],[575,779,"since you like the dress that much,"],[800,925,"I'll give you mine after."],[1001,1138,"Come on, it's Derek's birthday,"],[1167,1380,"don't ruin his mood, okay?"],[1572,1722,"Ivy, you're too kind."],[1801,2143,"She's wearing a cheap knockoff"],[2156,2373,"just to steal your spotlight."],[2381,2660,"She needs to apologize."],[2706,2819,"Seriously, Emmy."],[2836,2965,"You're like their guard dog."],[2986,3194,"Barking at people, for what?"],[3236,3403,"Because you think they're rich?"],[4391,4458,"What?"],[4871,5021,"This gown was handmade"],[5021,5196,"by designer Vivian Oakwood."],[5226,5351,"It's one of a kind."],[5405,5526,"You owe me five grand."],[5526,5601,"Me?"],[5638,5843,"I owe you five grand?"],[5864,6135,"The dress is obviously fake."],[7611,7728,"That's what you get"],[7728,7903,"for calling me a dog,"],[7903,8220,"you stupid peasant bitch."],[8875,8938,"Ow."]],"21":[[70,120,"Ow."],[350,529,"Oh my God, is that Hayden Scott?"],[546,704,"His dad is hella rich."],[713,825,"What is he doing here?"],[1555,1626,"Don't you dare"],[1626,1776,"put your fucking hands on her."],[2389,2460,"Arianna,"],[2548,2727,"can I speak to you in private for a sec?"],[4154,4308,"Arianna, have you had enough?"],[4354,4437,"It's my birthday."],[4471,4629,"Stop trying to embarrass me."],[4717,4775,"Where were you"],[4775,4913,"when they tore my dress apart?"],[4950,4996,"Or what about"],[4996,5088,"when your so-called friends"],[5088,5221,"tried to embarrass me?"],[5413,5572,"It's not my fault that"],[5572,5764,"you're wearing the same dress as Ivy."],[5926,6139,"Fine, I'll let it slide."],[6272,6339,"You're supposed"],[6339,6531,"to celebrate my birthday with me,"],[6556,6815,"and pay for everything."],[6898,6998,"Oh, that's right."],[7019,7140,"He's still counting on me"],[7140,7265,"to pay his bill."],[7315,7486,"Fine, let's play."],[7599,7811,"Alright, I get it."],[7878,7962,"It's your birthday."],[8008,8128,"This entire venue's already"],[8128,8216,"booked out anyway."],[8329,8487,"So have fun, birthday boy."],[8571,8625,"Hah."],[8658,8717,"I knew it."],[8762,8925,"In the end, you'll still give in"],[8925,9038,"to make me happy."],[9205,9321,"Alright everyone,"],[9363,9484,"stop standing around,"],[9584,9851,"it's time to party."],[9989,10268,"Woo!"],[10527,10744,"Come on, I have a VIP room here."],[10794,10865,"Let's go to dinner."],[10919,11011,"Wait, I thought you were here for"],[11031,11123,"Derek's birthday."],[11156,11269,"Of course not."],[11302,11473,"I came here to eat dinner with you."]],"22":[[950,1030,"What is it?"],[1188,1301,"You can ask me anything."],[1805,1935,"What's your plan with Derek?"],[2002,2122,"Are you gonna pay for his birthday?"],[2122,2177,"Yeah."],[2252,2310,"I am."],[2448,2498,"Oh."],[2610,2669,"I see."],[2727,2777,"Why?"],[2898,2965,"Are you jealous?"],[3044,3153,"Why would I be jealous?"],[3207,3269,"It's your money."],[3269,3374,"You can do whatever you want with it."],[3478,3616,"She still cares about him,"],[3661,3862,"if she's paying for his birthday party."],[3983,4183,"Alright, alright."],[4283,4379,"I'll tell you my secret."],[4483,4650,"This is my lesson for Derek."],[4767,4888,"He's been pretending to be rich"],[4888,5025,"for the past four years and"],[5084,5209,"tonight is the night when everyone"],[5209,5405,"sees him for who he truly is."],[5860,5960,"Maybe I can help you."],[6039,6151,"I know the hotel manager,"],[6151,6231,"I'll call him right now."],[6277,6343,"And I'll have him bring you"],[6343,6418,"a new dress."]],"23":[[1701,1755,"Wow."],[1776,1910,"Beluga caviar."],[1943,2052,"Four grand a pop."],[2122,2202,"How fancy."],[2398,2631,"Why is she always one upping me?"],[2840,3028,"My God, are you trying to"],[3028,3203,"steal our leftover food?"],[3203,3345,"She's probably never seen something"],[3345,3461,"so fancy before."],[3549,3745,"Arianna, you can pack the leftovers."],[3745,3887,"Derek is covering the bill tonight."],[3887,4016,"No need to steal food."],[4108,4279,"That's, that's not exactly what-"],[4279,4446,"Oh, so I don't have to pay?"],[4496,4625,"Well, that's just fantastic!"],[4813,4950,"Sir, here's tonight's bill."],[6322,6506,"Um, take this to the girl over there."],[6690,6748,"Sir,"],[6765,7036,"your bill is $36,000.89."],[7102,7194,"Cash or credit?"]],"24":[[25,87,"Wait."],[179,446,"Why is Maple Hotel making Derek pay?"],[558,709,"Doesn't he own this hotel?"],[863,1155,"Wait, um, she didn't already pay?"],[1226,1363,"Why would we give the bill"],[1363,1455,"to Miss Taylor?"],[1634,1764,"You're the one who booked the venue."],[2077,2306,"I, I, I'm..."],[2540,2673,"Ahh, happy birthday."],[2790,2919,"Now, the bill please?"],[2932,2998,"Derek,"],[3048,3182,"what's with your staff"],[3211,3370,"disrespecting you like this?"],[3395,3595,"You should fire him immediately!"],[3724,3920,"Derek, is everything okay?"],[4037,4095,"Fire him!"],[4149,4262,"Fire him."],[4262,4487,"Fire him! Fire him!"],[4512,4742,"Fire him! Fire him!"],[4763,5563,"Fire him! Fire him! Fire him! Fire him!"],[5588,5705,"Boss, I think these people"],[5705,5830,"are trying to dine and dash!"],[5943,5997,"Wait."],[6051,6260,"Arianna is the owner of this hotel?"]],"25":[[104,162,"Wait."],[162,350,"Who is this manager calling boss?"],[387,529,"Arianna or the guy next to her?"],[558,729,"And why doesn't the hotel manager"],[729,850,"even recognize Derek?"],[884,1130,"Doesn't this hotel belong to his family?"],[1167,1251,"No way!"],[1297,1426,"Derek wouldn't lie"],[1426,1539,"about something like this!"],[1580,1747,"That guy must be..."],[1747,1931,"an actor Arianna hired!"],[2043,2127,"Derek,"],[2127,2381,"just call the hotel's real manager"],[2381,2590,"and clear this up!"],[3470,3620,"Arianna, it's my birthday!"],[3666,3732,"What the hell are you"],[3732,3816,"doing right now?"],[3858,3983,"Just pay the damn bill,"],[3983,4066,"and I'll forget about everything"],[4066,4149,"that happened tonight."],[4179,4245,"That's funny."],[4525,4642,"You throw a party,"],[4688,4850,"let them eat and drink like kings,"],[4879,5038,"call me a broke nobody,"],[5038,5188,"and now you want me to pay?"],[5296,5459,"When did I ever say I'll pay for you?"],[5584,5676,"You..."],[5914,5976,"Arianna,"],[6064,6197,"what's that supposed to mean?"],[6227,6277,"What?"],[6277,6335,"Can't afford it?"],[6418,6498,"How about this?"],[6598,6744,"Split the bill with your friends."],[6998,7127,"You used my money to treat them"],[7127,7265,"plenty of times before."],[7298,7411,"I'm sure they'd be happy"],[7411,7507,"to return the favor."],[7582,7770,"Arianna, don't push it!"],[7928,8033,"Do you have to do this?"],[8153,8204,"Fine,"],[8204,8395,"just tell me"],[8395,8504,"what it will take for you"],[8541,8704,"to cover this bill?"],[8787,8896,"If you're asking for a favor,"],[8896,9009,"shouldn't you at least"],[9009,9117,"act like you need one?"],[9259,9430,"Arianna, you-"],[9430,9555,"Not willing? That's fine."],[9555,9680,"I won't force you."],[9864,9914,"Fine!"],[10472,10535,"I,"],[10623,10673,"beg you."],[10935,11061,"Doesn't sound sincere enough."],[11144,11240,"Beg me properly."],[11344,11457,"What did you just say?"],[11457,11561,"I said beg me."],[11586,11778,"And maybe, just maybe,"],[11778,11903,"I'll consider paying the bill."]],"26":[[141,208,"Arianna,"],[325,421,"I'm sorry."],[613,700,"I was wrong."],[804,988,"Please, don't humiliate me"],[988,1092,"in front of everyone."],[1238,1422,"Arianna, I'm begging you."],[1889,1981,"Please."],[2156,2285,"Pay for this bill."],[4262,4346,"Alright."],[4654,4708,"The bill."],[4954,5075,"Let's see."],[5075,5242,"You racked up quite the bill, Derek."],[5330,5467,"$40,000."],[5726,5847,"Thank you, Miss Taylor!"],[5926,6064,"I'll cover for you this time."],[6143,6264,"But it'll never happen again."],[6310,6402,"Is that clear, Derek?"],[6623,6873,"After all, we are friends"],[6873,7007,"and I can cover you."],[7027,7102,"But why should I pay"],[7102,7228,"for your girlfriend as well?"],[7332,7440,"And her friends too."],[7536,7674,"What am I, an ATM?"],[8583,8671,"Happy"],[8725,8842,"birthday."]],"27":[[504,738,"Why did Derek need Arianna to pay?"],[804,909,"Isn't he supposed to be"],[909,1046,"the billionaire's son?"],[1092,1326,"Does Derek not have money of his own?"],[1326,1497,"I think he's actually poor"],[1497,1659,"and Arianna's the rich one."],[2627,2706,"Arianna,"],[2736,2894,"you humiliated me like this."],[2940,3140,"I swear I'll never forgive you!"],[3140,3432,"Arianna, what kind of joke is this?"],[3486,3670,"You're just Derek's housemaid!"],[3682,3753,"Of course, you were"],[3753,3899,"holding onto his card."],[3899,4170,"How dare you act like it's yours?"],[4170,4458,"What exactly are you so proud of?"],[4575,4621,"I see."],[4662,4754,"So you were just holding"],[4754,4867,"onto Derek's card?"],[4913,5096,"You two are so stupid"],[5096,5246,"you have to hear Derek say it, huh?"],[5321,5392,"Alright then,"],[5392,5526,"let's have him say it himself."],[5568,5718,"Derek, tell them."],[5747,5918,"Who's really the servant here,"],[5943,6097,"you, or me?"],[6765,6911,"Since Derek won't say it,"],[6936,7069,"I'll tell you myself."],[7148,7340,"Derek's father is my-"]],"28":[[37,208,"Derek's father is my-"],[208,379,"Enough, Arianna!"],[792,896,"I've never been humiliated"],[896,1021,"like this in my life."],[1080,1230,"Everyone was laughing at me."],[1297,1384,"Arianna,"],[1418,1568,"I'll make you pay for this."],[1601,1730,"Twice over."],[2268,2435,"Running away already, Derek?"],[2489,2640,"I won't expose you yet,"],[2640,2857,"your nightmare is just beginning."],[3803,3937,"Sorry, you had to see all that."],[3937,4016,"Are you kidding?"],[4016,4116,"That was entertaining!"],[4162,4229,"And it definitely"],[4229,4337,"worked up my appetite."],[4391,4450,"Oh, and by the way,"],[4450,4592,"the money that you paid for Derek's bill."],[4592,4713,"I'll have the manager refund it."],[4738,4813,"No way."],[4813,4975,"That was my lesson for Derek."],[5038,5201,"I won't let you lose money over it."],[5267,5359,"Besides, I'll make sure"],[5359,5484,"Derek pays me back."],[5547,5655,"But I really didn't expect you"],[5655,5855,"to be the owner of Maple Hotel!"],[5914,6081,"No wonder the food here is so good."],[6143,6197,"I love it."],[6402,6485,"Well, if you like it,"],[6523,6644,"you can come here every day."],[6790,6956,"Just treat it like your own home."],[7032,7098,"I mean it,"],[7190,7307,"what's mine is yours."],[7716,7916,"Back then, my father wanted Hayden"],[7916,8041,"to be my fiancé,"],[8041,8208,"but I never really knew him."],[8283,8379,"Now I see."],[8420,8683,"He's elegant, kind, and honestly,"],[8733,8863,"he's fun to be around."],[9121,9209,"Now come on."],[9209,9300,"Have them prepare all of your"],[9300,9396,"favorite foods."],[9430,9572,"Eat first, then I'll take you home."],[10197,10256,"Bye."],[10310,10372,"Bye."],[10773,10831,"Arianna!"],[10885,10981,"Finally, you're back!"],[10981,11144,"I wanted to bring Derek by"],[11144,11290,"to apologize to you!"]],"29":[[475,546,"Arianna,"],[579,779,"this was all a misunderstanding."],[825,1042,"Derek was way out of line!"],[1055,1146,"Please forgive him."],[1176,1322,"Jeff, Derek's done nothing"],[1322,1418,"to offend me."],[1418,1522,"What exactly should he"],[1522,1659,"be apologizing for?"],[1810,1893,"But I heard you"],[1931,1993,"fired him."],[2102,2156,"Yeah,"],[2206,2298,"and you too, Jeff."],[2364,2448,"Did you forget?"],[2498,2640,"One of you was my driver"],[2640,2794,"who left me stranded on the road,"],[2877,3069,"and the other one was my tutor"],[3069,3294,"who made my grades plummet."],[3294,3382,"Tell me,"],[3382,3574,"why shouldn't I fire you both?"],[3778,4116,"Arianna, no, Miss Taylor,"],[4116,4320,"I, I was careless last time."],[4383,4558,"But I have been friends with"],[4558,4700,"your father for years."],[4700,4909,"You can't just fire me."],[4909,5050,"I need this job."],[5071,5334,"And Derek does even more."],[5372,5438,"How about this?"],[5492,5743,"He'll focus on teaching you."],[5784,5935,"Really focus on teaching you"],[5935,6010,"from now on."],[6089,6235,"Jeff, you've been talking so much,"],[6235,6318,"but look at Derek."],[6485,6639,"Does he look remotely sorry?"],[6773,6831,"Get up!"],[6977,7140,"Apologize to Miss Taylor!"],[7586,7678,"You idiot!"],[7724,7937,"Do you want to see her fire both of us?"],[7937,8133,"I owe a ton of money."],[8170,8279,"You think I could pay that back"],[8279,8412,"without this job?"],[8433,8646,"You need to play nice."],[8671,8771,"If you do,"],[8771,9034,"one day, the entire Taylor fortune"],[9034,9159,"could be yours."],[9196,9417,"Aw, I'm getting tired."],[9492,9609,"You two should leave."]],"30":[[237,342,"Apologize!"],[875,946,"Arianna,"],[988,1138,"you've gone too far this time."],[1138,1209,"Don't ever come"],[1209,1351,"begging for my help again!"],[2477,2585,"Almost forgot,"],[2673,2806,"Jeff's a gambling addict."],[2836,2923,"All those dues,"],[2961,3144,"I used to be the one covering for him."],[3224,3319,"But now that I've"],[3319,3520,"cut off Derek's credit card,"],[3520,3666,"let's see how he plans on repaying"],[3666,3878,"all those sky-high gambling debts."],[5176,5351,"Arianna, was it really you"],[5351,5488,"who paid for last night's party?"],[5513,5597,"That's insane!"],[5672,5768,"You must be loaded!"],[5805,5951,"So, does that mean that"],[5951,6160,"all of Derek's money came from you?"],[6160,6314,"We really thought he was some"],[6335,6493,"rich second-gen heir!"],[6548,6614,"Arianna,"],[6614,6790,"maybe you should consider me instead."],[6856,7023,"I swear I'd be way better than Derek!"],[7190,7294,"You wish."],[7294,7361,"But do you even think"],[7361,7461,"she'll look at you?"],[7553,7691,"Didn't you see her yesterday?"],[7782,7882,"She's already set her eyes"],[7882,7962,"on a new target."],[8037,8245,"If you want to turn, get in line."],[8525,8733,"So, just because"],[8733,8854,"I wouldn't go out with you,"],[8875,9000,"you had to go out of your way"],[9000,9100,"to humiliate me?"],[9192,9259,"Arianna,"],[9292,9496,"even if you pull all these stunts,"],[9534,9651,"I still won't like you."],[9805,10030,"You're just a spoiled brat"],[10030,10264,"with terrible grades,"],[10264,10427,"a shameless liar,"],[10477,10773,"and a walking joke."],[10773,10990,"You're nothing compared to Ivy,"],[11027,11186,"not even a single strand of her hair."],[11257,11357,"Exactly!"],[11386,11586,"Everyone knows Arianna's famous"],[11586,11966,"for having a GPA under 2, okay?"],[11966,12249,"She's chased after Derek for years,"],[12249,12362,"and now she's hanging"],[12362,12504,"all over Hayden."],[12504,12675,"We don't know if she's"],[12675,12854,"really a rich heiress,"],[12900,13029,"but what we do know"],[13071,13321,"she's a certified flirt."],[13901,14018,"Yeah, makes sense."],[14018,14172,"Arianna's got bad grades"],[14172,14314,"and bad character."],[14364,14497,"Derek's a top student."],[14497,14606,"he was even invited to"],[14606,14773,"the Honor Society last year."],[14793,14914,"Of course he wouldn't want her!"]],"31":[[25,275,"I didn't even want to have that party."],[325,408,"Arianna's the one"],[408,588,"that insisted I invite everyone."],[621,767,"But in the end,"],[817,963,"you had to set everything up"],[963,1092,"to embarrass me."],[1184,1238,"What?"],[1263,1397,"You think having money"],[1397,1509,"gives you the right to trample"],[1509,1651,"on other people's dignity?"],[1651,1789,"And don't twist the truth,"],[1789,2039,"I earned every cent you ever gave me."],[2102,2185,"Don't worry."],[2239,2381,"I won't ask for a single penny"],[2381,2477,"ever again."],[2590,2656,"And you can"],[2656,2815,"forget about me tutoring you."],[2840,3044,"Derek, apart from spending my money,"],[3044,3224,"what exactly have you taught me?"],[3257,3470,"If my grade is below a 2.0,"],[3536,3636,"isn't that the result"],[3636,3737,"of your tutoring?"],[3807,4016,"It's not my fault, you're an idiot."],[4124,4175,"Arianna,"],[4175,4383,"don't blame me for your incompetence."],[4429,4558,"You have all this money,"],[4558,4813,"why not buy yourself a brain?"],[5251,5359,"The real problem"],[5409,5563,"is your teaching methods."],[5563,5622,"Oh?"],[5672,5772,"Well, now that you've found yourself"],[5772,5868,"a new tutor,"],[5897,6051,"let's put it to the test."],[6076,6177,"At the end of the month,"],[6222,6339,"let's see your grades."],[6368,6493,"I won't ask for much,"],[6493,6794,"just get to 3.0 GPA"],[6831,7132,"and I'll admit I was the problem."],[7173,7232,"Oh?"],[7323,7528,"If I score above a 3.5,"],[7528,7595,"are you willing to"],[7595,7732,"make a bet with me, Derek?"]],"32":[[83,287,"If I score above a 3.5,"],[287,354,"are you willing to"],[354,492,"make a bet with me, Derek?"],[1084,1167,"You?"],[1167,1326,"Score 3.5?"],[1326,1405,"Please!"],[1497,1630,"If you're scared,"],[1630,1797,"just admit defeat and"],[1797,1968,"apologize to Derek."],[1985,2089,"We'll let this go."],[2143,2364,"Arianna, don't be impulsive."],[2364,2585,"This is impossible for you."],[2748,2873,"This idiot Arianna"],[2873,3053,"has completely lost it."],[3053,3199,"I'll use this exam to show her"],[3199,3311,"exactly what happens"],[3311,3461,"when she crosses me."],[3461,3557,"Fine."],[3603,3732,"If you can even manage to"],[3732,3895,"get above 3.5,"],[3970,4175,"I'll run 20 miles"],[4175,4387,"and publicly apologize."],[4512,4600,"20 miles?"],[4600,4738,"Mm, that's too easy."],[4804,4888,"If we're betting,"],[4921,5042,"let's make it interesting."],[5084,5226,"If you lose,"],[5259,5467,"you have to wear my lingerie"],[5467,5584,"on your head."],[5630,5718,"Join the girls'"],[5718,5876,"beach volleyball cheer squad,"],[5901,6031,"put on a miniskirt,"],[6076,6277,"and cheer while apologizing to me!"],[7194,7273,"Arianna,"],[7273,7374,"I don't think you'll ever see that"],[7374,7474,"in this lifetime!"],[7778,7845,"Fine."],[7978,8241,"But if you don't get above 3.5,"],[8375,8575,"you'll admit you're an idiot,"],[8650,8821,"you'll scrub the boys bathroom"],[8821,8929,"every day,"],[9046,9188,"and you'll have every virgin"],[9188,9275,"in this school"],[9359,9517,"lose their virginity."],[10610,10685,"Arianna,"],[10685,10898,"your dumb brain can't be saved."],[10923,11119,"No tutor can fix stupidity."],[11119,11298,"You're guaranteed to lose."]],"33":[[25,120,"So it's a deal."],[241,450,"But Derek, don't underestimate me."],[592,717,"You might lose,"],[775,867,"miserably."],[1643,1914,"It was just two times this week."],[1939,2097,"I know, but two times too many."],[3570,3636,"Oh!"],[3707,3770,"Oh!"],[3903,4033,"Dad, you came back?"],[4033,4154,"I missed you, sweetheart."],[4183,4283,"So I came back early."],[4383,4491,"Come on, let's go home."],[4825,4929,"Oh my God!"],[5000,5075,"Derek,"],[5075,5292,"is that Arianna's new sugar daddy?"],[5292,5513,"Oh, Emmy, don't jump to conclusions."],[5572,5860,"That man looks at least 50, doesn't he?"],[5930,6126,"Though they are awfully close."],[6260,6360,"I knew Arianna"],[6360,6523,"wasn't some rich heiress."],[6523,6656,"Guess we finally figured out"],[6656,6823,"where her money really comes from."],[6823,7002,"No wonder Derek didn't want her."],[7044,7194,"She's gross!"],[7244,7494,"Arianna, you humiliated me."],[7528,7649,"Now, I'll let you feel"],[7649,7807,"what it's like to be looked down on."],[7874,7987,"If I don't say anything,"],[7987,8133,"everyone will just assume"],[8133,8412,"you're some old man's kept woman."]],"34":[[66,204,"Derek, do you really think"],[204,346,"Arianna's being kept?"],[383,462,"And is that really how she"],[462,546,"makes her money?"],[604,704,"What do you think?"],[734,809,"Someone like her"],[809,971,"has to rely on someone else."],[1192,1347,"Even relying on her dad"],[1347,1509,"is still relying on a man."],[1564,1726,"This is what you get, Arianna,"],[1747,1864,"for crossing me."],[2419,2510,"Arianna,"],[2577,2656,"you're being unusually"],[2656,2727,"affectionate."],[2777,2869,"Did something happen?"],[2998,3078,"It's nothing."],[3140,3340,"I just haven't seen you in so long, Dad."],[3432,3503,"I've missed you."],[3816,3970,"Back then, when my father"],[3970,4170,"was in that accident overseas,"],[4220,4350,"I was powerless."],[4350,4483,"That's how Derek managed to"],[4483,4650,"deceive me and steal the company."],[4733,4954,"This time, I'll protect our company."],[5021,5130,"And more importantly,"],[5276,5497,"I'll protect my father."],[5643,5730,"Silly girl."],[5805,5897,"Tell me the truth."],[5964,6110,"Did Derek bully you again?"],[6206,6310,"Arianna, listen to me."],[6310,6427,"He's not right for you."],[6498,6644,"The Scott family is powerful."],[6702,6890,"And Hayden isn't just capable."],[6890,7152,"He's respectful, devoted,"],[7203,7365,"and he genuinely cares for you."],[7424,7553,"Dad, I'll listen to you."],[7674,7745,"Sweetheart,"],[7824,7937,"are you sure you're okay?"],[7995,8091,"You used to fight me"],[8091,8212,"whenever I said something bad"],[8212,8295,"about Derek."]],"35":[[16,275,"Dad, I fired Derek and Jeff."],[354,492,"From now on, I'll listen to you."],[558,596,"But you have to"],[596,725,"promise me something, too."],[796,875,"Stay."],[975,1088,"Don't go back abroad."],[1130,1263,"Stay here and be with me."],[1338,1418,"Please."],[1593,1668,"Of course."],[1710,1893,"As long as it makes my daughter happy,"],[1893,2002,"I'll do anything."],[2189,2260,"Yeah,"],[2281,2423,"I actually forgot about that."],[2444,2498,"Yeah."],[2635,2777,"So if you don't get an A,"],[2777,2852,"you have to help"],[2865,3007,"scrub the boys' bathroom"],[3073,3165,"and help"],[3194,3378,"every virgin lose their virginity?"],[3453,3678,"Do you think I was being reckless?"],[3757,3878,"Do you think I can win?"]],"36":[[45,171,"Do you think I can win?"],[287,404,"I'll help you win."],[500,671,"Plus, you've been working so hard."],[671,884,"Getting an A is totally possible."],[1005,1126,"Besides, I don't want you"],[1126,1288,"having anything to do with other guys."],[1914,1985,"It's okay."],[2018,2122,"I'm here to help you."],[2189,2268,"Trust me,"],[2268,2452,"Arianna, you're really smart."],[2523,2669,"Getting an A is gonna be easy."],[2727,2907,"You're nothing like what Derek says."],[2969,3136,"No, if anything, he held you back."],[3249,3328,"Thanks, Hayden."],[3420,3561,"I guess I'll be relying on you"],[3561,3670,"for a while."],[3770,3874,"Hope you don't regret it!"],[3903,3941,"Nah,"],[3974,4045,"I won't."],[4416,4529,"So, yeah."],[5630,5697,"Students,"],[5722,5830,"due to system maintenance,"],[5830,5910,"I will be announcing"],[5910,6014,"your grades myself."],[6256,6464,"As usual, Derek and Ivy"],[6464,6623,"performed exceptionally well."],[6644,6886,"Their GPA remains at 3.8."],[6940,7061,"The school heartthrob"],[7061,7223,"and class beauty,"],[7248,7394,"so perfect together."],[7465,7624,"Unlike some people"],[7661,7724,"who are about to"],[7724,7866,"humiliate themselves."],[8233,8345,"This is gonna be good."],[8541,8704,"However, this time,"],[8704,8900,"I want to highlight another student,"],[9025,9121,"Arianna."],[9534,9630,"Let me guess,"],[9630,9797,"Arianna failed again?"],[9864,10010,"Is she finally getting expelled"],[10010,10247,"for not even reaching a 2.0 GPA?"],[10247,10406,"Emmy, who gave you permission"],[10406,10518,"to speak out of turn?"],[10668,10764,"Actually,"],[10844,11161,"Arianna's GPA this time is 3.8."],[11161,11398,"Her progress has been remarkable"],[11398,11482,"and her essay was"],[11482,11632,"particularly well written."],[11745,11899,"I encourage you all to take a look"],[11899,12012,"and learn from her."],[12157,12270,"What?"]],"37":[[29,120,"What?"],[175,271,"3.8?"],[271,371,"No way!"],[396,571,"Arianna was failing before,"],[571,771,"how, how is this even possible?"],[1205,1309,"Leaving already?"],[1372,1443,"Derek, aren't you"],[1443,1543,"forgetting something?"],[1568,1668,"You lost."],[1851,2027,"It's time to accept your punishment."],[2089,2235,"You got lucky this time."],[2235,2394,"So, what's it gonna be?"],[2460,2610,"Will you apologize first"],[2610,2715,"or are you going straight"],[2715,2786,"to the locker room"],[2786,2902,"to change into a skirt?"],[3240,3370,"What are you so proud of?"],[3403,3628,"So what you did well once?"],[3678,3949,"Derek and Ivy always score high."],[3949,4083,"And they don't go around"],[4083,4229,"bragging about it like you!"],[4279,4333,"And what does that"],[4333,4441,"have to do with our bet?"],[4483,4667,"I scored over 3.5,"],[4688,4833,"meaning Derek lost."],[4833,5000,"Unless, Derek,"],[5000,5142,"you're trying to weasel your way"],[5142,5217,"out of it."],[5355,5409,"Fine."],[5463,5622,"I'll admit you're not stupid."],[5684,5939,"As far as wearing a bra and dress"],[5939,6126,"while apologizing?"],[6126,6268,"Forget it."],[6285,6402,"So you're backing out?"],[6660,6765,"Arianna, come on."],[6806,6919,"We're all classmates."],[6952,7077,"Making Derek, a man,"],[7077,7207,"do something so humiliating?"],[7207,7282,"I mean,"],[7282,7394,"it's a bit much, don't you think?"],[7457,7549,"Well he already admitted"],[7549,7645,"you're not dumb."],[7674,7749,"Isn't that enough?"],[7770,7862,"And what does this have to do"],[7862,7941,"with you, Ivy?"],[7970,8112,"If you care so much about Derek,"],[8137,8195,"why don't you take the"],[8195,8295,"punishment for him?"],[8358,8566,"Apologize to me and wear the skirt."],[8625,8742,"I'll accept that too."],[8779,8846,"I..."],[8904,8979,"I'm the main player"],[8979,9079,"on the volleyball team."],[9121,9317,"I can't be seen dancing in a skirt."],[9359,9496,"Arianna, you're going too far!"],[9513,9601,"Arianna, enough!"],[9601,9755,"You're so shameless!"],[9788,9993,"Honestly, I bet you cheated!"],[9993,10085,"That's the only way"],[10085,10247,"you could have gotten a 3.8."],[10293,10493,"Derek tutored you for months,"],[10493,10668,"and you still failed."],[10756,10835,"There's no way"],[10835,11002,"you're suddenly so smart."],[11040,11094,"Oh?"],[11106,11227,"Do you have any proof?"],[11269,11357,"Because if you don't,"],[11357,11532,"I can sue you for slander."],[11632,11711,"Proof?"],[11711,11920,"Your grades are proof!"],[11920,12024,"And who doesn't know"],[12024,12216,"you're being kept by an old man?"],[12320,12537,"You spend every night with him,"],[12566,12704,"when do you even have the chance"],[12704,12787,"to study?"],[13263,13425,"You want to accuse me of cheating?"],[13484,13546,"Fine."],[13605,13809,"But spreading disgusting rumors?"],[13842,13901,"Emmy,"],[13968,14114,"do you want to end up in jail?"],[14285,14418,"I'll report you right now!"],[14418,14547,"Erase all your grades,"],[14547,14677,"get you expelled!"],[15803,15982,"Arianna, stand up."]],"38":[[0,75,"Yes?"],[646,742,"You've been accused of"],[742,867,"cheating on your exams."],[867,971,"Do you have anything to say"],[971,1042,"for yourself?"],[1121,1309,"Teacher, may I ask,"],[1309,1455,"what evidence do you have"],[1455,1576,"to prove that I cheated?"],[1576,1818,"Well, since your previous grades"],[1818,1918,"were quite low"],[1918,2039,"and you suddenly improved"],[2039,2164,"so drastically,"],[2164,2264,"it makes sense that"],[2264,2381,"your classmates would doubt you."],[2406,2585,"So after careful consideration,"],[2590,2660,"we have decided"],[2660,2815,"to have you retake the test."],[2831,2911,"Do you agree?"],[3057,3157,"Of course."],[3203,3294,"I don't agree."],[3507,3570,"See?"],[3624,3803,"I told you she cheated."],[3870,4037,"If you really earned that score,"],[4083,4212,"what are you afraid of?"],[4212,4279,"Hm?"],[4287,4346,"What's wrong with"],[4346,4454,"taking the test again?"],[4550,4675,"You're accusing me of cheating?"],[4742,4833,"Whoever makes the claim"],[4833,4984,"must provide the evidence."],[5000,5109,"You need to prove it."],[5163,5255,"If you have no proof,"],[5255,5347,"then it's slander."],[5401,5518,"If anyone can casually"],[5518,5659,"accuse others without proof,"],[5659,5726,"does that mean"],[5726,5876,"we all have to retake exams"],[5876,6047,"any time someone feels like it?"],[6106,6193,"In that case,"],[6260,6435,"why bother having classes at all?"],[6523,6606,"Since when did"],[6606,6794,"Arianna become so sharp?"],[6794,7036,"She actually seems smarter now."],[7102,7303,"This is the school's decision."],[7303,7499,"You have no right to protest."],[7515,7574,"Arianna,"],[7574,7707,"I understand why you're upset."],[7707,7916,"But this is for your reputation too."],[8016,8112,"You don't want the students"],[8112,8245,"to keep doubting you, do you?"],[8245,8437,"Of course, I can retake the test."],[8512,8633,"But isn't it ridiculous"],[8633,8812,"that I have to be randomly accused"],[8812,8925,"without any reason?"],[8967,9200,"Arianna, it's just another test."],[9213,9384,"You don't need to be so nervous."],[9501,9613,"Who said I'm nervous?"],[9726,9901,"Let's see if you're still smiling"],[9901,10018,"after this test."],[10018,10147,"I mean, I really don't know"],[10147,10310,"why you're so eager to question me."],[10347,10422,"But does that mean"],[10422,10560,"every student who improves"],[10560,10668,"should be suspected?"],[10727,10835,"So, Teacher,"],[10890,11061,"since she chose to falsely accuse me"],[11061,11127,"without evidence,"],[11127,11286,"shouldn't there be consequences?"],[11344,11519,"If not, won't this encourage"],[11519,11657,"more baseless accusations"],[11657,11728,"in the future?"],[11815,12016,"So, what do you propose?"],[12082,12203,"Since Emmy baselessly"],[12203,12312,"accused me of cheating"],[12312,12474,"and has repeatedly targeted me,"],[12474,12687,"if my retest proves I did not cheat,"],[12721,12841,"she should drop out of school."],[12841,12892,"What?"]],"39":[[0,108,"Expulsion?"],[108,233,"Don't you think that's a bit extreme?"],[233,329,"But isn't it worse"],[329,417,"that she spread false"],[417,529,"rumors about me cheating?"],[550,717,"Think of the consequences,"],[717,821,"If this rumor spreads,"],[821,975,"it could ruin my reputation."],[975,1142,"If I couldn't handle the pressure and"],[1163,1359,"ended up taking drastic measures,"],[1380,1455,"what then?"],[1455,1693,"Arianna, don't joke of such things!"],[1701,1755,"So?"],[1797,1893,"You were so confident"],[1893,1976,"a moment ago."],[2064,2214,"Are you too scared to bet now?"],[2214,2460,"Of course, I dare!"],[2677,2831,"Teacher, I'm willing to bet on this!"],[2831,2911,"Everyone knows"],[2911,3036,"her grades were terrible!"],[3069,3194,"I'm sure she cheated!"],[3374,3495,"But if you did cheat,"],[3661,3778,"you have to drop out."],[3858,4020,"Our school has no place"],[4020,4112,"for a cheater."]],"40":[[0,141,"But if you did cheat,"],[296,408,"you have to drop out."],[408,479,"Fine."],[479,563,"No problem."],[684,738,"Alright."],[771,813,"Arianna,"],[813,971,"I'll prepare a new test for you."],[971,1126,"And you will take it immediately,"],[1126,1209,"with your classmates"],[1209,1309,"as your witnesses."],[1309,1434,"Oh, by the way, Derek,"],[1468,1568,"do you also need the teacher"],[1568,1676,"to witness our bet"],[1676,1789,"before you honor it?"],[1972,2135,"Arianna, are you sure"],[2135,2273,"you want to keep pushing this?"],[2385,2460,"If I were you,"],[2460,2623,"I would apologize to the teacher"],[2623,2694,"right now."],[2723,2836,"If you're sincere,"],[2873,3028,"maybe I'll put in a good word for you."],[3111,3211,"As far as the whole"],[3236,3370,"wearing a dress thing,"],[3490,3591,"I'll let that slide."],[3649,3828,"But you have to apologize to me first."],[3828,3953,"Stop rambling."],[4004,4129,"Instead of worrying about me,"],[4129,4262,"worry about yourself."],[4337,4483,"I'll ask you one more time,"],[4550,4667,"if I prove I didn't cheat,"],[4667,4771,"will you honor the bet?"],[4963,5088,"If you really didn't cheat?"],[5492,5551,"Yeah."],[5609,5663,"Fine."],[5684,5797,"I'll keep my word."],[5943,5997,"This time,"],[5997,6114,"with the teacher as a witness,"],[6164,6339,"you won't be able to weasel out of it."]],"41":[[3603,3741,"So, teacher,"],[3762,3937,"did Arianna bomb the test?"],[3937,4008,"I knew it!"],[4008,4129,"Teacher, maybe we don't need"],[4129,4204,"to announce the score."],[4204,4320,"I mean, if Arianna admits"],[4320,4471,"she was wrong now,"],[4517,4592,"I'm sure Emmy won't"],[4592,4708,"push to have her expelled."],[4758,4904,"Ivy, you're too nice!"],[4904,5013,"How can you stick up for her"],[5013,5184,"after everything she's done to you?"],[5184,5384,"Someone as rude and dishonest as her"],[5384,5580,"deserves to be kicked out of school!"],[5580,5647,"Emmy's right."],[5722,5818,"Arianna's the one that said"],[5818,5976,"she would clean the boys' bathroom"],[5985,6131,"and help them lose their virginity."],[6218,6423,"She should just admit that she lied,"],[6423,6664,"apologize, and drop out."],[6702,6919,"That's the price for liars"],[6919,7061,"and show-offs."],[7061,7123,"Enough."],[7173,7257,"The teacher hasn't even"],[7257,7361,"said anything yet."],[7399,7478,"Can you all shut up"],[7478,7607,"and show some respect?"],[7870,8041,"The test I just gave you was a"],[8041,8187,"competition-level exam"],[8187,8262,"prepared by the"],[8262,8458,"Academic Research Institution."],[8521,8683,"It's significantly harder than"],[8683,8821,"our school's standard test."],[8821,8879,"I knew it!"]],"42":[[0,116,"Teacher, you don't have to"],[116,266,"make excuses for her."],[296,483,"Even if the test wasn't harder,"],[483,588,"she still would have failed!"],[588,675,"Exactly!"],[675,825,"At the end of the day, she's just dumb."],[855,1055,"On top of that, she cheated."],[1055,1134,"It's unforgivable."],[1134,1305,"Arianna, you brought this on yourself."],[1305,1468,"It's too late for regrets now."],[1468,1539,"Yeah."],[1539,1647,"How is she gonna get out of this?"],[1664,1818,"This is so embarrassing."],[1981,2068,"The teacher hasn't even"],[2068,2193,"finished talking yet."],[2223,2344,"Why are you all so worked up?"],[2394,2469,"Don't cry"],[2469,2602,"when the results are announced."],[2602,2773,"Even though this test was"],[2819,2990,"more difficult, Arianna scored"],[2990,3144,"even better on this test!"],[3224,3357,"Not only did she not cheat,"],[3357,3482,"but she's clearly developed"],[3482,3678,"a new approach to learning."],[3678,3816,"Her progress is impressive"],[3816,3920,"and something everyone"],[3920,4004,"should learn from."],[4004,4204,"How is this possible?"],[4204,4333,"There's no way she didn't cheat!"],[4333,4454,"Teacher, are you sure"],[4454,4542,"you didn't make a mistake?"],[4542,4592,"Yes, teacher!"],[4592,4683,"Enough!"],[4683,4884,"Arianna has improved a lot."],[4884,4942,"I don't want to hear"],[4942,5046,"any more doubts about her!"],[5059,5184,"Classmates should encourage"],[5184,5359,"each other and support each other."],[5359,5447,"I hope this kind of"],[5447,5555,"malicious speculation"],[5555,5663,"stops here."],[5668,5905,"Let this be a lesson to everyone."],[5930,6101,"Emmy, the results are out."],[6101,6268,"You said if I didn't cheat,"],[6268,6352,"you'd drop out."],[6381,6523,"You're not going back on your word,"],[6523,6589,"are you?"],[6648,6835,"Getting good grades feels amazing!"],[6861,7040,"Huge thanks to Hayden for this one."],[7357,7453,"I..."]],"43":[[0,129,"Having second thoughts?"],[158,254,"That won't do."],[254,321,"The teacher just"],[321,425,"witnessed everything."],[425,583,"If you don't keep your promise,"],[596,709,"I'll sue you for slander"],[709,867,"and spreading fake rumors."],[867,963,"You're an adult,"],[963,1076,"you know what that means."],[1076,1259,"Arianna, we're all classmates."],[1259,1418,"I mean, do you have to be so aggressive?"],[1455,1597,"Emmy was just looking out for you!"],[1647,1814,"She was afraid you'd take a wrong turn."],[1814,1926,"She didn't mean any harm."],[1968,2147,"Can't you give her another chance?"],[2147,2327,"Oh, if you care so much,"],[2327,2494,"why don't you drop out instead?"],[2627,2711,"Arianna,"],[2823,2961,"Emmy's the one that crossed you,"],[2961,3036,"not Ivy."],[3036,3144,"Why are you coming after her?"],[3144,3194,"Yeah!"],[3211,3415,"Ivy even speaks up for you sometimes."],[3415,3582,"She treats everyone the same."],[3599,3674,"The same?"],[3732,3812,"If I were the one"],[3812,3895,"getting kicked out today,"],[3895,4037,"would she have stood up for me?"],[4037,4116,"Of course, I would have."],[4158,4237,"I'm always telling"],[4237,4337,"people to be nicer to you."],[4354,4475,"Drop the act."],[4475,4683,"Don't worry, you're next."],[4738,4938,"Ivy, I haven't forgotten"],[4938,5171,"a single thing you did to me."],[5342,5463,"The accident that left you"],[5463,5651,"paralyzed for the waist down?"],[5651,5793,"We made that happen."],[6423,6569,"Emmy, if you don't want to drop out,"],[6569,6723,"I'll give you another option."],[6723,6823,"What option?"],[6848,7019,"Well, since you have zero credibility,"],[7057,7165,"if you want to stay,"],[7165,7340,"you'll have to run 20 miles."],[7340,7428,"Not just run,"],[7453,7603,"you'll do it while shouting,"],[7603,7766,"I wronged Arianna!"],[7766,7895,"Arianna didn't cheat!"],[7895,8066,"Loud enough for everyone to hear."],[8066,8270,"Arianna, it's just a test!"],[8270,8337,"Oh?"],[8337,8454,"And who put you in charge of"],[8454,8554,"teaching me a lesson?"],[8666,8808,"Apologize right now."],[9038,9159,"Then go to the beach and dance"],[9159,9305,"to admit your mistake."]],"44":[[646,713,"Derek!"],[713,759,"Just-"],[980,1067,"Arianna!"],[1067,1159,"That's enough!"],[1205,1263,"Arianna,"],[1263,1384,"don't ruin your relationship"],[1384,1572,"with your classmates over one test."],[1572,1697,"Teacher, there's nothing to ruin."],[1697,1847,"We were never friends."],[1901,2006,"Besides, they were the ones"],[2006,2139,"who came at me first."],[2139,2243,"I've recorded everything"],[2243,2364,"they said about me."],[2364,2502,"If they don't keep their word,"],[2535,2656,"I'll have no choice"],[2656,2811,"but to get a lawyer involved."],[2998,3253,"Fine, it's, it's just a dance,"],[3390,3465,"I'll do it."],[3561,3845,"Alright, 20 miles."],[3912,3987,"I'll run."],[4095,4270,"Arianna, you're going too far!"],[4300,4500,"Look, Emmy barely exercises."],[4500,4625,"10 miles would be torture,"],[4625,4717,"let alone 20!"],[4821,4938,"They're accepting their loss,"],[4938,5046,"can't you just-"],[5046,5238,"Oh, and since you're so kind,"],[5267,5330,"why don't you help"],[5330,5430,"your dear friend Emmy?"],[5484,5555,"Tell you what,"],[5613,5709,"you don't have to do much,"],[5709,5809,"just split it with her."],[5847,5976,"10 miles sound fair?"],[6018,6089,"I..."],[6160,6318,"I'm not in good shape either."],[6318,6473,"I, I can't run."],[6473,6594,"See, Emmy?"],[6594,6752,"I tried to help you,"],[6752,6927,"but Ivy just won't do it."],[6927,6990,"You!"],[7082,7186,"Arianna,"],[7236,7361,"just wait."],[7432,7545,"I'll be waiting at the beach."],[7599,7699,"Don't keep me waiting."]],"45":[[1484,1572,"Come on, Derek!"],[1601,1705,"Keep dancing!"],[2268,2456,"When is this stupid song gonna end?"],[2485,2619,"Your moves are sloppy, Derek!"],[2619,2756,"Stop slacking off!"],[3065,3253,"This is the best day of my life!"],[4029,4112,"Emmy!"],[4204,4304,"You better hurry up,"],[4304,4466,"it's gonna get dark soon!"]],"46":[[33,104,"Emmy."],[104,266,"Ma'am, are you okay?"],[917,1009,"Oh, thank God, you're awake."],[1063,1151,"How do you feel?"],[1176,1284,"Awful."],[1322,1501,"My whole body aches."],[1501,1714,"Relax, the specialist checked you out,"],[1714,1818,"you're perfect and healthy."],[1864,2018,"You just have terrible stamina."],[2039,2127,"Oh, and the doctor's even"],[2127,2281,"recommended more exercise."],[2281,2360,"So don't forget,"],[2360,2602,"you still owe me 10 miles today."],[3115,3153,"You."],[3274,3349,"I'm done!"],[3536,3703,"If I run anymore, I'll die!"],[3724,3853,"Trust me, you won't."],[3887,3999,"If you pass out again,"],[3999,4191,"I'll contact every doctor in the area."],[4233,4379,"Oh, but if you don't want to run,"],[4441,4558,"you know your other option,"],[4633,4713,"to drop out."]],"47":[[45,237,"You're taking this too far!"],[308,387,"Too much?"],[454,679,"Weren't you all much worse to me before?"],[771,913,"Or are you choosing to drop out?"],[1080,1184,"I'll finish the run."],[1810,2031,"When did Arianna get so powerful?"],[2260,2394,"I can't beat her."],[2419,2585,"Emmy, don't be upset."],[2585,2660,"She's the one"],[2660,2765,"who's being unreasonable."],[2986,3140,"If she can bully you like this,"],[3140,3286,"then we can expose her"],[3286,3390,"for being a sugar baby."],[3415,3549,"It might teach her a lesson."],[3908,3999,"You took those photos of"],[3999,4141,"her and that old man last time,"],[4187,4250,"didn't you?"],[4475,4554,"If we..."],[4700,4821,"Ivy, you're too nice."],[4871,5017,"After everything she's done,"],[5017,5121,"you still want to"],[5121,5246,"get her back on track!"],[5509,5651,"A bitch like her deserves to be"],[5651,5826,"completely ruined!"],[6076,6177,"I'll post those photos of"],[6177,6268,"that old man and her"],[6268,6398,"on the school forum right now!"],[6502,6669,"Posting on the forum would be a mess."],[6819,6986,"But, next Friday"],[6986,7102,"is the school anniversary."],[7261,7323,"The principal"],[7323,7428,"and the new school director"],[7428,7507,"will be there."],[7570,7670,"If we..."],[7824,7912,"Good idea!"],[8237,8387,"We'll project it on the big screen,"],[8387,8558,"in front of the whole school!"],[8825,8917,"We'll expose her"],[8917,9196,"for the shameless slut she really is!"]],"48":[[4,75,"Ha!"],[75,291,"If you had seen Derek and Emmy,"],[291,487,"you would be laughing just like me."],[538,713,"Emmy collapsed halfway"],[713,850,"and I made sure the whole medical team"],[850,938,"was there to help her."],[988,1096,"And then when she woke up?"],[1151,1338,"I made her run the rest of the 20 miles!"],[1468,1643,"I haven't felt this good in ages."],[1689,1847,"Do you think I was being too harsh?"],[1872,1956,"Of course not."],[2002,2077,"If it were me,"],[2077,2214,"I would've done a lot worse."],[2285,2456,"I owe it all to your tutoring."],[2548,2711,"I finally got my revenge!"],[3023,3086,"Oh, right!"],[3098,3194,"There's a volleyball match"],[3194,3286,"in two days."],[3286,3457,"Your class against ours."],[3457,3578,"Since you transfer already,"],[3578,3653,"are you playing?"],[3712,3924,"Derek always steals the spotlight."],[3924,4120,"Just once, I would love to see"],[4120,4287,"someone put him in his place!"],[4346,4508,"Do you want me to join?"],[4875,4959,"Of course, and-"],[4959,5030,"Oh!"],[6677,6798,"I'll play, Arianna."],[6848,6998,"But I want you to cheer for me."],[8116,8245,"That's Arianna, right?"],[8245,8404,"The one being kept by an old man?"],[8633,8783,"Yeah, that's her."],[8842,8963,"She acts all innocent,"],[8963,9067,"but behind the scenes,"],[9067,9209,"she's disgusting."],[9209,9338,"She thinks she can get away with"],[9338,9451,"bullying her classmates"],[9451,9609,"just because she has a sugar daddy."],[9705,9830,"She's so vicious,"],[9864,10005,"and the school still lets her stay?"],[10076,10172,"Unbelievable."],[10802,11015,"Arianna, you're here too?"],[11227,11361,"Are you here to cheer for Derek?"],[11503,11594,"Not interested."]],"49":[[25,112,"Stop fronting."],[112,204,"If you're not here for me,"],[204,283,"then who else?"],[371,487,"Why would I waste my time"],[487,621,"watching a loser like you?"],[621,675,"You-"],[675,813,"Alright, Arianna."],[838,996,"Look, Derek's been good to you!"],[1013,1063,"No matter what,"],[1063,1201,"we were all friends once."],[1234,1322,"Do you really have to make"],[1322,1443,"things this tense?"],[1455,1626,"I have standards for my friends and"],[1626,1818,"I've never considered you one of them."],[1956,2152,"Arianna, that's too much."],[2248,2339,"Don't worry about her."],[2369,2477,"Who wants to be her friend?"],[2585,2686,"Arianna, you've been so"],[2686,2811,"full of yourself lately."],[2882,3073,"Getting kept by some rich old man"],[3073,3224,"and then she thinks she's all that?"],[3244,3353,"Shameless."],[3620,3732,"Say that again?"],[3883,4037,"Emmy, if you have this much free time,"],[4037,4162,"you should spend it at the gym"],[4162,4300,"instead of running your mouth."],[4767,4909,"Derek, aren't you about to go in?"],[4954,5038,"I heard that the class swapped out"],[5038,5125,"a player last minute."],[5125,5296,"Are you feeling the pressure?"],[5296,5434,"It doesn't matter, whoever it is."],[5538,5709,"You know my volleyball skills."],[5709,5860,"This game's easier than a test."],[6022,6160,"Derek, you're amazing!"],[6297,6377,"Arianna,"],[6485,6585,"who do you think will win?"]],"50":[[417,638,"Isn't that Arianna's new boy toy?"],[925,1247,"Though, Hayden is kind of hot."],[1276,1363,"Right, Ivy?"],[1989,2156,"Why is it always Arianna?"],[2210,2348,"If it's not a rich guy,"],[2348,2489,"it's someone outstanding."],[2531,2781,"Arianna, I stole Derek from you."],[2781,2948,"I can take this one too."],[3090,3224,"Hayden's probably being fooled."],[3224,3332,"I bet if he knew that"],[3332,3528,"she was some rich old man's plaything,"],[3545,3691,"he'd dump her like Derek did."],[3853,3949,"Don't worry, Ivy."],[4108,4191,"Hayden will figure out"],[4191,4300,"the truth soon enough."],[4400,4450,"Derek,"],[4487,4592,"isn't it time for you to warm up?"],[4642,4708,"Yeah."],[5442,5588,"So you're here to watch him play?"],[5789,5876,"What's it to you?"],[5876,5976,"Get lost!"]],"51":[[2765,2919,"Go Hayden!"],[4295,4366,"Oh you got him!"],[4383,4425,"You got-"],[4441,4487,"Yeah!"],[4546,4617,"Whoa!"],[5030,5100,"Yeah!"],[5155,5313,"Yeah, go Hayden!"],[5376,5484,"Woo!"],[5522,5705,"Derek was destroyed!"],[5718,5784,"I thought he was supposed"],[5784,5864,"to be good."],[5885,5960,"Hayden completely wiped"],[5960,6039,"the floor with him."],[6068,6126,"I didn't know"],[6126,6277,"Hayden was this good looking"],[6297,6423,"and this good at volleyball!"],[6502,6685,"I'm officially a fan now."],[7044,7157,"Looks like Hayden's gonna be the"],[7157,7278,"most popular guy in school."],[7374,7478,"No wonder Arianna"],[7478,7611,"ditched Derek to cheer for him."],[7711,7828,"She's so fickle."],[7841,7937,"It's an embarrassment"],[7937,8037,"to girls like us."],[8116,8208,"It doesn't matter"],[8208,8350,"how much she cheers him on."],[8470,8566,"Hayden would never"],[8566,8683,"go for someone like her."],[8742,8842,"Who would want"],[8842,8996,"some gold digging slut"],[8996,9167,"who's kept by an old man?"],[9388,9538,"Looking at her makes me sick."],[10018,10110,"Can I get some water?"],[10414,10635,"Hayden, you were amazing out there!"],[10806,10985,"I actually twisted my hand pretty bad."],[10985,11102,"Can you feed it to me?"],[12299,12391,"Thanks, Arianna."]],"52":[[45,75,"Hayden,"],[75,246,"you're not actually into Arianna,"],[246,329,"are you?"],[333,425,"Do you even know"],[425,554,"how bad her reputation is?"],[567,759,"She's being kept by some old man."],[784,842,"Shut up."],[925,1034,"Please don't be mad."],[1038,1188,"Look, Emmy's telling the truth."],[1197,1272,"She just doesn't want you"],[1272,1376,"being deceived."],[1418,1551,"We're Arianna's friends."],[1555,1626,"We don't want her going down"],[1626,1693,"the wrong path,"],[1693,1830,"but she won't listen to us."],[1856,1993,"If possible, maybe you"],[1993,2139,"could talk some sense into her."],[2168,2289,"So your way of helping your friend"],[2289,2448,"is by spreading rumors about her?"],[2506,2560,"What?"],[2573,2702,"But that's not what we meant!"],[2752,2948,"We're really just looking out for her."],[2957,3078,"She's trying to chase after you now,"],[3078,3174,"so maybe she'll actually"],[3174,3261,"listen to you."],[3395,3495,"Are you done?"],[3557,3703,"Wait, see, let me get this straight."],[3703,3807,"You think that Arianna's"],[3807,3895,"chasing me?"],[3978,4099,"Isn't it obvious?"],[4124,4220,"When she likes someone,"],[4225,4391,"she tries to get close to them."],[4400,4525,"When she was after Derek,"],[4525,4621,"she cheered him on."],[4675,4788,"Now, she cheers for you."],[4842,5038,"I see, but let me correct you."],[5125,5192,"I like her,"],[5276,5380,"and I'm the one chasing her!"],[5680,5843,"And I hope that she'll give me a chance"],[5939,6035,"to be her boyfriend."]],"53":[[12,54,"Oh."],[87,175,"No way."],[329,517,"You're chasing after Arianna?"],[600,750,"Do you even know what she-"],[905,1130,"She's being kept by some rich old man."],[1151,1338,"She's just a shameless whore."],[1351,1422,"If you don't mind-"],[1493,1714,"Ahhh!"],[2077,2143,"Hayden."],[2152,2302,"Oh my gosh!"],[2302,2385,"Did you really just"],[2385,2519,"pour your drink on me?"],[2519,2581,"You keep running that"],[2581,2677,"stupid little mouth,"],[2686,2806,"that drink to the face is gonna"],[2806,2961,"be the least of your problems."],[3244,3374,"Apologize to Arianna."],[3486,3636,"Emmy, I see you already forgot about"],[3636,3807,"running 20 miles the other day."],[3862,3949,"Emmy's not wrong."],[4020,4079,"Everyone knows"],[4079,4258,"Arianna used to throw herself at me."],[4300,4437,"Isn't that right, Arianna?"],[4479,4662,"Derek, I was blind before."],[4688,4854,"But now, you mean nothing to me."],[4917,4996,"So you're really gonna"],[4996,5080,"be with Hayden?"],[5146,5271,"What does that have to do with you?"],[5363,5472,"What if I gave you a chance to"],[5472,5601,"pursue me instead?"],[5668,5843,"Maybe I'd let you be my girlfriend."],[6035,6089,"Derek,"],[6156,6277,"how dare you say that?"],[6318,6427,"You were lucky"],[6427,6610,"I ever looked at you twice."],[6631,6790,"And now, you're nothing"],[6790,6936,"but a piece of trash to me."],[6952,7032,"Oh, and besides,"],[7082,7203,"don't you have a girlfriend?"],[7261,7415,"Saying this to me, aren't you afraid"],[7415,7524,"she'll misunderstand?"]],"54":[[37,162,"Arianna, don't think I'm"],[162,283,"ever gonna forgive you."],[408,525,"That's hilarious."],[567,629,"Derek, do you think"],[629,779,"your forgiveness means something?"],[829,946,"I could care less."],[1388,1559,"Hayden, you were amazing out there!"],[1568,1739,"You scored so many points today,"],[1747,1901,"you should have seen Derek's face."],[1910,2014,"He was fuming!"],[2064,2139,"He's just weak."],[2281,2331,"What?"],[2389,2435,"Don't move."],[2435,2519,"You're sunburned."],[4149,4250,"Honestly,"],[4358,4554,"I don't see what flaws you have."],[4579,4850,"You're good-looking, you're smart,"],[4879,5042,"and an incredible athlete."],[5063,5192,"All the girls around me today"],[5192,5363,"were completely obsessed with you."],[5376,5488,"I don't know them."],[5559,5643,"I don't care about them."],[5643,5759,"I only care about you."],[5843,5964,"How do you feel about me?"]],"55":[[12,104,"I don't care about them."],[104,216,"I only care about you."],[312,425,"How do you feel about me?"],[504,638,"I've been waiting for your response"],[638,800,"for a really long time, Arianna."],[930,1092,"Come on, let's get some food."],[1126,1234,"I heard the new cafeteria"],[1234,1297,"is pretty good!"],[1793,1939,"Ivy, don't be mad."],[2010,2089,"Why does Arianna"],[2089,2235,"get to be chased by Hayden"],[2260,2485,"while I'm stuck with this broke loser?"],[2523,2615,"Come on, Ivy."],[2686,2761,"I were so pissed about"],[2761,2915,"Arianna being so smug."],[2957,3086,"I didn't really mean what I said."],[3157,3307,"You must be hungry after the game."],[3345,3557,"How about I take you out to lunch?"],[3632,3674,"Fine."],[3770,3916,"I wanna try the new cafeteria."],[3966,4175,"No problem, Ivy, I got a new job."],[4200,4283,"Order whatever you want."],[4408,4471,"It's my treat!"]],"56":[[41,187,"I'll have vegetable soup,"],[187,421,"chicken breast, and a brownie."],[458,517,"What about you, Derek?"],[546,625,"That's not enough!"],[725,800,"I'll take"],[800,955,"one of everything from the menu!"],[980,1130,"That's a lot, Derek."],[1192,1376,"But I guess if we can't finish it,"],[1376,1468,"I'll take some to Emmy"],[1468,1534,"and the others."],[1593,1668,"They'll be so jealous"],[1668,1814,"when they see how good you are to me."],[1893,2006,"As long as you're happy."],[2031,2102,"I got this!"],[2648,2786,"Your card was declined."],[3078,3148,"It's impossible."],[3148,3319,"I... I had money in this account!"],[3628,3853,"Oh, so this is where you've been hiding?"],[3978,4116,"Telling me you're broke,"],[4162,4375,"and you're now splurging at the"],[4375,4633,"school's most expensive cafeteria?"],[4708,4808,"Hand over the money!"],[4838,4921,"I don't have any!"],[5017,5184,"Where's the cash?"],[5284,5405,"All you're doing is messing around"],[5405,5505,"with your girlfriend"],[5513,5597,"instead of working!"],[5609,5718,"I should be asking you that!"],[5818,5935,"Where's the money in my account?"],[6043,6193,"I used it to pay off a debt yesterday."],[6218,6356,"Still owe five grand,"],[6381,6489,"so cough it up!"],[6619,6752,"You're gambling again?"],[6848,6927,"That was my tuition"],[6927,7023,"for next semester!"],[7119,7232,"What am I supposed to do now?"],[7282,7344,"Wait,"],[7382,7603,"Derek's dad is a gambling addict?"],[7682,7824,"Uh, if you're not ordering anything,"],[7824,7962,"can you step aside, please?"]],"57":[[262,462,"Oh, so you think you can"],[483,592,"talk back to me now?"],[667,813,"You wouldn't want me showing up here"],[813,963,"every day now, would you?"],[975,1146,"So, get it straight,"],[1297,1380,"get me the money."],[1639,1826,"This is all I have left."],[2002,2060,"This?"],[2181,2281,"Not even close."],[2323,2410,"Figure it out,"],[2427,2573,"or you're dropping out next semester."],[3240,3486,"Ivy, don't be mad, okay?"],[3516,3624,"Let, let me explain it to you."],[3666,3782,"My dad took all my money."],[3953,4041,"I'll work harder."],[4099,4204,"I'll earn it back!"],[4208,4375,"I'll, I'll take care of you."],[4391,4454,"I'll make sure you have"],[4454,4546,"everything you want."],[4621,4671,"Please."],[4704,4808,"You believe me, don't you?"],[4867,4921,"Derek,"],[4963,5075,"you could work for a whole month"],[5075,5146,"and still not make"],[5146,5246,"as much as Arianna earns"],[5246,5388,"in a single day tutoring."],[5451,5501,"I..."],[5693,5772,"Arianna's here."]],"58":[[33,112,"Arianna's here."],[225,354,"Derek, even if you don't like her,"],[354,483,"you should consider being her tutor."],[517,650,"It's your best way to make money."],[742,855,"Ivy, what did you just say?"],[905,1084,"I'm saying this for your own good."],[1130,1301,"I, I wanna help more, but..."],[1430,1551,"I'm just worried about you."],[1622,1755,"No, I won't do it!"],[1810,1910,"What's the big deal?"],[1910,1997,"It's just a job."],[2035,2089,"Tutoring her"],[2089,2264,"pays way more than any side gig."],[2356,2569,"Besides, this will help you"],[2569,2736,"deal with the mess with your dad."],[2786,2969,"Would it bother you if I tutored her?"],[3032,3136,"Of course not."],[3190,3282,"I trust you."],[3382,3503,"You're this broke,"],[3553,3682,"if you don't start making money soon,"],[3682,3799,"what am I supposed to spend?"],[3853,3999,"Arianna is the only idiot"],[3999,4154,"willing to throw cash at you."],[4279,4412,"You think she'll hire me again?"],[4487,4587,"She probably won't care about"],[4587,4733,"having you on as another tutor."],[4804,4921,"Look, if you're too embarrassed to ask"],[4921,5071,"I'll, I'll do it myself."],[5134,5209,"Arianna!"]],"59":[[221,279,"Arianna,"],[279,425,"can Derek tutor for you again?"],[483,625,"He's going through a tough time."],[642,779,"You know about his dad, right?"],[813,959,"What does that have to do with me?"],[971,1146,"Oh, come on, help him out!"],[1146,1305,"You have plenty of money, right?"],[1463,1647,"I promise he'll focus on teaching you."],[1672,1810,"This way, your grades improve too."],[1810,1926,"It's win-win, right?"],[1972,2022,"Ha!"],[2047,2206,"Ivy, do you think I'm an idiot?"],[2260,2414,"You and Derek are so in love,"],[2414,2494,"and you expect me to"],[2494,2610,"hire him like before?"],[2748,2877,"To pay for both of you?"],[2990,3136,"How can you say that?"],[3161,3336,"Look, I'm looking out for you, Arianna."],[3340,3395,"Trust me."],[3461,3561,"I'll make sure Derek"],[3561,3666,"tutors you properly."],[3741,3803,"Right, Derek?"],[4158,4287,"Yeah, yeah, Arianna."],[4287,4466,"I can forgive what you did before."],[4558,4637,"Didn't you just say"],[4637,4758,"you'd never forgive me?"],[4934,5042,"But now that you need money,"],[5042,5134,"you suddenly can?"],[5305,5347,"You!"],[5447,5497,"Arianna,"],[5576,5663,"look, if you hate Derek"],[5663,5739,"because of me,"],[5739,5880,"I'll break up with him right now."]],"60":[[0,79,"Oh, please."],[133,179,"Don't."],[246,412,"If you wanna dump him, that's on you."],[467,546,"Don't go blaming me,"],[546,713,"or he'll think I forced you into it."],[746,871,"I just didn't expect you to"],[871,1076,"get tired of him this fast."],[1280,1388,"What do you mean?"],[1438,1526,"You liked him because"],[1526,1676,"he was the school's golden boy,"],[1705,1947,"top student, rich, perfect."],[2014,2122,"You couldn't wait to announce"],[2122,2202,"you were his girlfriend"],[2202,2314,"at his birthday party."],[2364,2435,"But now?"],[2477,2665,"You've realized he's not some rich heir,"],[2715,2898,"just the son of a gambling addict."],[2990,3165,"And suddenly, you regret it."],[3236,3399,"I'm not that kind of girl!"],[3432,3495,"Look, I just want"],[3495,3607,"what's best for Derek."],[3628,3762,"I want him to have a good future!"],[3807,3887,"Exactly."],[3933,4091,"And if he doesn't have a bright future,"],[4112,4216,"how could he ever deserve"],[4216,4308,"to be with you?"],[4329,4416,"Arianna,"],[4475,4688,"I was just feeling sorry for you."],[4738,5038,"After all, you liked Derek so much."],[5088,5246,"If you don't wanna help, fine,"],[5296,5451,"but you don't need to insult me."],[5518,5663,"You always assume the worst in people,"],[5689,5830,"no wonder Derek doesn't like you."],[5901,6185,"And there it is, your true feelings!"],[6214,6327,"Back when I liked Derek,"],[6343,6402,"he gave you"],[6402,6523,"everything I gave him."],[6602,6798,"You sat back and reaped the benefits,"],[6819,6902,"probably feeling"],[6902,7019,"pretty smug about it."]],"61":[[0,145,"Alright, Arianna!"],[183,300,"You know, I've always treated you"],[300,367,"like a friend."],[396,550,"Uh, you keep assuming"],[563,663,"the worst in me."],[688,767,"Women are supposed to"],[767,859,"support each other,"],[888,996,"so why do you always have to"],[996,1142,"attack and tear me down?"],[1163,1242,"Tear you down?"],[1322,1405,"You're the one who knows"],[1405,1551,"Derek's in deep trouble, and now"],[1576,1747,"you're trying to push me back to him!"],[1768,1876,"When did you ever offer to"],[1876,2002,"give him up to me before?"],[2093,2260,"You're overthinking this."],[2298,2506,"Derek is gonna be successful one day,"],[2560,2702,"he seems need a little help right now."],[2781,2898,"But if Hayden finds out"],[2898,3003,"you're being kept,"],[3032,3161,"think he'll still like you?"],[3236,3345,"Look, the truth is,"],[3345,3424,"Derek's going through"],[3424,3503,"a tough time right now,"],[3503,3595,"but deep down,"],[3653,3807,"he really does care about you."],[3849,3966,"He cares about me?"],[4074,4166,"That's hilarious."],[4208,4354,"Do you even believe that yourself?"],[4371,4483,"It's the truth!"],[4529,4617,"Look, Derek just doesn't wanna"],[4617,4675,"drag you down"],[4675,4754,"with his family problems,"],[4754,4892,"but he really does care."],[5075,5192,"If you agree to do this,"],[5246,5388,"I promise to stay out of the way."],[5455,5518,"Deal?"],[5609,5659,"Sure."],[5764,5910,"Let him come tell me that himself."],[6022,6156,"Derek's got a big ego."],[6185,6289,"If you really care about him,"],[6289,6510,"just come back to him later, okay?"],[6606,6727,"If you do this for him,"],[6727,6861,"he'll definitely be grateful."],[6890,6977,"So, what?"],[7040,7140,"You're saying I should"],[7165,7315,"beg him to teach me?"],[7361,7511,"Beg him to let me pay off"],[7511,7640,"his gambling debts?"],[7703,7857,"What's his gratitude even worth?"],[7924,8041,"This is ridiculous."],[8095,8245,"Ever since I stopped relying on him,"],[8245,8412,"my grades have skyrocketed."],[8458,8554,"I don't need him!"]],"62":[[112,200,"Arianna!"],[337,483,"Look, if you will just agree to this,"],[483,554,"I promise"],[554,713,"Derek will only have eyes for you."],[734,838,"He'll never lose his temper"],[838,946,"like before with you."],[992,1092,"If he treats you badly,"],[1167,1284,"I'll have you back."],[1309,1430,"I give him money,"],[1463,1614,"and I need you to protect me"],[1626,1768,"so he won't bully me?"],[1839,1981,"Oh my God, Ivy!"],[2018,2173,"Have you looked in the mirror lately?"],[2189,2302,"You're so manipulative!"],[2314,2423,"Enough, Arianna!"],[2477,2681,"Ivy's being polite and asking nicely,"],[2765,2902,"why are you treating her like this?"],[2961,3053,"It's okay, Derek."],[3140,3319,"Just be a little nicer to Arianna"],[3319,3436,"and she'll give you the job."],[3516,3653,"Just have to be respectful."],[3703,3862,"I already told you to drop this!"],[3899,4033,"Why are we begging her for anything?"],[4054,4191,"Just hang in there, okay?"],[4262,4341,"Once we graduate"],[4341,4437,"and we have a steady income,"],[4437,4558,"everything will be okay!"],[4679,4879,"Derek, just don't be so stubborn."],[4954,5042,"If it's for you,"],[5042,5201,"I don't mind suffering a little."],[5276,5459,"Can't you see this is all for you?"],[5555,5672,"Ivy, why are you"],[5672,5789,"putting yourself through this?"],[5943,6172,"Arianna, you made Ivy cry!"],[6172,6256,"Apologize!"]],"63":[[12,141,"Derek, are you stupid?"],[191,287,"Ivy's basically saying"],[287,417,"she doesn't wanna be with you."],[442,517,"You're lying."],[554,621,"All I've seen is"],[621,746,"you bully her this whole time."],[796,867,"If you're blind,"],[867,963,"there's nothing I can do."],[992,1121,"I'm not wasting any more time"],[1121,1188,"on you two."],[1226,1372,"Hope you stay together forever"],[1372,1476,"and never break up."],[1630,1685,"Arianna."],[1826,1918,"Just because you're well off"],[1918,1989,"doesn't give you a right to"],[1989,2093,"treat us like this."],[2118,2260,"And she's never done anything to you."],[2285,2360,"If you have a problem,"],[2364,2452,"take it out on me,"],[2498,2577,"not hers."],[2623,2698,"She's innocent."],[2711,2927,"Oh, your girlfriend's so delicate"],[2927,2998,"and innocent."],[3048,3161,"She loves you so much,"],[3161,3303,"she's begging me to give you a job,"],[3428,3574,"hell, she's practically offering to"],[3574,3695,"hand you over to me."],[3712,3837,"You better treat her right."],[3870,4016,"Derek, don't listen to her."],[4054,4120,"Look, I just wanted to"],[4120,4208,"help you out financially"],[4208,4316,"so you could live a better life."],[4316,4358,"I..."],[4437,4621,"Arianna, if you're worried about"],[4621,4833,"Derek's attitude, I'll talk to him."],[4875,4950,"You can't even"],[4950,5084,"guarantee he'll behave,"],[5117,5246,"and you want me to give him money?"],[5280,5447,"You used to like him, right?"],[5513,5622,"If you care about him,"],[5630,5755,"shouldn't you be happy to help?"],[5793,5868,"That was before."],[5930,6051,"I don't like him anymore."],[6131,6285,"And I've already got the best tutor."],[6414,6468,"That's right."],[6548,6631,"I'm currently overseeing"],[6631,6740,"Arianna's studies."],[6785,6898,"My rates are reasonable,"],[6915,7036,"and her improvement"],[7036,7132,"speaks for itself."],[7161,7315,"Arianna, you think"],[7315,7436,"bringing this pretty boy around"],[7436,7549,"is gonna make me jealous"],[7561,7691,"and come crawling back to you?"],[7882,7957,"Dream on."],[8012,8145,"Wait, weren't you the one"],[8145,8249,"who just said you wanted to"],[8249,8375,"come back and tutor me?"],[8462,8529,"Are you having a"],[8529,8658,"mental breakdown or something?"],[8779,8821,"You."]],"64":[[4,216,"Derek doesn't even compare to Hayden."],[229,296,"Someone as"],[296,437,"exceptional as Hayden"],[475,638,"is a better match for me."],[675,784,"I need to push Derek"],[784,909,"and Arianna together,"],[913,1017,"that's the only way"],[1017,1180,"I'll have a chance with Hayden!"],[1213,1288,"No matter what,"],[1347,1468,"I hope you'll consider"],[1472,1572,"what I said earlier."],[1609,1747,"The offer still stands."],[1751,1868,"If you wanna be with Derek,"],[1943,2022,"I'll step aside."],[2077,2198,"Just get lost already."],[2223,2335,"I don't want any of it."],[2419,2552,"I know you're just acting tough"],[2552,2656,"because Hayden's here."],[2698,2819,"We'll talk alone next time."],[2865,2936,"Either way,"],[3023,3165,"I'll make sure Derek waits for you."],[3933,3978,"They're gone."],[3978,4066,"You can let go now."],[4170,4229,"What?"],[4254,4341,"You don't like it?"],[4375,4450,"Was all this talk about"],[4454,4608,"chasing me around just a lie?"],[4704,4838,"No, of course it wasn't a lie."],[5263,5380,"You still don't believe me?"],[5463,5626,"It's not that I don't believe you,"],[5626,5701,"it's just,"],[5914,6135,"Now you can feel how sincere I am."],[6210,6406,"Arianna, I'm gonna ask you again."],[6423,6514,"Will you please"],[6527,6635,"give me the opportunity to"],[6635,6698,"pursue you?"],[6852,6994,"I'll work really hard,"],[6994,7190,"and I won't stop until I get a yes."],[7223,7303,"If you don't say anything,"],[7303,7486,"I'll still take that as a yes."],[7653,7811,"On Friday at the school festival,"],[7970,8074,"I'm gonna give you a little gift."],[8112,8166,"I'm gonna help you"],[8166,8295,"write your thesis for the student"],[8295,8404,"representative speech."],[8416,8487,"I want everyone"],[8487,8583,"who's ever doubted you"],[8583,8733,"to see how amazing you are."],[8808,8900,"That's the gift?"],[8979,9138,"Then I'll try to do my best."]],"65":[[1021,1138,"So you finally decided to"],[1138,1205,"come home?"],[1347,1405,"Tell me where"],[1405,1555,"the rest of the money is hidden!"],[1605,1710,"That was the last bit of money"],[1710,1801,"that I had saved,"],[1818,1918,"and you stole it all?"],[1956,2039,"Stole?"],[2193,2310,"I'm your father."],[2414,2540,"It's only right that a son"],[2540,2765,"shares his money with his father."],[3078,3215,"I worked so hard for that money."],[3286,3403,"And you lost it all"],[3403,3545,"in one night of gambling."],[3607,3766,"You call that working hard?"],[3878,3987,"When we were staying at"],[3991,4116,"Arianna's place,"],[4170,4329,"life was so much easier."],[4362,4500,"That girl adored you,"],[4592,4771,"if you just treated her better,"],[4808,4913,"we wouldn't be struggling"],[4913,5005,"like this now."],[5063,5146,"I don't like her,"],[5201,5355,"so why should I treat her better?"],[5430,5551,"If she wants to give me her money,"],[5555,5659,"that's her problem."],[5776,6001,"You useless piece of trash."],[6064,6218,"You're the pathetic one."],[6293,6418,"You took Arianna's money,"],[6464,6573,"but you just"],[6627,6890,"couldn't pretend you cared about her,"],[6902,7040,"and now look who we are."],[7278,7353,"Listen to me,"],[7361,7720,"you go beg Arianna to take us back,"],[7778,8187,"or I will beat you every single day."]],"66":[[158,229,"Mr. Murphy."],[337,454,"What brings you here today?"],[642,700,"Jeff,"],[788,1096,"you are three months behind"],[1167,1272,"on your payments."],[1447,1835,"When are you going to pay me up?"],[1939,1993,"I'll pay."],[2043,2202,"I'll pay, I'll pay today."],[2235,2352,"Dad, we don't have any money."],[2356,2414,"Shut up."],[2615,2723,"Did you see our bosses here?"],[2969,3073,"If we don't pay,"],[3098,3249,"you wanna watch me die today?"],[3278,3365,"Hand over"],[3399,3582,"whatever money you got left."],[3620,3770,"I don't have any money left."],[3778,3908,"You took every cent that I have."],[3912,3978,"No money?"],[4124,4195,"Say that again."],[4229,4475,"Go get me the money now!"],[4984,5084,"Alright!"],[5184,5409,"I've seen this act too many times."],[5655,5730,"You wanna hit him?"],[5885,5955,"Let me help."],[6114,6218,"Beat his son to death."],[6289,6368,"Hold on, no."],[6368,6410,"No, no."],[6439,6481,"Wait, hold on."],[6481,6523,"No."]],"67":[[0,58,"Oh no!"],[241,375,"Please, please, please stop!"],[375,458,"You'll kill him."],[625,696,"Please stop!"],[709,792,"You're gonna kill him!"],[792,946,"Look, he's my only son!"],[950,1142,"If you can't pay,"],[1234,1363,"don't worry about your son's life."],[1497,1739,"Your worthless life isn't safe either."],[1755,1989,"Mr. Murphy, wait,"],[1989,2223,"I have, I have another solution."],[2406,2694,"There's this rich heiress"],[2736,2861,"who's crazy about him."],[2869,3136,"And her father is the wealthiest man"],[3157,3265,"in Maple Valley."],[3278,3395,"If you get the money from her,"],[3395,3582,"it's not just 3 million."],[3611,3832,"30 million is like nothing for her."],[3916,4062,"Your son's worth that much?"],[4079,4183,"Please, believe me."],[4195,4416,"This girl is obsessed with him."],[4425,4575,"The money from before"],[4575,4646,"came from her."],[4654,4696,"Y, yes."],[4696,4833,"Arianna's completely"],[4833,4942,"infatuated with me."],[4942,5042,"She used to give me"],[5055,5276,"tens of thousands in pocket money."],[5276,5401,"She even let me"],[5401,5551,"stay at her family's mansion."],[5568,5718,"But I, I stopped taking her money"],[5739,5947,"because I, I didn't like her."],[6093,6272,"You're an idiot, then."],[6335,6619,"So you gave up a mansion"],[6710,6844,"to live in this dump?"]],"68":[[37,254,"It was my idiot son's fault"],[254,354,"for messing things up"],[408,538,"and making this young lady angry."],[538,608,"But it's fine,"],[608,817,"he just has to swallow his pride,"],[825,938,"and she will definitely"],[938,1038,"give us the money."],[1059,1226,"Listen, I, I'll make the call right now."],[1255,1334,"I promise."],[1459,1551,"I'll get you that money."],[1659,1780,"No need for that."],[1951,2027,"Take the kid away."],[2147,2214,"Oh no."],[2406,2615,"If what you're saying is true,"],[2673,2819,"bring 3 million dollars"],[2819,2969,"by noon tomorrow"],[3003,3111,"and you'll get him back."],[3169,3215,"But,"],[3465,3553,"if you're lying,"],[3753,3903,"you'll never see your son again."],[3970,4350,"And your life is forfeit too."],[4758,4825,"Wait, hold on."],[4850,4904,"Wait!"],[4934,5080,"Hold on, Mr. Murphy, wait!"]],"69":[[316,542,"Miss Arianna, please save Derek."],[554,663,"He's been kidnapped!"],[663,729,"and the kidnappers want"],[729,855,"3 million dollars."],[855,905,"Kidnapped?"],[905,1005,"Then call the police."],[1005,1080,"Why come to me?"],[1080,1142,"No!"],[1146,1284,"You can't call the police."],[1284,1401,"If you do that, they'll hurt him."],[1401,1614,"They'll cut off his arm if we don't pay."],[1659,1856,"Honestly, I kind of like to see them."],[1864,1947,"Miss Arianna, look,"],[1947,2173,"I know you're still mad at Derek,"],[2218,2373,"but when he comes back, I promise you,"],[2394,2565,"he will treat you right!"],[2907,2977,"No, thanks."],[3057,3174,"I'd rather he have nothing"],[3174,3269,"to do with me at all."],[3378,3490,"But I'm kind of curious,"],[3507,3586,"what would he look like"],[3586,3682,"with one less arm?"],[3720,3845,"Do you think if I only paid half,"],[3845,3970,"the kidnappers would settle"],[3970,4154,"for cutting off one hand?"],[4275,4454,"Miss Arianna, this isn't a joke."],[4483,4642,"If you don't save Derek today,"],[4950,5071,"I will die right here!"],[5255,5326,"I mean, I need"],[5359,5447,"can..."],[5480,5588,"Yeah, come help me."],[5676,5739,"Thank you."],[5914,5993,"Wait, you, you..."],[6010,6093,"Miss Arianna, you..."],[6114,6235,"What? You, you'll give him the money?"],[6281,6385,"Don't get ahead of yourself."],[6443,6594,"Jeff's trying to kill himself."],[6623,6715,"Keep an eye on him and"],[6715,6869,"call the police if necessary."],[6906,6994,"I'm going inside."],[7019,7057,"You."],[7311,7369,"Arianna,"],[7469,7599,"it's not good to let things escalate"],[7599,7678,"to this point."],[7686,7799,"I need to take care of him."],[7841,7907,"No need."],[7974,8108,"You have nothing to do with this."],[8128,8362,"Derek's not worth dirtying your hands."]],"70":[[600,692,"What's going on here?"],[746,850,"Mr. Taylor, Mr. Taylor."],[850,1042,"Mr. Taylor, please, save my son."],[1046,1109,"And you and I"],[1134,1192,"have been classmates"],[1192,1292,"for years."],[1292,1463,"Please, you just can't stand by"],[1463,1543,"and let him die."],[1543,1647,"Did you gamble again?"],[1685,1839,"Look, I promise you"],[1839,1964,"I will never gamble again."],[1989,2027,"Alright?"],[2064,2218,"Look, I was, I did a stupid thing,"],[2243,2398,"but Derek is innocent."],[2552,2598,"Please."],[2610,2773,"I'm asking you one last time"],[2773,2823,"for help."],[2823,2998,"Alright, I am begging you."],[3557,3699,"I'll let my secretary handle this"],[3699,3874,"and bring Derek back."],[3908,3962,"Okay."],[3966,4083,"Thank you, Mr. Taylor."],[4083,4137,"Thank you."],[4145,4366,"I will have Derek come by personally."],[4383,4462,"And thank you."],[5192,5359,"Mr. Scott, I am so sorry."],[5367,5584,"Um, complete misunderstanding."],[5593,5668,"I apologize."],[5693,5826,"I should not have kidnapped"],[5826,6126,"your uh, your friend's crush."],[6172,6306,"Who you calling someone's crush,"],[6331,6373,"huh?"],[6427,6489,"I, I don't know."],[6489,6606,"That's what Derek said."],[6744,6861,"As shameless as ever."],[6961,7111,"Alright, is Derek still alive?"],[7115,7165,"Don't worry,"],[7165,7269,"we just tied him up."],[7282,7399,"And didn't lay a finger on him."],[7411,7553,"So he didn't even get beaten up?"],[7582,7657,"No."],[7686,7766,"No, I promise."],[7845,7907,"We're professionals,"],[7907,8012,"we did not touch a"],[8016,8153,"single hair on his head."],[8229,8370,"Is this how you run a kidnapping?"],[8416,8646,"Because I'm not very satisfied."]],"71":[[8,58,"What do you mean? - You're"],[58,237,"supposed to be tough kidnappers."],[246,362,"You should have beaten Derek"],[371,462,"black and blue."],[496,550,"And me?"],[558,709,"Oh, I'm just a delicate girl."],[709,892,"How could I possibly stop you?"],[980,1071,"Miss Arianna,"],[1217,1280,"I get it now."],[2823,2990,"This is what you get for not paying up!"],[2998,3061,"Ah."],[3232,3299,"Ah."],[3299,3415,"Think you can mess with us?"],[3828,3928,"Please, stop!"],[3928,3991,"God."],[4033,4162,"Arianna's here!"],[4237,4383,"She'll pay you the money!"],[4558,4662,"Oh, yeah?"],[4838,5050,"Where is the money then?"],[5309,5417,"The money's on its way!"],[5417,5522,"Please stop hitting him!"],[5522,5634,"I'm begging you!"],[5939,6143,"Trying to buy some time, huh?"],[6202,6368,"Let's see how long you can last."],[6460,6535,"Keep hitting him."],[7223,7294,"Please stop!"],[7294,7386,"You can't do this!"],[7394,7636,"He's a golden boy, a top student."],[7640,7862,"And if you ruin his face or his brain,"],[7862,8033,"his life will be over!"],[8033,8137,"Please, stop!"],[8692,8854,"Derek, does it hurt?"],[8958,9180,"But this, it is nothing"],[9205,9330,"compared to what I went through"],[9342,9438,"because of you."]],"72":[[145,279,"This is for messing with us."],[713,825,"Oh, Miss Arianna,"],[925,1059,"we've beaten him pretty badly."],[1134,1338,"Any more, and it might get serious."],[2702,2773,"Derek,"],[2806,2861,"I'm so sorry"],[2861,2998,"I couldn't get here sooner."],[3048,3119,"Arianna,"],[3199,3315,"you came to save me?"],[3340,3403,"Of course."],[3470,3557,"Your dad came to us"],[3557,3716,"asking for 3 million dollars"],[3716,3807,"to rescue you and"],[3849,3962,"my dad didn't wanna help,"],[3962,4108,"but I convinced him."],[4158,4316,"Derek, do you see now?"],[4371,4466,"I'm the only one"],[4466,4621,"who truly cares about you."],[4662,4700,"Where's your"],[4700,4846,"precious Ivy in all this?"],[4884,4967,"Haven't you heard?"],[5025,5059,"A woman"],[5059,5159,"who spends money on you"],[5176,5280,"might not love you,"],[5280,5334,"but a woman"],[5334,5472,"who doesn't spend money on you"],[5480,5655,"definitely doesn't love you."],[5718,5801,"Arianna,"],[6051,6235,"I was an idiot before."],[6272,6481,"I'll treat you right from now on."],[6556,6631,"I promise."]],"73":[[33,196,"Take care of your injuries first."],[208,375,"Go to the hospital and get checked out."],[1142,1347,"Ugh, it's so gross!"],[1409,1480,"Arianna,"],[1526,1614,"did something happen"],[1614,1701,"between you and Derek?"],[1701,1897,"You don't seem to like him at all,"],[1943,2056,"in fact, you seem to hate him."],[2077,2160,"You noticed?"],[2248,2385,"I don't just dislike him."],[2469,2544,"I hate him."],[2640,2736,"I'm gonna play with him like"],[2736,2852,"a cat with a mouse."],[2886,3028,"Catch him, let him go,"],[3028,3119,"catch him again."],[3128,3353,"First, I'll make him grateful to me,"],[3407,3607,"and then I'll make him suffer"],[3632,3728,"like he's in hell."],[3933,4066,"Do you think I'm a terrible person?"],[4074,4112,"No."],[4183,4254,"Are you kidding me?"],[4262,4320,"Of course not."],[4320,4354,"I..."],[4400,4512,"I fully support you."],[4629,4721,"You're not even asking"],[4721,4796,"any questions."],[4796,4929,"You're just standing by my side,"],[4929,5034,"no matter what."],[5046,5271,"It feels amazing to be supported"],[5271,5405,"and trusted like this."],[5918,5997,"Hayden,"],[6101,6177,"thank you."]],"74":[[408,483,"Sorry, I don't,"],[483,613,"I don't drink Americanos."],[663,696,"What?"],[696,738,"Uh."],[884,959,"Um."],[1272,1368,"You can have mine."],[1368,1647,"It's a latte, it's really good."],[1714,1760,"Sorry,"],[1760,1914,"I meant I don't drink coffee at all."],[2252,2364,"Are you messing with me?"],[2431,2598,"You used to buy me coffee every day,"],[2602,2694,"and now all of a sudden,"],[2694,2777,"you don't drink it?"],[2806,2948,"Just because you never cared enough"],[2948,3073,"to learn her preferences."],[4212,4262,"Mm."],[4350,4446,"Tastes amazing."],[6018,6106,"You're hurting me!"],[6151,6310,"Arianna, what exactly"],[6310,6448,"is your relationship with Hayden?"],[6560,6664,"Are you two together already?"]],"75":[[12,133,"Are you two already together?"],[141,254,"No, we're not."],[312,446,"I like to be, but"],[492,654,"I don't wanna scare Hayden off."],[692,775,"I'll take it slow."],[825,930,"You two are always together"],[930,1042,"under the guise of tutoring."],[1101,1255,"Who knows what you're really doing?"],[1284,1447,"What could we possibly be doing?"],[1447,1634,"Hayden's not that kind of person."],[1634,1710,"Let go!"],[1797,1856,"I'll admit,"],[1889,2014,"I was with Ivy before,"],[2056,2131,"but I'm a man."],[2160,2248,"And you're a woman,"],[2277,2331,"you should learn"],[2331,2452,"how to respect yourself."],[2469,2585,"And ever since I talked to you"],[2585,2656,"last time,"],[2686,2811,"I've been serious about you."],[2823,2965,"When Ivy came up to me the other day,"],[2965,3128,"I, I told her to go away."],[3203,3244,"So what?"],[3420,3520,"You're saying you're so charming"],[3520,3595,"that even the school's"],[3595,3712,"beauty queen wants you?"],[3828,3895,"Does it hurt"],[3941,4087,"seeing me so close to Hayden?"],[4187,4245,"Yes."],[4441,4487,"Don't you think"],[4487,4621,"you're being too good to him?"],[4642,4725,"Every time you look at him,"],[4725,4829,"your eyes light up."],[4838,4971,"You used to look at me like that."],[5213,5338,"So, you could feel pain, too?"],[5338,5551,"What I went through because of you"],[5551,5714,"was a thousand times worse."],[5905,6026,"I gave you everything,"],[6064,6172,"and you trampled on me,"],[6172,6281,"leaving me to die."],[6493,6544,"Derek,"],[6610,6706,"I will never forget"],[6706,6923,"the despair and pain you caused me."]],"76":[[20,129,"I will never forget"],[129,342,"the despair and pain you caused me."],[838,934,"What you're feeling now"],[934,1038,"is only the beginning."],[1046,1176,"It's only gonna get worse for you."],[1188,1326,"What are you even talking about?"],[1463,1584,"I never even hurt you!"],[1672,1906,"You're alive and well."],[2406,2489,"Let go!"],[2694,2736,"Arianna,"],[2736,2894,"how dare you do this to me?"],[2898,3065,"No, no I won't allow it."],[3211,3278,"Didn't you hear?"],[3420,3511,"She said let go!"]],"77":[[25,183,"This is between me and Arianna."],[204,300,"It's none of your business!"],[308,433,"Know your place, Derek!"],[433,621,"What exactly is your place?"],[642,754,"Let me remind you,"],[796,950,"Arianna is only close to you"],[967,1134,"because she's mad at me."],[1142,1267,"We've known for years,"],[1326,1451,"she's crazy about me."],[1509,1593,"You're just a tool."],[1664,1922,"She's using you to get my attention."],[2790,3032,"Arianna, you, you hit me."],[3069,3169,"You bet I did."],[3274,3403,"I was planning to play with you"],[3403,3478,"a little longer,"],[3482,3582,"to let you experience"],[3582,3724,"what it's like to have your feelings"],[3724,3891,"toyed with and disrespected."],[4008,4162,"But who do you think you are?"],[4208,4396,"How dare you talk to Hayden like that?"],[4496,4579,"Get lost!"],[5055,5146,"Fine, Arianna."],[5330,5484,"Now even a loser like Derek"],[5484,5593,"is chasing after you."],[5701,5809,"But at least my grades"],[5809,5993,"are way better than yours!"],[6039,6177,"At the school festival,"],[6202,6360,"I'll be the star student"],[6360,6460,"giving the speech,"],[6460,6644,"and your scandal of being kept"],[6652,6810,"will be exposed."],[6848,6936,"I'll make sure"],[6936,7127,"you never hold your head up again!"]],"78":[[1092,1267,"I'm sorry you had to see that mess."],[1297,1447,"I, I'm sorry I didn't jump in there."],[1447,1568,"If, if he would have hurt you,"],[1568,1630,"I, I would have,"],[1659,1710,"He won't!"],[1755,1931,"I won't let him hurt me a second time."],[1935,2014,"A second time?"],[2444,2594,"So he's hurt you before?"],[2769,2890,"I'm so sorry, Arianna."],[2890,3011,"I promise I will protect you"],[3011,3115,"from here on out, okay?"],[3148,3265,"No, it's not your fault."],[3265,3432,"I was just too naive back then."],[3440,3570,"I regret it so much,"],[3570,3716,"but it's all in the past now."],[3807,3928,"My nightmare is over."],[3974,4029,"Well then,"],[4083,4258,"can I help you create new,"],[4300,4396,"beautiful dreams?"],[4412,4504,"Of course!"],[4625,4683,"And by the way,"],[4683,4821,"congratulations on being chosen"],[4821,4954,"as the student representative"],[4954,5084,"for the school festival."],[5134,5226,"Thanks to you,"],[5284,5422,"I've improved so much"],[5422,5522,"because of you and..."],[5739,5926,"Hayden, after the festival,"],[5980,6131,"I have to tell you a secret."]],"79":[[87,141,"Teacher."],[291,367,"Why is Arianna"],[367,458,"the student representative"],[458,600,"for the festival instead of me?"],[604,734,"Ivy, Arianna has made"],[734,888,"significant progress recently."],[925,1046,"Plus, her thesis led to"],[1046,1180,"a 50 million dollar donation"],[1180,1251,"from Oasis Group"],[1251,1388,"to fund student research."],[1401,1488,"The school has decided"],[1488,1559,"it's best for her"],[1559,1647,"to share her experience"],[1647,1751,"and inspire others."],[1764,1889,"But how did this happen?"],[1906,2010,"I mean, I'm always the one"],[2010,2168,"giving speeches at events like this."],[2185,2239,"Ivy,"],[2323,2431,"the selection criteria"],[2431,2577,"was posted on the school website,"],[2594,2723,"Arianna's thesis is loved"],[2727,2877,"by students and professors alike."],[2894,3023,"If you have further concerns,"],[3023,3132,"please talk to the principal."],[3478,3553,"I see."],[4024,4145,"That's the old man"],[4145,4250,"who's keeping Arianna."],[4446,4592,"So if that's how it is."],[4629,4863,"Arianna, you're just using his money"],[4863,5063,"to steal my spotlight."],[5134,5213,"This time,"],[5242,5442,"I'll make sure you're humiliated"],[5442,5555,"in front of everyone"],[5555,5739,"and despised by all."],[6706,6806,"Hello, everyone."],[6835,6931,"I'm Arianna,"],[6931,7102,"today's student representative."],[7190,7520,"I am so happy to be here to share-"],[7649,7774,"I object!"],[8078,8262,"I object to Arianna"],[8262,8379,"being representative."],[8837,9038,"Her opportunity was bought."],[9063,9346,"She's a kept woman with no morals."]],"80":[[25,162,"Today, I'm here to express"],[162,325,"Arianna's shameless behavior"],[325,462,"in front of everyone."],[492,704,"Arianna's being kept by an old man,"],[738,834,"flaunting his money"],[834,1009,"and bullying her classmates."],[1017,1188,"This time, she even used his donation"],[1188,1255,"to steal"],[1255,1397,"this speaking opportunity."],[1772,1914,"Ivy, do you have any proof"],[1914,2060,"to back up these accusations?"],[2060,2135,"Or did you forget"],[2135,2273,"what happened the last time"],[2273,2406,"someone tried to slander me?"],[2448,2535,"Arianna."],[2573,2686,"I just can't stand"],[2686,2861,"seeing everyone deceived by you."],[2898,3036,"You trade your body for money."],[3048,3144,"How can you represent"],[3144,3228,"the students?"],[3307,3415,"You used your sugar daddy"],[3415,3649,"to steal someone else's opportunity."],[3699,3874,"How can you inspire anyone?"],[3970,4054,"I'm warning you,"],[4137,4204,"stop making"],[4204,4341,"baseless accusations."],[4433,4550,"If I'm being kept,"],[4587,4688,"show me the evidence."],[4742,4838,"If you can't prove it,"],[4838,4925,"you're slandering me"],[4925,5038,"in front of all these people,"],[5038,5159,"and I'll have no choice"],[5176,5326,"but to involve the police."],[5342,5463,"Who said I have no proof?"],[5597,5789,"Everyone, look at the screen."],[6210,6331,"As you can see,"],[6352,6423,"the old man"],[6423,6510,"who donated to the school"],[6510,6706,"is the same one keeping Arianna."],[6781,6873,"Now you understand,"],[6927,7161,"Arianna's opportunity was bought."],[7257,7357,"And I have reason to believe"],[7357,7486,"her grades might be fake too."],[7494,7607,"I mean, how else could she improve"],[7607,7665,"so quickly?"],[7665,7853,"That really is Arianna."],[7924,8153,"Look how close she is to that old man,"],[8229,8416,"their relationship cannot be normal."],[8445,8562,"Ivy's right."],[8583,8683,"I wonder why Arianna"],[8683,8833,"was suddenly chosen to speak."],[8863,9042,"She really is being kept."]],"81":[[4,133,"Um, Mr. Taylor,"],[133,387,"the students don't know any better."],[400,500,"And they've mistaken"],[500,650,"you and your daughter for,"],[784,896,"I'll handle this right away."],[900,1001,"No no, no need."],[1084,1159,"I'd like to see what else"],[1159,1255,"they come up with."],[1280,1401,"You think this is the man"],[1401,1501,"who's keeping me?"],[1501,1576,"Yes!"],[1634,1760,"And now you have no way out."],[1851,1897,"Arianna,"],[1897,2039,"I can't believe you'd stoop so low"],[2039,2243,"for such an old, ugly man."],[2268,2331,"Shut up."],[2510,2660,"Who are you calling old and ugly?"],[2698,2781,"To me, he's the most"],[2781,2902,"handsome man in the world."],[2944,3036,"Let me correct that,"],[3057,3240,"he's now the second most handsome."],[3328,3465,"But I don't think he'll be mad at me"],[3465,3578,"for saying that."],[3649,3799,"So quick to change your mind."],[3824,3970,"Hmph, I guess"],[3970,4095,"I can't compete with her crush."],[4746,4817,"Arianna,"],[4838,5021,"how can you be so shameless?"],[5042,5313,"You're being kept by that old man,"],[5330,5547,"and not only did you admit it,"],[5559,5726,"but you have the nerve"],[5726,5926,"to call him handsome?"],[5997,6072,"Is he here today?"],[6101,6306,"Is that why you're lying to flatter him?"]],"82":[[0,137,"So calling him handsome"],[137,262,"makes me shameless?"],[437,475,"What,"],[475,625,"am I not allowed to tell the truth?"],[746,867,"Today's event is attended"],[867,1026,"by the new school board chairman,"],[1026,1167,"and here you are,"],[1188,1330,"in front of the entire school,"],[1330,1530,"praising the old man who's keeping you."],[1589,1697,"You're an embarrassment"],[1697,1789,"to our school!"],[1789,1901,"Ivy, the only one who'll be"],[1901,2031,"embarrassed today is you."],[2056,2122,"Arianna,"],[2156,2310,"since you already admitted it,"],[2327,2410,"I would suggest that"],[2410,2652,"you apologize to everyone and"],[2715,2790,"drop out."],[3098,3228,"Our principal is fair,"],[3278,3345,"if he finds out you"],[3345,3499,"violated school values like this,"],[3499,3578,"the consequences"],[3578,3845,"will be much worse than this!"],[3937,4066,"Ivy, you're too kind!"],[4154,4341,"That's why she keeps bullying you!"],[4362,4446,"She stole"],[4446,4642,"your speaking opportunity!"],[4700,4863,"The principal should punish her"],[4863,5034,"severely and expel her!"],[5167,5263,"I'd like to know,"],[5305,5467,"who told you I was being kept?"],[5547,5655,"You're jumping to conclusions"],[5655,5789,"based on a few photos."],[5818,5855,"Seems like"],[5855,6060,"all your studying was wasted."],[6118,6281,"We have a witness!"],[6302,6381,"A witness?"],[6523,6589,"Derek."],[7465,7615,"This is your witness?"],[7632,7816,"Derek, tell everyone,"],[7928,7978,"didn't you say"],[7978,8116,"Arianna was being kept?"],[8258,8387,"Derek, don't you know"],[8387,8508,"exactly what my relationship"],[8508,8604,"with this man is?"],[8625,8800,"The photos aren't clear."],[8988,9067,"I can't tell."],[9209,9263,"Derek,"],[9338,9471,"I'm giving you one last chance"],[9471,9663,"to explain the truth to everyone."]],"83":[[4,75,"Arianna,"],[75,308,"why should Derek clear your name?"],[337,500,"You're the one who's shameless!"],[613,788,"Threatening others on top of it,"],[800,900,"how did our school end up"],[900,1001,"with someone like you?"],[1026,1088,"Arianna,"],[1088,1238,"I know you've always liked Derek,"],[1251,1305,"but that doesn't mean"],[1305,1472,"you can force him to lie for you!"],[1514,1622,"Do you have any idea"],[1622,1747,"how embarrassing this is"],[1747,1901,"for all of us students?"],[1906,2006,"Ivy's right."],[2064,2293,"It's humiliating to be your classmate."],[2377,2627,"Arianna, if you have any self-respect,"],[2690,2815,"you should just drop out!"],[3261,3319,"Drop out?"],[3365,3457,"Of course!"],[3712,3937,"Everyone, what do you think?"],[4079,4229,"Should we let her stay?"],[4329,4425,"Drop out!"],[4437,4825,"Drop out!"],[4850,5117,"Drop out!"],[5130,5255,"Okay, that's enough."],[5401,5501,"I dare anyone"],[5501,5643,"to make any more trouble!"],[5647,5789,"Principal, you're finally here!"],[5814,5901,"We have proof"],[5901,6031,"that Arianna is being kept"],[6031,6126,"by an older man!"],[6151,6310,"Not only does she refuse to admit it,"],[6331,6481,"but she also bought her way"],[6481,6544,"onto this stage"],[6544,6673,"as a student representative."],[6715,6769,"Principal,"],[6769,6944,"you must stand up for all of us!"],[6944,7040,"Wait, you're saying that"],[7057,7340,"Arianna and this man have"],[7399,7540,"that kind of relationship?"],[7557,7657,"That's right, Principal!"],[7728,7832,"Maple Valley High"],[7832,8066,"has always valued integrity"],[8066,8262,"and strict discipline."],[8295,8362,"We can't let"],[8387,8604,"Arianna ruin our school's reputation!"],[8775,8842,"Principal,"],[8858,8975,"I heard the new board member"],[8975,9096,"is attending today's ceremony."],[9134,9209,"For the sake of"],[9209,9321,"the school's reputation,"],[9321,9538,"you must handle this seriously!"]],"84":[[0,112,"Uh, that's true."],[112,342,"Misconduct should be punished."],[412,579,"So, tell me,"],[579,667,"what do you think"],[667,880,"we should do with someone like that?"],[1001,1213,"Arianna, you see that?"],[1267,1447,"The Principal's gonna punish you!"],[1568,1726,"Principal, expel her!"],[1747,1889,"Someone like her doesn't deserve"],[1889,1997,"to stay in this school!"],[1997,2202,"Okay, you, you've all worked very hard"],[2202,2310,"to get to this school."],[2310,2510,"If you're expelled,"],[2577,2727,"all that effort will go to waste."],[2736,2852,"So what?"],[2919,3144,"That's the price of making a mistake!"],[3211,3274,"If Arianna"],[3274,3424,"dared to do something like that,"],[3424,3641,"she has to face the consequences!"],[3682,3799,"If we don't punish her,"],[3820,3903,"others will start"],[3924,4049,"following her example."],[4079,4158,"What's next,"],[4179,4383,"turning our school into a brothel?"],[4412,4625,"Okay, so what you're saying is that"],[4646,4888,"anyone who behaves improperly,"],[4938,5113,"harms fellow students,"],[5113,5305,"or damages the school reputation"],[5305,5463,"should be expelled?"],[5467,5551,"Exactly!"],[5580,5830,"We have to expel students like her!"]],"85":[[4,75,"Arianna,"],[204,283,"what do you think?"],[675,846,"The truth will speak for itself."],[896,963,"Principal,"],[975,1159,"maybe we don't have to expel her."],[1247,1405,"She should be given a second chance"],[1405,1530,"to correct her mistake."],[1547,1651,"How about this?"],[1701,1856,"Arianna admits her wrongdoing"],[1856,2014,"in front of everyone and"],[2072,2231,"kneels to apologize."],[2302,2423,"As long as she's punished,"],[2423,2573,"I think students will accept it."],[3007,3132,"Ivy, you just want to"],[3132,3261,"destroy my reputation."],[3303,3536,"You really are ruthless."],[3545,3645,"Arianna, this whole mess"],[3645,3762,"has gone on long enough."],[3787,3883,"Aren't you ashamed?"],[3966,4183,"Just apologize before it gets worse."],[4237,4329,"Apologize?"],[4400,4433,"Derek,"],[4433,4554,"you still haven't answered me."],[4583,4733,"What exactly is my relationship"],[4733,4821,"with this man?"],[4850,4929,"Or better yet,"],[4959,5038,"why don't you start"],[5038,5130,"by telling everyone"],[5130,5242,"who you really are?"],[5259,5342,"What does my identity"],[5342,5488,"have to do with any of this?"],[6035,6260,"Arianna, hit me for Hayden."],[6272,6393,"You played with my feelings."],[6510,6648,"Now it's time for you to pay."],[6815,6890,"You won't say it?"],[6902,7086,"Fine, I will!"],[7127,7349,"Derek drives my luxury car,"],[7374,7486,"lives in my villa,"],[7499,7695,"spends my money on his girlfriend Ivy,"],[7707,7899,"then turns around and slanders me."],[7932,8037,"Did everyone's flattery"],[8037,8124,"get to his head?"],[8141,8304,"Made him forget who he really is?"],[8350,8395,"Derek,"],[8429,8529,"you're just the son of"],[8529,8662,"my family's chauffeur."],[8958,9025,"What?"],[9129,9267,"I'm the real heiress."]],"86":[[16,133,"Derek is actually"],[133,316,"Arianna's chauffeur's son?"],[442,567,"No wonder Arianna paid"],[567,704,"for his birthday party last time."],[779,930,"He said his bank card was with her."],[980,1113,"We've all been played."],[1159,1255,"This is insane!"],[1272,1493,"Yeah, Arianna was so good to him,"],[1493,1647,"and he bullied her the whole time?"],[1647,1881,"Pretending to be the rich heir"],[1881,2077,"while calling her servant?"],[2298,2369,"Arianna!"],[2419,2498,"Don't push it!"],[2544,2690,"The only reason you're doing this"],[2690,2861,"is because I refuse to be with you!"],[2886,2998,"Now you've moved on"],[3007,3119,"and you wanna ruin me?"],[3169,3290,"The more you act like this,"],[3307,3486,"the more pathetic you seem!"]],"87":[[362,408,"Oh."],[1109,1276,"You dare hit me?"],[2152,2214,"Derek,"],[2348,2423,"for years,"],[2473,2627,"my family has taken care of you."],[2752,2911,"And this is how you repay us?"],[2965,3232,"With betrayal and ingratitude?"],[3582,3628,"What a..."],[3678,3824,"what a spectacle this"],[3912,4099,"school anniversary has turned into."],[4216,4258,"It's him!"],[4295,4471,"Principal, he's the old man"],[4471,4579,"who's been keeping Arianna!"],[4804,4942,"How dare you come to our school"],[4942,5038,"and stir up trouble?"],[5055,5146,"You're finished today!"]],"88":[[8,145,"Keeping Arianna is bad enough,"],[145,362,"but now you have the audacity"],[362,462,"to show up here?"],[554,617,"Principal,"],[663,788,"throw this man out!"],[855,917,"Enough!"],[930,1084,"Don't you know who he is?"],[1096,1234,"I don't care who he is!"],[1251,1468,"A man who preys on students is scum!"],[1493,1622,"Our school won't tolerate"],[1622,1697,"people like him,"],[1718,1906,"let alone take his dirty money!"],[1976,2085,"I said, shut up!"],[2227,2410,"Arianna, come here."],[3486,3682,"Allow me to introduce myself."],[3778,3895,"My name is Donald Taylor,"],[3995,4154,"chairman of Oasis Group"],[4220,4320,"and Maple Valley High's"],[4320,4421,"newest board member."],[4450,4529,"Arianna"],[4650,4796,"is my biological daughter."],[5255,5334,"The daughter I have"],[5367,5530,"cherished for 18 years,"],[5593,5726,"who I would never let suffer."],[5822,5897,"Yet today,"],[6006,6106,"you all ganged up on her"],[6106,6181,"and bullied her."],[6381,6443,"No way!"],[6493,6765,"Principal, he has to be an imposter!"],[6781,6890,"You fool!"],[7261,7361,"How much longer"],[7361,7545,"are you gonna keep this scene?"],[7603,7745,"What, what's happening here?"],[7782,7895,"What's going on?"]],"89":[[4,129,"Didn't you just say that"],[129,266,"people who lack integrity,"],[287,429,"harm their fellow students,"],[538,642,"and tarnish the reputation"],[642,771,"of this school should be expelled?"],[1034,1084,"Principal,"],[1172,1272,"the rules have been set,"],[1376,1455,"so let's follow them."],[1518,1722,"Anyone who lied about my daughter,"],[1722,1785,"Wait!"],[1851,2014,"Mr. Taylor, we didn't know"],[2014,2164,"Arianna was your daughter!"],[2339,2460,"It was a misunderstanding!"],[2615,2744,"We, we didn't mean it!"],[2769,2873,"A misunderstanding?"],[3040,3169,"And, and you think this"],[3186,3303,"erases your guilt?"],[3432,3495,"Today,"],[3570,3707,"my daughter had to fight"],[3753,3858,"just to prove the truth."],[3895,3991,"But what about tomorrow?"],[4008,4145,"What happens when another girl,"],[4175,4308,"without power,"],[4433,4550,"without protection,"],[4667,4833,"ends up being your next target?"],[4925,5063,"Anyone who spread rumors"],[5109,5242,"or lied about my daughter,"],[5284,5359,"Oasis Group,"],[5372,5551,"will never hire you after graduation."],[5601,5655,"As for"],[5722,5868,"the masterminds behind this,"],[5972,6256,"Ivy, Emmy, and Derek,"],[6310,6389,"there's no place for you"],[6389,6481,"at this school anymore."],[6752,6835,"You're all expelled!"]],"90":[[37,116,"You're all expelled."],[404,517,"It's over."],[592,746,"Everything's over."],[759,829,"No."],[829,980,"What do I do now?"],[1005,1092,"Principal!"],[1092,1251,"Maybe the photo was a lie but..."],[1292,1384,"what about Hayden?"],[1409,1630,"Arianna bought herself a boy toy."],[1651,1830,"She paid to keep Hayden."],[1839,1901,"That's a fact."],[1939,2060,"What she did is, is"],[2093,2193,"just as disgraceful."],[2223,2314,"Keeping a boy toy?"],[2373,2515,"So you're saying my daughter"],[2569,2631,"bought him?"],[2690,2752,"That's right."],[2798,2973,"Your daughter tried to buy Derek,"],[2982,3119,"and when he rejected her,"],[3140,3240,"she threw her money"],[3240,3390,"at the transfer student, Hayden."],[3415,3541,"She paid for him."],[3807,3858,"Whoa."],[3912,4158,"I had no idea my family was so rich"],[4187,4358,"that my daughter could afford to buy"],[4387,4554,"the son of Maple Valley's"],[4587,4696,"wealthiest man,"],[4754,4813,"Hayden."],[4900,4954,"What?"],[5005,5084,"What?"],[5146,5205,"Hayden?"],[5276,5451,"He's the heir"],[5451,5647,"to Maple Valley's richest family?"],[5680,5960,"Then how could he even like Arianna?"],[6006,6060,"No."],[6097,6218,"I, I don't believe it."],[6256,6348,"You're lying!"],[6348,6493,"Believe it or not, it doesn't matter."],[6544,6669,"You won't be seeing us again,"],[6702,6794,"nor will you be seen"],[6794,6948,"anywhere near Maple Valley."],[7027,7169,"As of now, the Maple Group"],[7169,7311,"is blacklisting you."],[7382,7444,"You're done."],[7536,7595,"Mr. Taylor,"],[7678,7828,"these three are beyond redemption."],[7866,8016,"They've hurt Arianna enough."],[8074,8316,"Please allow me to handle this my way."],[8391,8483,"You know, people should handle"],[8483,8575,"their own matters."],[8625,8683,"What?"],[8721,8771,"No."],[8783,8854,"No, no, It's okay."],[8896,8967,"No!"],[8996,9054,"No."],[9071,9238,"Oww, no."]],"91":[[150,216,"Arianna,"],[483,513,"I told you"],[513,604,"I have a gift for you tonight."],[959,1055,"Let me go first."],[1172,1217,"Okay."],[1422,1480,"Hayden,"],[1718,1901,"I'm so glad you came into my life and,"],[1943,2122,"at first, I was grateful to you,"],[2122,2323,"but over time,"],[2323,2527,"I couldn't help but fall in love."],[2590,2719,"We've already lost so much time."],[2719,2877,"I don't wanna waste another second."],[2957,3061,"I wanna marry you."],[3115,3178,"Right now."],[3228,3303,"A proposal?"],[3365,3553,"I, Isn't the guy supposed to do that?"],[3699,3774,"Arianna,"],[3912,4054,"I let you slip once before."],[4054,4187,"But this time,"],[4583,4667,"will you marry me?"],[4708,4846,"You, you remember too?"],[4879,5030,"I've always loved you, Arianna."],[5075,5213,"Nothing will ever change that."],[5263,5313,"Yes."],[5351,5392,"Yes."],[5392,5538,"A thousand times, yes."],[5755,5864,"Yeah!"],[6047,6114,"Well."],[6489,6594,"Thank you, Hayden."],[6669,6798,"And thank you, God,"],[6835,7027,"for giving me a second chance."],[7057,7290,"This time, I didn't let you slip away."],[7361,7507,"I chose to be your wife,"],[7586,7791,"to love you, forever."]]}