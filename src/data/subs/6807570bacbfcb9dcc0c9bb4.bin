],"44":[[20,58,"Dad?"],[91,162,"What are you..."],[467,546,"What the hell?"],[642,796,"Dad, tell me you're not trying to"],[796,900,"pay him to leave me."],[925,1084,"I was only trying to protect you."],[1172,1288,"I don't know what's more laughable."],[1317,1380,"The fact that you think"],[1380,1463,"that you can pay him"],[1463,1547,"to leave your daughter,"],[1580,1685,"or that you think this amount of money"],[1685,1760,"is enough."],[1760,1914,"How dare you speak to me like that."],[1914,2010,"I am your father,"],[2010,2114,"and I am trying to do"],[2114,2206,"what is best for you."],[2206,2277,"Stop it!"],[2327,2510,"If what's good for me is taking me away"],[2510,2619,"from the man that I love,"],[2652,2773,"then you can forget it."],[2932,3040,"Ashton is the best thing"],[3040,3169,"that's ever happened to me."],[3257,3315,"And you can't"],[3315,3445,"persuade me otherwise."]],"45":[[20,100,"So you're gonna do this?"],[100,171,"You're gonna throw away"],[171,304,"your whole family for him?"],[362,508,"If it means I stop being your puppet,"],[508,592,"then it's worth it."],[725,796,"Alright guys."],[892,975,"Send him away."],[1564,1680,"You'll see I was right."],[1768,1881,"He'll break your heart!"],[1918,2027,"Don't hold your breath."],[2389,2494,"I'm so sorry,"],[2494,2627,"he took it too far this time."],[2669,2861,"Don't apologize for your dad's actions."],[3040,3140,"Did you say you love me?"],[3207,3324,"Ash, don't get me wrong."],[3324,3465,"I said that only to get rid of him."],[3465,3549,"I love you too."]],"46":[[0,79,"I love you too."],[212,479,"But Ash, you're my best friend."],[479,767,"Sadie, friends or not,"],[767,934,"I've fallen for you a long time ago."],[959,1046,"Maybe when it was"],[1046,1272,"first Mandy introduced us,"],[1272,1351,"or when I was trying to"],[1351,1434,"chase off every guy"],[1434,1514,"who was trying to go"],[1514,1647,"after you in high school."],[1768,1960,"Or when I first saw you"],[1960,2085,"in your prom dress."],[