think it calls for a celebration."],[7115,7236,"I'll go get some drinks."],[8153,8229,"Corinne?"],[8320,8433,"What brings you here?"],[8487,8650,"Ashton's here, right?"],[8675,8742,"Yes."],[8742,8908,"Um, what do you want with him?"],[9038,9113,"I have something"],[9113,9263,"very important to tell him."],[9663,9818,"I'm pregnant with his baby."]],"48":[[87,175,"What's going on?"],[175,233,"Sadie?"],[387,475,"Corinne?"],[588,671,"What are you doing here?"],[746,817,"Ash."],[975,1130,"I'm pregnant with your baby."],[1993,2173,"That's impossible."],[2173,2260,"I don't believe you."],[2293,2452,"We can do a paternity test"],[2452,2527,"if you want."],[2581,2815,"But, you know it's your baby."]],"49":[[241,433,"Sadie, are you happy?"],[433,633,"Your best friend's gonna have a baby."],[721,913,"Mandy, you're gonna be an aunt."],[1030,1109,"I'm tired."],[1109,1247,"You guys talk."],[1247,1305,"Sadie."],[1372,1438,"Come on."],[1676,1764,"You should leave."],[1901,2018,"I'll contact you later."],[2431,2489,"Sadie?"],[2598,2711,"Please open the door."]],"50":[[200,308,"You'll see I was right."],[400,513,"He'll break your heart!"],[734,846,"Don't shut me out."],[846,967,"Let's talk, okay?"],[1514,1605,"You know, this is so"],[1605,1701,"typical of you, Ashton."],[1701,1810,"I knew you'd mess things up,"],[1810,1868,"but I didn't think it was"],[1868,1997,"gonna happen so quickly."],[2072,2147,"I'm sorry."],[2189,2273,"I didn't mean to."],[2439,2540,"Well, I think you should go."],[2598,2748,"She needs some time to process this."],[2836,2982,"Will you take care of her for me?"],[3044,3090,"Sure."],[3194,3311,"I'll go talk to her, okay?"],[4108,4162,"Sadie?"],[4250,4312,"It's Mandy."],[4683,4746,"Hey."],[4925,5050,"Oh, come here."],[5138,5230,"It's gonna be alright."],[5259,5355,"We're gonna figure something out"],[5355,5434,"together, okay?"],[6927,6981,"See?"],[7015,7169,"I told you, you're the father."],[7265,7328,"Okay."],[7428,7553,"I'll take the responsibility"],[7553,7661,"and raise the baby with you."],[7816,7966,"Whatever you need, I'll pay for it."],[8028,8158,"I don't need your money."],[8283,8412,"I want us to get married."],[8525,8692,"That's not gonna happen."],[8804,9017,"Sadie's the one that I love, not you."],[9104,9171,"Fine."],[9171,9300,"If we don't get married,"],[9300,9471,"I'll send the baby to foster care."],[9559,9693,"And you'll never find it."]],"51":[[4,129,"You're fucking crazy."],[166,291,"That's right, I'm crazy."],[291,417,"I'm crazy about you."],[442,650,"And I'll do anything to keep us together."],[2214,2298,"Ash?"],[2481,2556,"Are you drunk?"],[2723,2819,"We need to talk."],[3144,3199,"Corinne said that"],[3199,3299,"if we don't get married,"],[3299,3482,"she's gonna send the baby to foster care."],[3532,3599,"What?"],[3853,4154,"So, you're gonna marry her?"],[4325,4508,"I love you, Sadie."],[4692,4917,"But I don't have a choice."],[4942,5059,"It kills me knowing that,"],[5059,5176,"my baby's out there,"],[5176,5392,"and I'll never get to see them."],[5659,5855,"Especially after what me and Mandy"],[5855,5930,"have been through."],[6202,6381,"I have to marry Corinne."],[6527,6719,"I understand."],[6840,6940,"I've known you and Mandy"],[6940,7048,"your whole lives."],[7107,7198,"I know you."],[7503,7561,"The truth is,"],[7561,7703,"I knew ever since Corinne said"],[7703,7791,"she was pregnant that"],[7791,7882,"this was gonna happen."],[8016,8137,"And that's what breaks my heart"],[8137,8212,"the most."],[8308,8479,"So, what are we now?"],[8608,8692,"I don't know."],[8863,8942,"Maybe one day"],[8942,9213,"we can manage to go back to being..."],[9388,9505,"just friends."],[10201,10301,"Good night, Ash."]],"52":[[183,308,"Oh, sweetie,"],[308,487,"I didn't ask for you to come to the bar"],[487,633,"so you could cry even harder."],[754,817,"I'm fine."],[1176,1355,"Actually, I'm gonna use the bathroom."],[1755,1901,"Mandy, how are you doing?"],[2031,2097,"What do you want?"],[2202,2264,"Nothing much."],[2264,2364,"I'm just here to give"],[2364,2481,"this to you personally."],[2560,2815,"You're my fiancé's sister after all."],[3115,3328,"Me and Ashton's wedding invitation."],[3411,3495,"This is next Friday."],[3495,3595,"That's so soon."],[3661,3816,"Did my brother say yes to this?"],[3849,3945,"No, it's just me."],[3945,4012,"I'm just,"],[4049,4191,"just don't want a big belly"],[4191,4275,"on my wedding day."],[4396,4500,"Well, I'll see you at my wedding."],[4546,4650,"Unbelievable."],[4675,4800,"Well, if you can excuse me,"],[4800,4938,"I'm gonna go and use the washroom."],[5985,6051,"Here."],[6081,6143,"Thanks."],[6185,6247,"Corinne?"]],"53":[[0,50,"Corinne?"],[129,271,"Why are you using tampons?"],[271,425,"Aren't you five months pregnant?"],[462,617,"It's none of your business."],[955,1092,"What's she freaking out about?"],[1222,1351,"Is she on her period?"],[1384,1505,"Is she not pregnant at all?"],[1739,2031,"Hey, um, did you see Corinne?"],[2031,2139,"She didn't"],[2139,2277,"do anything to you, right?"],[2293,2377,"No, she didn't."],[2377,2481,"Oh, okay."],[2481,2548,"What's that?"],[2977,3136,"They're getting married next Friday."],[3219,3290,"I'm sorry."],[3349,3428,"I can't believe"],[3428,3570,"they're getting married so soon."],[3586,3749,"I need to get the truth fast."]],"54":[[275,350,"Hey Mandy."],[379,446,"Hey."],[579,675,"Thank you for coming."],[738,850,"I know I disappointed you."],[1034,1126,"How's Sadie?"],[1159,1447,"Still a total wreck, but she's been"],[1447,1580,"busy with something lately."],[1634,1856,"Just don't count on her coming today."],[1997,2143,"I actually prefer it that way."],[3445,3574,"The information you asked for,"],[3574,3645,"Ms. Sawyer."],[3774,3837,"Thanks."],[3870,3966,"This was really helpful."]],"55":[[1259,1472,"As we stand here today,"],[1472,1697,"in the presence of our loved ones,"],[1697,1897,"we celebrate the union"],[1897,2085,"between these two souls."],[2085,2243,"We're getting married, Ashton."],[2318,2406,"You're mine."],[2423,2606,"Sadie Sawyer can't do anything"],[2606,2723,"to keep us apart now."],[2827,3094,"A bond that ties them together"],[3094,3219,"in the eyes of our Lord."],[3324,3382,"Ashton?"],[3616,3674,"Ashton?"],[3720,3774,"Sorry."],[3853,3937,"Please continue."],[3970,4149,"Do you take Corinne Kaldwell"],[4149,4316,"to be your lawfully wedded wife,"],[4316,4579,"to live together in holy marriage?"],[4863,4929,"I do."],[5046,5201,"If there is anyone here today"],[5201,5321,"who knows of any reason"],[5321,5455,"why these two"],[5455,5593,"should not lawfully wed,"],[5613,5880,"speak now or forever hold your peace."],[6247,6389,"Since there is no objection-"],[6389,6485,"I object!"],[6844,6948,"I object!"]],"56":[[0,87,"I object!"],[125,271,"Get the hell out of my wedding,"],[271,367,"Sadie Sawyer."],[508,646,"I'm here to tell the truth."],[671,788,"I'm not leaving until everyone"],[788,880,"knows what you did."],[934,1021,"Truth about what?"],[1276,1384,"That's bullshit."],[1409,1572,"Ashton's the baby's father."],[1576,1772,"And we're making a family together."],[1780,1885,"You homewrecker."],[1910,1989,"I know you're upset,"],[1989,2106,"but now's not a good time."],[2106,2281,"Sadie, there's people that are watching."],[2281,2348,"Let's just go."],[2348,2389,"Leave, okay?"],[2389,2469,"No, Mandy!"],[2477,2606,"I'm not here to make a scene."],[2694,2840,"This wedding has to be stopped."],[2936,3015,"Corinne's been faking"],[3015,3094,"this pregnancy."],[3115,3207,"This is the proof."],[3641,3699,"Corinne."],[3958,4045,"You're pregnant."],[4233,4362,"Aren't you worried about the baby?"],[4416,4462,"I-"],[4462,4575,"She's not pregnant."],[4596,4738,"She's been faking this whole time."],[4758,4938,"Just to force Ash into marrying her."],[5305,5417,"Corinne, how can you lie"],[5417,5559,"about being pregnant?"],[5584,5709,"These documents are fake"],[5709,5809,"and she's framing me."],[5809,5943,"She's just jealous of us"],[5943,6081,"and making this whole thing up."],[6081,6143,"You liar!"],[6143,6252,"You fucking liar!"],[6252,6439,"Corinne, this is humiliating."],[6439,6510,"Stop."],[6585,6748,"Ashton's mine and I won't let you"],[6748,6936,"take him away from me, Sadie Sawyer."]],"57":[[0,166,"How do you explain this, then?"],[283,446,"What other lies are you spewing?"],[471,608,"So what if I lied?"],[642,779,"You forced me to."],[779,984,"I'm so much better than that tramp."],[984,1051,"I've loved you"],[1051,1180,"since the first day we met"],[1180,1343,"and you're just too infatuated"],[1343,1443,"with her to see it."],[1459,1597,"None of this is Sadie's fault."],[1597,1685,"Leave her alone."],[1722,1818,"I don't love you."],[1843,1972,"I only agreed to marrying you"],[1972,2043,"because of your lies."],[2043,2143,"You said you were pregnant!"],[2160,2310,"Ash, I messed up."],[2310,2498,"Just choose me and marry me."],[2498,2756,"I love you and I can't live without you."],[2882,3003,"You don't love me."],[3044,3207,"It's just a twisted obsession."],[3269,3403,"If you really loved someone,"],[3403,3495,"you would not ruin their"],[3495,3603,"chance at happiness."],[3628,3720,"And that's the sacrifice"],[3720,3816,"Sadie made for me,"],[3816,3958,"which you will never understand."],[4291,4408,"Sorry everyone for the farce,"],[4408,4621,"but there won't be a wedding today."],[5146,5230,"Let's get out of here?"]]}