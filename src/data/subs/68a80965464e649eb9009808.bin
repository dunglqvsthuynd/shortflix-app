,[2819,2919,"Looking for my brother?"],[2936,3023,"Hey, yeah."],[3078,3203,"He's out searching for his son."],[3261,3349,"Oh, they still haven't"],[3349,3461,"found the Little Prince?"],[3474,3557,"It's so sad."],[3557,3661,"I don't know what I'd do"],[3661,3803,"if I couldn't find my Luka."],[4179,4204,"All right."],[4204,4287,"We'll come back later, okay?"]],"44":[[158,225,"Mommy,"],[225,429,"does Mr. Mars have a son?"],[429,583,"Ah, Yeah."],[608,663,"Yeah he does."],[663,784,"They call him the Little Prince."],[871,988,"But he's missing right now."],[1021,1113,"That’s sad."],[1209,1376,"I have a feeling the Little Prince"],[1376,1497,"will be home soon."],[1547,1609,"Yeah."],[2072,2143,"Grandma?"],[2210,2289,"Yasmin,"],[2289,2439,"your dad's up to something."],[2464,2577,"Watch your back."],[3023,3140,"I need to see Tristen."],[3140,3261,"It's been days,"],[3290,3328,"and he's yet"],[3328,3432,"to find my grandson."],[3461,3591,"He's been searching nonstop,"],[3591,3611,"sir."],[3712,3791,"Please, God,"],[3853,3978,"grand me another miracle,"],[4058,4195,"show the Little Prince!"],[4195,4325,"his way back home."],[4571,4654,"You know what?"],[4654,4833,"We are going to go see grandma."],[4833,4884,"What do you say?"],[4884,5059,"Yes, yes. Yes, yes."],[5059,5109,"Let's go!"],[5134,5192,"Let's go!"],[6131,6218,"Grandson!"],[6268,6389,"My prayers are answered?"]],"45":[[45,233,"Short brown hair,"],[279,400,"high nose line,"],[433,533,"kind eyes."],[625,684,"It's him."],[684,788,"It's the Little Prince!"],[1155,1263,"Grandson."],[1443,1505,"Grandson."],[1505,1626,"Grandpa’s here!"],[2381,2431,"Hey!"],[2464,2573,"Where the hell are you going?"],[2573,2698,"That's my grandson!"],[2977,3115,"I just found the Little Prince."],[3153,3244,"But he's been taken."],[3265,3445,"Sent back up now!"]],"46":[[100,237,"Security team is here, sir."],[291,400,"Mount up, gentlemen."],[475,533,"Today,"],[579,734,"we bring my grandson home."],[1163,1217,"Get in!"],[1217,1272,"Luka?"],[1