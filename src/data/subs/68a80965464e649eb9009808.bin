2344,"I'm meant to have a grandson"],[2344,2398,"to spoil!"],[2677,2865,"I can't wait to surprise mommy!"],[3103,3148,"Oh, no."],[3157,3303,"I can’t lose my sight now."],[3336,3453,"I have to find mommy!"]],"13":[[187,329,"That kid came out of nowhere!"],[329,467,"If you weren’t driving,"],[467,600,"that boy would be dead now."],[650,696,"I'm going to make sure"],[696,750,"he's okay."],[750,779,"Yeah."],[896,984,"Hey, are you all right?"],[1030,1096,"Can you hear me?"],[1142,1259,"I'm taking him to the hospital."],[1639,1743,"He fainted from the shock."],[1776,1851,"He should regain"],[1851,1956,"consciousness shortly."],[1993,2064,"Thank you, doctor."],[2552,2623,"Tristen,"],[2656,2915,"this boy looks exactly like you"],[2927,3044,"when you were his age."],[3086,3128,"Dad,"],[3165,3257,"you do this all the time,"],[3257,3345,"you let your imagination"],[3345,3399,"run wild."],[3449,3545,"I'm telling you,"],[3570,3791,"this boy is your spitting image,"],[3791,3837,"right down"],[3837,4012,"to the shape of your earlobes."],[4145,4225,"Could this be"],[4225,4371,"my miracle grandson?"],[4379,4617,"He looks to be about five years old."],[4637,4679,"No,"],[4729,4817,"it's not possible,"],[4846,4913,"is it?"],[4925,5059,"Could the girl from six years ago"],[5059,5159,"have gotten pregnant?"],[5255,5351,"There was a woman,"],[5384,5417,"but,"],[5430,5555,"the chances of me getting her pregant"],[5555,5684,"from a one night stand have to be"],[5726,5855,"a fraction of a percent,"],[5855,5910,"right?"],[6022,6068,"Ow!"],[6131,6202,"Seriously?"],[6427,6581,"Run a DNA paternity test"],[6581,6669,"on these immediately."],[6710,6815,"Of course, Chairman Mars."],[6923,7044,"Dad, this is ridiculous."],[7044,7123,"He's not my son."],[7161,7265,"It's only ridiculous"],[7278,7353,"if I'm wrong."],[7953,8041,"The results"],[8041,8166,"of your paternity test."],[8174,8279,"I'll take that, thank you."]],"14":[[45,120,"My grandson."],[246,350,"He's my grandson!"],[412,533,"Miracles do happen!"],[1017,1109,"He's really my son?"],[1130,1251,"Tristen, you’re a father!"],[1305,1509,"My guardian angel must be his mother!"],[1576,1689,"I have to find her,"],[1689,1755,"now"],[1755,1860,"more than ever."],[1885,1939,"Luka?"],[2010,2106,"Who is that?"],[2143,2223,"Could it be her?"],[2719,2773,"Okay."],[2798,2927,"Luca’s smartwatch says he's here."],[2927,3086,"Why is he at the hospital?"],[3132,3240,"Luka baby, mommy's here."],[3269,3340,"Where are you?"],[3762,3832,"Is he in there?"],[3903,3974,"Luka?"],[4458,4646,"I've been searching for you, Angel,"],[4646,4871,"for six long years,"],[4871,4992,"to thank you for that night."],[4992,5063,"And now"],[5063,5246,"to thank you for my miracle son."],[5551,5668,"I finally found you!"]],"15":[[287,446,"What are you looking for?"],[1501,1576,"Mommy!"],[1605,1789,"Oh, Luka! Hi!"],[1826,1864,"Oh my God,"],[1864,1989,"what are you doing here?"],[1989,2035,"You hurt?"],[2035,2122,"Are you injured? Sick?"],[2122,2181,"What's going on?"],[2210,2323,"I can't tell mommy"],[2323,2515,"I almost ran into a car."],[2527,2740,"She already worries too much."],[2827,2948,"I'm fine, Mommy."],[3032,3219,"I wanted to surprise you at work,"],[3240,3403,"but my eyes got blurry,"],[3432,3603,"so I came to the hospital."],[3603,3666,"Okay."],[3737,3828,"You did the right thing."],[3853,3891,"Okay?"],[3891,3991,"But promise me"],[3991,4104,"you're not gonna run off"],[4104,4250,"without mommy again, okay?"],[4279,4404,"Cross my heart."],[4404,4517,"Cross your heart."],[4517,4592,"Good."],[4738,4859,"Whoever you're looking for"],[4859,4921,"ain't here."],[4979,5113,"But my grandson is so."],[5180,5230,"Let's go."],[5593,5764,"Where did he go?"],[5926,5997,"Tristen!"],[6035,6114,"He's gone!"]],"16":[[25,104,"Tristen!"],[171,250,"He's gone!"],[354,437,"What do you mean he's gone?"],[471,558,"He must have slipped out"],[558,613,"behind us."],[629,742,"What are you waiting for?"],[742,834,"Do something!"],[834,892,"James!"],[980,1076,"Lock down the hospital."],[1096,1184,"There's a five year old boy"],[1184,1297,"running around by himself."],[1317,1384,"He's my son."],[1397,1555,"I need you to find him now."],[1576,1643,"Yes, sir."],[1676,1743,"Let’s go."],[2731,2836,"Check the next floor."],[2977,3094,"Let's go! Find the boy."],[3582,3724,"Guess some rich kids gone missing."],[3724,3807,"That’s sad."],[3828,3895,"All right. Ready to go?"],[3895,3941,"Let’s go!"],[3941,4012,"Okay."],[4095,4162,"What’s the status?"],[4191,4241,"My men are doing"],[4241,4354,"a sweep on each floor."],[4379,4483,"We'll have an update soon."],[4508,4554,"Did you check in"],[4554,4637,"with hospital security?"],[4696,4788,"They're on board, sir."],[4804,4929,"This is torture."],[4959,5034,"Why haven't they"],[5034,5159,"found my grandson?"],[5188,5246,"I don't know, dad."],[5251,5288,"We've searched"],[5288,5380,"every inch of the building."],[5422,5534,"My son's nowhere to be found."],[5551,5755,"Set up a perimeter around the hospital."],[5780,5905,"He can't have gotten far by now."],[5930,5997,"Yes, sir."],[6089,6181,"And what are we going to do"],[6181,6239,"in the meantime?"],[6256,6335,"Let's take a drive."],[6348,6427,"See if we can find him."],[6531,6610,"All right."]],"17":[[258,354,"Riding in this sidecar are"],[354,450,"some of my favorite memories"],[450,529,"with my grandpa."],[538,658,"Then why are we selling"],[658,796,"grandpa's motorbike?"],[821,880,"You love it"],[880,1076,"more than anything."],[1130,1242,"Oh, no,"],[1242,1443,"not more than anything."],[1463,1580,"I don't love it more than you."],[1647,1755,"And my new job"],[1755,1839,"won’t even come close to"],[1839,1943,"covering your surgery."],[2043,2077,"All right."],[2077,2143,"What do you say?"],[2189,2302,"Whip it out one more time, yeah?"],[2344,2456,"Punch it, mommy,"],[2456,2510,"punch it!"],[2510,2631,"All right."],[3807,3849,"Ah."],[3866,4041,"This is the worst night of my life."],[4070,4225,"Where could our Little Prince be?"],[4254,43