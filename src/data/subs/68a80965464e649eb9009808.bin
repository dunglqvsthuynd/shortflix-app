,"Dig in."],[4275,4333,"Thank you."],[4333,4437,"Nice lady."],[4892,5084,"I need to save some for mommy."],[5100,5226,"She's going to love it."],[5405,5526,"Where's the fucking cake?"],[5580,5759,"I saw a little boy run off with it."],[5776,5880,"He was too fast for me."],[6089,6135,"That's him!"],[6135,6222,"In the glasses."]],"22":[[37,145,"That's who stole the cake."],[554,721,"Did you eat the Little Prince’s cake?"],[742,900,"No, I didn't eat it!"],[921,1013,"Are you sure?"],[1484,1739,"What do you have to say for yourself?"],[1751,1881,"That lady over there"],[1881,2031,"gave me the cake!"],[2097,2152,"Liar!"],[2185,2306,"Why would she even do that?"],[2360,2498,"That velvet cake was made special"],[2498,2573,"for the Little Prince."],[2573,2698,"You stole it!"],[2698,2882,"I didn't steal it!"],[2882,3065,"You're a dirty little thief!"],[3065,3178,"I'm not!"],[3407,3499,"What's going on?"],[3557,3749,"This dirty rat stole"],[3749,3849,"the special cake made"],[3849,3962,"for the Little Prince."],[4029,4145,"I didn't steal it!"],[4145,4279,"That lady over there"],[4279,4387,"gave me the cake!"],[4387,4437,"Liar!"],[4437,4592,"I saw you steal it."],[4592,4700,"So did I."],[4700,4796,"I don't lie,"],[4796,4996,"I always tell the truth!"],[5050,5180,"You filthy bastard!"],[5180,5234,"I'm going to put you"],[5234,5288,"in the dumpster"],[5288,5376,"where you belong."],[5672,5818,"Mommy, help!"],[6277,6364,"Help, mommy!"]],"23":[[137,296,"Mommy, help!"],[429,508,"Luka!"],[575,684,"Help, mommy!"],[692,771,"Shut up!"],[771,871,"You're coming with me."],[1013,1176,"Get your hands off my son!"],[1222,1301,"Get your hands"],[1301,1443,"off of my son!"],[1609,1739,"Perfect timing, Yasmin."],[1760,1926,"Your little fatherless mongrel here"],[1926,2014,"stole the Little Prince’s"],[2014,2110,"special cake."],[2122,2164,"Luka,"],[2231,2344,"tell mommy what happened."],[2356,2473,"That lady over there"],[2473,2606,"gave me the cake."],[2619,2731,"I didn't steal it."],[2731,2923,"I was gonna share the rest with you."],[2923,3086,"I only took one bite."],[3136,3190,"Okay."],[3211,3307,"Hey, mommy believes you."],[3357,3478,"My son is not a liar."],[3503,3578,"He didn't take the cake."],[3578,3724,"And I see about"],[3916,4041,"five security cameras"],[4041,4129,"that are watching us right now."],[4129,4308,"I'm sure our gracious host"],[4308,4429,"wouldn't mind letting everybody"],[4429,4504,"in this party"],[4504,4704,"watch exactly what happened."],[4733,4892,"The nerve to assume"],[4892,5017,"Declan Mars would share"],[5017,5163,"his security footage."],[5217,5342,"Who do you think you are?"],[5359,5484,"Tristen's lost love"],[5484,5588,"and the Little Prince?"],[5847,5951,"Please."],[6510,6656,"Have you found your son?"],[6727,6802,"I'm sorry, dad."],[6810,6877,"Me and my men,"],[6877,7007,"we turned the town upside down."],[7107,7182,"Still no sign of him."],[7649,7736,"Yasmin and her son"],[7736,7824,"must still be here."],[7882,7974,"I should go say hello."],[8066,8183,"Let's go talk to the guests."],[8216,8304,"My men will find him."],[8337,8391,"I promise."]],"24":[[41,216,"You're going too far, Gia."],[237,337,"Not far enough."],[362,437,"Security!"],[471,567,"Get this desperate slut"],[567,729,"and her thieving brat"],[729,880,"off the Mars’ estate."],[950,1034,"Let go!"],[1076,1217,"Do not touch my son, Gia!"],[2168,2223,"Mommy,"],[2281,2389,"my head hurts."],[2406,2456,"Oh my god!"],[2485,2519,"Oh my..."],[2519,2565,"Hey, somebody"],[2565,2698,"call an ambulance, please!"],[2698,2794,"Please, please, please!"],[2802,2907,"He has a brain injury,"],[2907,2973,"we need help!"],[3015,3057,"Please."],[3057,3178,"He's barely bleeding."],[3194,3365,"You act like it's the end of the world."],[3395,3561,"He's the son of a homeless beggar."],[3616,3687,"You should be thanking me"],[3687,3787,"if he dies honestly."],[3787,3920,"It saves you the hospital bill."],[4054,4275,"Out of my way, bitch!"],[4925,4971,"Oh!"],[5025,5117,"Did that hurt?"],[5163,5238,"Oops!"],[5413,5509,"Oh, and your,"],[5588,5714,"little beggar son,"],[6026,6160,"want you to have this."],[7115,7190,"Stop!"]],"25":[[487,567,"Stop!"],[692,829,"Tristen, thank god you're here."],[892,959,"Yasmin."],[988,1051,"You okay?"],[1209,1347,"My son has a brain tumor."],[1418,1493,"please just help us"],[1493,1589,"get to a hospital."],[1601,1672,"Of course."],[1822,1906,"Hey, come on, buddy."],[1939,2031,"My car's right over there."],[2527,2765,"Same hair, same height."],[2806,2994,"Could this little boy be my grandson?"],[3015,3069,"Turn him around."],[3069,3128,"Let me see."]],"26":[[120,350,"I can't see much with all that blood."],[379,542,"And he wears glasses."],[596,742,"My Little Prince doesn't"],[742,859,"wear glasses."],[963,1088,"Let’s get him to the hospital."],[1188,1255,"Thank you."],[1405,1509,"That kid's a thief."],[1509,1609,"Don't forget that."],[1897,1939,"No."],[1993,2156,"No, my son would never steal."],[2156,2239,"Check your cameras."],[2577,2640,"On it, bro."],[2898,3032,"The kid didn't steal the cake."],[3132,3203,"I lied."],[3257,3328,"She paid me."],[3395,3490,"I'm so sorry."],[3620,3770,"You set up a five year old?"],[3891,4070,"Tristen, please, I can explain."],[4070,4183,"Explain what?"],[4308,4462,"Bullied an innocent little boy?"],[4596,4688,"Why do you even care?"],[4688,4783,"He's a nobody."],[4796,4863,"Enough."],[4896,4954,"Gia,"],[5009,5071,"you're fired."]],"27":[[8,116,"Tristen, you can’t!"],[350,446,"I damn well can."],[546,654,"And after what you did today,"],[675,725,"I'll make sure"],[725,792,"you never worked"],[792,884,"in this industry again."],[1222,1280,"Come on."],[1351,1514,"Let's get this boy to the hospital."],[1551,1668,"Tristen, you drive!"],[1872,2039,"This isn't over, Yasmin."],[2093,2227,"You think things are tough now?"],[2293,2464,"Wait until I'm done with you."],[2940,2986,"Dr. Chu,"],[2986,3053,"Dr. Chu, please."],[3053,3111,"You have to save him."],[3111,3169,"You have to."],[3207,3274,"Don't worry."],[3299,3390,"We'll do our best."],[4333,4425,"You okay?"],[4738,4829,"Should umm..."],[4900,4988,"we call your husband?"],[5238,5280,"No."],[5321,5347,"No."],[5347,5455,"I lied to you the other day."],[5480,5513,"I don’t..."],[5701,5822,"I don't have a husband."],[5822,5880,"I just..."],[6001,6126,"I didn't know how to explain"],[6126,6214,"that I'm a single mom."]],"28":[[37,125,"Six years ago,"],[125,275,"I had an unplanned pregnancy."],[383,529,"It was just me with my grandma."],[554,675,"So it was..."],[742,855,"It was really hard."],[1063,1159,"Especially because"],[1159,1242,"my kid can outsmart"],[1242,1355,"all of the babysitters."],[1543,1618,"And..."],[1730,1797,"one day he started"],[1797,1926,"getting his nosebleeds."],[2077,2202,"Doctors found a tumor."],[2348,2444,"He was only four."],[2706,2790,"It was the first time"],[2790,2911,"I cried in front of Luka."],[2994,3123,"He took one look at me,"],[3123,3311,"and he started crying, too."],[3707,3845,"I brought my son into this world"],[3845,3912,"just to suffer."],[3912,4033,"What kind of mother does that?"],[4058,4108,"I don't..."],[4408,4496,"It breaks my heart"],[4496,4579,"to watch her cry."],[4729,4863,"Don't be so hard on yourself."],[4917,5030,"It isn’t your fault."],[6051,6110,"Tristen."],[6502,6585,"Is he okay?"]],"29":[[196,279,"Hey, how was he?"],[279,333,"How’s my son?"],[371,492,"We got him stabilized."],[492,604,"He'll be waking up soon."],[684,759,"Thank you."],[821,917,"Thank you, thank you!"],[1338,1443,"So, Tristen,"],[1468,1530,"you left the party"],[1530,1672,"to be with your assistant?"],[1672,1810,"I feel bad, man."],[1910,2006,"She's a single mom."],[2010,2102,"She has a sick kid."],[2118,2193,"It's killing her."],[2335,2510,"And somehow she reminds me"],[2510,2573,"of that girl"],[2602,2715,"from six years ago."],[3274,3378,"I wonder where the father is."]],"30":[[166,258,"Okay."],[258,316,"Um."],[429,517,"My son is officially"],[517,638,"out of danger for today"],[638,709,"at least."],[717,746,"So,"],[842,975,"I really can't thank you enough."],[975,1051,"But please"],[1051,1130,"go back to your party."],[1130,1234,"I can't keep you here."],[1263,1317,"It's fine."],[1626,1718,"Dad's calling again."],[2097,2352,"Tristen, how is Ms. Dutton’s son"],[2385,2431,"doing?"],[2519,2548,"Hi,"],[2548,2702,"my son is recovering fine."],[2836,2969,"Declan is a kind man,"],[2969,3065,"just like Tristen."],[3169,3286,"The Little Prince is really lucky"],[3286,3390,"to have in this family."],[3428,3528,"That’s good,"],[3528,3628,"that's very good."],[3649,3753,"Thank you for asking."],[3799,3924,"You're very welcome."],[3924,4058,"And if you can help us"],[4058,4154,"find my grandson,"],[4154,4229,"it is I"],[4229,4371,"who will be thanking you."],[4429,4462,"Yeah."],[4462,4542,"What does he look like?"],[4600,4788,"Oh, I have this picture here."],[4792,4850,"Hold on."],[5217,5288,"This captures"],[5288,5442,"the essence of my grandson."],[5643,5755,"That's the Little Prince?"]],"31":[[62,241,"That's the Little Prince?"],[367,513,"Well, I'm not a Michelangelo,"],[558,654,"but I did my best."],[675,759,"Short hair,"],[779,850,"cute nose,"],[884,959,"kind eyes."],[1009,1138,"Imagine my son Tristen"],[1138,1238,"at the age of five."],[1276,1347,"Okay, dad."],[1397,1459,"See you at home."],[1493,1572,"Bye chairman Mars."],[1655,1705,"Love you, dad."],[2227,2302,"We should head out."],[2502,2581,"You sure you're good?"],[2652,2698,"Yeah."],[2894,2969,"Bye, Mr. Mars."],[3086,3128,"Bye."],[3390,3428,"See you."],[4316,4371,"Luka!"],[4425,4537,"Oh my god, you're awake."],[4600,4746,"Oh, thank god."],[4746,4909,"Mommy was so scared."],[4934,5075,"Don't be scared, mommy."],[5092,5205,"I'm all right."],[5288,5359,"Yeah."],[5764,5893,"Yasmin, may I speak with you?"]],"32":[[191,275,"Luka’s brain tumor"],[275,371,"is now critical."],[379,529,"We can't delay his surgery,"],[529,658,"not even for a week."],[658,767,"Do you have the funds?"],[884,967,"I'm working on it"],[967,1046,"as we speak."],[1305,1718,"I have to come up with $175,000."],[1764,1922,"Or Luka will never see again."],[2635,2865,"So I did finish everything"],[2865,2965,"on today's task list."],[2965,3036,"It's almost five,"],[3036,3228,"so I'm gonna head out."],[3265,3319,"Is that okay?"],[3328,3407,"Are you"],[3407,3524,"busy with your son at the hospital?"],[3641,3687,"No,"],[3741,3812,"actually,"],[3812,3970,"I’m starting my second job tonight."],[3970,4099,"I'm going to be a cocktail waitress"],[4099,4187,"at a private club."],[4225,4283,"So."],[4450,4487,"Thank you."]],"33":[[304,375,"Hi."],[400,600,"I got the Mcallan 50 year"],[600,750,"as requested, sir."],[1017,1176,"We'd like to have a drink"],[1176,1230,"with you."],[1547,1614,"I,"],[1643,1760,"I actually can't."],[1780,1893,"I'm working right now, so,"],[1947,2002,"but thank you."],[2164,2318,"I just paid"],[2335,2560,"50K for this bottle of whiskey."],[2615,2836,"Surely you can have a drink."],[3023,3078,"Look,"],[3078,3182,"I just started working here,"],[3182,3332,"and I really, really cannot"],[3332,3499,"afford to lose these jobs right now."],[3499,3553,"So..."],[3774,3912,"I'll make it worth your while."],[4446,4529,"Five grand."],[4558,4629,"Per shot."],[4742,4996,"I need that money for Luka’s surgery."],[5376,5442,"You know what?"],[5680,5726,"Line’em up!"]],"34":[[834,980,"I cannot believe I just"],[980,1409,"made $35,000 doing shots!"],[1768,1885,"I don't feel so good..."],[2406,2569,"That's the Phoenix, Mr. Slade."],[2631,2806,"You're the king of car theft and,"],[2873,3053,"she's the best restorer in the biz."],[3078,3157,"You didn't tell me"],[3157,3261,"she was hot, too."],[3286,3382,"Fuck her all you want."],[3661,3762,"Hoo hoo, okay,"],[3762,3920,"That last shot was a mistake."],[3962,4062,"I got greedy."],[4091,4179,"Phoenix."]],"35":[[367,404,"Who,"],[404,471,"who are you?"],[471,500,"I don't,"],[500,621,"I don't think I know you."],[658,750,"My name is Jimmy."],[775