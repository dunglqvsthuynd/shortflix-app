{"1":[[821,950,"No wonder car collectors"],[950,1096,"call you the Phoenix."],[1109,1192,"Nobody can bring"],[1192,1372,"a dead classic back to life"],[1372,1543,"like Yasmin Dutton."],[1634,1705,"Thank you,"],[1772,1968,"but this is actually"],[1968,2152,"my last restoration for a while."],[2198,2281,"Whatever for?"],[2335,2419,"Because..."],[2560,2786,"I'm actually pregnant."],[2957,3032,"Pregnant?"],[3119,3244,"But you're still single."],[3244,3353,"Who's the father?"],[4233,4433,"My finest restoration yet."],[4592,4754,"I wish you were still here to see it,"],[4788,4875,"grandpa."],[6856,7094,"Why do I feel so weird?"],[8420,8491,"Dad?"],[8562,8629,"Gia!"],[8708,8850,"No, no!"],[10076,10135,"Help me!"],[10197,10293,"They're trying to kill me."],[10660,10773,"Where the hell is he?"],[10960,11015,"Quick!"],[11102,11173,"Kiss me."],[11715,11836,"Looks like he's not here."],[11836,11928,"Check outside."],[12433,12550,"You just saved my life."],[12583,12687,"Now kiss me again."],[12687,12825,"Kiss me and don’t ever stop."],[13701,13759,"I got knocked up"],[13759,13888,"by that hot homeless guy"],[13888,13938,"that night,"],[13938,13988,"and I had to"],[13988,14114,"pay back the buyer for the car"],[14114,14239,"that my dad stole."],[14239,14297,"So,"],[14297,14372,"you're one of the rare ones"],[14372,14485,"that actually stuck by me,"],[14485,14639,"and although I'm so thankful for that,"],[14639,14777,"it's just not enough."],[14802,14981,"The garage is..."],[15119,15215,"it's over."],[15269,15369,"And the baby?"],[15411,15507,"Are you keeping it?"],[15548,15728,"This baby is all I have left."],[15728,15940,"And, I already love him more"],[15940,16082,"than anything in the world."],[16132,16241,"Yeah."],[16312,16428,"Yeah, I'm keeping him."]],"2":[[204,271,"Your son's tumor is"],[271,446,"pressing on his optic nerve."],[446,583,"If we don't operate soon,"],[583,692,"he'll go blind."],[729,859,"How long do we have?"],[859,950,"A month,"],[950,1042,"maybe less."],[12