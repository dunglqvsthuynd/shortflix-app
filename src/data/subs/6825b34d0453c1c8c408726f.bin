{"1":[[645,745,"There she is!"],[950,1033,"After her!"],[1075,1241,"My name is Eliana Northwood."],[1279,1383,"Eighteen years old."],[1395,1520,"Only daughter and heir"],[1529,1675,"to the late great Alpha King."],[1704,1787,"People like to call me"],[1787,1895,"the Wolf Princess."],[1941,2016,"Lots of wolves"],[2016,2150,"would kill for this life."],[2187,2229,"Me?"],[2279,2404,"I'd rather run barefoot"],[2404,2479,"through the woods"],[2504,2645,"than sit on a stupid throne."],[2920,2966,"Hurry up."],[3012,3075,"Follow her!"],[3629,3720,"Don't let her get away."],[3737,3791,"Cut her off"],[3812,3983,"before she gets to the gates!"],[6583,6708,"How dare you stop me"],[6708,6833,"from leaving my own pack."],[6875,7062,"You may be the Beta, Uncle Marcus,"],[7079,7250,"but I'm still the Alpha King's heir."],[7358,7495,"Princess Eliana-"],[7495,7612,"No, don't call me that."],[7658,7729,"Call me Lia."],[7825,7958,"I'm not the Wolf Princess anymore."],[7958,8070,"I'm leaving that all behind."],[8070,8137,"For Derek."],[8162,8337,"I've let you have your ways for years"],[8337,8445,"since your father died."],[8575,8700,"I even let you play peasant"],[8700,8870,"and enroll in the Lunar Academy,"],[8945,9045,"under a fake name."],[9145,9258,"And now you do this?"],[9366,9529,"All for some small-fry Alpha"],[9529,9587,"like him?"],[9775,9862,"He doesn't even know"],[9920,10045,"who you really are."],[10095,10179,"He loves me."],[10258,10370,"Just like I love him."],[10450,10554,"That's all that matters."],[10683,10816,"And if you can't support me, Uncle,"],[10816,10879,"then just..."],[10970,11050,"lock me up!"],[11129,11195,"Or let me go."],[11637,11745,"I've settled the alliance"],[11783,11866,"with Alpha Derek"],[11866,11966,"and Silverwind Pack."],[12058,12166,"So you don't have to hide who you are"],[12166,12283,"from him anymore."],[12333,12379,"Oh my God."],[12462,12508,"Thank you."],[12666,12804,"Thank you, Uncle Marcus."],[12979,13004,"Umm."],[13062,13125,"I've gotta go tell"],[13125,13212,"Derek the good news."],[13608,13679,"This is the tree"],[13679,13820,"where Derek and I first met."],[13895,13979,"I can't believe"],[13979,14095,"it's been a year already."],[14150,14250,"I did the right thing."],[14308,14491,"Derek is a powerful Alpha now"],[14491,14595,"because of my help."],[14695,14804,"After I tell him the truth,"],[14833,14937,"we'll make things official"],[14962,15158,"and rule over all the packs together."],[15287,15337,"Who's there?"],[15754,15800,"Goddess."],[15966,16033,"Who are you?"]],"2":[[37,120,"What do you mean, who am I?"],[187,250,"You should've be informed"],[250,350,"about the contract already."],[533,620,"Contract?"],[1195,1241,"Cassian."],[1304,1370,"The Silver Wolf."],[1529,1608,"You can call me Caz."],[1662,1704,"Now come on."],[2050,2137,"I'm gonna make you look presentable."],[2137,2216,"Wait, wait."],[2325,2437,"what are you talking about?"],[2516,2558,"What do you mean,"],[2558,2654,"what am I talking about?"],[2691,2808,"I'm paying you to be my date"],[2808,2933,"to the Summer Solstice Dance."],[3029,3162,"We agreed to twenty thousand"],[3162,3233,"for one night."],[3266,3354,"Is the money not enough?"],[3404,3545,"I-I don't need your money."],[3616,3675,"You sure about that?"],[3775,3887,"Listen, dude,"],[3920,4016,"I don't know what kind of weirdo"],[4016,4104,"needs to pay someone"],[4104,4183,"in order to be their date"],[4183,4312,"to the Solstice Dance,"],[4370,4454,"but I already have one."],[4591,4625,"See?"],[4850,4875,"Oh."],[5045,5104,"My mistake then."],[5679,5720,"One moment."],[6287,6487,"Roman, what is going on?"],[6525,6620,"The deal was I'd show up"],[6620,6733,"to the Solstice Dance with a girl"],[6733,6845,"to get our parents off our back."],[6895,6966,"Then I take control"],[6966,7054,"of the Silverwind Pack."],[7091,7170,"Silverwind?"],[7220,7279,"That's the pack"],[7279,7404,"Derek has an alliance with now."],[7487,7650,"But I've never seen this guy before."],[7716,7808,"You're telling me now"],[7808,7900,"she got cold feet?"],[8137,8187,"Goddess."],[8320,8445,"Then who's this girl I'm here with now?"]],"3":[[33,83,"Derek."],[133,220,"Happy one year."],[245,304,"I'm so glad"],[304,400,"you were able to make it."],[441,566,"I-I brought a gift."],[837,937,"They're Moon Lilies."],[962,1104,"They're blessed by the Moon Goddess"],[1104,1200,"with healing powers."],[1250,1283,"I know that"],[1283,1416,"your grandma's feeling unwell,"],[1416,1662,"so I waited for hours for them to bloom"],[1662,1829,"so that I could pick them for you."],[2125,2187,"Derek!"],[2383,2445,"Hold tight, Roman."],[4375,4445,"Derek."],[4587,4658,"Who's this girl?"],[4841,4966,"Isn't it obvious, Lia?"],[4995,5116,"She's my new mate."]],"4":[[120,241,"She's my new mate."],[358,450,"But I'm your mate."],[475,550,"Not for long."],[691,820,"Derek doesn't want you anymore."],[1087,1175,"Cancel the contract."],[1216,1270,"I gotta go."],[1441,1595,"I'm a big time Alpha now, Lia."],[1625,1770,"I can't be seen at the Solstice Dance"],[1770,1912,"with an orphan Omega as my mate."],[2000,2100,"But Elise here"],[2120,2279,"is an Alpha's trueborn daughter."],[2320,2375,"She's someone"],[2375,2537,"worthy of being with me."],[2595,2687,"Derek made an alliance"],[2687,2800,"with the Silverwind Pack,"],[2812,3012,"the richest pack in the entire kingdom."],[3062,3245,"And in two days at the Solstice Dance,"],[3245,3358,"he's gonna seal the deal."],[3429,3520,"Imagine showing up"],[3520,3633,"with someone like you"],[3670,3812,"in front of the Wolf Princess."],[4075,4304,"Derek, about the alliance-"],[4304,4408,"What does a nameless"],[4408,4520,"little Omega like you"],[4520,4658,"have to do with pack business?"],[4716,4854,"You don't know anything about me,"],[4854,4891,"you slutty-"],[4891,4987,"You aren't allowed to talk"],[4987,5129,"to my future Luna like that."],[5433,5620,"But Derek, please-"],[5620,5812,"It's Alpha Derek to you now."],[6804,6945,"You have no right."],[6950,7050,"I have every right."],[7100,7191,"I'm an Alpha now,"],[7204,7362,"and I don't answer to pathetic"],[7366,7508,"little orphan wolves like you."],[7658,7754,"I'm not an orphan."],[7804,7875,"I just made that up"],[7875,7945,"to make you feel better"],[7945,8025,"about yourself,"],[8025,8162,"you insecure dick."],[8229,8312,"I am a daughter"],[8312,8433,"of the Northwood Pack."],[8437,8512,"I don't want to hear anymore"],[8512,8670,"of your stupid excuses."],[8679,8829,"You're lucky I don't have you banished"],[8841,8933,"with my new authority"],[8933,9083,"as the Alpha of the Stormvale Pack."],[9112,9187,"Fuck you."],[9266,9337,"How dare you."],[9362,9466,"No, how dare you."],[9520,9687,"You have no idea who I am,"],[9725,9850,"Alpha Derek."]],"5":[[25,187,"You have no idea who I am,"],[233,358,"Alpha Derek."],[795,929,"I lied about who I was"],[1045,1162,"so that you wouldn't treat me"],[1162,1245,"any different."],[1291,1433,"I wanted you to love me for me."],[1458,1550,"But I guess someone like you"],[1550,1787,"only cares about power and money."],[1858,1945,"And just so you know,"],[1975,2037,"the only reason"],[2037,2120,"you were able to secure"],[2120,2241,"the alliance with the Silverwind Pack"],[2241,2329,"was because of me."],[2379,2500,"Why else would the richest pack"],[2500,2591,"in the entire kingdom"],[2591,2733,"even give you the time of day, huh?"],[2875,2954,"If it wasn't for me"],[2983,3125,"helping you out behind the scenes,"],[3154,3304,"you'd still be some no-name,"],[3337,3587,"low-level Alpha of a no-name pack."],[3679,3837,"And you, you wouldn't be allowed"],[3837,3937,"in the same room as me."],[4045,4191,"If anyone should be on their knees,"],[4262,4337,"it would be you two."],[4445,4541,"I'm not an Omega."],[4637,4775,"I am the trueborn daughter"],[4775,4845,"of the great,"],[4845,5000,"late Alpha King Lawrence."],[5058,5191,"I am Eliana."],[5229,5366,"The Wolf Princess."],[5425,5791,"And I do not bow or beg to anyone."],[5891,5954,"Princess?"],[6037,6154,"She's the Wolf Princess?"],[6637,6700,"Wow."],[6845,7016,"That's real fucking funny, Lia."],[7025,7104,"Hasterical."],[7158,7233,"Maybe we should make her"],[7233,7362,"our little pack clown."],[7516,7645,"I-I'm not lying."],[7691,7787,"I'm telling the truth!"],[7979,8120,"I am the Wolf Princess."],[8158,8316,"Yeah, and I'm the Moon Goddess."],[8362,8504,"Do you think we're stupid?"],[8554,8804,"How could you be the Wolf Princess?"],[8845,8920,"I-I knew you'd be"],[8920,9025,"a drama queen about this,"],[9025,9116,"but come on."],[9170,9370,"You, the Wolf Princess?"],[9433,9545,"I mean, just look at you."],[9554,9654,"You don't even look good enough"],[9654,9733,"to be a maid."],[9808,9904,"You and I are from"],[9904,10045,"completely different worlds."],[10154,10275,"You're both idiots."],[10350,10416,"And you just lost"],[10416,10533,"your last shot at mercy."],[10625,10733,"In the Moon Goddess' name,"],[10733,10920,"I reject you as my mate."]],"6":[[0,100,"In the Moon Goddess' name,"],[100,287,"I reject you as my mate."],[700,891,"Aw, look at you, Lia."],[954,1037,"It hurts, doesn't it?"],[1120,1300,"It doesn't have to be this way, though."],[1354,1508,"If you get on your knees and beg,"],[1545,1662,"I'll think about keeping you"],[1662,1745,"as my pet."],[2129,2245,"She's not actually gonna do it,"],[2291,2333,"is she?"],[2408,2500,"You said you loved me, right?"],[2570,2670,"You told me you'd do anything"],[2670,2733,"to be with me."],[2816,2945,"Well, now's your chance to."],[3112,3262,"I accept your rejection."],[4762,4804,"You okay?"]],"7":[[41,87,"You okay?"],[262,287,"Yeah."],[500,616,"You little bitch."],[641,820,"I wasn't fucking finished talking."],[879,979,"Do you even know how many girls"],[979,1112,"would kill for the chance"],[1112,1183,"to be with me?"],[1320,1395,"And who the hell is this,"],[1395,1483,"your new boyfriend?"],[1512,1683,"This is none of your business, outsider."],[1704,1770,"You don't get to tell me"],[1770,1933,"what is and isn't my business."],[1941,1983,"It's okay."],[2258,2366,"They're not worth the effort."],[2620,2716,"And Derek, you were right."],[2775,2820,"We are from"],[2820,2958,"completely different worlds."],[3058,3179,"If you end up regretting this,"],[3262,3329,"that's on you."],[3662,3833,"About that contract mate thing,"],[3966,4100,"is the deal still on the table?"],[4433,4533,"Most definitely is."],[5291,5420,"Did we just bond?"]],"8":[[250,362,"Did we just bond?"],[425,500,"Oh look."],[541,600,"Freak one,"],[725,804,"and freak two."],[875,1016,"What a match made in heaven."],[1166,1387,"Take your little boy toy and get lost,"],[1387,1416,"Lia."],[1420,1525,"You're nothing to me now."],[1591,1770,"You're a pathetic excuse of an Alpha."],[1775,1879,"What did you just say to me?"],[1891,1958,"Did I stutter?"],[2037,2141,"I said you're pathetic."],[2270,2375,"Who is this guy?"],[2404,2533,"No respectable Alpha would act"],[2541,2733,"like an entitled, ungrateful brat."],[2779,2900,"Especially not to their mate."],[2916,3012,"Why do you even care?"],[3062,3150,"She's nobody."],[3283,3333,"Nothing."],[3354,3454,"She's my mate."],[3620,3712,"That's impossible."],[3787,3866,"And from now on,"],[3866,3933,"neither of you"],[3962,4054,"are allowed to touch her."],[4216,4258,"Got it?"],[4354,4516,"Where the hell did you find this guy,"],[4516,4545,"Lia?"],[4587,4750,"I mean, I knew you'd be desperate,"],[4750,4879,"but you're really going to downgrade"],[4879,5045,"to this random motherfucker?"],[5058,5162,"Can't see how she would downgrade"],[5162,5270,"when she was scraping the bottom"],[5270,5383,"of the fucking barrel with you."],[5391,5470,"Do you have any idea"],[5470,5562,"who you're talking to?"],[5625,5762,"I'm Alpha Derek,"],[5812,6012,"leader of the Stormvale Pack."],[6037,6191,"And I could have you banished"],[6220,6345,"for talking to me like that."],[6383,6533,"And I could have you executed."],[6908,7070,"I know who you are, Alpha Derek."],[7158,7345,"Now allow me to introduce myself."],[7466,7554,"I'm Cassian,"],[7629,7800,"Alpha of the Silverwind Pack."]],"9":[[62,150,"I'm Cassian,"],[229,408,"Alpha of the Silverwind Pack."],[575,654,"As if."],[716,812,"Alpha Cassian"],[816,983,"is the most powerful Alpha"],[983,1108,"in the western territories."],[1133,1333,"He would never be mated to a human."],[1345,1441,"And he definitely"],[1441,1529,"wouldn't dress like that."],[1683,1754,"Excuse me?"],[1841,1937,"He's an imposter."],[1979,2116,"Just like little Lia."],[2270,2304,"Right."],[2312,2362,"Yeah, yeah."],[2379,2425,"You're right."],[2479,2583,"This guy's just a poser."],[2608,2625,"I mean,"],[2625,2812,"the real Alpha Cassian is my ally."],[2879,3079,"And at the Solstice Dance in two days,"],[3116,3220,"I'll make my alliance"],[3220,3408,"with the Silverwind Pack official"],[3445,3645,"with Alpha Cassian then."],[3720,3758,"Fine."],[3850,3966,"I can't wait to see your face"],[3966,4020,"when you realize"],[4029,4133,"how much of a fucking idiot"],[4133,4162,"you are."],[4304,4379,"And as for you,"],[4466,4620,"this is the last favor"],[4629,4729,"I ever do for you."],[5029,5112,"Consider this payment"],[5112,5195,"for the last year."],[7108,7162,"One year."],[7370,7479,"I gave him my life,"],[7562,7616,"my love,"],[7683,7745,"everything"],[7841,7925,"for one year."],[7979,8054,"Just for this."],[8962,9070,"You really thought he'd choose you?"],[9200,9233,"Guys like that"],[9233,9333,"only care about one thing,"],[9400,9470,"climbing to the top,"],[9500,9554,"and they don't care"],[9554,9650,"who they crush on the way."],[9812,9895,"Why did you help me?"],[9950,10029,"What do you want?"],[10129,10245,"Tell me who you really are."]],"10":[[4,70,"I already told you."],[129,216,"I'm Alpha Cassian."],[225,316,"Oh, please,"],[345,450,"you really expect me to believe"],[450,545,"that you're the Alpha"],[545,654,"of the most powerful pack"],[662,770,"in the western territories?"],[800,862,"And if you were really"],[862,945,"the Wolf Princess,"],[1033,1070,"then you know I've been"],[1079,1204,"on an expedition for the last year"],[1204,1316,"before my dad got sick"],[1345,1458,"and I took over as Alpha."],[1491,1600,"We barely just met."],[1641,1720,"I don't know you"],[1741,1862,"and you don't know me."],[1870,1962,"And yet we bonded."],[2025,2137,"That must mean something more,"],[2137,2175,"right?"],[2383,2458,"Don't you want to get revenge"],[2458,2533,"on Alpha Derek?"],[2625,2729,"I can help you do that."],[2800,2929,"We can ruin him forever."],[3029,3137,"What do you get out of this?"],[3241,3325,"I avoid being married"],[3325,3458,"to some crazy she-wolf"],[3458,3533,"who's been obsessed with me"],[3533,3595,"for years."],[3762,3983,"And you, Your Royal Highness,"],[4108,4262,"can get your sweet revenge."],[4716,4775,"So what do you say?"],[5629,5679,"Alright."],[6020,6050,"Deal."],[7354,7466,"This doesn't fully mean"],[7466,7558,"that I trust you, though."],[7620,7687,"We have two days"],[7687,7812,"until the Solstice Dance."],[7850,8016,"I can contact the Silverwind leaders"],[8016,8175,"and make sure they play along"],[8175,8354,"with your charade and cover your ass."],[8408,8479,"Cover my ass?"],[8704,8758,"Why don't you worry about"],[8758,8820,"covering your own?"]],"11":[[208,250,"Listen,"],[283,458,"the Wolf Princess will arrive soon."],[529,650,"She's coming to claim"],[650,737,"her royal heirlooms"],[737,833,"in the Academy Vault."],[854,941,"Go get your team"],[962,1025,"and get ready"],[1025,1133,"to welcome the Princess."],[1204,1345,"And you have to treat the Princess"],[1345,1479,"with the utmost respect."],[1554,1616,"Understood?"],[1679,1812,"But Vice Principal Jones,"],[1812,1895,"I've never met"],[1895,2020,"the Wolf Princess before."],[2062,2154,"How am I supposed to know"],[2154,2233,"what she looks like?"],[2320,2433,"You'll know who she is."],[2470,2595,"The Princess will arrive soon."],[2650,2691,"Go!"],[2970,3091,"Who is this poor girl"],[3091,3187,"riding a bike?"],[3187,3279,"I can't let her mess up"],[3279,3370,"this important party."],[3370,3412,"Hey."],[3466,3604,"Park your bike somewhere else,"],[3604,3695,"stupid little girl."],[3712,3875,"The Wolf Princess will be here soon"],[3879,4016,"and you're blocking her path."],[4150,4266,"But I'm the Wolf Princess."],[4350,4387,"There!"],[4400,4475,"That must be her."],[4795,4908,"There she is."],[4908,5125,"It's my chance to win the big tip."],[5866,6045,"Not this bitch again."],[6520,6575,"Move!"],[6583,6720,"You're in the princess' way."]],"12":[[0,45,"Oh."],[58,108,"You again."],[158,270,"If I didn't know any better,"],[287,337,"I'd say you were"],[337,437,"a little fangirl of mine,"],[437,479,"Lia."],[558,662,"We're so honored"],[662,820,"to have you here today, Princess."],[837,879,"Princess?"],[879,920,"What are you..."],[1266,1300,"Oh,"],[1375,1416,"that's right."],[1450,1566,"I'm the Wolf Princess."],[1641,1729,"No, she's lying."],[1737,1850,"She's not the Wolf Princess."],[1850,1908,"I am."],[2066,2100,"You?"],[2200,2320,"Do you think we're stupid?"],[2383,2475,"What kind of princess"],[2475,2604,"rides in on a bicycle?"],[2737,2791,"Look at her."],[2904,2991,"Look at her clothes,"],[2991,3120,"her designer handbag."],[3158,3212,"She looks like"],[3212,3329,"she stepped off the runway."],[3408,3475,"And you?"],[3562,3666,"You look like you got lost"],[3666,3758,"in the bargain bin."],[3858,3920,"Please,"],[3941,4104,"she gets her clothes off the rack."],[4129,4262,"And that bag is obviously a fake."],[4262,4362,"You can tell by the quality"],[4362,4445,"of the shitty leather."],[4516,4654,"How dare you talk to Her Highness"],[4654,4695,"that way."],[4716,4775,"Guards."],[4950,5087,"Take this fake princess away."],[5133,5195,"No, wait!"],[5512,5579,"If I was a fake,"],[5687,5770,"how would I have this?"]],"13":[[58,137,"If I was a fake,"],[266,358,"how would I have this?"],[662,708,"That's one of"],[708,866,"the Northwood Pack emeralds."],[904,987,"Only the real Princess"],[987,1116,"is allowed to wear one of those."],[1175,1325,"Is she the real Princess then?"],[1450,1500,"Hello?"],[1529,1616,"When the Wolf Princess"],[1616,1679,"says something,"],[1679,1758,"you obey."],[1825,1987,"That necklace is obviously fake."],[1995,2116,"She probably saw a picture of it"],[2125,2216,"and decided to copy me"],[2216,2312,"because she's obsessed"],[2312,2383,"with being me."],[2475,2679,"If anyone's obsessed, it's you."],[2741,2837,"So, which one of you"],[2837,3025,"is the real Wolf Princess?"],[3166,3329,"It's me, you idiots."],[3341,3395,"Now hurry up"],[3395,3516,"and take her away already."],[3533,3570,"Wait!"],[3687,3875,"I can prove that I'm the real Princess."],[4120,4216,"Only the Northwood heir"],[4216,4320,"can open up the vault."],[4725,4870,"So let's see which one of us can do it,"],[4933,5054,"then she is the real Princess."],[5054,5162,"This is ridiculous."],[5162,5316,"I told you guys to take her away."],[5370,5408,"Why?"],[5475,5537,"Scared,"],[5575,5637,"Princess?"]],"14":[[75,108,"Fine."],[170,241,"Let her go."],[416,570,"Obviously I can open up the vault."],[570,658,"And once I do,"],[658,866,"I am locking your sorry ass inside."],[1145,1341,"After you, Your Highness."],[2404,2483,"Forget the code?"],[2712,2808,"Your Highness?"],[2829,2908,"Be quiet."],[2966,3108,"Let the Princess focus."],[3291,3400,"Go ahead and open the vault"],[3400,3550,"so we can kick this girl out,"],[3550,3629,"Your Highness."],[3925,4129,"You do know the code to the vault,"],[4129,4170,"right?"],[4208,4237,"Yes,"],[4237,4379,"just shut up so I can remember."],[4700,4770,"Need a hint?"],[4820,4912,"Six digits."],[4920,5087,"First number is nine."],[5337,5354,"Ugh."],[5362,5400,"Damn."],[5404,5437,"Sorry."],[5495,5541,"Seven."],[5591,5645,"My bad."],[5741,5850,"Look, if you don't know the code,"],[5850,5950,"you can just say that."],[6025,6116,"So what if I forgot?"],[6125,6245,"I haven't been here in ages."],[6295,6404,"How about you step aside?"],[6612,6720,"I'm so sorry."],[6770,6962,"What the hell is wrong with you?"],[6991,7091,"Hurry and clean this up"],[7091,7208,"for the Wolf Princess."],[7287,7320,"Oh,"],[7400,7470,"Princess."],[7612,7770,"My sincere apologies."],[7804,7875,"It's fine."],[7875,8033,"Just clean it up so I can move along."],[9987,10079,"You wanted your proof?"],[10275,10345,"There's your proof."]],"15":[[241,275,"Mom."],[341,366,"Hi."],[412,495,"You're at work today, right?"],[583,650,"Yeah, I need you to get me"],[650,737,"the code for the vault."],[900,950,"No, no, no."],[950,1050,"Don't ask why."],[1062,1137,"Just do it."],[1712,1833,"I knew you were a fake."],[1858,1920,"Guards!"],[1937,1975,"Hold on."],[2104,2187,"I want her to have a look"],[2187,2270,"inside the vault."],[2320,2425,"Poor little thing doesn't even know"],[2425,2520,"what power feels like."],[2570,2662,"Let's give her a little taste"],[2662,2812,"before we throw her back on the streets"],[2812,2875,"like a stray."],[2908,2954,"Trust me,"],[2995,3104,"when I say that real power"],[3104,3254,"doesn't come from inside a vault."],[3266,3312,"Oh yeah?"],[3341,3425,"And what would you know?"],[3454,3575,"You're not the Wolf Princess."],[3600,3666,"You're nothing."],[4725,4841,"Let go of me."]],"16":[[2466,2541,"See, Lia?"],[2625,2750,"This is where I belong."],[2791,2975,"You and I are from two different worlds."],[3012,3145,"I'm destined for greatness."],[3200,3333,"Well, if you're so great,"],[3400,3529,"how about one last test?"],[3620,3712,"Another test?"],[3733,3870,"She's already opened the vault."],[3870,4058,"That proves she's the Princess."],[4087,4116,"Well,"],[4179,4291,"never hurts to be sure,"],[4337,4375,"right?"]],"17":[[283,412,"How did she know that was there?"],[466,512,"Shut up."],[512,662,"It was just a lucky guess."],[816,912,"Do you know what this is?"],[962,1066,"A stack of books."],[1183,1362,"Looks may be deceiving, Elise."],[1412,1516,"But this is the Wolf Princess'"],[1516,1654,"safety deposit box."],[1695,1833,"Only she knows what's inside."],[1929,2104,"So if you really are the Wolf Princess,"],[2208,2362,"what's inside the box, Elise?"],[2508,2579,"Why would I tell you"],[2579,2666,"what's inside of it?"],[2850,2954,"I wouldn't want to be accused"],[2962,3050,"by your little minions"],[3050,3195,"of having another lucky guess."],[3266,3350,"So how about you tell us"],[3350,3475,"what's in the box first?"],[3483,3545,"Sound fair?"],[3604,3679,"Obviously,"],[3679,3866,"it has all of my favorite jewelry"],[3879,4016,"and some extra cash."],[4045,4075,"I mean,"],[4095,4166,"what else goes inside"],[4166,4291,"a safety deposit box?"],[4391,4433,"Wrong."]],"18":[[16,225,"There's no jewelry or gold"],[250,391,"or cash or anything vain"],[391,487,"like that inside."],[554,645,"Well, what do you say is in there then?"],[645,754,"Your depressing little diary?"],[933,1045,"I'll tell you exactly"],[1058,1170,"what's in this box."],[1204,1366,"It's the paper ring that Derek gave me"],[1366,1516,"almost exactly a year ago."],[1550,1654,"Before he was Alpha."],[1725,1929,"Before he had power or money."],[2062,2170,"I took that ring"],[2170,2266,"and I put it in this box"],[2266,2395,"like it was my greatest treasure."],[2504,2575,"Because it was."],[2604,2741,"Why would anyone put a piece of paper"],[2741,2879,"inside a safety deposit box?"],[3004,3116,"I wouldn't expect someone like you"],[3116,3191,"to understand."],[3258,3308,"After all,"],[3358,3520,"you're just a greedy bag chaser."],[3645,3695,"Oh yeah?"],[3804,3920,"Why don't you just shut up?"],[3966,4120,"I don't need another lecture from you."],[4141,4345,"You're probably full of shit anyway."],[6725,6958,"It's the paper ring just like she said."],[7025,7070,"Oh no,"],[7125,7208,"then that means..."],[7316,7450,"Now who's the fake?"],[8150,8212,"Ouch."]],"19":[[258,354,"Everything should be ready"],[354,445,"for the Solstice Dance"],[445,504,"tomorrow night,"],[537,620,"Alpha Cassian."],[695,745,"Perfect."],[804,875,"Then my job is done."],[954,1045,"You're leaving so soon?"],[1116,1266,"The Princess will be here any second."],[1329,1545,"Perhaps I can introduce you"],[1545,1658,"before the dance tomorrow?"],[1787,1833,"Thanks,"],[1883,2004,"but I'd like to keep my air of mystery"],[2004,2100,"before tomorrow night."],[2133,2308,"You know, I've been told that"],[2316,2420,"Her Highness is looking for a mate."],[2450,2575,"Every other Alpha in the kingdom"],[2575,2700,"will kill for a chance at"],[2737,2808,"earning her hand."],[3262,3379,"Thank you Vice Principal Jones,"],[3395,3487,"but that won't be necessary."],[3562,3633,"I already have a mate."],[4483,4529,"Elise."],[4704,4741,"Honey,"],[4741,4958,"maybe we should go now before-"],[4966,5054,"Let go of me!"]],"20":[[95,275,"Elise, what are you doing?"],[279,366,"This is your fault."],[375,541,"You and that bitch set me up."],[608,654,"Didn't you?"],[741,795,"Didn't you?"],[954,979,"Oh."],[1070,1120,"She's right."],[1120,1337,"I, I admit it."],[1491,1591,"She paid me"],[1591,1725,"to give her the codes to the vault."],[1725,1916,"And she told me to put the paper ring"],[1916,2175,"inside the Princess' safety deposit box."],[2175,2275,"This is ridiculous."],[2283,2350,"That's not true."],[2354,2416,"You're lying!"],[2429,2541,"I knew you were nothing"],[2545,2641,"but a little liar."],[2820,2954,"You're gonna pay for this."],[2954,3141,"Once Beta Marcus hears about this,"],[3141,3254,"you'll be thrown in a cell"],[3254,3500,"for the rest of your sad little life."],[3516,3587,"Trust me."],[3608,3666,"I'm not the one"],[3666,3787,"that's gonna pay for this."],[3808,3862,"Guard!"],[3891,3975,"Get her out of here."],[3975,4104,"No, no, no."],[4104,4141,"Please."],[4162,4191,"Please."],[4191,4283,"You don't know what you're doing."],[4283,4316,"You don't know"],[4316,4416,"who you're messing with."],[4420,4470,"Stop!"],[4495,4570,"No, please."],[4804,4841,"No!"]],"21":[[300,387,"No, you don't know what you're doing!"],[387,412,"You don't know"],[412,525,"who you're messing with!"],[525,562,"Stop!"],[562,600,"No!"],[612,645,"Please!"],[645,737,"What's all that noise?"],[812,862,"Stop!"],[912,962,"Stop it!"],[1037,1075,"No!"],[1112,1162,"Lia!"],[1562,1650,"Let go of me!"],[1650,1700,"Please!"],[1762,1812,"Stop it!"],[2187,2375,"Take your filthy hands off my mate!"],[2687,2725,"You okay?"],[3125,3250,"What the hell is going on here?"],[3325,3362,"Sir."],[3400,3537,"This girl tried to impersonate"],[3537,3625,"the Wolf Princess"],[3637,3787,"and even paid the cleaning lady"],[3787,3962,"to steal the code for the vault."],[3987,4125,"She should be arrested."],[4137,4262,"What on earth are you talking about?"],[4325,4375,"What girl?"],[5025,5087,"Your Highness."],[5137,5275,"My most sincere apologies"],[5275,5400,"for this misunderstanding."],[5475,5562,"Don't just stand there."],[5600,5712,"Get the Princess a seat."],[5787,5975,"Please excuse my foolish employees."],[6025,6087,"I'll make sure"],[6100,6200,"they're severely punished."]],"22":[[45,175,"But, but, but, Sir,"],[175,337,"we, we did what you asked."],[362,500,"We welcomed the Wolf Princess"],[500,612,"like you told us to."],[825,912,"She's not the Princess."],[925,1000,"She's a fraud."],[1025,1100,"Take her away!"],[1237,1300,"Don't touch me."],[1312,1425,"I'm Alpha Derek's mate."],[1425,1600,"I am the Luna of the Stormvale Pack."],[1625,1750,"I don't care what pack you're from."],[1775,1912,"And you insulted our Princess."],[1937,1987,"Anyone from"],[1987,2125,"the Alpha Derek Stormvale Pack"],[2125,2187,"should be banned"],[2187,2287,"from the Northwood estate."],[2287,2412,"You can't do this to me."],[2425,2483,"I'll have all your"],[2483,2600,"fucking heads for this."],[2600,2675,"Please, sir,"],[2762,2850,"have mercy on her."],[2887,2962,"My daughter just made"],[2962,3087,"a small mistake."],[3525,3700,"Did you say Elise is your daughter?"]],"23":[[8,158,"So Elise isn't the daughter"],[158,320,"of a rich and powerful Alpha."],[333,458,"So you let an imposter here,"],[508,620,"because she was your daughter?"],[795,870,"And you two."],[908,1008,"How stupid could you be"],[1008,1083,"to believe her?"],[1133,1245,"Please, sir,"],[1245,1433,"it was an honest mistake."],[1445,1583,"It will not happen again."],[1595,1733,"You're damn right it won't happen again!"],[1770,1895,"And I'll make sure you never work"],[1895,1983,"in this kingdom again."],[2008,2045,"What?"],[2045,2095,"Guard."],[2116,2150,"No."],[2170,2245,"Take them away!"],[2320,2375,"Get off me."],[2395,2462,"Get off me!"],[2500,2562,"Move! - I'll have your"],[2562,2658,"fucking head for this."],[3258,3308,"You okay?"],[3383,3420,"Yeah,"],[3520,3583,"I am now."],[3658,3795,"How did you get here so fast?"],[3816,3954,"And what's up with the tie?"],[4058,4108,"I had some business"],[4108,4170,"to attend to."],[4283,4358,"What's wrong with the tie?"],[4370,4470,"Oh nothing, nothing."],[4483,4533,"Just,"],[4595,4720,"I didn't know you cleaned up so good."],[4795,4845,"Oh really?"],[4995,5108,"Maybe this changes your mind?"],[5233,5283,"Maybe."]],"24":[[362,425,"Your Highness,"],[462,612,"I've taken care of everything."],[650,800,"Is there anything else I can do for you"],[800,962,"to make up for this grave error?"],[975,1125,"Oh, actually I was here"],[1125,1270,"to pick up the emerald"],[1270,1362,"jewels for my..."],[1475,1562,"my sister."],[1700,1775,"Your sister?"],[1812,1937,"Yes, my sister."],[1987,2100,"The Wolf Princess."],[2162,2337,"Goddess knows she runs me around"],[2337,2412,"like a horse,"],[2412,2550,"you know, all these errands."],[2587,2650,"Right,"],[2725,2787,"your sister."],[3087,3137,"Tomorrow."],[3175,3400,"I promise I'll tell him tomorrow."],[3437,3462,"So,"],[3600,3700,"do I finally get to meet"],[3700,3862,"this mysterious Wolf Princess"],[3862,3962,"at tomorrow's dance?"],[3962,4050,"Oh, I'm sure"],[4050,4187,"she'll be making an appearance."],[4625,4725,"Will he still want me"],[4787,4962,"after he knows who I really am?"]],"25":[[508,570,"This place might be"],[570,695,"a little out of your budget, but..."],[808,970,"Don't worry, I've been here before."],[1270,1470,"Lia, this place is invite only."],[1508,1608,"They don't let just anyone in."],[1783,1945,"Then I'm surprised they let you in at all."],[2570,2633,"I'm sorry,"],[2670,2770,"are you two lost?"],[2795,2933,"If you're looking for the thrift store,"],[2958,3058,"it's on the next block."],[3108,3145,"No."],[3258,3370,"We're in the right place."],[3433,3583,"The owner is an old time friend"],[3583,3695,"of the Royal Family."],[3795,3920,"The Royal Family?"],[3995,4195,"Are you saying you're"],[4270,4383,"the Wolf Princess?"],[4408,4470,"My God."],[4570,4645,"That can't be true."],[4720,4845,"The Princess is already here."],[4933,5020,"Well, how can that be?"],[5070,5170,"I just got here."],[5695,5733,"Hey!"],[5733,5845,"I was looking at that."],[5858,5970,"Royalty get first dibs."],[5995,6170,"Don't you know anything, peasant?"],[6345,6408,"I'm sorry,"],[6458,6558,"do I know you?"],[6583,6695,"Everybody knows me."],[6695,6870,"I am the Wolf Princess, after all."]],"26":[[20,95,"Your Highness,"],[108,320,"this girl, she tried to impersonate you"],[320,445,"to get into the store."],[633,708,"Moon Goddess,"],[795,883,"how many Wolf Princesses"],[883,920,"are there?"],[1158,1320,"It's like no one knows"],[1320,1483,"how to show respect these days."],[1595,1745,"But as for you,"],[1745,2008,"I think I can make an exception,"],[2020,2095,"handsome."],[2195,2308,"How very generous of you,"],[2345,2420,"Your Highness."],[2520,2833,"So, he believes her and not me."],[2870,2920,"You know,"],[2970,3145,"people are always telling me"],[3145,3295,"that I should settle down"],[3295,3458,"and find myself a prince."],[3458,3933,"And you look like the perfect..."],[4233,4295,"candidate."],[4620,4870,"Don't touch my mate."]],"27":[[183,383,"Don't touch my mate."],[845,983,"I didn't know you were so possessive."],[1120,1145,"Oh."],[1195,1245,"I mean,"],[1283,1470,"wouldn't any girl be upset,"],[1470,1583,"if someone was touching her mate?"],[1633,1658,"Right?"],[1708,1958,"How dare you touch me."],[2045,2270,"I can have your hand cut off for that."],[2445,2495,"Come on, Lia."],[2695,2783,"Let's find someplace else."],[3020,3058,"Hey!"],[3133,3345,"I am not done talking here."],[3445,3570,"When the Princess speaks,"],[3608,3670,"you listen."],[3770,3870,"Yeah, it's kind of hard to do that"],[3883,3945,"when all you've been doing"],[3945,4070,"is yapping our ears off."],[4108,4345,"I am the real Wolf Princess!"],[4383,4487,"You're just a dumb bitch."],[4504,4583,"A nobody!"],[4620,5095,"And it looks like this Mr. Tall Gorgeous"],[5208,5370,"just fished you out of the trash."],[5470,5508,"You know,"],[5608,5658,"now that I've gotten"],[5658,5745,"a better look at you,"],[5833,5908,"you look familiar."],[6008,6120,"I swear I've seen you before."],[6195,6333,"Of course you've seen me."],[6358,6520,"I am the Wolf Princess."],[6583,6608,"Well,"],[6608,6758,"if you really are the Wolf Princess,"],[6845,6920,"prove it."]],"28":[[66,279,"I, I, I don't have to prove"],[279,391,"anything to you."],[429,466,"Oh,"],[529,604,"what's the matter?"],[691,754,"You're not afraid"],[754,916,"of a little nobody like me,"],[941,991,"are you?"],[1104,1329,"Obviously I can prove it."],[1329,1504,"I just, I just shouldn't have to."],[1616,1766,"But I guess a peasant like you"],[1766,1904,"needs to be taught a lesson."],[2104,2166,"This here"],[2216,2341,"is a Northwood heirloom,"],[2341,2479,"straight from the pack vault."],[2516,2554,"Now,"],[2566,2641,"this emerald"],[2641,2804,"is hundreds of years old"],[2841,2954,"and can only be worn"],[2966,3091,"by the true heir to the throne,"],[3154,3216,"which is, of course,"],[3304,3329,"me."],[3416,3466,"See."],[3491,3679,"She's wearing the Princess' Emerald."],[3729,3891,"That proves she's the real deal,"],[3904,4004,"and you're the fake."],[4241,4404,"Is there a joke?"],[4516,4566,"Yeah."],[4679,4829,"Only the joke here is you."],[4916,5066,"I finally figured out who you are."],[5104,5204,"You're that distant cousin"],[5204,5354,"from the eastern territories,"],[5391,5504,"the one whose Alpha father"],[5504,5591,"disinherited her,"],[5604,5766,"because she preferred partying"],[5791,5929,"over running her own pack."],[6029,6104,"What was her name?"],[6329,6391,"Lauren."],[6491,6666,"I, I don't know"],[6666,6829,"what you're talking about."],[6891,7041,"I am Princess Eliana,"],[7104,7129,"you know,"],[7141,7354,"daughter of the Alpha Lawrence-"],[7354,7579,"I can accept you impersonating me."],[7579,7604,"Hell,"],[7629,7804,"I could even take you insulting me."],[7879,8154,"But never insult my father's memory."]],"29":[[154,279,"Are you insane?"],[304,454,"That cost more than your life!"],[462,666,"Call the Northwood Pack now!"],[879,1008,"You just cost yourself"],[1008,1104,"a one-way ticket"],[1104,1229,"out of the pack forever."],[1291,1441,"When the Beta Marcus gets here,"],[1516,1654,"you're gonna be banished"],[1666,1866,"for destroying that jewelry forever."],[1929,2079,"Banished for destroying"],[2079,2191,"costume jewelry?"],[2279,2316,"Okay,"],[2316,2629,"so maybe it's not the real emerald,"],[2629,2854,"but, but it doesn't matter anyway,"],[2854,2891,"you know?"],[2904,3054,"I, I, I don't want to wear"],[3054,3266,"my expensive jewelry in public."],[3304,3466,"Well, in that case..."],[3679,3816,"does this look real enough to you?"],[4079,4229,"How did you get that?"],[4266,4341,"You see, Lauren,"],[4354,4516,"if you really were the Wolf Princess,"],[4541,4604,"you would've known"],[4604,4704,"that the family jewels"],[4704,4754,"is kept inside"],[4754,4904,"the Lunar Academy vault."],[4941,5054,"And the last I heard,"],[5104,5241,"you got kicked out of school"],[5266,5416,"for destroying school property."],[5479,5666,"They wouldn't let you within 100 feet"],[5679,5816,"of my family's jewels."],[5941,6341,"You stupid fucking bitch!"]],"30":[[20,433,"You stupid fucking bitch!"],[633,783,"Lay your hand on my mate,"],[833,920,"and you'll lose it."],[1608,1670,"Are you okay?"],[1745,1770,"Yeah."],[1845,1870,"You know,"],[1870,1983,"you didn't have to do that, though."],[2058,2158,"Whether you're the Wolf Princess"],[2158,2195,"or not,"],[2245,2320,"you're still my mate."],[2408,2520,"It's my job to take care of you."],[2633,2745,"He really doesn't care"],[2745,2845,"if I'm the Princess."],[2883,3158,"He just wants me for me."],[3233,3258,"Come on,"],[3345,3383,"let's go."],[3470,3583,"Before Beta Marcus shows up"],[3595,3670,"and you really get into trouble."],[4383,4595,"What the hell is going on in here?"],[4633,4720,"Beta Marcus."],[4733,4808,"This girl,"],[4833,4945,"she was impersonating"],[4945,5083,"the Wolf Princess."],[5133,5258,"She even insulted her."],[5320,5533,"Oh, it's you, Lauren."],[5595,5745,"Still causing trouble for the Princess?"],[5783,5870,"Beta Marcus."],[5870,6120,"It's, it's not what it looks like,"],[6141,6220,"I swear."],[6270,6433,"But she was the one"],[6445,6670,"that impersonated the Wolf Princess."],[6733,6770,"Who?"],[6820,6858,"Show me."],[7120,7208,"Whoever you are,"],[7208,7358,"you better have a good explanation"],[7358,7420,"for this."],[7895,8108,"You were saying, Uncle Marcus?"],[8233,8308,"Princess?"]],"31":[[62,125,"Princess?"],[212,337,"What are you doing here?"],[412,487,"I thought you were going"],[500,587,"to meet Alpha Derek."],[662,787,"Uh, um..."],[825,875,"Wait."],[987,1112,"The Beta of the Northwood Pack"],[1125,1175,"knows you?"],[1262,1425,"Well, of course I know her."],[1500,1625,"I practically raised her."],[1687,1712,"She is"],[1712,1850,"the Wolf Prince - - I'm adopted"],[1850,2075,"by the North Pack family."],[2137,2250,"When my parents died,"],[2312,2362,"they took me in"],[2362,2425,"and raised me"],[2425,2525,"alongside the Princess."],[2612,2712,"That's why he calls me"],[2712,2800,"the Princess too."],[2925,3075,"What on earth are you talking about,"],[3087,3137,"child?"],[3187,3362,"Did you hit your head or something?"],[3512,3637,"You are the Wolf Prince -"],[3637,3775,"Princess' sister."],[3987,4037,"Sister?"],[4100,4300,"Oh, I mean, adoptive sisters, but"],[4350,4437,"family's family."],[4537,4575,"Oh."],[4662,4800,"Then why didn't you tell me?"],[4900,4937,"Oh,"],[5000,5112,"you know Princesses."],[5162,5287,"Spoiled brats, am I right?"],[5512,5562,"You know what?"],[5762,5912,"I'll handle whatever this later."]],"32":[[133,208,"As for you,"],[295,558,"I had a long chat with your father"],[558,620,"over the phone"],[620,658,"the last time"],[658,770,"you pulled a stunt like this,"],[770,808,"Lauren."],[895,983,"He and I already"],[983,1108,"agreed on a punishment"],[1145,1245,"for disrespecting"],[1245,1433,"Her Highness' name again."],[1695,1820,"Six months of house arrest,"],[1883,2008,"and you're never to set foot"],[2033,2220,"in the Northwood Pack ever again."],[2270,2308,"What?"],[2345,2570,"You can't do that to me!"],[2758,2833,"Take her away."],[2895,3020,"No!"],[3058,3183,"No! No!"],[3233,3345,"Fucking vile guards!"],[3370,3520,"No!"],[3558,3708,"I don't understand."],[3783,4045,"I expect you to give a full apology"],[4045,4258,"to the Wolf Princess'..."],[4508,4620,"sister."],[5258,5470,"I, I'm so sorry,"],[5520,5595,"Your Highness."],[5633,5820,"If I'd known you were so close"],[5820,5883,"to the Princess,"],[5883,5995,"I would have never,"],[6070,6233,"ever spoken to you like that."],[6283,6383,"I don't think you should be speaking"],[6383,6520,"to anyone like that,"],[6583,6820,"regardless if they're a Princess or not."],[6845,6933,"You should speak to everyone"],[6933,7070,"with kindness and respect."],[7158,7208,"Don't you think?"],[7358,7458,"I'm so sorry."],[8345,8408,"I'm sorry."],[8495,8570,"Have we met?"],[8733,8933,"I feel like I have seen you before."]],"33":[[95,158,"Beta Marcus."],[245,370,"You've probably seen me before."],[383,483,"I'm from the Silverwind Pack."],[608,645,"I'm-"],[670,758,"His name is Caz."],[845,920,"And,"],[1070,1170,"he's my mate."],[1270,1370,"Your mate?"],[1495,1633,"What happened to Derek?"],[1695,1908,"It's, it's a long story, but,"],[2033,2145,"Derek broke our bond"],[2145,2358,"and bonded with someone else."],[2383,2508,"And so you bonded"],[2508,2583,"with the first stranger"],[2583,2683,"you met on the street?"],[2758,2795,"Lia,"],[2895,3033,"I have taught you better than this."],[3108,3308,"Someone like you needs to be"],[3308,3470,"with someone of your status."],[3558,3733,"Someone worthy."],[3745,3845,"But he is worthy."],[3945,4058,"He's protected me."],[4120,4220,"He's looked after me."],[4233,4270,"God."],[4320,4483,"I don't need to be with some Alpha."],[4558,4620,"I just need someone"],[4620,4745,"who's gonna stay by my side."],[4833,4920,"She really doesn't care"],[4920,5020,"if I'm the Alpha or not."],[5083,5120,"So,"],[5195,5283,"Uncle Marcus?"],[5533,5633,"Do we have your blessing?"]],"34":[[25,137,"Do we have your blessing?"],[325,425,"Moon Goddess,"],[562,637,"you're going to send me"],[637,750,"to an early grave."],[900,950,"Fine!"],[1100,1225,"Do whatever you want,"],[1250,1312,"but make sure"],[1312,1450,"that you and your new mate"],[1462,1687,"are presentable at the Solstice Dance."],[1750,1850,"The Silverwind Alpha"],[1887,2075,"will make his formal introduction there,"],[2100,2412,"and we want to be on his good side."],[2500,2612,"Don't worry, Beta Marcus."],[2662,2750,"You can count on us."],[2837,2900,"We won't disappoint"],[2900,3000,"the Silverwind Alpha."],[3187,3250,"You have my word."],[3425,3500,"Well, at least this one’s"],[3500,3612,"better than Derek."],[4162,4212,"No!"],[4262,4387,"Get the fuck off me!"],[4412,4475,"Get off me!"],[5250,5275,"Yeah?"],[5362,5487,"What the hell, Elise?"],[5512,5687,"You told me that the real Wolf Princess"],[5687,5800,"was locked in her house."],[5962,6012,"Who's this bitch"],[6012,6125,"who says that she's her sister?"],[6287,6375,"This girl shows up"],[6400,6512,"and decides to destroy"],[6512,6575,"my necklace."],[6587,6787,"It's like she knew it was a replica."],[6875,7012,"Yeah, and she had one too."],[7125,7262,"You know, I think it was the real thing."],[7300,7412,"That's not possible."],[7412,7462,"There's no way"],[7462,7512,"she could have gotten"],[7512,7612,"the real Emerald"],[7612,7737,"from the Lunar Academy vault."],[7812,7900,"So what are you gonna do?"],[8025,8137,"I'll figure it out."],[8375,8412,"Hello?"],[8575,8637,"Hello?"],[8975,9012,"Marty?"],[9050,9237,"Yeah, I need to borrow the sting."],[9450,9487,"Take me to"],[9487,9575,"the Lunar Academy vault."],[9600,9637,"Now!"]],"35":[[1437,1500,"What do you think?"],[1637,1725,"Good enough for the dance?"],[1925,1975,"Definitely."],[2150,2212,"Don't know if the shoes"],[2225,2300,"work with the dress, though."],[2437,2512,"Obviously I'll wear"],[2512,2600,"the right ones on the day."],[3362,3412,"Need some help?"],[3512,3612,"Yeah, I think it's stuck."],[4675,4775,"It's just missing one thing."]],"36":[[675,712,"Sorry,"],[800,837,"I..."],[950,1050,"I don't know what came over me."],[1325,1437,"I'll wait for you outside."],[1766,1937,"Caz doesn't know I'm a princess,"],[1937,2141,"but he's a nice guy."],[2175,2358,"Maybe I can give him a chance."],[2383,2504,"He'd be lucky to have me."],[2650,2762,"What the hell is wrong with me?"],[2787,2887,"I need to control myself."],[2887,3012,"I can't scare my own mate off."],[3300,3437,"She's not a spoiled brat,"],[3487,3629,"but would she change if she knew"],[3629,3725,"who I really was?"],[3762,3904,"I don't want someone to love me"],[3904,4062,"just because I'm the Wolf Princess."],[4091,4250,"Should I tell him who I really am?"],[4362,4425,"Hey Caz,"],[4550,4662,"let me just finish getting ready"],[4662,4750,"and then we can go."],[4750,4800,"I'll pay."],[4875,4925,"You kidding?"],[4962,5025,"It's already sorted."],[5050,5125,"Wait, what?"],[5125,5150,"No!"],[5425,5525,"Caz, what the hell?"],[5562,5712,"This dress cost like ten grand."],[5750,5850,"Ah, it's pocket change."],[5900,5962,"Besides,"],[5987,6062,"what kind of guy would I be,"],[6062,6187,"if I didn't pay for my mate's things?"],[6275,6312,"I mean,"],[6325,6425,"are you sure you still want me"],[6425,6612,"to be your date to the Solstice Dance?"],[6675,6787,"I'm genuinely considering"],[6787,6875,"if I want to go or not."],[6912,6950,"Lia,"],[7025,7175,"there's nobody else I want by my side."],[7312,7475,"Even if I'm not the Wolf Princess?"],[7550,7762,"Even if I'm just Lia?"],[7850,8037,"I happen to like just Lia."]],"37":[[70,258,"I happen to like just Lia."],[470,508,"Oh."],[595,670,"That's my uncle."],[720,783,"I should go."],[908,1020,"I guess I'll see you at the dance then."],[1183,1283,"Are you sure you won't fall in love"],[1283,1383,"with the real Princess"],[1383,1445,"when you meet her?"],[1520,1608,"Her Royal Highness can make"],[1608,1783,"some other poor Alpha her prince."],[3295,3370,"What do you want, Roman?"],[3408,3545,"Where the fuck have you been?"],[3595,3708,"Did you forget the Solstice Dance"],[3708,3808,"is in three days?"],[3845,3920,"I haven't forgotten."],[3970,4033,"I've just been"],[4095,4133,"busy."],[4183,4308,"Busy, huh?"],[4370,4495,"Busy distracting yourself"],[4495,4620,"with your new date to the dance?"],[4633,4720,"Are you having me followed,"],[4720,4770,"little brother?"],[4770,4933,"I found your phone records."],[4970,5091,"A contract date?"],[5112,5270,"Caz, seriously?"],[5370,5520,"Claudia's going to be furious"],[5520,5595,"when she finds out"],[5595,5745,"that you blew her off."],[5783,5945,"Claudia isn't my mate."],[5983,6045,"No matter how much"],[6045,6158,"she wishes she was."]],"38":[[20,108,"The only reason"],[108,283,"that Claudia isn't your mate"],[320,445,"is because the Wolf Princess"],[445,570,"was supposed to take her place."],[608,808,"But you decided to run away"],[808,920,"from your own duties."],[958,1033,"I don't need to be mated"],[1033,1195,"into some spoiled Princess"],[1195,1283,"to run my pack."],[1370,1520,"If Claudia tells Grandmother"],[1533,1633,"what you've done-"],[1645,1783,"Grandmother isn't the boss"],[1783,1845,"of me anymore."],[1870,2045,"Even if she is Headmistress."],[2108,2195,"I'm Alpha now."],[2258,2383,"And in case you forgot, Roman,"],[2395,2458,"you're the Beta."],[2495,2570,"You answer to me."],[2620,2820,"Ugh, don't you get it?"],[2858,3020,"Claudia's father controls"],[3033,3233,"almost the entire eastern territory!"],[3283,3345,"The only person"],[3345,3495,"more powerful than him"],[3508,3645,"is the Wolf Princess herself."],[3720,3808,"Offending Claudia"],[3808,3920,"could start a pack war."],[3958,4270,"Whoever your little nobody date is,"],[4345,4558,"is she really worth that?"],[4695,4745,"She is."]],"39":[[308,366,"Good evening."],[575,637,"Just make sure"],[637,737,"you don't forget the gifts,"],[737,829,"Uncle Marcus."],[837,954,"They're for Caz and his family."],[1033,1075,"I'm meeting them"],[1075,1200,"at the Solstice Dance tonight."],[1220,1329,"Oh, wait, one second."],[1545,1620,"Caz is calling me."],[1620,1687,"Just give me a moment."],[1945,2000,"Caz."],[2025,2108,"Are you ready for tonight?"],[2158,2195,"Ready?"],[2250,2358,"I'm almost at the front steps,"],[2358,2466,"and you're not even here."],[2508,2641,"I had something important to do first."],[2704,2812,"Okay, well, it's too cold"],[2812,2904,"to wait for you out here."],[2958,3033,"I'll see you inside."],[3066,3187,"But you don't even have an invitation."],[3295,3358,"I don't need one."],[3391,3437,"Trust me."],[3566,3683,"Um, and when you get here,"],[3683,3750,"just let them know"],[3750,3833,"that you're my plus-one."],[4208,4308,"You didn't tell your new mate"],[4308,4429,"that we're the ones paying for"],[4437,4575,"the entire Solstice Dance?"],[4575,4625,"Doesn't even know"],[4625,4704,"I'm the Alpha yet."],[4775,4925,"Great way to start a relationship,"],[4925,4958,"brother."],[5033,5087,"Tonight."],[5212,5308,"I swear I'll tell Lia"],[5308,5387,"the truth tonight."],[5754,5866,"Invitation, please."],[5891,5962,"I don't have one."],[5979,6070,"I was told I didn't need one."],[6100,6245,"Who the hell do you think you are,"],[6266,6333,"little lady?"],[6333,6479,"This event was specially organized"],[6479,6604,"by the Silverwind Pack."],[6612,6683,"You're not getting in here"],[6683,6775,"without an invitation."],[6808,6887,"Now get out of here."]],"40":[[16,179,"I mean, I should be on the guest list."],[195,287,"Eliana Northwood."],[383,500,"The Wolf Princess?"],[570,604,"Look,"],[604,783,"you can just contact my uncle Marcus."],[783,870,"He can clear this up."],[908,937,"Look,"],[950,1066,"I see you've done your research"],[1066,1179,"on the royal family."],[1195,1308,"You're only fooling yourself."],[1308,1391,"Now get lost."],[1479,1512,"No."],[1562,1704,"Ah, Alpha Derek."],[1770,1845,"We've been expecting you."],[1895,1925,"Lia,"],[1925,2070,"how the hell did you get invited"],[2070,2175,"to the Solstice Dance?"],[2208,2304,"I'm guessing she had to blow"],[2304,2412,"some old fart teacher"],[2412,2516,"to get in as a plus-one."],[2804,2895,"Don't you have a vault"],[2895,3012,"to get kicked out of?"],[3070,3241,"Or did you not tell your precious mate"],[3250,3291,"about getting"],[3291,3408,"his whole pack banned?"],[3445,3475,"What?"],[3512,3550,"She doesn't know"],[3550,3645,"what she's talking about, sweetie."],[3687,3754,"She's just jealous"],[3754,3879,"because she can't get into this party."],[4062,4158,"Here's my invite."],[4166,4262,"Alpha Derek, no need."],[4316,4350,"See?"],[4350,4420,"Come straight through."],[4470,4625,"You're one of Alpha Cassian's"],[4625,4741,"very special guests."],[4850,4987,"The only thing that made you special"],[5012,5166,"was everything I did for you."],[5191,5329,"You wouldn't even be near this party"],[5329,5425,"if it wasn't for my help."],[5450,5641,"You or your clout-chasing poser"],[5641,5700,"of a mate."],[5704,5820,"All right, that's enough."],[5837,5891,"Okay, let's go."],[5908,5983,"Get her out of here."],[5983,6050,"Let go of me."],[6050,6133,"I'm going in."],[6204,6316,"I wouldn't do that if I were you."]],"41":[[79,220,"I wouldn't do that if I were you."],[558,608,"Are you okay?"],[679,758,"Do they just let anyone"],[758,829,"into these parties?"],[850,1020,"You're really still with this guy, Lia?"],[1037,1125,"Did breaking our bond"],[1125,1266,"make you this fucking desperate?"],[1270,1437,"Who the hell are you two guys?"],[1441,1541,"When Alpha Cassian"],[1541,1625,"hears about this,"],[1637,1700,"you two are gonna be"],[1700,1800,"thrown into a cell."],[1812,1866,"Oh, really?"],[1937,2050,"I'm sure he'll be thrilled."],[2133,2204,"Alpha Derek,"],[2275,2337,"please come inside"],[2337,2487,"while I deal with these outsiders."],[2904,3012,"The hell is going on here?"],[3154,3216,"Beta Roman."],[3250,3366,"I was just trying to prevent"],[3366,3454,"these two imposters"],[3454,3562,"from entering the dance."],[3687,3845,"Inform Alpha Cassian"],[3845,3954,"so that he can deal with them"],[3954,4025,"appropriately."],[4037,4150,"Imposters?"],[4166,4316,"Are you a goddamn idiot?"],[4370,4500,"That's Alpha Cassian."],[4595,4633,"What?"]],"42":[[0,79,"Alpha Cassian,"],[95,345,"please accept my sincere apologies."],[362,504,"That's enough, kick rocks."],[554,662,"I'll deal with your bullshit later."],[933,966,"Wait."],[1045,1187,"So you really are the Alpha?"],[1208,1350,"Oh, you believe me now, huh?"],[1654,1937,"We do have a dance to host, Caz."],[1991,2025,"Lia,"],[2104,2245,"this is the Silverwind Pack Beta,"],[2291,2416,"and my younger brother, Roman."],[2566,2595,"Come on,"],[2670,2775,"we have a lot of important people"],[2775,2841,"waiting on us."],[4562,4612,"Elise."],[4675,4770,"Elise, where are you going?"],[4833,4916,"Roman."],[4966,5112,"It's been so long."]],"43":[[133,245,"Oh, don't be like that, Roman."],[287,370,"I thought we had a good time"],[370,420,"last summer."],[558,704,"You'd call anything a good time"],[704,795,"if it would get you closer"],[804,950,"to a guy's bank account, Elise."],[954,1100,"Oh, you wound me, Roman."],[1175,1295,"Speaking of bank accounts,"],[1350,1433,"where is your Alpha?"],[1491,1525,"Why?"],[1600,1758,"Already looking to turn up"],[1758,1816,"from Derek?"],[1820,1845,"Oh,"],[1879,2012,"Derek has his uses,"],[2066,2191,"but the Silverwind Pack Alpha"],[2191,2287,"is the true prize."],[2675,2758,"Derek, honey,"],[2791,2937,"this is Beta Roman."],[2954,3054,"Told you I had connections"],[3054,3158,"with the Silverwind Pack."],[3287,3400,"So when do we get to finally meet"],[3404,3479,"Alpha Cassian?"],[3583,3620,"You'll see."],[4433,4654,"Thank you all for joining us tonight"],[4654,4812,"at the Solstice Dance,"],[4820,5012,"sponsored by the Silverwind Pack"],[5012,5200,"at our historic Lunar Academy."],[5229,5300,"Now honey,"],[5316,5441,"it's important to make"],[5441,5545,"a good first impression"],[5545,5666,"on the Silverwind Alpha."],[5787,5833,"Now,"],[5937,6133,"allow me to formally"],[6133,6291,"introduce you all to"],[6295,6604,"Alpha Cassian of the Silverwind Pack."],[8050,8091,"What?"],[8150,8250,"He's the Alpha?"],[8266,8395,"God, no fucking way."],[8441,8562,"That's Alpha Cassian?"],[8595,8691,"He's just a senior."],[8741,8870,"And who's that girl he's with?"],[8900,9008,"She can't be his mate, right?"],[9150,9220,"What was that about not"],[9220,9416,"letting just anybody into this dance?"],[9762,9908,"Alpha Cassian."],[9958,10029,"So nice of you"],[10029,10170,"to show your cowardly face."]],"44":[[16,79,"What do you want, Owen?"],[141,275,"So you break off your betrothal"],[287,379,"to my sister."],[425,633,"Go AWOL for what, a year?"],[683,854,"And you show up to the Solstice Dance"],[895,1025,"with this little whore on your arm?"],[1208,1295,"Hey, Owen,"],[1333,1366,"come on,"],[1366,1487,"let's not cause a scene here."],[1579,1712,"You disrespected my family."],[1745,1808,"My pack."],[1887,1983,"I don't owe you shit."],[2116,2329,"So you're Owen Ashwood, right?"],[2400,2504,"The Alpha's eldest son."],[2550,2625,"And who are you?"],[2691,2720,"Hm?"],[2779,2870,"You don't belong here."],[2891,2975,"You're a nobody."],[3029,3120,"You probably fucked your way"],[3120,3166,"to get here."],[3208,3270,"Better watch the way"],[3270,3366,"you speak to my mate,"],[3383,3412,"Owen."],[3425,3520,"It's okay, Caz."],[3558,3641,"I've got this."],[3704,3937,"So you're some big shot Alpha?"],[3962,4116,"Talk a big game about respect."],[4116,4162,"However,"],[4162,4291,"I don't think you've paid your respects"],[4291,4387,"to the Wolf Princess"],[4387,4504,"or the royal family"],[4504,4591,"since the passing"],[4591,4704,"of Alpha King Lawrence."],[4704,4812,"The Wolf Princess?"],[4816,4970,"You mean that spoiled little brat"],[4983,5112,"hiding away in her castle,"],[5120,5383,"expecting us to run her kingdom for her"],[5395,5516,"and bow at her feet?"],[5687,5866,"The Wolf Princess is coming tonight."],[5866,6025,"We need you to pipe the fuck down"],[6025,6179,"before you get all of our heads"],[6179,6237,"chopped off."],[6275,6312,"No, no,"],[6312,6412,"I'm sure Her Highness"],[6412,6612,"would get such a kick out of this guy."],[6641,6729,"You know, I heard that she’s"],[6729,6829,"probably coming of age"],[6829,6966,"to be able to take on a mate now."],[6995,7100,"She's probably got a whole list"],[7100,7237,"of all the eligible bachelors"],[7237,7312,"in the whole kingdom."],[7320,7400,"What a shame your name"],[7400,7525,"wouldn't be on that list."],[7537,7616,"I don't think the Princess"],[7616,7770,"is into entitled boys"],[7770,7970,"who use their dad's name and title"],[7987,8104,"to get what they want."],[8104,8245,"How fucking dare you."],[8283,8462,"I'll show you some goddamn respect."],[8891,9037,"You lay one finger on my mate,"],[9037,9162,"I'll break every fucking one."]],"45":[[29,137,"So the rumors are true."],[158,250,"You did bond yourself"],[250,329,"to a nobody."],[350,495,"A reject nobody,"],[545,616,"from what I heard."],[658,820,"Maybe Claudia did dodge a bullet."],[904,1012,"Mr. Ashwood,"],[1012,1158,"it's so nice to finally meet"],[1158,1266,"your acquaintance."],[1337,1395,"Elise,"],[1491,1554,"what are you doing?"],[1558,1616,"You're with me!"],[1654,1816,"Aren't you Alpha Derek's mate?"],[1825,1979,"He just lost his only shot at power"],[1979,2095,"with the Silverwind Pack."],[2150,2191,"He'll be back"],[2191,2295,"to being a nobody soon."],[2391,2508,"You little fucking traitor."],[2516,2658,"I hear your pack is the largest"],[2658,2808,"in the eastern territories."],[2816,2941,"I wonder what else is large."],[3054,3120,"Well, well,"],[3145,3258,"looks like all the dogs"],[3258,3354,"are after each other."],[3366,3520,"Are you calling me a dog, bitch?"],[3533,3637,"Woof, woof."],[3791,3900,"Are you the only one around here"],[3900,4112,"with some goddamn sense, Roman?"],[4133,4204,"Your Alpha,"],[4237,4320,"your brother,"],[4333,4437,"went back on our deal"],[4437,4587,"and took an outsider"],[4587,4662,"as his mate."],[4679,4808,"Is he just gonna do what he wants,"],[4908,5012,"or do what's right?"],[5033,5095,"Of course,"],[5141,5179,"Owen,"],[5187,5270,"the deal with our packs"],[5270,5412,"is really important to us."],[5429,5658,"We would never want to disrespect"],[5675,5820,"your father or your sister."],[5825,5908,"You see, folks?"],[5962,6170,"Even the great Alpha Cassian,"],[6187,6283,"the next best thing"],[6304,6495,"from the Alpha King himself,"],[6508,6679,"is still bound to the same laws"],[6700,6937,"of the land like the rest of us."],[6950,7066,"You think getting with an Alpha"],[7116,7145,"would have made"],[7145,7300,"your little rags-to-riches"],[7300,7450,"fairy tale dreams come true?"],[7454,7570,"Those jewels can't hide"],[7570,7691,"the smell of poor in her,"],[7729,7791,"trust me."],[7808,7887,"How about this?"],[7912,8141,"On behalf of my father and my pack,"],[8162,8387,"I'll forgive this little mistake."],[8437,8637,"Only if you kneel"],[8720,8845,"and beg for forgiveness."]],"46":[[12,116,"Beg for forgiveness."],[175,225,"We don't have to listen"],[225,345,"to a thing he says, Lia."],[387,475,"Oh, of course,"],[475,570,"I wouldn't expect"],[570,858,"the great Alpha Cassian to kneel."],[941,1008,"Just her."],[1175,1304,"The little stray you put in."],[1341,1416,"She's my mate."],[1466,1541,"You disrespect her,"],[1541,1629,"you disrespect me."],[1750,1862,"I'd like to see you make her kneel"],[1862,1933,"while I'm here."],[2012,2216,"Caz, be reasonable."],[2308,2366,"You wanna keep the deal"],[2366,2525,"between our packs so bad, Roman?"],[2562,2591,"You marry"],[2591,2741,"Claudia's crazy ass yourself."],[2766,2854,"I'm trying to do"],[2854,2983,"what's best for our future."],[3008,3079,"I'm running a little thin"],[3091,3200,"on patience here,"],[3225,3275,"Roman."],[3341,3387,"Enough!"],[3508,3608,"I'm the Alpha here,"],[3645,3720,"and you answer to me."],[3787,3845,"Not him,"],[3887,3945,"not you,"],[3995,4075,"and not my brother."],[4125,4220,"You say one more word"],[4220,4320,"against my mate,"],[4404,4487,"and the deal's off."],[4545,4670,"You're really gonna go to war"],[4704,4804,"for this, Caz?"],[4858,4916,"For her?"],[5150,5262,"I'd do anything for her."],[5383,5450,"He doesn't even know"],[5450,5583,"I'm the Wolf Princess yet,"],[5633,5791,"and he's still doing this for me."],[5970,6041,"All right, then."],[6175,6250,"Let's go to war."],[6550,6695,"That's enough, boys."],[8066,8145,"Claudia?"]],"47":[[75,183,"That's Claudia Ashwood."],[241,412,"Wow, she's gorgeous."],[458,495,"Wait,"],[550,629,"wasn't she supposed to be"],[629,750,"Alpha Cassian's date tonight?"],[825,975,"Wow, she's gorgeous."],[1470,1575,"Making another mess"],[1575,1683,"for me to clean up, Owen?"],[1716,1929,"I said I was gonna handle this, Claudia."],[1991,2075,"Well, obviously,"],[2075,2141,"Dad didn't trust you"],[2141,2279,"to handle it alone, dipshit."],[2329,2412,"So he sent me."],[2716,2775,"Cassian,"],[2887,3004,"darling."],[3050,3125,"Remember me?"],[3283,3354,"What do you want, Claudia?"],[3445,3520,"It's simple."],[3525,3687,"I wanna take back what's mine."],[3754,3887,"What was taken from me."],[3925,4041,"There's nothing to take back."],[4062,4150,"I already have a date."],[4183,4291,"And she's my bonded mate."],[4429,4520,"I heard."],[4637,4775,"I heard you paid a pretty penny"],[4775,4866,"for this one, too."],[4970,5058,"And you are?"],[5170,5275,"You can call me Lia."],[5345,5445,"All right, then, Lia."],[5495,5595,"I'm in a giving mood,"],[5637,5716,"so I'll make you an offer."],[5770,5904,"Whatever Cassian paid you"],[5904,5975,"to be his mate,"],[6041,6241,"I'll pay you ten times over,"],[6291,6362,"if you break your bond"],[6362,6445,"and return him to me."],[7054,7150,"Ten times?"],[7212,7337,"That's pocket change."]],"48":[[191,341,"How very generous of you,"],[341,412,"Ms. Ashwood."],[433,483,"Makes it sound like"],[483,570,"you could buy anything!"],[625,737,"I can buy anything."],[770,837,"So maybe instead of"],[837,970,"testing my patience,"],[991,1116,"you take my offer"],[1116,1258,"and thank me on your knees"],[1258,1429,"for not having you banished."],[1504,1579,"You don't have the authority"],[1579,1675,"to do that, Claudia."],[1750,1841,"Not yet I don't."],[1883,2016,"I'd take Ms. Ashwood's deal"],[2016,2091,"if I were you, Lia."],[2154,2275,"Her father is one of,"],[2275,2483,"if not the most powerful Alpha"],[2483,2558,"in the kingdom."],[2633,2733,"Oh please,"],[2766,2891,"look at her clinging to him"],[2891,3079,"like he'll leave the second she lets go."],[3145,3287,"Do you really think Alpha Cassian"],[3287,3425,"made you his mate out of love?"],[3466,3566,"He was just trying to avoid"],[3566,3637,"his betrothal."],[3695,3779,"He'll break that bond"],[3779,3920,"as soon as this dance is over."],[3995,4104,"The choice is yours."],[4166,4233,"But this offer"],[4233,4370,"is not gonna last all night."],[4429,4550,"So you'd better give me an answer"],[4550,4645,"before I change my mind."],[4700,4783,"They're wrong."],[4808,4966,"Caz wouldn't do that to me."]],"49":[[33,62,"You're here"],[62,220,"on behalf of the Ashwood family?"],[275,337,"That's right."],[425,545,"And you can afford everything?"],[570,704,"I most certainly can."],[895,1045,"I really hate to tell you this."],[1108,1187,"Actually, no, I don't."],[1187,1275,"I really love this."],[1300,1345,"You're wrong."],[1445,1533,"Excuse me?"],[1637,1770,"No amount of money has ever"],[1770,1866,"or will ever make me"],[1866,1958,"change my mind."],[2058,2237,"Some of you may choose your mates"],[2237,2437,"based on power or money."],[2570,2679,"But I'm staying with Caz."],[2725,2837,"Not because he's an Alpha."],[2958,3075,"But because he cares about me"],[3241,3354,"as much as I care about him."],[3637,3737,"And since you so rudely"],[3737,3854,"barged into this dance"],[3854,4070,"that my mate's family is hosting,"],[4137,4245,"I think you should leave."],[4333,4366,"Now."],[4579,4775,"You must either be new around here,"],[4791,4945,"or you're out of your fucking mind"],[4945,4987,"if you think"],[4987,5141,"you can talk to me like that."],[5229,5337,"We're from completely"],[5337,5425,"different worlds."],[5458,5525,"Caz probably got you"],[5525,5633,"out of the fucking gutter."],[5687,5804,"I'm practically royalty!"],[5854,5954,"Royalty, huh?"],[5970,6008,"Mm."],[6016,6070,"Hm."],[6295,6366,"I don't see it."],[6533,6650,"What? - You can't touch her,"],[6650,6695,"Claudia."],[6866,6933,"Maybe not."],[7025,7220,"I wouldn't wanna get my hands dirty"],[7220,7350,"by touching her anyway."],[7400,7533,"But I can still ruin you."],[7550,7683,"I can ruin all of you!"],[7879,8004,"What's all this commotion"],[8004,8054,"going on?"],[8116,8229,"It's the Headmistress."],[8266,8337,"Grandmother? - Grandmother?"]],"50":[[50,283,"Now what's with all this noise?"],[329,525,"This is still technically"],[525,675,"a school event."],[716,850,"Remember, children?"],[2058,2150,"Headmistress,"],[2250,2525,"Alpha Cassian went back on our deal."],[2525,2733,"As part of the Silverwind Council,"],[2758,2800,"you should-"],[2800,3104,"Oh, I'm well aware of what goes on"],[3104,3237,"in my school."],[3479,3675,"Granny, it's so good to see you."],[3675,3775,"Claudia, dear."],[4037,4254,"My, how beautiful you look."],[4254,4395,"It's been far too long."],[4466,4500,"Oh."],[4520,4633,"I thought I'd pay you a visit,"],[4633,4720,"since we are going to be"],[4720,4870,"officially family soon."],[4929,5025,"Oh yes, yes."]],"51":[[62,212,"Oh yes, uh, yes."],[287,337,"You know,"],[437,658,"a little birdy also told me"],[662,725,"that someone"],[725,920,"mysterious and powerful"],[962,1120,"would come to the dance tonight."],[1187,1487,"I wonder where that someone is."],[1545,1658,"Whoever they are,"],[1725,1995,"I certainly hope you won't make a scene"],[1995,2166,"in front of them, dear."],[2225,2362,"I would never, Granny."],[2433,2500,"In fact,"],[2529,2604,"as a token"],[2604,2787,"of my deepest appreciation"],[2787,2933,"for you and your family,"],[3000,3095,"I brought gifts."],[4891,4950,"I told you,"],[4950,5062,"we're from different worlds."],[5133,5220,"Now let me show you."]],"52":[[83,225,"I brought these Moon Lilies for you,"],[225,275,"Granny."],[304,400,"They're supposed to hold"],[400,520,"some of the Goddess' power,"],[558,683,"blessing you with longevity"],[683,750,"and fortune."],[825,1062,"How very thoughtful of you, Claudia."],[1125,1270,"Those lilies only bloom"],[1270,1383,"once every decade."],[1395,1550,"She's got a whole dozen."],[1587,1741,"They're like a fortune."],[1750,1804,"Well, duh,"],[1804,1941,"Claudia obviously can afford it."],[2054,2125,"And this."],[2212,2391,"This is an ancient statue"],[2391,2483,"of the Moon Goddess"],[2508,2695,"that's over a century old."],[2758,2845,"For your art collection."],[2962,3133,"Ancient statues of the Moon Goddess"],[3137,3237,"are priceless."],[3270,3437,"Well, obviously not for Ms. Ashwood."],[3450,3570,"No price is too high for her."],[3637,3679,"Oh,"],[3708,3833,"I, I can't believe"],[3833,3958,"you still remembered"],[3958,4041,"my collection."],[4112,4141,"Oh,"],[4187,4258,"I was just trying to be"],[4258,4404,"a considerate granddaughter-in-law."],[4950,5045,"I'm impressed."],[5125,5250,"Your talent for flattery"],[5250,5320,"is unmatched,"],[5320,5412,"Ms. Ashwood."],[5495,5533,"What a shame"],[5533,5637,"all your gifts don't live up"],[5637,5745,"to the hype you said."],[5833,5995,"No way she actually said that"],[5995,6158,"to Claudia fucking Ashwood."],[6170,6191,"Really,"],[6191,6329,"like does she think she can do better?"],[6445,6512,"You don't think so?"],[6595,6641,"Alright then."],[6641,6787,"I'd love to see you try to do better."],[6820,6929,"What are you gonna do, Lia?"],[6975,7133,"Make another stupid paper ring?"],[7295,7437,"Let's give it about five minutes."],[7487,7604,"Five minutes before what?"],[7641,7775,"Before I show you the real difference"],[7775,7862,"between you and I."]],"53":[[108,154,"Fine."],[225,350,"That gives me enough time"],[350,512,"to show my final gift."],[537,695,"I've saved the best for last, Granny."],[741,937,"The Moon Lilies, the statue,"],[970,1083,"those were just tokens"],[1083,1212,"of my appreciation."],[1287,1362,"But this,"],[1404,1583,"this is a true demonstration"],[1583,1804,"of my devotion to our future family."],[2662,2945,"As of today, the Northstar Estate,"],[2966,3104,"a sprawling manor"],[3120,3300,"overlooking the Moonlit Vale,"],[3325,3512,"a place of unmatched beauty"],[3537,3679,"where the Goddess herself"],[3679,3766,"once resided-"],[3841,3929,"belongs to you."],[4037,4145,"The Northstar Estate?"],[4170,4300,"No one's even allowed to go there."],[4337,4475,"It's the most exclusive property"],[4475,4570,"in the whole kingdom."],[4591,4695,"Only Claudia Ashwood"],[4695,4758,"could get her hands"],[4758,4841,"on something like that."],[5137,5170,"So,"],[5279,5416,"you still think my gifts"],[5416,5520,"don't live up to the hype?"],[5587,5612,"No,"],[5708,5758,"I don't."],[5883,5937,"You really should have"],[5937,6016,"done your research"],[6016,6191,"before trying to impress us all."],[6441,6554,"You said the Northstar Estate"],[6554,6691,"overlooks the Moonlit Vale?"],[6720,6887,"It's been untouched for centuries?"],[6916,7108,"That only the purest of bloodlines"],[7108,7225,"have ever set foot there?"],[7266,7354,"That's what you said, right?"],[7400,7483,"Obviously."],[7483,7612,"Everyone knows that."],[7800,7850,"You're wrong."],[7962,8070,"The Northstar Estate"],[8070,8229,"doesn't look over the Moonlit Vale."],[8229,8416,"It's on the opposite side of a cliff."],[8529,8641,"And untouched for centuries?"],[8650,8695,"Please."],[8770,8870,"It's been under construction"],[8870,8975,"for the last year."],[9000,9083,"That's impossible."],[9108,9200,"The land has been-"],[9204,9437,"Purchased by my family. A year ago."]],"54":[[75,191,"God, don't listen to her!"],[266,437,"That bitch is a fucking orphan."],[470,612,"She doesn't even have any family."],[691,716,"Derek,"],[716,825,"you should really shut your mouth"],[833,875,"when you don't know"],[875,991,"what you're talking about."],[2666,2908,"Are you insane, you fucking bitch?"],[3083,3137,"Whoops."],[3175,3304,"She just destroyed the lilies."],[3341,3429,"Lia, what are you doing?"],[4150,4325,"My goddess, I knew she was crazy."],[4383,4466,"Hey, guards,"],[4487,4554,"take her away!"],[4570,4600,"Wait!"],[4654,4700,"Caz,"],[4779,4895,"she's lost her mind."],[4908,5033,"I demand she be punished."],[5087,5187,"Lia was only pretending"],[5187,5275,"to be the Princess."],[5316,5429,"She can't afford all this."],[5466,5504,"I'll,"],[5600,5695,"I'll pay for the damages."],[5704,5737,"No,"],[5804,5875,"it's okay, Caz."],[5958,6062,"I'll cover them myself."],[6100,6300,"You arrogant little-"]],"55":[[12,208,"I'm gonna make you fucking pay."],[208,258,"Enough!"],[1308,1533,"Finally, Uncle Marcus is here."],[1604,1700,"Beta Marcus?"],[1754,1837,"Why is he here?"],[1887,2045,"Wait, that's the princess' uncle?"],[2233,2325,"That means the Wolf Princess"],[2325,2412,"is coming here too."],[3925,4087,"It’s time to show Claudia"],[4087,4262,"what royalty looks like."],[4845,4891,"What?"],[4966,5133,"Why is he bowing to her?"],[5162,5216,"I don't get it."],[5216,5325,"Who the fuck is she?"],[5420,5554,"Thank you for bringing these gifts,"],[5554,5645,"Uncle Marcus."],[5695,5733,"Uncle?"],[5825,5883,"Of course."],[5937,6025,"I'm at your command,"],[6108,6175,"Your Highness."],[6241,6316,"Your Highness?"],[6375,6466,"Wait, wait, wait."],[6491,6650,"Th, th, then, then means..."],[6750,6970,"Lia, you really are the Wolf Princess?"]],"56":[[20,154,"You really are the Wolf Princess?"],[404,495,"She was a princess"],[495,566,"this whole time?"],[741,791,"No, no."],[791,891,"She's, she's a fake."],[891,983,"She's an imposter!"],[1025,1275,"I've known Princess Eliana all her life."],[1395,1445,"Trust me."],[1575,1654,"She's the real deal."],[1933,2070,"Good to see you, Marcus."],[2133,2187,"Grandma?"],[2266,2383,"You knew about this?"],[2433,2554,"Oh, my dear,"],[2591,2725,"I always know"],[2729,2941,"what goes on in my school."],[3008,3204,"I am Princess Eliana Northwood,"],[3250,3383,"daughter of the Alpha King,"],[3433,3554,"and heir to the throne."],[3704,3850,"Some of you may not know who I am,"],[3954,4125,"granted, that's my fault."],[4229,4366,"I spent so long trying to run away"],[4366,4537,"from my title and my name."],[4670,4779,"I thought that's what I wanted."],[4866,4991,"But these last few days,"],[5045,5133,"I've learned what it means"],[5133,5254,"to be a Princess,"],[5358,5408,"a leader."],[5625,5729,"So as of today,"],[5795,5941,"I'm claiming my rightful title,"],[6020,6175,"not just as the Wolf Princess,"],[6254,6354,"but a Wolf Queen."]],"57":[[316,425,"Your Highness, I was wrong."],[425,491,"I was a fool."],[491,562,"I love you,"],[591,650,"I swear."],[658,791,"Please take me back."],[908,987,"Let me serve you."],[1075,1162,"You betrayed me,"],[1254,1358,"humiliated me."],[1458,1583,"You cast me aside."],[1670,1887,"I gave you all of the love I had in me,"],[1887,2025,"and you spat on it."],[2108,2183,"I'm never letting you"],[2183,2304,"into my life again."],[2362,2429,"You will remain"],[2429,2575,"inside of your pack's lands"],[2575,2708,"for the rest of your days."],[2741,2854,"You will never step foot"],[2854,2966,"into my kingdom again."],[3083,3162,"Your highness."],[3220,3341,"I've always admired you."],[3404,3750,"You're so wise, so kind, so beautiful."],[3829,3875,"Please."],[3875,3975,"Please let me serve you."],[4087,4229,"You serve me?"],[4308,4429,"The only thing you've ever served"],[4429,4512,"is yourself."],[4562,4641,"Just like Derek,"],[4641,4729,"you are now forbidden"],[4729,4816,"from my lands."],[4866,5000,"You will be kept inside your own"],[5000,5120,"and you will never step foot"],[5120,5204,"outside again."],[5254,5345,"No, no, you mean..."],[5391,5416,"No,"],[5416,5516,"you can't do this!"],[5554,5604,"Please."],[5650,5775,"This is bullshit!"],[5800,5916,"You can't just waltz in here"],[5916,6095,"and take everything I worked for."],[6112,6183,"Worked for?"],[6258,6316,"You stole,"],[6370,6425,"lied,"],[6433,6612,"and manipulated to get your way."],[6670,6758,"But that ends today."],[6820,7008,"I'll be having a chat with your father,"],[7025,7087,"the Alpha,"],[7125,7200,"real soon."],[7895,7941,"Grandma,"],[7966,8083,"would it kill you to let us in"],[8083,8187,"on the joke next time?"],[8195,8270,"Oh hush,"],[8325,8508,"I was just having a bit of fun."],[8633,8825,"Well, it is a dance, isn't it?"],[8937,9112,"Turn the music back on!"]],"58":[[400,437,"So,"],[562,633,"guessing I won't be meeting"],[633,704,"your sister then?"],[804,837,"No."],[920,1016,"My imaginary sister"],[1016,1125,"won't be joining us tonight."],[1237,1304,"At the shop,"],[1437,1504,"why didn't you tell me"],[1504,1637,"that you were really the Wolf Princess?"],[1737,1812,"You could have told me then"],[1812,1904,"and I would have believed you."],[1962,2029,"I just,"],[2266,2425,"I wanted you to like me for me."],[2612,2645,"I..."],[2795,2812,"I mean,"],[2812,2929,"I wasn't good enough for Derek"],[2929,3100,"when I wasn't the Wolf Princess,"],[3100,3187,"and so I just,"],[3233,3312,"I needed to be good enough"],[3312,3375,"for someone."],[3604,3691,"Are you disappointed?"],[3762,3941,"that I'm... just Lia?"],[4070,4183,"You're perfect, Lia."],[4270,4466,"And you'll always be just Lia to me."],[4595,4708,"That's the only thing I care about."],[4862,4945,"As long as I'm always"],[4945,5033,"just Caz to you."],[5395,5612,"So what now, your Royal Highness?"],[5625,5662,"No,"],[5725,5816,"no, do not call me that."],[6087,6191,"Well, there's the matter"],[6191,6325,"of your coronation as Queen."],[6366,6479,"And we didn't tell my grandmother about"],[6479,6654,"this, so, probably have to hold a-"],[6750,6791,"We can worry"],[6791,6912,"about the boring shit later,"],[6912,6987,"Alpha Cassian."],[7058,7108,"But for now,"],[7187,7391,"just Caz and just Lia"],[7462,7525,"can celebrate."]]}