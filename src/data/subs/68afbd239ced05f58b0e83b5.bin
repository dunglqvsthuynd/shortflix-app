"],[2681,2877,"How can you treat Ruby like this?"],[2877,3007,"Don't you care about the"],[3007,3069,"relationship"],[3069,3211,"between our families?"],[3211,3311,"Ruby is a well educated"],[3311,3428,"young woman."],[3428,3528,"How could you insult my daughter"],[3528,3682,"for some hussy?"],[3682,3820,"Because you're well educated"],[3820,3937,"daughter"],[3937,4083,"is a psychopath."]],"53":[[8,95,"This is surveillance"],[95,166,"footage from the day"],[166,325,"that my son had a near-fatal"],[325,408,"allergic reaction."],[408,604,"Because of what your sister fed him."],[1017,1255,"And Ruby hit him with her car."],[1255,1359,"She refused to pay"],[1359,1551,"for his medical expenses."],[1659,1830,"Is that enough evidence for you?"],[1951,2052,"Ruby."],[2052,2177,"How can you do this?"],[2177,2310,"Heston would be mine"],[2310,2431,"if she hadn't given birth"],[2431,2560,"to that bastard."],[2560,2781,"I'm doing this for our family."],[2781,3011,"Apologize to Adele right now."],[3011,3115,"Adam."],[3115,3219,"Do something."],[3219,3336,"Heston, you've already wronged"],[3336,3395,"my sister."],[3395,3532,"And now you want her to apologize"],[3532,3620,"to this"],[3620,3695,"woman."],[3695,3866,"Are you going to destroy"],[3866,3962,"the sacred friendship"],[3962,4120,"between our two households?"],[4120,4316,"All for her."]],"54":[[16,175,"She's the mother of my son,"],[175,408,"and she's about to become my wife."],[408,558,"I will protect them with my life,"],[558,721,"whatever the cost."],[721,917,"What's all this fuss about?"],[992,1138,"Patrick."],[1138,1380,"We've been friends for many years."],[1380,1643,"And for that reason and no other."],[1643,1910,"I won't pursue legal action against"],[1910,2035,"Ruby."],[2035,2214,"For harming Brad."],[2214,2268,"Dad."],[2268,2377,"Silence."],[2377,2577,"It's settled."],[2577,2665,"They're family has done"],[2665,2848,"our family tremendous favors"],[2848,3065,"through the years."],[3065,3207,"I hope you can understand."],[3378,3541,"However,"],[3541,3782,"Heston will marry Adele,"],[3782,3945,"the mother of my grandson."],[3945,4091,"I appreciate that,"],[4091,4225,"but I can't support this marriage"],[4225,4437,"between your son"],[4437,4608,"and some vagabond."],[4608,4796,"Our families are fighting like this"],[4796,4888,"because you're bewitched"],[4888,5080,"by some homeless woman."],[5080,5146,"You know who you're meant"],[5146,5363,"to be with Huston,"],[5363,5559,"and it's not her."],[6147,6318,"It's okay Adele."],[6318,6410,"I got your back."],[6610,6694,"Adele is the woman"],[6694,6861,"that I'm going to marry."],[6861,7082,"Nothing any of you do or say"],[7082,7215,"is ever going to change that."],[7215,7344,"If you insist on"],[7344,7582,"going through with this charade,"],[7582,7741,"our family will be forced"],[7741,7916,"to sever ties with yours."],[7916,8045,"Let me remind you"],[8045,8274,"that if you break that contract,"],[8274,8554,"you'll pay enormous penalties."],[8554,8737,"There's no price too high"],[8737,9013,"to maintain one's dignity."],[9013,9134,"Let's go."],[9384,9547,"Wait a second."],[9567,9747,"Get out of our way, bitch!"],[9747,9968,"Mr. Miller, please, just listen to me."],[9968,10168,"Get out of the way!"],[10168,10372,"Heston wants to be their for his child."],[10372,10560,"He's a loyal and responsible man."],[10560,10643,"And that makes"],[10643,10781,"a wonderful business partner."],[10781,10873,"Please."],[10873,11077,"Just hear him out."],[11202,11344,"This bitch conned Heston"],[11344,11473,"into marrying her."],[11473,11619,"Don't let her con you two."],[11619,11728,"Ruby's right."],[11728,11870,"Our business dealings here"],[11870,11945,"are over."],[11945,12078,"Why would I con you? I don't."],[12078,12237,"I don't want to keep Ruby around"],[12237,12295,"Heston."],[12295,12358,"Enough."],[12358,12520,"Stop talking and get out of our way."],[12871,12992,"Can it be?"]],"55":[[25,191,"Adele,"],[191,375,"my baby."],[375,633,"I can't believe I found you."],[804,967,"Ma'am?"],[967,1067,"Miss Miller, what games"],[1067,1213,"are you trying to play here?"],[1234,1518,"No Heston, no games."],[1518,1818,"She's my daughter."],[1830,1872,"Your daughter?"],[1872,2022,"What the hell are you talking about?"],[2022,2218,"It's her. I know it's her."],[2218,2381,"She has the birthmark."],[2452,2627,"It's Adele."],[2744,2898,"Adele?"],[2898,3028,"It's really you?"],[3028,3174,"Mom has been looking for you"],[3174,3390,"for 20 years."],[3687,3845,"I'm sorry."],[3845,4104,"I didn't recognize you."],[4104,4245,"I'm sorry I let my family"],[4245,4425,"humiliate you."],[4425,4491,"I'm sorry."],[4491,4654,"I'm so sorry."],[4704,4938,"Please forgive me."],[4938,5159,"Our family's finally whole."],[5167,5401,"How is this possible?"],[5401,5534,"Mom adopted me back then"],[5534,5743,"because she lost her daughter."],[5743,5860,"Now she suddenly finds her"],[5860,5926,"real daughter,"],[5926,6122,"and it's Adele."]],"56":[[16,112,"Does this mean that all"],[112,187,"the inheritance"],[187,371,"will go to Adele."],[371,571,"Out of everyone in the world?"],[571,729,"Why did your biological daughter"],[729,917,"have to be this bitch?"],[1255,1488,"If only she were out of the picture."],[1488,1643,"Heston would be mine."],[1643,1747,"My mom,"],[1747,1926,"dad and brother"],[1926,2139,"would all still be mine too."],[2139,2293,"You bitch!"],[2627,2723,"Guards!"],[2723,2898,"Get her out of here!"],[3207,3390,"You stole my fiancee."],[3390,3499,"And now you want to take my family"],[3499,3595,"too?"],[3691,3887,"I will kill you!"],[3887,3953,"Ruby."],[3953,4129,"She's your sister."],[4129,4300,"Ruby, have you gone insane?"],[4300,4387,"Thief!"],[4387,4542,"She's a fucking thief!"],[4546,4696,"If anyone's a thief, it's you."],[4696,4825,"You've stolen my mother's time"],[4825,5025,"and wasted her love."],[5025,5142,"You don't deserve to breathe"],[5142,5305,"the same air as her,"],[5305,5555,"let alone be loved by her."],[5689,