e some homeless"],[362,663,"person scavenging for trash."],[709,850,"Get your hands off of me!"],[850,1038,"I was invited by Frank."],[1038,1372,"Hey, how dare you push my sister."],[1372,1418,"Adam."],[1480,1659,"She hit me on purpose."],[1659,1739,"That's it."],[1739,2018,"Get out of here or I'll throw you out,"],[2018,2152,"my self."],[2364,2531,"What are you doing out here?"],[2585,2777,"I told you Brad's mother's coming."],[2777,2857,"Great."],[2857,2944,"This will be a good chance"],[2944,3053,"to break things off cleanly,"],[3053,3211,"with Brad's mother."],[3211,3307,"Mr. Deleon,"],[3307,3482,"the nanny you hired is here."],[3482,3624,"What's she doing here?"],[3624,3774,"Maybe she's here to stop you"],[3774,3928,"marrying your son's mother."],[4333,4400,"Is this nanny"],[4400,4483,"the one who's pregnant"],[4483,4650,"with triplets?"],[4650,4863,"This woman is trying to compete"],[4863,4929,"against Brad's mother"],[4929,5230,"to become Heston's wife."],[5230,5330,"Im going to set her straight."]],"50":[[16,204,"You have no right to tell me to leave."],[204,250,"That's it."],[250,354,"Come on, let's go."],[529,821,"This gala was held in honor of my son."],[821,938,"If anyone should leave, it's"],[938,1167,"you and your demented sister."],[1167,1272,"If your mother taught me any"],[1272,1363,"manners,"],[1363,1468,"it's time to use them."],[1468,1768,"She's just some homeless reject."],[1822,1893,"For all we know,"],[1893,2039,"she was probably abandoned by her"],[2039,2139,"mom as a kid."],[2139,2289,"So she's had an upbrining."],[2289,2506,"That must be why she's so,"],[2506,2590,"uncultured."],[2590,2711,"Yeah, she probably inherited"],[2711,2961,"her mother's trashiness too."],[2961,3132,"My mother escaped an abusive"],[3132,3228,"situation."],[3228,3374,"I supported it."],[3374,3561,"She'd be dead otherwise."],[3561,3661,"Adele?"],[3661,3741,"No."],[3741,3945,"She can't be my daughter, can she?"],[3945,4183,"She feels so familiar."],[4183,4283,"Miss."],