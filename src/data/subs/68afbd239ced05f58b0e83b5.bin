be incredible to them, I know it."],[8116,8324,"Excuse me."],[8967,9154,"Congratulations."],[9213,9376,"You're having triplets."],[9513,9613,"What?"]],"40":[[421,721,"I'm pregnant and with triplets."],[775,892,"Oh, should I tell Mr."],[892,1088,"Deleon about this?"],[1088,1272,"How?"],[1272,1405,"But he's the father."],[1405,1618,"He deserves to know-"],[1618,1693,"stop lazing around"],[1693,1818,"and make yourself useful."],[1818,1947,"Give that back."],[2022,2164,"You're pregnant."],[2164,2223,"I thought you said"],[2223,2377,"you didn't have a boyfriend."],[2377,2464,"It's none of your business,"],[2464,2623,"so give it back."],[2623,2790,"That's my private information."],[2802,2944,"Hey, everyone!"],[2944,3065,"Come look at this."],[3161,3257,"What?"],[3495,3570,"Oh my God!"],[3570,3720,"Is she really pregnant?"],[3774,3891,"Do yourself a favor."],[3891,4054,"Get rid of it."],[4054,4120,"Yeah."],[4133,4279,"You know, you did such a great job"],[4279,4421,"raising your first one."],[4421,4650,"Providing him with food and shelter."],[4758,4950,"Oh, wait. That's right."],[4950,5117,"You're an epic failure."],[5117,5226,"You know, you should just quit"],[5226,5326,"before you get fired."],[5326,5472,"Mr. Deleon is the only one who can"],[5472,5551,"fire me."],[5593,5684,"And he won't."],[5697,5893,"I bet that if I show this to Mr."],[5893,6072,"Deleon, he'll fire you on the spot."]],"41":[[0,87,"My personal life has"],[87,258,"nothing to do with my work."],[258,429,"You all have no reason to attack me"],[429,504,"like this."],[504,638,"Could you be more shameless?"],[663,717,"Who knows what kind of"],[717,825,"deadbeat loser knocked"],[825,905,"you up?"],[905,992,"Just leave."],[1021,1184,"Nobody wants you here."],[1184,1234,"Don't you know"],[1234,1393,"you're at the Deloen estate?"],[1393,1522,"We can't have a filthy slut"],[1522,1714,"like you tarnishing his reputation."],[1939,2068,"I bet you're pregnant"],[2068,2248,"by a different father this time, right?"],[2