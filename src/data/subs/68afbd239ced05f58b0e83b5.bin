{"1":[[25,179,"Please dad I'm begging you."],[279,371,"Dad, I'm begging you."],[383,588,"Just let me keep the baby."],[700,855,"You have brought shame to me."],[867,1009,"How can I let anyone know"],[1009,1117,"that you got knocked up"],[1117,1280,"by some random dude?"],[1906,2018,"Whoa!"],[2160,2281,"Are you okay?"],[2335,2373,"Yeah."],[2373,2627,"It's just the curse of the right two feet."],[2627,2723,"Or the"],[2761,2836,"left two,"],[2836,2948,"or the two"],[2948,3082,"left feet."],[3269,3399,"It's nothing that a beautiful women"],[3399,3499,"can't fix."],[3591,3653,"Wait a second."],[3653,3745,"How old are you?"],[3745,3832,"19."],[3832,3920,"If you're worried about"],[3920,4087,"whether I'm legal, don't be."],[4133,4433,"I'm old enough to make adult decisions."],[4729,4842,"Get an abortion,"],[4842,5075,"or get the fuck out of my house."],[5134,5251,"You're such a slut."],[5251,5405,"Just like your birth mother."],[5467,5543,"If word gets out,"],[5543,5680,"the Moore family name will be dragged"],[5680,5764,"through the mud."],[5780,5972,"You should be ashamed."],[5972,6197,"I'm going to ask you one more time."],[6227,6377,"Who is the father?"],[7040,7182,"I'm going to a meeting."],[7182,7482,"Contact me when you wake up."],[7962,8099,"I don't know who the father is,"],[8099,8287,"but I'm keeping this baby."],[8320,8558,"Then you're even dumber than I thought."],[8558,8646,"Chris, are you going to let"],[8646,8804,"this disgrace of a child"],[8804,8879,"live in our house?"],[8879,8954,"Or are you going to help"],[8954,9171,"raise this bastard child?"],[9171,9296,"Get rid of the kid or"],[9296,9413,"get out of my house."]],"2":[[550,671,"It's okay, baby."],[671,880,"Everything's going to be alright."],[880,1180,"I'll raise you up alone as best as I can."],[1463,1593,"Stay out!"],[1593,1697,"Don't come back!"],[1697,1780,"You hear me?"],[1780,1943,"You're dead to me."],[2761,2965,"Thanks, baby."],[3169,3232,"Mommy, look!"],[3232,3311,"A bottle."],[3311,3382,"I'll go get it."],[3382,3511,"Brad, wait for me!"],[4250,4450,"Ah!"],[4450,4571,"Brad!"],[4808,4950,"Area secure sir."],[5176,5372,"My bones have given up on me Heston."],[5372,5497,"You hear me."],[5547,5647,"If you don't get married"],[5647,5776,"soon, I'll be six feet under"],[5776,5939,"before I ever meet my grandchild."],[6085,6272,"You know dad."],[6272,6393,"I don't even have a girlfriend."],[6393,6460,"How am I supposed to get"],[6460,6589,"you a grandchild?"],[6669,6781,"If you want a baby so bad,"],[6781,6969,"just have one yourself."],[6969,7123,"Watch it."],[7415,7494,"Mommy's going to go talk"],[7494,7607,"to the doctor, okay?"],[7607,7695,"You stay right here."],[7695,7770,"Don't move."],[7770,7924,"Mommy, don't forget to tell them"],[7924,8070,"it was that lady who hit me?"],[8070,8249,"She should be paying, not you."],[8308,8466,"All right, I will."],[8466,8575,"You little scrooge."],[8925,9096,"Brad's not in the clear yet."],[9096,9221,"He has a pretty serious staph"],[9221,9325,"infection from the scrape"],[9325,9451,"on the pavement."],[9451,9751,"He'll need follow up treatment."],[9876,10122,"Can I ask how much that cost?"],[10172,10352,"With no insurance,"],[10352,10589,"at least ten grand."],[11423,11661,"Dear God almighty."],[11661,11936,"Please bless me with a grandbaby."],[12512,12704,"Heston, look at him."],[13121,13304,"He's a spitting image of you."]],"3":[[62,266,"The resemblance is uncanny."],[300,429,"Did God really answer my"],[429,508,"prayers?"],[538,754,"Did God bless me with a grandbaby."],[809,984,"Sorry, sir."],[984,1063,"Wait, wait, kid."],[1063,1176,"Don't go."],[1518,1647,"Go get him."],[1647,1701,"Go get him?"],[1701,1768,"You go get him."],[1768,1951,"I'm not chasing after someone else's kid."],[1951,2147,"That's called kidnaping, dad."],[2302,2602,"Good thing I got that boy's hair."],[2619,2744,"Come here, son."],[2744,2844,"A little closer."],[3194,3415,"Notify the hospital lab."],[3453,3628,"I want a DNA test,"],[3628,3699,"right now."],[3903,4016,"Dad, you're being delusional."],[4016,4120,"Some random homeless kid"],[4120,4233,"isn't going to be my son."],[4254,4487,"Yeah, you just wait and see."],[4575,4700,"My guts never wrong."],[4700,4850,"Sir,"],[4850,5038,"the results are in."],[5509,5734,"99.9% match."],[5734,5885,"I have a grandchild."],[5885,6043,"Ha ha ha!"],[6043,6181,"Dad! Dad! Your leg."],[6181,6264,"Be careful."],[6264,6456,"I don't care about my leg."],[6456,6656,"The Deleon name lives on."],[6656,6790,"I have an heir."],[7186,7298,"He is my son."],[7298,7553,"Was it that girl from six years ago?"],[8295,8408,"I don't care what it takes."],[8408,8550,"You find my grandson and"],[8550,8771,"bring him home."],[9434,9588,"What am I supposed to do?"],[9588,9747,"Even with all the money I saved up,"],[9747,9939,"I'm barely able to cover the hospital"],[9939,10060,"fees."],[10548,10639,"Block all exits."],[10639,10769,"We must find the heir."]],"4":[[2077,2252,"To avoid your little bum."],[2260,2410,"My car got scratched."],[2410,2556,"You should compensate me."],[2556,2706,"Your car hit my son."],[2748,2932,"Today's bill is 100."],[2944,3115,"Future treatment is ten grand."],[3115,3265,"Ten grand?"],[3265,3461,"Are you insane?"],[3461,3574,"Your little hobo kid"],[3574,3641,"caused all of this"],[3641,3766,"by running into the streets."],[3766,3908,"You should be compensating me"],[3908,3991,"for my trouble."],[3991,4149,"You weren't paying attention."],[4149,4254,"You're responsible."],[4254,4358,"Don't get too close to me"],[4358,4479,"with your filthy hands."],[4512,4658,"I might catch something."],[4729,4879,"If you want to blame someone."],[4879,5180,"Blame yourself for not watching your kid."],[5184,5384,"Wait a minute."],[5384,5530,"Are you trying to scam me?"],[5530,5755,"To squeeze money from someone rich?"],[5989,6064,"Yeah, well, that's just simply not"],[6064,6185,"gonna happen."],[6227,6431,"Oh, let go of me."],[6523,6556,"Bitch!"],[6556,6644,"Not until you pay me the money"],[6644,6777,"that you owe."],[7157,7194,"Sir."],[7194,7336,"No sign of the kid yet."],[7374,7432,"But I don't think"],[7432,7599,"the kid could have got far."],[7599,7753,"He must be around here still."],[7753,7899,"All right. Keep searching."],[7899,8008,"Let go of me."],[8208,8324,"Heston!"],[8375,8470,"Heston!"]],"5":[[125,287,"Heston!"],[487,629,"Heston!"],[629,704,"Come back?"],[704,900,"Hello? I'm over here."],[1172,1388,"Run and I'll call the cops."],[1388,1509,"The cops arrest people"],[1509,1626,"who hit kids with their car"],[1626,1710,"and drive away."],[1710,1864,"Is that what you want?"],[2610,2719,"Here."],[2769,2927,"My insurance info."],[2927,3019,"Call them."],[3019,3157,"But if you go by the book,"],[3157,3345,"claims take three months to process."],[3345,3457,"Three months?!"],[3457,3687,"My son can't wait that long for treatment."],[3766,3874,"Gasp!"],[3962,4066,"Not my problem."],[4066,4308,"Screw you and your kid."],[5839,5976,"I'm sorry Brad."],[5976,6051,"I swear"],[6051,6185,"I'll find a way to get you the care"],[6185,6327,"you need."],[6398,6585,"Widen your search?"],[6660,6802,"I need you to find my son now."]],"6":[[725,913,"This could pay for Brad's treatment."],[1063,1284,"But what if he really needs it, too?"],[1422,1568,"Sir, you forgot your wallet."],[2102,2198,"That face."],[2318,2489,"Why does he look so familiar?"],[2669,2756,"A homeless woman is"],[2756,2902,"giving me my wallet back?"],[3474,3528,"Here."],[3645,3791,"Take this, I insist."],[3795,3841,"Thank you."],[3908,4004,"Thank you sir,"],[4004,4137,"but I can't take your money."],[4312,4475,"Maybe you can give me a job."],[4475,4571,"I have grit."],[4629,4738,"I work hard."],[4771,4921,"I'll do anything."],[5209,5267,"All right."],[5367,5447,"As a matter of fact,"],[5447,5551,"I'm looking to hire a nanny."],[5613,5676,"Here,"],[5726,5897,"take this and go to the Deleon Estate."],[5914,6022,"Tell them I sent you."],[6131,6177,"Mommy!"]],"7":[[825,892,"Guess what?"],[955,1076,"Mommy just got a job."],[1096,1272,"We are gonna have a home, a real one."],[1814,2047,"Man, the Deleon's are loaded."],[2047,2243,"That kid's life just changed forever."],[2243,2335,"Private schools,"],[2335,2510,"drivers, anything he wants."],[2715,2790,"Brad?"],[3858,3949,"Move along."],[3958,4029,"Go!"],[4058,4191,"Both of you, get out!"],[4195,4350,"You're scaring off my customers."],[4521,4688,"Hey, once mommy gets paid,"],[4696,4846,"I'll get you the biggest juiciest"],[4846,4959,"steak ever."],[4959,5117,"But today,"],[5167,5326,"how about we go to the Soup Kitchen?"],[5367,5613,"Can I eat a super duper big steak?"],[5647,5772,"Yeah, baby. One day."],[5780,5997,"Can it be super duper big?"],[6639,6844,"Mr. Deleon told me to come here."],[6856,7098,"He said he's looking for a nanny."],[7203,7469,"Steve, I heard Heston hired someone new."],[7970,8112,"That is correct, Miss Ruby."],[8166,8466,"Allow me to introduce Miss Adele Moore."],[8692,8787,"Be careful."],[8808,8942,"That's Ruby Miller."],[8979,9121,"The Millers, and the Deleon's"],[9121,9255,"are practically family."],[9317,9438,"There's even talk of a marriage"],[9438,9626,"between her, and Mr. Heston."],[9663,9851,"You got to be kidding me, her?"],[9876,10010,"I need this job though."],[10030,10201,"Brad's treatment depends on it."],[10268,10364,"Her?"],[10410,10618,"That street rat."],[10668,10773,"What?"],[10773,10935,"Done scamming strangers and decided"],[10935,11140,"to sleep your way into a mansion instead?"],[11165,11319,"Let me make this crystal clear."],[11319,11432,"As long as I'm around,"],[11490,11745,"you'll never be one of us."],[11866,11949,"Miss Ruby,"],[12007,12078,"about the other day."],[12078,12320,"That was just all a misunderstanding."],[13179,13284,"Why do I get deja vu"],[13284,13438,"every time I see her?"]],"8":[[350,454,"Heston."],[454,600,"Thank god you're here."],[600,825,"You can't seriously be thinking of hiring"],[825,925,"her, right?"],[955,1121,"I mean, she's homeless,"],[1121,1330,"and she's got a grubby little kid in tow."],[1347,1434,"There's no way"],[1434,1593,"she can do this job, right?"],[1593,1693,"You have a kid?"],[1730,1805,"Yes, sir."],[1805,1964,"A boy. He's seven."],[2118,2181,"I see,"],[2331,2435,"you're hired."],[2694,2907,"Come with me."],[3240,3365,"What?"],[3482,3741,"How could Heston hire her, of all people?"],[3745,3933,"She looks like, she literally"],[3933,4062,"just crawled out of the gutter."],[4066,4187,"Well, Miss Adele"],[4187,4291,"does have experience"],[4291,4425,"raising a child."],[4487,4671,"And since Mr. Heston recently"],[4671,4938,"learned that he has a son of his own."],[4938,5034,"He needs someone who knows"],[5034,5171,"what they're doing."],[5205,5317,"Heston has a kid."],[5317,5397,"What..."],[5397,5538,"Since when?"],[5618,5814,"Oh, and,"],[5814,5972,"one more thing."],[6210,6327,"We are gonna take good care of you."],[6335,6456,"I'll have her cleaned up"],[6456,6606,"and properly dressed."],[9046,9250,"What are you doing in my room?"],[9309,9413,"Oh,"],[9459,9517,"I'm sorry."],[9517,9647,"I thought this was the guest room."]],"9":[[1038,1105,"So what's it like"],[1105,1217,"raising a seven year old?"],[1301,1451,"Oh, well,"],[1451,1555,"they're very curious,"],[1555,1722,"and they ask a million questions,"],[1801,1960,"and they just want to play and explore"],[1960,2110,"and make new friends."],[2110,2323,"I mean, my son is so full of life."],[2323,2590,"He's sweet and clever and"],[2665,2811,"a little mischievous."],[2811,3036,"Once I find my son, maybe he and,"],[3053,3199,"Adele's son can play together."],[3199,3345,"He'll need someone kind."],[3390,3566,"Do you want to see a picture of him?"],[3566,3720,"I mean, not to brag,"],[3720,4020,"but he is the cutest kid in the world."],[4066,4208,"Yeah, I'd love to see him."]],"10":[[563,650,"Hey, dad."],[684,754,"Heston,"],[792,934,"did you get my grandson's room"],[934,1005,"ready yet?"],[1042,1151,"Yes, dad."],[1172,1284,"It's been ready for a while now."],[1317,1451,"Okay, I want to see it."],[1459,1518,"Show me."],[1597,1722,"I'm so sorry. I'll be right back."],[1931,1985,"Dad, look,"],[1985,2114,"I got everything a boy could want."],[2114,2293,"I got action figures,"],[2310,2348,"a puzzle."],[2348,2502,"I got this, like, boogie board."],[2527,2673,"It's packed, we got everything."],[2781,2852,"No."],[2919,3028,"No, this won't do."],[3057,3157,"We're going to have to knock down"],[3157,3278,"the wall in the room next door"],[3278,3399,"so that he's got enough room"],[3399,3536,"to store all of his toys."],[3586,3770,"Actually, no."],[3824,3953,"I'm going to build my grandson"],[3953,4116,"an entire amusement park."],[4225,4412,"Wow, an entire amusement park"],[4412,4592,"just for Mr. Heston's son?"],[4646,4817,"That boy is really fortunate."],[4879,5034,"My little brad hasn't even been to"],[5034,5159,"an amusement park yet."],[5167,5317,"Dad, you're going to spoil him rotten."],[5392,5580,"It's my grandson we're talking about."],[5580,5714,"If I don't want to spoil him,"],[5714,5793,"who will?"],[5847,5918,"Don't forget about"],[5918,6001,"the amusement park."],[6022,6114,"I'm hanging up."],[6781,6873,"Wow."],[6973,7186,"It looks like you just shoved"],[7190,7357,"an entire toy store in here."],[7369,7449,"What kind of clothes"],[7449,7565,"do you get ur son?"],[7645,7791,"Well, kids at this age"],[7791,7887,"love moving around a lot."],[7899,8045,"So they tend to sweat a lot."],[8087,8224,"Lose cotton fabrics are probably"],[8224,8308,"the most comfortable"],[8308,8362,"for them."],[8441,8571,"He'll be a great father."],[8587,8800,"His son is really lucky to have him."],[8833,8992,"I wonder if Brad's father would"],[8992,9109,"care about him like this."]],"11":[[492,592,"My God."],[592,759,"$10,000."],[759,942,"This toy alone would be enough to pay"],[942,1146,"for Brad's medical fees."],[1146,1267,"Take it."],[1338,1434,"Give it to your son."],[1434,1584,"Oh, no. No."],[1584,1768,"Mr. Heston, it's too expensive."],[1768,1914,"Nonsense."],[2118,2210,"He deserves it."],[2210,2469,"I insist."],[2469,2519,"Speaking of which,"],[2519,2644,"what do you plan on doing with your son"],[2644,2794,"when you come to work?"],[2848,2965,"Daycare center."],[2965,3061,"How about you just bring him in"],[3061,3136,"tomorrow?"],[3136,3236,"Really."],[3236,3432,"Oh, thank you, Mr. Heston."],[3432,3611,"He's a really well-behaved kid."],[3611,3828,"I promise he will not bother anyone."],[3874,3978,"It's a good chance to learn"],[3978,4041,"how to get along"],[4041,4254,"with a seven year old boy."],[4688,4884,"How beautiful."],[5155,5351,"Yeah."],[5647,5876,"Mommy, this place is huge."],[5910,6081,"Yeah it is, here."],[6135,6364,"Can you be a good boy and play"],[6364,6489,"with this toy"],[6489,6706,"that I got you while mommy's working?"],[6727,6815,"And then once mommy's"],[6815,6873,"done working,"],[6873,7132,"we'll go get something yummy to eat. Okay."],[8512,8808,"Your son is absolutely adorable."],[8837,8954,"I've got some chocolate."],[8996,9109,"Do you mind if I give him a treat?"],[9163,9271,"Thank you Wren."],[9271,9405,"But my son's allergic"],[9405,9609,"to milk, so he can't have chocolate."],[9609,9726,"I see."],[9772,9909,"Well, how about I make him a nice"],[9909,10072,"bowl of oatmeal instead?"],[10072,10189,"Without the milk?"],[10189,10310,"That'd be nice."],[10310,10481,"Thank you."],[11169,11277,"Hey Wren can you help me"],[11277,11403,"with something."]],"12":[[3386,3490,"Baby, what happened?"],[3490,3699,"Mommy? Itching."],[3699,3832,"Did you have milk?"],[3832,4012,"I didn't, I just ate the oatmeal"],[4012,4204,"Miss Wren gave me."],[4254,4354,"Adele."],[4408,4529,"Hi."],[4529,4596,"Who gave you permission"],[4596,4667,"to bring your filthy"],[4667,4800,"little Hobo kid to work."],[4842,4975,"Please just move aside."],[4975,5096,"I don't have time for this right now."],[5096,5201,"I'm sorry."],[5288,5430,"Who said that you can leave?"],[5534,5647,"Well, I guess this is what happens"],[5647,5822,"when you raise a fatherless bastard."],[5843,5989,"You don't learn any respect."],[5989,6164,"My son is not a bastard."],[6189,6331,"Oh, please."],[6352,6510,"I read your file."],[6552,6698,"You?"],[6698,6923,"Well, you're just a washed up stray,"],[6923,7032,"dragging around a kid"],[7032,7248,"you had out of wedlock."],[7248,7382,"No home."],[7382,7549,"No husband."],[7607,7862,"I mean, without a dad, your kids only gonna"],[7862,7978,"grow up to be a"],[8008,8262,"good for nothing loser crackhead."],[8291,8483,"You better watch your mouth."],[8483,8508,"Oh."],[8508,8750,"I'm sorry, did I strike a nerve?"],[8750,9042,"Then tell me who's the father?"],[9121,9217,"Huh?"],[9238,9446,"Where is he now?"],[9647,9776,"Mr. Deleon, we've blocked off every street"],[9776,9922,"street and started our search."],[9922,10101,"We promise that within just two days,"],[10101,10256,"we will find your son."],[10256,10326,"Good job."],[10326,10414,"Is Adele's son here?"],[10414,10464,"Yes sir."],[10535,10839,"I see, let's go meet him."]],"13":[[41,208,"Can't name the father"],[208,291,"because you don't even know"],[291,458,"who he is, right?"],[458,604,"Is this some kind of scam?"],[625,746,"Faking an injury at work"],[746,888,"to milk compensation?"],[963,1126,"What kind of mother does that?"],[1126,1388,"Teaching your kid to lie and cheat."],[1388,1559,"Oh, disgusting."],[1559,1697,"I'm not doing this with you."],[1697,1822,"Not in front of my son."],[1822,1910,"We're leaving."],[1910,2039,"Hold on."],[2039,2185,"You still haven't answered me."],[2202,2331,"Who said that you can bring a kid"],[2331,2456,"into Heston's estate?"],[2464,2815,"Mr. Deleon gave me permission directly."],[2911,3086,"Oh, please."],[3086,3290,"You really expect me to believe that?"],[3290,3403,"Why would Heston,"],[3403,3599,"let you bring a kid to work?"],[3649,3891,"You brought your kid here on purpose"],[3891,4029,"because you heard that Heston's"],[4029,4183,"looking for his son."],[4229,4529,"You're trying to pass him off as his."],[4546,4654,"Oh."],[4654,4917,"How low can you go?"],[4917,5134,"So is this some twisted scam?"],[5134,5226,"Are you really dumb enough"],[5226,5438,"to think that that kid is Mr. Deleon's."],[5488,5630,"What? No."],[5630,5747,"I'm not as calculated"],[5747,5914,"as you guys are making me out to be."],[5914,6068,"Oh. Save it."],[6114,6252,"You knew his son would be around"],[6252,6389,"the same age."],[6389,6602,"You brought your boy here"],[6602,6698,"to mess with Heston's"],[6698,6819,"head and try to cash in."],[6927,6994,"You're nothing but a"],[6994,7077,"street rat who's"],[7077,7273,"crawled in hoping for crumbs."],[7394,7545,"Don't talk to my mommy like that."],[7545,7657,"You're mean."],[7674,7786,"Get your hands off of me!"],[7786,7912,"You vile little boy."],[7920,8074,"How dare you push me?"],[8095,8208,"You know, if your mother hasn't"],[8208,8324,"taught you any manners,"],[8362,8612,"then allow me to personally teach you"],[8612,8737,"a lesson."],[9522,9634,"Let my son go."],[9634,9755,"Let go of him!"],[10143,10276,"Mom!"],[10343,10452,"Brad Baby!"],[10639,10748,"Come back!"]],"14":[[162,225,"Mommy!"],[266,312,"Mommy!"],[312,437,"Help me!"],[600,734,"Brad, mummy's coming."],[796,1013,"Brad, baby, mommy's here."],[1301,1405,"This is what you get for"],[1405,1576,"threatening me at the hospital."],[1576,1760,"And for trying to use your kid"],[1760,1947,"to steal Heston from me."],[1947,2035,"Why do we have to work"],[2035,2202,"with such a degenerate?"],[2202,2389,"Ruby, just let him out."],[2389,2515,"If you have something against me,"],[2515,2748,"take it out on me and not my son."],[2781,2898,"This looks like a great opportunity"],[2898,3028,"for you and your little bastard son"],[3028,3161,"to do a little reflecting."],[3161,3219,"Mommy!"],[3219,3307,"Mom! Mom!"],[3307,3445,"Come save me!"],[3549,3636,"Mommy's here,"],[3636,3816,"don't worry baby, don't be afraid."],[4779,4929,"Stop her!"],[5321,5484,"Let go of me!"],[5484,5643,"My son is having an allergic reaction."],[5643,5755,"If he isn't treated in time,"],[5755,5914,"he might die."],[6068,6177,"So what?"],[6177,6377,"His life is worthless anyway."],[6414,6452,"You know,"],[6452,6660,"you should really know your place."],[6660,6810,"This is Heston's home."],[6810,6948,"Your son had no right to"],[6948,7073,"be here in the first place."],[7173,7311,"What are you doing?"],[7565,7678,"Mr. Deleon."],[7678,7786,"My son is inside there,"],[7786,7932,"and he's having an allergic reaction."],[7932,8033,"Please help."],[8033,8120,"Step aside."]],"15":[[37,221,"Baby, open your eyes."],[221,383,"Come on, baby."],[383,529,"All right. Don't worry. We have an epi-pen."],[529,633,"We have an epi-pen"],[729,754,"Come on."],[754,959,"Don't scare mommy, okay?"],[980,1188,"Don't worry. It's fast acting."],[1393,1497,"His breathing's already really"],[1497,1580,"improved."],[1630,1801,"Thank you, Mr. Heston."],[1801,2072,"Thank you for saving my son."],[2072,2198,"For all we know, the little bastard"],[2198,2356,"boy might be faking it."],[2944,3161,"How dare you call my son a bastard?"],[3236,3386,"You,"],[3386,3570,"you little mothe-"],[3832,3949,"First you insulted him"],[3949,4091,"and now you locked him in a closet."],[4091,4212,"Oh, you're lucky"],[4212,4416,"I don't kill you with my bare hands."],[4416,4562,"I dare you to try,"],[4562,4767,"you fucking homeless bitch!"],[4800,5046,"I will do more than mess with your kid."],[5046,5296,"I will fucking end him."],[5321,5426,"There's nothing quite"],[5426,5676,"like motherly instinct or motherly rage."],[5676,5876,"Oh, if you mess with my son again,"],[5876,6131,"you are going to wish you are dead."],[6164,6352,"Oh, now you're fucking asking for it"],[6352,6418,"Adele."]],"16":[[296,437,"Mommy."],[1526,1685,"Heston."],[1685,1810,"Adele brought her child here"],[1810,1935,"without authorization?"],[2006,2202,"Then she and her little hobo kid"],[2202,2423,"started causing a scene."],[2423,2527,"I was trying to educate them"],[2527,2694,"on the concept of manners,"],[2694,2857,"but she hit me."],[2961,3140,"I gave her authorization."],[3244,3382,"Going to educate me too."],[3470,3528,"Well, no."],[3528,3820,"No, that's, that's not what I meant."],[3866,4054,"The kid was throwing a tantrum"],[4054,4279,"and was bothering the staff."],[4308,4433,"You're lying."],[4433,4596,"My kid never threw a tantrum."],[4596,4800,"He was playing nicely the whole time."],[4800,4934,"And then he accidentally had milk,"],[4934,5063,"which he is allergic to."],[5063,5255,"And he came to find me."],[5267,5513,"Shut up!"],[5513,5739,"No one is talking to you."],[5780,5922,"Ruby, this is my house."],[5985,6122,"I don't recall giving you authority."],[6122,6260,"Know your place."],[6289,6448,"Oh, Adele."],[6448,6585,"This is all my fault."],[6585,6794,"Your son ate the oatmeal I made,"],[6794,6915,"but I didn't put any milk in it."],[6915,7007,"I swear."],[7007,7140,"My child has allergies,"],[7140,7349,"and I'm very careful."],[7349,7499,"It's okay, I believe you."],[7561,7674,"But now the question is."],[7799,8016,"How did milk get in Brad's oatmeal?"],[8016,8170,"What are you asking me for?"],[8208,8425,"Your son's only in this situation"],[8425,8591,"because you weren't watching him."],[8721,8921,"How dare you accuse me without evidence?"],[8921,9146,"You know I can sue you for defamation."],[9146,9392,"If I remember correctly."],[9392,9459,"In the kitchen,"],[9459,9588,"there's a surveillance cam."],[9588,9684,"Why don't we check it,"],[9855,9989,"Please?"],[10035,10143,"Oh, you're really treating this place"],[10143,10322,"like home, aren't you?"],[10322,10460,"Like they're going to check the footage"],[10460,10581,"just because you said so."],[10581,10664,"Sam,"],[10689,10848,"check the surveillance footage immediately."]],"17":[[930,1021,"Ruby,"],[1088,1213,"you abused and nearly killed"],[1213,1397,"a child on my property."],[1405,1518,"From now on, you're banned"],[1518,1639,"from setting foot in this house."],[1639,1735,"As far as the partnership"],[1735,1872,"between our families."],[1872,1993,"That's terminated."],[1993,2277,"No, no, no."],[2277,2485,"Heston, you can't do this."],[2515,2577,"If you do this,"],[2577,2877,"my entire family will suffer huge losses."],[2919,3023,"And you, too."],[3023,3123,"Your quarterly paychecks"],[3123,3207,"will be withheld."],[3269,3457,"You're lucky I don't fire you."],[3474,3632,"If this ever happens again,"],[3732,3853,"I will."],[3970,4079,"Heston."],[4112,4233,"Please consider the friendship"],[4233,4366,"between our families."],[4391,4475,"Okay."],[4475,4642,"Please forgive me."],[4642,4758,"Just this one time."],[4758,4896,"I'm begging you."],[4929,5042,"Don't touch me."],[5109,5176,"I don't want someone as"],[5176,5317,"vile as you near me."],[5434,5576,"Mommy! My arm!"],[5576,5693,"It hurts."],[5693,5797,"Okay, baby."],[5797,5860,"Hold on. Okay."],[5860,6026,"We'll get you to the hospital soon."],[6026,6252,"Sam, get the car immediately."],[6252,6443,"Come on."],[6806,6881,"Why is it that"],[6881,7115,"everybody's got a grandchild but me?"],[7273,7478,"My little, precious little grandson."],[7478,7670,"Where are you?"],[7761,7878,"Mr. Chairman, you've been sitting here"],[7878,8062,"for the past three days."],[8062,8266,"You've only met the boy once."],[8266,8416,"Even if you saw him,"],[8416,8587,"you'd recognize him again?"],[8587,8821,"Who thinks I wouldn't recognize him?"],[8821,9067,"My grandson."],[9067,9196,"I still recognize him"],[9196,9401,"in a sea of children."],[9401,9655,"He's my flesh and blood."],[9655,9880,"Doctor, please save my son."]],"18":[[29,87,"What happened?"],[87,191,"He accidentally had milk"],[191,312,"which he's allergic to."],[312,487,"I think his wound from the car accident"],[487,675,"is getting infected."],[675,821,"Look at that poor little guy."],[821,1021,"How did his face swell up like that?"],[1021,1130,"How could you be so careless?"],[1130,1334,"Hurry up and bring him to the exam room."],[1397,1676,"What a shameful thing to have happened."],[1676,1751,"Where's his father?"],[1751,1914,"Shouldn't he be here?"],[1914,2068,"How irresponsible."],[2118,2252,"If that was my grandchild,"],[2252,2377,"I had a whole army"],[2377,2519,"of people at the ready."],[2535,2698,"Of course you would, Mr. Chairman."],[2698,2932,"But please, sir, don't get too excited."],[2932,3128,"It's not good for your heart."],[3128,3286,"Precious little grandson."],[3286,3461,"Where are you?"],[3636,3691,"Oh, no."],[3691,3745,"Um, miss."],[3745,3807,"The gentleman's heart again."],[3807,3845,"Please."],[3845,3974,"Nurse! Help! Please!"],[3974,4091,"Quick!"],[4091,4191,"Yes!"],[4992,5176,"Brad baby, how are you feeling?"],[5176,5301,"Does anything hurt?"],[5301,5409,"Mommy! I'm better now."],[5751,5943,"But I'm a little hungry."],[5943,6106,"Thank goodness."],[6106,6214,"What do you want to eat?"],[6214,6514,"Mommy will buy you anything you want."],[6531,6581,"Mommy,"],[6581,6765,"can we go to that restaurant again?"],[6765,6940,"Of course baby."],[6940,7286,"I'll get you a super duper big steak."],[7394,7528,"But there are lots of people"],[7528,7611,"at the restaurant,"],[7611,7803,"and we don't want to make you sicker,"],[7803,8028,"so you have to wear the mask. Okay?"]],"19":[[892,963,"Hi."],[963,1146,"I would like to order your surf and turf"],[1146,1222,"thank you."],[1255,1347,"Move along."],[1376,1568,"Both of you, get out."],[1872,1935,"Sorry,"],[1935,2035,"we're all out."],[2114,2231,"Why was everyone else able"],[2231,2331,"to order the surf and turf,"],[2331,2590,"but when I asked. You're all out."],[2590,2706,"Because at our restaurant,"],[2706,2907,"we don't serve street folks."],[2940,3015,"What?"],[3015,3103,"On what basis"],[3103,3261,"do you have to treat us differently?"],[3261,3461,"Because you don't belong here?"],[3478,3595,"The two of you are bringing down"],[3595,3703,"the status of our restaurant"],[3703,3858,"just by sitting here."],[3895,3962,"Look at you."],[4008,4245,"Two dirty, low class beggars."],[4245,4404,"And do you want me to serve you?"],[4416,4521,"Keep dreaming."],[4600,4817,"I came in as a paying customer."],[4913,5005,"Why does my status"],[5005,5105,"have to do with anything?"],[5105,5180,"Where's your manager?"],[5180,5292,"I want to talk to them."],[5292,5463,"As if I'm going to lose my job."],[5463,5605,"Wasting the manager's time,"],[5651,5743,"for you."],[5743,5834,"Chloe."],[5851,5947,"Come here and help me"],[5947,6143,"kick out these homeless losers."],[6310,6427,"Don't bully my mommy."],[6489,6669,"Oh, wow. Look at this little pipsqueak."],[6669,6748,"How dare you threaten me,"],[6748,6861,"you little shit!"],[7173,7315,"How dare you raise your hand"],[7315,7407,"at my son!"]],"20":[[375,454,"Chloe."],[454,517,"Get her."],[1176,1226,"Oh!"],[1226,1526,"Get these bums out of here."],[1534,1622,"Look at you."],[1672,1931,"You look just like a drowned sewer rat."],[2052,2193,"Get out of my way!"],[2193,2402,"Let go of my son!"],[2402,2489,"Brad!"],[2544,2731,"That little shit! Pinched me!"],[2744,2865,"Brad, don't be afraid Mommy's here."],[2865,3032,"Mommy will help you, okay?"],[3032,3228,"Mommy! No."],[3228,3365,"I'll go get help."],[3465,3766,"Oh, let go of me!"],[3812,3983,"Please help me!"],[4070,4195,"What are you doing?"],[4208,4479,"How dare you, you little bitch."],[4512,4746,"I will kill you."],[4792,5000,"Help. Help my mom's hurt."],[5430,5663,"Mister, please save my mommy."],[5730,5868,"I'll ask again."],[5868,6047,"Are you going to apologize?"],[6214,6385,"You scums are the one that"],[6385,6456,"have to apologize."],[6456,6560,"I told you what will happen"],[6560,6648,"if you don't apologize."],[6648,6819,"You dumb bitch!"],[6923,7107,"Stop it right there!"],[7173,7328,"What the hell do you think you're doing?"]],"21":[[0,250,"Someone better start talking now."],[337,475,"Hey boss so,"],[475,604,"you've always said that you don't want"],[604,721,"any riffraff in the restaurant."],[721,855,"And so we were only"],[855,988,"abiding by your wishes,"],[988,1238,"and they were soiling the place"],[1238,1413,"with their lifestyle."],[1413,1472,"You people"],[1472,1655,"are the ones soiling this place."],[1655,1822,"You four,"],[1822,1951,"you're all fired."],[1951,2164,"No! Please, Mister Deleon."],[2185,2435,"No, no, please, Mr. Deleon,"],[2435,2502,"we were wrong."],[2502,2631,"Just please forgive us."],[2631,2806,"Not a chance. Guards!"],[2806,2877,"Get them out of here!"],[2877,3044,"Take them to the police station."],[3044,3178,"They must pay for the crimes"],[3178,3294,"they committed."],[3294,3461,"No, no please."],[3461,3607,"Mr. Deleon."],[3820,3970,"Hey."],[3970,4099,"It's okay."],[4099,4250,"Brad's with the guards."],[4291,4404,"Oh, Mr. Deleon,"],[4404,4704,"thank you so much for saving us again."],[5668,5822,"Let's get you cleaned up."],[6448,6627,"Wow."],[6840,7011,"This dinner's my way of apologizing"],[7011,7140,"for the mess that happened earlier."],[7282,7386,"It's my fault for not"],[7386,7545,"training my employees better."],[7582,7653,"I'm so sorry"],[7653,7795,"you two had to go through that."],[7849,8033,"You're like a superhero, mister."],[8033,8116,"I've always wanted"],[8116,8379,"someone like you to be my dad."],[8379,8512,"Can I call you dad?"],[8608,8833,"I mean, that might be nice, right?"],[8908,9117,"Hey, I bet we even look the same too."],[9238,9271,"I mean,"],[9271,9334,"I think it's safe"],[9334,9513,"to take his mask off, right?"],[9513,9659,"I still don't even know what you look like."],[9672,9818,"Mommy, I want to eat steak."],[9905,10060,"Can I take off my mask?"],[10060,10218,"Yeah, baby. Go for it."]],"22":[[316,371,"Oh my God."],[479,646,"I think his stitches opened up."],[704,846,"Come on baby."],[1046,1188,"How could you be this careless?"],[1317,1443,"I've seen your face for far"],[1443,1564,"too many times lately."],[1564,1614,"It was hard enough"],[1614,1730,"trying to stabilize his condition."],[1730,1943,"And now the wound is open again."],[2077,2273,"This is all my fault."],[2314,2552,"I failed him in every step of the way."],[2585,2715,"He's known nothing but struggle"],[2715,2823,"his entire life"],[2865,2994,"and now this."],[3653,3858,"Adele, don't blame yourself."],[3858,4020,"You're doing the best that you can."],[4020,4124,"No."],[4124,4358,"Brad suffered so much because of me."],[4358,4491,"He was clearly hurt,"],[4491,4654,"but I was too stubborn."],[4717,4946,"And now his injuries are worse."],[5163,5388,"No matter how hard I try,"],[5455,5651,"it's always one step forward"],[5651,5801,"and two steps back."],[5855,6156,"He is the best kid in the entire world."],[6306,6539,"He deserves a better mom than me."],[6573,6744,"You're a phenomenal mother."],[6744,6840,"Don't lie to yourself"],[6840,6973,"and think that you're not."],[7419,7653,"Does my son's mother love him this fiercely?"],[7653,7703,"Does she do"],[7703,7811,"everything she can for him"],[7811,8024,"like Adele does for Brad?"],[8024,8174,"Hey, listen to me."],[8174,8299,"I'm going to get the best doctor"],[8299,8458,"in this hospital to treat Brad."],[8533,8608,"He's going to recover,"],[8608,8687,"and he's going to be back"],[8687,8850,"stronger and better than ever."],[8858,9117,"Mr. Deleon, thank you so much."],[9117,9413,"Your kindness means the world to me."],[9459,9547,"We managed to get the bleeding"],[9547,9730,"under control. He's in the clear now."],[9793,9909,"Oh my gosh."],[9943,10114,"Did you hear that? Brad's alright."]],"23":[[913,1209,"Adele, your son's a real rock star."],[1393,1472,"Don't forget that."],[1472,1564,"You're lucky."],[1726,1814,"I'm so sorry."],[1814,1964,"I need to attend to some other"],[1964,2064,"business here at the hospital."],[2064,2118,"Okay?"],[2227,2306,"I'll see you later."],[2686,2765,"I've already been informed"],[2765,2844,"that Brad's follow up"],[2844,2977,"treatment will be personally overseen"],[2977,3090,"by the hospital director."],[3090,3299,"The director? That's fantastic."],[3349,3461,"Where's the director now?"],[3461,3611,"I'll take Brad to go see him."],[3611,3712,"He's in the VIP clinic,"],[3712,3966,"attending to a very important patient."],[4008,4212,"Great. I'll take Brad to see him."],[4237,4312,"Deep breath."],[4758,4825,"Once more."],[5380,5447,"Your heart rate"],[5447,5684,"has calmed down tremendously."],[5814,5947,"But in the future."],[5947,6247,"Try not to get so excited."],[6289,6460,"How can I not get excited?"],[6460,6560,"Those chumps have been"],[6560,6631,"searching for my"],[6631,6806,"grandson for so long."],[6806,6965,"And all they've found out"],[6965,7140,"is that his name is Brad Moore."],[7140,7282,"And nothing else!"],[7282,7382,"Mr. Chairman, now that we have his"],[7382,7603,"name, it's only a matter of time"],[7603,7728,"until we find him."],[7774,7878,"I'm positive we'll hear"],[7878,7987,"good news soon."],[7987,8170,"I will award whoever finds my"],[8170,8333,"grandson, $100,000."],[8408,8637,"No. $1 million."],[8787,8879,"Director Lawson."],[8879,8979,"A woman and her son are"],[8979,9054,"here to see you."],[9150,9238,"I see."],[9238,9426,"Whoa!"],[9480,9584,"Brad. Come on, baby."],[9584,9655,"Let's sit down."],[9951,10001,"Mommy."],[10001,10118,"This place looks nice."],[10118,10210,"Can we go inside?"],[10260,10314,"Shh."],[10314,10402,"Don't fuss. Okay?"],[10402,10548,"We'll wait here for the director."],[10581,10727,"Patience, baby."],[10727,10852,"Who's speaking out there?"]],"24":[[37,200,"Mr. chairman, your condition is"],[200,325,"stabilized now."],[325,504,"Please rest and excuse me"],[504,667,"while I go check on another patient."],[925,1046,"So you're Brad Moore?"],[1046,1234,"Yep. Hello, director. Larry."],[1372,1509,"What a polite young man."],[1626,1705,"The wound is no longer"],[1705,1797,"a major problem."],[1826,2022,"But don't forget to do the follow ups."],[2072,2331,"Yeah. Thank you. Director."],[2331,2506,"Here's an estimated cost of your son's"],[2506,2602,"follow ups."],[2852,2944,"Don't worry."],[2944,3107,"Mr. Heston has already instructed"],[3107,3215,"me to bill him."],[3236,3407,"Mr. Deleon has already helped us"],[3407,3499,"so much."],[3499,3603,"I can't let him spend any more"],[3603,3707,"money on us."],[3707,3787,"Actually,"],[3820,4054,"I would like to pay the bill myself."],[4104,4337,"But could I have some more time?"],[4337,4408,"Of course."],[4479,4625,"But hospital administration"],[4625,4742,"may not be so forgiving"],[4742,4884,"if you're late on your payments."],[4884,5009,"No late payments."],[5059,5196,"Thank you doctor."],[5267,5342,"Good job, buddy."],[7094,7236,"Boss, you gave Adele time off to"],[7236,7365,"spend time with her son."],[7399,7524,"What's she doing selling flowers"],[7524,7607,"on the street?"],[7691,7836,"Sam, I need you to"],[7836,7941,"do something for me."],[8316,8412,"Yes, sir."],[8412,8483,"Understood."],[9013,9146,"How much are the flowers?"],[9200,9380,"It's five for one bundle and"],[9380,9476,"ten for two."],[9476,9559,"I want them all."],[9584,9726,"The whole flower bouquet."],[10018,10135,"Keep the change."],[11023,11115,"Brad."],[11115,11277,"Mommy's done early."],[11277,11378,"An angel came by and"],[11378,11524,"bought all the roses."],[11569,11678,"Mommy's going to come home and"],[11678,11778,"we can spend the rest"],[11778,11886,"of the day together."]],"25":[[513,608,"Is that Adele?"],[642,742,"How many part time jobs"],[742,821,"does she have?"],[913,1084,"Go check on her son in the hospital."],[1555,1772,"Yeah so we can have a fun night."],[2410,2510,"Mr. Deleon."],[2510,2610,"You're finally here."],[2652,2765,"We've been waiting forever."],[2765,2806,"Not now."],[2806,2877,"Sweetie."],[3236,3378,"All right, Adam, get to the point."],[3378,3495,"Why did you call me down here."],[3611,3832,"Well, obviously, we need to discuss"],[3832,3933,"the partnership"],[3933,4037,"between our families."],[4149,4262,"And also,"],[4308,4404,"when are you going to let Ruby"],[4404,4504,"off the hook, man?"],[4579,4717,"Just get back together with her."],[4742,4771,"Adam."],[4771,4884,"We were never even together"],[4884,4992,"in the first place."],[5109,5280,"And for the millionth time,"],[5280,5397,"I'm not interested in Ruby."],[5505,5568,"At this point,"],[5568,5659,"I don't know which one of you"],[5659,5764,"struggles to understand"],[5764,5880,"the word \"no\" more,"],[5901,6051,"but there's no chance."],[6114,6189,"So lay off."],[6189,6252,"Whatever."],[6302,6360,"Your loss."],[6452,6489,"Here."],[6644,6735,"Drink's on me."],[6990,7290,"Let me apologize on behalf of Ruby."],[7461,7528,"Cheers."],[7590,7653,"Cheers."]],"26":[[208,383,"What is she doing here?"],[771,846,"Serving drinks."],[846,913,"Are you?"],[1001,1138,"Oh, well, I shouldn't be surprised."],[1138,1272,"This is a far more fitting job"],[1272,1384,"for someone like you."],[1543,1689,"Learn some tact and get the hell"],[1689,1780,"out of Heston's house"],[1780,1901,"before you embarrass yourself."],[1926,1964,"Okay?"],[1993,2135,"If you think you can seduce him"],[2135,2206,"just because you're"],[2206,2298,"under the same roof."],[2335,2410,"Think again."],[2448,2552,"You're dreaming."],[2610,2852,"You see, families like ours"],[2890,2965,"are elite."],[3048,3165,"Superior."],[3370,3482,"Do you really think he'd consider"],[3482,3632,"a low class homeless skank"],[3632,3695,"like you?"],[3799,3945,"But he'd consider you?"],[3974,4062,"Didn't Mr. Deleon"],[4062,4183,"reject you the other day?"],[4183,4375,"Shut up, you stupid homeless bitch!"],[4412,4617,"I'm warning you. Back off!"],[4617,4679,"He's mine."],[4846,4975,"Do you understand that?"],[5017,5150,"My Heston."],[5259,5367,"We're about to get engaged."],[5367,5668,"So if you try to seduce him again,"],[5701,5914,"I'll make sure you regret it."],[5914,6051,"My Heston."],[6051,6193,"When did he become yours?"],[6193,6331,"Oh, you sound like a possessive"],[6331,6435,"teenage girl."],[6435,6619,"And you sound defeated. Bitch."],[6698,6810,"Just wait and see."],[6898,7048,"He'll be mine soon enough."],[7315,7390,"Heston?"],[7465,7640,"Heston, I'm right here."],[7640,7732,"Don't touch me."],[7849,7941,"Heston!"],[7941,8124,"You don't look too well. Okay?"],[8187,8370,"Let me take you somewhere to rest."],[8370,8429,"No."]],"27":[[37,250,"Never expected Mr. Deleon to have"],[250,417,"such poor taste in women."],[417,508,"Who drugged me?"],[679,779,"Was it you?"],[938,1076,"Don't be silly."],[1155,1272,"Why would I do that?"],[1359,1551,"I only want one thing from you."],[1701,1839,"Trying to find your son..."],[1989,2097,"is like looking for a needle"],[2097,2252,"in a haystack."],[2252,2377,"I can help you."],[2494,2627,"I can give you a child."],[2627,2711,"Heston."],[2857,3061,"Just get the fuck away from me."],[3199,3340,"He said don't touch him."],[4041,4133,"Bitch!"],[4170,4333,"This isn't fucking over."],[6043,6181,"Mr. Heston."],[6181,6364,"What? What are you doing?"],[6406,6531,"Adele, tell me you don't want this,"],[6531,6619,"and I'll stop."],[6723,6819,"Tell me you don't feel the"],[6819,6927,"connection, too."],[6969,7086,"I swear to God I've met you"],[7086,7190,"in another life."],[7261,7378,"I need to be close to you."],[7891,7982,"Mommy."],[8041,8166,"He's given me and Brad"],[8166,8333,"exactly what we need."],[8333,8416,"This time,"],[8512,8641,"I'll return the favor."]],"28":[[1034,1130,"Anything that happened"],[1130,1205,"last night. Don't worry."],[1205,1255,"I'm going to take"],[1255,1401,"full responsibility for it."],[1559,1655,"You won't have anything"],[1655,1822,"to take responsibility for."],[1964,2022,"What?"],[2106,2168,"Adele."],[2252,2314,"Adele."],[2398,2540,"I just don't want whatever this is"],[2540,2590,"to end."],[2644,2715,"Tell me what you want."],[2715,2865,"I'll get it for you. Anything."],[2865,2965,"Mr. Heston, I don't want"],[2965,3053,"or need anything."],[3053,3290,"Let's just forget this happened, okay?"],[3440,3636,"No. Adele, wait."],[3799,4012,"She... she just ran away."],[4225,4350,"Did I say something?"],[4400,4517,"Did I do something?"],[4633,4763,"Was I a bad lay?"],[4959,5242,"No. Not a chance."],[5488,5613,"Dear God,"],[5638,5834,"please bring my dear grandson back"],[5834,5939,"to my side."],[5943,6051,"Oh, my."],[6072,6289,"Miss him so dearly."],[6289,6402,"Did I come at a bad time?"],[6448,6506,"Shh."],[6531,6644,"Don't interrupt."],[6719,6852,"I mean, the big guy upstairs are"],[6852,6956,"discussing how to get"],[6956,7102,"my grandson back."],[7165,7290,"I see."],[7344,7486,"Still no luck with the search."],[7486,7624,"Don't even get me started."],[7720,7803,"But since"],[7803,8024,"the alien blood runs through his veins,"],[8112,8233,"I can sense him."],[8274,8441,"I'm sensing you're losing it, Frank."],[8683,8842,"Sir, Brad Moore was discharged"],[8842,8950,"from the hospital yesterday."],[8950,9009,"His mother wanted us"],[9009,9121,"to give her thanks."],[9192,9255,"Thank you."],[9321,9459,"Did you say Brad Moore?"]],"29":[[25,196,"Yes. Brad Moore."],[196,321,"He's a young patient of mine."],[383,517,"He's around seven years old."],[579,725,"Came in with a pretty nasty gash"],[725,796,"on his arm,"],[796,946,"and he got infected."],[1142,1263,"Heston, look at him."],[1338,1505,"He's a spitting image of you."],[1639,1776,"The Lord has answered"],[1776,1876,"my prayers."],[1943,2047,"You don't by any chance"],[2047,2202,"have his phone number, do you?"],[2289,2494,"Even better, his address?"],[2506,2598,"Absolutely."],[2857,2998,"Here's his contact information."],[2998,3119,"Fantastic, all right."],[3119,3207,"Look out! Doc!"],[3232,3370,"I'm going to bring my grandson home."],[3370,3407,"But..."],[3407,3516,"- Look out! - Frank! Frank!"],[3516,3624,"- Frank, wait! Wait! - Move!"],[3828,4024,"Brad, we finally have a home, baby."],[4074,4170,"We can say goodbye"],[4170,4258,"to this tent."],[4279,4475,"Mommy, can I have my own room now?"],[4512,4604,"Of course."],[4633,4725,"Your room is going to be filled"],[4725,4913,"with lots of awesome toys."],[4959,5080,"My baby's never going to sleep"],[5080,5188,"on the streets again."],[5188,5284,"Yay!"],[5430,5513,"Let's go!"],[5910,6001,"We did it!"],[6001,6085,"Come here."],[6635,6790,"This place is awesome."],[6790,7044,"It's huge. I love it."],[7069,7186,"After meeting Heston,"],[7186,7307,"my life has only gotten"],[7307,7457,"better and better."],[7503,7615,"You stay here and play."],[7615,7691,"Mommy's going to go make you"],[7691,7770,"a snack."],[8500,8646,"Mom, your phone's ringing."],[8733,8842,"Who is it?"],[8892,9021,"Can you help me answer it?"],[9096,9175,"Hello?"],[9175,9296,"Mommy can't come to the phone"],[9296,9384,"right now."],[9421,9576,"Brad, tell your mommy"],[9576,9697,"it's an emergency."],[9743,9876,"It's your grandpa on the phone."]],"30":[[45,225,"My precious grandson."],[279,379,"Grandpa's been looking"],[379,508,"all over for you."],[521,667,"I don't have a grandpa."],[667,771,"You shouldn't lie."],[771,880,"You sound old."],[880,1055,"You should know right from wrong."],[1092,1259,"Well, you do now."],[1317,1493,"You're a clever little one, aren't you?"],[1576,1726,"It seems like you do have the"],[1726,1876,"Deleon gene."],[1947,2102,"I can't wait to meet you."],[2139,2298,"Matter of fact, I'm on the way"],[2298,2435,"to your house right now."],[2744,2936,"Hello, little hobo boy."],[2936,3078,"Good thing you're home."],[3307,3549,"Well, fancy meeting you here."],[3845,3933,"Give me that."],[4033,4124,"Get down."],[4358,4412,"Hello?"],[4512,4575,"Brad."],[4654,4721,"Are you there?"],[4783,4921,"Ruby, what the hell are you doing"],[4921,4971,"in my house?"],[4971,5084,"Leave my son alone."],[5380,5588,"Ruby, have you lost your damn mind?"],[5668,5739,"This isn’t good!"],[5739,5855,"My grandson's in danger."],[5855,5926,"Step on it."],[6031,6131,"I should call Heston."],[6131,6231,"Have him hurry over there."],[6456,6589,"We're sorry, but the number you have"],[6589,6715,"dialed is currently busy."],[6748,6810,"Please try..."],[6840,6902,"Shit."],[6902,7023,"How can he drop the ball at a"],[7023,7148,"critical moment like this?"],[7674,7766,"Drive faster."],[7811,7957,"Whoever tries to mess with my"],[7957,8229,"grandson shall witness my wrath."]],"31":[[4,79,"Guess what?"],[204,342,"I just bought this entire"],[342,437,"apartment complex."],[517,571,"Yay!"],[734,846,"Now I just want you and your little"],[846,925,"bastard son to get the hell"],[925,1021,"off my property."],[1021,1159,"The landlord hasn't notified me"],[1159,1201,"about this."],[1201,1326,"I'll have to check with him first."],[1326,1526,"Oh! Stop blabbering."],[1555,1768,"This is my property now. Okay?"],[1797,1931,"If I tell you to scram,"],[1981,2064,"then you should leave."],[2089,2264,"Okay. Get moving."],[2339,2464,"Throw these pieces of trash out"],[2464,2560,"where they belong."],[2669,2790,"They outnumber us."],[2790,2915,"I can't be stubborn here."],[2915,3078,"Not after what happened last time."],[3174,3236,"Wait."],[3319,3449,"We'll leave on our own."],[3524,3712,"Oh. Oh, wonderful."],[3712,3837,"You know, I am so glad that we could"],[3837,3937,"come to an agreement."],[3991,4175,"Oh, but just, one more thing."],[4208,4379,"I actually don't just want you to leave"],[4379,4483,"this apartment."],[4558,4700,"I want you to leave the city,"],[4775,4859,"and Heston."],[4884,5030,"What? Leave the city?"],[5067,5205,"What good does that do for you?"],[5238,5363,"Oh, well, you know, out of sight,"],[5363,5422,"out of mind."],[5626,5768,"I knew Heston before you."],[5851,5922,"You!"],[6001,6118,"Well, you're just some whore"],[6118,6302,"who had a child out of wedlock."],[6339,6573,"How dare you sleep with him?"],[6606,6756,"You're the one who drugged him."],[6798,6911,"That would have never happened"],[6911,7065,"if it weren't for your little schemes."],[7094,7269,"I don't care about any of your stupid"],[7269,7394,"excuses, okay?"],[7411,7695,"You and your stupid hobo kid are in my"],[7695,7912,"way, toying with Heston's emotions."],[7991,8062,"Isn't this all because you're"],[8062,8162,"trying to seduce him?"],[8179,8229,"What?"],[8266,8429,"I never seduced him."],[8441,8541,"You know what? I actually don't give a"],[8541,8712,"flying fuck what you have to say."],[8712,8858,"You're still in my way."],[9000,9096,"If you want to live,"],[9225,9355,"then get the hell out of the city."],[9413,9505,"Once and for all."],[9663,9718,"Fine."],[9793,9880,"We'll leave right now."]],"32":[[0,150,"Options there..."],[183,258,"And..."],[258,354,"Hold on a second."],[375,429,"Hey, dad."],[483,579,"Why the hell didn't you"],[579,675,"pick up your phone?"],[679,813,"Hurry up and get over here."],[813,963,"I just found my grandson,"],[963,1113,"and he's in danger."],[1126,1197,"What?"],[1317,1409,"I'm on my way."],[2114,2373,"Mommy, do we have to leave?"],[2431,2581,"We just got here."],[2581,2731,"I have my own room."],[2927,3073,"Sometimes, baby,"],[3073,3219,"when things don't go in your favor,"],[3219,3324,"you just have to go."],[3399,3482,"So let's get out of here"],[3482,3566,"and we'll make things work."],[3566,3645,"Okay?"],[4162,4279,"Adele."],[4433,4529,"Not so fast."],[4583,4713,"What else do you want?"],[4746,4867,"You need to compensate me"],[4867,5005,"for my propertie's cleaning fees"],[5005,5130,"and depreciation."],[5155,5251,"It smells."],[5267,5526,"Your filth is all over my property."],[5551,5701,"What are you talking about?"],[5730,5851,"It hasn't even been one day"],[5851,5930,"since we moved in."],[5930,6001,"There's nothing to"],[6001,6131,"compensate you for."],[6239,6331,"You're insane."],[6364,6531,"And I don't care."],[6656,6790,"If you don't want to pay up."],[6810,6894,"Then fine."],[6940,7023,"I'll let it go."],[7044,7148,"If..."],[7269,7432,"your filthy hobo son"],[7432,7782,"kneels and licks my shoes."],[7803,7999,"Ruby. That's too far."],[7999,8145,"Then pay up. Broke bitch."],[8299,8412,"Shake her down."],[8412,8537,"Bring me every single cent"],[8537,8646,"you find on her."],[8917,9117,"No! Let me go!"],[9150,9288,"I said let me go!"],[9363,9488,"Baby, it's okay."],[9522,9580,"No!"],[9701,9826,"You evil witch!"],[9826,9964,"Let go of my mommy!"],[9984,10047,"Ew!"],[10072,10306,"Get off of me, you nasty little shit!"],[10356,10531,"I haven't even gotten to you yet,"],[10531,10664,"but it looks like you"],[10664,10785,"need another lesson."]],"33":[[12,91,"Don't touch him, Ruby."],[91,246,"He just got out of the hospital."],[287,437,"If it's money you want, fine."],[437,525,"I'll give it to you."],[550,679,"Oh, so now you want to"],[679,771,"talk about money?"],[771,921,"Too late. Bitch!"],[921,1142,"God, please, just let him go."],[1180,1284,"You're gonna hurt him."],[1313,1413,"If you don't want your son to"],[1413,1501,"kneel down,"],[1568,1634,"then fine."],[1651,1914,"But now you have to beg in his place."],[2018,2089,"Come on."],[2147,2214,"Beg."],[2289,2435,"If you do the job well enough."],[2448,2594,"I'll consider letting him go."],[2594,2648,"Mommy!"],[2648,2773,"No! Don't do it!"],[2882,2957,"Well,"],[3069,3282,"are you gonna get on your knees?"],[3403,3490,"No?"],[3582,3661,"Fine."],[3853,3903,"Wait."],[3903,3991,"I'll do it."],[4033,4079,"Mommy!"],[4079,4220,"No! Don't do it!"],[4362,4533,"Please, Ruby."],[4558,4646,"Just let him go."],[4646,4738,"You're gonna hurt him."],[4738,4892,"Didn't think you'd live to see the day,"],[4892,4938,"huh?"],[4988,5084,"You filthy,"],[5113,5472,"disgusting, worthless street rat."],[5472,5772,"Please, just let my son go."],[5780,5930,"Dream on."],[5976,6147,"I will never let this little bastard go."],[6147,6322,"Even if you beg me a thousand times."],[6385,6493,"Why you ask?"],[6552,6681,"Because I want you to taste"],[6681,6948,"what it's like to lose someone you love."],[7582,7649,"No!"],[7728,7828,"What in heaven's name do you think"],[7828,7982,"you're doing?"],[8028,8224,"You have mess with the wrong kid."],[8316,8583,"And now you're going to pay."],[8621,8729,"My precious grandson."],[8854,8983,"Are you hurt anywhere?"]],"34":[[112,375,"How dare you hurt my grandson?"],[550,709,"Your,"],[709,838,"grandson?"],[942,1030,"Frank."],[1030,1217,"Sir, respectfully."],[1217,1338,"What are you talking about?"],[1338,1426,"I'm telling you,"],[1426,1730,"he is the sole heir to my family."],[1814,1997,"And if you mess with him,"],[2027,2202,"you're messing with me."],[2243,2544,"Oh, I oh, no, sir, this."],[2615,2831,"This isn't what it looks like."],[2831,3174,"You see, I bought this apartment complex."],[3240,3449,"I was simply asking them to leave."],[3465,3582,"She's a liar."],[3582,3724,"She hurt me."],[3753,3895,"You kicked us out."],[3895,4037,"And you grabbed Brad's arm, knowing"],[4037,4195,"he was clearly hurt."],[4204,4350,"Oh, you even tried to hurt him?"],[4358,4637,"You vile, vicious woman."],[4637,4696,"Sir."],[4850,5046,"Our families are old friends."],[5084,5246,"You're not seriously going to believe"],[5246,5451,"this street woman over me."],[5472,5697,"This woman is the mother of my"],[5697,5805,"grandson."],[6022,6126,"I think maybe it's time"],[6126,6277,"to call your father"],[6277,6343,"and sever"],[6343,6581,"all of our business relationship."],[6585,6752,"No, no, please."],[6752,7102,"Please, sir, I am so sorry I was wrong."],[7111,7386,"Please don't do this to us."],[7386,7465,"One condition."],[7574,7686,"She and the boy stay"],[7686,7987,"here for a year, rent free."],[8066,8174,"Fine."],[8174,8370,"Okay, great."],[8370,8558,"Now you leave"],[8558,8650,"and don't come near"],[8650,8908,"my grandson ever again."],[9392,9605,"Oh, my crew,"],[9672,9918,"my precious little grandson."],[9943,10101,"Let me hug you."],[10126,10201,"Who are you?"],[10201,10347,"And what do you want with my son?"],[10347,10581,"Your son is my flesh and blood."],[10664,10781,"I'm his grandfather."]],"35":[[517,738,"Proof is in the pudding."],[838,971,"Brad."],[1105,1255,"Meet your grandfather."],[1255,1397,"Come here, kiddo."],[1397,1543,"Let me hug you."],[1793,1914,"Oh."],[2135,2235,"Grandpa?"],[2235,2369,"I have a grandpa."],[2369,2560,"Yes, my dear grandchild"],[2560,2652,"and grandpa"],[2652,2861,"finally found you."],[2861,3048,"Come on, let's go meet your father."],[3048,3144,"I don't want to."],[3144,3303,"I want to be with my mommy."],[3328,3516,"Oh your mommy can come too."],[3586,3699,"Miss Adele, please."],[3699,3874,"Will the two of you come with me?"],[3883,4141,"I don't even know who Brad's father is."],[4141,4362,"He's a stranger."],[4362,4592,"It's just a lot for us to take in."],[4629,4850,"I understand your hesitation."],[4934,5159,"Perhaps we should start slowly."],[5284,5397,"It would be my pleasure"],[5397,5593,"to provide some necessities"],[5593,5834,"and some toys for Brad."],[5935,6181,"It sounds too good to be true."],[6181,6318,"This gentleman doesn't"],[6318,6548,"seem like a bad person."],[6581,6765,"That's very generous of you, sir."],[6898,7094,"Brad and I would be happy to accept."]],"36":[[45,258,"Brad you're part of our family now."],[325,504,"You're the sole heir to our empire."],[554,775,"All of our businesses,"],[775,1080,"properties, yachts, everything."],[1317,1434,"Come on son."],[1434,1539,"Let me show you all the toys"],[1539,1780,"grandpa bought for you."],[1818,1956,"Come on keep going."],[1956,2139,"There's a whole room full of toys back there."],[2439,2548,"Yes."],[2548,2665,"You heard me."],[2665,2794,"I already did your job."],[2794,3069,"Brought my grandson and his mother back."],[3069,3274,"Now hurry up and get to the address"],[3274,3386,"I just sent you."],[3386,3553,"His mother's there too?"],[3553,3628,"Well, dad, remember,"],[3628,3874,"are your families in a unique situation?"],[3874,4083,"Don't tell her who I am yet alright."],[4083,4275,"I don't want her to get any ideas."],[4275,4383,"All right, all right."],[4383,4558,"I got it."],[4704,4904,"Boss."],[4904,4996,"Are you asking the chairman"],[4996,5088,"to hide your identity"],[5088,5334,"because you don't know who to choose?"],[5334,5467,"I mean, on one hand,"],[5467,5655,"you've got the mother of your son,"],[5655,5905,"and on the other, you've got Miss Adele."],[5905,6118,"Just focus on driving. All right."],[6118,6235,"Eyes on the road."],[6610,6911,"Pew, pew!"],[7369,7444,"What's the matter?"],[7444,7628,"You're not excited to finally meet him."],[7686,7791,"Where's his mother at?"],[7820,8012,"His mother is at work."],[8012,8124,"I don't know who her boss is,"],[8124,8274,"but that devil of a man wouldn't"],[8274,8408,"grant her any time off."],[8425,8533,"Well, maybe we should just wait"],[8533,8658,"for her to get here."],[8683,8754,"Wait."],[8892,8988,"What are you talking about son."]],"37":[[25,175,"There is no more waiting."],[175,279,"You should be preparing"],[279,429,"for your marriage to his mother."],[1117,1418,"That marriage is a big commitment."],[1426,1605,"I need some time to think about it."],[1643,1726,"Think?"],[1726,1881,"What is there to think about?"],[1881,2014,"He is your son."],[2014,2139,"Your only child."],[2139,2344,"If you don't marry his mother,"],[2344,2427,"what are you going to do?"],[2427,2531,"You trying to avoid"],[2531,2644,"taking responsibility?"],[2644,2861,"No, dad, that's not what I meant. I'm."],[2861,3028,"I'm going to take full responsibility for him."],[3028,3082,"Of course."],[3082,3140,"But,"],[3249,3407,"marriage is not the only option here."],[3407,3586,"You won't marry her."],[3586,3774,"Are you going to let my grandson suffer"],[3774,3983,"under some step mother instead?"],[3983,4066,"No. Damn it!"],[4066,4195,"Dad could put words in my mouth."],[4195,4266,"That's not what I meant."],[4266,4408,"Get out of my sight."],[4408,4512,"You should be celebrating"],[4512,4763,"a new life ahead of you. Not