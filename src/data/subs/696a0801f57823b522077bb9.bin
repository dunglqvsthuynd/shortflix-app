{"1":[[8,72,"Miss Collins!"],[72,184,"Mr. Graham is here."],[712,840,"Oh no, I'm screwed."],[868,988,"The plot is about to start."],[1292,1376,"Three days ago,"],[1376,1492,"I time-traveled into a novel world"],[1492,1552,"formed by several novels."],[1592,1704,"I became the true heiress,"],[1704,1772,"the Villainess,"],[1772,1840,"who dies miserably in the end."],[1932,2020,"System!"],[2100,2180,"System!"],[2192,2352,"Coming."],[2372,2588,"Can I not go downstairs?"],[2628,2724,"Sorry, host."],[2724,2784,"Host."],[2784,2908,"Please follow the storyline,"],[2908,3052,"or you will be wiped out."],[3084,3392,"You win!"],[5012,5144,"Miss Collins."],[5440,5568,"Lizzie, come here."],[5740,5796,"Ethan."],[5796,6022,"This is my long-lost daughter, Lizzie."],[6050,6114,"Lizzie,"],[6180,6260,"this is Ethan Graham."],[6260,6392,"He is your sister's fiancé."],[6860,6980,"Key Plot Hint:"],[6980,7180,"Host, don't change your Villainess persona."],[7180,7356,"Act out the key plot ."],[7360,7436,"When Elizabeth saw Ethan,"],[7436,7552,"although he was in a wheelchair,"],[7552,7712,"he still looked handsome and elegant."],[7712,7840,"Elizabeth's heart was filled with jealousy."],[7840,7976,"Ivy Collins is just a fake heiress."],[7976,8040,"She doesn't deserve to have"],[8040,8156,"such a wonderful fiancé!"],[8700,8776,"System."],[8776,8856,"I'm done."],[8860,9028,"You completed the plot for the first time."],[9028,9124,"You're rewarded with three chances"],[9124,9188,"to change one word"],[9188,9276,"in the original novel."],[9276,9492,"Change one word?"],[9548,9656,"What good is that?!"],[9756,9896,"There are tears"],[9896,10004,"on Ivy's fair face,"],[10004,10236,"making her look fragile and attractive."],[10296,10504,"Fine, right here."],[10560,10772,"Change \"tears\" to \"ink\"."],[11536,11760,"I wanna talk with Ethan"],[11760,11932,"about our engagement."],[11932,12036,"This engagement"],[12036,12248,"is between the Collins and Graham families."],[12268,12516,"Lizzie, now that you're back,"],[12520,12668,"I shouldn't take your fiance."],[13532,13748,"The System is so cool."],[13748,13892,"Look at the color of that ink."],[13892,14016,"It must be high quality."],[14028,14232,"Ivy, your face..."],[14300,14540,"Why are they looking at me like that?"],[14560,14640,"Ivy."],[14668,14872,"The eyeliner you're using is so cheap."],[14872,14980,"It's running all over."],[14992,15148,"Mom, Dad."],[15172,15400,"Is our family going bankrupt?"],[16180,16376,"Did I say something wrong?"],[16412,16508,"Elizabeth."],[16508,16620,"Ivy isn't here."],[16620,16660,"There are some things"],[16660,16780,"I need to make clear to you."],[16780,16892,"I only love Ivy."],[16892,17040,"Don't covet things that don't belong to you."],[17040,17156,"I won't marry you."],[17256,17368,"Key Plot Hint:"],[17368,17548,"Host, please act according to the plot."],[17640,17820,"Covet things that don't belong to me?"],[17820,17976,"Ivy stole my rich heiress life in the past!"],[17976,18132,"I'm Dad's biological daughter, not her!"],[18160,18256,"My parents are mine."],[18256,18388,"The engagement is mine, too."],[18408,18564,"She is nothing but an imposter!"],[18876,18940,"Ethan Graham"],[18940,19108,"looks like a gentleman."],[19108,19252,"But he's kind of stupid."],[19280,19392,"What kind of decent man"],[19392,19592,"would be so eager to be a simp?"],[19660,19800,"What's going on?"],[19856,20036,"Elizabeth's lips didn't move just now."],[20056,20244,"Did I hear her mind?"]],"2":[[0,143,"Am I getting old"],[143,279,"and hearing things?"],[387,524,"What's wrong with this male supporting lead?"],[559,651,"Come on, fight back!"],[651,840,"Tell the whole world loudly"],[867,1048,"you insist on being the female lead's simp."],[1048,1167,"Elizabeth Collins, shut up!"],[1183,1275,"That's it."],[1275,1427,"Keep scolding me."],[1427,1532,"Don't stop."],[1667,1787,"Did I say something wrong?"],[1812,1851,"You..."],[1860,1919,"And all of you,"],[1964,2139,"you only care about Ivy."],[2176,2235,"If that's the case,"],[2283,2328,"why did you even"],[2328,2380,"bring me back?"],[2423,2583,"Come on, cooperate with me."],[2616,2807,"So we can finish the storyline soon."],[2807,2912,"It seems"],[2916,3100,"I need to reschedule the physical exam."],[3100,3267,"I need to check my brain."],[3267,3347,"I don't care!"],[3347,3432,"The engagement to the Graham family"],[3432,3584,"can only belong to me!"],[3584,3647,"Ivy is just an imposter."],[3647,3752,"She's not worthy of marrying Mr. Graham."],[3764,3864,"You guys."],[3864,3964,"Don't just stand there."],[3964,4107,"Blame me, scold me, whatever."],[4156,4315,"When the female lead comes out and cry,"],[4324,4471,"then I'll smash the vase"],[4475,4596,"and storm upstairs in a rage."],[4620,4775,"That way, this plot can be over."],[4864,5043,"I'm going to smash that one later."],[5096,5207,"Wait, that's a Qing Dynasty antique"],[5228,5356,"worth millions."],[5367,5460,"No way."],[5464,5575,"I have to keep an eye on that vase."],[5579,5635,"Elizabeth,"],[5684,5756,"what exactly are you..."],[5756,5815,"Lizzie,"],[5860,5932,"I'm sorry."],[5967,6147,"This is all my fault."],[6300,6384,"I don't know"],[6407,6512,"where this black stuff came from."],[6564,6748,"And it can't be cleaned for now."],[6748,6848,"It's okay, Ivy."],[6879,7071,"Ivy, you're the most gorgeous girl."],[7071,7100,"Yes."],[7268,7371,"Ethan."],[7407,7479,"I'm sorry."],[7484,7635,"I can't be selfish"],[7640,7756,"and hold onto this engagement."],[7759,7992,"You belong to Lizzie."],[8071,8151,"I..."],[8176,8268,"I'll step aside."],[8440,8631,"Of course you should step aside."],[8651,8787,"After all, you were kissed by"],[8787,8920,"that Little Punk yesterday."],[8951,9115,"And you still miss that kiss,"],[9115,9256,"unable to sleep."],[9271,9480,"What Little Punk?"],[9512,9692,"This plot is truly ridiculous."],[9695,9823,"A little punk"],[9840,9915,"suddenly turns over a new leaf"],[9915,10028,"for the female lead."],[10028,10079,"Seven years later,"],[10079,10179,"he returns as a rich CEO."],[10279,10395,"Poor Mom and Dad."],[10395,10479,"Back then,"],[10479,10607,"you forcibly separated them."],[10607,10748,"So after Little Punk returned,"],[10756,10956,"he had someone break your legs."],[11204,11323,"Why is everyone's reaction"],[11371,11592,"so different from what I expected?"],[11628,11707,"My head..."],[11748,11828,"It hurts."],[12020,12168,"The second plot modification starts now."],[12168,12240,"Countdown: 60 seconds."],[12279,12368,"If unused within 60 seconds,"],[12368,12540,"you'll lose this chance."]],"3":[[64,196,"The upcoming plot"],[196,327,"goes like this."],[448,563,"Ivy's face was pale,"],[675,775,"sweating heavily."],[775,883,"She leaned against Ethan's wheelchair."],[916,1000,"When Ethan saw this,"],[1000,1164,"his heart felt a sudden pain."],[1208,1324,"He wheeled himself"],[1324,1411,"over to Ivy's side."],[1435,1527,"He wanted to tell her"],[1527,1696,"she was the only one in his heart."],[1739,2144,"Change the word \"lean\" to \"lift\"."],[3603,3907,"So this is my fragile sister?"],[3907,3967,"Ivy!"],[3967,4086,"Put me down, now!"],[4088,4164,"Ethan!"],[4164,4267,"Don't say more!"],[4267,4367,"I've made up my mind!"],[4367,4552,"Besides, my health is poor!"],[4552,4703,"I could die at any moment!"],[4703,4788,"Being with you"],[4788,4920,"will only hold you back!"],[4920,5000,"Ivy!"],[5103,5203,"Put me down first!"],[5203,5239,"Ivy!"],[5239,5303,"I'm disabled."],[5303,5360,"I can't take a fall."],[5792,5932,"How \"fragile\"."],[6203,6307,"I..."],[6356,6448,"I don't know"],[6448,6604,"why I did that."],[6756,6864,"Enough!"],[6864,6987,"Stop being so hypocritical!"],[7023,7231,"You pretend to be weak and pitiful."],[7231,7348,"So everyone"],[7348,7412,"will blame me, right?"],[7428,7500,"Fine."],[7500,7659,"Yeah! I'm unreasonable."],[7700,7859,"I'm just vicious, okay?"],[8007,8164,"I just need to smash this vase."],[8164,8312,"This plot will end."],[8712,8792,"Smash this one."],[8892,8987,"Whatever."],[9115,9384,"You guys just stay with this imposter!"],[9714,9767,"Yay!"],[9815,9940,"I'm gonna go lie down for a bit."],[9940,10056,"I'm exhausted."],[10071,10151,"Mom, Dad."],[10179,10379,"Is Lizzie angry?"],[10379,10476,"Should I"],[10476,10584,"go comfort her?"],[10648,10748,"No, no need."],[10748,10907,"I'm feeling a little off today."],[10907,10959,"I'd better go home"],[10959,11035,"and see a doctor."],[11035,11107,"Mr. Collins, Mrs. Collins."],[11143,11312,"Sorry to disturb you today."],[11340,11400,"I'll take my leave now."],[11471,11559,"Ethan,"],[11576,11712,"why don't we go grab some dinner?"],[11887,12004,"Alright, then."],[12015,12176,"Lizzie has quite a temper."],[12176,12279,"I'll go talk to her."],[12440,12495,"I'll talk to her."]],"4":[[96,204,"Back to my acting work again."],[204,335,"So annoying, so annoying."],[356,451,"In my next life,"],[451,579,"I never want to work again."],[596,771,"Lizzie, it was my fault."],[819,919,"I apologize to you."],[940,1011,"Rest assured,"],[1043,1232,"I won't fight you over Ethan."],[1243,1319,"Ivy."],[1319,1443,"How could you make such a decision"],[1448,1556,"without discussing it with me?"],[1644,1739,"Ethan."],[1755,1844,"I just"],[1912,2087,"didn't want to make things difficult for you."],[2296,2392,"Your face is getting dark again."],[2680,2755,"Elizabeth, you..."],[2844,3055,"You could stop crying at any time."],[3055,3123,"Ivy."],[3123,3460,"You are really good at fake crying."],[3503,3607,"Alright."],[3639,3724,"Lizzie,"],[3724,3956,"love can't be forced."],[3992,4211,"Ethan and Ivy are in love."],[4224,4252,"Besides,"],[4252,4500,"Ivy's piano skills are at a master's level."],[4500,4743,"Ethan happens to love the piano."],[4788,4988,"They are a perfect match."],[4988,5152,"Piano?"],[5152,5303,"I remember that later on,"],[5303,5567,"Ivy often has sex with that Little Punk"],[5567,5720,"on the piano."],[5720,5984,"Those scenes are really sexy."],[6003,6156,"My piano skills"],[6156,6271,"are just average."],[6288,6343,"Ivy,"],[6343,6456,"don't be so humble."],[6456,6564,"Go play a piece"],[6564,6635,"to let her know"],[6635,6743,"the gap between you two."],[6843,7040,"The third plot modification starts now."],[7040,7148,"Countdown: 60 seconds."],[7192,7315,"After playing Will-o'-the-Wisps once,"],[7315,7523,"Ivy's expression remained cool."],[7543,7768,"It was like super easy to her."],[7948,8356,"Change \"once\" to \"one hundred times\"."],[8600,8800,"It seems modifying a word in the System"],[8800,8971,"can be done via three methods."],[8979,9207,"Replacing, adding, or deleting."],[9615,9715,"Then I'll just"],[9715,9904,"play a simple tune for everyone."],[9940,10131,"Please don't laugh at me."],[11643,11768,"Listening to it again is fine."],[12331,12423,"You guys want some too?"],[13908,14063,"Don't blame me for being a heartless dad."],[14063,14171,"Who would"],[14171,14287,"listen to this so many times in a row?"],[14324,14503,"Ivy, stop playing."],[14512,14636,"Take a break, okay?"]],"5":[[432,555,"Ethan,"],[559,779,"did I play well?"],[808,896,"It was good."],[975,1035,"It's just..."],[1035,1127,"I never want to hear it again."],[1140,1196,"So his obsession"],[1196,1356,"with listening to Ivy play piano"],[1356,1475,"is cured just like that?"],[1483,1667,"We're both supporting roles, dude."],[1703,1832,"Fixing this bad habit of yours"],[1851,2019,"is basically me setting you free."],[2035,2176,"Then let me play another song for you."],[2303,2387,"Mr. Collins, Mrs. Collins."],[2407,2512,"It's getting late."],[2512,2580,"I'm heading home now."],[2580,2700,"Assistant! Hurry!"],[2755,2935,"Let's go! We're leaving!"],[2960,3016,"Hurry up! Quick!"],[3071,3151,"I'm sleepy."],[3151,3288,"I'm going to bed."],[3335,3428,"Mom, Dad."],[3447,3647,"Do they dislike me?"],[3647,3775,"Is it because my playing"],[3775,3939,"was really bad?"],[4032,4107,"It's geting late."],[4107,4215,"You should get some rest."],[4220,4292,"Your father and I"],[4292,4443,"are going to bed too."],[4607,4696,"Congratulations, host."],[4696,4800,"You survived another day."],[4800,4864,"In future storylines,"],[4864,5020,"modification word counts can accumulate."],[5071,5179,"In the past few days,"],[5179,5260,"this accumulation feature"],[5260,5371,"hadn't appeared yet."],[5403,5492,"It seems..."],[5492,5603,"I experienced"],[5603,5732,"several key plots"],[5732,5811,"to unlock it."],[5811,5975,"If I save them up,"],[5975,6167,"I can modify a whole sentence,"],[6196,6335,"or even"],[6335,6576,"change the entire ending."],[6628,6776,"With the Golden Finger,"],[6776,6940,"I can break free from fate"],[6940,7268,"and control my own life."],[7400,7540,"Lately, all of a sudden,"],[7540,7620,"I feel like my health"],[7620,7695,"is failing me."],[7695,7795,"It seems"],[7795,8012,"I need to move up this year's checkup."],[8028,8115,"I think so, too."],[8115,8215,"I need to specifically"],[8223,8376,"get my brain checked."],[8392,8468,"What's wrong with your head?"],[8551,8656,"Nothing."],[8656,8815,"Just like Ivy,"],[8815,8987,"my headaches are acting up."],[8995,9176,"I can read Elizabeth's mind."],[9200,9312,"If I told anyone about this,"],[9312,9379,"I'm afraid"],[9379,9551,"they'd think I'm crazy."],[9551,9635,"Right, right."],[9664,9784,"I have a headache, too."],[9851,9951,"I guess"],[9951,10095,"it's just from all the stress lately."],[10095,10176,"Yes."],[10207,10304,"You should get some rest."],[11351,11476,"I'm going to see"],[11476,11604,"if this person really exists."],[11692,11807,"Look up \"Little Punk\" for me."],[11915,12015,"I want to see"],[12015,12140,"if Elizabeth's mind"],[12140,12259,"is telling the truth."],[12664,12792,"There were things"],[12792,12943,"I clearly didn't want to do."],[13000,13140,"But a strange force"],[13140,13268,"kept driving me to do them."],[13324,13640,"There's something weird about Elizabeth."],[14828,14924,"Ivy."],[14924,15019,"William."],[15019,15131,"What happened to your hand, Ivy?"],[15143,15240,"William."],[15240,15519,"I practiced piano for too long today,"],[15547,15691,"so my hand hurts a little."]],"6":[[0,128,"Why did you play for so long?"],[167,364,"Did Lizzie bully you again?"],[364,483,"Don't be scared, Ivy."],[512,624,"I'll be back tomorrow morning."],[624,732,"For me,"],[763,896,"you are my only sister."],[896,996,"I won't let her bully you."],[996,1132,"But William,"],[1159,1335,"Lizzie is your biological sister."],[1335,1427,"I don't have"],[1427,1591,"such a disgraceful sister."],[1612,1707,"Just get some rest."],[1755,1819,"Wait for me to come home."],[2260,2348,"She's the Collins's biological daughter."],[2348,2507,"So what?"],[2532,2651,"In the Collins family,"],[2651,2760,"they prefer me."],[3407,3488,"Lizzie,"],[3488,3567,"I didn't mean to"],[3567,3660,"steal our brother William from you."],[3671,3784,"William fed me"],[3784,4032,"because my hand is injured."],[4052,4235,"A peasant is just a peasant."],[4260,4607,"Is this how you usually bully Ivy?"],[4607,4875,"William looks quite aloof and cold."],[4884,5060,"But I feel like he's missing something."],[5064,5188,"Looking closely,"],[5188,5400,"he's just missing a cuckold mark."],[5407,5511,"What is going on?"],[5511,5667,"Is there a ghost?"],[5696,5779,"Three."],[5779,5832,"Two."],[5847,5900,"One."],[5952,6067,"Let the phone ring."],[6067,6132,"What phone?"],[6167,6288,"What is ringing?"],[6303,6495,"What exactly is that voice?"],[6715,6848,"There's the call, as expected."],[6848,6923,"Go on, answer it."],[6923,7000,"Soon,"],[7000,7100,"you'll get the good news"],[7100,7243,"of becoming a fake father."],[7315,7500,"My brother is the male supporting lead"],[7500,7615,"in Runaway Pregnant Bride."],[7615,7812,"To avoid the male lead, the female lead"],[7812,8020,"took my brother as her baby's dad."],[8031,8176,"Later, when the leads reunited,"],[8200,8348,"my brother naturally became a thorn"],[8348,8507,"in the male lead's side."],[8559,8804,"His ending wasn't much better than mine."],[8879,8956,"William,"],[8956,9100,"your phone is ringing."],[9100,9195,"Answer it."],[9212,9331,"Why isn't he answering?"],[9364,9476,"He's not answering?"],[9476,9620,"How am I supposed to watch the show?"],[9656,9915,"Did I just hear Elizabeth's mind?"],[9943,10204,"William, it's Megan calling."],[10204,10268,"Answer it."],[10376,10495,"Elizabeth is talking nonsense."],[10564,10671,"I can't believe her. I can't."],[10892,11076,"William, I'm pregnant."],[11076,11215,"You're going to be a father."],[11240,11320,"Well?"],[11320,11487,"Isn't it a nice surprise to be a dad?"],[11676,11820,"Why isn't William reacting?"],[11851,11948,"Weird."],[11976,12168,"I can clearly see him being cuckolded."],[12171,12251,"William."],[12251,12420,"What's wrong? Aren't you happy?"],[12420,12515,"Uh, no."],[12592,12676,"I'm very happy."],[12704,12836,"Of course you're happy."],[12859,12996,"After all, you did nothing,"],[12996,13080,"and still got a son."],[13124,13268,"That day at the hotel,"],[13296,13440,"Megan was right beside you,"],[13440,13519,"sleeping with her lover."],[13575,13659,"The next day,"],[13691,13756,"you thought"],[13756,13847,"you were the one who slept with her."],[13880,13987,"You asked to take responsibility."],[14075,14256,"Sleeping too heavily"],[14256,14436,"is really not a good habit."]],"7":[[16,156,"I was drunk that night,"],[156,275,"and Megan took me to a hotel."],[275,348,"When I woke up the next day,"],[348,448,"I thought I was the one who slept with her."],[479,636,"Megan and I were childhood sweethearts."],[636,712,"I like her."],[751,891,"So I immediately said I'd marry her."],[891,1051,"But Elizabeth just came back."],[1067,1135,"How could she know"],[1135,1248,"about what happened that night?"],[1251,1335,"William."],[1335,1540,"Is Megan pregnant?"],[1612,1676,"Are you two"],[1676,1780,"getting married soon?"],[1787,1907,"Yes, she's pregnant."],[1907,2028,"You'd better hurry up."],[2035,2148,"Megan is the goddess"],[2148,2207,"you've admired"],[2207,2371,"for so many years."],[2416,2583,"Your girl is cheating on you?"],[2592,2771,"Nothing special. Just take it."],[2807,2939,"This is such great news."],[2939,3071,"You should tell Mom and Dad first."],[3071,3235,"I'll go see Megan tomorrow"],[3235,3371,"and congratulate her properly."],[3375,3456,"I forgot."],[3456,3688,"Ivy and Megan are best friends."],[3688,3992,"Ivy knew the baby isn't William's."],[3992,4128,"But she still persuaded Megan"],[4128,4292,"to marry William"],[4292,4411,"before finding the real father."],[4439,4700,"Just to avoid gossip when the baby is born."],[4700,4779,"William,"],[4800,4879,"I want some porridge."],[5084,5139,"Oh."],[5532,5635,"William,"],[5756,5867,"it's about time."],[5888,6015,"I'll drive you girls to school."],[6035,6156,"It's quite a coincidence."],[6156,6356,"Elizabeth and Ivy"],[6356,6540,"attend the same drama school."],[6595,6815,"The Collins family discovered the problem"],[6828,7012,"because of a physical exam at school."],[7012,7092,"William."],[7092,7223,"But Lizzie"],[7223,7379,"doesn't seem to be done eating."],[7407,7568,"I want everyone to know"],[7568,7684,"I'm the most favored in the family."],[7704,7812,"So this time,"],[7812,7871,"I have to make William"],[7871,8035,"take only me to school."],[8048,8151,"Oh, right."],[8151,8243,"I haven't finished eating."],[8243,8328,"You guys go ahead."],[8331,8431,"As a supporting role,"],[8431,8548,"I know the drill."],[8548,8720,"The family driver happens to be off,"],[8728,8843,"so I'll walk to school"],[8843,8984,"and get mocked by my classmates."],[8984,9023,"They'll say"],[9023,9207,"the Collins family doesn't care about me at all."],[9223,9307,"I need to eat up."],[9307,9384,"Otherwise,"],[9384,9548,"I won't have the energy to walk that far later."],[9548,9740,"If I hadn't heard Elizabeth's mind,"],[9740,10020,"I probably would only drive Ivy to school."],[10023,10171,"William, let's go."],[10212,10368,"The driver is off today."],[10392,10592,"Let's wait for Lizzie."],[10659,10912,"My brother only cares about business."],[10915,11000,"Why would he notice"],[11000,11107,"such a small thing?"],[11295,11356,"Lizzie,"],[11356,11631,"this cash and card are for you."],[11700,11812,"This black card"],[11812,11915,"is my supplementary card."],[11948,12028,"It has no limit."],[12071,12148,"If you see something you like,"],[12148,12228,"just buy it yourself."],[12284,12412,"William?"],[12412,12520,"Didn't William come back"],[12520,12679,"to support me?"],[12679,12836,"Why is he treating Lizzie so well?"],[12836,12991,"He gave her an unlimited supplementary card."],[13008,13208,"I don't even have one."],[13224,13375,"What's going on?"],[13447,13771,"Didn't William come back to support Ivy?"],[13791,13871,"Shouldn't he be"],[13871,14071,"scolding me without asking about the details?"]],"8":[[119,243,"William,"],[243,343,"I want one black card, too."],[343,528,"My hand is injured,"],[536,604,"so I want to buy a bag"],[604,728,"to make myself happy."],[967,1011,"Ivy,"],[1083,1191,"did you hurt your hand"],[1191,1380,"playing the piano?"],[1388,1519,"Lizzie wanted to listen."],[1548,1732,"It's nothing if I get hurt a little."],[1732,2023,"Was Lizzie the only one there that day?"],[2112,2155,"Huh?"],[2155,2248,"What's happening?"],[2280,2432,"Has this stupid brother"],[2432,2548,"suddenly grown a brain?"],[2667,2864,"Ethan and our parents were there too."],[2864,3076,"I was happy to play for everyone."],[3076,3119,"Since Mom, Dad,"],[3119,3288,"and Ethan were all there last night,"],[3292,3503,"surely no one would dare wrong Ivy."],[3520,3596,"Elizabeth has suffered"],[3596,3684,"a lot on the outside."],[3684,3771,"She probably never got to eat"],[3811,3979,"a breakfast like this before."],[3992,4071,"Lizzie,"],[4103,4192,"hurry up and eat."],[4352,4520,"Is this some new tactic?"],[4535,4711,"Is he waiting for me to let my guard down?"],[4711,4864,"Just to push me into the disaster again?"],[4943,5103,"That's terrifying. Truly terrifying."],[5103,5156,"Jeez."],[5156,5215,"What kind of nonsense"],[5215,5367,"is Elizabeth thinking?"],[5379,5500,"Am I that kind of person?"],[5515,5596,"Ivy."],[5611,5696,"Mom, Dad,"],[5696,5800,"and Ethan were all there last night."],[5815,5952,"No one would have dared to bully you."],[5992,6156,"Is William implying"],[6156,6303,"I wrongly accused Elizabeth?"],[6315,6428,"William."],[6428,6579,"I didn't mean it."],[6579,6731,"My brother"],[6759,6940,"isn't exactly brainless."],[6956,7087,"It's a pity he's such a love-struck fool."],[7112,7184,"Otherwise,"],[7204,7320,"he wouldn't let his fiancée"],[7320,7440,"play him like a moron."],[7456,7592,"Since I heard about it,"],[7592,7735,"I'll send someone to investigate."],[7735,7807,"However,"],[7807,7879,"I trust Megan."],[7879,7976,"She's not that kind of person."],[8004,8092,"I'm done eating."],[8115,8184,"Since you want"],[8184,8268,"to take me to school,"],[8268,8384,"I'll give you a chance."],[8384,8495,"Let's go."],[8707,8764,"Didn't they say"],[8764,8835,"Ivy was going to be"],[8835,8920,"abandoned by the Collins family?"],[8920,9000,"Looking at it now,"],[9000,9104,"that's not the case at all."],[9104,9320,"A peasant versus a piano prodigy."],[9320,9392,"If it were you,"],[9392,9476,"who would you choose?"],[9476,9556,"It seems"],[9556,9731,"even if Elizabeth got her rich parents back,"],[9751,9920,"she'll never be a real lady."],[10248,10451,"Why are you blocking the car door and posing?"],[10451,10564,"Just let me out."],[10712,10828,"Everyone,"],[10828,10979,"let me reintroduce myself."],[10979,11084,"I am Elizabeth Collins."],[11100,11279,"The Collins family's only true heiress."],[11328,11423,"From now on,"],[11423,11707,"if anyone uses the Collins name"],[11707,11835,"to show off around town,"],[11868,11971,"remember to tell me."],[11971,12100,"Is this beauty Elizabeth Collins?"],[12100,12195,"Lizzie,"],[12220,12295,"I never intended"],[12295,12407,"to compete with you for anything."],[12440,12576,"You don't have the Collins blood,"],[12576,12684,"so you can't be a Collins."],[12684,12784,"How could you compete with me?"]],"9":[[24,160,"Ivy!"],[176,416,"William, I'm fine."],[428,548,"Don't blame Lizzie."],[583,732,"I just lost my footing."],[740,859,"She really lives up to being the female lead."],[859,1024,"She must have eyes in the back of her head."],[1056,1235,"Come on, stand up for the female lead!"],[1235,1416,"Scold me loud and clear!"],[1432,1527,"She is just an outsider"],[1527,1644,"living under our roof now!"],[1644,1780,"Never mind shoving her,"],[1792,1912,"even if I hit her,"],[1912,2023,"she should just take it!"],[2023,2200,"Oh yeah, perfect!"],[2219,2351,"My line delivery"],[2351,2519,"is really getting better."],[2528,2632,"My sister Elizabeth"],[2632,2764,"is definitely schizophrenic."],[2764,2876,"Lizzie,"],[2876,3019,"don't say things like that next time."],[3023,3167,"That's all?"],[3180,3311,"Come on, get angry!"],[3324,3460,"I picked on her on purpose."],[3460,3547,"But you just let it go?"],[3547,3624,"William."],[3664,3756,"Ivy,"],[3756,3856,"as for Lizzie,"],[3856,3971,"although she has a bad temper,"],[3984,4075,"she's not a bad person."],[4092,4203,"So don't hold it against her."],[4203,4367,"You said I'm your only little princess."],[4367,4439,"As expected,"],[4439,4596,"everything the Collins family said"],[4596,4692,"is a lie."],[4703,4879,"I understand, William."],[4892,4984,"Alright."],[4984,5092,"You two should go inside now."],[5400,5496,"Is that Elizabeth?"],[5496,5543,"Why does it feel like"],[5547,5643,"she's a completely different person?"],[5643,5720,"Looking at her now,"],[5720,5871,"she's even prettier than Ivy."],[5871,6024,"What's the use of being pretty?"],[6024,6320,"Ivy is a piano genius, you know."],[6851,6928,"Lizzie."],[6928,7095,"William wants us to get along."],[7104,7243,"If you need help with anything,"],[7243,7331,"just let me know."],[7331,7535,"I actually do have something"],[7535,7607,"What is it?"],[7731,7831,"I'm thirsty."],[7851,7948,"Go get me a glass of water."],[8092,8276,"That's not the kind of help I meant."],[8287,8468,"If you can't even help with such a small thing,"],[8484,8631,"what can you do?"],[9043,9184,"Little Punk is here."],[10256,10364,"So you're the real daughter"],[10364,10584,"the Collins family just found?"],[10800,10959,"I like your temper."],[11015,11331,"How about you hang out with me tonight?"],[11512,11571,"Does he..."],[11571,11687,"Does he actually like"],[11687,11812,"Elizabeth's temper?"],[11831,11992,"Or,"],[12140,12251,"right here works too."]],"10":[[796,875,"You b*tch!"],[1567,1660,"Wyatt!"],[1660,1751,"You hit me?"],[1776,1860,"Wyatt!"],[2060,2119,"Wyatt."],[2496,2571,"Lizzie."],[2571,2616,"How could you"],[2616,2735,"bully Wyatt like that?"],[2735,2867,"Bully him?"],[2867,3000,"He insulted me."],[3000,3139,"If I don't hit him, who should I hit?"],[3139,3256,"Should I hit you instead?"],[3275,3335,"I won't let"],[3335,3435,"you talk about Wyatt like that."],[3543,3796,"He's actually a good person."],[3811,4060,"He gets into fights and bullies classmates,"],[4060,4279,"yet he's a good person?"],[6784,6976,"If you dare lay a finger on me,"],[7028,7264,"it means Ivy fails to take care of me."],[7264,7359,"I'd like to see"],[7359,7607,"how she explains that to my family!"],[8476,8571,"Whoa."],[8571,8735,"Ivy cares about you so much,"],[8751,8848,"and you care about her too."],[8859,9007,"Don't tell me you two"],[9007,9243,"are actually dating?"],[9328,9512,"There's nothing between Wyatt and me."],[9515,9623,"It's not what you're saying."],[12312,12507,"Why can't Wyatt understand me?"],[12528,12679,"With his current status,"],[12700,12863,"how could my parents possibly accept him?"],[12863,12987,"Go pour me a glass of water."],[13131,13263,"Stop dawdling."],[13263,13408,"You can't even handle a simple task."],[13419,13503,"I don't know why"],[13503,13659,"the Collins family bothers raising you."],[15163,15259,"Class has started."],[15284,15440,"Very beneficial for agricultural production."],[15515,15612,"I can't focus."],[15612,15731,"I can't study at all."],[16047,16296,"I've always got excellent grades."],[16296,16415,"What if Elizabeth surpasses me?"],[16491,16571,"Impossible."],[16643,16771,"Elizabeth is always dead last in class."],[17228,17315,"What should I do?"],[17356,17587,"Is Wyatt really ignoring me?"],[17596,17652,"In the book,"],[17652,17828,"Ivy had excellent grades."],[17828,17919,"But because of Wyatt,"],[17919,18036,"her academic performance plummeted."],[18063,18191,"She almost didn't graduate."],[18191,18331,"Later, the Collins family used their money"],[18340,18463,"to buy her a diploma."],[18475,18580,"They also bought fame for her"],[18608,18736,"as a \"genius girl\"."],[18759,18880,"So she gained a foothold"],[18880,18996,"in the showbiz."],[19028,19219,"Ivy turned bad because of Wyatt."],[19224,19363,"But just because her family"],[19363,19503,"separated her from Wyatt,"],[19524,19624,"she hated the family"],[19624,19856,"who raised her for twenty years."],[19896,20263,"I just can't understand her."],[20296,20384,"In my previous life,"],[20384,20447,"I was known as"],[20447,20575,"the youngest Best Actress."],[20575,20680,"But my biggest regret was never"],[20680,20896,"receiving professional training."],[20924,21152,"Just as I planned to study systematically,"],[21152,21331,"I time-traveled to this world."],[21371,21603,"This happens to give me a chance to study."],[21668,21808,"I'll take on the career"],[21840,21884,"that the female lead doesn't want."],[21956,22040,"As for Ivy,"],[22059,22159,"if she wants to degrade herself,"],[22180,22252,"then let her be."]],"11":[[1012,1092,"Ivy."],[1176,1256,"Hmm?"],[2690,2876,"One guy suddenly pinned her in the corner."],[2876,2958,"It was Wyatt."],[2958,3140,"Ivy blushed and turned around."],[3140,3318,"They kissed each other passionately."],[3552,3676,"This is definitely"],[3676,3788,"a key plot."],[3788,3932,"Just reading the text description"],[3932,4124,"makes me feel sick."],[4196,4288,"I originally intended"],[4300,4492,"to save up some words."],[4500,4624,"But now"],[4680,4836,"I can't help changing words."],[4836,4916,"Starting from tomorrow,"],[4984,5216,"I'll definitely save more words."],[5324,5508,"You're cold to me in public,"],[5564,5720,"but so passionate in private."],[5916,6016,"You little siren."],[6064,6152,"The Collins family just found"],[6152,6264,"their biological daughter,"],[6304,6488,"so things aren't easy for me right now."],[6488,6600,"I can't let Elizabeth"],[6600,6740,"get any dirt on me again."],[7000,7144,"Am I just dirt to you?"],[7144,7232,"Ivy."],[7260,7400,"Are you feeling ashamed of me?"],[7416,7520,"No, that's not it."],[7536,7744,"The Collins family is just too shallow."],[7760,7836,"They only look at"],[7836,7952,"the surface of a person."],[7952,8080,"They will never know"],[8080,8228,"how kind you really are."],[8268,8348,"Ivy."],[8384,8560,"Wyatt."],[9800,9880,"Ivy!"],[10140,10328,"I changed \"pinned her in the corner\""],[10328,10504,"to \"threw her into the corner\"."],[10504,10676,"Now the whole plot has changed."],[10700,10832,"Judging from that,"],[10912,11112,"someone's ending up in the hospital."]],"12":[[27,225,"Wyatt carried Ivy worriedly."],[225,420,"He shouted loudly and rushed to the infirmary."],[652,812,"Whoa, she really got in hospital."],[948,1060,"What a funny show!"],[1224,1612,"Should I go to watch it or not?"],[1632,1836,"Ding. Host, please go to the hospital."],[1908,2172,"Since I have no choice,"],[2180,2348,"I'll go to the hospital and see."],[2716,2860,"Why is Wyatt carrying Ivy?"],[2888,2992,"What's going on?"],[3016,3100,"As I know,"],[3100,3192,"they're not even friends."],[3192,3324,"I'm in the same class as them."],[3340,3484,"During class this morning,"],[3500,3664,"Ivy seemed really worried about Wyatt."],[3704,3808,"Maybe they're dating."],[3808,3888,"Impossible."],[3908,4140,"How could Goddess Ivy date a punk?"],[4160,4320,"Goddess Ivy fainted."],[4320,4496,"Wyatt must have done something to her."],[4496,4556,"Let's go."],[4556,4636,"Let's go check it out."],[4648,4760,"We can't let Wyatt"],[4760,4852,"hurt our Goddess."],[5064,5208,"Hurry, hurry!"],[5680,5788,"Are you deaf?"],[5812,5948,"Hurry up and save Ivy!"],[6560,6716,"If you can't save her,"],[7060,7228,"I won't let you off!"],[8312,8500,"Why did I do that?"],[8524,8656,"How could I hurt her?"],[8684,8808,"The wound isn't serious."],[8808,8932,"A bandage is all she needs."],[8972,9144,"But since she injured her head,"],[9236,9360,"you'd better take her to the hospital"],[9360,9496,"for a thorough checkup."],[9792,9912,"Then why don't you"],[9912,10020,"examine her right now?"],[10044,10120,"Every minute wasted"],[10120,10260,"puts her in more danger!"]],"13":[[4,180,"But we don't have the equipment here."],[300,472,"Then why aren't you bandaging her?"],[2228,2488,"Elizabeth, your sister is hurt."],[2488,2672,"And you're just standing there gloating!"],[2688,2768,"What makes you think"],[2768,2888,"I'm gloating?"],[2984,3100,"I should be asking you."],[3100,3256,"Wasn't Ivy with you just now?"],[3256,3376,"How did she get hurt all of a sudden?"],[3376,3528,"Don't you owe the Collins family"],[3528,3624,"an explanation?"],[3648,3768,"Don't try to deny it."],[3784,3892,"After I left,"],[3916,4012,"it was just the two of you"],[4012,4132,"in the classroom."],[4132,4196,"You must have"],[4196,4304,"done something to my sister!"],[4304,4380,"It wasn't me!"],[4380,4464,"I didn't do it!"],[4520,4640,"Obstacles from others"],[4640,4744,"will only make those two"],[4744,4996,"more convinced that their love is true."],[5024,5148,"If no one stands"],[5148,5344,"in their way this time,"],[5348,5588,"what will their ending be?"],[5652,5732,"Wyatt."],[5840,5920,"It hurts."],[6140,6296,"I'll take you to the hospital right now."],[6296,6344,"Okay."],[6424,6520,"Wyatt Perry, right?"],[6520,6616,"Put Ivy down!"],[6640,6788,"I'll take her to the hospital."],[6788,6876,"Who are you?"],[6904,6992,"What's happening?"],[7032,7192,"Why is Ethan here?"],[7264,7364,"Poor guy."],[7408,7532,"I bet right now,"],[7532,7764,"he's crying in his heart."]],"14":[[200,284,"Why are you glaring at me?"],[296,380,"It wasn't me who made"],[380,564,"your fiancée cheat on you."],[576,680,"Bring Miss Ivy back over here."],[764,860,"Wyatt."],[896,1148,"This is Ivy's fiancé."],[1148,1236,"You'd better put her down."],[1268,1456,"I know you like Ivy."],[1540,1648,"You don't care about"],[1648,1764,"stealing someone's fiancée."],[1764,2052,"But Ivy still cares about her reputation."],[2136,2380,"Wyatt, put me down first."],[3924,4076,"You hurt Ivy."],[4076,4164,"I've called the police."],[4332,4484,"How did this male supporting lead know?"],[4516,4612,"You're lying!"],[4700,4784,"Just you wait."],[4892,5092,"Is the show over this quickly?"],[5116,5200,"This male supporting lead..."],[5200,5356,"What does he plan to do next?"],[5408,5560,"Since he's the male supporting lead,"],[5584,5708,"I guess"],[5708,5868,"he'll forgive Ivy."],[5868,5936,"You,"],[5936,5988,"come with me."],[5988,6092,"We're taking Ivy to the hospital."],[6116,6260,"I still have class."],[6268,6384,"You only have one class this afternoon."],[6396,6492,"You'll make it back from the hospital in time."],[6528,6620,"Why did you check my schedule"],[6620,6748,"so thoroughly?"],[6804,6864,"Oh."],[6940,7136,"Ivy and I take the same classes."],[7228,7436,"Maybe he checked Ivy's schedule,"],[7476,7556,"and that's how he knew mine."],[7712,7768,"If I stay,"],[7768,8000,"I can watch Wyatt get arrested by the police."],[8016,8152,"If I go, I can watch the drama"],[8152,8356,"between the male supporting lead and the female lead."],[8396,8548,"It's such a tough choice!"]],"15":[[36,200,"She keeps calling me \"male supporting lead\"."],[212,332,"Is she trying to piss me off?"],[528,636,"You are suspected of intentional assault!"],[636,740,"Please come with us!"],[752,880,"I had someone trailing Ivy."],[908,976,"They filmed"],[976,1056,"the entire incident on the rooftop."],[1088,1208,"I've handed the video over to the police."],[1232,1384,"Wyatt will probably be stuck in jail"],[1384,1440,"for a few days."],[1484,1608,"Can we go now?"],[1608,1680,"Let's go."],[1728,1912,"I just want to watch dramas."],[1924,2124,"I go wherever the drama is."],[2140,2328,"Ivy has a fiancé?"],[2340,2488,"How come we've never heard of that before?"],[2520,2592,"She's been keeping it a secret."],[2592,2700,"So who would have known?"],[2768,2936,"If I hadn't planted a bug in Ivy's clothes,"],[2936,3052,"I wouldn't have known"],[3052,3224,"she was injured at all."],[3248,3292,"Luckily,"],[3292,3400,"I asked Ivy's classmate"],[3400,3480,"to keep an eye on her."],[3480,3560,"Otherwise, I wouldn't have known"],[3560,3652,"she was hurt."],[3932,4012,"Honey,"],[4056,4200,"what are you doing here?"],[4244,4380,"I came to the hospital for a checkup,"],[4382,4485,"and I just happened to see Ivy."],[4485,4567,"What about you?"],[4672,4716,"I..."],[4716,4828,"Me too."],[5136,5328,"Good thing I talked my way out of that."],[5340,5416,"I can't say"],[5416,5572,"I can read Elizabeth's mind."],[5580,5796,"That's why I investigated Ivy in advance."],[6012,6140,"I'm sorry for making you worry."],[6144,6332,"The doctor says it's just a flesh wound,"],[6332,6424,"nothing serious."],[6464,6544,"Ivy,"],[6580,6748,"how exactly did you get hurt?"]],"16":[[0,116,"It was just a misunderstanding."],[116,288,"I accidentally tripped and fell."],[288,428,"Wyatt Perry saved me."],[492,572,"Ethan,"],[572,724,"Wyatt is a good person."],[724,840,"You've wronged him."],[852,928,"Please tell the police"],[928,1028,"to release him."],[1028,1116,"Ivy is actually lying"],[1116,1200,"to cover for him."],[1200,1344,"They do love each other."],[1368,1552,"Then what about me?"],[1552,1704,"What's wrong with this male supporting lead?"],[1704,1796,"Hurry up and speak."],[1796,1844,"I have to go back"],[1844,2000,"to school for class later."],[2000,2140,"Don't waste my time."],[2248,2424,"Are you sure you want Wyatt released?"],[2424,2572,"He is innocent."],[2624,2704,"Ivy!"],[2704,2836,"How can you be so foolish?"],[2836,3008,"Wyatt Perry is just a punk."],[3008,3068,"How can you get involved"],[3068,3188,"with someone like him?"],[3188,3268,"Exactly."],[3296,3372,"You don't need to worry"],[3372,3456,"about Wyatt's situation."],[3456,3616,"Let him cool his heels in jail."],[3616,3780,"So he will stop pestering you."],[3828,3936,"Mom, Dad."],[3960,4112,"Wyatt didn't do anything wrong."],[4112,4264,"You can't let him stay in jail."],[4392,4480,"Ethan."],[4480,4544,"I know"],[4544,4688,"you're different from Mom and Dad."],[4688,4796,"You definitely won't make things"],[4796,4880,"difficult for Wyatt,"],[4880,4956,"right?"],[4984,5048,"This daughter..."],[5048,5240,"Does she know right from wrong?"],[5268,5368,"What if I insist Wyatt"],[5368,5496,"receives the punishment he deserves?"],[5496,5628,"If that's the case,"],[5628,5692,"then I've completely misjudged you"],[5692,5772,"all these years."],[5772,5868,"There is no reason"],[5880,6056,"for our engagement to continue."],[6224,6304,"Every time I use"],[6304,6416,"the engagement to threaten him,"],[6416,6532,"he always compromises."],[6540,6732,"This time will be no exception."],[6740,6912,"Ethan, you love her so much!"],[6912,7052,"How can you call off the engagement?"],[7052,7160,"Hurry up and forgive her!"]],"17":[[0,80,"Weird."],[92,216,"It feels like some force"],[220,344,"is stopping me from saying"],[348,452,"\"call off the engagement\"."],[452,592,"Then let's call off the engagement."],[1204,1364,"He's actually quite handsome,"],[1364,1520,"just a bit cold."],[1520,1584,"Adrian."],[1676,1872,"So it's Ethan's big brother, Adrian."],[1892,2072,"He's one of the few sensible people."],[2072,2208,"He tried to knock some sense into Ethan,"],[2208,2312,"but Ethan was blinded by love."],[2312,2424,"Ethan wouldn't listen to Adrian"],[2424,2532,"and even cuts ties with him."],[2532,2700,"In the end, Ethan gave"],[2700,2908,"his shares to the female lead."],[2908,3020,"The male and female leads then"],[3020,3140,"use those shares"],[3140,3332,"to take over the entire Graham family."],[3452,3604,"Did I just read her mind?"],[3636,3756,"How does she know all this?"],[3804,3920,"Could she be reborn too?"],[3920,4064,"You and Ethan are indeed ill-suited."],[4064,4228,"I will make the decision for this engagement."],[4248,4328,"It's called off."],[4468,4528,"Three days ago,"],[4528,4596,"I found myself"],[4596,4692,"back ten years in the past."],[4692,4812,"In my previous life, because of Ivy,"],[4812,4920,"Ethan turned against me,"],[4920,5048,"and the company was taken over."],[5048,5128,"In this life,"],[5144,5240,"I certainly won't let history repeat itself."],[5240,5408,"I can't let Ethan get together with Ivy again."],[5412,5568,"Why is there a strange force"],[5580,5756,"urging me to refuse canceling the engagement?"],[5780,5956,"I don't even want this engagement."],[6012,6092,"Ethan,"],[6136,6368,"is this what you want, too?"],[6384,6484,"My brother's decision"],[6500,6596,"is my decision."],[6616,6768,"Our parents died a long time ago."],[6768,6852,"My brother took on the heavy burden"],[6852,6980,"of running the company."],[6980,7088,"Adrian has been like a father to me."],[7088,7212,"I can't fall out with my brother"],[7212,7316,"just because of Ivy."],[7352,7552,"Doesn't he love me deeply?"],[7556,7712,"Why would he agree to cancel the engagement?"]],"18":[[7,73,"D*mn it."],[76,148,"Is this engagement"],[148,264,"really going to be canceled?"],[264,376,"That's impossible!"],[376,536,"No matter what the female lead does,"],[536,612,"the male supporting lead Ethan"],[612,700,"should still love her"],[700,844,"and beg her not to leave!"],[856,944,"Mr. Collins, Mrs. Collins."],[972,1132,"Ivy and I really aren't a good match."],[1168,1308,"Let's call off the engagement."],[1332,1540,"Marriage is a matter between two families."],[1540,1600,"Mom and Dad"],[1600,1768,"definitely won't agree to this."],[1768,2040,"Ethan, have you made up your mind?"],[2040,2256,"You can hit me or scold me."],[2256,2360,"But my decision is final."],[2376,2456,"Fine."],[2504,2704,"Then the engagement is off."],[2704,2860,"They reached a consensus just like that?"],[2860,3012,"The plot is in total chaos!"],[3048,3148,"Ethan, you have to be there."],[3148,3388,"So Ivy and Wyatt can get happy ending!"],[3388,3464,"How can you give up"],[3464,3568,"your true love so easily?"],[3568,3904,"I despise you."],[3916,4124,"Tomorrow my mom will personally go"],[4124,4276,"to the Collins family to break the engagement."],[4276,4340,"Mm-hmm."],[4352,4432,"Alright."],[4576,4716,"Ivy was immature."],[4760,4956,"We've wronged you."],[4964,5188,"The Collins family is so reasonable."],[5188,5580,"Or have they known Ivy's actions?"],[5584,5632,"Fine."],[5652,5756,"If the engagement is off, so be it."],[5772,5836,"Let's see in the end"],[5840,5964,"who'll regret it first."],[5964,6088,"The engagement can be called off,"],[6088,6240,"but Wyatt is still in detention."],[6240,6320,"You should"],[6340,6484,"get him released first, right?"],[6484,6596,"You're the one who was hurt."],[6612,6704,"If you don't care,"],[6720,6820,"I won't either."],[6820,6944,"As the victim,"],[6964,7108,"as long as I forgive Wyatt,"],[7108,7296,"he'll be fine."],[7300,7380,"Looks like"],[7392,7568,"I need to go to the police station right away."]],"19":[[20,108,"Mr. Collins, Mrs. Collins."],[116,248,"There's nothing more for us here."],[248,372,"I'll take my brother"],[372,460,"and head home first."],[460,512,"Hmm."],[512,576,"Alright."],[636,844,"Elizabeth seems to know a lot."],[844,960,"I was reborn."],[964,1120,"I won't let the tragedy repeat itself."],[1120,1228,"Maybe she can help me."],[1228,1424,"Mom, Dad, I'm heading back too."],[1492,1584,"Miss Collins,"],[1596,1736,"would I have the honor"],[1848,1972,"of getting your number?"],[1976,2212,"Is Adrian hitting on Lizzie?"],[2288,2516,"Is the Cold-faced Grim Reaper"],[2516,2672,"finally looking for love?"],[2692,2900,"Sorry, I'm still a student."],[2900,3084,"I won't add strangers' contact info."],[3096,3192,"My name is Graham Adrian."],[3196,3272,"I'm 28."],[3272,3324,"Male."],[3324,3384,"Single."],[3384,3492,"My hobby is"],[3492,3576,"making money."],[3616,3772,"What kind of hobby is that?"],[3784,3940,"We're not strangers anymore, right?"],[3996,4068,"My brother..."],[4068,4244,"Is he treating this like a blind date?"],[4244,4492,"He's clearly into Elizabeth."],[4508,4640,"We don't really"],[4640,4744,"know each other well,"],[4744,4896,"so we're still strangers."],[4944,5092,"Then introduce yourself."],[5144,5296,"That way, we won't be strangers anymore."],[5304,5384,"Jeez."],[6372,6444,"This man"],[6444,6616,"is really thick-skinned."],[6820,6976,"Since Miss Collins has reservations,"],[6976,7120,"I won't press the matter."],[7156,7272,"We'll meet again soon."]],"20":[[0,176,"Every time I showed interest in Adrian,"],[176,300,"he ignored me."],[300,584,"Why did he ask for Elizabeth's number?"],[584,636,"Elizabeth Collins."],[636,760,"Aside from having the Collins blood,"],[760,860,"she's good for nothing."],[916,1004,"Mom, Dad."],[1012,1124,"I have to go to the police station."],[1124,1204,"Ivy!"],[1236,1340,"A punk like Wyatt"],[1340,1480,"deserves to be taught a lesson."],[1484,1612,"Are you seriously going to find him?"],[1628,1792,"He isn't that kind of person!"],[1804,1932,"You don't know him at all."],[1936,2024,"I'm leaving."],[2048,2128,"Ivy!"],[2152,2228,"If you insist on getting involved"],[2228,2348,"with that punk,"],[2348,2492,"then don't ever call me your Dad again."],[2756,2836,"Dad!"],[2840,2920,"Mom!"],[2940,3028,"Look at her."],[3028,3156,"You raised her for so many years,"],[3156,3292,"and look what a piece of work you raised."],[3532,3740,"You can't separate the main couple."],[3740,3932,"The more Mom and Dad try to stop them,"],[3932,4016,"the more they'll be hated."],[4016,4220,"Once Little Punk becomes a powerful CEO,"],[4228,4404,"the Collins family is still doomed."],[4532,4684,"The Collins family suffered Wyatt's revenge"],[4684,4736,"and got destroyed completely."],[4760,4884,"Ivy and Wyatt"],[4884,4976,"lived happily ever after."],[5084,5196,"The plot has changed,"],[5196,5440,"and the storyline in the novel updated too."],[5480,5656,"But the ending for the leads"],[5676,5776,"is still a happy ending."],[5848,5928,"The Collins family"],[6084,6224,"is still doomed to ruin."],[6440,6548,"The mind I heard earlier"],[6548,6640,"was all true."],[6640,6756,"It seems Wyatt really will"],[6756,6892,"destroy the Collins family years from now."],[6892,6996,"Thankfully, God showed mercy"],[6996,7164,"and let me hear Elizabeth's mind."],[7176,7352,"As long as I follow my daughter's guidance,"],[7360,7536,"changing our destiny will be possible."]],"21":[[152,252,"Your precious daughter"],[252,376,"just ran off."],[376,532,"Aren't you going to chase her?"],[548,704,"I want to watch more dramas."],[704,888,"I'm here for the gossip!"],[1092,1188,"You are"],[1188,1284,"our precious daughter."],[1304,1412,"You have class soon,"],[1412,1564,"so I need to get you back to school."],[1668,1768,"Did Edward really say"],[1772,1848,"I am"],[1848,1960,"his precious daughter?"],[1984,2124,"And he's driving me to school?"],[2296,2392,"This isn't right."],[2428,2508,"Something's off."],[2696,2780,"Just let Ivy"],[2780,2928,"handle her own issues."],[2944,3076,"Your studies are what matter."],[3896,4016,"Ethan and Adrian"],[4016,4140,"wasted too much of my time."],[4140,4400,"Those Graham brothers are absolutely toxic."],[5532,5724,"Hurry inside, Lizzie."],[5876,5952,"Got it."],[5952,6032,"Go on."],[6320,6424,"The rumor that Elizabeth is not being loved"],[6424,6600,"is totally fake."],[7344,7456,"They were hugging."],[7456,7532,"Finally, they ignored"],[7532,7612,"worldly norms."],[7644,7752,"In front of everyone,"],[7756,7860,"they shared a sweet kiss."],[8216,8356,"That is way too gross."],[8356,8516,"Good thing I didn't watch the drama yesterday."],[8516,8592,"Otherwise,"],[8616,8760,"I would be too sick to have dinner."],[8884,9032,"Those two skipped school to go to a bar."],[9036,9152,"At night, Ivy didn't"],[9152,9252,"go back home."],[9252,9324,"She went with Wyatt"],[9324,9400,"to a cheap motel instead."],[9468,9568,"Ivy claimed"],[9576,9792,"she was staying at a friend's place."],[9824,10000,"But she secretly went out with Wyatt."],[10068,10196,"The Collins family doesn't know yet."],[10304,10420,"But this time,"],[10460,10568,"I don't think Ivy"],[10580,10732,"will be able to cover it up."]],"22":[[60,196,"I can't waste"],[196,272,"all of my energy"],[272,392,"on those two."],[428,504,"I still have my own life"],[504,612,"to live"],[624,796,"and my own dreams to fulfill."],[2100,2360,"This storyline isn't going quite right."],[2408,2564,"What happened to Dad and Mom?"],[2584,2796,"I was supposed to be hated by my parents here."],[3160,3240,"Lizzie."],[3636,3796,"A true heiress is a true heiress after all."],[3796,3849,"True."],[3865,3936,"Who would neglect"],[3936,4020,"their own flesh and blood"],[4020,4116,"to dote on someone else?"],[4116,4296,"Goddess Ivy is pretty pitiful, too."],[4312,4492,"Being switched at birth wasn't her fault."],[4512,4608,"Now it looks like"],[4608,4740,"she's being abandoned."],[4768,4892,"Yeah."],[4892,5008,"Ivy is still injured."],[5016,5100,"Mr. and Mrs. Collins"],[5100,5188,"came to pick up Elizabeth"],[5188,5292,"as if nothing had happened."],[5480,5612,"If they knew the daughter"],[5612,5712,"they pampered for all these years"],[5712,5820,"hangs out with a punk,"],[5828,6056,"smoking and drinking,"],[6056,6232,"staying in cheap motels,"],[6232,6344,"and sleeping together."],[6352,6508,"They would trigger a heart attack!"],[6524,6604,"-What? -What?"],[6628,6760,"Smoking and drinking?"],[6760,6944,"Staying in cheap motels?"],[6968,7128,"Is Ivy crazy?"],[7180,7288,"With me here,"],[7292,7408,"they can't openly show"],[7408,7552,"their concern for Ivy."],[7560,7716,"I should just go to sleep."],[8064,8164,"It's getting late."],[8164,8304,"I'm going upstairs."],[8308,8384,"Okay."]],"23":[[0,76,"Lizzie has suffered"],[76,212,"so much out there all these years,"],[232,372,"yet she's still so thoughtful."],[400,464,"Lizzie"],[464,620,"uses arrogance"],[620,788,"to mask her softness."],[936,1044,"Actually, she cares more about family"],[1044,1216,"than anyone else."],[1336,1416,"That's enough."],[1464,1612,"Having Lizzie is enough for us."],[1648,1760,"As for Ivy,"],[1784,1852,"whatever path she chooses"],[1852,1968,"in life,"],[1976,2112,"is up to her."],[2308,2388,"In the past life,"],[2388,2460,"Ivy relied on her branding"],[2460,2612,"as a genius pianist"],[2612,2756,"and her innocent \"first love\" face"],[2756,2880,"to enter the entertainment industry."],[2932,3008,"Now that"],[3008,3112,"she's getting cozy"],[3112,3212,"with a thug,"],[3232,3416,"how can she still market that \"first love\" face"],[3416,3592,"and be crowned the campus goddess?"],[3736,3932,"I'll hold onto the note from yesterday."],[3976,4072,"As for right now,"],[4072,4184,"I don't even need to lift a finger."],[4184,4248,"The male and female leads"],[4248,4384,"will ruin themselves on their own."],[4472,4552,"Lizzie,"],[4564,4672,"don't you think you owe Wyatt"],[4672,4764,"an apology?"],[4840,4996,"What?"],[4996,5148,"I didn't want to deal with this moron,"],[5148,5216,"but she had to come knocking"],[5216,5356,"on my door herself."],[5388,5469,"Me?"],[5469,5616,"Owe him an apology?"],[5616,5748,"What nonsense are you talking about?"],[5816,5916,"I fell and got hurt"],[5916,6024,"on my own yesterday."],[6036,6140,"Wyatt was kind enough"],[6140,6260,"to take me to the infirmary,"],[6264,6384,"but you slandered him"],[6388,6540,"and got him sent to the police station."],[6552,6628,"Tell me,"],[6628,6688,"shouldn't you"],[6688,6788,"apologize to him?"],[6944,7028,"So it wasn't Wyatt"],[7028,7128,"who hurt Ivy?"],[7152,7288,"Wyatt actually saved her?"],[7324,7416,"Then Elizabeth"],[7436,7588,"really went too far."],[7604,7728,"Then didn't we"],[7728,7832,"wrong Wyatt yesterday?"]],"24":[[204,332,"What did I say?"],[348,520,"If anyone sent him to the police,"],[520,592,"it was Ethan who sent him"],[592,724,"to the security team."],[736,868,"Why are you yelling at me?"],[932,1048,"Ethan made the mistake,"],[1048,1116,"but I've already broken off"],[1116,1228,"my engagement with him."],[1252,1324,"Are you saying"],[1324,1480,"you didn't fan the flames?"],[1480,1604,"Who do you think you are?"],[1668,1828,"Do you think you're worth the effort?"],[1888,2064,"If you want to protect that punk,"],[2072,2192,"go ahead and protect him yourself."],[2192,2368,"Don't drag me into it."],[2452,2536,"Elizabeth,"],[2536,2664,"how can you say that?"],[2692,2868,"Wyatt has been wrongly accused."],[2896,2964,"I just want you to"],[2964,3028,"apologize to him."],[3052,3156,"Is that so hard?"],[3208,3300,"First,"],[3332,3488,"the police took him away"],[3488,3640,"because they must have evidence."],[3640,3724,"Second,"],[3732,3828,"I have absolutely nothing"],[3828,3980,"to do with this matter."],[4008,4100,"Third,"],[4168,4360,"you might be eager to please Wyatt,"],[4432,4556,"but I'm not that stupid."],[4652,4816,"The police took Wyatt away"],[4816,4892,"all because you"],[4892,4980,"said things in front of Mom and Dad"],[4980,5076,"that you shouldn't have said."],[5080,5152,"And you urged them"],[5152,5264,"to pressure the police station."],[5332,5412,"Is Ivy"],[5412,5556,"out of her mind?"],[5556,5640,"Asking me to apologize"],[5640,5760,"to Wyatt is one thing,"],[5760,5928,"but she's openly accusing the Collins family"],[5928,6076,"of using improper means"],[6076,6176,"to detain Wyatt."],[6184,6284,"Is she trying to get the Collins family killed?"],[6284,6388,"Will she not stop until she does?"],[6452,6628,"Wyatt has a big heart."],[6656,6788,"As long as you apologize to him,"],[6788,6896,"he will forgive you."],[6968,7040,"So that is"],[7040,7156,"the truth of the matter."],[7196,7324,"The Collins family used their power"],[7324,7488,"to have the police detain Wyatt."],[7512,7676,"That really is going too far."],[7680,7820,"That Wyatt guy really"],[7820,7936,"is quite pitiful."],[8488,8624,"Ethan's change in attitude toward Ivy"],[8624,8736,"and the fact that the police"],[8736,8852,"have detained Wyatt,"],[8852,8956,"prove that"],[8992,9196,"they have evidence."],[9212,9464,"And now, that evidence is here."]],"25":[[0,108,"Are you sure"],[160,316,"that you injured yourself,"],[320,428,"and it has nothing to do with Wyatt?"],[548,628,"Of course."],[748,876,"In that case,"],[928,1088,"I apologize for subjecting everyone"],[1088,1332,"to this eyesore along with me."],[1388,1552,"What does she mean by that?"],[2368,2448,"Impossible."],[2472,2544,"Only Wyatt and I"],[2544,2660,"were there at the time."],[2660,2776,"There was no one else."],[2844,2940,"Damn!"],[3208,3400,"You're lukewarm to me in public,"],[3464,3692,"but so hot in private, huh?"],[3736,3828,"You little vixen."],[3884,3992,"My private intimate moments"],[3992,4172,"are being publicly judged by so many people."],[4208,4372,"This is going to be the death of me!"],[4376,4524,"If what Ivy said is true,"],[4528,4612,"and she only just broke off"],[4612,4700,"her engagement with her fiancé"],[4712,4840,"then what is this?"],[4840,4960,"Two-timing?"],[4960,5036,"An affair?"],[5192,5256,"She really is"],[5256,5400,"a pure and innocent goddess!"],[5708,5800,"What are you looking at?"],[5800,5900,"Stop looking!"],[5912,5996,"Everyone, close your"],[5996,6076,"eyes right now!"],[6164,6416,"As expected, only Wyatt"],[6420,6580,"would protect me like this."],[6872,7048,"If I don't let everyone see clearly,"],[7048,7176,"I don't know how"],[7176,7228,"the Collins family's name"],[7228,7348,"can otherwise be cleared."],[7380,7484,"Go ahead, keep smashing."],[7504,7628,"If the phones break,"],[7636,7800,"you can just buy everyone new ones."]],"26":[[0,80,"Oh, right!"],[80,148,"I was just thinking"],[148,228,"about getting a new phone."],[236,344,"So,"],[344,444,"thanks in advance, Wyatt."],[524,696,"I'm just afraid Wyatt can't afford it."],[764,900,"What are you afraid of?"],[900,976,"He and Ivy"],[976,1104,"are boyfriend and girlfriend."],[1148,1276,"If he can't pay,"],[1276,1392,"just ask Ivy."],[1912,2028,"Ivy,"],[2044,2204,"this is the real reason"],[2204,2388,"the police took Wyatt away, isn't it?"],[2428,2576,"Where did this video come from?"],[2604,2744,"How did Elizabeth get it?"],[2820,3032,"It's you! It's all you!"],[3060,3140,"For the past few days, you"],[3140,3232,"have been plotting against me."],[3252,3328,"Elizabeth,"],[3328,3468,"you are so vicious!"],[3532,3708,"Did I force you to kiss him?"],[3712,3792,"Or did I force you"],[3792,3888,"to defend him?"],[3908,4096,"The Good Samaritan who sent me the video"],[4096,4220,"probably sent a copy to your"],[4220,4372,"fiancé as well."],[4372,4504,"I'm guessing"],[4504,4604,"that's the reason"],[4604,4676,"why he wants to break off"],[4676,4788,"the engagement with you."],[4852,5012,"No wonder when I said yesterday"],[5012,5156,"that I fell on my own,"],[5156,5364,"everyone's reaction was so strange."],[5368,5576,"It turns out they knew all along."],[5576,5692,"Then what does that make"],[5692,5796,"my behavior yesterday?"],[5796,5952,"Was I a clown?"],[6296,6540,"Now I have nothing left."],[6612,6760,"I only have Wyatt."],[6860,6964,"Ivy,"],[6964,7056,"don't worry."],[7084,7168,"I'm here."],[7204,7276,"I won't let you suffer"],[7276,7464,"the slightest grievance again."],[8200,8400,"Today, I'll show you"],[8448,8656,"that bullying my woman"],[8656,8836,"comes with a price!"]],"27":[[64,176,"You're just relying on your"],[176,356,"pretty face, aren't you?"],[420,500,"Today,"],[568,684,"I'll make sure you can"],[684,796,"never show your face again!"],[884,964,"No!"],[1044,1180,"This wasn't in"],[1216,1352,"the System's generated plot."],[1392,1540,"It's hard to dodge the System's plot."],[1540,1696,"I originally wanted to save my word edits,"],[1696,1756,"but I still"],[1756,1908,"want to be an actress in the future."],[1992,2096,"For the sake of this face,"],[2476,2696,"change \"walk\" to \"kneel\"!"],[3328,3432,"What am I doing?"],[3468,3604,"No matter how much you hate me,"],[3608,3700,"you shouldn't hurt people in public"],[3700,3836,"and drag yourself down with it."],[3892,4044,"Novel male leads"],[4044,4204,"are all a little sick in the head."],[4204,4288,"Take Wyatt, for example."],[4288,4420,"Because of childhood trauma,"],[4420,4568,"he lashes out violently at the drop of a hat."],[4580,4732,"But is having childhood trauma"],[4732,4796,"really a valid excuse"],[4796,4880,"to hurt others?"],[4952,5008,"Wyatt,"],[5044,5200,"why the sudden grand gesture?"],[5204,5332,"I really can't accept such an honor."],[5356,5492,"Teacher, it's him!"],[5492,5532,"It's him!"],[5544,5660,"That blond guy!"],[5708,5788,"Elizabeth,"],[5788,5880,"are you alright?"],[5928,6008,"Teacher,"],[6040,6168,"Wyatt tried to kill me!"],[6208,6292,"I'm scared."],[6320,6428,"I'm really scared."],[6500,6580,"Elizabeth,"],[6580,6652,"you...!"]],"28":[[0,72,"Teacher,"],[76,216,"look, he's still holding a knife."],[216,268,"I feel like"],[268,372,"he poses a serious threat"],[372,536,"to my personal safety."],[752,1000,"Wyatt, what do you think you're doing?"],[1072,1164,"Teacher, Wyatt"],[1164,1280,"he didn't mean it like that."],[1296,1356,"He didn't"],[1356,1484,"really intend to hurt Elizabeth."],[1500,1588,"Look at her,"],[1588,1700,"she isn't hurt at all."],[1744,1892,"He tripped on his own."],[1924,2120,"Otherwise, the consequences would be bad."],[2128,2256,"All the students saw it."],[2256,2404,"He just wanted to ruin my face."],[2448,2520,"Wyatt didn't really"],[2520,2616,"mean to hurt you."],[2636,2832,"Look, you aren't hurt at all."],[2860,2952,"Besides,"],[2964,3108,"you were the one who wronged him first."],[3144,3256,"I wronged him?"],[3300,3544,"Teacher, those two were dating,"],[3556,3640,"but they were caught by Ivy's"],[3640,3752,"fiancé,"],[3752,3892,"who then broke off the engagement."],[3892,4092,"Can you blame me for that?"],[4124,4228,"It's not like I held their heads together"],[4228,4384,"and forced them to kiss."],[4416,4644,"Students these days are so wild."],[4756,4880,"Wyatt just wants to disfigure me,"],[4880,4928,"simply because"],[4928,5036,"I'm too beautiful,"],[5036,5200,"making Ivy's title of \"School Beauty\""],[5200,5376,"feel illegitimate."],[5420,5496,"Just to make his"],[5496,5684,"girlfriend happy,"],[5708,5848,"he attacked me so viciously."],[5848,5928,"Teacher,"],[5928,6108,"letting someone like him into the school"],[6108,6328,"is like letting a wolf into a flock of sheep."],[6384,6580,"Keeping him here"],[6644,6712,"will only damage"],[6712,6844,"our school's reputation."],[6904,7128,"Ivy, Wyatt, Elizabeth."],[7128,7180,"The three of you,"],[7180,7288,"come with me to the office."]],"29":[[12,144,"This scumbag male lead."],[144,284,"Does he have any idea"],[284,436,"how much damage he's caused me?"],[444,580,"He might get expelled"],[580,728,"or end up back in jail,"],[728,804,"but I"],[812,1028,"I've lost a pawn."],[1088,1236,"Why is she acting so aggrieved?"],[1244,1352,"Who the hell"],[1352,1488,"is the one who's truly pitiful?"],[1788,1932,"That's exactly what happened."],[1996,2064,"Alright."],[2064,2120,"We understand"],[2120,2224,"the general situation now."],[2444,2516,"Young man,"],[2516,2604,"you need to come with us."],[2640,2720,"Take him away."],[3068,3212,"Last time he hurt someone,"],[3212,3312,"he was only released"],[3312,3428,"because the victim settled."],[3448,3680,"But I won't forgive him this time."],[3732,3880,"As long as I refuse to settle,"],[3880,4148,"he's going to be stuck"],[4164,4324,"at the police station for a few days."],[4436,4592,"Alright, we're done here."],[4592,4708,"You two can go back now."],[5408,5488,"Elizabeth,"],[5824,5920,"Wyatt didn't hurt"],[5920,6028,"you at all."],[6036,6116,"Why must you be"],[6116,6220,"so cruel?"],[6240,6392,"Don't you know doing this"],[6392,6532,"could get him expelled?"],[6536,6636,"It will leave a stain"],[6636,6728,"on his record."],[6772,6876,"That Little Punk"],[6876,6996,"is already covered in stains."],[6996,7108,"What's one more?"],[7120,7216,"He's probably lost count"],[7216,7268,"of how many times"],[7268,7404,"he's been to the police station."],[7464,7608,"Is there really any difference"],[7636,7716,"between the police station"],[7724,7860,"and his own home?"],[7868,7948,"Elizabeth,"],[7964,8040,"I didn't expect you to be"],[8040,8164,"so unreasonable."],[8212,8316,"Well, congratulations then."],[8316,8484,"on finally seeing me clearly."],[8504,8616,"If you people"],[8628,8740,"dare to provoke me again,"],[8740,8856,"I will destroy you."]],"30":[[0,80,"Elizabeth,"],[112,236,"don't think returning to the Collins family"],[236,384,"means you've reached the top."],[384,456,"Do you really think"],[456,568,"I can't handle you?"],[576,680,"Let me tell you,"],[732,932,"I just didn't want to fight before."],[932,1132,"But since you're so aggressive,"],[1132,1300,"don't blame me for fighting back."],[1352,1452,"I'm waiting."],[1548,1628,"Hold on."],[1712,1792,"In the future,"],[1824,1968,"your kids with Little Punk"],[1968,2064,"won't be able to get government jobs."],[2074,2202,"Are you out of your mind?"],[2258,2358,"You psycho!"],[3014,3126,"Megan is also"],[3126,3266,"a female lead in a book."],[3278,3466,"She and Ivy are best friends."],[3498,3638,"For her sake,"],[3642,3746,"Ivy wouldn't hesitate"],[3746,3930,"to stab her own brother in the back."],[3966,4138,"My poor brother."],[4138,4298,"He didn't come home last night."],[4442,4554,"Megan suddenly"],[4554,4702,"felt unwell last night."],[4706,4798,"My brother felt sorry for her,"],[4798,4930,"so he stayed to take care of her,"],[4930,5134,"sleeping on the floor all night."],[5210,5386,"Today's plot involves"],[5410,5674,"the two female leads pouring their hearts out,"],[5686,5798,"being moved by each other's"],[5798,5974,"fairy-tale romances,"],[5998,6114,"and making a pact"],[6114,6246,"to support one another."],[6278,6418,"Today's show"],[6418,6546,"probably won't happen."],[6626,6742,"I'll just watch the show"],[6742,6858,"from within the plot."],[7250,7338,"Elizabeth,"],[7374,7482,"why aren't you leaving yet?"],[7494,7686,"Oh, I'll head out as soon as I pack my things."],[7686,7786,"You guys go ahead."],[7802,7878,"It's getting late,"],[7878,7954,"so we're taking off."],[7954,8022,"Bye."],[8030,8162,"Bye."],[8162,8276,"Bye."],[8276,8370,"Those guys are actually"],[8370,8448,"future entertainment superstars"],[8448,8570,"who became connections"],[8570,8704,"for Ivy."]],"31":[[12,208,"But since this book focuses on romance,"],[216,336,"Ivy's career"],[336,472,"is only mentioned in passing."],[472,644,"So I'm going to secure"],[644,768,"these connections for myself."],[1576,1756,"Miss Collins, we meet again."],[1776,1912,"I wonder if the video I provided"],[1952,2076,"was helpful to you?"],[2104,2164,"Oh,"],[2184,2336,"so it was you who sent it."],[2340,2432,"I thought"],[2432,2580,"it was from Ethan."],[2628,2708,"My brother hired someone"],[2708,2808,"to film that video."],[2832,2920,"I suspected back then"],[2920,3028,"that he was reborn too."],[3076,3216,"But seeing Elizabeth, I realized"],[3260,3340,"he was just hearing"],[3340,3440,"her mind."],[3448,3528,"Miss Collins,"],[3576,3656,"this time,"],[3704,3868,"may I have the honor"],[3876,4020,"of inviting you to afternoon tea?"],[4052,4240,"Afternoon tea is so boring."],[4240,4412,"I just want to go home and lie down,"],[4448,4672,"but if we're going to Blue Lake,"],[4672,4804,"then I'm interested."],[4804,4968,"Ivy and Megan"],[4968,5104,"are meeting there right now."],[5128,5364,"How about we go to Blue Lake?"],[5408,5624,"Can this man read minds?"],[5624,5736,"How does he know me so well?"],[5764,5860,"Agreeing immediately"],[5860,5968,"wouldn't look good."],[6000,6092,"It makes it seem like I'm desperate"],[6092,6244,"for this afternoon tea."],[6264,6368,"Us girls"],[6368,6496,"need to be a little reserved."],[6552,6712,"It would be great if he said,"],[6716,6892,"\"Princess, please join me.\""],[7268,7376,"Princess, please join me."],[7500,7576,"That meme seems"],[7576,7692,"very popular lately."],[7892,7988,"Mr. Graham"],[8000,8176,"doesn't look like someone"],[8176,8336,"who keeps up with online trends."],[8336,8400,"Oh,"],[8468,8540,"I just got a new"],[8540,8656,"5G phone recently."],[8936,9008,"Princess, please get in the car."]],"32":[[100,196,"My family's driver"],[196,316,"is already waiting for me."],[348,428,"It's fine."],[480,556,"I'll give your father"],[556,656,"a call right now."],[1044,1124,"Uncle,"],[1176,1256,"I'm taking Elizabeth"],[1256,1376,"out for afternoon tea today."],[1656,1736,"All settled."],[1744,1844,"It's not that I wanted"],[1844,2004,"to have this afternoon tea."],[2008,2096,"It's mostly because"],[2096,2260,"there happens to be gossip there."],[2268,2420,"How could I resist?"],[2424,2504,"Alright,"],[2504,2636,"I'll do you this favor."],[2716,2796,"Thanks."],[3980,4120,"Why can't I hear anything?"],[4120,4212,"There is such huge gossip,"],[4212,4324,"but I can't catch a word."],[4348,4480,"To want it but not get it,"],[4532,4656,"is the loneliest feeling."],[5220,5300,"William?"],[5428,5492,"Big Brother?"],[5548,5812,"Why is William here?"],[6020,6084,"Wow."],[6092,6156,"What a coincidence."],[6292,6372,"William,"],[6384,6488,"what are you doing here?"],[6692,6748,"How about"],[6748,6872,"we go somewhere else to chat?"],[6876,6972,"That sounds great."],[8592,8672,"Big Brother."],[8724,8804,"Big Brother."],[9208,9288,"Big Brother."],[9396,9524,"Why are you here?"],[9524,9624,"What is going on?"],[9648,9824,"Are the male supporting leads all awakening?"],[9836,9924,"Did Big Brother"],[9924,10000,"also find out"],[10000,10116,"that he's being cheated on?"],[10200,10280,"In the past life,"],[10316,10440,"William's genius son"],[10440,10560,"found his biological father"],[10616,10692,"and even set him up"],[10692,10804,"with Megan."],[10920,11060,"Backstabbed by those two,"],[11112,11232,"William turned dark."],[11308,11380,"In the end, after the Collins family"],[11380,11428,"went bankrupt,"],[11428,11524,"he chose to commit suicide."],[11572,11652,"But in this life,"],[11740,11852,"things seem different."],[11920,11996,"Could William"],[11996,12164,"also hear Elizabeth's mind?"]],"33":[[56,136,"William,"],[212,324,"what are you doing here?"],[452,532,"Passing by."],[572,672,"Just passing by."],[708,892,"Hmph, passing by."],[900,976,"Why didn't you pass by"],[976,1084,"the Himalayas?"],[1152,1264,"Just passing by?"],[1308,1444,"Your fiancée"],[1448,1532,"and your dear sister"],[1532,1608,"are both here today."],[1636,1704,"Aren't you going over"],[1704,1820,"to say hello?"],[1836,1936,"No need."],[2136,2304,"No, really, no need."],[2464,2620,"If you're too shy,"],[2640,2772,"I can go call them for you."],[2836,3044,"I followed them here."],[3120,3272,"I was afraid of being spotted."],[3372,3544,"One is your fiancée,"],[3584,3716,"and the other is your dear sister."],[3756,3912,"Why are you tailing them?"],[3960,4128,"That's not very gentlemanly."],[4136,4280,"I might just tell on you."],[4380,4588,"What do you want?"],[4760,4888,"Since you followed them here,"],[4912,5032,"you must be prepared."],[5072,5148,"You definitely have some gossip."],[5148,5256,"Share it with us."],[5296,5416,"Keeping it all to yourself"],[5460,5600,"won't end well for you."],[5640,5780,"Adrian is so awesome."],[5780,5896,"I've got to learn from him."],[5936,6040,"Once I learn his ways,"],[6040,6264,"I'll be able to get even more gossip."],[6296,6376,"Wait a minute."],[6376,6436,"Why is Adrian"],[6436,6504,"showing up here"],[6504,6636,"with my sister?"],[6724,6912,"He's up to no good with Lizzie,"],[7052,7188,"and don't you try to deny it."],[7296,7376,"I bet"],[7564,7704,"you surely brought along"],[7748,7888,"Megan's listening device."],[7968,8048,"Hand it over."],[8156,8288,"Let's all enjoy the gossip together."],[8288,8408,"Does this jerk have"],[8408,8512,"any sense of boundaries?"],[8548,8696,"This is my privacy, okay?"],[8716,8796,"Gossip."],[8808,8916,"I want the gossip."],[8948,9024,"Lizzie"],[9024,9076,"definitely has some"],[9076,9200,"misunderstanding about Megan."],[9216,9368,"It's the perfect chance for her to listen"],[9372,9512,"and clear up the misunderstanding."]],"34":[[236,284,"Uh"],[300,400,"Let me say this first,"],[428,576,"I don't actually suspect Megan."],[576,644,"I just feel"],[644,720,"Megan,"],[756,836,"are you saying"],[860,1088,"this baby isn't my brother's?"],[1094,1172,"Holy sh*t."],[1216,1448,"Talk about perfect timing."],[1448,1648,"It's explosive right from the start."],[1708,1788,"Ivy,"],[1856,1996,"William treats me so well,"],[2044,2176,"yet I'm deceiving him like this."],[2256,2328,"Tell me,"],[2328,2484,"am I a bad woman?"],[2564,2660,"I trust that Ivy"],[2660,2744,"wouldn't help anyone else"],[2744,2832,"keep secrets from me."],[2880,2960,"Megan,"],[2992,3144,"what's done is done."],[3168,3256,"The child acts as"],[3256,3376,"needs a father after all."],[3420,3552,"Just marry my brother."],[3564,3720,"It will give the child a name,"],[3720,3780,"and allow him"],[3780,3908,"to grow up healthy and happy."],[3924,4080,"It's good for both of you,"],[4120,4288,"and for the child as well."],[4296,4392,"What about me?"],[4452,4600,"How did I ever wrong Ivy?"],[4600,4660,"She actually wants"],[4660,4764,"me to be the fall guy."],[4884,5060,"I know this is for the best,"],[5108,5220,"but I just feel"],[5228,5364,"a little guilty towards William."],[5468,5564,"My brother loves you."],[5564,5688,"He loves you with all his heart."],[5716,5840,"Even if he knew this child"],[5840,5952,"wasn't his,"],[5988,6144,"he would still choose to forgive you."],[6236,6332,"I knew it,"],[6352,6508,"he's just asking to be cuckolded."],[6592,6760,"I know William likes me,"],[6884,6964,"but"],[6980,7152,"But what, Megan?"],[7196,7336,"Just forget about that man"],[7336,7512,"and live a good life with my brother."],[7548,7720,"If you don't mention this,"],[7724,7892,"he will never know."]],"35":[[0,144,"What if I can't forget him?"],[172,252,"Ivy,"],[300,372,"although I only"],[372,484,"met him once,"],[532,696,"I've already fallen in love with him."],[908,1116,"Megan, is he handsome?"],[1148,1228,"Yes."],[1344,1424,"I think"],[1464,1624,"it was love at first sight."],[1720,1860,"Love at first sight,"],[1912,2056,"how romantic."],[2176,2256,"Megan,"],[2312,2452,"if you like him,"],[2464,2540,"then be brave and go for it."],[2540,2676,"Pursue your own happiness."],[2816,2900,"But I don't know"],[2900,3000,"who he is."],[3076,3208,"The world is so big,"],[3236,3372,"where am I supposed to find him?"],[3372,3452,"But your belly"],[3452,3580,"won't wait that long."],[3644,3724,"Why don't you"],[3776,3932,"marry my older brother first?"],[3960,4084,"Once you find that man,"],[4128,4264,"you can divorce my brother."],[4284,4404,"He loves you so much."],[4420,4500,"If you meet"],[4500,4600,"your true love,"],[4620,4756,"he will surely let you go"],[4756,4924,"and wish you both well."],[5196,5288,"I didn't expect that what I heard"],[5288,5436,"in Elizabeth's mind was actually true."],[5472,5652,"My fiancée and my dear sister"],[5652,5760,"One cheats on me"],[5760,5864,"and dupes me into fatherhood,"],[5888,6032,"while the other helps hide it"],[6032,6180,"and even schemes for her."],[6336,6412,"I am just"],[6412,6540,"a huge joke."],[6548,6704,"William is indeed a good man."],[6768,6868,"But I've already given my body"],[6868,7000,"and heart to someone else."],[7000,7136,"I can't give them to him."],[7204,7284,"I think"],[7380,7552,"William will understand."],[7608,7776,"As long as you are by his side,"],[7788,7992,"he'll be satisfied."],[8084,8188,"Before I find the baby's"],[8188,8328,"biological father,"],[8396,8556,"I will treat him well."],[8580,8796,"♪ Listen to me say thank you ♪"],[8828,8948,"♪ Because of you ♪"],[8952,9132,"♪ The four seasons are warm ♪"]],"36":[[264,360,"I recently"],[416,568,"I also fell in love with someone."],[616,744,"I just wanted to enjoy some gossip,"],[788,864,"but how did it end up"],[864,1012,"being about my own brother?"],[1100,1288,"Mom and Dad only see the surface."],[1296,1412,"They have no idea"],[1412,1528,"how wonderful Wyatt is."],[1548,1628,"People like them"],[1628,1784,"don't understand what true love is."],[1844,1924,"Besides,"],[1936,2072,"Ethan has a broken leg."],[2096,2272,"He's been a burden to you for years."],[2296,2368,"Are you really going to"],[2368,2516,"let him drag you down forever?"],[2592,2672,"Ivy,"],[2740,2808,"I support you"],[2808,2948,"in pursuing your own happiness."],[3084,3272,"Yes, I'm not wrong."],[3288,3428,"My love isn't wrong either."],[3552,3632,"Megan,"],[3672,3816,"I will be with Wyatt,"],[3816,3912,"and we'll face"],[3912,4028,"all difficulties together."],[4056,4148,"You hang in there too."],[4164,4260,"I hope you"],[4260,4420,"reunite with the one you love soon."],[5456,5556,"What is your plan?"],[5628,5732,"I will never let"],[5732,5820,"Ethan and Ivy"],[5820,5928,"have anything to do with each other."],[5956,6088,"If he finds out the truth"],[6092,6236,"and still wants to marry Megan,"],[6256,6388,"then I'll stay away from him."],[6388,6616,"After all, being too close to a love-struck fool"],[6620,6748,"will only bring misfortune."],[6820,6956,"My brother hasn't been"],[6956,7108,"driven crazy by the shock, has he?"],[8144,8280,"I'm fine now."],[8312,8476,"I'm doing f**king great."],[8864,9016,"Rather than staying in pain,"],[9120,9280,"I might as well just pull out"],[9280,9456,"all the thorns at once."],[9508,9736,"I've been such a fool for years."],[9736,9900,"Megan and I only ever held hands."],[9900,9988,"There was almost no kissing"],[9988,10092,"or hugging."],[10124,10268,"I thought she was just shy,"],[10296,10536,"but the truth is she doesn't love me."],[10568,10648,"Today,"],[10692,10900,"it's time for me to wake up."]],"37":[[20,188,"Since she wants"],[188,356,"to pursue true love,"],[480,648,"I'll set her free."],[712,844,"Brother,"],[844,1020,"what do you mean"],[1020,1136,"by setting her free?"],[1180,1300,"What's going on?"],[1300,1456,"Is it what I think it is?"],[1476,1656,"Breaking off two engagements in two days?"],[1692,1880,"The plot is a total mess."],[1908,2136,"Don't worry about it, kid."],[2272,2376,"I know what I'm doing."],[2484,2588,"Doesn't Megan think"],[2588,2800,"that what she did was right?"],[2804,2912,"Then let everyone see"],[2912,2980,"whether her behavior"],[2980,3112,"is truly right."],[3544,3708,"The wedding is already scheduled."],[3736,3872,"I can't just cancel it"],[3872,3964,"without a valid reason."],[4008,4112,"It would be best if Megan"],[4112,4240,"called off the engagement herself."],[4272,4388,"If she refuses,"],[4424,4596,"I'll expose this scandal."],[4648,4740,"This recording"],[4740,4896,"is the best evidence."],[5312,5416,"Adrian."],[5416,5456,"Hm?"],[5456,5560,"How old are you?"],[6012,6180,"Just a friendly reminder,"],[6192,6236,"Well,"],[6236,6412,"you're already twenty-eight this year."],[6424,6612,"Soon to be thirty."],[6612,6812,"Round that up,"],[6820,6912,"and you're fifty."],[6912,7028,"Keep calculating,"],[7044,7152,"and you're basically in the grave."],[7152,7292,"Is there any difference?"],[7324,7396,"Hold on,"],[7440,7592,"I just listened to a bit of your gossip."],[7624,7760,"Did you have to roast me like that?"],[7780,7900,"Oho."],[7900,8240,"Something's going on between these two guys."],[8248,8348,"And you, Lizzie."],[8360,8428,"Do you realize"],[8428,8540,"that old men like him"],[8540,8708,"are very scheming?"],[8732,8868,"He specifically targets"],[8868,9104,"innocent girls like you."],[9180,9256,"Today,"],[9256,9364,"he invites you to afternoon tea,"],[9364,9580,"but tomorrow,"],[9580,9728,"who knows what he'll try?"],[9800,10028,"William, let me remind you,"],[10060,10164,"you're the same age as me."]],"38":[[0,160,"Hey, don't go there."],[208,324,"I'm not the one deceiving"],[324,444,"young girls."],[588,764,"Remember this, Lizzie."],[780,880,"If you meet"],[880,980,"an old man like him again,"],[988,1120,"stay far away."],[1208,1360,"We might be friends,"],[1360,1536,"but thinking you can steal my sister"],[1536,1700,"is just wishful thinking."],[1708,1876,"To be fair,"],[1892,2128,"Adrian isn't exactly an old man."],[2148,2264,"With his looks,"],[2264,2468,"he's actually quite my type."],[2492,2540,"Mm-hm."],[2540,2612,"I knew it,"],[2652,2772,"Elizabeth has good taste."],[2856,2952,"But seriously,"],[3024,3164,"wearing a suit"],[3164,3308,"to afternoon tea?"],[3308,3472,"He looks like a stuffy old official."],[3476,3668,"He even has a fountain pen"],[3668,3852,"in his pocket. Can you believe it?"],[3876,4008,"We young people"],[4008,4200,"just can't pull off that style."],[4256,4464,"Fine. In this lifetime,"],[4500,4636,"no fountain pen will ever appear"],[4648,4800,"in my suit pocket again."],[4800,4868,"Huh?"],[4896,5108,"He took the pen out."],[5136,5248,"That pen"],[5252,5432,"looks pretty expensive."],[5736,5832,"I'm giving this pen"],[5900,6036,"to you as a gift."],[6068,6140,"You're still in school,"],[6140,6248,"so it should be useful to you."],[6536,6608,"Lizzie doesn't need"],[6608,6756,"your gift."],[6788,6900,"Since you don't want it anymore,"],[6916,7072,"I'll take it. Thanks."],[7096,7212,"I'm only twenty-eight."],[7288,7424,"Am I really not young anymore?"],[7452,7580,"What a pity."],[7608,7764,"Isn't it just a pen?"],[7804,7948,"I'll buy her a whole box later."],[8284,8440,"My sister and I are leaving."],[8472,8600,"Please make yourself at home."],[8648,8728,"Oh, right."],[8780,8900,"Thank you so much,"],[8900,9052,"for acting as an elder"],[9052,9200,"and treating Lizzie to tea."],[9268,9388,"Remember to settle the bill."],[9856,9960,"Let's go."],[9960,10132,"Check, please!"]],"39":[[220,372,"Only when I'm near Elizabeth"],[396,544,"can I hear her mind."],[660,788,"If I want to change my fate"],[788,924,"and know these details,"],[1068,1228,"I must get close to Elizabeth."],[1288,1376,"Megan and Ivy"],[1376,1452,"can't hear it."],[1568,1744,"Could it be that Elizabeth's mind"],[1968,2056,"is actually related to terms"],[2056,2180,"like \"male lead\" and \"female lead\"?"],[2944,3028,"Next time,"],[3104,3184,"I must get"],[3184,3328,"Elizabeth's contact information."],[3768,3876,"Mom, Dad,"],[4076,4216,"Lizzie went out"],[4216,4296,"with Adrian today."],[4308,4400,"You knew that, right?"],[4456,4536,"This is a disaster."],[4616,4768,"I have a bad feeling about this."],[4832,4948,"The way you handled this,"],[4972,5116,"there are nine things wrong."],[5188,5268,"First,"],[5352,5500,"what kind of person is Adrian?"],[5520,5680,"We grew up together."],[5700,5772,"He's so old."],[5772,5912,"Is he good enough for my sister?"],[6000,6276,"Second, my sister is so young."],[6300,6452,"You let her go out alone."],[6452,6592,"Can you guarantee she won't be tricked?"],[6648,6720,"Third"],[7124,7436,"Why is Big Brother nagging like a monk?"],[7648,7764,"Between the two of them,"],[7764,7908,"there is absolutely no future."],[7940,8076,"- We want to run away, too. - We want to run away, too."],[8120,8280,"- But there's no escape. - But there's no escape."],[8352,8476,"- Is this really our son? - Is this really our son?"],[8476,8596,"- He's clearly my dad. - He's clearly my dad."],[8672,8752,"Do you"],[8772,8852,"understand now?"],[8900,8988,"- Uh-huh. - We get it."],[9040,9140,"Oh, dear."],[9140,9224,"William,"],[9232,9348,"we know everything"],[9368,9488,"you're saying."],[9496,9604,"But our families have a marriage contract"],[9604,9720,"after all."],[9728,9832,"If things between Ethan and Ivy"],[9832,9972,"don't work out"],[9988,10068,"Mom,"],[10112,10248,"if you put it that way,"],[10272,10388,"I have to criticize you."],[10476,10696,"Your way of thinking is highly inappropriate."],[10736,10816,"There are exactly"],[10816,10932,"ten reasons why."],[11012,11092,"First of all"],[11504,11584,"Hey,"],[11588,11740,"why did you have to get him started?"],[11794,11912,"Oh, god."],[11912,12132,"Why couldn't I just keep my mouth shut?"]],"40":[[164,236,"The narrative in Ivy's book"],[236,360,"has collapsed."],[360,472,"Aside from the ending,"],[472,588,"the middle section has"],[588,652,"pretty much vanished."],[832,1040,"With the plot twisted this much,"],[1044,1164,"although my chances of changing my fate"],[1164,1276,"have increased,"],[1280,1384,"I've also lost the ability"],[1384,1540,"to foresee the future."],[1616,1748,"I suspect Big Brother's book"],[1772,1996,"has changed completely, too."],[2424,2536,"The only thing these two books"],[2536,2704,"have in common"],[2704,2828,"is that the ending is unchanged."],[2828,2884,"Obviously,"],[2928,3112,"a few minor changes"],[3112,3264,"aren't enough to alter the outcome."],[3292,3372,"However,"],[3396,3512,"it seems everyone else"],[3512,3584,"is also working hard"],[3584,3672,"to change their destiny."],[3676,3788,"At least it shows"],[3848,4000,"that I'm not fighting this battle alone."],[4260,4340,"Here."],[4400,4512,"What is this?"],[4554,4624,"From now on,"],[4624,4716,"I'll give you a fountain pen every day."],[4716,4792,"You can just throw them around"],[4792,4932,"for fun."],[5212,5312,"This pen"],[5366,5510,"must cost hundreds of thousands, right?"],[5572,5700,"Is Big Brother crazy?"],[5700,5828,"Or is the Collins Group"],[5836,5992,"going bankrupt ahead of schedule?"],[6084,6224,"Anything that old man has,"],[6256,6348,"the Collins family has too."],[6360,6568,"Just ignore him from now on."],[6680,6832,"So that's what this is about."],[6846,6994,"I wasn't planning to see him anyway."],[7008,7088,"But,"],[7094,7312,"one pen is enough."],[7316,7448,"Next time you see something you want,"],[7450,7620,"just buy it with the card I gave you."],[7622,7744,"No need to save me money."]],"41":[[115,204,"Don't worry."],[204,272,"I certainly won't be"],[272,387,"saving you any money."],[716,819,"Dad, Mom,"],[819,1008,"Big Brother, I'm back."],[1048,1224,"She hasn't been home for two days."],[1224,1383,"She's finally back today,"],[1388,1603,"and she brought Megan with her."],[1623,1851,"Dad, Mom, Big Brother,"],[1880,2064,"should I not have come back?"],[2087,2171,"I'll leave right now."],[2264,2300,"Wait."],[2603,2771,"Uncle, Auntie,"],[2787,2980,"Ivy stayed at my place the last two nights."],[2992,3096,"She didn't come back on purpose"],[3096,3180,"just to see"],[3200,3324,"if you would come looking for her."],[3332,3467,"But you didn't even"],[3467,3547,"call her once."],[3584,3688,"She cried herself to sleep"],[3688,3811,"these past two nights."],[3879,4000,"The night before last,"],[4000,4088,"she slept at a hotel"],[4088,4192,"with Little Punk."],[4243,4375,"She was only at your place last night,"],[4392,4515,"mainly to swap tips"],[4520,4652,"on how to cheat"],[4652,4807,"on your partners."],[4860,4971,"Is Lizzie suggesting"],[5035,5143,"that Megan cheated"],[5143,5275,"on William?"],[5315,5447,"Uncle, Auntie,"],[5471,5543,"Ivy has shared a bond with you"],[5543,5671,"for over twenty years."],[5703,5828,"Even in her dreams these past nights,"],[5828,5967,"she was calling out your names."],[5984,6064,"How can you be"],[6064,6139,"so cruel as to"],[6139,6239,"push her away?"],[6260,6347,"Are you sure she wasn't"],[6356,6476,"calling out Little Punk's name"],[6476,6579,"in her dreams?"],[6595,6723,"Given that she could just watch"],[6728,6868,"Mom and Dad get their legs broken later,"],[6868,6995,"I absolutely"],[7020,7120,"don't believe"],[7156,7268,"this bullsh*t."],[7323,7392,"To avoid upsetting Lizzie,"],[7392,7504,"Ivy originally"],[7515,7651,"didn't want to come back."],[7692,7823,"But her headaches flared up,"],[7835,7915,"and I couldn't stand seeing her in pain,"],[7915,8000,"so I brought her home."],[8084,8143,"Lizzie,"],[8168,8292,"you are a generous person."],[8331,8395,"You are here to join"],[8395,8487,"this family,"],[8500,8620,"not to break this family apart,"],[8640,8700,"right?"]],"42":[[139,239,"This Megan"],[239,404,"is even more disgusting than Ivy."],[420,540,"She is acting so melodramatic."],[624,712,"I'm just"],[736,867,"petty like that."],[875,1011,"I just don't like Ivy."],[1035,1151,"Seeing her annoys me."],[1159,1259,"What are you going to do about it?"],[1280,1424,"I'm your future sister-in-law."],[1443,1483,"How can you speak"],[1483,1572,"to me like that?"],[1591,1692,"I just did."],[1692,1764,"So what?"],[1783,1860,"William,"],[1876,2023,"aren't you going to discipline your sister?"],[2039,2196,"Are you just going to let her speak to me"],[2228,2367,"and our child like that?"],[2367,2507,"She has the nerve to mention the child?"],[2516,2651,"She dares to use an illegitimate child"],[2651,2767,"as leverage?"],[2783,2932,"What on earth is going on?"],[2960,3023,"Megan,"],[3083,3203,"my sister"],[3215,3339,"is a little rude,"],[3396,3600,"but you are as kind as Ivy,"],[3628,3764,"so you won't hold a grudge against her, right?"],[3771,3920,"I didn't expect William"],[3920,4047,"to actually fight magic"],[4092,4179,"with magic."],[4264,4415,"Of course I won't hold a grudge."],[4435,4632,"But she is so arrogant and domineering,"],[4647,4792,"she really needs to be disciplined."],[4820,4984,"This is the Collins family's business,"],[5011,5143,"so there's no need for you to worry about it."],[5192,5352,"I'm going to marry into the Collins family,"],[5407,5579,"and I can't tolerate Elizabeth."],[5584,5671,"So,"],[5671,5839,"helping Ivy is helping myself."],[5892,5979,"Megan,"],[6003,6139,"don't say anymore."],[6143,6279,"After I graduate,"],[6296,6443,"find a job, and earn money,"],[6468,6615,"I'll repay Mom and Dad."],[6635,6764,"As for anything else,"],[6831,6964,"I won't force it."]],"43":[[171,255,"Plot Hint:"],[255,417,"Megan couldn't help but speak up"],[417,575,"to defend Ivy."],[575,687,"Then, Megan"],[687,840,"delivered a long,"],[840,927,"emotional speech."],[959,1035,"I can only edit"],[1035,1151,"one character right now,"],[1191,1351,"which is obviously a drop in the bucket."],[1408,1728,"So I'll just add a word"],[1864,2107,"and change the phrase to"],[2176,2487,"\"speak the truth about Ivy.\""],[3187,3320,"Mom, Dad,"],[3332,3435,"I'm leaving right now."],[3688,3792,"Are you really"],[3792,3915,"so heartless?"],[3928,4124,"William, have you forgotten?"],[4124,4224,"When you were little,"],[4224,4328,"you often used to brag to me"],[4335,4384,"that you had such"],[4384,4496,"a cute sister."],[4532,4675,"And Uncle, Aunt,"],[4707,4800,"while she was growing up,"],[4800,4911,"every time you took her out,"],[4911,5020,"weren't you always envied?"],[5067,5175,"Do you remember why"],[5179,5288,"Ivy worked so hard"],[5288,5415,"to learn the piano?"],[5452,5535,"I once asked her the reason."],[5611,5703,"She said she wanted to be"],[5703,5803,"her parents' pride."],[5860,5979,"But now,"],[5979,6075,"how did she turn out like this?"],[6092,6200,"Ivy learned the piano"],[6200,6300,"purely because of Vivian."],[6311,6392,"She said,"],[6407,6531,"\"Vivian is so ugly,"],[6548,6687,"yet everyone envies her"],[6687,6804,"just because she plays a little piano."],[6807,6940,"It's just too unfair.\""],[6943,7179,"So she decided to learn it, too."],[7215,7315,"What?"],[7371,7471,"She learned the piano"],[7471,7620,"because of the Morgan family's daughter?"],[7712,7779,"Megan,"],[7787,7968,"are you remembering it wrong?"]],"44":[[76,152,"Megan,"],[160,300,"could you be mistaken?"],[327,463,"How could I be wrong?"],[496,620,"Ivy and Vivian were best friends"],[620,712,"when they were little."],[748,900,"It was precisely because Vivian was ugly."],[924,1100,"Ivy said hanging out with her"],[1140,1283,"made her own beauty stand out."],[1288,1424,"Megan, are you crazy?"],[1448,1564,"I'm not lying."],[1583,1671,"Ivy learned the piano"],[1687,1739,"just so she could"],[1739,1851,"outshine Vivian."],[1851,1919,"Vivian wasn't"],[1919,2035,"as pretty as Ivy,"],[2035,2139,"and her talent for the piano"],[2139,2228,"wasn't as good as Ivy's, either."],[2235,2364,"After being outshined a few times,"],[2412,2567,"she actually fell into a depression."],[2583,2719,"She was so pathetic."],[2760,2819,"The Morgan family"],[2819,2951,"used to live next door to us."],[2987,3071,"Then the whole family moved abroad"],[3071,3296,"to treat their daughter's depression."],[3296,3396,"I never imagined"],[3396,3560,"that this had anything to do with Ivy."],[3603,3771,"After Vivian returned, she became"],[3775,3920,"a famous music producer."],[3943,4143,"She targeted Ivy in the entertainment industry,"],[4171,4315,"but the male and female leads"],[4315,4428,"went after her instead,"],[4471,4684,"driving her to slit her wrists."],[4752,4856,"Megan, have you lost your mind?"],[4856,4971,"What are you talking about?"],[4992,5152,"Do you remember when we were young,"],[5156,5264,"and Ivy lost her favorite"],[5264,5332,"kitten,"],[5332,5479,"crying about it for three whole days?"],[5479,5635,"Actually, that cat"],[5635,5779,"was thrown out by her."],[5803,6020,"I was the one who gave her the idea."],[6039,6175,"She threw it out herself?"],[6211,6292,"Ivy,"],[6315,6415,"I only bought it"],[6415,6543,"because you liked it."],[6568,6723,"Dad, that's not true!"],[6723,6815,"It's Megan"],[6815,6959,"She... she's possessed!"],[6959,7120,"She did like the kitten,"],[7171,7359,"but she got bored of it quickly."],[7392,7535,"To keep up her gentle,"],[7535,7656,"kindhearted image,"],[7656,7735,"she secretly"],[7735,7868,"threw the kitten away."],[7904,8015,"Crying for three days"],[8043,8228,"was just part of the act."]],"45":[[4,88,"After all,"],[115,176,"she isn't your"],[176,279,"biological daughter."],[312,459,"If she didn't use some tricks,"],[491,563,"how could she keep you"],[563,667,"doting on her?"],[716,763,"No"],[783,883,"That's not true! Megan,"],[903,967,"you're crazy!"],[967,1016,"What are you saying?"],[1016,1083,"Security!"],[1083,1208,"Stop her!"],[1216,1311,"Let Megan finish speaking."],[1696,1796,"So,"],[1839,1935,"Ivy"],[1939,2080,"knew she wasn't our biological daughter"],[2080,2160,"all along?"],[2176,2280,"She knew from the very first time"],[2280,2400,"she went for a check-up."],[2403,2492,"She was scared back then,"],[2492,2583,"so she told me."],[2600,2735,"I was the one who helped her"],[2735,2855,"forge the results"],[2900,3007,"and cover up the truth."],[3023,3183,"But later, for some reason,"],[3203,3332,"things still went wrong."],[3332,3452,"That was obviously"],[3464,3592,"the power of the plot."],[3615,3707,"So Ivy's"],[3707,3864,"past obedience and innocence"],[3867,4020,"were all just an act?"],[4028,4135,"That's not true!"],[4139,4211,"Don't listen to her!"],[4211,4320,"Megan is framing me!"],[4324,4488,"I never did any of that!"],[4515,4707,"I only found out a few days ago"],[4732,4896,"that I wasn't mom and dad's biological daughter."],[4915,5007,"Framing you?"],[5024,5111,"Ivy,"],[5111,5252,"that's not right."],[5296,5367,"I've clearly been helping you"],[5367,5443,"cover up your lies this whole time."],[5484,5639,"When you stayed at Wyatt's place recently,"],[5671,5735,"didn't I cover for you"],[5735,5807,"then, too?"],[5828,5943,"I see what's going on now."],[5943,6088,"She came here today just to"],[6088,6171,"kick me while I'm down"],[6179,6296,"and suck up to Elizabeth!"]],"46":[[12,184,"You've said plenty about Ivy,"],[196,291,"but what about you?"],[312,404,"Do you genuinely"],[404,516,"want to marry William?"],[524,563,"Come on,"],[571,644,"tell us the truth"],[655,819,"this time."],[900,1011,"Why did I just blurt out"],[1011,1151,"all those secrets about Ivy?"],[1172,1240,"Uncle,"],[1283,1332,"of course I genuinely"],[1332,1443,"want to marry William."],[1475,1639,"I'm pregnant with his child."],[1651,1739,"If I don't marry him,"],[1748,1876,"who else can I marry?"],[2251,2371,"The baby she's carrying"],[2376,2496,"isn't Big Brother's at all."],[2496,2635,"It's from a one-night stand."],[2651,2792,"Who knows whose bastard it is."],[2944,3012,"Ivy,"],[3067,3192,"you want to expose each other?"],[3207,3275,"Bring it on."],[3284,3396,"So you knew all along"],[3396,3484,"that the baby Megan is carrying"],[3484,3635,"isn't your brother's?"],[3643,3760,"You weren't planning"],[3760,3900,"to say anything, were you?"],[3900,4032,"Mom, no."],[4039,4207,"I was going to say something."],[4252,4324,"Big Brother,"],[4343,4535,"you've always doted on me the most."],[4535,4620,"I would never help"],[4620,4752,"Megan hide this from you."],[4752,4832,"I came back today"],[4832,4947,"just to tell you"],[4956,5115,"that you can't trust Megan."],[5115,5184,"William,"],[5232,5384,"we've been together for years."],[5396,5496,"Do you really believe"],[5496,5592,"that nonsense?"],[5596,5692,"If this child isn't yours,"],[5692,5815,"whose could it be?"],[5828,5964,"That night, you clearly"],[6100,6279,"It's a real dog-eat-dog show."],[6303,6412,"I just changed one word,"],[6412,6548,"and look at the chaos it caused."],[6551,6651,"Not bad at all."]],"47":[[136,316,"It's a real dog-eat-dog show."],[339,448,"I just changed one word,"],[448,583,"and look at the chaos it caused."],[587,687,"Not bad at all."],[700,832,"The part after \"dog-eat-dog\""],[832,948,"was bleeped out."],[1008,1148,"This whole mind-reading thing,"],[1148,1275,"how does it actually work?"],[1275,1464,"Am I the only one who can hear it?"],[1472,1543,"William,"],[1543,1680,"say something!"],[1700,1855,"If even you don't trust me,"],[1855,1912,"then there's no need"],[1912,2000,"for us to get married."],[2003,2167,"William loves me so much,"],[2203,2283,"he definitely won't agree"],[2283,2364,"to calling it off."],[2432,2512,"Fine."],[2516,2639,"Then let's cancel the wedding."],[2667,2787,"William, stop joking."],[2807,2916,"We're about to start"],[2916,3012,"preparing for the wedding."],[3032,3187,"Even if it's just for the sake of the baby,"],[3247,3300,"as parents,"],[3300,3396,"we shouldn't be so impulsive."],[3432,3579,"First, we need to be sure the baby"],[3579,3671,"is actually my brother's."],[3715,3835,"Even though it hasn't been born yet,"],[3839,3971,"we can perform an amniocentesis."],[3971,4143,"Megan, do you dare?"],[4179,4288,"Stopping me from getting married"],[4300,4439,"what good does that do her?"],[4467,4615,"Now you know what panic feels like."],[4647,4820,"When you were digging up dirt on me,"],[4839,4992,"weren't you having a blast?"],[5015,5079,"William,"],[5115,5207,"are you really going to act on"],[5207,5328,"these baseless rumors"],[5356,5500,"and risk hurting our child"],[5520,5664,"just to do a genetic test?"],[5664,5739,"William"],[5739,5811,"can't stand seeing me cry."],[5843,5900,"This time,"],[5932,6088,"I'll be able to cry my way out of this."],[6088,6224,"William, don't believe her."],[6239,6279,"She told me"],[6279,6407,"she doesn't like you at all."],[6407,6523,"She's only with you"],[6523,6643,"because of your status."],[6651,6735,"She also said"],[6751,6843,"that as soon as you get close,"],[6843,6951,"she feels disgusted."],[6964,7164,"Ivy, stop making things up!"]],"48":[[0,143,"I'm telling the truth."],[148,252,"The baby in her belly"],[252,387,"is from a one-night stand,"],[396,467,"and she's still"],[467,551,"obsessed with that guy."],[563,644,"She's tricking you"],[644,755,"into being the father"],[763,916,"while planning to find him."],[967,1059,"Ivy!"],[1059,1180,"Stop making things up!"],[1191,1248,"What sin has the Collins family committed"],[1248,1343,"to deserve this?"],[1367,1508,"Why is it just one disaster after another?"],[1511,1623,"We never get a moment of peace."],[1692,1816,"It's a good thing we can hear"],[1816,1944,"Lizzie's mind."],[1960,2092,"It let us see"],[2092,2196,"their true colors sooner."],[2235,2300,"William,"],[2371,2460,"it's not like that."],[2471,2548,"William,"],[2564,2651,"what do you think about this?"],[2712,2812,"If William continues"],[2812,2903,"to be deluded by Megan,"],[2923,3019,"then I, as his father,"],[3019,3096,"will have to intervene."],[3151,3256,"The Collins family cannot accept"],[3267,3411,"a daughter-in-law like her."],[3435,3560,"We can certainly proceed"],[3560,3632,"with the wedding."],[3667,3720,"But,"],[3788,3952,"you need to do an amniocentesis first."],[3996,4135,"If it proves the child is mine,"],[4135,4192,"the wedding goes on as planned."],[4235,4352,"But if not"],[4396,4596,"So, Megan, do you dare?"],[5184,5339,"Doing the test right now"],[5352,5511,"is likely to harm the baby."],[5547,5684,"If something happens to the child,"],[5692,5800,"you'll regret it forever."],[5839,5967,"William, stop this."],[6032,6160,"We've known each other for years."],[6207,6275,"Don't you know by now"],[6275,6375,"what kind of person I am?"]],"49":[[0,184,"How ironic."],[184,364,"Years of my selfless devotion"],[375,544,"never won her heart."],[559,675,"Yet a stranger"],[675,800,"has a one-night stand with her,"],[843,1011,"and she falls deeply in love."],[1051,1191,"She's even willing to suck up to me"],[1191,1291,"just to give their bastard"],[1340,1511,"a legitimate status."],[1532,1612,"William"],[1664,1867,"William has been my lapdog for years."],[1883,2064,"Why did he suddenly change?"],[2100,2235,"If you want the wedding,"],[2283,2444,"you must prove the child's identity."],[2483,2648,"If the child is proven to be mine,"],[2648,2783,"I will provide a billion"],[2800,2896,"to help the Chandler family"],[2896,3000,"survive the loan crisis."],[3044,3128,"If not,"],[3155,3260,"then we are through."],[3288,3439,"And the Chandler and Collins families"],[3484,3635,"will have no further relationship."],[3635,3779,"The Chandler family is drowning in debt,"],[3803,3947,"and we can't pay it back at all."],[3988,4115,"Father is waiting for the wedding"],[4115,4292,"so William can bail us out."],[4324,4388,"But this child"],[4388,4507,"isn't William's."],[4552,4707,"How can it pass a paternity test?"],[4720,4800,"William,"],[4824,4943,"I am a mother."],[4979,5084,"No matter what,"],[5107,5196,"I won't let my child"],[5196,5279,"face even the slightest possibility"],[5279,5396,"of getting hurt."],[5452,5607,"For old times' sake,"],[5675,5820,"I'll give you one last choice."],[5856,6075,"The Chandler family calls off the wedding."],[6100,6260,"Whether you keep the baby or not"],[6271,6396,"is up to you."],[6423,6515,"From then on,"],[6540,6628,"our families will just have"],[6628,6759,"a standard business relationship."],[6800,6956,"It saves face for everyone."],[7007,7087,"What do you say?"],[7156,7268,"How can I do that?"],[7287,7415,"The Chandlers are relying on"],[7415,7556,"the Collins' investment to survive."],[7584,7715,"If Father knows I initiated"],[7715,7792,"the cancellation of the wedding,"],[7823,7915,"he'll beat me to death."]],"50":[[0,115,"William,"],[143,243,"you can't do this to me."],[260,368,"You know how much my parents"],[368,512,"are looking forward to this wedding."],[548,675,"If you back out now,"],[724,883,"how am I supposed to explain it to them?"],[924,1040,"When you do something wrong,"],[1103,1272,"you always have to pay the price."],[1327,1612,"Do you really have no regard for our past?"],[1671,1783,"This is already me"],[1783,1871,"showing mercy for old times' sake."],[1907,2048,"If Megan calls off the wedding herself,"],[2107,2255,"I won't expose her scandal"],[2255,2344,"to the public."],[2371,2544,"You have such a cruel heart."],[2935,3007,"My baby"],[3155,3260,"My baby"],[3303,3420,"We can't let this child"],[3439,3596,"have an accident at the Collins' house,"],[3615,3760,"or we'll never be able to explain it."],[3771,4000,"If something actually happened to this kid,"],[4000,4088,"that would be great."],[4092,4200,"He's a genius"],[4200,4328,"with an IQ of 180."],[4403,4515,"In the future, he'll destroy the Collins family"],[4515,4639,"for his father's sake."],[4652,4867,"It seems the protagonist has luck on her side."],[4903,4960,"Even their child"],[4960,5143,"is a genius with an IQ of 180."],[5188,5311,"From what Lizzie says,"],[5315,5384,"this child won't be"],[5384,5488,"in any danger."],[5524,5692,"Your pregnancy seems unstable."],[5724,5939,"It looks like you'll lose the baby."],[5980,6039,"Why don't we go to the hospital"],[6043,6096,"and abort it?"],[6179,6352,"Since he's going to destroy the Collins family,"],[6367,6523,"he shouldn't be born at all."],[6592,6728,"The baby is fine."],[6748,6868,"I just had"],[6868,6959,"some heart palpitations."],[7020,7148,"I'm fine now."],[7168,7248,"Are you sure?"],[7276,7404,"How about"],[7479,7640,"I take you to the hospital?"],[7656,7735,"No need."],[7835,7923,"I have things to do."],[7923,8040,"I'm leaving now."]],"51":[[16,100,"Remember,"],[176,264,"you only have three days"],[264,364,"to think it over."],[412,508,"In three days,"],[536,629,"if I don't receive"],[629,755,"an answer,"],[816,975,"I will take action."],[1056,1216,"As for how it will end,"],[1267,1508,"I can't guarantee anything."],[1787,1876,"That crazy woman"],[1876,2000,"exposed all my dirty laundry,"],[2007,2087,"and now,"],[2107,2244,"she's finally reaping what she sowed."],[2287,2367,"Ivy."],[2396,2455,"Dad."],[2480,2560,"You know as well as I do,"],[2576,2707,"Megan is not a good person."],[2719,2851,"You can't believe a word she says."],[3012,3100,"Enough."],[3116,3200,"For the next couple of days,"],[3207,3335,"don't go to school."],[3352,3464,"Just stay home"],[3464,3567,"and cool off."],[3596,3696,"And as for Wyatt,"],[3739,3843,"I expect you"],[3856,3944,"to never have any contact"],[3944,4035,"with him again."],[4043,4211,"Even though you are my daughter"],[4224,4332,"and I can forgive you,"],[4396,4556,"there is a limit"],[4575,4679,"to my patience."],[4728,4864,"If she remains this obstinate,"],[4884,4964,"I will disown her."],[4992,5139,"I can't let the Collins family be ruined"],[5156,5288,"just for Ivy."],[5324,5464,"Lizzie has already sent Wyatt"],[5464,5560,"to the police station."],[5584,5639,"Why do you all"],[5639,5775,"still insist on targeting him?"],[5792,5903,"The police station?"],[5947,6028,"What happened?"],[6060,6156,"What did that Wyatt"],[6184,6300,"do to Lizzie this time?"],[6375,6495,"Wyatt was just playing a joke"],[6495,6595,"on Lizzie."],[6631,6815,"I didn't expect Lizzie to overreact"],[6828,7004,"and have Wyatt arrested."],[7015,7135,"Now the school is even considering"],[7135,7256,"expelling him."],[7312,7392,"Lizzie,"],[7415,7528,"go to the police station"],[7548,7712,"and tell them to release Wyatt."]],"52":[[48,132,"Release him?"],[187,272,"Ivy,"],[279,451,"he held a knife to me."],[524,624,"He deserves whatever"],[626,717,"punishment he gets."],[728,851,"If you feel so sorry for him,"],[851,948,"why don't you go keep him company inside?"],[951,975,"What?"],[996,1191,"- What? A knife? - What? A knife?"],[1191,1240,"Lizzie,"],[1275,1408,"why didn't you tell me?"],[1408,1448,"Huh?"],[1491,1612,"That little brat"],[1612,1748,"pulled a knife at school!"],[1792,1871,"This won't do."],[1876,1996,"I'm calling the school board right now."],[2039,2107,"If they don't"],[2107,2216,"kick that Wyatt kid out,"],[2244,2355,"I'm canceling the building donation"],[2412,2523,"I promised."],[2523,2703,"It was just a tiny knife."],[2719,2848,"Are these people crazy?"],[2867,3019,"Why are you just standing there?"],[3035,3203,"Go immediately"],[3203,3303,"and make the call for me!"],[3371,3435,"This school,"],[3435,3556,"what the hell are they doing?"],[3615,3703,"If anything happens to my Lizzie,"],[3703,3828,"if she suffers even the slightest mishap,"],[3867,3939,"I’d like to see how they"],[3939,4024,"explain themselves to me!"],[4032,4224,"Crazy. Everyone's gone crazy."],[4232,4347,"Something this huge happens,"],[4364,4520,"and no one at the school even notified me."],[4543,4688,"Do they have no respect for me at all?"],[4771,4864,"I'm going over there right now."],[5032,5103,"Big Brother,"],[5143,5256,"don't you think Dad's reaction"],[5256,5403,"is a bit excessive?"],[5420,5500,"Indeed."],[5532,5684,"Dad is getting on in years, after all."],[5715,5775,"The way he handles things"],[5852,5984,"isn't exactly appropriate."],[5996,6084,"I knew it."],[6084,6196,"You're always the reasonable one."],[6220,6400,"But I heard"],[6407,6523,"Wyatt has joined some sort of"],[6523,6604,"gang of thugs."],[6715,6823,"I'll get the funds ready immediately,"],[6879,6995,"and pull some strings."],[7015,7192,"I'm going to wipe that gang out"],[7192,7348,"by the roots!"]],"53":[[24,200,"I will completely destroy"],[200,352,"that organization!"],[524,644,"How is Big Brother even crazier"],[644,700,"than Dad?"],[712,779,"Dad just wants to get"],[779,888,"Wyatt expelled,"],[903,1016,"but Big Brother wants to ensure the demise of"],[1016,1191,"every thug in Riverton."],[1200,1375,"If Wyatt gets expelled,"],[1375,1559,"how is the rest of the plot to start?"],[1559,1628,"Besides,"],[1644,1800,"that gang"],[1812,1935,"is supposed to show up later."],[2055,2323,"After Wyatt turned bad, he recruited his thugs."],[2323,2532,"and leads them to conquer the underworld."],[2539,2703,"successfully becoming the boss."],[2776,2919,"Later, he launders the money,"],[2948,3067,"and that's how he becomes the powerful CEO."],[3356,3464,"Now, all these important plot points"],[3464,3620,"are going to disappear."],[3735,3843,"Did I cast a spell"],[3903,4075,"on the Collins family?"],[4075,4200,"Why is everyone suddenly"],[4271,4464,"being so cooperative?"],[4500,4679,"In that case,"],[4767,4947,"I'll be able to change my fate soon."],[5384,5464,"Lizzie,"],[5475,5688,"next time something like this happens,"],[5688,5788,"you must tell the family."],[5788,5824,"Ah"],[5935,6007,"Honestly."],[6024,6143,"How dare any random riffraff"],[6167,6235,"try to bully the daughter"],[6235,6347,"of the Collins family."],[6379,6484,"I just thought"],[6484,6668,"I could handle it by myself."],[6831,6976,"When I first came to the Collins family,"],[6976,7151,"I didn't get much attention."],[7168,7268,"Weren't they always taking care of"],[7268,7364,"the female lead?"],[7371,7587,"Why has their attitude changed?"],[7607,7707,"That night,"],[7712,7856,"Ivy's headaches acted up."],[7871,8087,"I left Lizzie behind to stay with Ivy."],[8140,8231,"The next day, I found out"],[8231,8384,"that Lizzie had a fever."],[8384,8500,"After the fever broke,"],[8535,8687,"she seemed like a different person."],[8728,8828,"And suddenly, I could"],[8828,8935,"hear her mind."]],"54":[[8,68,"If I hadn't"],[68,227,"heard Lizzie's mind,"],[260,343,"I'm afraid I really would have"],[343,455,"mistreated my own biological daughter"],[475,679,"for the sake of an adopted one."],[700,791,"She didn't tell us about Wyatt."],[816,908,"She must have felt"],[948,1019,"that we wouldn't"],[1019,1172,"stand up for her."],[1291,1500,"I really want to slap myself."],[1567,1716,"But slapping myself isn't enough;"],[1760,1855,"later,"],[1871,2067,"I'll have to slap Edward a few times, too."],[2123,2200,"Mom,"],[2200,2364,"you're blowing this out of proportion."],[2383,2487,"Look at Lizzie."],[2487,2551,"She doesn't have"],[2551,2644,"a single scratch on her."],[2676,2764,"The one who is actually hurting"],[2764,2839,"is Wyatt."],[2864,2983,"He's still at the police station."],[2996,3076,"We should get him"],[3076,3171,"out of there first."],[3187,3271,"Ivy,"],[3279,3415,"if Wyatt were innocent,"],[3439,3560,"would the police have arrested him?"],[3615,3675,"Are you really going to"],[3675,3775,"throw years of the Collins family's teachings"],[3807,3960,"out the window"],[3960,4079,"just for that thug?"],[4088,4156,"This time,"],[4179,4324,"it seems that acting cute"],[4324,4403,"won't be enough to get me off the hook."],[4452,4564,"Do Mom and Dad"],[4564,4660,"really hate me now?"],[4684,4739,"Mom,"],[4771,4811,"I"],[4811,4871,"Enough."],[4907,4996,"From now on,"],[5056,5228,"other than home and school,"],[5232,5356,"you're not going anywhere."],[5407,5471,"And in the future,"],[5503,5660,"if you ever contact Wyatt again,"],[5688,5803,"then leave the Collins family."],[5860,5952,"If you want Wyatt,"],[5971,6164,"or remain a daughter of the Collins family."],[6184,6288,"The choice is yours."],[6303,6407,"In terms of blood,"],[6420,6568,"I don't have the Collins family blood."],[6592,6804,"In terms of debt, I owe the Collins family."],[6820,6931,"From the very beginning,"],[6931,7084,"I've only had one bargaining chip,"],[7104,7300,"and that was the Collins family's love."],[7331,7431,"But now,"],[7471,7668,"not a shred of that chip remains."],[7804,7940,"Have you made your choice?"],[7995,8112,"Do you think you've won?"],[8143,8220,"No."],[8240,8471,"It's only just begun."]],"55":[[12,100,"From now on,"],[136,279,"I'll always be part of the Collins family."],[308,428,"In that case,"],[471,528,"from now on,"],[544,624,"don't ever let me hear"],[624,716,"the name Wyatt"],[716,824,"come out of your mouth again!"],[872,964,"I understand."],[1027,1096,"Elizabeth,"],[1124,1308,"this is all your fault."],[1327,1432,"If it weren't for you,"],[1451,1535,"I would always have been"],[1535,1623,"the Collins family's little Princess."],[1639,1776,"If you just disappear,"],[1787,2003,"everything will go back to normal."],[2019,2139,"All the things that belong to me,"],[2160,2323,"I'll take them back, piece by piece."],[2371,2500,"As long as I keep up the act,"],[2539,2648,"one day,"],[2671,2839,"I'll win back Mom and Dad's hearts."],[2851,2960,"I'll make them see"],[2983,3151,"that blood ties don't matter,"],[3151,3267,"only excellence does."],[3394,3455,"Plot Hint"],[3503,3643,"As long as I keep up the act,"],[3661,3743,"one day"],[3743,3909,"I'll win back Mom and Dad's hearts."],[3909,4043,"I'll make them see"],[4043,4177,"that blood ties don't matter,"],[4177,4328,"only excellence does."],[4328,4543,"So the female lead intends"],[4543,4779,"to crush me with her academics"],[4779,4871,"and talent?"],[4932,5052,"I'm ready for her."],[5088,5200,"Let's see who wins."],[5760,5935,"Sending Wyatt to the police station"],[5935,6024,"was letting him off easy."],[6088,6200,"And as for Ivy,"],[6220,6315,"Wyatt was crazy enough"],[6315,6388,"to go that far,"],[6388,6507,"yet she still defended him?"],[6556,6623,"About such a big incident,"],[6651,6784,"Lizzie didn't say a word."],[6804,6956,"We've mistreated her,"],[6979,7184,"that's why she endures in silence."],[7187,7292,"From now on,"],[7323,7512,"I will treat Lizzie twice as well."],[7568,7676,"Lizzie, come here."],[7923,8015,"For over twenty years,"],[8015,8151,"I've endured by playing the good girl."],[8184,8464,"I can continue to endure now."]],"56":[[51,179,"This little outfit is cute."],[317,427,"This one is nice too."],[475,528,"Hey,"],[528,624,"Megan, come here."],[988,1100,"What's wrong?"],[1135,1267,"You look pale."],[1293,1456,"The baby you're carrying"],[1467,1612,"cannot be put at risk."],[1635,1751,"Listen to Mom."],[1770,1876,"The child in your belly"],[1876,1983,"is more important than anything."],[1983,2119,"Nothing can happen to it."],[2139,2196,"If"],[2196,2316,"they find out William"],[2316,2448,"doesn't want to marry me anymore"],[2671,2807,"Megan, are you cold?"],[2844,2992,"Mrs. Walker, bring a blanket."],[3707,3796,"Oh dear,"],[3796,3867,"you"],[3875,4007,"You're just too nervous."],[4035,4107,"But,"],[4107,4175,"all pregnant women"],[4175,4275,"are like this."],[4315,4439,"Once you're married,"],[4452,4535,"have William spend more time with you,"],[4535,4628,"and you'll be fine."],[4688,4747,"Right."],[4756,4824,"William"],[4824,4960,"is the child's father,"],[4988,5147,"so he should contribute more."],[5267,5339,"Your belly"],[5347,5479,"is getting too big to hide."],[5515,5564,"As for the wedding,"],[5584,5711,"let's keep it simple."],[5756,5832,"I"],[5864,5960,"Megan,"],[6003,6088,"do you have"],[6088,6215,"pre-wedding jitters?"],[6256,6315,"Tell you what,"],[6324,6448,"I'll call William"],[6476,6607,"and ask him to come over."],[6612,6656,"Hey,"],[6659,6731,"Mom,"],[6740,6795,"wait."],[7115,7179,"Hello?"],[7215,7304,"William,"],[7356,7448,"Megan isn't feeling"],[7448,7531,"very well today."],[7548,7684,"Come over to the house right away"],[7695,7835,"and comfort her."],[7904,7992,"While you're at it,"],[8015,8107,"bring the fine tobacco and wine"],[8107,8228,"that your uncle likes,"],[8256,8331,"as well as the jewelry"],[8340,8459,"that Megan and I like."],[8671,8712,"Hello?"],[8856,8931,"William,"],[8940,8995,"why are you silent?"],[8995,9092,"What is the meaning of this?"],[9092,9168,"Megan is still carrying"],[9168,9271,"your child."]],"57":[[36,152,"My child?"],[167,243,"It seems she hasn't"],[243,360,"told you anything at all."],[436,516,"Mrs. Grant,"],[544,616,"I suggest you"],[616,696,"ask your"],[696,791,"precious daughter"],[796,943,"what exactly happened."],[948,988,"Hello?"],[1148,1235,"That William"],[1240,1367,"has some nerve."],[1496,1619,"What exactly happened?"],[1639,1728,"I"],[1751,1816,"Come on,"],[1816,1987,"say something!"],[2071,2180,"William"],[2319,2500,"he broke off our engagement."],[2551,2635,"What?"],[2664,2803,"You're pregnant with his child,"],[2835,2980,"and he wants to break it off?"],[2983,3080,"Who does he think you are?"],[3087,3235,"Who does he think the Chandler family is?"],[3243,3307,"Megan,"],[3315,3456,"why did he break off the engagement?"],[3515,3620,"I don't know."],[3667,3796,"It's normal for"],[3796,3928,"young couples to fight."],[4003,4188,"Just clear up the misunderstanding."],[4207,4320,"You have a child together."],[4320,4428,"Calling off the engagement"],[4428,4535,"is just nonsense."],[4535,4796,"He is very determined."],[4839,4960,"Did he give a reason"],[4975,5107,"for breaking it off?"],[5139,5279,"Everything was fine before."],[5315,5439,"But recently, the Collins family"],[5488,5660,"found their long-lost daughter."],[5764,5896,"It seeems she's been saying"],[5900,6043,"a lot of bad things about me over there."],[6160,6264,"Elizabeth."],[6360,6564,"They say sisters-in-law are difficult."],[6587,6635,"She's just trying"],[6656,6807,"to show you who's boss."],[6879,6959,"However,"],[6959,7064,"your in-laws have been"],[7071,7240,"hoping for a grandson for years."],[7248,7343,"They absolutely won't let her"],[7343,7468,"do whatever she wants."],[7504,7643,"Mark my words today,"],[7664,7748,"this wedding"],[7748,7848,"can't be cancelled."],[7907,7992,"Just set your mind at ease"],[7992,8128,"and get ready to be a bride."]],"58":[[68,148,"That's right."],[184,264,"You two have been together"],[264,356,"for so long,"],[364,491,"and you already have a child."],[516,700,"Calling off the engagement now"],[811,900,"we would become a laughingstock"],[900,1043,"if word got out."],[1203,1327,"I'm going to find Edward right now."],[1348,1427,"Dad,"],[1427,1532,"forget it."],[1572,1823,"I don't even want to get married anymore."],[1823,1896,"Nonsense!"],[1903,2032,"You can't be willful about this."],[2067,2235,"I'm going to the Collins house right now."],[2251,2348,"I want to see who matters more:"],[2351,2492,"a daughter who will eventually marry out,"],[2492,2580,"or the baby"],[2580,2751,"that you're carrying."],[2796,2875,"I'll go with you."],[2875,2973,"- Let's go. - Okay."],[3611,3807,"Lizzie, have a grape."],[3856,4007,"Oh my gosh, this is decadent."],[4028,4135,"So decadent."],[4192,4356,"Why am I getting used to it?"],[4356,4435,"Being hand-fed like this."],[4507,4711,"All the things Lizzie missed out on before,"],[4771,4935,"I'll make up for every single one."],[4935,5024,"Lizzie,"],[5071,5228,"how have your studies been lately?"],[5256,5339,"Are they difficult?"],[5371,5496,"Studies?"],[5496,5656,"That's my strong suit."],[5656,5743,"But Elizabeth"],[5743,5915,"is always at the bottom of the class."],[5915,5996,"Dad,"],[5996,6164,"Lizzie seems to be struggling"],[6164,6271,"with her studies lately."],[6288,6392,"But that's okay."],[6407,6495,"If there's anything she doesn't understand,"],[6495,6584,"she can ask me."],[6595,6715,"I can patiently teach her everything."],[6731,6864,"I need you to teach me?"],[6864,6968,"I just don't study."],[6968,7084,"If I actually tried,"],[7084,7235,"I could get first place in no time."],[7284,7384,"Just as I thought."],[7392,7592,"Elizabeth is still so shallow."],[7631,7695,"The Collins family"],[7695,7820,"could never like"],[7820,7907,"someone like her."]],"59":[[8,84,"Exactly."],[84,156,"My Lizzie"],[156,279,"just doesn't feel like studying."],[300,400,"If she really put her mind to it,"],[400,512,"she'd be as good as anyone."],[516,616,"Ha ha ha."],[636,720,"This is completely different"],[720,840,"from the humility Edward"],[840,996,"used to teach me."],[1008,1164,"I think"],[1216,1367,"with Lizzie's talent,"],[1380,1480,"academics alone"],[1480,1575,"won't be enough to satisfy her."],[1644,1755,"Why not give her Starlight Pictures,"],[1755,1812,"a subsidiary of"],[1851,1971,"the Collins Group?"],[2071,2164,"That way, when she graduates,"],[2164,2276,"if she wants to be an actress,"],[2296,2392,"she can film whatever"],[2416,2507,"she likes."],[2512,2696,"Hahaha."],[2696,2783,"That sounds wonderful."],[2803,2896,"Is he"],[2896,3007,"actually serious?"],[3023,3151,"Starlight Pictures"],[3151,3335,"is worth billions."],[3364,3507,"And he's just giving it to her?"],[3596,3760,"I'm a daughter of the Collins family too."],[3764,3867,"Why don't I get"],[3867,3960,"that kind of treatment?"],[4032,4100,"William,"],[4100,4232,"you shouldn't say such absurd things,"],[4232,4356,"even as a joke."],[4452,4543,"Well, well."],[4543,4796,"The Chandlers walk into the Collins house"],[4796,4964,"like they own the place."],[4964,5147,"No wonder security didn't stop them."],[5164,5303,"It's because my brother has been catering to"],[5303,5452,"Megan for so many years."],[5456,5632,"I really don't think his efforts back then"],[5632,5760,"were worth it."],[5779,5856,"Hey,"],[5856,5975,"what are you staring at?"],[5992,6071,"Go bring out"],[6071,6192,"your best tea."],[6203,6320,"It's getting late,"],[6320,6428,"so let's skip the tea."],[6459,6600,"We were just about to go to bed."],[6631,6715,"You two,"],[6740,6859,"just say whatever you came to say."],[6892,7020,"I heard from William that"],[7048,7251,"you're giving Starlight Pictures to Elizabeth."],[7312,7471,"I'm afraid that's hardly appropriate."],[7543,7643,"How can you hand such a massive asset"],[7643,7804,"over to a woman?"],[7915,7984,"I know"],[7984,8123,"you just found this daughter"],[8123,8243,"and feel you owe her,"],[8307,8404,"but making it up to her"],[8404,8564,"should have its limits."]],"60":[[1,73,"What the h*ll?"],[74,167,"Is this guy sick?"],[180,331,"Ever since he walked in,"],[336,491,"he hasn't stopped yapping,"],[491,651,"and every word is a dig at me."],[791,1011,"Uncle Chandler, is it?"],[1088,1211,"At least you remember your last name is Chen."],[1211,1278,"You're an outsider,"],[1278,1419,"it's none of our business."],[1432,1591,"My dad and brother's assets"],[1591,1746,"are theirs to give to whoever they please."],[1746,1887,"If they give it to me, I'll take it."],[1887,2012,"Why are you spouting such bullsh*t?"],[2028,2176,"How can you be so rude?"],[2200,2292,"Being rude"],[2292,2451,"is better than being shameless like you."],[2507,2632,"Don't you agree?"],[2651,2728,"In-laws,"],[2760,2876,"is this the 'good daughter'"],[2876,2951,"you brought back?"],[3007,3096,"She's vulgar"],[3160,3267,"and unreasonable!"],[3328,3443,"No wonder our Megan"],[3443,3500,"was so angry"],[3500,3596,"when she came back."],[3715,3811,"Elizabeth must"],[3811,3971,"apologize to us today."],[4028,4143,"Otherwise,"],[4143,4315,"there will be no wedding,"],[4315,4460,"and you can forget about"],[4488,4600,"the child in her belly!"],[4600,4696,"It seems Megan"],[4696,4820,"didn't tell them anything."],[4875,4996,"They think just because of the baby,"],[4996,5160,"they can manipulate the Collins family."],[5200,5279,"And they expect Lizzie"],[5279,5375,"to apologize to them?"],[5392,5471,"Dream on."],[5507,5607,"You want me to apologize?"],[5628,5707,"You two shameless"],[5707,5779,"old fools."],[5792,5903,"You're full of sh*t,"],[5903,6007,"yet you talk so big."],[6007,6103,"Your daughter"],[6111,6206,"probably learned it from you,"],[6208,6256,"didn't she?"],[6271,6384,"That's how she became so"],[6384,6443,"shameless."],[6459,6595,"You still dare to mention the child?"],[6595,6715,"If you want it,"],[6728,6892,"go ahead and raise it yourselves."],[6892,6959,"Don't try to pin it"],[6959,7043,"on the Collins family."],[7071,7151,"Mr. Collins,"],[7159,7235,"this daughter of yours is really"],[7235,7328,"something else."],[7359,7528,"What do you have to say about this?"],[7535,7656,"Give us a solution."]],"61":[[44,172,"What solution do you expect from me?"],[243,300,"My daughter"],[300,428,"has already made it very clear."],[467,591,"The Collins family cannot accept"],[591,744,"a daughter from the Chandler family."],[779,883,"The wedding"],[883,972,"is off."],[1008,1100,"As for that child,"],[1100,1280,"do whatever you want with it."],[1308,1532,"It has nothing to do with the Collins family."],[1559,1639,"You"],[1728,1912,"William, what do you say?"],[1923,2028,"I've already"],[2028,2092,"I already made it very clear"],[2092,2216,"on the phone."],[2255,2435,"If there's anything you still don't understand,"],[2496,2680,"go ask your precious daughter."],[2719,2803,"Listen to me."],[2844,2992,"From now on, if anyone visits,"],[3000,3132,"report to us first."],[3203,3296,"Only after we agree,"],[3296,3400,"can you let them in."],[3443,3547,"If this happens again,"],[3547,3667,"don't bother working for the Collins anymore."],[3867,3920,"Fine."],[3984,4052,"Great."],[4088,4152,"Just great."],[4175,4296,"The Collins family"],[4296,4443,"is really something else."],[4488,4647,"If this is how they want it,"],[4696,4932,"this won't end peacefully."],[5167,5243,"Alright."],[5260,5400,"You people are good."],[5432,5624,"Seems I made this trip for nothing."],[5660,5879,"I hope you don't regret this."],[5967,6039,"Goodbye."],[6064,6139,"See yourself out."],[6160,6239,"Humph."],[6443,6664,"I was the one who revealed"],[6664,6868,"that Megan is pregnant."],[6907,7100,"When Frank finds out the truth,"],[7135,7240,"he's going to hate my guts."],[7295,7420,"Just my luck."],[7464,7623,"It's good that we spoke plainly."],[7659,7804,"Easier to cut ties with them."],[8135,8184,"Sweetie,"],[8204,8304,"you said so much just now."],[8304,8379,"You must be thirsty."],[8492,8640,"Next time you see these people,"],[8640,8731,"just ignore them."],[8735,8907,"Let your big brother handle it."],[8940,9135,"We don't want our precious girl getting tired."],[9159,9256,"It wasn't that tiring."]],"62":[[20,80,"Hey,"],[108,167,"Lizzie."],[204,279,"Listen to your mom."],[324,440,"Don't jump in to help your brother"],[440,524,"just because you feel bad for him."],[536,620,"He's a grown man;"],[624,687,"he can handle it himself."],[700,948,"I scolded them because I felt bad for him?"],[972,1088,"Since when?"],[1527,1771,"Originally, the book only had an ending for my brother,"],[1776,1932,"and the middle part was blank."],[1983,2180,"But now, a new plotline has appeared."],[2507,2703,"The Chandler family is so shameless."],[2703,2855,"They're actually waging a media war."],[2887,3007,"\"Top Rich Heir"],[3007,3192,"Abandons Pregnant Fiancée\""],[3203,3339,"What kind of trash headline is that?"],[3392,3479,"Brother,"],[3507,3688,"you gave Megan three days"],[3688,3839,"for old times' sake,"],[3843,3928,"but instead,"],[3947,4135,"she's dragging your name through the mud."],[4164,4415,"Nobody knows if that child is a Collins"],[4428,4620,"without a paternity test."],[4739,4852,"Megan probably assumes"],[4852,5000,"that since William has no proof,"],[5011,5179,"as long as she sticks to her story,"],[5188,5396,"she can brand him as a total scumbag."],[5439,5524,"That leaves William"],[5524,5660,"with only two choices:"],[5684,5775,"marry her,"],[5803,5903,"or fight back."],[5943,6111,"But if he fights back"],[6111,6332,"without producing concrete evidence,"],[6392,6576,"he'll have no choice"],[6576,6687,"but to accept the slander."],[6759,6879,"The Chandler family"],[6879,7071,"is even holding a press conference."],[7092,7231,"They're determined to make the Collins family"],[7231,7356,"take the fall."],[7368,7415,"Sigh."],[7428,7579,"The world inside this book"],[7579,7659,"is truly something else."],[7668,7784,"I haven't been here long,"],[7792,7868,"but I've already encountered"],[7868,8023,"so many shameless people,"],[8056,8220,"each more outrageous than the last."],[8231,8315,"Does Megan"],[8315,8512,"really think I don't have evidence?"],[8548,8687,"If she dares to twist the facts,"],[8692,8735,"then I won't hesitate"],[8735,8884,"to release the recording from that day!"],[8900,9059,"So what if the whole world finds out"],[9068,9207,"that I was cheated on?"],[9215,9379,"Fine. I can live with that."]],"63":[[40,96,"Sigh."],[104,163,"William,"],[184,352,"you need to watch out for the Chandler family"],[372,508,"acting out of desperation and doing bad things."],[532,640,"You must be prepared."],[683,779,"As expected of"],[796,975,"the former head of the Collins family,"],[1000,1164,"Dad is still very sharp."],[1188,1272,"Don't worry,"],[1327,1419,"I'm prepared."],[1427,1707,"My brother only turned dark once in the book."],[1732,1903,"Has he turned dark ahead of schedule?"],[1935,2028,"Am I really"],[2028,2212,"just a character in a book?"],[2228,2403,"Lizzie definitely knows something."],[2467,2583,"I can't ask her directly,"],[2623,2816,"but I should talk to her more often"],[2839,2916,"and see if I can"],[2916,3032,"get more information out of her."],[3176,3360,"Lizzie, it's getting late."],[3364,3439,"You and Ivy"],[3439,3539,"should go get some rest."],[3543,3700,"You have school tomorrow."],[3703,3720,"Oh."],[3728,3752,"Okay."],[3752,3788,"Go ahead."],[3888,4075,"The Collins family has matters to discuss."],[4124,4307,"I don't need to listen anyway."],[4347,4507,"I can see it all in the book."],[5303,5571,"The upcoming plot is basically this:"],[5571,5664,"Eldest Brother reveals"],[5664,5835,"that he has audio evidence."],[5903,6056,"Then Second Brother, the movie star,"],[6079,6203,"and Third Brother, the esports god,"],[6211,6440,"who can't leave due to training,"],[6468,6707,"call to ask about the wedding date"],[6731,6895,"so they can make time to return early."],[7348,7431,"\"Add me as a friend.\""],[7459,7551,"\"I'll tell you in detail.\""],[7620,7764,"\"Email is inconvenient.\""],[7804,7864,"\"Okay.\""],[9035,9148,"It's strange, actually."],[9151,9295,"In these books,"],[9295,9484,"Adrian doesn't exist at all."],[9551,9668,"Why is that?"]],"64":[[1011,1124,"How did he find out?"],[1143,1235,"I know the answer, too,"],[1267,1475,"but the System won't let me say."],[1732,1835,"It was Maxwell."],[1860,2007,"Adrian wasn't supposed to find out"],[2007,2205,"until a month after Maxwell and Megan"],[2211,2267,"got together."],[2271,2435,"But now, he knows ahead of schedule."],[2483,2583,"Could it be that"],[2632,2735,"he has a System, too?"],[2939,3051,"Last time at Blue Lake,"],[3055,3180,"I found out Megan was cheating,"],[3180,3303,"so I had someone look into it."],[3324,3511,"That hotel happens to be mine."],[3575,3684,"So it was Eldest Brother"],[3684,3796,"who caused the butterfly effect,"],[3800,3935,"allowing Adrian"],[3935,4084,"to track the guy down early."],[4115,4292,"After Megan and he reunited,"],[4307,4434,"didn't they blame Eldest Brother?"],[4434,4527,"for keeping them apart for seven years?"],[4539,4656,"Well, nothing's keeping them apart now."],[4688,4947,"What's this good show you want me to watch?"],[5056,5156,"I'll find a time"],[5156,5279,"to let Maxwell discover that Megan"],[5279,5352,"is the one he's been looking for."],[5400,5456,"As for the specific time,"],[5456,5547,"I'll coordinate with your eldest brother."],[5647,5832,"It'll be the cheaters' grand reunion scene."],[5928,6156,"But I have classes."],[6175,6303,"Will I make it?"],[6343,6464,"Uncle Gu,"],[6464,6604,"you promised me a good show,"],[6604,6679,"so you have to keep your word."],[6695,6884,"My brothers might not take me,"],[6920,7007,"so I'm counting on you."],[7248,7287,"Deal."],[7420,7500,"Oh,"],[7631,7776,"looks like there's a good show on."]],"65":[[84,191,"Top Heir"],[200,348,"Abandons Pregnant Fiancée"],[383,583,"Fiancée In Tears All Day,"],[616,775,"Diagnosed With Depression."],[835,875,"Tsk."],[903,1016,"Look at these headlines."],[1056,1140,"Rich people"],[1140,1283,"really act like they're above the law."],[1327,1456,"My heart aches for Megan."],[1467,1559,"Megan, you must first"],[1559,1655,"protect the baby."],[1703,1835,"That man is such scum."],[1860,1928,"Abort the baby"],[1928,2028,"and start a new life."],[2123,2203,"I'm done with this."],[2244,2348,"My brothers"],[2348,2496,"must have a plan."],[2544,2692,"I can accept not getting married,"],[2712,2803,"but I need"],[2803,2939,"William to tell me personally"],[2971,3148,"why on earth he's treating me this way."],[3180,3264,"The day after tomorrow,"],[3264,3360,"the Chandler family"],[3360,3511,"will hold a press conference"],[3532,3679,"to properly address this matter."],[3711,3839,"Make sure you all attend."],[3856,3935,"We'll certainly be there."],[3960,4071,"Because of this incident,"],[4084,4247,"the Collins stock has dropped significantly,"],[4247,4467,"so William is sure to come."],[4467,4560,"When he does,"],[4560,4752,"I'll make him apologize to Megan"],[4767,5000,"and marry her with a grand wedding."],[5152,5228,"I will attend"],[5228,5335,"this press conference."],[5360,5447,"Since William is coming"],[5447,5556,"to this press conference,"],[5579,5728,"he must be trying to win me back."],[5743,5843,"When that happens,"],[5864,6039,"as long as he sincerely admits his mistake,"],[6079,6228,"I'm willing to forgive him."],[6812,6892,"Hello?"],[6935,7112,"I'm going to the press conference."],[7128,7220,"And when I see you,"],[7220,7364,"I'll have a surprise for you."],[7387,7595,"Okay, I'll be waiting for your surprise."],[7668,7895,"I didn't expect William to be so thoughtful."],[7923,8087,"He's not just coming to apologize,"],[8107,8271,"he even prepared a surprise for me."]],"66":[[20,100,"Megan."],[391,540,"Mom, Dad,"],[587,744,"William gave in to me."],[763,859,"Really?"],[1375,1456,"Understood."],[1591,1667,"Get out!"],[1707,1844,"You can't even handle a simple task."],[1848,1955,"What use are you to me?"],[2928,3160,"Ms. Andrews, are you okay?"],[3247,3328,"I'm fine."],[3347,3488,"Tell everyone to get back to work"],[3488,3571,"and to be extra careful."],[3571,3715,"Make sure there are no more mistakes."],[3811,3924,"Why is Mr. Quinn"],[3924,4060,"so angry this time?"],[4071,4171,"Same old story."],[4224,4335,"He still hasn't found"],[4388,4520,"the person he's looking for."],[5771,5871,"Mr. Quinn,"],[5896,6015,"we found the person you're looking for."],[6071,6175,"What?"],[6448,6512,"You know the consequences"],[6512,6643,"of lying to me."],[6643,6723,"It's the truth."],[7028,7128,"It is Megan,"],[7159,7292,"William's fiancée."],[7312,7456,"She's already my woman."],[7479,7623,"Why would she marry someone else?"],[7640,7759,"Based on the timing,"],[7768,7895,"she must be carrying"],[7904,8004,"my child."],[8120,8240,"I'm aware of the situation now."],[8292,8335,"Remember,"],[8368,8492,"you know nothing."],[8504,8576,"Pretend you never"],[8576,8700,"saw this video."],[8743,8795,"Understood."]],"67":[[4,128,"All right. You may go."],[532,691,"Megan can't marry anyone else."],[704,796,"She belongs to me."],[872,956,"I'm going to the press conference"],[956,1048,"in person"],[1064,1191,"to meet with Megan."],[1256,1340,"That William"],[1340,1409,"How dare he try to claim the title"],[1409,1596,"of Megan's fiancé."],[1628,1723,"I'll make sure he pays"],[1723,1864,"a heavy price for this."],[3132,3292,"My parents think I'm just a kid,"],[3292,3388,"so they won't let me get involved."],[3424,3543,"Thankfully,"],[3592,3792,"Adrian kept his word and brought me here."],[4152,4315,"This male lead"],[4343,4539,"is a bit more normal than Wyatt."],[4628,4815,"At least he doesn't hit people."],[4952,5128,"But the NPCs around him"],[5211,5371,"seem to have it even worse."],[5435,5520,"Later on,"],[5520,5660,"when the female lead gets jealous of Claire,"],[5703,5879,"the male lead tries to comfort her"],[5935,6028,"by publicly humiliating"],[6028,6152,"Claire."],[6167,6296,"Because of this, Claire"],[6311,6504,"holds a grudge against the male lead."],[6512,6668,"She secretly teams up with Adrian,"],[6668,6812,"hoping to bring down the Quinn Group."],[6923,7007,"It's a pity, though."],[7007,7164,"Claire and Adrian's moves"],[7171,7251,"are discovered by the leads'"],[7251,7420,"genius son."],[7420,7520,"And so, Claire"],[7520,7668,"meets a tragic end."],[7735,7871,"Does Maxwell know the"],[7879,8076,"identity of the Chandler family yet?"],[8228,8304,"That's right."],[8548,8679,"I've already leaked the news"],[8771,8920,"to Maxwell."],[9051,9131,"Oh."],[9204,9364,"As everyone knows,"],[9395,9623,"the female lead belongs only to the male lead."],[9635,9823,"If a male supporting lead even holds her hand,"],[9823,9959,"he gets punished by the male lead."],[9992,10059,"This male lead"],[10071,10200,"definitely won't tolerate"],[10200,10307,"the female lead marrying someone else."],[10307,10500,"So he's going to crash the wedding."]],"68":[[600,704,"The plot of the book"],[704,819,"is unfolding right now."],[864,951,"It looks like"],[967,1108,"I just have to wait patiently."],[1864,1948,"Originally,"],[1948,2171,"it was just between my daughter and her fiancé."],[2171,2328,"There was a small misunderstanding."],[2348,2483,"But my son-in-law said"],[2507,2703,"he wanted everyone here to witness this,"],[2771,2864,"so"],[2864,2967,"we organized this"],[2967,3096,"press conference."],[4375,4492,"It's him."],[4539,4707,"The man from that night."],[5060,5247,"I can't believe he's here."],[5292,5379,"I thought I would never"],[5379,5532,"see him again in my life."],[5588,5707,"I never expected him"],[5707,5832,"to show up at a place like this."],[5960,6067,"Does he"],[6067,6235,"recognize me too?"],[6379,6471,"But"],[6523,6628,"I'm about to become"],[6628,6751,"another man's wife."],[6840,6995,"What happened that night"],[6995,7159,"must simply be treated like a dream."],[7259,7312,"As for"],[7312,7443,"the child in my belly,"],[7484,7651,"it will be up to William and me"],[7687,7851,"to raise him well together."],[7979,8148,"And as for my love,"],[8192,8379,"it must remain buried here."],[8459,8568,"Today,"],[8571,8695,"I really need to"],[8695,8843,"add some fuel to their fire."],[8987,9068,"Megan,"],[9112,9204,"tonight,"],[9248,9384,"I've prepared a big gift for you."],[9428,9528,"I hope you like it."],[9543,9664,"What gift?"],[9720,9904,"Just listen and you'll know."]],"69":[[1032,1132,"Megan,"],[1159,1319,"are you saying this child"],[1319,1435,"doesn't belong to my brother?"],[1467,1551,"Ivy,"],[1551,1680,"William treats me so well"],[1692,1803,"and yet I deceived him like this."],[1823,1903,"Tell me,"],[1912,2060,"am I a terrible woman?"],[2060,2167,"Megan,"],[2167,2339,"what's done is done."],[2348,2551,"The baby needs a father, after all."],[2555,2683,"If you marry my brother,"],[2683,2839,"it will give this child a legitimate status,"],[2839,3016,"and ensure a happy, healthy upbringing."],[3114,3211,"Holy sh*t."],[3211,3375,"I thought they were here to apologize?"],[3375,3532,"But they dropped a huge bombshell right away!"],[3556,3652,"Oh my God."],[3671,3803,"What kind of twisted logic is that?"],[3860,3947,"She cheated, got pregnant"],[3947,4084,"with another man's child,"],[4084,4247,"and wants her fiancé to play the sucker dad?"],[4309,4368,"Damn."],[4370,4456,"The sucker dad."],[5047,5124,"Megan,"],[5192,5288,"once I give a gift,"],[5288,5443,"I never take it back."],[5752,5956,"How could he do this to me?"],[6003,6071,"It seems William"],[6071,6196,"knew about this long ago."],[6207,6284,"The reason he"],[6284,6492,"didn't reveal the truth right away"],[6528,6648,"was to publicize the scandal himself"],[6687,6804,"and completely destroy Megan."],[6851,6971,"If Megan had even a shred"],[6971,7076,"of shame,"],[7076,7148,"she should have just"],[7148,7240,"ended things amicably back then."],[7271,7340,"Ultimately,"],[7340,7476,"the Chandler family was just too bullying."],[7504,7604,"They're greedy and want everything."],[7768,7871,"This recording"],[7871,7979,"is clearly a fake!"]],"70":[[56,196,"Hey, Mr. Chandler!"],[212,316,"Mr. Chandler!"],[368,551,"Whether this recording is fake or not,"],[575,648,"we can hire a"],[648,767,"professional forensic agency."],[767,908,"One test is all it takes to know."],[943,1024,"But for now,"],[1059,1200,"let's let everyone hear the rest."],[2151,2332,"No wonder the Collins family"],[2332,2471,"had that attitude before."],[2471,2687,"Turns out they knew all along"],[2687,2892,"she was carrying some other man's bastard."],[2916,3064,"What is there to hesitate about?"],[3092,3180,"Megan,"],[3180,3311,"just forget about that man"],[3315,3403,"and live a good life"],[3403,3535,"with my brother from now on."],[3535,3656,"As long as you don't say anything,"],[3656,3756,"he will never know"],[3756,3839,"about this."],[3871,4015,"But what if I can't forget him?"],[4015,4120,"Ivy,"],[4120,4307,"even though we only met once,"],[4307,4464,"I've already fallen in love with him."],[4511,4643,"What love at first sight?"],[4643,4739,"Clearly that guy"],[4739,4884,"is just good in bed,"],[4884,5024,"and she can't bear to leave him."],[5528,5679,"That voice"],[5679,5779,"it's definitely that show-off,"],[5779,5892,"the male lead."],[5984,6064,"As expected,"],[6092,6192,"my concern these past few months"],[6192,6284,"was not in vain."],[6300,6407,"This woman actually"],[6407,6512,"has a place for me in her heart."],[6520,6579,"Oh my God,"],[6579,6759,"he heard my true feelings."],[6776,6864,"I'm so embarrassed I could die."],[6884,7043,"Sure enough, in this book world,"],[7068,7207,"only the male and female leads"],[7207,7312,"count as real people."],[7331,7507,"To them, the other supporting characters"],[7540,7679,"are just clowns"],[7679,7795,"to be toyed with at will."],[7892,7979,"Uncle Gu,"],[7992,8100,"why are you looking at me?"],[8179,8259,"It's nothing."],[8356,8520,"I don't care about this \"book world.\""],[8551,8640,"All I know is that"],[8643,8843,"we are flesh and blood, with real feelings."],[8856,8915,"Hmph."],[8915,9023,"I intend to see,"],[9035,9087,"in this life,"],[9087,9231,"if the supporting roles don't step aside,"],[9256,9351,"whether the leads can still reach"],[9351,9492,"the happy ending from their past life."]],"71":[[260,391,"Do you like"],[391,491,"this gift?"],[671,751,"William,"],[787,896,"I don't know where you"],[896,1024,"got this recording,"],[1056,1183,"but it's all fake."],[1216,1296,"I never said"],[1296,1372,"any of that."],[1508,1632,"The Chandler family still relies"],[1632,1739,"on William's help."],[1771,1967,"I'll deny this recording to my grave."],[2032,2183,"She's already mine,"],[2207,2371,"yet she still wants to marry William."],[2423,2628,"No way. I absolutely won't allow it."],[2664,2816,"Then let the media friends"],[2816,3003,"here today bear witness."],[3071,3171,"We'll send this recording"],[3171,3284,"to a professional agency"],[3284,3379,"for analysis."],[3400,3464,"Let's see if what you claim"],[3464,3564,"is actually true."],[3700,3779,"William,"],[3879,4024,"we've been together for so many years."],[4088,4188,"Do you really have to"],[4188,4339,"be so heartless?"],[4535,4624,"After all these years,"],[4743,4875,"so surely,"],[4875,5020,"you still love me."],[5843,5988,"It seems the Chandler family"],[5988,6152,"is in serious trouble this time."],[6228,6352,"Things have gone this far,"],[6412,6640,"and Megan still dares to claim"],[6671,6812,"that she loves William?"],[7084,7207,"The upcoming plot"],[7207,7328,"is still generating."],[7348,7476,"I wonder if William"],[7476,7595,"has been swayed."],[7928,8040,"Just to be safe,"],[8064,8220,"I need to give William a reality check."],[8384,8529,"Megan says tearfully,"],[8531,8681,"\"We've been together for so many years,"],[8681,8809,"and you've been so good to me."],[8809,8943,"You've done so much for me."],[8943,9061,"Of course I love you.\""],[10105,10268,"\"We've been together for so many years,"],[10340,10423,"and you've been so good to me."],[10431,10564,"You've done so much for me."],[10620,10771,"Of course I love your money.\""]],"72":[[20,100,"William,"],[148,260,"let me explain!"],[408,548,"Megan,"],[548,704,"from now on,"],[748,864,"you stick to your path,"],[891,988,"and I'll stick to mine."],[1040,1164,"We are finished."],[1219,1448,"My... my daughter"],[1448,1519,"just made a mistake"],[1519,1651,"that all women make."],[1651,1732,"At worst,"],[1732,1851,"she can get an abortion,"],[1851,1928,"and you two can still"],[1928,2087,"have a good life together."],[2096,2228,"She cheated on him"],[2228,2312,"so shamelessly,"],[2312,2476,"and still expects him to play happy family?"],[2476,2583,"Like mother, like daughter."],[2612,2692,"No."],[2739,2867,"This is my baby."],[2892,3071,"I won't let you hurt him."],[3176,3288,"Getting an abortion?"],[3303,3439,"That would be great,"],[3507,3603,"but I wonder if"],[3603,3771,"Mr. Quinn can hold himself back."],[3892,4024,"Go get 'em, Male Lead!"],[4028,4188,"Admit you're the other man!"],[4192,4296,"I'm rooting for you!"],[5711,5932,"That dress costs a fortune."],[6011,6200,"Oh, it's quite expensive."],[6260,6328,"Yeah."],[6388,6512,"But even expensive clothes"],[6528,6648,"can be used to hold sunflower seeds."],[6648,6759,"I've lived a second life,"],[6759,6823,"yet I'm still not as open-minded"],[6823,6915,"as this little girl."],[6915,7015,"Watching the drama"],[7015,7176,"really goes best with sunflower seeds."],[7228,7315,"Exactly."],[7340,7551,"Though this time, I have competition."],[7776,7859,"Plot Hint:"],[7885,8075,"Maxwell descends like a god,"],[8075,8235,"walks up to Megan,"],[8235,8357,"and shields her behind him."],[8468,8595,"Descends like a god?"],[8615,8723,"Come on,"],[8764,8887,"let me see"],[8887,9092,"what 'descending like a god' looks like."]],"73":[[231,375,"Come to the hospital with me."],[400,487,"Let's go."],[551,632,"No!"],[687,819,"This is my child."],[916,1024,"None of you have the right"],[1024,1119,"to decide his fate."],[1300,1380,"William,"],[1480,1583,"I beg you,"],[1635,1771,"let me keep this child."],[1823,1971,"As long as you agree to keep him,"],[2003,2171,"I'll do anything you want."],[2271,2387,"If the Chandler family could"],[2387,2460,"get rid of this child,"],[2460,2551,"that would be for the best."],[2600,2712,"But if they can't,"],[2748,2855,"I will find another way"],[2855,3012,"to ensure he is never born."],[3039,3171,"William,"],[3275,3400,"I never thought you could be"],[3400,3567,"so cold and heartless."],[3667,3800,"Do you think once the baby is gone,"],[3800,3924,"I'll get back together with you?"],[4035,4135,"Let me tell you,"],[4192,4307,"if I lose this child,"],[4367,4511,"I will only hate you more!"],[4524,4639,"Even at a time like this,"],[4639,4720,"she still assumes"],[4720,4815,"that I'll humbly beg for her love"],[4815,4960,"just like I used to."],[5024,5124,"How dare these people try"],[5124,5239,"to kill my child."],[5264,5403,"The Chandler family, the Collins family"],[5403,5535,"they all deserve to die!"],[5592,5660,"Stop!"],[5688,5924,"Did he come to save me?"],[5935,6160,"Oh boy, fam,"],[6160,6315,"here comes the main plot."],[6360,6512,"That little girl"],[6520,6679,"really seems to enjoy the gossip."],[6679,6764,"Mr. Quinn?"],[6800,6915,"Could this child"],[6951,7140,"actually belong to Maxwell?"],[7335,7479,"All of you, stop right now!"]],"74":[[227,348,"Hahaha!"],[1876,1960,"As long as I'm here,"],[2016,2164,"no one dares to bully Megan."],[2196,2280,"I knew it."],[2280,2471,"Now this is a real man,"],[2512,2635,"unlike William."],[2676,2839,"He can't even accept a child."],[2935,3016,"Mr. Quinn,"],[3096,3215,"what gives you the right"],[3215,3388,"to speak to me like that?"],[3488,3560,"What?"],[3656,3815,"Is there something going on"],[3864,3992,"between you and my fiancée?"],[4367,4447,"Mr. Collins,"],[4535,4696,"the child Megan is carrying is mine."],[4735,4875,"We are in love,"],[4928,5075,"and we are a perfect match."],[5132,5211,"As for you,"],[5239,5307,"that was only because Megan"],[5307,5415,"was blind before."],[5464,5588,"From now on, you and she"],[5588,5747,"have nothing to do with each other."],[5747,5864,"Damn,"],[5864,5943,"he's acting so self-righteous"],[5943,6067,"for someone who's just the other man."],[6096,6228,"The drama tonight"],[6228,6420,"just keeps on coming."],[6459,6543,"Remember this."],[6543,6676,"I am Maxwell."],[6715,6779,"From now on,"],[6804,6948,"I'm your man."],[7023,7092,"Okay."],[7163,7292,"Big Brother must be"],[7292,7484,"feeling pretty awful right now."],[7528,7587,"Sigh."],[7620,7848,"Loving the wrong person sure is miserable."],[7859,7935,"In this life,"],[7935,8064,"it's safer to"],[8064,8176,"just stay single."]],"75":[[52,163,"Little girl."],[204,287,"You're actually worrying about"],[287,364,"the future already?"],[424,504,"But,"],[532,655,"people like Maxwell and Megan"],[655,759,"are really"],[759,851,"despicable rats."],[1032,1116,"Do I need to remind"],[1116,1211,"you two?"],[1251,1367,"Megan is technically still"],[1367,1508,"my fiancée."],[1527,1623,"She was before,"],[1635,1744,"but not anymore."],[1764,1864,"Megan has been with me"],[1864,1980,"for ten years."],[2060,2164,"In the first year,"],[2164,2271,"I gave her a luxury car"],[2271,2480,"worth millions."],[2544,2607,"Since then,"],[2607,2712,"on every birthday,"],[2751,2883,"the gold and jewelry I gave her"],[2883,3044,"were worth millions more."],[3060,3224,"I will pay you back for all of it."],[3464,3560,"That's great."],[3643,3792,"I won't count anything else."],[3792,3911,"Just for the gifts,"],[4028,4264,"I've spent over a hundred million on her"],[4264,4452,"and the Chandler family."],[4507,4652,"I'll pay it all back."],[4652,4756,"Won't that do?"],[4764,4903,"Talk is cheap."],[5000,5120,"How about this, Mr. Quinn?"],[5147,5252,"You write me an IOU."],[5271,5392,"As long as I get that note,"],[5392,5471,"from then on,"],[5496,5596,"Megan"],[5628,5739,"will be your fiancée."],[5739,5828,"I absolutely won't fight you for her."],[5992,6107,"If you don't write it,"],[6107,6239,"I'll have to list out exactly"],[6239,6388,"what I've paid for over the years."],[6443,6559,"If everyone finds out"],[6559,6684,"that the future Mrs. Quinn"],[6684,6784,"shamelessly took so many things"],[6784,6964,"from another man,"],[6964,7092,"you won't be able to save face,"],[7092,7223,"will you, Mr. Quinn?"],[9792,9923,"Starting today,"],[9948,10048,"Megan"],[10076,10220,"and I are square."],[10451,10548,"I'd like everyone here"],[10548,10679,"to bear witness for us."],[10731,10851,"Effective immediately,"],[10851,10956,"the engagement between the Collins and Chandlers"],[10956,11071,"is officially terminated."],[11184,11384,"William and Megan"],[11412,11571,"are free to marry whomever they choose"],[11607,11704,"and have no further ties."],[11768,11971,"This man is just too petty."],[12059,12235,"He's not worth my love at all."],[12300,12412,"Only Maxwell"],[12412,12584,"is the one I'll spend my life with."],[12640,12748,"In that case,"],[12771,12924,"may I take Megan and leave?"],[12940,13028,"Be my guest."],[13640,13731,"The Quinn family"],[13731,13947,"is just as good as the Collins family."],[13968,14208,"It seems even though Megan is reckless,"],[14231,14363,"she's still useful."],[14431,14519,"The trouble with our eldest"],[14519,14631,"is finally behind us."],[14631,14712,"Let's go."],[14740,14819,"Let's go."],[15152,15231,"Hey,"],[15284,15363,"Lizzie."],[16015,16143,"Dad, Mom."],[16275,16430,"Let's go home."],[16430,16500,"Okay."]]}