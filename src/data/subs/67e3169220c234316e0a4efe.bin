{"1":[[462,604,"Ok, Ellie Jones,"],[604,863,"it’s your first high school party and..."],[863,1017,"you might be the preacher's daughter"],[1017,1092,"but just"],[1092,1163,"be cool."],[1234,1347,"Be cool."],[1347,1409,"I can't believe"],[1409,1664,"I spilled my drink on the Asher King."],[1664,1881,"Oh, he's going to get Red Snakes"],[1881,2006,"to come after you."],[2052,2177,"With that face and body of his..."],[2243,2394,"I don't mind him coming after me."],[2556,2677,"What are you looking at, dork?"],[3148,3236,"That's what you get,"],[3236,3378,"for showing up to a party,"],[3378,3470,"dressed like that!"],[3490,3566,"Good luck going home"],[3566,3670,"to your preacher father,"],[3670,3820,"smelling like vodka!"],[4091,4404,"Oh, such bitches!"],[4404,4517,"Are you okay?"],[4537,4692,"I'm fine, really."],[4804,4888,"Okay, Sasha,"],[4888,5063,"I've been thinking about it,"],[5113,5355,"and I think I'm ready."],[5413,5655,"OMG, it's Ellie Jones,"],[5655,5818,"the perfect preacher's daughter,"],[5818,5955,"finally ready to swipe her V-card"],[5955,6122,"before we go off to college in the fall?"],[6122,6243,"No, no, no, no."],[6243,6356,"No, Sasha."],[6398,6748,"I think I'm ready to have my first drink."],[6831,7032,"I, I mean, I already smell like vodka,"],[7032,7102,"and..."],[7190,7269,"yeah, just..."],[7340,7394,"why not?"],[7453,7578,"Well, I'll take it!"],[8070,8262,"Come on, it's not about how it tastes,"],[8262,8454,"it's about how it makes you feel!"],[8454,8571,"Live a little!"],[8571,8662,"She's right,"],[8662,8867,"I've been too good my entire life."],[8896,9013,"Just once,"],[9050,9188,"I want to feel free."],[10222,10301,"Where's the bathroom?"],[11423,11536,"Oh my gosh,"],[11640,11757,"it's, it’s him."],[11961,12187,"It's the Asher King."]],"2":[[100,191,"Enjoying the show?"],[287,425,"You're the one half-naked."],[437,629,"Some girl spilled her drink on me."],[629,771,"I'm waiting on my clothes to dry."],[1597,1705,"I see they got you, too."],[1847,1901,"Never thought"],[1901,2068,"I'd see Ellie Jones at a party."],[2131,2252,"Do you know who I am?"],[2277,2464,"Obviously, preacher's daughter."],[2677,2727,"And you,"],[2727,2840,"do you know who I am?"],[2923,3028,"Asher King."],[3040,3190,"And? What else do you know?"],[3269,3482,"That you're in a gang,"],[3611,3745,"the Red Snakes."],[3745,3841,"Good, and?"],[3862,3924,"And..."],[4058,4124,"you're..."],[4225,4500,"the bad boy at school."],[4600,4700,"And you're..."],[5005,5121,"the good girl."],[5551,5676,"Guess I've met my match."],[6794,6915,"The cops are here!"],[7169,7248,"No, no, no,"],[7248,7361,"I, I, I can't be here."],[7374,7453,"Come with me."],[8470,8600,"Can you be a good girl for me?"]],"3":[[25,145,"Can you be a good girl for me?"],[487,642,"The, the cops are here, and they..."],[671,717,"so, I mean,"],[717,838,"my, my uncle's a sheriff and-"],[850,971,"Don't worry, I've been to juvie."],[971,1059,"I can give you all the tips"],[1059,1151,"and all the tricks."],[1309,1443,"You're enjoying this, aren't you?"],[1459,1551,"Enjoying what?"],[1710,1818,"You touching me,"],[1918,2043,"or watching you squirm?"],[2281,2360,"Hey guys,"],[2360,2540,"I think I found something."],[2585,2660,"Oh my gosh."],[2686,2748,"Oh my god."],[2794,2877,"I can't breathe."],[2877,2973,"You need to be quiet."],[3069,3140,"But they're..."],[3153,3257,"I really need to get out of here"],[3257,3336,"I'm gonna go to jail."],[3336,3457,"I'm gonna get in trouble."],[3495,3570,"I just..."],[4366,4496,"Looks like they all ran."],[4496,4675,"Let’s get out of here."],[4900,4950,"I've never been"],[4950,5088,"kissed like that before."],[5301,5467,"I've actually never been kissed at all."],[5547,5714,"Kissing her felt so different."],[5755,5926,"Almost like it was my first kiss too."],[5989,6076,"Well, in that case,"],[6076,6160,"let me try again."],[7111,7261,"Are you sure about this, good girl?"],[7394,7540,"There's no going back after this."]],"4":[[45,179,"There's no going back after this."],[2706,2777,"I never knew"],[2777,2982,"good-girl, preacher's daughter, Ellie Jones"],[2982,3107,"could be so dangerous."],[3128,3253,"And I never knew"],[3253,3570,"the tough and rough Asher King"],[3570,3636,"could be..."],[3682,3799,"so gentle."],[4070,4279,"Maybe you just bring out the best in me."],[4813,4925,"Crap, it's my dad."],[4925,5071,"I'm up so late for curfew."],[5071,5138,"Let me take you home."],[5138,5221,"No, no."],[5221,5447,"Asher, if my dad sees me"],[5447,5572,"with a Red Snake,"],[5626,5734,"he'll kill us both."],[5930,6214,"But thank you for a special first time,"],[6222,6285,"Asher."],[6406,6531,"It's a night I'll never forget."],[6677,6744,"Me neither."],[7665,7803,"Ellie Jones."],[7862,8012,"I've never felt this way before."],[8045,8153,"Dammit, what am I thinking?"],[8153,8287,"Our worlds are miles apart."],[8287,8412,"We'll never make it work."],[8500,8721,"But for her, I can at least try."],[8883,8975,"I want to try."]],"5":[[29,125,"I've never thought"],[125,375,"I'd lose my virginity to Asher King,"],[412,625,"the bad boy at school."],[646,784,"And I've definitely never thought"],[784,980,"that six weeks following that night"],[980,1163,"would be the best time of my life."],[1176,1359,"He's sweet."],[1359,1468,"He's charming."],[1509,1685,"He makes me feel alive."],[1697,1722,"But,"],[1818,1989,"one thing I should have known is..."],[2039,2306,"all good things come to an end."],[2452,2552,"Morning, Dad."],[2640,2740,"Ellie Jones,"],[2752,2869,"what's wrong with that skirt?"],[3140,3349,"It's just a uniform, Dad."],[3449,3591,"It's not that short."],[3695,3832,"You look like a slut."],[3878,4162,"Timothy, Capter 2, Verses 9-10,"],[4170,4325,"women shall adorn themselves"],[4325,4466,"in respectable apparel,"],[4466,4650,"with modesty and self-control."],[4708,4813,"Go change,"],[4867,5059,"before you embarrass yourself,"],[5142,5213,"and me."],[6068,6260,"Hey, hey, what's wrong?"],[6310,6468,"Asher, what are you doing here"],[6468,6523,"during the day?"],[6523,6602,"If my dad sees you-"],[6602,6698,"Where do you think you're going?"],[6719,6886,"Don't touch her, you filthy snake."],[7027,7123,"What are you doing?"],[7123,7353,"Fraternizing with a gang member?"],[7478,7549,"Let her go."],[7607,7741,"Keep your claws off me."]],"6":[[29,196,"Wrath is one of the Seven Deadly Sins,"],[196,266,"Pastor."],[266,379,"If you hurt her again,"],[471,558,"you'll see mine."],[905,1001,"Now, if you'll excuse us,"],[1001,1092,"we're late for school."],[1922,2031,"How much will it cost"],[2031,2122,"to keep your demonic"],[2122,2185,"little brother"],[2185,2285,"away from my daughter?"],[2352,2460,"Asher bagged"],[2460,2573,"the preacher's daughter, huh?"],[2590,2711,"I will not let your brother"],[2711,2915,"ruin my reputation in the church."],[2973,3040,"It'll cost you"],[3040,3148,"a pretty penny, Pastor."],[3182,3290,"Whatever it takes."],[3319,3424,"Very well, Pastor."],[3449,3553,"I'll keep Asher away"],[3553,3853,"from your precious little girl."],[3987,4170,"Whatever it takes."]],"7":[[513,583,"I'm gonna park."],[617,713,"See you in class?"],[967,1071,"Excuse me!"],[1180,1284,"Oh my goodness."],[1338,1593,"You just came out of Asher King's car?"],[1605,1780,"No girl has ever been in there."],[1864,2043,"Are you two dating?"],[2043,2198,"Shh, Sasha."],[2281,2485,"You know, my dad is a pastor."],[2485,2794,"If he finds out about me and Asher,"],[2794,2957,"he'll kill both of us."],[2990,3153,"Did you just come to school with Asher,"],[3153,3278,"you little prude?"],[3465,3557,"I know."],[3566,3649,"The good girl thinks"],[3649,3816,"she has a chance with the bad boy."],[3912,4012,"You're pathetic."],[4024,4149,"And you think,"],[4170,4337,"you have a chance with him?"],[4404,4454,"I mean,"],[4454,4708,"you slept with every guy at school."],[4742,4829,"What did you say to me?"],[4829,4900,"You little-"],[4900,5013,"Come on, Claudia."],[5013,5121,"Leave her alone."],[5288,5376,"Don't touch me,"],[5376,5522,"you disgusting little worm."],[5522,5618,"Claudia, stop!"],[5668,5801,"No wonder your mom left you,"],[5893,6001,"I would have too."],[6965,7090,"Nice one, Claudia."],[7165,7278,"Stay away from her."]],"8":[[12,125,"Stay away from her."],[233,287,"Ellie."],[458,517,"Ellie."],[1042,1105,"What happened to her?"],[1105,1251,"Asher, we were just-"],[1251,1372,"Attacking a defenseless student,"],[1372,1447,"yeah, I could see that."],[1447,1539,"It's not what it looks like."],[1539,1651,"The little bitch pushed me first."],[1651,1751,"You're the bitch, Claudia."],[1810,1876,"That's why no one in the school"],[1876,1943,"would actually date you"],[1943,2010,"unless they were looking for"],[2010,2097,"something quick and cheap."],[2581,2698,"Now if you mess with her again,"],[2836,2898,"I'm going to make sure"],[2898,2982,"you never show your face"],[2982,3073,"in this school again."],[4800,4929,"Asher never cares about anyone"],[4929,5059,"or anything in this school."],[5117,5301,"Why did he stand up for that little bitch?"],[6202,6293,"What are you doing here, Jax?"],[6489,6527,"I'm here"],[6527,6639,"because everybody in the gang"],[6639,6694,"is talking about"],[6694,6769,"how my little brother"],[6769,6902,"got into a fight for a girl."],[6931,7044,"And not just any girl."],[7044,7232,"The fucking pastor's daughter."],[7357,7432,"And she's connected"],[7432,7545,"to the police department."],[7603,7724,"What were you thinking?"],[7786,7845,"It's nothing."],[7853,7916,"Better be."],[7924,8033,"You know the Red Snake rules,"],[8033,8095,"little bro."],[8191,8400,"No relationships outside the gang."],[8475,8608,"If you break those rules,"],[8758,8854,"your little girlfriend's going to be"],[8854,8938,"the one to pay."],[9250,9376,"Doesn't look like nothing to me."],[9709,9751,"Don't worry,"],[9751,9838,"I'll cut ties with her."],[9914,9997,"I'll never look at her again."],[9997,10093,"Just don't hurt her."],[10097,10147,"Deal."],[10189,10326,"The Snakes are our only family now,"],[10326,10377,"Asher."],[10523,10710,"Don't fuck it up."],[11732,11840,"If you break those rules,"],[11903,11991,"your little girlfriend's going to be"],[11991,12066,"the one to pay."],[12395,12495,"Meet me in the nurse's office,"],[12495,12533,"Claudia."],[12533,12579,"I need you."]],"9":[[600,675,"Where am I?"],[934,1071,"Asher, did you save me?"],[1430,1655,"I'm so sorry for what I have to do, Ellie,"],[1655,1801,"but I need to keep you safe."],[1830,1956,"You got me in trouble with your dad"],[1956,2102,"and with some stupid mean girl."],[2289,2381,"You're too complicated."],[2381,2477,"I don't do drama."],[2548,2702,"But you took my virginity."],[2727,2786,"Asher, you..."],[2861,2990,"you said I was the only girl..."],[3098,3165,"the only girl"],[3165,3274,"you would change for."],[3449,3528,"Wait."],[3574,3695,"Did I hear that right?"],[3737,3895,"You threw yourself at Asher,"],[3895,4024,"you little skank!"],[4070,4250,"Asher, the past six weeks, we-"],[4250,4346,"It was nothing."],[4592,4658,"We're done."],[5050,5188,"How could you do this to me?"],[5251,5392,"I'm doing it for you, Ellie."],[5843,5997,"What does that even mean?"],[6010,6214,"It means if we stayed together,"],[6252,6435,"my gang would make your life hell."],[6493,6602,"It means I don't want you."],[6602,6656,"I never did."],[6656,6731,"I want Claudia."],[8170,8283,"As soon as I leave this room,"],[8283,8383,"we're strangers."],[8454,8621,"Get over it and get over me, Ellie."]],"10":[[154,204,"Okay..."],[304,429,"okay, you've served your purpose."],[429,500,"You can leave now."],[567,625,"Whatever."],[713,855,"I know you'll need me soon enough again."],[1897,2093,"I'm doing this to protect you, Ellie."],[2122,2210,"I can't let you get hurt"],[2210,2285,"because of me."],[3682,3849,"Stop thinking about Asher."],[3962,4108,"You knew a bad boy like him"],[4108,4241,"would never truly change."],[4358,4454,"Just forget about him!"],[5084,5284,"Wait, when was my last period?"],[5576,5643,"Wait, no, no, no,"],[5643,5726,"this can't be right."],[5764,5834,"My period was supposed"],[5834,5951,"to start two weeks ago."],[6197,6272,"No."],[6322,6514,"No, I, I can't be pregnant."],[6631,6706,"You're late for school,"],[6706,6790,"Ellie Jones."],[6852,6952,"What is that?"]],"11":[[25,120,"What is that?"],[867,1013,"This is from that Red Snake,"],[1013,1109,"Asher King?"],[1197,1347,"Please, calm down."],[1347,1447,"It's nothing."],[1484,1568,"Do you know what this will do"],[1568,1718,"to my reputation at the church?"],[1772,1851,"Your mother would be"],[1851,1956,"so ashamed of you."],[1956,2027,"Stop, Dad."],[2027,2177,"Stop, you're hurting me."],[2264,2339,"We broke up,"],[2339,2494,"so you don't have to worry about me"],[2494,2606,"being with him anymore."],[2615,2740,"Then why do you still have it?"],[2769,3007,"I raised a slut and a liar."],[3094,3157,"That's it."],[3178,3232,"You're going to"],[3232,3349,"Catholic Boarding School."],[3436,3557,"If you won't stop seeing"],[3557,3687,"that Red Snake devil,"],[3762,3816,"I'll make sure"],[3816,3941,"he doesn't see you again."],[4008,4137,"No, no, no, Dad."],[4245,4429,"Please, please don't send me away."],[4550,4662,"I'm calling the school."],[4717,4825,"Start packing."],[5684,5885,"Asher is the father of my child."],[5989,6081,"He saved me once,"],[6081,6218,"and he's the only one"],[6218,6318,"who can help me now."],[6423,6523,"I need to find him."],[8174,8320,"What is that loser doing here?"],[8454,8504,"Ellie?"],[8579,8666,"Might as well show her"],[8666,8817,"who Asher really belongs to."],[9509,9676,"Oh, I should not have come."],[9772,10001,"He clearly doesn't care about you, Ellie."],[10130,10289,"He won't care about this baby."]],"12":[[462,563,"What the hell?"],[759,850,"Ellie, you shouldn't be here."],[850,925,"What are you thinking?"],[975,1155,"I just came to talk to you, but,"],[1284,1430,"clearly you don't care."],[1664,1726,"You're right."],[1789,1906,"What was I thinking?"],[1906,2056,"It must have taken everything she's got"],[2056,2135,"to come down here."],[2293,2410,"If you want to talk, let's talk."],[2410,2481,"Just not here."],[2848,2994,"Asher, you just won’t give up on Ellie,"],[2994,3090,"will you?"],[3215,3282,"Seriously?"],[3307,3449,"Asher, you're that embarrassed"],[3449,3566,"to be seen with me?"],[3695,3812,"Here's a lesson for you, Ellie."],[3812,3899,"I'm in a gang."],[3958,4008,"Okay?"],[4087,4233,"And Red Snakes cannot be seen"],[4233,4329,"with non members,"],[4329,4450,"I'm trying to protect you."],[4450,4533,"From who?"],[4533,4612,"From all of them,"],[4612,4775,"especially the leader, Donovan Black."],[4775,4825,"He's the one that"],[4825,4946,"convinced my big brother Jax"],[4946,5030,"to join when we were young,"],[5030,5130,"and then I got roped in."],[5171,5488,"So if we like, got together-"],[5488,5572,"Then they would think that"],[5572,5684,"you were distracting me"],[5684,5930,"from my tasks and my responsibilities."],[6181,6272,"And I don't even want to think about"],[6272,6339,"what they would do to you,"],[6339,6393,"so I need you to"],[6393,6514,"leave me alone forever."],[6835,6919,"I can't."],[6990,7048,"Why not?"],[7215,7298,"Because..."],[7394,7444,"I'm..."]],"13":[[0,54,"Why not?"],[95,187,"Because..."],[450,517,"I'm..."],[1226,1363,"Why do you leave, baby?"],[1914,2039,"He's still with Claudia."],[2147,2298,"I can't believe I almost told him"],[2298,2444,"I'm pregnant with his baby."],[2565,2656,"Face it, Ellie."],[2748,2923,"The Asher you knew is gone."],[2936,3036,"And you're alone."],[3257,3332,"What is wrong with you?"],[3332,3453,"I told you to leave me alone."],[3532,3616,"Ellie, wait!"],[3695,3899,"Asher's still hung up on that little bitch!"],[3966,4095,"Oh, she's gonna pay."],[5246,5355,"You snuck out."],[5709,5814,"I know what to do with you."],[5955,6056,"Dad!"],[6114,6202,"Get in the car!"],[6202,6322,"Dad, what are you doing?"],[6523,6589,"I'm sending you"],[6589,6752,"to catholic boarding school right now!"],[6752,6806,"No!"],[6948,7102,"You'll never see that gangster,"],[7102,7223,"Asher King, again."]],"14":[[8,79,"I'm sending you"],[79,250,"to catholic boarding school right now!"],[283,337,"No!"],[667,809,"You'll never see that gangster,"],[809,905,"Asher King, again!"],[984,1076,"Don't make me hurt you for real"],[1076,1172,"this time, pastor."],[1184,1376,"Matthew 26:52!"],[1397,1534,"Put your sword back in its place,"],[1534,1618,"because if you draw the sword,"],[1618,1735,"you're gonna die by the sword."],[1780,1835,"Oh!"],[2047,2110,"Oh no!"],[2298,2423,"Asher, I'm not going with you!"],[2423,2565,"You don't really have a choice, Ellie."],[3048,3136,"You're coming with me,"],[3136,3257,"whether you want to or not."]],"15":[[658,784,"What's going on with you, Ellie?"],[1217,1338,"Look, I know your dad is no saint,"],[1338,1409,"but I know he wouldn't just"],[1409,1530,"kidnap you out of nowhere."],[1551,1659,"Stop pretending like"],[1659,1789,"you care about me, Asher."],[1889,2006,"You made it very clear"],[2006,2131,"I meant nothing to you."],[2193,2293,"As soon as I leave this room,"],[2293,2394,"we're strangers, Ellie."],[2435,2565,"Get over it and get over me."],[2773,2890,"I did that to protect you."],[3136,3257,"That's what my dad said too."],[3349,3490,"What is he protecting you from?"],[3511,3566,"You!"],[3641,3712,"He's trying..."],[3791,3899,"to keep me away from you,"],[3908,3933,"but..."],[4033,4120,"I can't let him."],[4175,4225,"Because..."],[4650,4771,"because I'm pregnant..."],[4967,5038,"with your baby."],[5201,5267,"Asher."]],"16":[[0,120,"I'm pregnant, Asher,"],[120,300,"and my dad knows"],[300,454,"he can't keep me away from you."],[533,667,"And when the school tells him,"],[667,834,"he's never gonna let me come back."],[938,1113,"So I'm never gonna see you again?"],[1322,1405,"Or our baby..."],[1768,1822,"No."],[1864,2027,"No, I'm not gonna let that happen."],[2206,2302,"You're moving in with me."],[2389,2489,"Move in with you?"],[2540,2619,"Yeah, I live alone."],[2665,2719,"My brother lives with"],[2719,2819,"our gang leader, Donovan."],[2882,2973,"I'm gonna keep you safe."],[3044,3186,"From the Red Snakes and your father."],[3357,3474,"Asher, I don't..."],[3474,3553,"I don't know."],[3666,3816,"I mean, what about Claudia?"],[3828,3978,"Claudia never meant anything to me."],[4016,4133,"I just used her"],[4241,4316,"to keep you away from me"],[4316,4387,"for your own good."],[4771,4879,"Do you trust me, Ellie?"],[5455,5543,"Then you're staying here."],[5638,5809,"He’s just doing this for the baby."],[5885,6089,"I still need to stay away from him."]],"17":[[0,133,"I meant nothing to him?"],[150,246,"And now Asher King"],[246,333,"moved that desperate little"],[333,362,"skank"],[362,458,"to his house."],[458,567,"I knew I did the right thing,"],[567,646,"following them here."],[750,867,"Red Snakes' number one rule"],[867,1051,"is no relationship outside the gang."],[1051,1163,"Wait until his brother, Jax"],[1163,1267,"hears about this."],[1830,1885,"Um..."],[1951,2206,"Asher, I can't stay here."],[2206,2248,"I don't..."],[2248,2456,"I don't have any pajamas."],[3194,3265,"Pajamas?"],[3507,3682,"And I can clean your school uniform."],[3703,3820,"It's the last one you have, right?"],[4350,4575,"A little privacy, please."],[4788,4946,"Turn around, Asher."],[5146,5238,"What if I don't want to?"]],"18":[[4,104,"What if I don't want to?"],[412,671,"Thank you, but..."],[746,859,"I've got it from here."],[1376,1468,"Whatever you say, Ellie."],[1680,1739,"Gosh,"],[1822,1964,"I burn when he touches me."],[2152,2252,"Stop it, Ellie."],[2260,2456,"He's just being nice for the baby's sake."],[2456,2577,"He doesn't want you."],[2631,2790,"God, I really want her."],[2882,3023,"Okay, you can turn around now."],[3591,3716,"Now that she's in my shirt,"],[3716,3974,"all I want to do is tear it off."],[4533,4692,"Don't, Asher."],[4692,4771,"If anyone in the gang"],[4771,4859,"finds out about you two,"],[4859,4971,"she's going to be in danger."],[5271,5388,"Since you keep"],[5455,5588,"getting yourself into trouble,"],[5630,5755,"click this button once,"],[5843,5935,"and I'll come find you."],[6022,6210,"Whether it's your dad or the Red Snakes,"],[6210,6306,"I'm going to keep you safe."],[6460,6539,"You know that, right?"],[6690,6748,"Yes."],[6886,6948,"Asher, I know."]],"19":[[442,588,"Asher, don't."],[625,763,"I don't want to get hurt again."],[942,1001,"No, you're right."],[1059,1117,"I'm sorry."],[1326,1476,"You can sleep on the bed."],[1509,1605,"I'll go and take the couch."],[1793,1931,"I'm sorry I can't tell you"],[1931,2064,"how I truly feel, Ellie."],[2168,2218,"Really."],[2777,2869,"What is it that just can't wait"],[2869,2982,"till tomorrow, Claudia?"],[3111,3345,"Your little brother and Ellie Jones"],[3432,3528,"are living together."],[3557,3641,"Ellie Jones?"],[3678,3774,"The preacher's daughter?"],[4108,4204,"Give The Snakes my word."],[4258,4341,"Ellie Jones,"],[4341,4491,"every move is to be watched."],[4775,4900,"And not a word of this."],[4929,5063,"If you go to Donovan"],[5063,5209,"or anyone else in the gang,"],[5259,5326,"I'll make sure"],[5326,5484,"it's the last words you ever say."],[5530,5655,"I won't tell anyone, Jax."],[5689,5789,"You better not."],[5897,5985,"The Red Snakes aren't supposed"],[5985,6110,"to date outside the gang."],[6318,6464,"If Asher decides he's going to be"],[6485,6673,"more loyal to Ellie Jones"],[6673,6777,"than he is to us,"],[6856,6961,"we'll just have to get rid of her."],[7428,7595,"That little skank started it,"],[7657,7803,"but I'll be the one to finish it."]],"20":[[1288,1372,"What are you doing up?"],[1380,1472,"There was a gunshot."],[1484,1634,"That was a car backfiring."],[1751,2031,"Is he staying up to protect me?"],[2193,2352,"I'm just really scared."],[2419,2623,"Being in your bed all by myself."],[2686,2794,"You're safe. I'm here."],[2915,2986,"I don't know."],[2986,3119,"I'm just really freaked out."],[3607,3682,"Well..."],[3682,3795,"What do you gonna do about it?"],[3999,4145,"God, I can feel her warmth"],[4145,4283,"standing so close to her."],[4320,4441,"After everything,"],[4441,4662,"why do I still want him close to me?"],[4758,5013,"Maybe we can"],[5013,5150,"sleep in the bed together?"],[5467,5530,"I don't think"],[5530,5643,"that would be a good idea."],[5643,5730,"Why, I mean,"],[5880,6076,"the bed's big enough for the both of us."],[6118,6293,"Space isn't what I'm worried about."],[6635,6840,"I'm going to be out here protecting us."],[6923,7098,"What if I want you with me?"],[7323,7486,"Asher, please."],[7511,7703,"We can just sleep."],[7766,7882,"She's so innocent."],[7882,7966,"But she has"],[7966,8170,"no idea what she's doing to me."],[8279,8379,"The closer I am to her,"],[8379,8487,"the safer she is."],[8541,8591,"Right?"],[9000,9217,"I've never cuddled with a girl before."],[9338,9530,"This actually feels so nice."],[9622,9818,"It feels so good staying in his arms."],[9859,10018,"I don't ever want to leave."],[10439,10506,"Oh my gosh."],[10506,10610,"We're going to be late for school."],[10610,10685,"I have to get up."],[11198,11257,"Asher?"],[11257,11327,"You in there?"],[11336,11411,"Shit!"],[11453,11549,"It's my brother."],[11599,11753,"He can't find Ellie in here with me."],[12103,12149,"Hello?"],[12174,12249,"Little bro?"]],"21":[[12,66,"Hello?"],[154,212,"Little bro?"],[354,433,"Asher, what are you..."],[625,742,"Jax, is that you?"],[788,859,"Oh, oh no."],[913,1030,"Asher's brother is here?"],[1080,1192,"Red Snakes cannot be"],[1192,1284,"with non-members."],[1338,1543,"If we got together-"],[1543,1622,"I don't even want to think about"],[1622,1689,"what they would do to you,"],[1689,1805,"so I need you to leave me alone."],[1826,1997,"Yeah, I just wanted to stop by"],[1997,2147,"and see how you're doing."],[2327,2477,"Someone had fun last night."],[2477,2598,"Oh, yeah."],[2598,2756,"It was some girl from school."],[2756,2857,"She just left."],[2857,2969,"So there's no way"],[2969,3161,"this is Ellie Jones' uniform?"],[3203,3265,"No."],[3269,3461,"You know, I broke things off with her."],[3520,3674,"Then you wouldn't mind if I come in"],[3674,3945,"and do a little check, would you?"]],"22":[[880,1034,"So you really did break up with Ellie?"],[1059,1167,"I told you I don't care"],[1167,1288,"about Ellie Jones."],[1368,1443,"Now can I please"],[1443,1543,"have some peace and quiet"],[1543,1639,"while I'm trying to shower?"],[1689,1751,"All right, Asher,"],[1751,1830,"but remember..."],[1830,1985,"The Snakes are our family."],[1985,2118,"Don't lie to them or me."],[2869,2940,"Oh my God."],[3044,3161,"What were you thinking"],[3161,3278,"last night, Asher?"],[3294,3436,"You need to be colder to Ellie."],[3490,3616,"If anyone finds out you..."],[3749,3820,"like her..."],[3858,3941,"Jax is going to be"],[3941,4074,"the least of your concerns."],[4141,4204,"Finish your shower"],[4204,4304,"and go to school, Ellie."],[5100,5242,"I need to see you."],[5242,5417,"Be at The Snake Pit in ten."],[6076,6235,"I'll bring you to Mr. Black now."],[6898,7027,"Asher King!"]],"23":[[254,400,"I just can't believe"],[400,513,"you're living with Asher King"],[513,750,"and you're pregnant with his baby!"],[796,975,"You say that like it's a good thing."],[1026,1301,"Okay, if my dad finds out,"],[1330,1393,"I'm dead."],[1393,1597,"And if Asher's brother finds out,"],[1735,1814,"we're both dead."],[1814,1972,"You're just so different"],[1972,2122,"than the good girl I used to know."],[2248,2364,"So, do you think you guys"],[2364,2460,"will get back together?"],[2460,2523,"Or..."],[2623,2773,"Sometimes I hope we do,"],[2773,2857,"but like..."],[2911,3015,"Asher's in a gang."],[3065,3161,"You know, I don't know"],[3161,3616,"if he could really be my family..."],[3766,4066,"If he could be my home, you know?"],[4170,4316,"I'm sure he'll change for you"],[4316,4471,"and your baby, Ellie."],[4546,4783,"And I hate to break it to you, but..."],[4859,5025,"you don't really have anyone else."],[5046,5138,"Yeah, but like,"],[5155,5413,"me and Asher being together causes..."],[5530,5638,"so many problems."],[5651,5705,"And..."],[5784,5922,"it's like something"],[5922,6168,"doesn't want us to be apart."],[6210,6293,"Oh my gosh."],[6302,6435,"I think I know someone"],[6435,6519,"who wants you apart."],[6519,6602,"Look!"]],"24":[[329,404,"I gotta go."],[2289,2369,"Why are you hiding here"],[2369,2456,"like a little bug?"],[2540,2706,"Is Asher King bored of you already?"],[2744,2932,"It's none of your business, Claudia."],[2969,3207,"And didn't Asher reject you?"],[3303,3415,"Just face it, Claudia,"],[3415,3528,"nobody wants you."],[3620,3770,"You better take that back,"],[3770,3941,"you little wannabe Virgin Mary."],[3966,4020,"And..."],[4099,4212,"what if I don't?"],[4212,4320,"Then I'll tell everyone"],[4320,4454,"you and Asher are still together."],[4487,4612,"Who's gonna get to you first?"],[4625,4825,"Your priest daddy or Asher's gang?"]],"25":[[0,100,"Who's gonna get to you first?"],[116,308,"Your priest daddy or Asher's gang?"],[629,679,"What?"],[725,825,"No comeback this time,"],[825,900,"you little rat!"],[1071,1209,"Click this button once,"],[1284,1384,"and I'll come find you."],[1497,1584,"I don't need one."],[1639,1764,"Asher's gonna save me."],[1839,1897,"Really?"],[1985,2064,"Where is he?"],[2456,2573,"Asher King."],[2640,2715,"Mr. Black."],[3395,3541,"I called you here today,"],[3566,3653,"because you haven't been helping"],[3653,3762,"as much as you should."],[4124,4183,"Is there anything"],[4183,4320,"distracting you from your family,"],[4320,4429,"The Snakes, Asher?"],[4504,4604,"A girl, perhaps?"],[4679,4817,"Someone outside the family, maybe?"],[4863,4950,"If he knows about Ellie,"],[4950,5034,"he'll hurt her."],[5113,5159,"But that means"],[5159,5284,"he'll have to hurt me first."],[5313,5392,"Because you know,"],[5392,5509,"there's something you want to tell me."],[5622,5734,"Now's the time."],[5922,5993,"Yeah, there is something"],[5993,6101,"I want to tell you."]],"26":[[54,129,"I think I'm ready"],[129,229,"for more responsibilities"],[229,316,"with The Snakes."],[316,392,"You know, I have a hard line"],[392,475,"I'm never going to hurt a woman,"],[475,663,"but I want to prove to you that I'm loyal."],[800,938,"It's the only way to make him think"],[938,1109,"I'm more loyal to him than Ellie."],[1109,1347,"Keep your enemies close, Asher."],[1347,1522,"Something big going down tonight."],[1584,1714,"Report to me at six."],[1714,1826,"And if you mess this up,"],[1826,1918,"I'm going to have a hard time"],[1918,2035,"believing what you just told me."],[2277,2444,"Anything to keep him away from Ellie."],[2506,2615,"Anything for The Snakes."],[2811,2873,"Ellie?"],[3011,3119,"What's that noise?"],[3119,3290,"It's the panic button I told Ellie to hit"],[3290,3399,"if she's ever in trouble."],[3411,3591,"It's just an alarm I set,"],[3591,3732,"reminding me I have a test next hour."]],"27":[[179,342,"Where's your Red Snake bandana?"],[654,738,"Sorry, sir."],[738,863,"I must have left it in my locker."],[1322,1405,"You go now."],[1426,1551,"I'll see you tonight."],[1672,1843,"Don't let your family down, Asher."],[2081,2181,"Ellie's in danger."],[2181,2293,"I have to move fast!"],[3082,3182,"Look around!"],[3228,3345,"Where is Asher?"],[3345,3511,"Asher, where are you?"],[3536,3574,"Aw."],[3641,3720,"Looks like you got some of that"],[3720,3795,"in your hair."],[3841,3949,"Let me help with that."],[4621,4808,"No wonder Asher dumped you for me."],[4833,5042,"You can barely fill out a training bra!"],[5321,5397,"I wonder what the church"],[5397,5534,"is gonna think of these photos?"],[5534,5618,"The preacher's daughter"],[5618,5751,"is a real slut."],[5805,5930,"I hit the panic button!"],[5972,6072,"Where is Asher?"],[6110,6264,"He swore he would protect me"],[6264,6348,"and our baby."],[6731,6794,"Ellie!"],[6977,7040,"Ellie!"],[7720,7962,"I've never felt this kind of pain before."],[8408,8554,"How dare you hurt Ellie again!"]],"28":[[467,567,"You better pray she's okay,"],[567,671,"or I'm going to end you myself."],[1013,1084,"Ellie."],[1530,1601,"Where are we going?"],[1601,1680,"We're going home."],[2494,2556,"You were bleeding."],[2556,2635,"I'm calling a doctor."],[2698,2777,"It's fine."],[2923,3023,"This is..."],[3023,3132,"it doesn't hurt anymore."],[3161,3282,"You're still shivering."],[3482,3574,"I'm just cold."],[3803,3920,"I'm not scared anymore."],[3920,4016,"Thanks to you."],[4270,4346,"Now do you believe me"],[4346,4450,"that I was never with Claudia?"],[4450,4487,"I was just..."],[4550,4646,"pretending so"],[4646,4758,"you'd be safe."]],"29":[[0,321,"I was just pretending so you'd be safe."],[367,487,"You're too good for me, Ellie."],[671,742,"Here."],[1255,1397,"I'm sorry I didn't get there sooner."],[1505,1584,"If anything would have happened"],[1601,1701,"or our baby..."],[1968,2097,"I tried to be cold to you."],[2097,2210,"I tried to stay away from you"],[2210,2339,"so you'd be safe."],[2410,2660,"But trying to resist you"],[2660,2752,"is killing me."],[2927,2990,"There's no other girl"],[2990,3090,"that makes me feel this way."],[3628,3745,"I'll give you some privacy."],[3912,3999,"I'll be right outside."],[4888,4979,"What if I say"],[4979,5159,"I don't want privacy this time?"],[5388,5534,"What if I say I want you?"]],"30":[[2823,2877,"Don't,"],[2961,3032,"Asher."],[3169,3415,"You keep saying you don't want me"],[3415,3495,"but then you do things"],[3495,3661,"to make me think otherwise."],[3703,3816,"I do want you."],[3862,3908,"I just..."],[3941,4024,"know that I shouldn't."],[4295,4375,"I do want you."],[4375,4479,"Couldn't you tell in the shower?"],[4533,4592,"Yes."],[4763,4842,"But,"],[4892,4988,"for more than..."],[5138,5221,"sex."]],"31":[[0,100,"More than..."],[191,275,"sex."],[508,563,"I..."],[638,746,"I want to be with you."],[813,884,"Be there for our baby."],[942,1096,"I know you're afraid of your father,"],[1096,1201,"but he's not the only one"],[1201,1301,"we should be worried about."],[1405,1526,"My brother Jax knows about us,"],[1526,1605,"and if our gang leader,"],[1605,1710,"Donovan finds out,"],[1730,1885,"all the Snakes will come after us."],[1968,2052,"What are they gonna do?"],[2085,2202,"They'll beat me until I'm loyal"],[2218,2339,"and if I survive that,"],[2419,2560,"what they'll do will really kill me."],[2660,2736,"They'll hurt you."],[2802,2877,"They'll take our baby."],[2982,3040,"They'll make sure"],[3040,3261,"that I never leave them for you again."],[3465,3524,"So can you see"],[3524,3616,"I'm trying to protect you?"],[3641,3757,"I can take care of myself."],[3807,3874,"It didn't look that way"],[3874,3991,"when Claudia had you cowering"],[3991,4066,"in the locker room."],[4692,4800,"Oh no,"],[4800,4925,"it’s Donovan Black."],[5413,5497,"Come outside."],[5547,5672,"It's time to prove your loyalty,"],[5672,5734,"little King."],[5943,6031,"Where are you going?"],[6051,6135,"I can't tell you."],[6172,6260,"It's for your safety."],[6481,6577,"You're doing something"],[6577,6765,"for Donovan and The Red Snakes,"],[6773,6831,"aren't you?"]],"32":[[0,225,"Asher, I know The Red Snakes"],[225,412,"are like your family or something,"],[412,688,"but I don't want the father of my baby"],[688,784,"to be in a gang."],[800,1051,"We can't keep..."],[1172,1301,"living like this,"],[1409,1539,"lying like this."],[1539,1668,"It's not that simple, Ellie."],[1726,1785,"Asher,"],[1918,2081,"you don't have to be bad."],[2081,2147,"You can..."],[2264,2389,"you can be good for me..."],[3003,3057,"You don't know"],[3057,3178,"what you're talking about, Ellie."],[3449,3536,"This is for you."]],"33":[[346,575,"I need you to arrest Asher King, Joseph."],[621,846,"Ellie's obsessed with this demonic kid."],[846,984,"As pastor of this town,"],[984,1176,"how do you think it makes me look?"],[1284,1443,"As my brother, do something."],[1493,1605,"Well, you know I've tried"],[1605,1760,"to take him down before."],[1780,1847,"Without proof,"],[1847,2006,"there's nothing I can do, David."],[2072,2298,"If you need proof, I got it for you."],[2560,2781,"Track Ellie and you'll find Asher."],[2848,2936,"Keep an eye on him"],[3015,3157,"and catch him in the act."],[3257,3374,"I want this piece of trash"],[3374,3503,"to rot in jail."],[5096,5276,"Let's see what you're up to tonight,"],[5276,5372,"Asher King."]],"34":[[100,208,"All units, stand by."],[208,329,"I got the King brothers in sight."],[350,412,"On my command,"],[412,583,"move in and arrest those fuckers."],[613,721,"Jax, get the goods."],[804,1042,"Asher, be ready to drive us away."],[1080,1163,"And fast!"],[1163,1226,"We can't get caught"],[1226,1376,"because you drive like a little bitch."],[1739,1793,"Hey..."],[1910,1964,"Be safe."],[2060,2143,"You too, little bro."],[2519,2590,"Move in now."],[2590,2648,"There's a weapon."],[2648,2719,"Move in now."],[3157,3324,"You don't have to be bad."],[3324,3378,"You can..."],[3503,3649,"you can be good for me."],[3832,3970,"I'm doing this for Ellie and the baby."],[3970,4099,"I need to prove my loyalty"],[4099,4283,"and throw Donovan off my tracks."],[4283,4475,"I'm doing the right thing, right?"],[5021,5100,"Don't move!"],[5100,5167,"Don't move!"],[5188,5242,"I'm good!"],[5242,5284,"Go."],[5326,5372,"Go!"],[5442,5518,"Drop the weapon!"],[5547,5663,"Drop the weapon!"],[5663,5784,"That cop is gonna shoot him!"],[5851,5922,"This is my chance"],[5922,6022,"to prove that I'm a Snake,"],[6022,6160,"and it can keep Ellie safe!"]],"35":[[62,145,"He did well, Jax."],[162,279,"Risked his life for mine."],[342,479,"He's a loyal Snake for sure."],[550,700,"I'll have his cut delivered tomorrow."],[767,880,"My one question is..."],[1030,1109,"How did the police know"],[1109,1184,"to find us there?"],[1217,1330,"And so fast?"],[1388,1501,"Not just any girl."],[1539,1710,"The fucking pastor's daughter."],[1710,1797,"And she's connected"],[1797,1860,"to the police department?"],[1981,2060,"No idea."],[2060,2210,"Well, you better find out."],[3557,3636,"I'm so sorry."],[3737,3991,"Asher, I didn't mean anything I said."],[4054,4158,"I need you."],[4262,4383,"Please wake up."]],"36":[[775,846,"Ellie..."],[942,1063,"Asher, you were right."],[1163,1267,"I need you."],[1568,1659,"We need you."],[1935,2064,"I proved my loyalty tonight."],[2181,2318,"I knew that cop that shot Donovan"],[2318,2402,"had bad aim."],[2640,2740,"I'm just hoping"],[2740,2894,"this makes it easier for us."],[2940,3161,"Asher, your world, this world, it's..."],[3357,3457,"it's so scary."],[3574,3666,"And I don't want you getting"],[3716,3799,"hurt anymore."],[3799,3920,"I can't lose you."],[3920,4062,"That's what I have to do for us."],[4237,4275,"But I don't want to"],[4275,4421,"talk about that right now."],[4421,4500,"I want to talk about us."],[4537,4604,"We're an us?"],[4700,4779,"You want that?"],[4854,4954,"More than anything."],[5246,5426,"I just... hope we don’t get caught."],[5622,5755,"Can we keep it a secret, Ellie?"],[5776,5822,"Yeah."],[5976,6043,"Let's do it."],[6886,6961,"I'm sorry."],[6961,7036,"I'm all banged up."],[7036,7094,"It's okay,"],[7132,7186,"it's okay."],[7394,7440,"I just..."],[7440,7603,"I want to be gentle with you, Ellie."],[8470,8525,"Looks like you've been"],[8525,8675,"lying right to my face, little bro."]],"37":[[54,191,"I knew you were still seeing each other."],[237,308,"Do you know"],[321,442,"the reason we got caught tonight"],[442,571,"was your little girlfriend?"],[608,692,"What are you talking about?"],[734,838,"Ellie, what is he talking about?"],[838,863,"I, I,"],[863,917,"I don't know."],[971,1030,"I don’t,"],[1030,1151,"I don't know what you're talking about."],[1151,1376,"Oh, so you didn't tell Sheriff Jones"],[1376,1472,"where to find us tonight?"],[1555,1593,"No."],[1651,1818,"No, I would never do that."],[1818,1943,"Why, why would I do that?"],[2018,2164,"The, the cops are here and they..."],[2210,2252,"So, I mean,"],[2252,2356,"my uncle's the sheriff and..."],[2406,2469,"You did say"],[2523,2648,"your uncle is the sheriff."],[2669,2727,"He probably has"],[2727,2811,"the whole police department"],[2811,2907,"in his back pocket."],[2907,2957,"See?"],[2957,3078,"Your uncle is tracking you!"],[3115,3236,"No, there's..."],[3236,3307,"there's no way."],[3778,3933,"But my dad might be."],[4571,4646,"I'm sorry."],[4658,4838,"Since you started seeing this girl,"],[4838,4954,"everything's gone wrong."],[4988,5100,"You have to make a choice."],[5184,5251,"Family,"],[5347,5480,"or the girl who's ruined everything."],[5526,5655,"You have to decide."]],"38":[[250,300,"You don't know"],[300,404,"what you're asking me to do, Jax."],[404,538,"Ellie's my family now, too."],[759,875,"If you care for my brother,"],[884,1071,"you'll leave before Donovan finds out."],[1105,1188,"After tonight,"],[1251,1322,"because of you!"],[1388,1564,"Do you honestly really want"],[1564,1672,"more blood on your hands?"],[1726,1843,"Don't talk to her like that."],[1935,2022,"Dig your graves then,"],[2022,2068,"little bro."],[2302,2464,"I'm so sorry, Asher."],[2569,2627,"Don't be."],[2706,2798,"I meant what I said."],[2852,3123,"But my dad is tracking me."],[3123,3282,"And he probably sent my location"],[3282,3349,"to my uncle"],[3349,3474,"and then now you're hurt."],[3553,3645,"It's not your fault."],[3695,3799,"Is he still tracking you?"],[4416,4533,"We need to get out of here."],[4854,4925,"No, Stop!"],[4925,5005,"You're gonna hurt yourself!"],[5005,5142,"I don't care if I'm hurt."],[5184,5246,"We need to get out of here."],[5246,5326,"I need to keep you safe."],[5426,5530,"I need to keep both of you safe"],[5530,5588,"now that you're pregnant"],[5588,5651,"with my baby."],[5780,5868,"You're pregnant?"]],"39":[[8,162,"You got my daughter pregnant?"],[225,312,"You slut!"],[358,408,"You're supposed to wait"],[408,500,"until you got married!"],[679,746,"And you,"],[746,838,"devil child."],[921,1005,"Let me make sure"],[1005,1234,"you and your gang is arrested!"],[1309,1422,"Stay away from us."],[1530,1626,"Dad, stop!"],[1626,1735,"You're hurting him."],[1897,1981,"Listen here."],[1981,2189,"You are not keeping that baby."],[2231,2381,"You'll ruin my reputation"],[2381,2444,"in the church."],[2552,2702,"You thought boarding school"],[2702,2781,"was hard?"],[2882,3061,"I'm shipping you off to the convent."],[3140,3265,"You'll have the baby there."],[3299,3553,"It’ll be adopted by God fearing couple!"],[3553,3586,"No."],[3632,3687,"No, Dad."],[3687,3845,"You're not taking my baby."],[4029,4137,"And as for you,"],[4137,4320,"you think you gotta away with this."],[4416,4537,"You thought wrong."],[5105,5201,"If you thought you’re gonna"],[5201,5338,"take Ellie and my baby away from me,"],[5338,5409,"you're dead wrong."],[5472,5663,"Let me break it to you, son."],[5726,5910,"But I'm never wrong!"],[5980,6081,"Dad, stop!"],[6135,6272,"You're hurting him!"]],"40":[[12,116,"Dad, stop!"],[175,346,"You're hurting him!"],[346,433,"Come away with me, Ellie."],[433,554,"Don't listen to him, Ellie."],[617,796,"Don't make me dig this any deeper."],[859,913,"Fine!"],[934,996,"I'll go with you."],[996,1067,"Just stop."],[2081,2143,"And now I'm going to"],[2143,2293,"take my girl and our baby home."],[2444,2535,"And when the baby is born,"],[2535,2602,"I'm going to love it better"],[2602,2715,"than you ever could have done."],[2977,3119,"I'm a man of God."],[3178,3315,"Asher, you are the devil."],[3357,3482,"You'll pay for this, Ellie."],[3482,3616,"You'll both pay for this!"],[4604,4763,"You must be in a lot of pain."],[4775,4871,"It's not that bad."],[5605,5868,"Sorry, this is kind of a tough angle."],[6602,6690,"Is this better?"]],"41":[[25,133,"Is this better?"],[133,262,"Much better."],[300,492,"I like seeing you from this angle."],[1080,1163,"We shouldn't."],[1305,1530,"You're hurt and in pain, and I don't..."],[1597,1735,"wanna make it worse..."],[1735,1910,"Then help me feel better."],[2560,2748,"Oh God, did I hurt you?"],[2748,2915,"I... I'm sorry, we shouldn't."],[2915,3040,"It's not your fault."],[3144,3257,"Plus it's my fault."],[3257,3570,"I can't control myself around you."],[3933,4033,"That makes two of us."]],"42":[[675,746,"What are we gonna do"],[746,1038,"about my dad and your brother?"],[1593,1655,"I'm not gonna"],[1655,1751,"let them tear us apart."],[2102,2398,"I'm falling for you, good girl."],[2773,3123,"I'm falling for you too, bad boy."],[4012,4066,"Wait."],[4183,4241,"Ellie..."],[4700,4767,"I've been thinking"],[4929,5021,"we need to talk."]],"43":[[16,120,"We need to talk."],[971,1138,"I've been thinking"],[1518,1693,"I want to be a better father figure"],[1693,1793,"for our baby."],[2047,2147,"The gang was all I knew"],[2147,2260,"before you, but..."],[2502,2652,"you made me want to be better."],[3549,3624,"I wanna be better"],[3645,3883,"for you and for our family."],[4404,4575,"I can be good for you, Ellie."],[4583,4679,"I promise."],[4892,4988,"I believe you."],[5017,5363,"I... Thank you."]],"44":[[246,325,"If you don't want me"],[325,454,"to involve the police again,"],[496,621,"make sure Asher"],[621,846,"and Ellie never interact again."],[875,1076,"Especially now that Ellie is pregnant."],[1113,1263,"But I can't tell Jax that."],[1330,1463,"The fewer people that know,"],[1463,1559,"the better."],[1559,1789,"They go to the same fucking school."],[1789,1951,"What do you expect me to do about that?"],[1985,2060,"Sounds like a problem"],[2060,2189,"you're gonna have to take care of."],[2218,2302,"Doesn't it?"],[2335,2456,"If you want this money,"],[2456,2585,"you got one more chance"],[2585,2702,"to solve it yourself."],[2756,2877,"Or I'm calling the sheriff."],[2907,3011,"You might be paying me,"],[3011,3161,"but you don't own me, Pastor."],[3203,3294,"This isn't for your family,"],[3294,3370,"it's for mine."],[3390,3520,"Cash is just a bonus."],[3695,3887,"No one cages this snake."]],"45":[[216,350,"Make sure you sign it with an A."],[775,875,"You called?"],[975,1138,"I'm sure you've kept your mouth shut"],[1138,1209,"and stayed quiet"],[1209,1480,"about my brother's... transgressions?"],[1514,1680,"I wouldn't betray you, Jax."],[1755,1805,"I would'nt want to be"],[1805,1926,"on the wrong side of the Snakes,"],[1926,1968,"which is"],[2039,2193,"more than little Ellie Jones can say."],[2193,2273,"Is that so?"],[2331,2494,"Then prove your loyalty"],[2494,2660,"and put this in my brother's locker."],[2769,2882,"Anything for the Snakes."],[3028,3215,"Perfect, Asher will get pinned for this,"],[3215,3332,"and he'll be expelled."],[3361,3399,"I'll send him"],[3399,3486,"on a mission out of town"],[3486,3595,"and bring his little girlfriend"],[3595,3699,"back to her father."],[3737,3895,"They'll never see each other again."],[6398,6514,"Good luck protecting Ellie"],[6514,6614,"when you're banned and expelled"],[6614,6710,"from this school."],[6773,6877,"Don't worry, Asher,"],[6923,7048,"you can always cry on my shoulder."]],"46":[[896,1038,"God, does he remember"],[1038,1113,"the last time"],[1113,1217,"he told me to be quiet..."],[1338,1484,"this happened?"],[1901,2006,"Will you read this for me?"],[2481,2540,"Wow."],[2623,2882,"Asher, this is like one of the best essays"],[2882,2969,"I've ever read."],[3057,3190,"Didn't think I had it in me, huh?"],[3353,3436,"If I ace this,"],[3436,3620,"it'll bring my grade up to a B."],[3883,4020,"You're definitely going to."],[4346,4525,"I never knew the bad boy"],[4525,4796,"Asher King was so secretly a genius."],[4833,4921,"I guess I just needed"],[4921,5030,"someone to inspire me..."],[5192,5292,"to believe in me."],[5647,5880,"Asher King, report to the Principal's office."],[5914,6031,"Now."]],"47":[[425,583,"Asher King,"],[650,792,"you have always been a problem"],[792,888,"at this school."],[930,1096,"With the amount of trouble you cause,"],[1096,1230,"you should have been expelled"],[1230,1368,"a long time ago."],[1409,1530,"I haven't done anything."],[1622,1780,"Then explain this!"],[1956,2081,"That wasn't me."],[2248,2310,"I swear."],[2310,2489,"I'm really trying to make myself better."],[2669,2798,"Stay close to Ellie."],[2798,2927,"Provide for our family..."],[3003,3111,"I don't want to give up now,"],[3178,3269,"I can't."],[3328,3574,"Fine. If you swear it wasn't you,"],[3574,3691,"you have until the end of the day"],[3691,3866,"to find out who it really was."],[3912,4154,"Otherwise, you're expelled."],[4433,4558,"I wish we could just be like"],[4583,4833,"a normal couple that..."],[4863,5067,"comes to school together and..."],[5113,5292,"goes to the movies and..."],[5417,5551,"goes to the school dance."],[5638,5814,"Have some faith in Asher."],[5814,5947,"Don't give up on him."],[6001,6089,"I've never seen you"],[6089,6231,"look at a guy like this."],[6268,6373,"And to be honest,"],[6373,6502,"I've never seen Asher"],[6502,6673,"look at anyone like this either."],[6773,7002,"Yeah, but I mean..."],[7002,7132,"would he still look at me the same"],[7132,7344,"if I wasn't pregnant with his baby?"],[7394,7482,"Definitely."],[7482,7695,"You're special, Ellie."],[7774,7849,"You got this."],[8149,8270,"Pregnant?"]],"48":[[0,120,"Pregnant?"],[663,696,"Hey."],[775,838,"You okay?"],[921,946,"No."],[971,1113,"Someone vandalized the school"],[1113,1234,"and they're framing me."],[1267,1459,"I'll... I'll tell them it was me!"],[1505,1543,"No."],[1630,1764,"The culprit is gonna get expelled,"],[1764,1914,"I can't let you take the blame for this."],[1914,2052,"Why not? I mean..."],[2081,2339,"It was... probably my dad."],[2410,2506,"I, I'm gonna go tell them"],[2506,2598,"it was me."],[2627,2694,"No, wait!"],[3057,3232,"I don't think it was your dad."],[3345,3511,"In the photo, there was a rat."],[3524,3620,"That's a symbol"],[3620,3770,"the Snakes use as a warning."],[3832,3966,"They kill rats."],[4204,4279,"I need to get out of here,"],[4358,4462,"I need to find Jax."],[4466,4517,"Maybe he's gonna-"]],"49":[[75,183,"Asher..."],[233,396,"Ellie, I swear I didn't do it."],[713,834,"You don't believe me either?"],[959,1130,"I..."],[1180,1292,"There he is!"],[1447,1547,"Get him!"],[1659,1818,"Asher, I'm gonna need you"],[1818,1947,"to open your locker for me."],[2339,2423,"Excited for a front row seat"],[2423,2569,"to watch your boy toy get expelled?"],[2756,2915,"Asher, your locker."],[2915,2994,"Open it."],[3782,3824,"What?"],[3933,4112,"No, it can't be!"],[4137,4295,"Why the outburst, Claudia?"],[4350,4425,"You know, uh,"],[4425,4550,"maybe she has something"],[4550,4621,"to do with it."],[4654,4775,"As if!"],[4913,4996,"See?"],[5084,5209,"Nothing here but books."],[5476,5618,"Maybe your bag."],[5672,5847,"You want to strip search me too?"],[5847,5918,"Here, take my bag."],[5930,6035,"You're not gonna find anything."],[6560,6677,"What's this?"]],"50":[[83,258,"That's... that's not mine!"],[258,367,"I swear!"],[383,700,"Uh... then why is it in here?"],[759,1034,"You must have put it there!"],[1151,1267,"Asher King and Ellie Jones"],[1267,1338,"framed me!"],[1372,1426,"Claudia,"],[1426,1530,"enough"],[1530,1622,"of your lies!"],[1672,1735,"You have been caught"],[1735,1822,"red-handed,"],[1856,2002,"and you are expelled."],[2022,2173,"No!"],[2173,2218,"You ca..."],[2218,2364,"You can't expel me! - Come with me."],[2381,2481,"I'm innocent!"],[2481,2577,"We need to call your parents."],[2577,2648,"No!"],[3144,3232,"Come on."],[3232,3336,"There is something I need to do."],[3883,3966,"I can't believe"],[3966,4108,"you framed Claudia for me."],[4233,4391,"I hate getting you in trouble, but..."],[4625,4729,"but I love that you're only"],[4729,4800,"bad for me,"],[4850,4934,"good girl."],[5042,5130,"And I like that"],[5130,5467,"you're only good for me, bad boy."],[5559,5693,"Do you wanna show me"],[5693,5918,"how bad you can be for me?"]],"51":[[1956,2127,"What if someone sees us in here?"],[2235,2289,"Then we have to"],[2289,2389,"make the show worth it."]],"52":[[296,404,"You don't think anyone saw us"],[404,517,"coming in here, do you?"],[592,704,"I don't know."],[746,863,"Are you still embarrassed"],[863,959,"to be seen with me?"],[1042,1184,"I've never been embarrassed of you,"],[1184,1213,"Ellie."],[2523,2656,"And I can prove it to you."],[3174,3232,"Damn it!"],[3307,3495,"Asher King and Ellie Jones,"],[3566,3707,"this isn't over yet!"],[4512,4671,"There's something you should know."],[4742,4859,"They're not just living together."],[4950,5059,"Asher got Ellie Jones"],[5059,5134,"pregnant."]],"53":[[1605,1701,"Are you sure about this?"],[1922,1985,"No,"],[2060,2177,"something missing."],[2748,2869,"Now I'm sure."],[2965,3111,"And you sure"],[3111,3286,"you can't tell I'm pregnant?"],[3286,3432,"I mean, my baby bump is starting-"],[3432,3478,"Ellie,"],[3561,3620,"you look beautiful."],[3753,3812,"No one is gonna know"],[3812,3858,"you're pregnant."],[3858,3903,"And with me,"],[3903,4016,"no one is gonna mess with you."],[4149,4295,"What about our families?"],[4329,4371,"I don't want you"],[4371,4454,"to worry about that right now."],[4567,4662,"I just want you to have the best night"],[4662,4708,"of your life."]],"54":[[1472,1551,"Oh my God!"],[1551,1751,"Is that Asher King with Ellie Jones?"],[1901,2047,"She's so beautiful,"],[2047,2231,"I almost didn't recognize her!"],[2565,2627,"Asher,"],[2627,2811,"everyone is starring at us."],[2923,3036,"I don't...I don't know,"],[3044,3128,"if I should be here."],[3290,3386,"Well if they wanna to stare at us,"],[3386,3445,"let's give them something"],[3445,3490,"to look at."]],"55":[[1096,1205,"May I have this dance?"],[1976,2035,"Asher,"],[2035,2210,"this is the best night of my life."],[2352,2439,"I want you to say that"],[2439,2515,"every night."],[2690,2727,"What can I do"],[2727,2865,"to make this night better for you?"],[3157,3453,"Honestly, it's... freezing in here."],[3645,3745,"And I'm starving."],[3908,4137,"Ever since I got pregnant,"],[4137,4466,"I'm hungry all the time."],[4583,4754,"Well, why don't I go get you a jacket?"],[4754,4938,"And you can get both of you"],[4996,5117,"some food."],[5284,5359,"Okay."],[6639,6823,"Oh my God, does this have nuts in it?"],[6956,7115,"I'm gonna be sick."],[7941,8074,"A little early for morning sickness,"],[8074,8195,"isn't it, Ellie Jones?"]],"56":[[0,33,"Claudia?"],[33,250,"What are you even doing here?"],[250,379,"You're not supposed to be here,"],[379,479,"you're expelled."],[479,571,"And you're not supposed"],[571,646,"to be pregnant!"],[679,813,"You're supposed to be a virgin"],[813,938,"sitting in your daddy's pews,"],[938,1030,"and I'm the one"],[1030,1142,"who should be with Asher!"],[1251,1447,"Let go of me, Claudia!"],[1447,1601,"Oh, I'll let go."],[1601,1789,"But first, you need to say,"],[1818,1939,"I'm a stupid slut, who let a boy"],[1939,2152,"who doesn't give a fuck about me"],[2152,2239,"knock me up."],[2239,2385,"No, I'm not saying that"],[2385,2560,"because it's not true."],[2660,2811,"Oh, don't you get it, Ellie?"],[2857,3111,"The Red Snakes are coming after you."],[3111,3232,"You'll be shipped off,"],[3232,3399,"and Asher will be left all alone"],[3399,3586,"with only me there to comfort him."],[3586,3832,"And you know how he just loves"],[3853,4020,"to run back to me whenever he's hurt."],[4287,4454,"That's not gonna happen."],[4546,4683,"Asher is gonna save me."],[4738,4850,"Are you sure about that?"],[4904,5005,"Let's see how he reacts"],[5009,5113,"when the whole school"],[5113,5321,"knows you're a dumb whore."],[5342,5551,"Oh sorry,"],[5551,5684,"a dumb pregnant whore."],[5747,5910,"Bye bye, good girl Jones,"],[5910,6085,"hello, pathetic single mom!"]],"57":[[70,175,"Claudia stop!"],[175,321,"Hey everyone!"],[321,429,"Look!"],[525,684,"I know we all know Ellie Jones"],[684,813,"as a good Godly girl,"],[813,921,"but look at her now!"],[921,1138,"Pregnant and alone!"],[1305,1455,"I’m, I'm not pregnant, Claudia."],[1455,1572,"Please stop spreading rumors."],[1651,1705,"Fine!"],[1730,1847,"If you're not pregnant,"],[1847,1918,"and no longer"],[1918,2047,"a picture perfect good girl,"],[2085,2181,"then I'm sure you wouldn't mind"],[2181,2310,"taking a few sips of this!"],[2381,2452,"I mean,"],[2452,2602,"we all saw her wasted at that party"],[2602,2698,"a few months back."],[2744,2831,"If you're really"],[2831,2961,"Asher King's girlfriend,"],[2961,3182,"take a few sips, and act like it!"],[3278,3440,"Asher, where are you?"],[3482,3574,"Please don't let them"],[3574,3666,"hurt our baby!"]],"58":[[275,404,"Asher, where are you?"],[500,571,"Please don't let them"],[571,679,"hurt our baby!"],[1017,1138,"News flash, Claudia!"],[1384,1501,"I changed my ways for Ellie."],[1501,1597,"I don't drink anymore."],[1597,1693,"Something I never would have done"],[1693,1764,"for you!"],[1764,1935,"You're gonna be a terrible mom."],[1947,2027,"Just like your mom"],[2027,2106,"who left you!"],[2106,2164,"I mean,"],[2202,2352,"who wouldn't leave you?"],[2352,2560,"You're a pathetic little whore!"],[3136,3253,"See!"],[3253,3424,"The little skank is pregnant!"],[3887,3962,"Fine."],[4099,4162,"I am pregnant."],[4162,4283,"But this has nothing"],[4337,4454,"to do with Asher."],[4454,4625,"And you can call me a whore"],[4625,4767,"all you want, because..."],[4767,4884,"because I had this baby"],[4884,4975,"out of wedlock-"],[4975,5084,"And that would be a lie!"],[5084,5201,"Because it is my baby."],[5689,5834,"And me and Ellie are getting married."]],"59":[[45,237,"And me and Ellie are getting married."],[688,871,"What is going on here?"],[975,1188,"Asher King and Ellie Jones assaulted me!"],[1188,1330,"Claudia, what are you doing"],[1330,1451,"on school grounds?"],[1572,1685,"Look what she's holding!"],[2185,2273,"She tried to make Ellie"],[2273,2377,"drink alcohol."],[2406,2540,"Is that true, Ellie?"],[2577,2711,"Yes, it's true."],[2844,2911,"Well, Claudia."],[2911,3007,"It looks like"],[3007,3161,"expulsion wasn't enough for you."],[3161,3282,"Maybe juvie is."],[3361,3520,"No!"],[3541,3661,"No!"],[3661,3899,"No! It’s all Ellie Jones's fault!"],[3899,4099,"Screw you, you skanky bitch!"]],"60":[[371,596,"Thank you for being my hero, again."],[734,813,"But, um..."],[813,913,"what you said back there"],[913,1151,"about... marrying me?"],[1255,1380,"Did you mean it?"],[1418,1551,"Every word."],[1639,1697,"I've been saving up"],[1697,1780,"to buy a ring."],[1922,2068,"I want us to be a real family."],[2189,2331,"I want that too."],[2640,2840,"I... I also want you to know that"],[2915,3115,"what Claudia said about my mom,"],[3253,3382,"it's not true."],[3503,3703,"She died, when I was young."],[3862,4058,"And I just want to be a good mom"],[4058,4204,"to honor her."],[4258,4346,"My mom died too."],[4466,4629,"Her and my dad were in a car crash"],[4629,4700,"when I was 12,"],[4700,4813,"and they both passed."],[4929,5080,"I want to be the dad that I never had."],[5263,5351,"But all that pain was worth it,"],[5351,5492,"now that I have you."],[5568,5705,"You're gonna be a great dad."],[5772,5868,"You're gonna be a great mom."],[6748,6911,"You have five minutes"],[6911,7032,"to clear out your locker"],[7140,7273,"and you are never to set"],[7315,7532,"foot on school grounds again."],[8721,8808,"You might be expelled"],[8808,8871,"from this school,"],[8871,8933,"but you're also"],[8933,9054,"expelled from this town!"],[9100,9317,"Never let me see you here again,"],[9317,9405,"or this rat won't be"],[9405,9517,"the only thing that dies."]],"61":[[266,437,"This is your last chance, Jax."],[437,629,"Don't fucking threaten me."],[738,855,"Not a threat."],[955,1055,"An offer."],[1092,1263,"You have until midnight."],[1263,1434,"Just get Ellie home back to me,"],[1434,1614,"away from your devil brother,"],[1630,1805,"and I'll give you enough money"],[1805,1943,"to start a new life somewhere..."],[1943,2072,"so far away from me,"],[2072,2189,"that I never have to hear"],[2189,2356,"the last name King again."],[2389,2569,"And if I don't?"],[2694,2836,"I'll tell Donovan Black"],[2836,2952,"everything!"],[2986,3098,"He won't just hurt Asher."],[3098,3365,"He will kill your daughter."],[3465,3649,"If she has that baby with Asher,"],[3649,3799,"she's already dead to me."],[3799,3970,"I have nothing to lose."],[4054,4258,"The question is, do you?"]],"62":[[462,600,"Go inside and get some rest."],[600,663,"I'll be home soon."],[663,855,"I just gotta pick something up."],[1013,1101,"It's not something"],[1101,1217,"for the Snakes, right?"],[1217,1288,"Never."],[1376,1476,"It’s for us."],[4154,4279,"I was hoping to find you here."]],"63":[[116,479,"Uh... Asher will be back soon."],[700,846,"I'm not here to talk to Asher."],[846,967,"I'm here for you."],[1038,1134,"I know that you're pregnant,"],[1205,1338,"and soon Donovan will know too."],[1397,1651,"Jax... please don't hurt me."],[1680,1755,"My brother is gonna be"],[1755,1876,"the one that gets hurt."],[1976,2223,"Please, Ellie, listen."],[2252,2385,"After our parents died,"],[2460,2585,"I tried to take care of Asher."],[2585,2673,"I really did."],[2781,2886,"But I was young"],[2886,3019,"and we had no one to turn to..."],[3111,3353,"Donovan, he offered me a job"],[3403,3516,"He sheltered us."],[3578,3703,"He told us we were family."],[3858,3999,"I love my brother."],[4216,4346,"So do I."],[4391,4466,"If that's true,"],[4466,4571,"then you'll help me."],[4767,4871,"How?"],[4929,5050,"Your father offered me money"],[5050,5201,"if I return you home by midnight."],[5401,5484,"If you're not home,"],[5484,5584,"he is gonna tell Donovan"],[5584,5663,"everything,"],[5663,5826,"and he will kill Asher."]],"64":[[0,120,"But if I can get the money,"],[150,312,"I can use it to help Asher"],[312,425,"start a new life somewhere safe."],[1259,1418,"It's your decision, Ellie."],[1697,1960,"If you love him, you'll let him go."],[3870,4070,"This is it, Ellie Jones."],[4095,4270,"I'm gonna to ask you to be mine."],[4291,4387,"Forever."],[4942,5038,"Ellie."],[5455,5555,"What's going on?"],[5722,5818,"Uh..."]],"65":[[58,316,"Asher, I can't do this anymore."],[392,496,"I've thought about it, and"],[517,684,"I'm going back to my dad's house."],[734,855,"What are you talking about?"],[921,1172,"All I do is cause you pain, Asher."],[1276,1376,"Everyone thinks"],[1376,1497,"you're ruining my life,"],[1497,1714,"but I'm ruining yours."],[1780,1906,"We're so different."],[1997,2218,"Our families are never gonna give up."],[2314,2477,"Ellie, please don't do this."],[2477,2573,"It's already done."],[2681,2869,"I'm so tired."],[2869,3003,"And I don't want to deal with this"],[3003,3069,"anymore."],[3069,3224,"And I'm going back to my dad’s"],[3224,3490,"because I miss my old life,"],[3574,3737,"my life before you."],[3737,3891,"He broke his own heart"],[3891,4091,"to protect you before."],[4091,4250,"Now it's your turn, Ellie."],[4300,4416,"If you care at all,"],[4416,4550,"you won't follow me."]],"66":[[312,421,"Ellie?"],[671,788,"Jax."],[813,946,"What are you doing here?"],[975,1101,"Ellie just left me."],[1514,1622,"What did you do?"],[1626,1676,"Nothing."],[1739,1881,"She made her own choice."],[1906,2027,"Let me go."],[2214,2327,"Asher, listen to me."],[2327,2423,"Donovan knows"],[2423,2556,"you got Ellie pregnant."],[2556,2736,"You need to leave town now."],[2777,2952,"I'm not leaving Ellie or my baby."],[2969,3098,"Donovan will kill you!"],[3382,3503,"I got you a ticket."],[3516,3687,"It's the first train out in the morning."],[3757,3858,"You'll be safe."],[3858,3970,"You'll be fine."],[4004,4170,"I'm not gonna be fine without Ellie."],[4170,4270,"Don't you understand that?"],[4329,4421,"This is where I was."],[4517,4662,"I bought her an engagement ring."],[5034,5105,"I may not be able to"],[5105,5163,"give her the world,"],[5163,5213,"but I will give her"],[5213,5330,"everything that I have."],[5659,5772,"You really love her?"],[5772,5905,"More than anything."],[6456,6556,"Fine."],[6648,6819,"If you really love her,"],[6869,7061,"you’ll listen to me now."],[7107,7257,"If you want to save Ellie"],[7257,7369,"and your baby..."],[7436,7557,"I have a plan."]],"67":[[533,788,"Dad, I'm home!"],[959,1063,"Can please just stop"],[1063,1180,"all this craziness?"],[1297,1484,"I'll do whatever you want!"],[1514,1643,"Ellie, you're back."],[1680,1922,"Leave the King brothers alone."],[2014,2097,"Please!"],[2143,2335,"Don't get uncle Joseph involved."],[2469,2569,"You can send me"],[2569,2669,"wherever you want."],[2719,2794,"The car will be here"],[2794,2915,"first thing in the morning,"],[2915,3023,"to take you to the convent."],[3182,3311,"And you'll leave them alone?"],[3386,3536,"I will if you go."],[3574,3687,"I'm going."],[4020,4300,"But don't think for a second"],[4300,4441,"that I came back for you."],[4496,4662,"I'm not your good little girl"],[4662,4829,"anymore, okay?"],[4929,5050,"Do you understand?"],[5105,5242,"You can send me away"],[5242,5455,"and keep me away from Asher,"],[5455,5655,"but I promise you,"],[5839,6160,"I will do anything to protect my baby."]],"68":[[863,984,"Good morning, Eleanor."],[1038,1105,"Nice of you not to"],[1105,1251,"sneak out again last night."],[1292,1455,"You didn't give me much of a choice."],[1547,1655,"You locked me in my room."],[1655,1755,"Don't talk back."],[1847,1981,"Maybe the nuns will teach you"],[1981,2060,"some manners."],[2089,2152,"Now, let's go."],[2152,2239,"The car is here."],[2519,2627,"You're not gonna"],[2627,2756,"take me yourself?"],[2823,2952,"Don't you want to say bye?"],[3048,3203,"You've embarrassed me enough."],[3294,3399,"I don't want to be seen with you"],[3399,3553,"until this devil spawn"],[3582,3674,"has been adopted"],[3674,3824,"by a couple of my choice"],[3824,3916,"from the church."],[4316,4471,"I will protect my baby."],[4521,4633,"Good luck with that."],[5372,5476,"Knock it off!"],[5492,5613,"Stop that crying!"],[6264,6427,"On the way back to town,"],[6448,6544,"stop by the apartments"],[6544,6644,"on Riverside Drive."],[6677,6852,"Give this to Jax King."],[6977,7223,"Don't touch it or my daughter."],[8479,8641,"Forgive me, Asher."],[8641,8821,"I will miss you and the family"],[8821,8883,"we could have"],[8883,9038,"for the rest of my life."]],"69":[[116,237,"Forgive me, Asher."],[287,467,"I will miss you and the family"],[467,650,"we could have for the rest of my life."],[1505,1664,"What, why are we stopped?"],[2886,3061,"Don't worry, Ellie, you're safe."],[3140,3253,"Asher!"],[3457,3545,"But how?"],[3628,3703,"You really think"],[3703,3782,"I'd let you screw up your life"],[3782,3866,"just for me?"],[4070,4124,"Remember, Ellie,"],[4124,4266,"I always told you I'd protect you."],[4350,4446,"You saved me."],[4529,4713,"I love you, Ellie."],[4892,4954,"I love you too,"]],"70":[[70,442,"Uh, Jax, I was just about to leave,"],[442,579,"but Asher..."],[596,796,"please just let us explain."],[834,971,"I don't need an explanation"],[971,1030,"from you, Ellie."],[1192,1305,"It's okay."],[1384,1480,"I know everything."],[1647,1785,"Thanks for loving my brother."],[2060,2177,"This is from my dad."],[2289,2464,"You guys can get out of here."],[2464,2594,"I'm not letting you though."],[2665,2798,"I'm not letting you go again."],[2894,3007,"We're all gonna go."],[3190,3311,"No, we're not."],[3370,3465,"You guys take the money"],[3465,3541,"and start a new life"],[3541,3678,"somewhere in a new town."],[3707,3824,"Don't worry about Donovan."],[3824,3953,"I'll make sure he doesn't bother you."],[3962,4074,"Jax, no."],[4091,4241,"Don't worry about me,"],[4241,4329,"little brother."],[4441,4575,"Let me take care of you"],[4575,4658,"one last time."],[4692,4758,"Thank you."],[6272,6410,"Isn't this heart warming?"]],"71":[[342,504,"Isn't this heart warming?"],[667,829,"Where do you think you're going, Asher?"],[863,900,"You think you’re gonna"],[900,959,"break the rules"],[959,1046,"of the gang?"],[1088,1230,"Just let them go, Donovan."],[1380,1539,"I'll do anything you want."],[1564,1655,"It's not you I want."],[1735,1826,"It's them."],[1847,1947,"And I won't rest"],[1947,2127,"until Asher King is on the ground!"],[2848,2944,"Please."],[2977,3078,"Please, please, please."],[3128,3236,"You can kill me."],[3236,3286,"Just don't hurt Ellie."],[3286,3353,"Don't hurt our baby."],[3411,3541,"It's too late to negotiate."],[3703,3803,"Little rats."]],"72":[[29,221,"It's too late to negotiate."],[367,450,"Little rats."],[1105,1155,"Oh!"],[3753,3832,"Go!"],[3866,3962,"Get out of here!"],[4095,4333,"Asher, take Ellie"],[4362,4504,"and start a new life."],[4504,4600,"Go!"]],"73":[[0,75,"Go!"],[763,905,"I love you, big brother."],[1259,1338,"Name him after me."],[2606,2723,"Sheriff Jones?"],[2844,2969,"It's Jax King."],[3157,3244,"There's been a murder..."]],"74":[[262,400,"You wanna step out, please?"],[729,842,"You know, you did the right thing,"],[842,1030,"son, by turning yourself in, and"],[1092,1134,"I'm gonna see"],[1134,1234,"if they'll go easy on you"],[1234,1434,"for taking down Donovan Black."],[1451,1572,"And thanks for tipping me off"],[1572,1668,"to that other crime."],[1710,1856,"What happened, Joseph?"],[2010,2068,"Jax?"],[2256,2327,"What happened is you've been"],[2327,2523,"colluding with gang members."],[2523,2652,"You're under arrest for aiding"],[2652,2773,"and abetting a Red Snake."],[2902,2994,"Joseph!"],[3290,3407,"I guess we're not so different"],[3407,3499,"after all."],[3582,3666,"Looks like we're heading to"],[3666,3749,"the same place."],[3824,4141,"I see you in hell... Pastor."],[4254,4383,"Get these off me!"],[4529,4658,"Joseph, what are you doing?"]],"75":[[1172,1292,"You sure about his name?"],[1334,1418,"Yeah."],[1484,1634,"Little baby Jax."],[1897,2027,"He protected us, so..."],[2147,2277,"we have to protect him."],[2464,2565,"You know, the officers are saying"],[2565,2694,"he's is doing really well."],[2769,2944,"He might be looking at an early release."],[3069,3219,"That's so great!"],[3219,3319,"Hear that, honey?"],[3386,3486,"You might get to meet"],[3486,3661,"your uncle Jax soon."],[3895,4049,"We love you so much, son."],[4946,5084,"Alright, Officer King."],[5084,5213,"You're gonna be late for work."],[5543,5676,"Well, since I'm already late."],[6669,6802,"Ellie Jones,"],[6890,7077,"now that we have our baby Jax"],[7077,7223,"and our own little family,"],[7415,7561,"will you make me the happiest man alive"],[7561,7640,"and marry me?"],[8049,8216,"Of course I will, Asher."],[9522,9684,"I love you so much,"],[9763,9943,"my beautiful good girl."],[10060,10322,"I love you too, my sweet bad boy."]]}