{"1":[[704,813,"Mia!"],[834,942,"Why are you wearing that"],[942,1059,"outdated old thing again?"],[1109,1217,"I told you to throw that out."],[1247,1322,"It's comfy."],[1388,1459,"Plus, you know I don't really"],[1459,1551,"like to dress up anyway."],[1593,1776,"Oh my God, Mrs. Wilson,"],[1776,1901,"I almost thought you were the maid."],[1985,2072,"Your husband."],[2106,2293,"He's so rich."],[2327,2477,"Can't he buy you a new dress?"],[2515,2623,"Where's Mr. Wilson?"],[2660,2777,"Missing at his own party?"],[2790,3015,"He's just busy with work..."],[3082,3174,"He's on a business trip."],[3249,3403,"Oscar-winning actress Jennifer Walsh"],[3403,3545,"spotted with a new fling,"],[3616,3812,"rumored to be Tyler Wilson, CEO of"],[3812,3920,"the Wilson Corp..."],[4754,4829,"I've been in love with"],[4829,4950,"Tyler for seven years,"],[4950,5046,"and I chose to be a"],[5046,5230,"housewife for three years."],[5263,5397,"I thought if I kept giving,"],[5397,5613,"one day he'd reciprocate my feelings."],[6585,6677,"Why were you with"],[6677,6877,"Jennifer at the airport?"]],"2":[[0,150,"We'll get divorced once we finalize the"],[150,254,"asset division next week."],[279,387,"Is it because of Jennifer?"],[454,567,"You don't need to know why."],[633,717,"Just sign your name."],[842,955,"And what if I refuse?"],[1000,1163,"You want money, huh?"],[1213,1330,"This card has no limit."],[1376,1634,"Just sign the papers, and it's yours."],[2510,2677,"Tyler, the power's out..."],[2719,2798,"I'm scared..."],[2844,2890,"Don't worry."],[2927,3048,"I'll be right there."],[3236,3315,"Sign the papers."],[3332,3478,"Don't make me ask a third time."],[3524,3649,"It's time to wake up from the dream"],[3649,3762,"that turned into a nightmare."],[3816,3862,"Fine."],[3970,4166,"If you're so eager to divorce me,"],[4166,4308,"I will grant you that."],[4696,4767,"Happy now?"],[4808,4896,"You can stay here until"],[4896,5021,"the divorce is finalized."],[5071,5125,"After that,"],[5125,5309,"you should probably move out."],[5309,5363,"Yeah, don't worry."],[5363,5522,"I'll be out before you even ask."],[6314,6502,"Oh, and by the way, you should go see a"],[6502,6594,"fucking urologist,"],[6594,6681,"because it's been three years"],[6681,6790,"and you haven't touched me once."],[6810,7040,"If there's a problem, go see a fucking"],[7040,7107,"doctor before it"],[7107,7223,"ruins your next marriage."],[7232,7311,"The hell was that?"],[7369,7449,"I didn't touch you because"],[7449,7549,"I'm not attracted to you."],[7561,7670,"Oh, go see your fucking date!"],[7670,7732,"Mia!"],[8295,8533,"Screw being a housewife."],[8566,8725,"Screw fucking Tyler!"],[8758,8904,"If he thinks I'm a gold digger, huh?"],[9042,9125,"I'll show him"],[9125,9296,"what a gold digger looks like."]],"3":[[50,129,"From now on,"],[129,342,"I'm no longer Tyler Wilson's wife."],[379,450,"I'm just me."],[479,521,"Miss."],[700,850,"This is our most expensive set,"],[892,938,"Two million."],[1121,1213,"I'll take it."],[1514,1701,"Our fourth quarter has been beating"],[1701,1839,"great expectations."],[2665,2873,"I'll take those two and that one."],[2957,3086,"Here's my card."],[3174,3219,"Go on."],[3274,3440,"And our investors have"],[3440,3641,"been really happy with it."],[4049,4149,"I'll take the whole rack."],[4400,4550,"Mr. Wilson, maybe you should..."],[5059,5246,"Has this woman lost her damn mind?"],[7040,7144,"Didn't you see I'm home?"]],"4":[[0,166,"Yeah, you're home, and?"],[183,342,"Mia, what's with this attitude?"],[483,675,"Let me remind you that we signed the"],[675,821,"divorce papers, so all that's left is"],[821,909,"splitting the assets."],[967,1067,"Half of this home is mine,"],[1067,1205,"and I'll act however I want."],[1247,1409,"You can't just do nothing, and not even"],[1409,1493,"preparing me a meal."],[1530,1643,"Oh, you want dinner?"],[1764,1889,"Here, enjoy."],[2114,2335,"You're spending my money, mind you."],[2377,2506,"And this is the attitude I get?"],[2523,2606,"Well, you gave me"],[2606,2781,"your card to divorce you."],[2815,2907,"You never said I had to"],[2907,3044,"continue being your housemaid."],[3161,3319,"You know, I never realized how petty"],[3319,3549,"and rude you really are!"],[3611,3687,"Sorry."],[3699,3874,"Yeah, I'm not being nice anymore."],[3895,4020,"My heart's empty for you,"],[4070,4200,"and I'm done with you."],[4333,4562,"Oh, and just so you know,"],[4562,4637,"moving forward,"],[4637,4825,"there's nothing between us."],[4884,4929,"Ever!"],[6589,6744,"Fuck you, asshole."]],"5":[[166,450,"Oh, he must be mad then!"],[483,638,"Oh my god, he's more than mad."],[638,855,"I mean his face went totally livid!"],[930,988,"That's what a"],[988,1201,"cheating scumbag deserves."],[1380,1589,"Let's not talk about him."],[1647,1768,"What's your plan now?"],[1793,1922,"I mean I've just been a housewife for"],[1922,2248,"the past three years, but I guess it's"],[2248,2369,"time to get back to work."],[3044,3157,"Congrats on winning the"],[3157,3315,"young designer award, Mia!"],[3361,3461,"- Hey bro. - Hey."],[3461,3557,"You're gonna be the best"],[3557,3691,"jewelry designer ever."],[4283,4471,"Our star designer?"],[4471,4642,"So, where are you planning to work?"],[4729,4808,"Well, of course the top"],[4808,4917,"design company."],[4950,5100,"The Wilson Corp."],[5163,5184,"What?!"]],"6":[[154,275,"You're going back to work?"],[279,367,"Mm-hmm."],[483,583,"You've been living the good life for"],[583,658,"three years now."],[658,775,"What could you possibly do now?"],[825,921,"Jewelry designer."],[1026,1076,"You?"],[1234,1317,"Listen, don't expect"],[1317,1409,"me to give you a job."],[1493,1551,"Well, don't worry."],[1551,1676,"I already have the position."],[1751,1822,"Which company?"],[1868,2035,"A major international firm."],[2248,2348,"What is so shocking?"],[2410,2523,"You know, before we were married,"],[2523,2665,"I was a well-known jewelry designer"],[2665,2773,"that all the firms wanted."],[2827,2932,"And you said it yourself,"],[2932,3065,"it was before we got married."],[3128,3261,"The market's different now."],[3261,3370,"I'm just telling you, don't set"],[3370,3482,"yourself up for failure."],[3520,3728,"You... Forget it."],[3807,3937,"I was just giving you a heads up."],[3937,4024,"We're getting divorced soon,"],[4024,4108,"so I don't have to"],[4108,4225,"keep you in the loop anymore."],[4308,4341,"Fine,"],[4458,4592,"Let's see how long it takes before you"],[4592,4750,"come crawling back."],[5459,5572,"The acquisition contracts were just"],[5572,5659,"sent over by legal.."],[5697,5826,"Oh, and the new design director is"],[5826,5939,"in the department."],[5939,6081,"They are throwing a little welcome party."],[7019,7236,"Hi, I'm Mia, and you are...?"]],"7":[[108,542,"Uh, Mia. This is Mr. Wilson. The CEO."],[658,796,"It's nice to meet you, Mr. Wilson."],[938,1172,"You! Come with me!"],[1447,1605,"Why did Mr. Wilson"],[1605,1822,"take Mia into his office?"],[1876,1972,"Did he know her before?"],[2035,2118,"No way."],[2256,2402,"I bet she slept her way to the top."],[2423,2535,"That's how she lean to"],[2535,2702,"the design director position."],[2815,2977,"Hey, don't you all have work to do?"],[3465,3586,"Mr. Wilson's never invited"],[3586,3787,"an employee to meet them alone."],[3899,3995,"Does he really have some sort of"],[3995,4104,"special relationship with"],[4104,4208,"the new design director?"],[4371,4466,"What was that about?"],[4491,4642,"Isn't this what you wanted?"],[4642,4775,"Acting like strangers in the office?"],[4817,4996,"You better cut it out! No matter how"],[4996,5142,"hard you try to get my attention."],[5196,5263,"I'm not changing"],[5263,5372,"my mind about the divorce."],[5434,5522,"Oh really?"],[6577,6677,"Watch this."],[6802,6940,"Mr. Wilson, be professional."],[6940,7090,"I don't want everyone in the office thinking"],[7090,7261,"I got this job through connections."],[7699,7799,"The audacity!"],[7978,8083,"Mr. Wilson."],[8199,8270,"Are you okay?"],[8324,8646,"I'm fine. I'm perfectly... fine."]],"8":[[233,279,"Mia!"],[521,625,"What did Mr. Wilson"],[625,763,"wanna talk to you about?"],[821,905,"Just wait, Tyler."],[946,1117,"I'm about to ruin your reputation."],[1413,1576,"Mr. Wilson, he..."],[1793,1814,"He..."],[1901,2118,"Wait, are you okay, Mia?"],[2318,2460,"He asked me to be his mistress."],[2673,2790,"And then when I said"],[2790,2932,"no, he threatened me."],[3048,3115,"No way."],[3203,3286,"Mr. Wilson would never"],[3286,3399,"go for someone like you!"],[3549,3661,"Did you see that?"],[3661,3799,"Mia's hair was all messed up"],[3799,3949,"when she left Mr. Wilson's office."],[4033,4441,"I bet SHE was the one who initiated."],[4550,4692,"Mr. Wilson seems so aloof."],[4771,4871,"I never thought he would"],[4871,5000,"be somebody who would pull"],[5000,5196,"something like workplace harassment."],[5317,5380,"Keep it up, guys."],[5430,5584,"Let everyone know that Tyler is nothing"],[5584,5776,"but a two-faced scumbag!"],[5809,5964,"Let's see if Jennifer still wants him."],[6005,6093,"What an opportunity!"],[6247,6331,"Absolute opportunity."],[6335,6477,"And you turned him down?"],[6548,6585,"Wait, what?"],[6690,6790,"I have wanted to be"],[6790,6902,"Mr. Wilson's mistress"],[6902,7094,"like forever just to be near him"],[7094,7190,"every single day."],[7198,7344,"When will I be so lucky?"],[7557,7674,"These people are beyond saving!"]],"9":[[120,200,"Jennifer, oh my god,"],[200,321,"you're not gonna believe this."],[358,546,"Mr. Wilson tried to make the new design"],[546,767,"director his mistress and she totally"],[767,959,"like shut him down."],[1021,1113,"No way."],[1192,1297,"Who in their right mind"],[1297,1443,"would turn down Mr. Wilson?"],[1476,1622,"-That's what we.. -And that face!"],[1739,1830,"I know."],[1839,2001,"Mia told us herself so, it is true."],[2014,2093,"Is that so?"],[2110,2189,"Absolutely."],[2239,2339,"There's something going on"],[2339,2519,"between them, I guarantee it."],[2923,3140,"Connor, what are you doing here?"],[3169,3224,"Back to work."],[3716,3824,"She really said that?"],[3933,3999,"Absolutely."],[4483,4600,"I heard you told people"],[4600,4708,"I wanted you to be my mistress?"],[4808,4938,"Well, I thought the atmosphere was"],[4938,5063,"a little bit dull in the office,"],[5063,5217,"so I told the joke to lighten the mood."],[5217,5338,"So, I should be thanking you then?"],[5392,5488,"You're very welcome."],[5647,5826,"Well, I will be on my way."],[6235,6318,"What the hell is that?"],[6318,6368,"You got the whole"],[6368,6493,"office talking about us."],[6564,6702,"Be a shame not to make good on it."],[6823,6927,"We can talk this through!"],[7027,7248,"If you're gonna talk the talk,"],[7248,7390,"you gotta walk the walk."]],"10":[[0,87,"You gotta walk the walk."],[129,229,"Don't worry, you'll like it."],[312,358,"Okay."],[517,784,"I'm sorry. It's all my fault."],[788,955,"What exactly are you sorry for?"],[1059,1284,"I'm sorry for spreading lies and"],[1284,1472,"tarnishing your reputation."],[1551,1622,"Is that all?"],[1697,1780,"Maybe we should follow"],[1780,1876,"through with this after all."],[1918,2047,"Okay, I will clear it up!"],[2047,2143,"I'll set the record straight with"],[2143,2335,"everyone tomorrow, okay? Happy now?"],[2473,2556,"You got a problem?"],[2719,2786,"No."],[2911,3011,"You win."],[3161,3324,"Submit your resignation letter."],[3324,3411,"Remember that."],[3440,3624,"Why? What? No, I'm not quitting."],[3687,3912,"Fine. Go ahead and be stubborn."],[3949,4124,"Make sure you quit one way or another."],[4283,4387,"Bring it on!"],[4900,4975,"Good morning."],[6005,6156,"What is going on?"],[6335,6502,"They think Mr. Wilson must like your style,"],[6502,6664,"so they're all copying you!"],[6752,6881,"Great. Yeah, this is"],[6881,7027,"gonna make things worse."],[7415,7599,"Good morning, Mr. Wilson."],[7636,7699,"Mia?"],[8345,8504,"Good morning, Mr. Wilson."],[8608,8737,"I was going to clear things."],[8737,8854,"This client is yours."],[8967,9088,"If you don't land the deal by the end"],[9088,9280,"of the day, pack things and leave."],[9384,9551,"You can't take this one."],[9551,9697,"This guy's known to be impossible!"],[9726,9922,"If you're scared, you can back out."],[10055,10135,"I'll take it."]],"11":[[45,129,"I'll take it."],[175,412,"If you fail, don't come crying to me."],[425,633,"Rest assured, I'm gonna nail this case."],[704,750,"Fine."],[855,930,"I'll be watching."],[1167,1338,"Oh my god, Katie, my legs"],[1338,1451,"are like jelly, help me."],[1488,1626,"I found nothing scared you."],[1626,1797,"Why'd you take this one?"],[1856,1960,"It's like Mr. Wilson"],[1960,2077,"setting you up for failure."],[2114,2206,"I have to stay,"],[2206,2310,"I can't give up that easily."],[3228,3349,"Come in!"],[3628,3770,"Oh, apologies, Mr. White."],[3849,3937,"I can come back tomorrow."],[3978,4062,"You're already here."],[4116,4250,"No need to rush off."],[5271,5405,"Have a seat."],[5605,5755,"I'm the project liaison, Mia."],[5768,5876,"Here's your revised proposal"],[5876,5980,"according to your requests."],[6014,6151,"If there's anything else that you need,"],[6151,6210,"I'd be more than"],[6210,6306,"happy to accommodate you."],[6489,6552,"You'd be more than"],[6552,6715,"happy to accommodate me?"],[6744,6856,"Yes, anything that you need."],[7269,7382,"Have a drink with me then."]],"12":[[79,154,"You're not backing out"],[154,275,"of the deal now, are you?"],[342,542,"Is there something in that drink?"],[692,938,"Sorry, I'm pregnant. I can't drink."],[1109,1155,"Perfect."],[1359,1463,"I love pregnant woman."],[1597,2035,"Your job is to keep the client happy."],[2064,2377,"So do your best to accommodate me."],[2414,2473,"Mr. Wilson?"],[2552,2798,"I was looking into it, and that client,"],[2798,2898,"that Mia went to go see..."],[2998,3274,"he's involved in quite a bit of"],[3274,3465,"sexual harassment scandals."],[3549,3620,"Would you like me to"],[3620,3766,"terminate the partnership?"],[3874,3958,"If you've got that much"],[3958,4091,"free time, then keep working."],[4183,4454,"Yeah. Sorry, I spoke out of turn."],[4909,4979,"What kind of a meeting"],[4979,5080,"gets scheduled at night?"],[5117,5192,"That stupid woman"],[5192,5447,"wouldn't actually go, would she?"],[5559,5663,"Rest assured,"],[5663,5814,"I'm gonna nail this case."],[6126,6306,"We're going to PixieSpectrum Designs."],[7052,7148,"Let me go!"],[7173,7286,"The more you resist,"],[7294,7394,"the more I like it."],[7749,7811,"Drive faster."],[7987,8007,"Mia!"],[8571,8683,"Great. Now I'm"],[8683,8812,"definitely getting fired."]],"13":[[58,183,"Mr. Wilson, he hit me!"],[183,312,"How dare you attack me!"],[492,725,"Oh, Tyler, you arrived just in time."],[829,1109,"Your employee attacked me."],[1226,1343,"You have to deal with this."],[1426,1497,"You were the one"],[1497,1589,"that was getting handsy."],[1626,1693,"You're lucky"],[1693,1805,"I didn't kick your balls in."],[1843,1976,"You're just a lowly employee!"],[2060,2298,"I did you a favor. Don't be ungrateful."],[2318,2594,"You fucking creep. A favor?"],[2644,2848,"I'd be sorry to see that tiny thing."],[2977,3078,"Also,"],[3094,3324,"I'm the director of the design department."],[3549,3795,"Tyler, just hand this"],[3795,3928,"bitch over to me right now."],[3978,4133,"And I'll forget this ever happened."],[4187,4245,"Otherwise..."],[4245,4329,"Otherwise what?"],[4416,4504,"You're a smart man."],[4550,4662,"You wouldn't want to ruin a good"],[4662,4817,"client relationship"],[4817,5000,"over some nobody, would you?"],[5221,5296,"Come out!"],[5472,5613,"What? Are you crazy? You're not"],[5613,5739,"actually gonna give me to him, are you?"],[5739,5793,"Shut up!"],[5793,5897,"I said come out."]],"14":[[145,229,"Wise decision,"],[304,392,"Mr. Wilson."],[1138,1305,"Who the fuck said you could touch her?"],[1543,1668,"Tyler, what the hell are you doing?"],[1789,1935,"Since you can't control your hands,"],[1989,2127,"I'll take care of that for you."],[2318,2498,"I'm sorry. I won't do it again."],[2644,2736,"Are you sure about that?"],[2802,2857,"Wait, wait, wait!"],[2940,3190,"Before you ruin his hand, can we"],[3190,3319,"at least get him to sign the contract?"],[3319,3357,"Oh my God."],[3403,3561,"Is the contract that important to you?"],[3624,3782,"Yes, okay. I'm not quitting after this."],[3862,3962,"Even if you don't work, you have"],[3962,4049,"enough money to live comfortably"],[4049,4175,"for the rest of your life."],[4200,4320,"God, you don't get it."],[4320,4412,"It's not about the money."],[4412,4675,"It's about my career and my dream."],[4700,4825,"I'll sign it. Just let me go."],[4825,4921,"I'll sign it right now."],[5789,6060,"Great. I will be on my way."],[6060,6168,"You guys have fun."],[6210,6322,"The contract is signed."],[6322,6477,"The deal is done. Now let me go."],[6594,6785,"Connor, do you have enough"],[6785,6890,"evidence of Cooper's behavior?"],[6956,7040,"Got it all, sir."],[7136,7319,"What? You can't do this to me."],[7374,7432,"Hand the evidence"],[7432,7603,"over to the cops. You're done."]],"15":[[258,362,"Why is she still here?"],[437,525,"Is she waiting for me?"],[859,992,"No need to thank me, I just..."],[996,1234,"My phone died and I can't call an Uber."],[1259,1347,"Could you maybe..."],[1397,1593,"Didn't you just buy a car with my card?"],[1668,1835,"Uh, yes,"],[1897,2006,"but I haven't really driven in a while"],[2006,2064,"and I took it out"],[2064,2318,"yesterday and I scratched it up."],[2544,2686,"Thanks for earlier, by the way."],[2706,2777,"Don't read into it."],[2811,2873,"I would have done the"],[2873,3044,"same for any other employee."],[3098,3199,"I knew this jerk wouldn't"],[3199,3303,"actually stand up for me."],[3361,3420,"Mr. Wilson."],[3978,4137,"You know, I can get the door myself."],[4229,4312,"This is my car."],[4412,4512,"But we're going in the same direction"],[4512,4633,"so can't you give me a ride?"],[4721,4733,"No."],[5138,5271,"Come on, get in, Mr. Wilson."],[5288,5347,"Get out, now."],[5347,5472,"No, I'm not getting out of the car."],[5472,5505,"Come on."],[6214,6368,"Would it kill you to give me a ride?"],[6464,6602,"You just walked into my office"],[6602,6777,"and turned it into me harassing you."],[6827,6927,"If we ride together,"],[6927,6986,"I can't even imagine"],[6986,7186,"what the next rumor would be."],[7228,7332,"Move."],[7403,7478,"Drive."],[7728,7770,"Asshole!"],[8370,8500,"I knew you wouldn't be so heartless..."],[8867,8913,"Don't litter."],[9246,9342,"You jerk!"]],"16":[[479,583,"Cooper got arrested?"],[650,804,"Does that mean my contract is in vain?"],[888,1017,"If I don't seal this deal,"],[1021,1142,"Tyler is going to fire me."],[1263,1476,"No, no, I won't let him."],[1488,1622,"I am gonna resign before"],[1622,1814,"he even has the chance."],[1956,2039,"Okay."],[2344,2373,"Whoa!"],[2723,2986,"Wow, damsel saves the hero."],[2990,3174,"Oh my gosh, they're perfect together."],[3499,3570,"Seen enough?"],[3649,3828,"Oh, carry on."],[3858,3949,"We didn't see anything."],[4237,4379,"So, about last night..."],[4379,4479,"Wait, hold it."],[4537,4617,"Let me go first!"],[4688,4842,"Here is my resignation letter,"],[4871,5017,"which means you are no longer my boss."],[5046,5226,"So technically, I am firing you."],[5259,5280,"Ha!"],[5321,5484,"You? Fire me?"],[5526,5630,"Yeah, it's better to do"],[5630,5714,"that before you fire me."],[5818,5905,"Why would I fire you?"],[5935,6056,"Cooper may be arrested, but the"],[6056,6151,"business is still ongoing."],[6231,6310,"And didn't you sign"],[6310,6393,"the contract yesterday?"],[6581,6673,"Wait, so this means I don't"],[6673,6769,"have to leave the company?"],[6869,7065,"But just now, you already fired me."]],"17":[[150,266,"It was a misunderstanding!"],[321,462,"I mean, I love it here."],[462,542,"I don't want to leave."],[613,821,"So, about this resignation..."],[1096,1259,"No! No! It doesn't count."],[1317,1443,"It doesn't... it doesn't count."],[1547,1609,"Oh!"],[1655,1818,"Congrats on sealing the deals!"],[2085,2306,"Did we walk in at the wrong time?"],[2389,2444,"How long are you"],[2444,2590,"planning to stand up to me?"],[2669,2773,"Oh, sorry."],[3053,3244,"I tripped. Yes."],[3257,3395,"And then Mr. Wilson, being the caring"],[3395,3674,"boss that he is, helped me out."],[3737,4012,"We get it. Accidents happen."],[4049,4216,"Well, since you scored such a big win,"],[4216,4362,"we should go out and celebrate."],[4400,4500,"Yes! And tonight's on me."],[4600,4850,"Mr. Wilson, care to join us?"],[4896,4975,"He's not going."],[5117,5209,"I mean, he can't. He's"],[5209,5376,"really busy with work."],[5497,5555,"Well, it just so"],[5555,5647,"happens I'm free tonight."],[5739,5914,"Okay. Yeah."],[6001,6268,"Mia, tonight I'm going to make sure"],[6268,6406,"everyone sees you"],[6406,6498,"for the tramp you are!"]],"18":[[120,200,"Order whatever you want,"],[200,325,"everything's on me."],[325,462,"Don't mind if we do."],[1217,1480,"Mia! You've been with us for a while now,"],[1514,1597,"but we still"],[1597,1747,"don't know much about you."],[1839,1985,"How about we use tonight to get to know"],[1985,2085,"each other a little better?"],[2198,2289,"Sounds good! I'd love to"],[2289,2373,"get to know you better."],[2469,2556,"I heard you're married!"],[2731,2840,"How come you didn't invite your"],[2840,3207,"husband to such a special celebration?"],[3319,3557,"Mia's married? And what's this thing"],[3557,3695,"going on with Mr. Wilson?"],[3778,3912,"I never thought she"],[3912,4066,"was that kind of person."],[4175,4387,"Sarah is clearly out to get me,"],[4387,4692,"but Tyler and I are already divorced."],[4692,4829,"Still, doesn't feel right to bring it up."],[4942,5125,"Mia, if it's a touchy topic, I mean,"],[5176,5330,"you don't have to talk about it."],[5355,5605,"Sarah, that's her private life."],[5605,5680,"It's none of your business."],[5714,6068,"Oh, sorry. I was just trying to get to"],[6068,6260,"know Mia better. That's all."],[6314,6431,"Be respectful, okay?"],[6544,6794,"What's the deal? I mean, what could be"],[6794,7061,"so sensitive about someone's marriage?"],[7132,7228,"Katie, it's fine."],[7436,7657,"Honestly, talking about my husband just"],[7657,8016,"makes me really emotional because he..."],[8207,8316,"He..."],[8357,8456,"He?"],[8783,8917,"He passed away."],[9334,9563,"How? That must be so hard for you."],[9647,9813,"Widowed at such a young age."]],"19":[[62,233,"Well, you know, I'm used to it."],[250,358,"You know our whole marriage was"],[358,583,"a facade even before he died."],[625,804,"Is she taking another jab at me?"],[884,1017,"I'm sorry you had to go through that."],[1146,1405,"Oh, it's alright. I mean, my husband"],[1405,1647,"didn't really do much, and our marriage"],[1647,1780,"was dead in every sense."],[1860,1993,"Honestly, not much changed"],[1993,2206,"even after he was actually gone."],[2352,2506,"Uh, how about we play a fun"],[2506,2719,"drinking game? Lighting the mood?"],[2773,3015,"So now he wants to play games, huh?"],[3069,3186,"What are you mumbling about now?"],[3211,3395,"I said I’m really digging this vibe."],[3503,3561,"Oh!"],[3782,3891,"Kiss someone of the"],[3891,4099,"opposite sex for one minute."],[4337,4558,"If no one else is up for it, I guess"],[4558,4704,"I could make the sacrifice..."],[4721,4900,"I will take a drink."],[4954,5176,"You'd rather drink than kiss me?"],[5576,5655,"Alright, next round."],[5655,5780,"I know how fucking loyal you are to"],[5780,5876,"Jennifer, so I wouldn't"],[5876,6051,"wanna step on any toes."],[6143,6227,"Next round!"],[6297,6364,"See?"],[6756,6944,"Alright, French kiss someone of the"],[6944,7127,"opposite sex for a minute."],[7378,7532,"Mr. Wilson, I'm up for it."],[7728,7786,"You know you could"],[7786,7891,"always just take a drink."]],"20":[[855,1063,"I'm the first to lay eyes"],[1063,1201,"on Mr. Wilson for so long."],[1201,1426,"And this fucking Mia beat me to it."],[1989,2193,"I must have had too much to drink."],[2193,2348,"I'm imagining things."],[2540,2769,"Okay, who's next?"],[2831,2886,"Oh!"],[3082,3136,"Alright."],[3303,3370,"That's another one."],[3707,3908,"I'm gonna go to the bathroom."],[4191,4454,"Alright, your turn. Let's go."],[4592,4733,"Oh, I mean send more shots."],[4733,4900,"- Take care of her."],[5205,5251,"Alright."],[6047,6168,"Stop drinking so much"],[6168,6289,"if you can't handle it."],[6598,6706,"Woah."],[7365,7457,"What's up with you?"],[7570,7699,"You smell good."],[7853,7978,"Okay, come on. Let's go drink."],[8024,8199,"No more? Let's go home."],[8233,8483,"No, I don't want to go home."],[8550,8625,"Mia, don't push it."],[8692,9225,"Shh...You know, you look just like"],[9225,9588,"my ex-husband who's an asshole."],[9693,9864,"I mean, your eyes..."],[9864,10231,"that nose... these fucking lips..."]],"21":[[300,521,"Alright, let's get you home."],[788,1105,"Spin it. Spin it around."],[1134,1263,"Tyler, you're mine!"],[1313,1484,"Alright, alright, alright."],[1689,1830,"Mr. Wilson will pay for all of this?"],[1843,1993,"I hope so."],[2189,2285,"Hey guys, welcome back."],[2348,2594,"Cheers to Mr. Wilson."],[2602,2673,"Cheers."],[3849,4066,"I think I'm gonna just call it a night."],[4250,4487,"Whoa, Mr. Wilson. You've had a little"],[4487,4654,"bit too much to drink?"],[4792,4909,"Let me take you home."],[4946,5092,"Cut the crap, Sarah, unless you're"],[5092,5209,"ready to leave the company."],[5288,5360,"Mr. Wilson, I..."],[5370,5400,"Connor, Connor?"],[5409,5476,"Yeah, yeah."],[5860,6085,"Come on. I got you, I got you."],[6902,7040,"How did you even get this drunk?"],[7040,7102,"I mean, I'm almost"],[7102,7265,"sober, but you are still..."],[7574,7695,"It is so hot..."],[7791,8049,"Tyler? What are you doing?"]],"22":[[8,141,"Tyler, it's Mia,"],[141,275,"not Jennifer."],[275,404,"I think I've been drugged."],[508,588,"Mia, help me..."],[1163,1259,"Tyler stop."],[1422,1526,"Here, come on."],[1