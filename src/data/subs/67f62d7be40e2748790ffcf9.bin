8,"Get your facts straight."],[2869,2969,"When have I ever"],[2969,3215,"interfered in Mr. Wilson's marriage?"],[3274,3545,"Last night, you kissed him and then you"],[3545,3632,"left with him while he"],[3632,3724,"was already out of it."],[3778,3870,"We all saw it."],[3903,4016,"And why was he out of it?"],[4062,4175,"Enlighten me, please."],[4250,4379,"What are you implying?"],[4512,4662,"I think you're jealous that Mr. Wilson"],[4662,4888,"chose me over you in the game."],[4971,5046,"And now you're"],[5046,5251,"spreading rumors to spite me."],[5359,5434,"That makes sense."],[5497,5672,"She was about to lose it"],[5672,5897,"when Mr. Wilson didn't pick her."],[5947,6093,"I wouldn't be surprised if the whole"],[6093,6227,"Mr. Wilson is married"],[6227,6393,"thing is made up too."],[6556,6656,"I'm not lying!"],[6760,6794,"All right."],[6894,7032,"My friend has a picture of"],[7032,7173,"Mr. Wilson with his wife."],[7440,7553,"Just wait, okay?"],[7665,7753,"Your friend has a..."],[7753,7970,"like a picture of them together?"],[7987,8049,"Of course."],[8153,8366,"My friend knows Mr. Wilson well."],[8466,8650,"Feeling scared now, Mia?"],[8804,8967,"Oh, here's the photo."],[9117,9313,"Crap! My secret's about to get out."],[9513,9734,"How is this possible..."]],"26":[[154,204,"Who is it?"],[233,362,"Yeah, yeah, who's in the photo?"],[875,980,"If you're gonna fake it,"],[980,1155,"at least have their faces on it."],[1184,1276,"This could be anyone."],[1368,1509,"Phew! Thank goodness! it's just a"],[1509,1618,"picture of my back."],[1697,1964,"No, does it not have their faces?"],[2014,2189,"Is your friend some kind of paparazzo?"],[2214,2344,"No way, okay, she must"],[2344,2540,"have a photo of them."],[2619,2873,"I'll just ask her to send it to me."],[2894,2990,"No, that's enough!"],[3036,3153,"This is work hours,"],[3165,3336,"okay, stop wasting our time."],[3374,3486,"And if you continue to"],[3486,3603,"spread lies about me,"],[3636,3820,"I guarantee you'll regret it."],[3933,3978,"Okay, everybody,"],[3978,4091,"that's it, back to work."],[4854,5046,"Mia, you've got lucky this time,"],[5080,5292,"but your luck won't last forever."],[5338,5693,"Mess with me, and you'll pay for it."],[5964,6172,"You're Mrs. Wilson, though."],[6172,6314,"It's the big deal if they find out."],[6314,6489,"Not for much longer, anyway."],[6585,6727,"Forget all about him."],[6781,7111,"You are beautiful, smart, talented."],[7123,7253,"Plenty of men are gonna be into you."],[7311,7540,"Yeah, you're right, they will."],[7599,7670,"You just watch."],[7753,7866,"I'm gonna make him pay."]],"27":[[525,546,"Mia?"],[650,734,"The new partner's here."],[779,938,"Mr. Wilson wants you to join us."],[980,1117,"Okay, sure, yeah, I'll come right now."],[2031,2218,"Mia, oh my God, it's been so long."],[2252,2385,"Oh my God, Alex, wait,"],[2385,2498,"when did you get back?"],[2585,2706,"Are you the new partner?"],[2786,2869,"You two know each other?"],[2873,3032,"Oh yeah, we go way back."],[3190,3311,"Mr. Wilson,"],[3311,3495,"have you seen the urologist yet?"],[3557,3595,"Hey."],[3724,3770,"What?!"],[3812,3987,"So Mr. Wilson is having an erectile"],[3987,4099,"dysfunction problem?"],[5730,5968,"Maybe it's time to see a urologist."],[6806,6927,"I think I just learned something"],[6927,7048,"I wasn't supposed to know."]],"28":[[0,183,"Um, this is my new design proposal for"],[183,287,"the collaboration, if you guys"],[287,358,"want to take a look?"],[621,809,"I'm the client. I should see it first."],[813,938,"I'm the supplier."],[938,1067,"I'll review it before the client does."],[1126,1247,"Can't you guys look at it together?"],[1284,1317,"No!"],[1384,1484,"Fine. Then neither"],[1484,1584,"of you gets to see it."],[1614,1747,"You know what? It doesn't matter."],[1747,1926,"I trust Mia's designs completely."],[2022,2097,"You talk like you've"],[2097,2223,"known each other forever."],[2235,2448,"Well, of course, Mr. Wilson. And, uh,"],[2448,2548,"you were nowhere to be"],