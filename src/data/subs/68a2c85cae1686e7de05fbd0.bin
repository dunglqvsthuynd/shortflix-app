],[2673,2836,"When is this nonsense gonna end?"],[2932,3023,"Whether you wanna believe it or not,"],[3023,3128,"I didn't leave you"],[3128,3328,"out of revenge or betrayal."],[3582,3691,"I don't trust you!"],[3891,3924,"You know what,"],[3924,4083,"the proof's right here and I'm gonna find it."],[4162,4191,"Wait,"],[4191,4320,"no, don't touch that."],[4320,4346,"Why?"],[4346,4458,"Is this something secret?"],[4637,4775,"Christin, that's my life's work."],[4925,5038,"Who cares?"],[5038,5171,"You left your wife and daughter"],[5171,5309,"for some mistress?"],[5609,5743,"I bet that's your little love diary."],[5951,6026,"Enough!"],[6727,6815,"Get away from the fire!"]],"39":[[266,387,"Get away from the fire!"],[533,604,"Go, go!"],[604,675,"I'll handle this."],[2230,2310,"Let go!"],[2456,2556,"Stop it!"],[2719,2790,"You liar!"],[2877,2998,"You lied on us."],[3053,3169,"You bullied Mom!"],[4137,4216,"I curse you!"],[4270,4471,"May your organs rot and"],[4471,4629,"your soul burn in hell!"],[4846,4946,"May God bless you."],[5167,5226,"But I can't."]],"40":[[45,145,"This is all your fault,"],[145,296,"cause you had an affair with a married man!"],[358,462,"I told you..."],[462,642,"I am not the damn mistress!"],[1092,1175,"Look."],[1301,1468,"Dr. Clare is an upright scholar."],[1509,1705,"He's respected by all of his students."],[1814,1939,"The ones who trust him the least"],[1939,2052,"are you and your daughter."],[2239,2318,"Impossible!"],[2364,2427,"How could we..."],[2485,2694,"misunderstand Dad all this time?"],[2790,2919,"If I was actually his mistress,"],[2919,3032,"why would I lie to you,"],[3032,3119,"his ex-wife?"],[3440,3490,"Dad!"],[3536,3674,"I have to say sorry."],[3741,3845,"We have to go, okay?"],[3845,3958,"We have to apologize."],[5342,5413,"You're awake."],[5709,5809,"I can't believe"],[5809,5947,"Charlie left you guys here alone."],[6097,6327,"Maybe... I can take care of you"],[6327,6410,"and..."],[6410,6493,"Annabel"],[6493,6556,"from now on."],[6639,6702,"Never!"],[6827,6906,"I'm..."],[6906,7027,"I'm used to being with Dad."],[7065,7261,"What I said... it was just anger."],[7261,7407,"I regret it so much."],[7532,7628,"I'm scared."],[7628,7820,"I can't accept the new dad."],[7820,7887,"Don't worry."],[7970,8045,"We still have time."],[8108,8204,"Isaac, enough."],[8204,8324,"Okay, you're kind, but..."],[8375,8458,"not now."],[8516,8708,"We gotta find Charlie and find out the truth."],[8879,8975,"Let's go find the doctor."],[10239,10310,"I would'Ve had Christin"],[10310,10464,"if it wasn't for that little brat!"]],"41":[[280,363,"Professor,"],[447,537,"your wife and daughter"],[537,734,"burned all of the data and notes"],[734,897,"on the Unicorn Project derivative."],[934,1021,"Why keep going?"],[1161,1274,"My memory is my notes."],[1334,1441,"There's so many kids out there"],[1441,1548,"who need this technology,"],[1548,1634,"not just Anna."],[1708,1855,"I just hope that they don't suffer"],[1855,1931,"in the same way."],[1975,2215,"Your body cannot handle more radiation."],[2288,2382,"You're gonna die."]],"42":[[387,527,"Hey, guys."],[527,730,"Guess who got a promotion?"],[900,964,"Let's celebrate."],[1001,1081,"Congrats."],[1114,1184,"That's great."],[1211,1327,"Come on, guys."],[1354,1514,"Let's forget about the boring stuff."],[1564,1648,"We're celebrating."],[1925,2075,"You know I'm allergic to claret."],[2282,2429,"Dad, don't make a scene."],[2429,2555,"Just do it for me."],[2655,2729,"Okay, I'll do it."],[4210,4400,"Enough, celebrate it yourself!"],[4451,4617,"We have nothing to celebrate."]],"43":[[90,136,"Anna?"],[296,403,"You knew it, didn't you?"],[427,550,"On the day Dad left,"],[620,790,"you knew he was allergic to claret."],[877,967,"Mom told you."],[1084,1194,"Chris, no, no, no."],[1194,1301,"I, I, I didn't."],[1301,1418,"Get out of my house!"],[1574,1624,"Anna!"],[1705,1828,"I'll use conservative treatment"],[1828,1975,"to protect her nerves,"],[1975,2115,"but if she gets hit there again,"],[2115,