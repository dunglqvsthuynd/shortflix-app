767,846,"I wanna do"],[846,888,"for you,"],[917,955,"Anna."],[1080,1217,"But I'm probably gonna die."],[1438,1543,"There's not time for us."],[1605,1772,"Just remember Isaac always loved you."],[2231,2252,"Oh!"],[2781,2823,"Dad!"],[2852,2969,"Save Isaac!"],[3028,3148,"He's putting on a show."],[3148,3274,"Charlie, it's just blood!"],[3274,3378,"For God's sake!"],[3378,3482,"Isaac's dying and you're..."],[3482,3670,"Have you ever cared about my health?"],[3749,3812,"Even once?"],[4283,4316,"Dad,"],[4429,4596,"save Isaac or I'll kill myself!"],[4713,4750,"Anna!"],[4808,5050,"You're gonna threaten your own life over him?"],[5067,5205,"Yes or no?"],[5509,5559,"As you wish."],[5684,5718,"Nurse,"],[5776,5818,"draw his blood."],[5818,5897,"Save Isaac."],[6010,6110,"But his medical records say..."],[6110,6177,"It doesn't matter."],[6177,6264,"Just do it!"]],"31":[[671,754,"Mom,"],[754,905,"is Dad gonna be okay?"],[959,1121,"He doesn't look so good."],[1121,1330,"Of course, he's just pretending."],[1760,1868,"Hey, how are you feeling?"],[2214,2314,"Thanks, Chris."],[2314,2448,"I'm feeling a lot better."],[2673,2752,"In a month,"],[2823,2961,"I'll be out of your lives."],[5025,5191,"Here's the proposal for the Unicorn Project."],[5263,5459,"The research center agreed to fully fund"],[5459,5568,"the derivative research"],[5568,5697,"to cure your daughter's birthmark."],[5876,5968,"That's great."],[6264,6339,"Hold up!"],[6339,6481,"Where do you guys think you're going?"]],"32":[[16,112,"None of your business."],[125,250,"Not my business?"],[304,437,"What about your wife and your daughter?"],[592,667,"We're divorced."],[734,825,"Divorced?"],[888,1030,"Then let's settle things carefully."],[1059,1217,"Chris, how'd you split the property?"],[1359,1401,"Chris,"],[1564,1601,"tell her."],[1743,1868,"He left everything to me."],[1868,1918,"Really?"],[2002,2239,"House, car, savings, everything?"],[2423,2519,"That's impossible!"],[2581,2656,"Chris,"],[2656,2752,"don't be naive."],[2752,2898,"Men are greedy."],[3161,3290,"I trust him on this."],[3495,3603,"Then how's he been getting by"],[3603,3682,"this whole time?"],[3682,3849,"He's hiding cash"],[3849,4037,"probably for this pretty little mistress."],[4037,4141,"Chris, you gotta fight for it."]],"33":[[29,66,"Alright."],[120,221,"Hand over the rest of your money."],[362,504,"Chris, I gave you everything."],[558,621,"You don't cooperate,"],[621,742,"then I'll search you myself."],[804,838,"No..."],[1059,1117,"No need."],[1292,1368,"You want everything?"],[1693,1830,"You even want my watch?"],[1860,1956,"Will you want my phone?"],[2239,2314,"That's everything."],[2364,2506,"Would you want my organs too?"],[2506,2606,"Most of them are shot."],[2690,2848,"I'm sure that a few of them might be"],[2848,2898,"worth something."],[2927,3028,"That's it?"],[3065,3140,"I don't buy it."],[3140,3228,"You should search him."],[3365,3440,"Stop!"],[3528,3728,"Professor is too weak for this."],[3728,3883,"Well, you have the rest of money, Ms. Mistress?"],[3966,4120,"You never visit and we can't find you."],[4120,4237,"Did you forget about us already?"]],"34":[[29,79,"Enough!"],[308,412,"I've bigger things to deal with."],[412,546,"Run off with your mistress again?"],[638,700,"Say what you want."],[829,925,"If you leave now,"],[971,1140,"then you'll lose me and Annabel forever."],[1230,1280,"Alright then."],[1413,1455,"Fine."],[1497,1559,"Whatever you say."],[3019,3161,"Professor, you sure about this?"],[3199,3324,"Bridget, you're my best student."],[3395,3536,"I left all my notes about Anna"],[3536,3636,"in my private studio."],[3678,3933,"Please, keep pushing the Unicorn Project,"],[3991,4079,"until Anna's cured."],[4187,4300,"Professor, you spent your whole life"],[4300,4421,"caring for others,"],[4525,4671,"never once thought about yourself."],[4817,4884,"I'm a dad."],[4929,4996,"A husband."],[5025,5150,"I have responsibilities."]],"35":[[141,179,"Wait,"],[412,525,"I thought that you might need this."],[1088,12