to fuck you right here"],[1426,1514,"in front of your daughter?"],[1584,1626,"Mom!"],[1755,1843,"You think I'm weak."],[1872,2018,"That seizure was fake."],[2085,2173,"Surprise."],[2314,2377,"Dad!"],[2377,2431,"Dad!"],[2502,2652,"I actually hurt my dad!"],[2723,2873,"For a jerk like you!"],[2936,3011,"Charlie?"],[3040,3111,"Oh..."],[3111,3324,"Christin, you think you're a saint?"],[3432,3545,"You're just a slut."],[3586,3732,"You invited me to your house"],[3732,3820,"on my birthday."],[3912,4124,"You told him to give me your room."],[4124,4304,"You gave him claret!"],[4412,4671,"You broke his heart over and over again."],[4746,4900,"You destroyed your family"],[4900,5034,"with your own hands."],[5451,5526,"Mom,"],[5526,5613,"I regret it."],[5684,5901,"I shouldn't have treated Dad that way."],[5985,6043,"Regret?"],[6131,6177,"Oh..."],[6177,6272,"it's too late."],[6327,6443,"He's never coming back."],[6552,6660,"What do you mean?"]],"47":[[0,75,"He didn't tell you?"],[183,300,"He's dying."],[417,546,"I overheard the doctors."],[546,800,"All his organs are failing from radiation."],[988,1222,"He's got, what, maybe a month left?"],[1284,1413,"It's great, isn't it?"],[1584,1651,"Christin,"],[1705,1843,"you're gonna be mine anyway."],[1872,1981,"I'd rather die."],[1981,2085,"I'll kill you!"],[2160,2210,"Police!"],[2377,2519,"Isaac, you're under arrest"],[2519,2629,"for selling fake medicine."],[2665,2811,"You bitches have no one to blame."],[2811,2907,"But yourselves!"],[3328,3641,"Mom, what have I done to Dad?"],[3691,3795,"What have I done?"],[3841,3974,"Isaac, Charlie..."],[3974,4066,"why has it taken me so long"],[4066,4187,"to realize how crazy I've been?"],[4220,4304,"It was us."],[4350,4446,"We hurt Dad!"],[4517,4642,"I'm such a fool!"],[4758,4846,"I'm a jerk!"],[5125,5171,"Anna?"],[5230,5292,"Doctor!"],[5643,5709,"Why did you let her"],[5709,5814,"hurt the birthmark again?"],[5814,5939,"Just save her, please!"],[5964,6114,"Ma'am, we'll do our best."],[6114,6252,"But the Unicorn Project,"],[6277,6406,"the one that discovered the cure,"],[6418,6631,"recently lost a lot of data in a fire."],[6664,6823,"The lead researcher is still working on it,"],[6823,6973,"but the treatments effectiveness"],[6973,7036,"has been weakened."],[7077,7178,"Unicorn Project?"],[7553,7657,"That's my life's work!"]],"48":[[25,112,"Right, that's,"],[112,191,"I've heard, that's named"],[191,354,"after the lead researcher's daughter."],[479,596,"Wait, the medical expert,"],[596,763,"the one who's working on the Unicorn Project,"],[804,913,"is his name Charlie Clare?"],[1038,1138,"Yes, it is."],[1138,1184,"You know him?"],[1184,1251,"That's good."],[1363,1514,"Your daughter's condition"],[1514,1655,"is currently untreatable."],[1655,1851,"The Unicorn Project is just the only hope."],[2131,2177,"Ma'am?"],[2256,2360,"He's my husband."],[2473,2576,"I've destroyed everything"],[2576,2690,"and I think he hates me."],[3040,3123,"Stop it!"],[3720,3766,"Mom,"],[3841,3995,"this is God's punishment."],[4049,4287,"I wish my death could make Dad forgive me."],[4341,4479,"No, no, no, sweetie."],[4479,4625,"You're just a child."],[4625,4717,"This is my fault."],[4717,4838,"I'll take whatever punishment comes,"],[4838,4896,"but..."],[4896,5071,"I promise you, I will find your father"],[5071,5184,"and I won't let you die."]],"49":[[291,392,"I'm okay, Mom."],[462,571,"I'm lucky I got to be"],[571,750,"a part of the Unicorn Project."],[800,1001,"I'd probably be dead by now."],[1096,1245,"If I hadn't destroy his documents,"],[1245,1376,"you might be cured, but now..."],[1459,1601,"It's enough, Mom."],[1601,1730,"We messed up a lot."],[1730,1835,"We don't deserve it."],[1864,1964,"I owe you, Anna."],[1964,2052,"And I owe your dad."],[2052,2135,"I just..."],[2135,2264,"I hope it's not too late."],[2369,2439,"Mom,"],[2560,2736,"do you think we could still find Dad?"],[2840,3023,"I miss him so much."],[3319,3428,"That's his student."],[3478,3595,"She must know where your dad is."],[3707,3795,"Please wait!"],[3908,4029,"Why are you here?"],[4029,4162,"You know where Charlie is, right?"],[4162,4212,"Just..."],[4212,4283,"tell us where he is."],[4283,4429,"We've been looking for so long."],[4633,4713,"No comment."],[4888,4954,"We're sorry."],[4954,5021,"Please!"],[5059,5192,"We just wanna know the truth."],[5238,5280,"Just..."],[5372,5526,"let us see him one last time."],[5730,5868,"He has no words for you."],[5918,5989,"Please!"],[6056,6218,"We've realized our mistakes."],[6306,6439,"Just tell me where he is."],[6439,6631,"I have to tell him I'm sorry."],[6773,6902,"You'll never see him again."]],"50":[[0,129,"You will never see him again."],[158,191,"Why?"],[241,333,"Because he doesn't want to"],[333,450,"see you anymore."],[633,771,"He will never forgive you."],[771,846,"We can do it."],[846,975,"We can make up for it."],[975,1101,"Make up for it?"],[1101,1230,"You slandered him."],[1288,1480,"You forced him to donate blood."],[1480,1634,"You took everything from him."],[1726,1960,"And you destroyed his life's work."],[2039,2193,"How can you possibly make up for that?"],[2252,2470,"Bridget, I am sorry for everything I've done,"],[2470,2594,"and I don't deserve forgiveness."],[2594,2669,"but just"],[2706,2815,"let us see Charlie again."],[2815,2911,"Please!"],[3482,3616,"Organ failure?"],[3616,3732,"How could that be?"],[3732,3807,"You're lying."],[3807,4066,"How could his organs just fail for no reason?"],[4108,4191,"Because of you!"]],"51":[[16,116,"Because of you!"],[325,396,"Professor,"],[454,600,"he took on some risky research"],[600,709,"for Unicorn Project."],[779,1001,"He exposed himself to radiation,"],[1001,1159,"just to find a cure for your birthmark."],[1251,1401,"He could've retired in glory,"],[1455,1543,"become a famous"],[1543,1705,"nuclear medical researcher,"],[1743,1914,"but instead, he went back to the lab,"],[1914,2110,"and he worked himself to organ failure,"],[2173,2235,"for you!"],[2519,2727,"Have you ever cared about my health?"],[2727,2811,"Even once?"],[3224,3274,"Dad!"],[3486,3657,"Save Isaac or I'll kill myself!"],[3682,3732,"Anna?"],[4116,4316,"You threaten your own life over him?"],[4366,4508,"Yes or no?"],[5155,5221,"As you wish."]],"52":[[33,200,"So he did all that for me?"],[241,392,"Even though his body was so..."],[479,529,"weak?"],[617,684,"Hey, no."],[684,804,"This is all my fault, okay?"],[838,1030,"Please take us to Charlie, okay?"],[1101,1276,"Just let us apologize at least,"],[1276,1393,"even if he doesn't forgive us."],[1430,1601,"You don't get that chance!"],[1697,1847,"After everything you've done to him,"],[1956,2043,"it's too late."],[3040,3219,"He left something for you."],[3474,3541,"If I'm gone,"],[3666,3762,"give this to my daughter."],[3828,3866,"Okay?"],[4212,4283,"I understand."],[4533,4717,"He recorded it after the fire."]],"53":[[70,129,"Chris,"],[175,221,"Anna,"],[367,477,"this might be the last time"],[477,596,"I get to talk to you like this."],[725,829,"When you watch this,"],[829,888,"umm..."],[959,1092,"I might not be around anymore."],[1201,1255,"I was struggling"],[1255,1397,"when you decided to leave me, but..."],[1463,1530,"in the end..."],[1651,1755,"it was the only choice I had."],[1989,2102,"I always thought that"],[2143,2256,"we had a happy family"],[2323,2444,"and you always loved me."],[2660,2823,"You showed me what family means."],[3007,3140,"You taught me responsibility."],[3249,3299,"Oh, no,"],[3299,3420,"little monsters!"],[3420,3582,"Daddy is gonna catch you!"],[3582,3707,"You've got a good shot."],[3774,3916,"Oh, no!"],[3916,3999,"Oh, no!"],[4062,4229,"You left me so many sweet memories,"],[4295,4421,"my most precious treasures."]],"54":[[75,179,"But God's not fair."],[225,433,"Somehow I lost you both along the way."],[479,596,"But you don't need me anymore,"],[679,809,"so it's time to say goodbye."],[963,1013,"Anna,"],[1130,1292,"my beautiful unicorn baby girl."],[1413,1751,"Let's see if you got superpowers or not."],[1935,1997,"Hey!"],[2168,2227,"Back off!"],[2227,2318,"Do you want me to tell your parents"],[2318,2381,"about this?"],[2590,2694,"Hey, Anna."],[2840,2890,"Come here."],[3040,3311,"I always knew that your unicorn birthmark was"],[3353,3449,"very painful for you,"],[3490,3816,"and I would never dare promise anything"],[3862,3920,"until now."],[3953,4162,"The Unicorn Project was a success."],[4229,4300,"It worked."],[4354,4542,"It'll cure your neural skeletal"],[4625,4738,"birthmark and..."],[4808,4950,"and you're never gonna get bullied again."],[5860,5947,"Annabel Clare,"],[5993,6143,"I wish you happiness forever."],[6335,6506,"But that's the last thing that I can do for you."],[6548,6794,"Thank you for the good times,"],[6856,6948,"memories,"],[7069,7152,"the love."],[7278,7474,"But Christin, Annabel,"],[7557,7670,"if I were to choose again,"],[7849,7966,"I wouldn't have become family"],[7966,7999,"with you."]],"55":[[325,421,"Mom,"],[421,613,"if I got another chance,"],[613,788,"I treat Dad so much better."],[871,1101,"Charlie, your dad, he sacrificed so much"],[1101,1173,"for us, but..."],[1217,1584,"I trusted a criminal and hurt him over and over."],[1634,1760,"You've been punished, Mom."],[1835,1993,"Isaac took all our money,"],[2031,2118,"even our house."],[2273,2415,"Do you think Dad will come back?"],[2489,2606,"I don't know,"],[2606,2823,"but I am so sorry for letting this happen"],[2823,2857,"and..."],[2911,3019,"I lost my job,"],[3019,3098,"the family fortune"],[3098,3253,"and now we're drowning in debt."],[3724,3778,"Dad!"],[4204,4387,"Sorry, I got the wrong person."],[4499,4805,"This year's Nobel Prize is about to be announced,"],[4805,4946,"and scientists who have made"],[4946,5109,"extraordinary achievements in-"],[5109,5176,"Charlie?"]],"56":[[25,70,"Charlie?"],[229,329,"You know who that is?"],[471,533,"He's the greatest"],[533,646,"nuclear medical specialist"],[646,738,"from the 2020s."],[888,1167,"The greatest nuclear medical specialist?"],[1167,1251,"Absolutely!"],[1334,1430,"He led the Unicorn Project"],[1430,1493,"for his daughter."],[1589,1797,"He risked radiation exposure until basically"],[1797,1910,"all of his organs shut down."],[1972,2035,"And somehow,"],[2085,2152,"he survived."],[2214,2310,"He's my dad!"],[2381,2531,"I'm his unicorn daughter."],[2531,2694,"Okay, that's a ridiculous joke."],[2727,2790,"Is this live?"],[2790,2857,"Where is he?"],[3499,3557,"Dr. Clare,"],[3616,3687,"there are rumors that"],[3687,3782,"you've been exposing yourself"],[3782,3924,"to dangerous levels of radiation"],[3924,4016,"to finish this project."],[4016,4095,"Do you care to comment?"],[4262,4425,"Yes, that's true."],[4483,4758,"I knew the risks when going into this project,"],[4842,5021,"but I exposed myself to radiation,"],[5021,5155,"because someone very close to me"],[5155,5263,"was affected by this."],[5288,5438,"Dr. Clare, can you tell us more about"],[5438,5484,"your daughter?"],[5484,5668,"You must love her so much to take such"],[5668,5776,"risk for your research."],[5776,5918,"And your wife, how did you two meet?"],[6527,6648,"I don't have a family anymore."]]}