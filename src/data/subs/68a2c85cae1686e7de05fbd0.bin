{"1":[[567,646,"Isaac,"],[709,934,"you have such an interesting job."],[934,1113,"I wish my dad was cool like you."],[1213,1393,"I wish Isaac could be my dad!"],[1693,1893,"I gave up my nuclear medical research"],[1893,2047,"to take care of you two,"],[2047,2164,"but I'm left behind."],[2811,2902,"Charlie Clare,"],[2902,2990,"where have you been?"],[3053,3178,"Your head, what happened?"],[3607,3749,"He has a serious head injury."],[3749,3937,"We need to contact his family immediately."],[4225,4287,"The cake..."],[4354,4462,"Don't worry about the cake."],[4462,4571,"Worry about yourself."],[4571,4667,"Call your family."],[5000,5071,"Christin, I..."],[5071,5213,"Charlie, where are you?"],[5213,5321,"Come here, Isaac!"],[5321,5413,"Where the hell are you?"],[5413,5559,"Isaac traveled across the world"],[5559,5638,"to celebrate Anna's birthday"],[5638,5773,"and you can't even be here on time?"],[5773,5868,"Christin, I'm in the-"],[5989,6043,"Christin?"],[6118,6193,"When are they coming?"],[6352,6427,"They're not coming."],[6685,6961,"Oh, I tripped and fell on my way here."],[7228,7323,"Anna, look."],[7770,7874,"How clumsy!"],[8258,8429,"And you bought that cake again?"],[8429,8541,"Gross!"],[8541,8637,"It was your favorite."],[8637,8758,"That was years ago."],[8758,8925,"Look at what Isaac got me."],[8925,9084,"You should learn from him, okay?"],[9430,9563,"I almost got hit by a car"],[9563,9701,"to buy this cake for you,"],[9701,9859,"and you treat it like trash."],[9859,10039,"I've given so much to you all,"],[10039,10251,"but you just want to be someone else's wife,"],[10251,10435,"someone else's daughter."],[10435,10668,"Fine then, let me disappear completely."],[10935,11111,"Okay, you don't have to ever see this cake"],[11111,11169,"ever again."],[11745,11803,"Benjamin,"],[11861,12095,"I'm willing to participate..."],[12095,12178,"in that project."],[12178,12328,"Is this your final decision?"],[12328,12541,"This classified research project"],[12541,12691,"requires you to cut off all ties"],[12691,12854,"with the outside world,"],[12854,13046,"including Christin and Annabel."],[13046,13219,"I'm afraid they don't need me anymore."],[13254,13329,"I see."],[13329,13492,"The research people will pick you up"],[13492,13630,"in seven days."],[13630,13859,"You'll be remembered for your sacrifice."],[14126,14293,"You said it was just me and our daughter"],[14293,14376,"in your world."],[14406,14460,"I did it,"],[14493,14585,"but now I've become the one"],[14585,14698,"messing things up."],[15173,15348,"There's no point sticking around."]],"2":[[425,592,"There we go, sort of..."],[1096,1251,"Wow, this must have cost a fortune!"],[1359,1459,"Today's Thanksgiving."],[1509,1722,"Thank you, Isaac, for being with us today."],[1826,1981,"Mommy and I picked this tie for you."],[2777,2852,"Hold on, Dad!"],[3011,3236,"Why don't we take a family photo together?"],[3253,3303,"Aw..."],[3457,3532,"Here you go."],[3820,3903,"Come here, girls."],[3903,3953,"Come on."],[4412,4558,"Don't just stand there!"],[4558,4675,"Take a photo for us!"],[4720,4806,"Come on."],[5501,5634,"Enjoy your time."],[5634,5718,"I'm gonna head out."],[5747,5864,"Charlie!"],[5864,5976,"It's Thanksgiving!"],[5976,6068,"We have a guest."],[6381,6427,"Dad,"],[6477,6560,"here you go."],[6560,6669,"Happy Thanksgiving!"],[6735,6815,"Thank you!"],[7040,7161,"Chris, um..."],[7161,7365,"do we still have some of those freebie bags?"],[7449,7520,"Right?"],[7799,7862,"Yeah..."],[8133,8187,"Ah..."],[8512,8579,"It's fine,"],[8650,8733,"fits me well."],[8825,8892,"Thank you."],[8917,9075,"Charlie, stop being childish, okay?"],[9075,9180,"It's a gift."],[9180,9275,"We still care about you."],[9484,9542,"What?"],[9588,9805,"Did you expect your 10-year-old daughter"],[9805,9930,"to pay for a gift?"],[10122,10168,"That reminds me."],[10168,10293,"Can you transfer your paycheck?"],[10293,10364,"The bills are due."],[10452,10581,"Oh, I got it."],[10656,10735,"That's the only reason"],[10735,10885,"that you called me over here for."],[11040,11111,"Here you go."],[12157,12233,"Where are you going?"],[12383,12499,"I'm gonna go see my friends."],[12629,12787,"You're still hanging out with those lowlifes?"],[12946,13088,"I've taken care of this family"],[13088,13263,"for over 10 years."],[13367,13484,"I deserve some me time."],[13571,13642,"Charlie,"],[13742,13901,"I'll lock you out if you dare leave right now!"],[14109,14164,"Charlie!"],[14164,14218,"Dad!"],[14330,14476,"We're very, very mad!"],[14527,14639,"If you go,"],[14639,14781,"you're not my dad anymore!"]],"3":[[408,621,"You finally decided to show up"],[621,771,"after a whole night?"],[1343,1472,"You reek of alcohol!"],[1530,1651,"And where's the breakfast?"],[2164,2277,"Stop being a drama queen!"],[2277,2435,"Anna's hungry, so go cook!"],[2435,2565,"Yeah, I'm hungry!"],[2756,2915,"Why don't you ask Isaac to do it?"],[3028,3144,"You prefer him, don't you?"],[3319,3478,"How dare you talk like that?"],[3636,3757,"You've changed, Charlie."],[4162,4358,"Daddy, that smells great!"],[4429,4496,"Charlie,"],[4717,4867,"you're a master chef in the kitchen."],[4904,5042,"You always know exactly what we need."],[5088,5242,"My girls deserve the best."],[5926,6022,"Stay with us, okay?"],[6022,6214,"No more leaving on those research trips."],[6264,6477,"Dada, you make the best room."],[6477,6710,"I want you to stay here forever!"],[6898,7086,"I'll always be here for you,"],[7086,7178,"my princess."],[7290,7444,"And my queen, of course."],[7570,7707,"Chris, seriously?"],[7820,7907,"Who's changed?"]],"4":[[266,346,"Charlie,"],[346,492,"Isaac and I have an early show tomorrow-"],[663,754,"Wait..."],[754,921,"are you packing to make room for Isaac?"],[1084,1155,"You don't have to do that."],[1155,1238,"He's gonna take this room"],[1238,1363,"and I'm gonna bunk with Anna."],[1472,1522,"Isaac!"],[1797,1856,"Dad,"],[1856,2039,"where are you going with this suitcase?"],[2077,2114,"Oh,"],[2185,2306,"Isaac's staying over tonight"],[2306,2389,"and..."],[2389,2535,"your dad's gonna take the storage room."],[2665,2790,"The storage room?"],[2882,3057,"That room's disgusting!"],[3148,3532,"It's full of cobwebs, dust, junk."],[3532,3666,"There's not even a bed!"],[3753,3853,"Oh, Chris,"],[3853,3928,"come on!"],[3978,4170,"Charlie shouldn't have to sleep in there."],[4170,4308,"I'll take the storage room."],[4308,4416,"Wait, Isaac!"],[4533,4679,"You've got a show tomorrow."],[4742,4879,"You need to sleep well."],[4879,4959,"It's okay."],[4959,5071,"Dad could stay there."],[5113,5230,"It's just one night."],[5568,5634,"It's fine."],[5834,5914,"I'll go."]],"5":[[29,79,"Dad!"],[154,266,"You can come back"],[266,408,"as soon as Isaac leaves tomorrow."],[500,621,"It's fine."],[621,746,"That won't be necessary."],[1188,1292,"Finally!"],[1292,1547,"Daddy, we have our own home!"],[1547,1651,"We do!"],[1651,1793,"Hey, you haven't changed yet!"],[1793,1931,"Get off my clean sheets!"],[2081,2298,"Mommy, we have our own home!"],[2298,2377,"Our home."],[2377,2489,"The best in the world."],[3123,3219,"Leave those!"],[3324,3415,"Isaac needs them."],[3895,3991,"Whatever you say."],[5547,5588,"Here."],[5668,5768,"Five million dollars."]],"6":[[37,79,"Here."],[158,250,"Five million dollars."],[337,487,"Compensation for the research."],[871,1021,"I'll leave it for my daughter."],[1901,2064,"Dad, you look terrible!"],[2448,2594,"Oh, come on, let's go."],[3449,3661,"We used to be so happy."],[3795,3878,"Here we go!"],[3878,3941,"Ready?"],[4137,4320,"Best Dad ever!"],[4537,4662,"Grab the bubble!"],[6043,6156,"We're so lucky, Charlie."],[6264,6414,"Promise we'll always be this happy?"],[6414,6481,"Of course."],[7040,7111,"Chris..."],[7198,7257,"Anna..."],[7415,7549,"you'll be happy together."],[7786,7912,"Just not with me."]],"7":[[70,171,"We're on our way."],[221,342,"Happy birthday, Charlie!"],[392,458,"You ready?"],[546,613,"I'm ready."],[1359,1472,"Well, old friend..."],[1543,1659,"heading out tonight."],[1659,1730,"Guess..."],[1801,1897,"this is goodbye."],[4333,4512,"Did they actually remember?"],[5025,5105,"Charlie,"],[5130,5321,"it's Isaac's birthday today."],[5321,5380,"We're gonna have a little"],[5380,5434,"birthday party here."],[5434,5543,"You don't mind, right?"],[5543,5714,"Oh, and Linda and Faye are gonna"],[5714,5797,"bring Annabel."],[6003,6083,"Thanks."],[6844,6994,"Cheers!"],[7557,7670,"Oh, look at Isaac,"],[7670,7820,"still peeling shrimp for Christin"],[7820,7945,"after all this time."],[8124,8316,"Christen, be honest,"],[8316,8483,"feeling any sparks?"],[8483,8671,"Maybe a fire rekindling?"],[8796,8958,"You better pay him back appropriately,"],[8958,9009,"girl!"],[9009,9175,"Yeah, don't leave him hanging!"],[9884,9976,"What are you doing?"],[9976,10090,"My dad's right here."],[10385,10481,"Charlie, I..."],[10806,10881,"Wow..."],[10956,11036,"What a scene!"],[11090,11211,"Should we all clear the table,"],[11211,11361,"so you two can make out?"],[11695,11807,"Honey, I didn't mean..."],[11807,11874,"Don't worry."],[11961,12049,"You guys have fun."],[12116,12228,"I have stuff to do, anyway."],[12283,12391,"Wait, where are you going?"]],"8":[[4,112,"Where are you going?"],[112,262,"Where would you even go?"],[475,513,"Seriously?"],[513,592,"Are you ten?"],[592,742,"Is having a tantrum and storming out?"],[742,825,"It's ridiculous!"],[950,1034,"It's my fault."],[1076,1130,"Please..."],[1176,1272,"don't fight over me."],[1772,1851,"I'll make it up to you."],[2072,2118,"Go on,"],[2152,2193,"drink it."],[2231,2323,"I know you're allergic,"],[2360,2540,"but now you don't have a choice."],[2923,3040,"Come on, he's trying to do something nice!"],[3040,3111,"Just drink it!"],[3349,3516,"You know I'm allergic to claret."],[3611,3657,"Oh, come on."],[3657,3741,"It's not gonna kill you."],[3741,3837,"Just drink it already."],[4279,4429,"Dad, don't make a scene."],[4429,4558,"Just do it for me."],[4650,4733,"Okay, I'll do it."],[4825,4971,"I'll do it for you just this once."]],"9":[[1121,1188,"Are you okay?"],[1363,1438,"Come on, guys."],[1438,1589,"Let's not let him kill the vibe."],[1589,1664,"Hey, Isaac,"],[1714,1931,"I bet you and Chris still remember that"],[1931,2106,"\"Romeo and Juliet\" duet."],[2210,2381,"How about a little encore?"],[2381,2498,"Let's see that kiss again."],[2552,2694,"Yes, show us!"],[2719,2869,"We wanna see that stage chemistry"],[2869,2944,"up close."],[3019,3119,"Chris,"],[3119,3228,"don't be shy!"],[3228,3478,"You were on fire during that performance."],[3478,3628,"You guys are ridiculous."],[4462,4642,"\"Romeo, Romeo, Romeo..."],[4725,4825,"Here's drink."],[4825,4913,"I drink thee.\""],[6268,6443,"You're so weird tonight, Dad."]],"10":[[50,91,"Wait!"],[137,216,"Where's Dad?"],[400,458,"Charlie?"],[692,838,"His allergy meds?"],[838,1046,"He really is allergic to claret?"],[1084,1151,"He used to be."],[1151,1288,"I thought he'd grown out of it."],[1288,1372,"Oh my God!"],[1372,1488,"Where did he go?"],[3111,3174,"Mom!"],[3620,3745,"He left me his card."],[3816,4020,"It has $5 million on it."],[4020,4116,"He's gone."],[4287,4458,"I took out family portrait"],[4458,4612,"as your birthday gift to me."],[4708,4921,"It's his birthday today?"],[5221,5321,"He promised..."],[5422,5593,"he promised he would never leave us."],[5630,5718,"When did he go?"],[5718,5809,"Where is he going?"]],"11":[[746,892,"Why is Dad going to the car?"],[938,1034,"Where is he going?"],[1092,1192,"He'll be back in five minutes."],[1192,1242,"He's just..."],[1359,1443,"being dramatic."],[1488,1576,"He'll be knocking at the door,"],[1576,1701,"begging for forgiveness."],[2152,2239,"See?"],[2239,2323,"You were right."],[2427,2535,"He can't leave us."],[2535,2606,"He wouldn't."],[3357,3470,"I'm here to deliver this."],[3536,3720,"It's a Decree of Forced Divorce."],[3812,3916,"As of today,"],[3999,4141,"you're no longer legally connected to"],[4141,4279,"Dr. Charlie Clare."],[4437,4491,"No!"],[4683,4817,"This isn't real!"],[4817,4960,"Dad would never leave us!"],[5155,5246,"Get out!"],[5246,5351,"I don't wanna see you anymore!"],[5351,5505,"Anna and I are better off without you!"],[5801,5897,"I'm not leaving,"],[6014,6039,"okay?"],[6039,6143,"Wherever you two are,"],[6143,6252,"that's where I'll be."],[6306,6373,"Always."],[6802,6902,"It's okay."],[7799,7878,"It's okay."],[8158,8258,"Is he really gone?"],[8416,8495,"Ann?"],[8621,8675,"Dad!"],[8737,8825,"Please, don't go!"],[8825,8863,"Dad!"]],"12":[[37,125,"Please, don't go!"],[125,162,"Dad!"],[437,492,"Drive."],[838,975,"Bring my dad back!"],[1159,1213,"Dad!"],[1968,2035,"Charlie?"],[2385,2456,"Dad!"],[2819,2973,"Bring my dad back!"],[3461,3607,"He actually loved this."],[3770,3962,"I was so awful to him."],[4020,4187,"I thought he'd always be here."],[4483,4683,"Actually, you know, I'm sorry."],[4683,4742,"No."],[4900,5025,"We're not gonna lose your dad like this,"],[5025,5080,"okay?"],[5134,5255,"We'll go to his company tomorrow."],[5255,5338,"We'll bring him back."]],"13":[[429,479,"Ma'am,"],[479,583,"what are you doing here?"],[583,658,"My husband,"],[658,779,"Charlie Clare, was brought in last night"],[779,867,"for a project."],[950,1080,"Alright, hold on one second."],[1476,1526,"Sorry,"],[1526,1622,"there's no mention of Charlie Clare"],[1622,1697,"in the system."],[1697,1876,"You got the ID number or anything?"],[1919,2012,"Um..."],[2289,2423,"That's his driver's license."],[2540,2627,"It's not valid."],[2627,2756,"Doesn't show up anywhere in the system."],[2831,2923,"You're lying!"],[2923,3082,"My dad worked here for years!"],[3123,3265,"This is a restricted area, ma'am."],[3307,3395,"I gotta ask you to leave"],[3420,3449,"now."],[3449,3557,"But my husband does work here,"],[3557,3645,"if you just let me check your system."],[3645,3820,"Ma'am, I'm asking you to leave."],[4396,4458,"What's going on here?"],[4479,4599,"Sir, these two say they're here"],[4599,4758,"for their husband and dad,"],[4758,4850,"but there's no record."],[4938,5034,"That can't be!"],[5088,5363,"How does my dad's identity just disappear?"],[5422,5455,"Sir,"],[5513,5605,"my husband was brought in"],[5605,5705,"last night by your team."],[5780,5830,"Name?"],[5830,5926,"—Charlie Clare. —Charlie Clare."],[6206,6264,"This way."],[6644,6773,"Mrs. Clare,"],[6819,6890,"Annabel,"],[6923,7073,"I get that this is hard for you."],[7136,7269,"But I've gotta be honest,"],[7390,7640,"there's no Charlie Clare anywhere."],[7774,7882,"That's not true!"]],"14":[[12,141,"That's not true!"],[141,271,"He was here last night!"],[271,421,"Your guards took him!"],[454,592,"Give me my dad!"],[592,684,"Sorry, sir."],[684,729,"No,"],[746,800,"it's all right."],[875,913,"Look,"],[967,1247,"if Charlie Clare is real to you,"],[1276,1372,"then tell me."],[1443,1614,"when is your dad's birthday?"],[1614,1726,"His birthday..."],[1726,1864,"it was... um..."],[2085,2177,"It was yesterday."],[2531,2690,"It's Isaac's birthday today."],[2719,2786,"We're gonna have a little"],[2786,2840,"birthday party here."],[2840,2927,"You don't mind, right?"],[2957,3090,"Oh, come on, it's not gonna kill you."],[3090,3207,"Just drink it already."],[3207,3370,"Dad, don't make a scene."],[3370,3495,"Just do it for me."],[3495,3586,"Okay, I'll do it."],[3616,3757,"I'll do it for you just this once."],[4133,4346,"Sir, I understand why Charlie's upset"],[4346,4441,"with me, but..."],[4441,4537,"just let me see him once"],[4537,4738,"so I can apologize from the bottom of my heart."]],"15":[[41,400,"As I told you, Charlie Clare doesn't exist."],[538,625,"How could that be?"],[625,746,"He's my dad!"],[746,959,"Alright then, what does he like to eat?"],[1067,1172,"Let me think..."],[1714,1814,"Oh, burritos!"],[1814,1926,"My favorite!"],[2152,2231,"What's that?"],[2285,2439,"Sourdough toast,"],[2439,2527,"your mom's favorite."],[2598,2702,"Good morning, sweetie."],[2702,2865,"Just one more dish and then we can eat."],[2865,3007,"All of our favorites are here."],[3007,3103,"What else do we have to make?"],[3319,3453,"Let's just eat."],[3453,3628,"I've got lessons this afternoon."],[3849,3920,"Sure."],[4316,4454,"I don't remember right now."],[4525,4583,"Okay."],[4654,4800,"Who are his friends?"]],"16":[[497,567,"Chris!"],[637,737,"Guess what?"],[737,877,"My buddies invited me to golf."],[937,1101,"I love golfing and I haven't played in forever."],[1344,1471,"But don't worry."],[1471,1648,"I'll be home before dinner, I promise."],[1648,1701,"No."],[1731,1861,"No way am I gonna let you hang out those"],[1861,1978,"sketchy guys."],[2095,2252,"They're good guys, Chris."],[2392,2522,"Why don't you come meet them?"],[2749,2822,"I'm swamped."],[3553,3626,"See?"],[3707,4030,"You can't name his interests, his habits,"],[4030,4170,"nor his friends."],[4381,4738,"So what proof do I have that he is actually real?"]],"17":[[333,427,"Mom."],[427,543,"I'm hungry, Mom."],[787,837,"Go wash up."],[837,904,"I'll make something."],[4661,4794,"I wish for my sweetie"],[4831,5051,"to be as brave and wise"],[5091,5191,"as the unicorn."],[5342,5488,"Isaac wants to talk to you."],[5488,5608,"Hey, Annabel,"],[5652,5739,"it's Isaac!"],[5795,5965,"Just got a BMW!"],[5989,6079,"Wanna go for a ride?"],[6306,6406,"I'm not going!"],[6466,6589,"What do you want then?"],[6589,6756,"I can get a Porsche instead..."],[6756,6900,"I don't want any of that!"],[6900,7043,"I want my dad back!"],[7444,7497,"Annabel,"],[7560,7657,"don't listen to him."],[7711,7791,"I'll find your dad."],[7791,7887,"I promise."],[7941,8104,"Who needs that cheap jerk?"],[8144,8311,"I don't miss him one bit!"]],"18":[[680,764,"Shit!"],[1231,1291,"Mom!"],[1334,1411,"Anna?"],[1491,1581,"It's flooding!"],[1824,1900,"Um..."],[1971,2072,"I'll call your dad!"],[2732,2827,"Daddy's here."],[2827,2982,"It'll be fine, sweetie."],[3026,3129,"Don't be afraid."],[3140,3193,"Mm-hmm."],[3193,3329,"I'll fix the shower right now."],[3390,3490,"Honey, be careful!"],[3653,3710,"No worries."],[3710,3843,"Just take Anna downstairs."],[4674,4818,"I'll call a plumber."],[4864,4938,"No need."],[4938,5105,"It's just a shower head."],[5138,5258,"I can fix it myself!"],[5258,5333,"No..."],[5348,5421,"Sweetie."],[5421,5475,"Sweetie?"],[5682,5745,"Annabel?"],[5769,5842,"Annabel?"]],"19":[[283,316,"Faye,"],[316,380,"Annabel's hurt!"],[380,410,"It's urgent!"],[410,527,"Can you drive us to the ER?"],[527,710,"Sorry to hear that."],[710,890,"But it's raining out..."],[1211,1291,"Isaac?"],[1291,1338,"Annabel's hurt!"],[1338,1428,"Can you please..."],[1428,1544,"Chill, babe!"],[1558,1838,"I'm kind of busy and it's pouring outside."],[1838,2065,"Just put some ointment on her."],[2065,2242,"Kids bounce back fast, right?"],[2662,2819,"Charlie, her fever's getting worse."],[2852,3003,"We need to get her to the ER now!"],[3163,3226,"But it's pouring."],[3226,3303,"Maybe we should wait."],[3303,3396,"There's no time!"],[3423,3480,"Chris, it's fine."],[3480,3546,"I got it."],[3546,3626,"Come here, Anna."],[4037,4147,"Okay. It's okay."],[4147,4207,"It's okay."],[4207,4260,"It'll be fine."],[4307,4414,"Okay, okay."]],"20":[[938,1030,"Anna, come on."],[1030,1155,"This is the burrito your dad left for you"],[1155,1238,"in the fridge."],[1238,1338,"I hate him!"],[1426,1476,"Come on, sweetie."],[1476,1568,"At least try it."],[1605,1689,"I said no!"],[1689,1785,"I hate him!"],[2802,2852,"Dad!"],[2902,2957,"Dad!"],[2990,3048,"Don't go!"],[3090,3136,"Anna?"],[3249,3324,"Anna?"],[3415,3499,"Uh. Doctor?"],[3841,3978,"The bleeding won't stop."],[3978,4058,"If it keeps up,"],[4058,4175,"it could be life threatening."],[4254,4412,"She had this birthmark since she was born."],[4412,4500,"Can we remove it?"],[4529,4688,"It's connected to nerves in her skull,"],[4688,4838,"so surgery's too risky."],[4859,5038,"The only option is to target the tissue"],[5038,5176,"with radioactive drugs"],[5176,5301,"for precise removal,"],[5301,5505,"but nuclear medicine isn't advanced"],[5505,5588,"enough yet."],[5588,5647,"What can we do?"],[5647,5743,"How can we save her?"],[5872,6006,"I'll use conservative treatment"],[6006,6147,"to protect her nerves."],[6147,6277,"But if she gets hit there again,"],[6277,6377,"it could be deadly."],[6377,6435,"Clear?"],[7136,7253,"Annabel's mom?"],[7403,7511,"Why didn't you tell us about her"],[7511,7653,"medical history or allergies?"],[7653,7795,"It's really dangerous!"],[7795,7870,"I didn't know."],[7870,7999,"Her dad handles all that."],[7999,8212,"I've never seen such an irresponsible parent."],[8212,8308,"Call her dad."],[8308,8479,"She needs proper care tonight."],[8675,8733,"Anna?"]],"21":[[450,504,"Anna?"],[1618,1830,"Daddy, aren't you tired?"],[1910,2018,"Daddy's superman."],[2056,2168,"Daddy doesn't get tired."],[2214,2444,"Will you protect me like this forever?"],[2531,2606,"Of course!"],[3749,3828,"Dad?"],[3828,3899,"Charlie?"],[4145,4387,"You're a nuclear medicine researcher, right?"],[4537,4617,"I respect your work."],[4617,4708,"I really do."],[4708,4825,"It's important."],[4825,5075,"But you have a constant exposure to radiation."],[5075,5272,"It puts your organs at risk."],[5313,5409,"You know this."],[5618,5826,"Professor, I can try to shut down the project."],[5889,6085,"It's just for a birthmark that nobody cares about."],[6131,6318,"Bridget, I have to save Anna."],[6544,6623,"Thank you..."],[6748,6844,"but I can't quit."],[6881,6940,"I don't want to."],[6940,7136,"Sir, I really suggest...."],[7340,7415,"Let's go."],[7640,7695,"Wait, wait!"],[7695,7928,"Professor Charlie, this is worse than I thought."],[8099,8266,"Your organs are shutting down."],[8662,8750,"How much time?"],[9280,9342,"One year?"],[9471,9551,"No..."],[9609,9709,"One month."],[10189,10247,"Alright."],[10322,10410,"That's enough time."],[12153,12262,"Don't go, Dad!"]],"22":[[20,145,"Don't go, Dad!"],[145,212,"Please!"],[271,437,"I want you to make me burritos!"],[437,658,"I want you to fix my shower head!"],[700,892,"I'm not the one who can't live without you!"],[892,1042,"But... I forgive you!"],[1284,1372,"Charlie..."],[1484,1676,"Charlie, just come home, okay?"],[1676,1797,"Like you did five years ago!"],[1797,1893,"Stay with us."],[2127,2293,"Charlie, she's only 10."],[2293,2385,"We need you."],[2423,2544,"You're gonna leave us alone?"],[2590,2673,"Dad!"],[2952,3157,"That's so ugly,"],[3157,3345,"like a little duckling!"],[3345,3536,"What's with that triangle?"],[3536,3870,"Are you an alien or something?"],[3870,4204,"Let's see if you got superpowers or not!"],[4433,4483,"Hey!"],[4550,4612,"Back off!"],[4612,4733,"Do you want me to tell your parents?"],[4984,5071,"Anna, Anna."],[5238,5505,"Daddy, why do we have this birthmark?"],[5580,5784,"I don't like it!"],[5784,5905,"Hey, it's okay."],[6064,6118,"You know what?"],[6147,6243,"It makes you special,"],[6272,6373,"like a unicorn."],[6414,6539,"You like unicorns, don't you?"],[6573,6656,"Really?"],[6727,6911,"Yes, of course!"],[6911,7102,"My baby girl is a little unicorn."],[7620,7786,"Honey, if you don't like it,"],[7828,7978,"I'll help you get rid of it, okay?"],[8817,8954,"Sorry, I... I can't."],[9075,9134,"Why?"]],"23":[[100,358,"It's an ultra-confidential project."],[821,896,"I just can't."],[984,1092,"Why the hell won't you come home?"],[1092,1155,"I've apologized."],[1155,1251,"What more do you want?"],[1251,1280,"Ma'am!"],[1280,1463,"The professor is too weak"],[1463,1580,"for this kind of pushing."],[1735,1789,"Who is she?"],[1943,2035,"She's my student."],[2298,2448,"A young pretty student."],[2448,2577,"That's why you won't come home, huh?"],[2577,2652,"No!"],[2652,2856,"Ma'am, I am just the research assistant"],[2856,2940,"to the professor."],[2940,3061,"No, you're a homewrecker."],[3107,3207,"Chris, stop!"],[3457,3507,"Dad!"]],"24":[[45,112,"Dad!"],[450,617,"What the hell is going on here?"],[900,1001,"Just like I thought,"],[1055,1201,"you left your wife alone"],[1201,1363,"to be with your young mistress?"],[1459,1551,"What a jerk!"],[1551,1689,"Stop with the lies!"],[1726,1893,