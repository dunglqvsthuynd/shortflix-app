1,513,"your new captain to the Boston Howlers."],[513,775,"As you know, Tom is a legend."],[775,909,"And this is his last season"],[909,1071,"before retirement."],[1071,1197,"So let's give the hero"],[1197,1393,"the respect he deserves."],[1463,1597,"Well Tom,"],[1597,1701,"you’ve met everyone?"],[1747,1839,"Not everyone."],[2527,2731,"It's nice to meet you,"],[2731,2823,"Coach."],[2957,3107,"Seriously?"],[3107,3253,"He ghosted me,"],[3253,3328,"and now he's pretending"],[3328,3436,"he doesn't know me?"],[3574,3716,"Pleasure's all mine,"],[3716,3828,"Mr. Wright."],[3828,3978,"She never called even though I left"],[3978,4079,"her my number."],[4145,4258,"And now she's acting like"],[4258,4375,"we never met?"],[4425,4608,"Mr. Wright,"],[4984,5125,"finally!"],[5171,5267,"Hold this."],[5388,5689,"Aren't you a sight for sore eyes!"],[6051,6151,"Cindy Kraft."],[6151,6389,"My father owns this team."],[6552,6652,"I was hoping that"],[6652,6852,"I could give you a"],[6852,6973,"personal tour."],[7002,7115,"I'll show you eh-"],[7186,7390,"everything there is to see."],[7390,7657,"Tom's moved on. Why wouldn't he?"],[7657,7836,"He can get any girl he wants."],[7836,8028,"You mean nothing to him, Kate."],[8049,8179,"Please excuse me."],[8971,9084,"Who the hell is that?"],[9084,9180,"And why does Tom seem to"],[9180,9338,"care about her so much?"],[9388,9542,"Got to do something about it."],[9542,9730,"Tom Wright belongs to me."],[9930,10047,"Hey, Coach!"],[10114,10214,"Coach! Wait up! Hey!"],[10493,10681,"You forget easily don’t you, Coach?"]],"10":[[87,262,"You forget easily, don't you, Coach?"],[475,567,"I-"],[800,1017,"I have no idea what you're talking about."],[1017,1151,"Of course you don't."],[1180,1288,"You have something that"],[1288,1430,"belongs to me."],[1480,1685,"And- Well,"],[1755,1981,"I was hoping I could get it back."],[2932,3040,"Don't give him the power"],[3040,3144,"over you again, Kate."],[3144,3365,"He ghosted you, left you alone"],[3365,3470,"in a hotel room after"],[3470,3611,"he got what he wanted."],[3716,3832,"I don't think so."],[3870,4116,"Not until you give me back"],[4116,4212,"you took"],[4283,4383,"from me."],[4700,4896,"Oh, so you do remember."],[5367,5505,"Remember you?"],[5634,5818,"I fell for you, Tom."],[5893,6064,"And now we have a baby together."],[6427,6539,"So-"],[6539,6819,"After a month, is there anything-"],[6944,7144,"anything"],[7144,7278,"that you want to tell me?"],[7878,8016,"Tom. I'm-"]],"11":[[20,75,"I'm-"],[75,216,"Coach Turner!"],[283,542,"My office! Now!"],[1584,1676,"Ms. Kraft?"],[1893,1956,"Can I help you?"],[2377,2515,"Kate Turner."],[2515,2677,"She's fast."],[2677,2819,"What a fine new assistant coach"],[2819,2932,"you've got here, Coach Harvey."],[2932,3082,"She's just an assistant."],[3082,3190,"She doesn't even deserve"],[3190,3328,"to share an office with me."],[3328,3470,"I would never hire a broad"],[3470,3641,"to coach the boys,"],[3641,3799,"but the board forced me."],[3841,3937,"Two years ago we had"],[3937,4154,"another lady assistant coach."],[4258,4375,"She sat right here"],[4454,4608,"at your desk,"],[4608,4804,"until I got her fired"],[4804,4884,"by spreading a rumor that"],[4884,5055,"she might be pregnant."],[5113,5301,"You know, sometimes all it"],[5301,5584,"takes is a whisper in the right ear."],[5659,5776,"I need this job."],[5805,5889,"No one else can know"],[5889,6018,"about my baby. Not now!"],[6097,6222,"You look nervous, Kate."],[6264,6564,"Are you hiding something?"]],"12":[[0,129,"Ms. Kraft,"],[129,237,"I'll make sure there's nothing"],[237,312,"to whisper about."],[312,462,"Don't you Ms. Kraft me?"],[462,567,"You're just some nobody"],[567,700,"who's coaching some crappy"],[700,763,"college team."],[763,930,"Who did you sleep with to get this job?"],[930,1146,"I got this job fair and square."],[1146,1251,"In fact, I interviewed with"],[1251,1359,"your father himself."],[1359,1488,"You can call him and ask him."],[1593,1685,"Honey,"],[1685,1901,"my father may own this team,"],[1901,2114,"but I run this rink."],[2260,2394,"Here's a million dollars."],[2452,2719,"Quit this job and get out of here."],[2719,2802,"Now!"],[2907,3078,"Take it, Turner."],[3078,3165,"You would never make that"],[3165,3370,"even if you sold yourself."],[3528,3732,"This job is my dream."],[3787,3941,"I worked really hard to get here,"],[3941,4112,"and I'm not giving it up."],[4900,5201,"You stupid bitch!"],[6523,6639,"I know how to get a parasite"],[6639,6756,"out of my ice rink."],[7132,7207,"You're fired!"],[7628,7749,"Hey!"],[7866,8012,"Don't you dare touch her!"]],"13":[[925,1059,"Tom, I-"],[1059,1205,"I was just talking to Coach Harvey here."],[1205,1359,"We were talking about Kate's career,"],[1359,1509,"and she got mad, and she tried to"],[1509,1601,"attack me. I’m-"],[1609,1772,"Ms. Kraft’s right, Tom."],[1835,1972,"Kate doesn't deserve to be here."],[1972,2131,"She's not qualified."],[2173,2285,"Not qualified?"],[2344,2452,"Kate was the captain of her"],[2452,2569,"college team and the league's"],[2569,2756,"best defender for four straight years."],[2781,2915,"She'd be a pro player right now"],[2915,3032,"if it wasn't for an injury."],[3069,3257,"You're a star player, Tom."],[3294,3465,"You don't have to defend this-"],[3524,3670,"this nobody."],[3883,3999,"You know what, Coach?"],[3999,4112,"You're right."],[4112,4304,"I am the star player,"],[4304,4429,"which means"],[4429,4608,"you don't get to tell me what to do."],[4608,4763,"You come at Kate one more time,"],[4763,4859,"and I'm off the team."],[4967,5038,"Go ahead and picture"],[5038,5150,"this headline."],[5150,5309,"Coach loses star player"],[5309,5451,"on the very first day."],[5497,5622,"That would end your career."]],"14":[[83,316,"I'm sorry. Please!"],[316,508,"I promise it'll never happen again."],[558,629,"Good."],[675,871,"Now get out! Both of you."],[946,1071,"But Tom, this is"],[1071,1213,"Coach Harvey's office."],[1213,1288,"Yeah."],[1338,1455,"Not anymore."],[2977,3178,"This is Coach Turner's office now."],[3453,3716,"And you, Ms. Kraft."],[3795,4012,"One more misstep, and you have to"],[4012,4158,"explain to your father"],[4158,4308,"why I left his team."],[4333,4437,"Please- Please don't leave."],[4437,4571,"We'll give you whatever you want."],[4779,5025,"I'm so glad you said that."],[5025,5213,"I want"],[5409,5555,"Coach Turner-"]],"15":[[70,371,"I want Coach Turner"],[400,784,"to give me a personal tour"],[784,942,"of the arena."],[2135,2360,"Fuck!"],[2673,2761,"Why is Tom Wright"],[2761,2998,"so interested in that worthless skank?"],[3624,3770,"And that concludes your private tour,"],[3770,3891,"Mr.-"],[3912,4087,"Captain Wright."],[4149,4254,"I'll let you explore on your own"],[4254,4333,"from here."],[4429,4629,"So, are you always this formal"],[4629,4796,"with players or just the ones"],[4796,4909,"that you slept with?"],[4909,5009,"Excuse me?"],[5009,5134,"Oh, okay."],[5134,5271,"So we're back to pretending like"],[5271,5376,"nothing happened between us"],[5376,5509,"that night six weeks ago."],[6026,6135,"You think I can forget you"],[6135,6285,"after tonight?"],[6468,6614,"Look Tom,"],[6614,6765,"you are the most sought after"],[6765,6873,"NHA star, okay?"],[6873,6994,"And I'm your coach."],[7040,7215,"This is our careers we're talking about."],[7215,7315,"So to protect that,"],[7315,7394,"we need to stay away"],[7394,7515,"from each other."],[7536,7674,"Okay, fine."],[7745,7995,"I will stay away,"],[8028,8329,"if you answer one question."],[8512,8662,"Why didn't you call me?"]],"16":[[20,141,"Why didn't you call me?"],[1764,1885,"I left you my number"],[1885,2039,"so you could find me."],[2064,2248,"You vanished without a word."],[2248,2406,"I wanted to find you."],[2452,2502,"I have to go."],[2502,2552,"Oh!"],[2790,2844,"Oh my God!"],[3028,3140,"I'm so sorry."],[3140,3228,"It's your old injury."],[3228,3374,"I'm fine, really."],[3599,3741,"Let me look at it."],[4416,4529,"You just want to see me naked,"],[4529,46