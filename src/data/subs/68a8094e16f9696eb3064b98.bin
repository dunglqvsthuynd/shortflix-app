,"Here's a check for a million dollars."],[2164,2398,"Get out of my stepson's house"],[2398,2590,"and life forever."],[3641,3862,"I'm not leaving Tom’s side."],[3862,4087,"He's the father of my child."],[4141,4312,"You don't have a choice, bitch."],[5038,5284,"Do whatever you want to me."],[5284,5397,"Strip me naked!"],[5397,5505,"But you're not going to buy me"],[5505,5580,"with your money."],[5580,5764,"You stupid girl!"],[5764,5905,"You really think that I would share"],[5905,6072,"my stepson's fortune with you"],[6097,6314,"and your bastard child?"],[6385,6648,"Tom's money belongs to me."],[7440,7603,"I know how to shove that money"],[7603,7716,"down your throat."],[8008,8158,"No, no, no."],[8158,8312,"I'm pregnant with Tom's child."],[8312,8475,"It’s- It's his child."],[8475,8625,"Please don't. My baby!"],[9296,9480,"What the fuck is going on here?"]],"42":[[909,1026,"You! Come here."],[1480,1576,"Now get the fuck out of here"],[1576,1768,"before I kill you."],[3165,3399,"She attacked me because I wouldn't"],[3399,3520,"give her money."],[3536,3632,"I wonder whose bastard"],[3632,3887,"baby she's carrying, Tom."],[4270,4350,"It'll hurt Tom"],[4350,4483,"if he found out from someone else that"],[4483,4675,"this baby is his."],[4675,4804,"I need to tell him now."],[4804,4959,"Tom, I'm-"]],"43":[[29,283,"No, Kate. You don't need to explain."],[316,513,"I already pulled the security footage."],[588,742,"The daughter of a team owner"],[742,888,"assaulting a coach."],[946,1138,"I sent this to your father already."],[1138,1322,"And if you so much as look at Kate"],[1322,1468,"or her baby ever again,"],[1597,1793,"I will post it online for your followers"],[1793,1897,"to devour."],[2064,2302,"Did Tom just say her baby?"],[2302,2435,"He doesn't know Kate's pregnant"],[2435,2548,"with his child."],[2615,2886,"And I'll make sure he never will."],[2919,3103,"And you, Evelyn!"],[3849,3958,"I'm cutting off your allowance"],[3958,4074,"for the next three months."],[4074,4195,"No. No."],[4275,4483,"No. No, the Black- No! No-"],[4825,5013,"And if you so much as look at Kate"],[5013,5146,"one more time,"],[5146,5384,"I will cut you off forever."],[5467,5638,"That won’t be necessary, Tom."],[5697,5834,"We’re leaving."],[6981,7232,"I- I heard"],[7232,7361,"what you said earlier."],[7411,7590,"You did?"],[7703,7866,"I'm pregnant with Tom’s child."],[7866,8024,"It's- It's his child!"],[8024,8112,"Please don't. My baby!"],[8762,8996,"You're a brave woman, Kate."],[8996,9200,"And you're gonna be a great mom."],[9396,9672,"How I wish this was my baby"],[9672,9930,"and I could be a great dad too."],[9964,10185,"Tom, you’re the-"],[10585,10685,"Hello?"],[10685,10935,"Miss Turner, it's your brother."],[10935,11165,"Get to the hospital now."],[11394,11494,"I have to go."]],"44":[[684,809,"Miss Turner, your brother needs"],[809,942,"surgery now."],[942,1130,"You'll have to pay the $20,000"],[1130,1242,"before we can operate."],[1259,1559,"Sorry, but we can't wait any longer."],[1568,1739,"I- I'll figure it out."],[1943,2118,"20,000?"],[2139,2318,"I've been saving for Kevin's surgery"],[2318,2506,"but I don't have half that much."],[2506,2677,"How am I gonna get the money?"],[3691,3807,"Coach Turner,"],[3807,3962,"you've been busy!"],[3962,4154,"Pregnant with the player's child."],[4154,4308,"And now this?"],[4308,4487,"Your lover in a hospital bed."],[4658,4771,"Coach Turner, is it true that"],[4771,4859,"you're pregnant by a player"],[4859,4917,"on your team?"],[4917,5034,"Is this man your lover?"],[5055,5146,"He's my brother!"],[5205,5384,"Sure. But you know what the tabloids"],[5384,5480,"are gonna print?"],[5505,5668,"Coach sleeps her way through team"],[5668,5893,"to save secret boyfriend."],[5955,6097,"Tell us who the father is!"],[6097,6185,"Tell us who you slept with"],[6185,6302,"to get this coveted coaching job!"],[6648,6790,"Stop! Please stop!"],[6798,6906,"Show us the bump, Coach!"],[7023,7115,"I'll show it."],[7390,7478,"Hey!"],[7540,7716,"Get your filthy hands off her!"]],"45":[[20,200,"Get your filthy hands off of her."],[358,558,"Tom Wright?"],[558,804,"The biggest NHA superstar himself?"],[804,971,"What- What are you doing here?"],[1113,1259,"Give me that camera."],[2281,2431,"You'll be hearing from my lawyers."],[2431,2635,"And both of your careers are over."],[2635,2769,"And if I ever see Kate's photo"],[2769,2877,"on any tabloid,"],[2877,2990,"I will hunt you down"],[2990,3165,"and I will shred you to pieces."],[3244,3374,"You understand?"],[3374,3495,"Now get the hell out of here."],[3495,3553,"Sorry, Mr. Wright."],[3553,3653,"Sorry, Mr. Wright, we're leaving."],[3653,3770,"Miss Turner."],[3883,4045,"Tom, it was Kate who called"],[4045,4183,"the paparazzi."],[4183,4366,"She's using the publicity"],[4366,4512,"to fund her lover's treatment."],[4554,4617,"I warned you"],[4617,4750,"to stay away from her, Cindy."],[4750,4938,"But clearly, words don't work on you."],[4959,5017,"Security!"],[5017,5109,"No."],[5459,5588,"Kate's using you"],[5588,5755,"to build a cozy nest for her lover"],[5755,5901,"and their illegitimate child!"],[5960,6202,"I did all of this for you, son!"],[6202,6339,"Stepson!"],[6339,6414,"Isn't that what you always"],[6414,6514,"call me, Evelyn?"],[6514,6694,"And Kate's not the one using me."],[6694,6881,"It's you who has always used me"],[6881,6994,"as your personal ATM."],[7052,7148,"Get them out of here."],[7148,7207,"No."],[7207,7319,"And if they ever show their face"],[7319,7474,"this hospital or any hospital for"],[7474,7586,"that matter, I want you to"],[7586,7716,"feed them to the cops."],[8274,8420,"Don't worry."],[8521,8625,"I won't let anything happen"],[8625,8750,"to your baby's father."],[8804,8917,"Kevin's my brother."],[8917,9079,"You are my baby's father."],[9142,9309,"Tom, Kevin’s my-"]],"46":[[41,208,"Tom, Kevin’s my-"],[208,258,"Miss Turner,"],[258,467,"we just got Kevin's latest blood reports"],[467,571,"and we need to rush him"],[571,684,"into surgery right now."],[684,917,"But you must pay the $20,000 upfront"],[917,1017,"before we can do that."],[1055,1180,"Doctor, I don’t- -Look Doctor,"],[1180,1359,"surely that isn't necessary, okay?"],[1393,1522,"Miss Turner is a very good friend"],[1522,1601,"of mine."],[1609,1739,"Tom Wright!"],[1739,1897,"Kate, why didn't you tell me that you"],[1897,2022,"knew the Tom Wright?"],[2022,2239,"He's our hospital's biggest donor."],[2239,2456,"He practically owns the establishment."],[2464,2606,"Please hurry. I want the best team"],[2606,2769,"to operate on Kevin right away."],[2769,2894,"Absolutely!"],[2894,2990,"Anything that you say."],[3028,3165,"Preparation for surgery."],[3165,3207,"Okay."],[3557,3795,"I promise I'll pay you back, okay?"],[3837,3899,"What you did-"],[3899,4095,"No, you don't owe me anything, Kate."],[4095,4362,"No money, no explanation, okay?"],[4362,4508,"Now come on, let's get you home."],[4508,4608,"Get you some rest."],[4608,4754,"You come back tomorrow,"],[4754,4909,"Kevin will be awake,"],[4921,5113,"and will be healthy, okay?"],[5113,5205,"I promise."],[5292,5376,"Come on."],[5376,5551,"I can't live with Tom anymore."],[5551,5734,"Not after what happened today."],[5805,5955,"Tell us who the father is."],[5955,6043,"Tell us who you slept with"],[6043,6218,"to get this coveted coaching job."],[6360,6514,"I'm not coming with you, Tom."]],"47":[[29,175,"I'm not coming with you, Tom."],[396,479,"If I live with him,"],[479,638,"it’s only a matter of time until the press"],[638,742,"finds out that I'm pregnant with"],[742,850,"his baby."],[850,1038,"It'll take his focus off the season."],[1038,1188,"His last season."],[1188,1359,"I can't do this to him."],[1493,1609,"Your fame,"],[1697,1751,"it follows"],[1751,1935,"me and my baby everywhere."],[1993,2206,"I can't live with you anymore."],[2206,2364,"I'm moving out today."],[2406,2631,"Look Kate,"],[2631,2840,"I can handle the truth."],[2940,3103,"I know that you don't want to"],[3103,3182,"live with me anymore"],[3182,3345,"because you want to be with him,"],[3486,3645,"your baby's father."],[3728,3937,"You are the father of my child."],[3937,3999,"The man you saw"],[3999,4145,"is my brother, Kevin."],[4325,4404,"You're right."],[4567,4729,"I want to be with him,"],[4813,4979,"the father of my baby."],[5213,5313,"Well, then you shall have"],[5313,5422,"what you want."],[5734,5822,"But you're not moving out"],[5822,5910,"of the apartment."],[6064,6172,"I am."],[6172,6218,"What?"],[6218,6348,"No, Tom, I can't-"],[6348,6519,"It’s not up for debate, Kate."],[6581,6731,"I have another place in the city."],[6731,7032,"I'll go there and you take the apartment."],[7173,7378,"I want you and your baby to be safe"],[7378,7636,"with or without me."],[7912,8016,"Okay?"],[10143,10222,"Tom, wait!"]],"48":[[1559,1801,"Your surgery was successful, Kev."],[1956,2085,"Soon you'll be fit enough to run"],[2085,2260,"after a little niece or nephew."],[2302,2481,"If the Tom Wright hadn’t intervened,"],[2569,2686,"the doctors would never perform"],[2686,2786,"that surgery."],[3048,3215,"Kate, it's his kindness"],[3215,3328,"that saved me."],[3395,3595,"His kindness made me fall for him."],[3724,3812,"Kate,"],[3903,4054,"he's the father, isn't he?"],[4362,4475,"He's the one you told me about"],[4475,4600,"those two months back,"],[4679,4729,"the one you had that"],[4729,4929,"unforgettable night with,"],[4929,5142,"the one you lost your heart to?"],[5255,5397,"Tell him you love him, Sis!"],[5397,5526,"Tell him it's his baby."],[5526,5693,"I can't, okay?"],[5693,5951,"Tom is a legend with big dreams"],[5951,6122,"and I'm a nobody who's just pregnant"],[6122,6227,"with his baby, okay?"],[6227,6402,"You know, he can feel sorry for me,"],[6402,6519,"but he's never going to love me."],[6519,6606,"Nonsense, Kate."],[6606,6819,"Tom loves you."],[6906,7057,"I have proof."],[7253,7399,"Proof?"]],"49":[[87,183,"Tom wouldn't have told me to"],[183,387,"give this to you if he did not love you."],[771,838,"He came by"],[838,905,"while you were talking to"],[905,1076,"the doctors after my surgery."],[1146,1313,"He came in and he was like,"],[1313,1447,"tell her this is from you."],[1534,1614,"But does he think I'm"],[1614,1755,"your boyfriend or something?"],[1864,2052,"And I tried to clarify, but he just left"],[2052,2156,"in a hurry."],[3449,3624,"Shopping for a fan girl?"],[3691,3828,"For someone special."],[3978,4087,"I'm going to ask her to be my date"],[4087,4216,"at the NHA Gala."],[4416,4483,"Tom wanted me"],[4483,4696,"to be his date at the NHA Gala."],[4779,4988,"He's not ashamed to be seen with me."],[8512,8621,"Your pregnancy will be the"],[8621,8762,"special feature at tonight"],[8762,8946,"NHA Gala, Kate."],[8946,9146,"And afterward, Tom will be too"],[9146,9246,"embarrassed to even be"],[9246,9346,"seen with you."]],"50":[[1501,1647,"Get ready, Mrs. Wright."],[1647,1822,"Show's about to begin."],[2002,2260,"Why am I looking for her?"],[2260,2406,"Kate is probably with her lover"],[2406,2560,"right now."],[2577,2748,"I must stop thinking about her."],[4354,4425,"Is that?"],[4425,4600,"Oh shit!"],[4600,4725,"Coach Turner!"],[4742,4833,"Hot!"],[5676,5793,"She looks even more stunning"],[5793,6018,"in that dress than I had imagined."],[6414,6581,"My stepson"],[6581,6773,"cannot find out that"],[6773,6944,"worthless assistant coach"],[6977,7198,"is carrying his baby!"],[7244,7444,"No way am I sharing my fortune"],[7444,7791,"with that low class whore!"],[7811,7945,"Tom will never know."],[8416,8579,"And soon, Kate's baby will be"],[8579,8717,"gone forever."],[9125,9250,"I'm going to go take care of this"],[9250,9413,"right now."],[10110,10293,"I need to tell you something."],[10422,10606,"I'm-"]],"51":[[75,212,"I'm pregnant with- -Tom!"],[287,437,"There you are!"],[437,542,"The Federation needs you"],[542,696,"for the photo, son."],[729,834,"Let's go."],[946,1084,"Good job, Mrs. Wright."],[1084,1213,"And now it's time to separate"],[1213,1438,"that skank from your stepson"],[1438,1547,"forever."],[1697,1830,"Soda."],[1830,1972,"Orange."],[3862,3937,"Hey!"],[3970,4070,"Waiter,"],[4179,4346,"take this to Coach Turner,"],[4346,4471,"the one in blue."],[4896,4975,"Closer."],[5217,5309,"Smile."],[5609,5734,"Act natural."],[6352,6519,"Your poor baby will be gone"],[6519,6744,"before Tom finds out it was his, Kate."],[6906,7019,"Orange soda,"],[7019,7148,"to refresh you, Miss."],[7374,7490,"Enjoy yourself."],[8087,8170,"Cheers."]],"52":[[16,120,"No, Kate! Don't!"],[709,809,"Don't drink this."],[809,921,"Tom, what the hell?"],[1505,1572,"You!"],[1643,1735,"Come here."],[2056,2193,"I want you to tell everyone here"],[2193,2352,"where you got this drink."],[2773,2882,"Really, Cindy?"],[2882,3019,"You drugged Kate's drink?"],[3837,3978,"Ugh, eww..."],[3978,4116,"Tom, you're mistaken."],[4141,4229,"Kate's the one who's been"],[4229,4404,"manipulating you."],[4433,4579,"I'm cutting you off, Evelyn."],[4625,4721,"You're on your own now."],[5226,5467,"Tom, you save the baby."],[5559,5655,"Our-"]],"53":[[383,521,"Damsel in distress"],[521,725,"always has her hero to rescue her."],[742,892,"If only you knew the thing"],[892,1059,"she was keeping from you, Tom."],[1117,1267,"I must tell Tom now that he's the"],[1267,1359,"father of my baby"],[1359,1522,"before Cindy ruins everything."],[1755,1864,"What is it, Kate?"],[1910,2039,"I've been meaning to tell you-"],[2039,2131,"I think we've heard enough"],[2131,2248,"from you already, bitch."],[2556,2656,"That's enough!"],[2886,2998,"Dad!"],[3028,3157,"You're an embarrassment."],[3157,3361,"You're leaving this country tonight,"],[3361,3495,"and you're not coming back"],[3495,3620,"until you've learned your lesson."],[3741,3853,"You bitch!"],[3991,4074,"First you trapped Tom"],[4074,4158,"and then you turned my dad"],[4158,4208,"against me?"],[4208,4396,"I haven't trapped anyone, Cindy."],[4396,4504,"I got this coaching job"],[4504,4612,"on my own merit."],[4717,4867,"Oh, really?"],[5038,5226,"She lied her way into this job"],[5226,5309,"with this."],[5484,5605,"My pregnancy report?"],[5663,5743,"She's been pregnant this"],[5743,5855,"whole time and she's been lying"],[5855,5905,"about it."]],"54":[[45,208,"I couldn't tell anyone because"],[208,471,"Cindy got the last female coach fired"],[471,546,"by spreading a rumor"],[546,709,"about her pregnancy."],[842,992,"You disgust me."],[1092,1380,"As far as today, you will have no role,"],[1484,1789,"no voice, and no association"],[1789,1922,"with anything"],[1922,2052,"bearing the Howlers’ name."],[2264,2373,"See you bitch!"],[2439,2552,"The owner of the Howlers team"],[2552,2702,"just fired you himself."],[2702,2865,"Your child's gonna end up poor and"],[2865,3048,"pathetic, just like its mother."],[3378,3536,"I was talking to you,"],[3536,3616,"bitch!"],[3983,4283,"My team does not discriminate."],[4379,4625,"Coach Turner is an excellent coach."],[4767,4904,"I interviewed her myself."],[4996,5113,"Oh, maybe you should tell everyone"],[5113,5276,"who the father is, Kate!"],[5276,5351,"Go ahead!"]],"55":[[12,246,"You don't have to answer that, Kate."],[246,325,"You don’t owe any explanation"],[325,437,"at anyone here."],[588,838,"Not even to the father, Tom?"],[996,1163,"You know the rules, Coach."],[1163,1305,"Fraternizing with a player"],[1305,1455,"and having his baby?"],[1589,1755,"Now that's a violation."],[2177,2260,"Kate's pregnant"],[2260,2419,"with a player's baby?"],[2527,2598,"Kate,"],[2694,2827,"what the hell is she talking about?"],[2827,2940,"Tom, I-"],[2994,3103,"You know what? Eh-"],[3103,3236,"Just excuse us, everyone."],[3236,3361,"Kate and I have to talk about"],[3361,3511,"something in private."],[4550,4733,"Say something, please."],[5184,5484,"Tell me that Cindy is lying, Kate."],[5534,5755,"Tell me that it's a lie."],[5755,5943,"That you’re having a child"],[5943,6151,"with another player on my team."],[6222,6318,"After everything"],[6318,6410,"we've been through, he's"],[6410,6569,"still questioning if I slept with"],[6569,6710,"another player?"],[6823,7057,"Cindy wasn't lying, Tom."],[7545,7678,"Jesus Christ!"],[7953,8099,"I want to know who it is."],[8191,8425,"I want to know who else you're fucking!"],[8454,8700,"No, Tom. Listen."],[8896,9117,"My baby's father"],[9255,9496,"is you, Tom!"]],"56":[[50,350,"You are the father of my baby!"],[400,554,"Our baby!"],[554,671,"What the fuck are you talking about?"],[671,742,"It's impossible."],[742,842,"The doctor said that I can't-"],[842,1130,"No, you can have kids, okay?"],[1130,1251,"Even though the doctor is giving you"],[1251,1359,"almost 0% chance"],[1359,1468,"because of your injury,"],[1468,1618,"that night when we met,"],[1618,1701,"despite everything,"],[1701,1939,"we made our baby, Tom."],[2598,2690,"What?"],[3090,3157,"Why do you-"],[3157,3274,"Why don't you say something?"],[3274,3390,"Why- Why don't you tell me"],[3390,3478,"you've been pregnant"],[3478,3586,"this whole time with our child"],[3586,3691,"and I had no idea?"],[3691,3887,"Because you vanished!"],[3924,4074,"That night in the hotel room,"],[4074,4295,"you've left me by myself, okay?"],[4329,4521,"And for me, it wasn't a mistake."],[4521,4733,"But maybe it was for you."],[4804,4950,"No, no. I never vanished."],[4950,5117,"I- I left to protect you."],[5180,5301,"The paparazzi, they were there."],[5301,5509,"They- They were going to find us."],[5509,5584,"Your coaching career"],[5584,5676,"would have been over before"],[5676,5797,"it even started."],[5930,6231,"Tom, even if that's true,"],[6277,6664,"you're a star, okay?"],[6773,6931,"I’m nobody."],[7194,7361,"No one wants to see people like"],[7361,7474,"us together."],[7645,7716,"They’re just gonna think"],[7716,7786,"that I trapped you"],[7786,7924,"and then having this baby."],[7924,8008,"Just like you thought"],[8008,8120,"that I slept with a player"],[8120,8199,"a minute ago."]],"57":[[112,287,"I don't give a damn about what"],[287,442,"the whole world thinks."],[508,784,"I only care about you and me."],[813,896,"Tom-"],[896,967,"Hey!"],[1172,1393,"You mean the world to me."],[1543,1739,"And I'm not letting you go this time."],[1835,1926,"But Tom-"],[2239,2444,"Our baby needs us."],[2515,2640,"both of us."],[3545,3670,"Are you okay?"],[3762,3912,"It's all I ever wanted."],[3987,4091,"Yeah."],[4279,4408,"I’ve loved you from the first time"],[4408,4521,"I saw you."],[4683,4758,"I’ve loved you through"],[4758,4904,"the ups and downs."],[5025,5167,"I couldn't stop loving you"],[5167,5309,"even when I thought you were"],[5309,5476,"having someone else's baby,"],[5605,5876,"even when I believed"],[5876,6097,"that you didn't love me back."],[6222,6356,"I never stopped."],[6873,7040,"And I know now"],[7132,7298,"that I want to spend the rest"],[7298,7599,"of my life loving you"],[7599,7795,"and our baby."],[8170,8375,"Forever and always."],[9313,9505,"I’ve always loved you, Tom."],[9605,9818,"You’re the only man I've ever desired."],[11369,11457,"Wait-"],[11632,11886,"You sure you can handle me, Coach?"]],"58":[[25,325,"Once I start, I won't be able to stop."],[425,625,"I want you, Captain."],[625,792,"All of you."],[6439,6556,"I can't wait to see her face"],[6556,6656,"when Tom dumps her."],[6656,6969,"Oh! My stepson hates liars."],[7019,7152,"I wonder if she'll even"],[7152,7307,"come out alive."],[9597,9718,"Now do you believe us"],[9718,9793,"when we say that she"],[9793,9930,"honey trapped you, Tom?"],[10176,10260,"You don't need to protect"],[10260,10402,"the skank, Tom."],[10464,10564,"I'll find the player that"],[10564,10681,"she's fraternize with,"],[10681,10831,"and I'll have them both fired."],[10965,11207,"In that case, Coach,"],[11248,11365,"you'll have to fire me."]],"59":[[16,79,"I am the player"],[79,150,"that Coach Turner is"],[150,250,"having a baby with."],[1317,1438,"That's a direct violation"],[1438,1547,"of team policy."],[1618,1735,"You're the team captain!"],[1735,1856,"You know that!"],[1914,2052,"Kate seduced Tom!"],[2052,2193,"She used her position of power"],[2193,2419,"to- to trap a star player."],[2419,2594,"No, that's not what happened."],[2594,2719,"Enough!"],[2781,2965,"You're fired, Kate!"],[2965,3111,"Effective immediately!"],[3307,3440,"If Kate is out,"],[3470,3561,"then I'm out too."],[3561,3803,"No, Tom! It's your last season!"],[3862,3978,"There's nothing more important"],[3978,4229,"to me than you and the baby, Kate."],[4808,5030,"Sorry to disappoint you, Walter."],[5176,5347,"But I hereby resign as the captain"],[5347,5476,"of the Howlers."],[6264,6377,"You sure about this, son?"],[6435,6564,"It's your final season."],[6660,6773,"There is nothing I care"],[6773,6861,"about more right now"],[6861,7065,"in this life than Kate."],[7378,7444,"You should be ashamed"],[7444,7557,"of yourself."],[7615,7862,"You just cost an NHA star his career."],[7899,8116,"I think we should let Tom's fans"],[8116,8291,"decide what her punishment will be."],[8495,8671,"She's ruining the Howlers season!"],[8671,8808,"She doesn't deserve to be"],[8808,8879,"among us."],[8879,8983,"Throw her out!"]],"60":[[83,171,"Even Tom can't"],[171,325,"save you from them, Kate."],[325,467,"You better run for your life!"],[721,959,"We're talking about you, dumbass!"],[1680,1914,"And the evil stepmother too."],[2852,2948,"Coach Harvey,"],[2948,3082,"didn't you say that pregnant women"],[3082,3174,"can't coach?"],[3211,3319,"What about it?"],[4012,4116,"This even better!"],[4116,4262,"What the hell is going on?"]],"61":[[312,575,"I’m glad to see the NHA Chief is here"],[575,692,"to settle this matter."],[700,813,"Let me be clear."],[813,942,"I don't step into team affairs"],[942,1080,"unless something truly historic"],[1080,1167,"has happened."],[1284,1359,"We were talking about"],[1359,1501,"one of our brightest athletes"],[1501,1647,"and a capable young coach"],[1647,1835,"who made a mistake."],[1914,2035,"Damn right they did!"],[2035,2198,"And now they're going to pay for it!"],[2277,2464,"I wasn't finished."],[2464,2610,"They made a mistake,"],[2610,2802,"falling in love."],[2802,2961,"Not breaking any rules."],[2961,3128,"Not bribing any players."],[3128,3307,"Not endangering anyone."],[3495,3616,"There has been no abuse"],[3616,3712,"in this situation."],[3712,3870,"No protocol broken."],[3920,4099,"This is not an offense."],[4099,4362,"This is a relationship."],[4362,4562,"And handled more professionally"],[4562,4754,"than the leadership around them."],[4875,5109,"And speaking of leadership,"],[5109,5255,"Coach Harvey,"],[5292,5417,"I'm firing you."],[5705,5839,"And appointing Kate Turner"],[5901,6068,"as the Howlers new head coach."],[7090,7257,"That is, if she's still willing."],[7486,7590,"I'm willing."]],"62":[[291,367,"Cool."],[433,592,"The fans are better."],[829,921,"As if."],[1222,1343,"And Tom,"],[1343,1455,"I hope this changes"],[1455,1572,"your decision too."],[1672,1851,"The Howlers would be honored"],[1851,2056,"if you stay on as their captain."],[2644,2748,"I’m in."],[2836,2932,"Can't really quit a team"],[2932,3003,"that's got the best coach"],[3003,3136,"in the business now, can you?"],[3570,3724,"Well then! This new season is gonna be"],[3724,3928,"a hell of a lot more interesting."],[4483,4779,"Welcome back to the Ivy Cup Final."],[4783,4904,"This is it, folks!"],[4904,5067,"One last goal could seal"],[5067,5184,"the championship for"],[5184,5296,"the Boston Howlers!"],[5438,5601,"Come on guys, you got this!"],[6619,6827,"Oh! No! Was that?"],[7002,7186,"Oh! Jesus! God!"],[7186,7407,"Oh no no- Not now!"]],"63":[[141,266,"Howlers Captain Tom Wright"],[266,392,"with possession."],[392,617,"He's known for straight goals,"],[617,771,"never an assist in a final."],[838,938,"This is"],[938,1130,"his moment!"],[1255,1484,"An assist is like a message."],[1484,1680,"I see you. I trust you."],[1680,1797,"Now finish the job."],[2114,2364,"And Captain Wright dishes it off."],[2815,2994,"It's a goal!"],[2994,3224,"Howlers win the Ivy Cup."],[3224,3382,"This one's historic."],[3382,3532,"Making them the first team"],[3532,3712,"with a female head coach to win!"]],"64":[[2581,2794,"I missed it, didn't I?"],[2836,2965,"It's okay."],[3407,3707,"She's ready to meet her parents."],[4225,4400,"Guess what?"],[4400,4491,"Your daddy scored"],[4491,4629,"the winning goal tonight."],[4909,5113,"Actually,"],[5113,5230,"I passed."],[5426,5613,"Just like you taught me, Coach."],[5805,6018,"Well, it took me a whole season, but-"],[6085,6239,"I finally coached your heart."]]}