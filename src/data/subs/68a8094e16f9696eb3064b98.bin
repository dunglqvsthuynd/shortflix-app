{"1":[[550,796,"I'm pregnant with Tom Wright's baby?"],[796,946,"The most famous hockey player"],[946,1080,"in the US?"],[4750,4925,"What a shot!"],[4925,5092,"Legendary Tom Wright"],[5092,5259,"scores the victory goal"],[5259,5476,"for the Fangs!"],[5476,5618,"But which team will he pick for his"],[5618,5801,"final season before retirement"],[5801,5960,"still remains a mystery."],[5960,6206,"This is far from over, folks!"],[6393,6577,"God! Tom Wright can body check me"],[6577,6685,"any day."],[6698,6844,"In your dreams."],[6844,6981,"He's bedded every top model"],[6981,7132,"and heiress."],[7132,7228,"Can’t believe this is gonna be"],[7228,7328,"his last season."],[7361,7590,"I'm gonna miss that fine view!"],[7590,7816,"Ten goals, zero assists?"],[7816,7899,"Come on, guys!"],[7899,8049,"Not that fine of a view."],[8329,8533,"Look at his game trail, okay?"],[8533,8662,"Tom Wright missed every opportunity"],[8662,8762,"to assist."],[8762,8950,"Tom is a legit star, Kate."],[8950,9092,"He knows what he's doing!"],[9092,9355,"Yeah! If you think you can do better,"],[9355,9530,"why don't you show us?"],[9634,9743,"Gladly."],[10047,10172,"If Tom Wright focus more on"],[10172,10435,"the puck than his fans,"],[10435,10527,"he might actually earn"],[10527,10652,"that last name of his."],[11286,11411,"Oh-"],[11411,11611,"An assist is sort of like a message."],[11799,11845,"Kate!"],[11941,12045,"Kate- -She’s dead."],[12183,12374,"I see you. I trust you."],[12374,12508,"Now finish the job."],[13221,13609,"Wow! Should I just retire now or"],[13609,13784,"am I allowed to get a drink first?"],[14143,14268,"Oh my God!"],[14268,14435,"Tom Wright?"],[14435,14685,"Did I just offend the most popular,"],[14685,14960,"most loved NHA player to his face?"]],"2":[[50,158,"Mr. Wright, I didn't-"],[158,204,"No, no no-"],[275,408,"I'm intrigued."],[408,579,"Please"],[579,759,"finish your comment,"],[759,884,"Coach."],[942,1134,"Well, I-"],[1255,1388,"I think if you thread those passes,"],[1388,1530,"you could really"],[1768,1914,"elevate your game."],[2056,2198,"Oh, you do?"],[4612,4779,"I need to speak with your manager."],[4779,4942,"No, please! Don't have me fired, sir."],[4942,5100,"I really need this job."],[5100,5163,"My brother-"],[5163,5321,"Fired?"],[5376,5526,"I want to ask him if I'll let you"],[5526,5626,"clock out early so I can"],[5626,5768,"buy you a drink."],[5997,6106,"And you can share everything"],[6106,6339,"in this notebook with me."],[6619,6802,"Shoot. I-"],[6877,7073,"I forgot my wallet at the hotel."],[7165,7294,"Don't fall for it, Kate."],[7294,7499,"He's teasing you for free drink."],[7678,7857,"You don't trust me, do you?"],[8216,8333,"Take this as my collateral."],[8333,8483,"I go get my wallet."],[8550,8637,"Wait!"],[8637,8917,"Is this the 2015 Stanley Cup ring?"],[9004,9129,"You know your hockey, Coach."],[9280,9396,"I'll be back."],[9459,9605,"Wait for me."],[9751,10051,"Why is my heart racing?"],[10197,10326,"Stop it, Kate!"],[10326,10460,"Tom Wright is famously"],[10460,10556,"an f*-boy."],[10952,11002,"Do you want me to"],[11002,11111,"tell you some my bet is-"],[11136,11227,"Here you go!"],[11227,11311,"Enjoy, gentlemen."],[11515,11711,"Damn lady,"],[11711,11866,"it’s one fine looking ring."],[11866,12049,"A gift from your sugar daddy, huh?"]],"3":[[83,162,"With all due respect,"],[162,337,"it’s none of your business."],[392,458,"Please let go."],[458,563,"You're hurting me."],[1263,1580,"So, now you want to play nice huh?"],[1614,1693,"I'll tell you what."],[1718,1810,"How about an exchange"],[1810,1972,"for this precious ring back?"],[3153,3249,"You bitch!"],[3607,3728,"Don't you dare!"],[4308,4375,"God!"],[4608,4750,"You're all banned from every arena"],[4750,4867,"in the country."],[4867,4967,"And if you drag your ass"],[4967,5121,"back to any game ever again,"],[5121,5226,"trust me,"],[5226,5334,"I'll know."],[5334,5426,"And you'll think what happened"],[5426,5626,"here was a fucking picnic."],[5626,5722,"Am I clear?"],[5722,5876,"Yes. -Yes, Mr. Wright."],[5876,6001,"We’re sorry, Mr. Wright."],[6277,6373,"Go!"],[6544,6660,"And you."],[7032,7161,"You’re not working here anymore."],[7228,7336,"Let's go."],[7336,7432,"What-"],[7507,7678,"Excuse me,"],[7678,7782,"Mr. Wright?"],[7816,7891,"Tom!"],[7891,7982,"Whoa!"],[7982,8083,"I can't just quit."],[8083,8233,"I need that job."],[8299,8487,"I'm saving up for the surgery, doctor."],[8487,8629,"I'm gonna make it happen."],[8858,8963,"Trust me."],[8963,9092,"You don't need a bar job."],[9221,9505,"This is the job that you need."],[9551,9734,"To be a pro hockey coach."],[10005,10155,"You have talent, Kate."],[10218,10318,"Being a pro coach"],[10318,10447,"has been my dream."],[10447,10548,"He doesn't even know me,"],[10548,10764,"and yet, he sees me."],[10827,11073,"Look, I'm in town tomorrow"],[11073,11194,"for an interview."],[11194,11323,"To choose the last team I play with"],[11323,11444,"before I retire."],[11490,11615,"And once I do,"],[11749,11840,"I want to help you become a"],[11840,11974,"pro coach, Kate."],[12203,12287,"Wow! I-"],[12533,12716,"Thank you, Tom."],[13350,13488,"You know, you're not really who I"],[13488,13601,"thought you were."],[13747,13893,"Interesting."],[13993,14151,"I didn't know you thought about me."]],"4":[[942,1238,"So, looks like it's about to rain,"],[1238,1405,"and my flight's"],[1405,1551,"tomorrow morning."],[1551,1743,"God! I wish I could kiss her right now."],[1789,2006,"I wish you would kiss me right here."],[2181,2314,"Well, if your hotel's nearby,"],[2314,2481,"there's still time to"],[2519,2644,"discuss my notes."],[2823,3073,"For research purposes, that is."],[3224,3390,"Oh, I would very much like to do"],[3390,3632,"some research."],[4904,4971,"Oh my God!"],[5030,5163,"I'm all wet!"],[5484,5655,"I mean, from the rain."],[5655,5718,"I'm-"],[5718,5801,"Wet."],[6147,6339,"Yeah, I can see, Coach."],[7849,7995,"The-"],[7995,8083,"Bathroom and the towel are"],[8083,8174,"to your right."],[1021