{"1":[[240,390,"Okay."],[466,702,"\"The Bather,\" Rococo style"],[702,927,"is a sensual art style."],[974,1117,"Seen in the strokes,"],[1141,1264,"erotically charged."],[1638,1845,"Boucher painted sin in pink,"],[1931,2121,"turning voyeurism into fashion..."],[2298,2439,"But tell me, class,"],[2542,2742,"what is true decadence?"],[3360,3478,"Now I'm sure many of you"],[3478,3627,"have been keeping up with the midterms"],[3627,3840,"and assignments I have been submitting."],[3867,4027,"Very good. Yes!"],[4060,4157,"Progression."],[4210,4347,"Very good, Miss Langford."],[4347,4417,"Nice."],[4484,4651,"Is it art itself?"],[4708,4938,"Or is it the way it's been packaged"],[4951,5105,"for the audience?"],[5151,5335,"Art doesn't just explore."],[6896,7080,"Guides our gaze."],[7080,7474,"Shapes our..."],[7474,7567,"desire."],[7667,7867,"Oh my god, I'm so sorry."],[7921,8094,"All right."],[8224,8343,"Class is over."],[8343,8475,"Desire doesn't wait."],[8935,9072,"No, not you, Miss Langford."],[9072,9265,"Please. Take a seat."],[9386,9552,"Now, please."],[10333,10430,"Come on."],[10518,10615,"Hand it here."],[11157,11297,"Really?"],[11818,11961,"Is this what you truly desire?"],[12078,12173,"I..."],[12399,12612,"I'll be keeping this sketch."],[12749,12959,"Maybe I'll talk about it with you later,"],[12959,13123,"about your"],[13123,13260,"artistic choices."],[13890,14074,"[phone ringing]"],[14634,14761,"Hey, what's up?"],[14781,14961,"It's six fifteen now!"],[14974,15075,"Don't forget,"],[15075,15248,"tonight is your engagement party"],[15248,15338,"and you are meeting your"],[15338,15555,"fiancé's father for the first time."],[15555,15719,"You have to make a good impression"],[15719,15819,"or else..."],[15829,15979,"But we've only been dating for two weeks"],[15979,16199,"and he hasn't even proposed."],[16236,16396,"At least I don't think he did."],[16403,16603,"You have twenty minutes to get to the rose garden."],[16623,16810,"Be late and I will bury you"],[16810,16900,"next to the roses."]],"2":[[343,513,"Oh my god."],[530,640,"Did you crawl here?"],[640,834,"Do you even know how late you are?"],[850,950,"Listen."],[957,1104,"-You listening? -Yes, I'm listening."],[1104,1364,"Darius is a seven-figure fantasy"],[1364,1584,"wrapped up in abs and privilege."],[1591,1808,"This deal dies without daddy's blessing."],[1808,1885,"Okay?"],[1885,2088,"Okay, where even is Darius?"],[2115,2202,"He's not even here."],[2202,2335,"He's more late than I am."],[2335,2455,"Yeah, well, when your daddy is a"],[2455,2732,"world-famous painter, punctuality is optional."],[2782,2876,"Okay, did you hear that"],[2876,3009,"his dad's last painting sold for"],[3009,3171,"ten million dollars?"],[3256,3586,"Every girl in town is after Westley's son."],[3660,3713,"Okay."],[3737,3960,"Wait, did you just say Westley Winslow?"],[3960,4204,"Like, Professor Westley Winslow?"],[4204,4280,"You are listening!"],[4280,4407,"Yes, go."],[4954,5058,"[knock knock]"],[5141,5245,"Come in."],[5542,5682,"Professor Winslow."],[5739,6019,"Well, if it isn't the quiet, talented artist"],[6036,6256,"that paints naked portraits."],[6309,6529,"Did you come here to be my live model or..."],[6539,6673,"did you want me to be yours?"],[6733,6826,"That sketch..."],[6863,6940,"Give it back to me."],[6966,7237,"Not until I'm done perfecting the more..."],[7237,7349,"heroic proportions."],[7454,7624,"Your son is my fiancée."],[7694,7834,"You can't do this."],[7854,8124,"And as my fiancée's father,"],[8178,8314,"it's inappropriate for you to"],[8314,8410,"keep that sketch."],[8475,8605,"My son has a hundred women"],[8605,8792,"wanting to come into his bed every day."],[8822,8958,"Ten of which already have."],[8982,9212,"This picture of you two"],[9222,9315,"proves nothing."],[9419,9599,"Taking someone's personal artwork"],[9599,9746,"is a violation."],[9830,9973,"No, Miss Langford."],[9994,10095,"You,"],[10130,10293,"drawing"],[10300,10408,"your teacher exposed"],[10408,10620,"without his permission,"],[10627,10760,"that's the violation."],[11214,11414,"Just like I'm doing right now."],[11451,11591,"You see,"],[11650,11767,"this..."],[11941,12156,"is what violation"],[12270,12369,"feels like."]],"3":[[140,200,"My sketch!"],[206,337,"Touch it and you fail."],[1114,1461,"I'm sorry that I sketched you naked"],[1461,1618,"without your permission."],[1628,1901,"It just kind of happened."],[1901,2035,"It was an accident."],[2165,2315,"An accident?"],[2432,2539,"You fantasizing about your"],[2539,2649,"professor naked in class"],[2649,2849,"was an accident, then..."],[2886,2992,"What about now?"],[3243,3426,"Is this an accident?"],[3757,3850,"Honey, I'm sorry."],[3850,4007,"I'm running so late."],[4007,4187,"Got caught up with a uh..."],[4187,4298,"...work thing."],[4298,4391,"I'll be there soon."],[4451,4671,"You really are my son's fiancée."],[4851,4984,"I told you."],[5762,5895,"How original."],[5895,6049,"Another woman after the family fortune."],[6059,6224,"You two really deserve each other."],[6282,6349,"No."],[6880,6923,"Go."]],"4":[[93,183,"Oh, Darius,"],[183,306,"it's such an honor for Mia"],[306,420,"that you chose her."],[427,610,"Well, she is a lovely girl."],[650,762,"Let's hope she's enthusiastic"],[762,832,"under the sheets"],[832,967,"as she is at brunch, you know?"],[1007,1194,"She'll be enthusiastic, alright?"],[1695,1945,"Oh, here you are, darling."],[3613,3850,"I feel a little nervous."],[4057,4160,"Weird."],[4214,4341,"Here, put this on."],[4361,4477,"Close your eyes."],[4494,4634,"Don't look, don't think."],[4644,4735,"Everything will be easier"],[4735,4868,"if you just obey."],[4881,5031,"Okay, sweetheart?"],[5111,5211,"I raised you for twenty years"],[5211,5336,"to make me money."],[5338,5468,"Don't blow it."],[5515,5645,"Unless he asks."],[5672,5785,"Here you go."],[5859,6022,"Yeah, yeah, have a little."],[6136,6259,"There you go."],[6272,6356,"Yum, yum."],[6846,6990,"You ready?"],[7023,7223,"Oh yes, you are."],[7407,7537,"If I can't see it,"],[7537,7670,"then it's not real."],[7670,7844,"Just pretend it's a dream."],[7844,8004,"It's only a dream."],[8124,8294,"Oh, Darius."],[8294,8465,"Where is your father?"],[8465,8655,"We haven't seen each other for so long,"],[8655,8840,"and I have something for him."],[8925,9105,"I haven't seen him, but Mia."],[9122,9329,"Mia, on the other hand..."],[9362,9486,"Yeah, Mia!"]],"5":[[296,650,"(breathing heavily)"],[757,1047,"No, no, no, don't take it off."],[1157,1287,"It feels so good."],[1368,1528,"I feel so good."],[1528,1631,"I've never felt"],[1631,1778,"like this before."],[1849,2026,"I want it so bad."],[2228,2395,"Are you real?"],[5165,5452,"Now I feel hot and unusual."],[5512,5709,"Like I don't know where I am."],[5792,5855,"Is this what"],[5855,5989,"the first time feels like?"],[6383,6583,"Are you sure you want this?"],[6589,6870,"Tonight, I'm yours."]],"6":[[900,1077,"Happy engagement, my love."],[1898,1968,"Professor Winslow!"],[1975,2095,"What are you doing here?"],[2238,2369,"You thought I was Darius,"],[2375,2475,"didn't you?"],[2672,2786,"This was a mistake,"],[2786,2839,"Professor Winslow."],[2846,2952,"Let's just pretend it never happened."],[2952,3056,"No, no, no, you said"],[3056,3179,"I felt so good."],[3390,3695,"I know, but you're my fiancé's father."],[3695,3843,"This isn't right."],[3845,4000,"Was it what you imagined?"],[4134,4307,"Mia, babe, you in there?"],[4447,4541,"Mia?"],[4541,4651,"Stop it!"],[4651,4844,"I'm gonna be your daughter-in-law."],[4971,5118,"Then call me by my actual name."],[5168,5288,"Call me daddy."],[5328,5375,"Don't!"],[5465,5689,"Mia, baby, you in there?"]],"7":[[93,230,"Mia!"],[523,784,"Where are you?"],[1004,1097,"Oh!"],[1097,1221,"There you are."],[1231,1394,"Oh, Darius!"],[1401,1528,"I was just in here"],[1528,1658,"having a bath."],[1911,2080,"You know, I was calling out to you"],[2080,2275,"and why didn't you answer?"],[2422,2636,"And shouldn't we be celebrating"],[2636,2816,"our engagement together?"],[2866,2989,"You're drunk, honey."],[2989,3126,"We can celebrate later."],[3383,3709,"I'll meet you in our bedroom."],[4300,4487,"Go! He's not gone yet!"]],"8":[[93,233,"Darius?"],[643,784,"Maybe next time."],[1264,1451,"Oh, look how perfect"],[1451,1591,"you look together!"],[1644,1771,"Oh, I'd hate you if I didn't"],[1771,1898,"like looking at you so much."],[2032,2155,"Darius?"],[2278,2449,"I trust that you are"],[2449,2622,"satisfied with Mia's performance?"],[2622,2826,"I wasn't myself last night."],[2826,2979,"I will make up for it tonight."],[3707,3770,"Father!"],[3900,3967,"Westley!"],[3967,4167,"No, please, that won't be necessary."],[4234,4414,"I was looking for you last night."],[4414,4507,"I couldn't find you."],[4507,4671,"We haven't seen each other"],[4671,4841,"for twenty years."],[4904,5021,"You're keeping count?"],[5198,5331,"Now that I look at you, I guess"],[5331,5468,"it has been twenty years."],[5482,5648,"Still as elegant as ever, of course."],[5712,5806,"Wait, wait, wait."],[5872,6019,"You two know each other?"],[6052,6149,"Well, there's a lot about me"],[6149,6353,"that you don't know, my darling girl."],[6399,6663,"Westley and I used to be lovers."],[6713,6773,"Mm!"],[6803,6976,"You never forget your first love."],[7020,7150,"Do you?"],[7307,7487,"Speaking of which, shall we"],[7487,7682,"talk about the wedding?"],[7707,7873,"Well, that depends if these two"],[7873,8024,"actually love each other."],[8061,8174,"Do you?"],[8201,8328,"Dad, don't ruin the moment"],[8328,8475,"with too many questions, okay?"],[8618,8835,"Are you wearing my watch, son?"],[9112,9241,"Finders keepers."],[9271,9362,"Just like my"],[9362,9496,"soon-to-be wife."]],"9":[[500,784,"That watch looks so familiar."],[820,1028,"This watch is a family heirloom"],[1028,1181,"passed down to my father,"],[1207,1297,"just like it's going to be"],[1297,1404,"passed down to me."],[1501,1608,"Right, Dad?"],[1755,1971,"Oh, where'd you come from?"],[3019,3127,"You know, son,"],[3147,3341,"you should be very careful taking that"],[3341,3513,"which doesn't belong to you."],[3563,3659,"Especially when it wasn't yours"],[3659,3770,"to begin with."],[4140,4237,"Perhaps we should"],[4237,4414,"talk about the wedding."],[4461,4641,"What do you want, Mia?"],[4798,4998,"I want whatever"],[5005,5145,"Mr. Winslow decides."],[5221,5342,"Is that so?"],[5398,5502,"How will we know if these two"],[5508,5608,"actually love each other"],[5615,5765,"if the bride can't even speak for herself?"]],"10":[[16,113,"I have the"],[113,273,"perfect wedding venue."],[280,452,"I called, and they have an"],[452,607,"opening in one week!"],[650,854,"It's a castle and a winery,"],[854,1014,"and we can have caviar,"],[1021,1110,"and we can do that beautiful"],[1110,1274,"little sparkly thing that we so remember"],[1274,1394,"when we were looking at all this lovely-"],[1478,1618,"-You okay? -Sorry."],[1624,1695,"Yeah."],[1865,2032,"You just tell us what you want, Mia,"],[2098,2265,"our soon-to-bride to be."],[2539,2769,"Well, I must say, Mrs. Langford,"],[2769,2982,"I am quite surprised."],[2982,3189,"I don't know whose wedding this is."],[3203,3313,"Mia's or yours?"],[3376,3460,"Oh."],[3853,4014,"Oh my God!"],[4047,4287,"I'm so sorry. So sorry, Miss."],[4314,4391,"That's okay."],[4401,4500,"Just take Mrs. Langford"],[4500,4604,"up to the changing room."],[4604,4768,"-Okay? -Yes, sir."],[4788,4928,"No, no, no, it's fine."],[4981,5105,"You two just stay here."]],"11":[[36,86,"Professor Winslow,"],[86,216,"what are you doing here?"],[236,433,"Do you see any dresses you like?"],[543,633,"You can't be here."],[633,734,"They'll find out."],[747,844,"So?"],[964,1167,"Don't let them find out."],[1374,1468,"Do you really want to marry a man"],[1468,1624,"you have to babysit?"],[1754,1901,"I have to."],[2048,2118,"He doesn't see you"],[2118,2252,"the way I see you, Mia."],[2342,2457,"I see so much more."],[2949,3231,"Darius, no! Stop! We can't do this anymore."],[3231,3331,"You're getting married."],[3331,3436,"You can't say no to this."],[3436,3560,"You never said no."],[3656,3800,"No, no, we can't."],[3800,3957,"I miss you, though."],[4024,4104,"I miss you."],[4120,4240,"I miss you too."],[4501,4671,"We could still have some fun."],[4731,4877,"She'll never find out anyway."],[5318,5488,"Really? You'd throw it"],[5488,5638,"all away just for money?"],[5779,5845,"If that's what you think,"],[5845,5982,"then you don't know me at all."],[5992,6197,"Oh, I know you'd have a lot more fun"],[6197,6302,"if you were with me."],[6359,6453,"Marry me instead."],[6603,6770,"But he's age-appropriate,"],[6770,6909,"and my stepmother would"],[6909,7040,"never let me marry older."],[7047,7272,"Really? Well,"],[7272,7457,"then don't let her find out."],[7467,7751,"Could be our little secret."],[7884,7984,"How?"],[8071,8121,"Okay, no."],[8121,8224,"That would never work."],[8238,8298,"Uh-uh-uh."],[8375,8435,"Daddy didn't say"],[8435,8511,"you could leave yet."]],"12":[[0,53,"Don't move."],[326,460,"I need to get out of here."],[503,647,"Everyone is trying to control me."],[774,897,"Though, I do kind of"],[897,1031,"like being controlled."],[1074,1214,"No, I need to get a job"],[1214,1344,"and be independent."],[1361,1481,"That way I can take care of myself"],[1481,1678,"and nobody can tell me what to do."],[2265,2385,"Let me have a look."],[2582,2726,"Oh, good job, Tony."],[2726,2772,"Thanks."],[2772,2872,"That looks great."],[2926,3064,"Maybe just a little"],[3064,3166,"touch right there."],[3400,3490,"Nice work, Tim."],[3516,3580,"Thanks."],[4214,4361,"Mia, where are you?"],[4401,4624,"I told you to stop calling me."],[4671,4918,"I said, where are you?"],[5015,5151,"That's none of your business."],[5331,5562,"Mia! What are you doing?"],[5625,5745,"Are you playing house?"],[5752,5879,"We haven't seen you for days."],[5885,6006,"Now you have a job?"],[6036,6176,"Oh, my God."],[6199,6359,"You have a fiancé."],[6436,6546,"You want a job?"],[6556,6659,"That tuition goes."],[6659,6800,"You gotta quit your job right now."],[6833,6910,"Tina, stop."],[6910,7033,"You're not supposed to be here."],[7397,7617,"You ungrateful little bitch."],[7704,7877,"This what you want? A job?"],[8044,8191,"I will see that"],[8191,8411,"you become less than a"],[8411,8728,"little wet rat of a housewife."],[9416,9472,"Hey!"],[9479,9572,"Ugh!"],[9672,9753,"You..."],[9753,9806,"Give me that!"],[9853,9913,"Tina."],[9913,9953,"No!"],[9959,10036,"Disgusting!"],[10160,10210,"Stop!"],[10216,10340,"You helped them with these?"],[10357,10507,"They're actually pretty good."],[10764,10841,"No!"],[11481,11571,"Mommy!"]],"13":[[86,253,"What the hell did you do?"],[316,370,"Get out!"],[490,563,"Both of you!"],[637,817,"Go see Darius now!"],[867,1044,"Shut up, you little brats."],[1127,1257,"Go to hell, Tina!"],[1331,1419,"I'm earning my own money"],[1419,1561,"whether you like it or not."],[1685,1901,"And as soon as I can provide for myself,"],[1901,2088,"I'm cutting you out of my life."],[2252,2349,"Well,"],[2412,2665,"a top university student like you,"],[2665,2842,"wanna work here in my place."],[2922,3089,"My stepmother wants to sell me to"],[3089,3189,"the highest bidder."],[3276,3403,"I'd rather eat grass."],[3596,3770,"A smart girl, I must say."],[3907,4154,"Well, come with me, my darling,"],[4154,4447,"and I'll make you a star."],[4531,4674,"I can assure you,"],[4674,4884,"as long as you work for me,"],[4934,5234,"you'll never have to worry about another bill"],[5302,5469,"or stepmom..."],[5535,5626,"again."],[6540,6663,"Have you seen this?"],[6663,6753,"Oh, God."],[6753,6883,"Is that her?"],[6883,7057,"That's Mia!"],[7083,7250,"-Oh! -Could you imagine?"],[7297,7380,"Oh, Mia."],[7380,7557,"That is so embarrassing."],[7764,7861,"God damn it, Mia."]],"14":[[30,83,"Jeez."],[453,532,"What the hell is this?"],[620,880,"Uh-oh, Professor seen."],[1003,1141,"You think this is funny?"],[1311,1464,"I asked you a question!"],[1584,1770,"I don't care how much money"],[1770,1871,"you spent on the school."],[1915,2113,"If I see any of these on campus,"],[2142,2285,"all of you will be expelled."],[3677,3817,"Keep your hands still, darling."],[3817,3930,"I need to cuff you."],[4007,4086,"Don't worry."],[4086,4244,"I'm experienced enough."],[4244,4367,"I won't hurt you."],[4367,4521,"Unless you like it rough."],[4741,4904,"Do I really have to do this?"],[4904,5028,"Of course."],[5035,5165,"My men need to ensure"],[5165,5295,"you're up for the task."],[5398,5575,"If I'm cuffed, how can they judge"],[5575,5668,"if I can dance or not?"],[5739,5835,"Whoever said you're going to be"],[5835,5929,"dancing, darling?"],[6099,6252,"You are the main event!"],[6306,6423,"Let the bids begin!"],[6569,6743,"Bids? Bids for what?"],[7000,7220,"You really don't get it, huh?"],[7370,7610,"They are bidding for you!"],[7767,8038,"Tonight, you are getting auctioned off"],[8038,8244,"to one of my men."],[8561,8729,"No, I only agreed to work here"],[8729,8850,"so I could perform."],[8898,9019,"I didn't agree to this!"],[9019,9152,"Please, just let me out!"],[9265,9422,"Well, sorry."]],"15":[[583,700,"God damn it."],[794,977,"Mia, you better not be in there."],[1264,1624,"Behold! Tonight's shining star!"],[1798,2005,"A straight-A student,"],[2005,2332,"Miss Mia Langford!"],[2399,2564,"So, what's an innocent"],[2564,2709,"virgin worth these days, huh?"],[2782,2956,"Let me go, you bastard!"],[2982,3069,"I've already told you"],[3069,3199,"I'm not for sale!"],[3283,3513,"I quit! I quit! I'm done! I'm done!"],[3550,3646,"Enough!"],[3807,4000,"You better behave."],[4184,4304,"I'm warning you."],[4471,4579,"Do you know how much money"],[4579,4764,"this club has paid for this show?"],[4784,4961,"There's no going back now."],[5141,5298,"I didn't mean to deceive you."],[5298,5388,"I didn't know it was"],[5388,5458,"going to be like this."],[5458,5632,"Could you please just let me out?"],[5712,6022,"Let me out! Please let me go!"],[6072,6186,"And who is going to cover"],[6186,6279,"the losses, huh?"],[6279,6336,"Who?"],[6499,6643,"Do you know how much money"],[6643,6743,"we have spent..."],[7077,7193,"promoting you?"],[7467,7568,"Well..."],[7617,7814,"Unless you'd like me to"],[7814,7964,"warm you up a bit."]],"16":[[163,260,"Professor Winslow!"],[361,500,"She said no!"],[507,633,"Are you fucking deaf?"],[710,826,"Get out of here, all of you,"],[826,947,"before I call the cops."],[1033,1073,"Hey."],[1221,1398,"Are you okay? Did he hurt you?"],[1878,1975,"Mia."],[2018,2175,"Look at me, everything is alright."],[2175,2259,"I'm here now."],[2756,2849,"You're safe."],[3113,3223,"What do you want?"],[3400,3536,"I thought I made it clear."],[3593,3673,"Back off!"],[3707,3930,"You! Need to back off."],[4140,4277,"You roughed up my guy,"],[4351,4524,"trashed my show,"],[4614,4688,"and now you think"],[4688,4871,"you can just walk out of here?"],[4981,5318,"My men paid good money to be here."],[5402,5462,"Now, what am I"],[5462,5595,"supposed to give them?"],[5859,6001,"Look, whatever you paid, I'll..."],[6023,6124,"I'll cover the costs."],[6124,6209,"I'll pay every penny."],[6540,6643,"You heard this?"],[6736,6852,"Knight in shining armor,"],[6852,6993,"flashing his cash."],[7067,7160,"Sorry, pal."],[7263,7400,"Money doesn't cut it."],[7440,7640,"No service, no leaving."],[7854,7997,"That's the rules around here."]],"17":[[130,258,"Sir, please..."],[258,485,"please don't cause any trouble for him."],[540,630,"If the rule is that"],[630,880,"guests need to require service,"],[947,1107,"then I'll serve him."],[1261,1460,"I thought you had ambition."],[1644,1793,"Just another girl"],[1793,1968,"being bailed out by your daddy."],[2052,2115,"Leave it."],[2182,2332,"Just get my stuff and go."],[3937,4197,"Please, don't be angry with me."],[4477,4581,"Whatever you want..."],[4888,4964,"Anything."],[5015,5138,"Anything?"],[5348,5462,"Enough!"],[5525,5679,"Do you really want this?"],[5929,5999,"Or are you just used to"],[5999,6116,"giving yourself away?"],[6266,6353,"You really think I'm"],[6353,6493,"that kind of girl?"],[6876,7170,"I didn't come here to sell myself."],[7270,7455,"I came here to be on my own."],[7731,7834,"Obviously, you don't believe me,"],[7861,7947,"and I'm clearly not"],[7947,8088,"worthy of your trust."],[8251,8438,"At least we know you're not worthy."],[8515,8645,"You think I want to live"],[8645,8768,"without pride?"],[8955,9129,"I have no one else."],[9569,9686,"No one except you."]],"18":[[463,627,"I don't understand."],[710,848,"You'd rather be here"],[848,974,"than go back to school."],[1014,1186,"I wanted to go back."],[1186,1368,"But Tina, she forced me to withdraw"],[1368,1602,"and suspend my studies."],[1660,1801,"I had no choice."],[1808,2008,"You didn't think to come to me?"],[2008,2162,"You thought I wouldn't care?"],[2265,2349,"I didn't want to"],[2349,2482,"hurt your reputation."],[2502,2872,"I don't give a damn about my reputation."],[3003,3169,"I give a damn about you."],[3336,3527,"Just you doing this..."],[3527,3757,"already feels like more than I deserve."],[3840,3966,"You're wrong."],[4022,4313,"You deserve so much more."],[4313,4544,"You deserve to go to school."],[4577,4711,"You deserve everything and you"],[4711,5018,"don't have to try to earn me."],[5098,5307,"You don't have to be anything else but yourself."],[5307,5548,"You just be the girl who loves to sketch."],[5640,5844,"The one that chooses her own path."],[6092,6232,"Then will you stay?"],[6376,6483,"Will you be there?"],[6546,6659,"Unless you choose to walk away"],[6659,6793,"from yourself."],[6886,7050,"I've got no reason to leave."]],"19":[[170,330,"Here's a question for the class."],[337,600,"Should an artist fall in love"],[600,700,"with their own creation?"],[784,887,"No way."],[887,1011,"Art should be objective."],[1077,1284,"Actually, I believe that"],[1284,1428,"creation itself is love."],[1454,1558,"Well, it sounds like Miss Langford"],[1558,1685,"speaks from experience."],[1718,1771,"What if the work"],[1771,1930,"controls the artist instead?"],[2352,2792,"Then the art is worth the risk."],[3075,3257,"I suggest you all take a page"],[3257,3376,"from Miss Langford's book"],[3390,3713,"and create art with real emotion."],[4824,4904,"What are you doing?"],[4911,4998,"What's wrong?"],[5008,5091,"Little Miss Teacher's pet"],[5091,5205,"can't bite back?"],[5225,5305,"Pick that up."],[5305,5385,"Oh, we're not going to"],[5385,5562,"touch your stuff, stripper."],[5572,5682,"Who knows what you came back from"],[5682,5802,"that nightclub with?"],[5889,6009,"She probably has herpes."],[6179,6302,"How did you know about the club?"],[6329,6406,"Didn't you hear?"],[6419,6469,"You're the hot"],[6469,6599,"newest attraction, babe."]],"20":[[73,163,"Hand it to me."],[200,387,"Whoa, somebody's angry."],[397,613,"How about we dance that off, stripper?"],[760,930,"What a poser."],[970,1094,"She's not even an artist."],[1097,1197,"She should be expelled."],[1214,1264,"Professor Winslow"],[1264,1391,"will never expel her."],[1454,1584,"Oh, we all know the"],[1584,1718,"reason for that is..."],[1808,2005,"Hey! Did you seduce the"],[2005,2132,"professor to pity you?"],[2138,2218,"Poor girl."],[2235,2352,"No, I-I didn't."],[2415,2505,"Professor Winslow is"],[2505,2625,"an honorable teacher."],[2682,2752,"There's nothing"],[2752,2859,"going on between us."],[3216,3283,"Professor Winslow."],[3720,3877,"Nothing between you two?"],[3930,4017,"You liar."],[4040,4160,"Your grades are all thanks to the"],[4160,4257,"professor, right?"],[4334,4467,"Come on, fess up, huh?"],[4527,4624,"Just how many times"],[4624,4741,"has she slept with him?"],[4801,4928,"It's a joke that the school even"],[4928,5041,"gave her a scholarship."],[5085,5155,"You're wrong."],[5188,5327,"I earned my scholarship here"],[5327,5485,"and I earned my own money to be here."],[5492,5572,"Earned it."],[5618,5899,"Sweetie, only poor people need scholarships."],[5925,6132,"She probably has an OnlyFans account."]],"21":[[0,192,"She probably has an OnlyFans account."],[623,744,"Sounds like somebody's questioning"],[744,914,"the college's choices"],[914,1074,"for an outstanding student."],[1191,1361,"Yes, yes, yes, yes..."],[1361,1481,"How about we settle this"],[1481,1701,"with a little friendly competition?"],[1735,1838,"Loser drops out."],[1905,1971,"Uh..."],[2025,2198,"Fine. Let's do it."],[2295,2485,"I'm not losing to a poor girl."],[4047,4175,"Own up to your lies"],[4191,4381,"and I'll hand over your paints."]],"22":[[1394,1444,"Woah!"],[1444,1511,"What's going on here?"],[1511,1758,"Some sort of like art show or art contest?"],[1948,2012,"Check out this one."],[2012,2118,"It's great, isn't it?"],[2138,2208,"Gorgeous."],[2208,2409,"I would love that for my bedroom. I would..."],[2419,2648,"I just paid an artist 500 bucks last week and..."],[2668,2782,"this is way better."],[2782,2816,"Oh."],[3033,3212,"Well, I think the answer is pretty clear."],[3212,3373,"Mia's won the competition."],[3426,3570,"She's proven her talents once again."],[3586,3777,"Please, don't make me drop out."],[3777,3870,"My dad will kill me."],[3900,4100,"Same here. I didn't even want to be"],[4100,4217,"part of this contest."],[4250,4417,"I think you all owe me"],[4417,4641,"and Professor Winslow an apology."],[4931,5078,"He's not going to expel you."],[5138,5298,"As long as you swear to never bully"],[5298,5452,"anyone ever again."]],"23":[[36,143,"Professor Winslow,"],[143,293,"I wanted to thank you."],[333,387,"Thank me?"],[487,586,"You denied in front of them"],[586,734,"that we had no connection."],[940,1007,"I only said that"],[1007,1151,"so they wouldn't misjudge you."],[1261,1451,"You said in class"],[1481,1758,"that a worthy creation must justify the risks"],[1758,1928,"of being controlled by it."],[2058,2185,"So now..."],[2425,2772,"Take control of me, Professor."],[3249,3370,"Oh, Mia."],[3436,3600,"Your fiancé"],[3600,3737,"is waiting in the hallway."],[4491,4567,"Baby! I'm here to"],[4567,4694,"pick you up from school."],[4694,4748,"Hey!"]],"24":[[133,243,"Okay."],[460,653,"We'll get there right on time."],[707,834,"You know what I think?"],[834,920,"I think I should meet"],[920,1031,"the rest of your family."],[1171,1421,"I have no other family. It's just"],[1421,1558,"me and my stepmother."],[1695,1965,"Look, Darius, I have something to tell you."],[2138,2343,"My stepmother set this whole engagement up"],[2343,2579,"just to get her claws into the Winslow family."],[2579,2665,"Oh, I know."],[2692,2762,"What if I told you"],[2762,2869,"I'm in on it?"],[2989,3049,"What?"],[3123,3216,"I know what Tina's after,"],[3216,3316,"but my dear, I don't mind."],[3426,3618,"You see, once I get married,"],[3618,3813,"I get a huge inheritance."],[3887,4037,"And when that happens, I'm going to"],[4037,4164,"kick my dad out of the house."],[4314,4558,"Kick him out? It's his house."],[4558,4681,"How do you plan on doing that?"],[4681,4814,"It's my grandfather's house."],[4858,5080,"See, I have a plan."],[5181,5552,"And soon enough, it'll all be mine."]],"25":[[3,240,"Look, Darius, my stepmother"],[258,368,"forced me into this,"],[368,694,"but I don't buy the whole money-grabbing scheme."],[857,1017,"Everything that Professor Winslow has,"],[1017,1104,"he's earned it."],[1164,1287,"It's not ours to take."],[1384,1571,"But... Wait, what?"],[1805,1940,"I'm sorry."],[2023,2172,"I love someone else."],[2322,2450,"I'm gonna talk to my stepmother"],[2450,2639,"and tell her to call off the engagement."],[3023,3143,"Your stepdaughter just gave me"],[3143,3260,"a big, independent speech,"],[3260,3456,"saying she wants to call off the engagement."],[3563,3730,"No. Don't worry."],[3730,3873,"She'll come around."],[4020,4094,"Here."],[4684,4874,"Ooh! Give her these."],[4874,4984,"They'll loosen her up."],[5025,5253,"You need to propose to her immediately"],[5253,5372,"and take her virginity."],[5392,5472,"And then when you do,"],[5492,5608,"she'll be all yours."],[5755,5897,"And where is your father?"],[5897,6066,"He's not answering my calls."],[6086,6184,"I know where he is."],[6184,6439,"If you scratch my back, I'll scratch yours."]],"26":[[60,180,"Evening, Father."],[266,386,"Evening, son."],[386,523,"You seem to be in a good mood."],[523,633,"Of course."],[656,826,"I feel great tonight because"],[826,1061,"I'm going to propose to Mia real soon."],[1554,1760,"Dad, did you hear what I said?"],[1830,1923,"Wait."],[1974,2185,"Is Miss Langford agreed to marry you?"],[2245,2330,"She will."],[2345,2539,"After tomorrow, she'll have no choice."],[2605,2733,"No choice."],[2799,2923,"You know, I seem to recall"],[2923,3149,"Miss Langford not liking phrases like that."],[3199,3404,"What's the problem, Father?"],[3422,3478,"Wait."],[3526,3810,"Don't tell me you don't approve our marriage."],[3877,3998,"On the contrary,"],[4017,4128,"as long as you and Miss Langford"],[4128,4296,"are on the same page, I have no issue."],[4504,4577,"That's great, then."],[4694,4831,"All right. Wish me luck, Dad."],[4838,4938,"Love you, buddy."],[5288,5415,"No choice."],[5465,5672,"Darius, you will regret this."]],"27":[[103,176,"Follow me."],[176,296,"I have something to show you."],[340,487,"The surprise."],[1107,1207,"You always wanted to see your"],[1207,1361,"mother's heirlooms."],[1491,1598,"Why here, though?"],[1651,1818,"It looks so creepy."],[1868,2008,"Quit whining!"],[2802,2949,"It's okay. It's okay."],[3043,3189,"Hey, you're okay."],[3423,3727,"Nice and snog."],[4524,4731,"Ah, sweet innocent art."],[4864,4944,"Gorgeous."],[5218,5468,"But tomorrow, you're going to be"],[5468,5598,"trending everywhere."],[5769,5961,"Oh, darling."],[5998,6169,"You've got great camera presence."],[6222,6316,"Don't worry."],[6376,6486,"The lighting's perfect."],[6629,6696,"I'm going to make you"],[6696,6936,"look gorgeous and obedient."],[7093,7240,"Why am I tied to the chair?"],[7280,7467,"This was your idea, sweetheart."],[7547,7687,"You begged me to film you."],[7734,7910,"Why don't you tell everyone"],[7910,8015,"that you begged me"],[8015,8191,"not to call off the engagement?"],[8314,8508,"You're insane."],[8518,8651,"This is going to ruin me."],[8668,8803,"You've already ruined me,"],[8803,8898,"but not for long."],[8926,9159,"Wait till my father hears about this."],[9299,9500,"No. Please."]],"28":[[26,243,"Well, well, the little virgin who"],[243,450,"pretended to be so pure."],[677,784,"Let's see how long that"],[784,957,"performance lasts, huh?"],[1121,1299,"If you don't leave my father,"],[1351,1464,"I will kill him."],[1611,1878,"No! No, please. Please don't."],[1898,2148,"So, what will you do?"],[2395,2509,"Stay with you."],[2509,2659,"Mm-hmm. Good girl."],[2886,2939,"Mia?"],[3099,3243,"-What the fuck! Dad? -Mia?"],[3299,3416,"What the hell did you do?"],[3416,3473,"Oh, okay."],[3510,3615,"She's barely coherent."],[3615,3703,"Did you drug her?"],[3710,3773,"N-No."],[3830,3940,"What made you think you could"],[3940,4030,"get away with this?"],[4037,4080,"No, Dad."],[4344,4400,"Mia?"],[4507,4604,"Mia, are you okay?"],[4667,4844,"I'm so sorry he did this to you."],[4844,4958,"I'm so sorry I wasn't here."],[5208,5338,"I'm calling 911."],[5408,5799,"No... No, please, he's still your son."],[5922,6032,"Let's just go."],[6152,6272,"You're no son of mine."],[6349,6429,"You're done!"],[6489,6596,"I'm freezing your accounts,"],[6596,6653,"cutting you off."],[6653,6846,"You're not getting a single penny from me."],[7210,7313,"I'll make you pay."]],"29":[[513,583,"Westley."],[623,717,"Are you okay?"],[1024,1151,"I'll tell the whole school"],[1151,1311,"who you've been sleeping with."],[1341,1498,"What is it? Is it Darius?"],[1861,1905,"Come."],[2118,2268,"You're safe now. Do you hear me?"],[2355,2429,"Whatever Darius did,"],[2429,2625,"I'll take care of it. Okay?"],[2896,3023,"I'm so sorry."],[3086,3299,"This is all my fault."],[3463,3546,"Hey."],[3937,4064,"Don't say that."],[4107,4254,"You didn't do anything wrong."],[4351,4521,"Darius will pay