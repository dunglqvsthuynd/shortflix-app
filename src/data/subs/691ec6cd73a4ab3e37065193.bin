,[547,653,"Can't even look at you."],[814,904,"Sorry, Pops."],[957,1127,"You may have won her heart, but..."],[1191,1341,"I have her future."],[1538,1618,"Let's go."],[3213,3433,"Just let me be, Darius."],[3496,3653,"But you chose this."],[3773,3933,"Such a poor pathetic girl,"],[3933,4054,"you look so lost."],[4137,4254,"Look at you."],[4454,4560,"I said I was sorry."],[4617,4791,"You think apologizing to me now"],[4791,4931,"will mean anything?"],[5068,5248,"I'm not an easy guy to deal with."],[5311,5364,"Please!"],[5364,5462,"Just stop."],[5502,5725,"-Just relax, okay? -Let go of me."],[5852,6072,"Just let it happen, okay?"],[6079,6296,"No, get off of me!"],[6447,6496,"You!"],[6496,6543,"Stop!"],[6583,6623,"Dad?"]],"33":[[240,357,"Back for round two, old man?"],[660,894,"Aw, Dad, what the fuck?"],[967,1081,"I'm done with your arrogance."],[1104,1157,"Pathetic!"],[1187,1234,"Stop!"],[1281,1341,"Professor."],[1708,1828,"Let's get out of here."],[1875,1981,"This isn't over, Mia!"],[1991,2168,"Money-sucking parasite!"],[2262,2328,"Augh!"],[2956,3003,"Professor-"],[3003,3103,"Not now!"],[3226,3390,"I need to cool off."],[4140,4230,"I'm sorry."],[4230,4344,"Professor Winslow, I-"]],"34":[[243,363,"Are you hurt?"],[620,807,"I think so."],[890,970,"Can you look?"],[1444,1554,"You know..."],[1658,1798,"You're good at playing sweet."],[1931,2230,"First, you deny any connection we had"],[2230,2385,"to your classmates."],[2435,2538,"Then you choose Darius"],[2538,2749,"not once but twice and now-"],[2892,2947,"What, you even try to"],[2947,3069,"cozy up to me again."],[3133,3309,"I was trying to protect you."],[3446,3623,"If the word got out that we were together,"],[3623,3783,"you could lose your position."],[3850,4007,"And as for Darius-"],[4070,4177,"Enough."],[4371,4561,"I am not some backup option"],[4561,4647,"you can just choose"],[4647,4791,"whenever you're bored."]],"35":[[36,186,"Professor, can you keep looking?"],[707,812,"Turn around."],[1324,1458,"Are you angry with me?"],[1561,1711,"Yes, I'm angry."],[1818,2004,"I'm angry that you doubted me,"],[2048,2205,"but what I'm most angry about is that"],[2205,2345,"after everything..."],[2949,3159,"I can't let you go."],[3283,3536,"I'm sorry that Darius hurt you."],[3636,3780,"I was just scared that"],[3780,4018,"once you found out who I really am, then"],[4018,4257,"you wouldn't want me anymore."]],"36":[[587,673,"What time is it?"],[1024,1201,"You slept deeply last night."],[1358,1458,"Don't move."],[1778,2008,"Are you painting me?"],[2032,2255,"You awake looks more like a painting"],[2255,2355,"than when you're asleep."],[2622,2792,"Well, that sounds a little erotic."],[2922,3179,"Without guilt, erotic is just"],[3179,3313,"another form of art."],[3480,3807,"So, this is how you see me?"],[3910,4020,"From a long time ago."],[4204,4307,"In a dream."],[4716,4834,"I wish time could stop."],[4971,5123,"If you want to stay,"],[5190,5475,"sometimes you need to leave something behind."],[5762,5862,"Get up."],[6399,6496,"What stays behind"],[6496,6619,"isn't just a painting."],[6736,6810,"It's the shedding"],[6810,6950,"of an old identity."],[7113,7187,"A part of you that"],[7187,7350,"no longer serves you."],[9909,10004,"Dad!"]],"37":[[6,33,"Dad!"],[623,704,"Tell me it's good news."],[800,894,"When's the last time anything"],[894,1071,"actually went right?"],[1114,1201,"What do you mean?"],[1211,1341,"The plan failed."],[1361,1474,"My dad's screwing around"],[1474,1594,"with that bitch Mia."],[1805,1888,"What?"],[1908,2115,"How could she do that to me?"],[2205,2355,"How could she take him"],[2355,2469,"and make him her own?"],[2469,2549,"What?"],[2579,2665,"No."],[2706,2796,"Westley is mine."],[2882,2986,"How do you know it was her?"],[3026,3153,"Because I saw it."],[3166,3256,"Saw what?"],[3326,3470,"Fucking art."],[3523,3606,"They used their bodies"],[3606,3730,"to make the painting."],[3870,4097,"[laughs]"],[4254,4371,"Are you serious?"],[4427,4531,"Oh, come on."],[4531,4637,"Maybe he just brought one of his"],[4637,4708,"new flings over and..."],[4708,4861,"and that's what they did."],[4888,4988,"No way."],[4988,5075,"My dad doesn't drag"],[5075,5248,"women into his bedroom."],[5345,5408,"Wait."],[5505,5615,"I just thought of something,"],[5615,5769,"something more easier,"],[5769,5882,"more straightforward."],[5919,5989,"What's that?"],[6059,6222,"Come into my place and"],[6236,6379,"make sure you look hot."],[6473,6563,"Well, that's easy."]],"38":[[540,640,"[clears throat]"],[807,890,"What are you wearing?"],[890,997,"I said to look hot."],[997,1131,"Like, I swear to God."],[1291,1358,"Oh."],[1458,1651,"I've had more men eating out of the"],[1651,1750,"palm of my hand"],[1750,1938,"than you have had hot dinners."],[1958,2065,"My boy."],[2125,2278,"I'm aging like a fine wine."],[2379,2475,"Cool."],[2539,2642,"Just follow my lead"],[2642,2802,"and those two will crash and burn."],[2836,2956,"Well, I can't wait to hear your plan."],[2956,2996,"What is it?"],[3046,3081,"Simple."],[3139,3293,"As long as those two are tight,"],[3293,3521,"nothing we say or do will stick."],[3576,3693,"That's obvious."],[3843,3937,"Wait."],[3973,4100,"Are you saying that we should"],[4100,4257,"drive a wedge between them?"],[4351,4401,"Oh."],[4501,4667,"What is wrong with me?"],[4934,5118,"Am I in love with him?"],[5208,5415,"My head is so full of Westley."],[5472,5628,"Get your head on straight, Mia."],[5638,5795,"Tonight, I'll stick with the plan."],[5869,6086,"Wait in his study and surprise him."],[6710,6980,"Good evening, my beloved step-daughter."]],"39":[[70,193,"What are you doing here?"],[286,383,"Well, what else?"],[383,500,"I'm here to bust up your"],[500,700,"stupid little affair with Westley."],[870,947,"Okay."],[947,1034,"What am I looking for?"],[1061,1194,"A small silver key."],[1231,1474,"Dad stashed it in the study."],[1474,1681,"Find it, and you can open the safe."],[1701,1854,"Okay, I will find it."],[2956,3047,"Well, I looked everywhere"],[3047,3203,"and I can't find it."],[3430,3493,"Oh?"],[4084,4187,"Found it."],[4307,4427,"You've really been living the"],[4427,4561,"high life, haven't you?"],[4561,4722,"Your cheeks are practically glowing."],[4834,4971,"Cut to the chase, Tina."],[5045,5241,"Oh, relax, Mia."],[5285,5448,"We're not blood, I know, but we've"],[5448,5565,"lived in the same house for years"],[5565,5732,"and I really hate to see you being"],[5732,5852,"played like a fiddle."],[5889,5962,"Played like a fiddle?"],[5962,6066,"Okay, what are you on about?"],[6066,6186,"What are you even doing here?"],[6523,6730,"I am here to see him."],[6783,6853,"What else?"],[6910,7013,"Him?"],[7040,7163,"You mean Darius."],[7220,7414,"Oh, no, no, no."],[7414,7650,"Not that ignorant, little boy."],[7737,7921,"I'm here to see Westley."]],"40":[[6,73,"Westley?"],[126,193,"Westley."],[263,360,"Oh, my darling."],[487,690,"He's been stringing you along."],[727,887,"He's been seeing me too."],[947,1057,"You're full of it."],[1087,1201,"Westley's real with me."],[1201,1291,"Oh, it's the oldest"],[1291,1404,"trick in the book."],[1418,1627,"Get you into bed, feed you sweet words,"],[1627,1695,"make you feel like you're"],[1695,1811,"the only one in the world,"],[1811,1908,"and then really,"],[1908,2012,"you're just his muse."],[2055,2312,"Shut up! That's not true."],[2359,2472,"Oh, honey."],[2519,2645,"Why would he settle for just you"],[2645,2802,"when he can have both of us?"],[2846,3083,"Mmm, a mother-daughter duo?"],[3113,3276,"That's exactly the kind of thrill"],[3276,3430,"that a guy like Westley would love."],[3460,3656,"Stop it! I'm not buying it!"],[3737,3897,"I'm calling him right now."],[4157,4267,"Have a look at that."],[4357,4467,"Go on."],[4634,4691,"Mmm-hmm."],[4748,4854,"Go ahead and call him."],[4948,5025,"Rich guys like him"],[5025,5209,"always spin the same lies."],[5209,5310,"They're all the same,"],[5310,5555,"chasing after the next perky little butt,"],[5612,5812,"having fun, moving on."],[5912,5982,"That's exactly why he"],[5982,6122,"left me 20 years ago."],[6166,6366,"And he will leave you, too."],[6516,6716,"Honey, I'm the only one who"],[6716,6846,"actually has your back."],[6876,6950,"Why do you think I wanted to"],[6950,7107,"set you up with Darius?"],[7157,7210,"At least you'd have"],[7210,7384,"a name and a title."],[7450,7624,"You didn't listen, did you?"],[7711,7784,"Nope."],[8158,8218,"No."],[8375,8475,"It's not true."]],"41":[[310,610,"My poor, naive little sweetheart."],[930,1114,"Whoa, whoa, whoa, easy there, Mia."],[1181,1314,"You're crying. What's going on?"],[1358,1458,"Just let me go."],[1478,1524,"Oh, no."],[1541,1688,"My fiancée is bawling her eyes out."],[1688,1768,"If I don't give a damn,"],[1768,1878,"what kind of man am I?"],[1931,2008,"I need to get out of here."],[2008,2158,"Please, just let me leave."],[2619,2736,"What are you doing?"],[2736,2866,"Let go of me."],[2892,3013,"You shoved me aside."],[3063,3136,"Treat me like a dog"],[3136,3229,"when you need me."],[3266,3400,"When you're done, you just"],[3400,3550,"expect me to scram?"],[3680,3767,"Can we just talk"],[3767,3897,"about this another time?"],[3977,4077,"Time."],[4137,4364,"I think it's time for you to learn"],[4364,4534,"who's in charge here."],[4551,4637,"[slap]"],[4761,4891,"Now, kneel!"],[4991,5111,"I said, kneel!"],[5195,5278,"You're going, huh?"],[5578,5689,"Save me, Professor."]],"42":[[16,90,"What's this?"],[150,200,"Huh?"],[230,410,"So, this is what you've been using"],[410,527,"to sneak around with my dad?"],[570,710,"Oh... Ah!"],[757,810,"Come here."],[1027,1134,"Oh, no. Mia!"],[1358,1501,"Oh, good. She's still breathing."],[1614,1708,"Found the key to the safe."],[1728,1801,"Got her phone."],[1828,1961,"What are you going to do with her phone?"],[1998,2188,"I'm going to text the old man, of course."],[2215,2285,"Ah.."],[2349,2532,"[chatter]"],[2549,2632,"Here!"],[2632,2802,"Oh. It's about time, thank you."],[2842,2956,"Put the drinks on the account."],[2969,3036,"Cheers, boys."],[3043,3103,"Cheers."],[3426,3606,"So, do you have any pictures of"],[3606,3740,"this mystery lover of yours?"],[3783,3920,"I don't think I do, but actually, I"],[3920,4014,"might have some saved."],[4014,4087,"Let me check."],[4270,4381,"Westley, we're done."],[4414,4467,"I'm sick of your"],[4467,4584,"controlling bullshit."],[4657,4811,"Teacher, student, future in-laws,"],[4811,4934,"this messed-up affair is"],[4934,5058,"dragging us to hell."],[5128,5388,"Goodbye. Don't come looking for me."],[5398,5608,"Westley, man, you all right?"],[5745,5975,"Yeah, um, look, I'm really sorry,"],[5975,6099,"but I have to go."]],"43":[[1274,1383,"Let's go, let's go."],[1798,1908,"Okay, yes."],[2482,2712,"Alright, Daddy-o."],[2739,2956,"Let's see what you're hiding."],[3159,3253,"What the hell?"],[3346,3526,"It's just an envelope. That's it?"],[3570,3797,"Uh, It could be a Swiss bank account"],[3797,3917,"certificate or something like that."],[3917,4037,"Open it up."],[4617,4828,"No, this... This can't be."],[4828,4951,"What does it say?"],[5071,5228,"It says I'm your son."],[8094,8201,"Mia!"],[8231,8384,"Mia, are you here?"],[8715,8845,"What are you two doing here?"]],"44":[[200,293,"What's this about?"],[347,467,"You broke into my safe?"],[487,590,"Damn right!"],[684,837,"Are you pissed off, Dad?"],[894,1044,"Are you my real dad?"],[1388,1538,"Why don't you tell him?"],[2215,2479,"I was so poor."],[2719,2772,"I didn't have the"],[2772,2939,"money to raise you."],[3033,3286,"So Westley agreed to take"],[3286,3460,"you on as his own child."],[3727,4064,"So... I'm not even your real son?"],[4167,4220,"Never planned on"],[4220,4361,"giving me a dime, did you?"],[4544,4701,"Are you serious right now?"],[4831,4951,"After all of this?"],[4988,5151,"You're a good for nothing,"],[5151,5291,"no-good slacker."],[5311,5435,"You broke into my safe."],[5435,5608,"You're fucking lazy like your mother."],[5608,5869,"Oh, big deal! I stole your girl."],[5869,5965,"Mia spilled everything"],[5965,6056,"about you two."],[6099,6282,"Said she's sick of your old-man smell"],[6282,6383,"and wants to be with me."],[6383,6463,"No, you're lying."],[6539,6659,"Mom?"],[7013,7193,"It's true, Westley."],[7233,7387,"Mia has chosen."]],"45":[[286,380,"Help!"],[557,777,"Now, you had your fun with her."],[834,1104,"Sign over your inheritance to me"],[1104,1247,"and you'll never see me again."],[1534,1624,"You're not getting a"],[1624,1878,"single cent of my money."],[2082,2165,"She's pregnant!"],[2312,2375,"What?"],[2449,2665,"That's why she's leaving you."],[2726,2892,"She's pregnant with my child."],[3029,3189,"Hate us all you want, but..."],[3259,3473,"Are you really gonna let your grandkid"],[3473,3620,"grow up dirt poor?"],[3730,3852,"Show me the pregnancy test"],[3852,4000,"and I will send you the money."],[4100,4391,"Piece of cake. A fake one will do."],[4464,4694,"Westley! Help!"],[4878,4981,"No, Westley, Professor!"],[4981,5088,"No, don't think it so badly."],[5088,5170,"Just let them be lovers"],[5170,5277,"and you and I can be together again."],[5277,5415,"We can be a family!"],[5435,5542,"What was that noise?"],[5555,5632,"Um, nothing."],[5632,5739,"I didn't hear anything."]],"46":[[26,156,"Don't get distracted."],[163,253,"What do you think about my proposition"],[253,350,"that we can be a family?"],[350,397,"We can be together!"],[397,467,"Shut up!"],[637,784,"What was that noise? Is there someone upstairs?"],[810,930,"No way. Probably just a book"],[930,1057,"falling or something."],[1241,1511,"I... I am checking on that noise."],[1511,1621,"No, you're just hearing things again."],[2132,2278,"Oh God."],[2375,2552,"Westley, thank god."],[2552,2752,"Mia, how... how'd you get here?"],[2782,2962,"She probably locked herself in."],[2999,3146,"-Yeah. -Mia."],[3146,3336,"Honey, what happened?"],[3390,3586,"Darius, he trapped me in here."],[3586,3717,"She... she's lying!"],[3717,3840,"I didn't even know she was even here."],[4223,4377,"Stop! Stop! Stop!"],[4377,4531,"You're gonna kill each other!"],[4607,4808,"You're going to jail! Both of you!"],[4848,5058,"No! Westley, my sweet love, please..."],[5075,5208,"Please, just be reasonable."],[5225,5360,"Get the hell out of my house"],[5360,5565,"before I beat the shit out of you and your son!"],[5565,5672,"No! No!"],[5685,5799,"I'm gonna call the cops"],[5799,5955,"because you touched me!"],[6036,6219,"Get out! Now!"]],"47":[[216,306,"Hey, hey!"],[324,560,"I'm getting you to a hospital, okay?"],[1011,1097,"Hey."],[1411,1481,"The police went by the house"],[1481,1621,"to arrest Darius."],[1711,1825,"You okay?"],[1958,2195,"Yeah. You're quite the handful."],[2355,2485,"Thank you for bringing me here,"],[2485,2746,"Westley, but... just go."],[2789,2882,"What?"],[2942,3079,"You heard me."],[3153,3404,"Look, I... I don't know what they told you, but..."],[3404,3524,"I'm not leaving you here."],[3524,3666,"Not now. Like this."],[4204,4434,"I need to rest, Westley."],[4481,4534,"Don't leave."],[4657,4688,"Please."],[6086,6289,"Okay. Everything's looking good."],[6309,6489,"All your vital signs are normal."],[6489,6639,"I just need you to get some rest and"],[6639,6773,"eat some really good food."],[6803,6883,"Take good care."],[6883,7027,"-Thanks, Doctor. -Thank you."],[7200,7507,"Hey, uh... how are you?"]],"48":[[100,236,"Are you feeling any better?"],[323,440,"How dare you show your face"],[440,547,"in front of me again?"],[774,848,"Don't say that."],[848,1024,"I'm still your mother after all."],[1097,1307,"Don't you have a son to take care of?"],[1361,1528,"Stay the hell away from me."],[1544,1778,"Mia, please. I'm in really deep trouble."],[1808,2001,"It's Westley. He's suing me."],[2105,2225,"You know that I didn't steal"],[2225,2382,"anything on purpose. Please!"],[2402,2552,"Please, just put in a good word for me."],[2552,2645,"Please, for old time's sake."],[2645,2752,"Please, please, please."],[2806,3036,"You've done so many awful things to me."],[3036,3256,"and now you're here asking for my help?"],[3340,3570,"Keep dreaming, Tina."],[3740,3970,"You ungrateful little bitch!"],[3970,4034,"If I'm gonna go down,"],[4034,4180,"you're coming down with me!"],[4297,4517,"Let go, Tina. I can't breathe."],[4517,4728,"Westley will leave you eventually"],[4728,4911,"and who will protect you then?"],[4911,5038,"Huh? Who?"],[5065,5188,"Unto me."],[5298,5385,"I'm going nowhere!"]],"49":[[33,176,"Darius is the one who was hurting Mia."],[176,293,"Not me!"],[293,420,"He dragged me into it."],[420,515,"Please, please."],[515,615,"Oh, enough!"],[615,682,"No..."],[787,884,"The police already got your"],[884,1107,"fingerprints all over my safe."],[1107,1254,"The charges aren't getting dropped."],[1394,1598,"Tina Langford. You're under arrest,"],[1598,1775,"for breaking and entering,"],[1775,1861,"theft,"],[1861,2008,"drugging your step-daughter,"],[2008,2122,"slapping,"],[2122,2225,"bullying,"],[2225,2385,"acting with evil intent,"],[2385,2542,"giving away your birth child,"],[2542,2706,"blackmailing Mr. Winslow,"],[2706,2866,"and making offensive gestures."],[2899,2982,"You're coming with me."],[2982,3176,"No, no, no, please don't touch me."],[3196,3343,"Please, Mia, please, Westley."],[3343,3400,"Please!"],[3400,3656,"Why don't you love me? No!"],[3930,4024,"You okay?"],[4157,4287,"Yeah, yeah."],[4457,4771,"You know, I'm going home."],[4871,5065,"You're more than welcome to join me."],[6700,6773,"Isn't there something"],[6773,6870,"you want to tell me?"],[7367,7417,"Do you want to"],[7417,7517,"own up to your own mistakes?"],[7707,7751,"What?"],[7904,8074,"I will give you one second."]],"50":[[20,223,"I shouldn't have left you."],[296,377,"And?"],[513,714,"I really, really"],[714,897,"want to be with you."],[1371,1454,"You're not going to hide from me"],[1454,1581,"anymore, are you?"],[1711,2035,"No. Never."],[2035,2185,"Mr. Winslow."],[2288,2425,"That's not what you call me."],[2766,2856,"Professor?"],[2882,3009,"Mm-mm."],[3536,3603,"Daddy."],[3853,4180,"Daddy's pissed. Very pissed."],[4794,4978,"Daddy, please forgive me."],[4978,5125,"I'll do anything."],[5125,5305,"I can't hold out much longer."]],"51":[[797,937,"From now on..."],[1017,1127,"I'm yours."],[1411,1638,"And? You'll..."],[1664,1801,"Behave."],[1858,1938,"And you'll..."],[1938,2065,"Keep you safe."],[2232,2415,"And as your first reward..."],[2882,3040,"Put your hands out."],[3763,3847,"Yes, you can take it off."],[3847,3933,"Okay, thank you."],[4958,5045,"Congratulations,"],[5045,5155,"Miss Mia Langford."],[5218,5338,"Your artwork has been selected for"],[5338,5428,"the Free Muse Art"],[5428,5522,"Festival Exhibition."],[5775,6049,"Oh my God! This is the top art show"],[6049,6156,"in all the city!"],[6269,6433,"I can't believe I actually got in!"],[6443,6559,"You got talent, kid."],[7317,7490,"You didn't pull any strings, did you?"],[7517,7587,"Hell no."],[7607,7721,"The committee picks all the art pieces."],[7721,7947,"No strings pulled. This was all you."],[7984,8138,"Congratulations, baby."],[8221,8385,"So they actually loved my work?"],[8445,8488,"Yeah."],[8715,8945,"Yeah, they do. Mrs. Winslow."],[9125,9377,"Mrs. Winslow? Really?"],[9432,9683,"Yeah. Of course. School first."],[9853,9966,"Then a proposal."],[10153,10270,"A proper proposal."],[10410,10537,"For the woman I love."],[10647,10864,"You know, I might not say yes."],[11257,11344,"Say that again."],[11518,11718,"I will not say yes."],[11758,11805,"Really?"],[11858,12082,"Until you punish me, Daddy."]]}