on't deserve to be Lila's mother?"],[9763,9880,"Well, a skank like you"],[9880,10047,"doesn't deserve to be her nanny!"],[10168,10239,"I have no choice"],[10239,10322,"but to show Lila"],[10322,10514,"this incriminating video."],[10514,10564,"No!"],[10643,10756,"Oh, yes, Nicole!"],[10835,10940,"I'm going to tell Lila"],[10940,11073,"all about how you fucked"],[11073,11290,"her daddy on her birthday!"]],"31":[[20,133,"I'm going to tell Lila"],[133,312,"all about how you fucked her daddy"],[312,454,"on her birthday!"],[483,638,"Sarah, Lila is your daughter,"],[638,804,"how could you do that to her?"],[834,925,"That bustard child"],[925,1051,"means nothing to me."],[1084,1297,"Ethan is the only one who matters."],[1368,1493,"She still has no idea"],[1493,1630,"Lila is her daughter."],[1697,1864,"She's completely insane!"],[1872,2002,"I can't let her tell Lila."],[2002,2102,"She trusts me,"],[2102,2235,"and plus she's six!"],[2248,2423,"This would scar her for life!"],[2464,2594,"After we show it to Lila,"],[2594,2698,"I will describe it"],[2698,2936,"to your blind old granny, too."],[2936,3028,"Let's see what she thinks"],[3028,3157,"of her precious granddaughter"],[3157,3353,"spreading her legs for her boss."],[3357,3557,"She might actually die"],[3557,3657,"from the shock!"],[3720,3858,"You have three seconds."],[3874,3945,"Leave,"],[3978,4083,"or I'll make sure"],[4083,4208,"your hand gets chopped off."],[4233,4316,"Three."],[4575,4658,"Sarah,"],[4658,4746,"you are going to get"],[4746,4850,"what's coming to you."],[4879,4938,"Two."],[4996,5075,"You'll traumatize"],[5075,5167,"your own daughter"],[5196,5359,"just to get what you want!"],[5359,5463,"You're a goddamn"],[5463,5584,"psychopath!"],[5630,5680,"One!"],[5955,6035,"Okay!"]],"32":[[4,104,"Okay!"],[104,287,"Okay, okay, fine! I'll leave!"],[992,1080,"Sign it,"],[1080,1251,"and get the hell out of this house."],[1334,1518,"I'll tell Lila and Ethan you quit."],[1689,1801,"Quitting your job doesn't mean"],[1801,18