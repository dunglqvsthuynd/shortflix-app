{"1":[[450,567,"Doctor, how are they?"],[567,671,"I'm so sorry."],[671,834,"The two older patients"],[834,950,"didn't make it."],[950,1151,"As for Mr. Wilson,"],[1151,1267,"he's in a coma."],[1338,1480,"I'm so sorry."],[2965,3249,"Just yesterday we were happy."],[3286,3324,"And now"],[3324,3566,"everything’s changed."],[3620,3741,"Ethan,"],[3745,3937,"what do I do without you?"],[4112,4258,"Ethan, you're not supposed to"],[4258,4291,"be here."],[4291,4400,"What are you doing?"],[4400,4454,"You’re not supposed to"],[4454,4562,"see the bride before the wedding."],[4562,4617,"I'm sorry."],[4617,4792,"I just missed you so much."],[5013,5221,"I just can't get enough of you."],[5989,6085,"What's going on?"],[6106,6193,"Nicole Brown,"],[6193,6302,"you are under arrest"],[6302,6373,"for the murder of"],[6373,6473,"Mr. and Mrs. Wilson."],[6473,6535,"No!"],[6535,6644,"You're coming with us."],[6644,6702,"Ethan,"],[6756,6815,"Ethan..."],[6852,6973,"Ethan wake up..."],[7040,7127,"Let me go!"],[7127,7211,"Stop resisting!"],[7211,7340,"I didn't do it!"],[7340,7424,"Nicole,"],[7424,7620,"I can't believe you’d do this."],[7682,7811,"You knew your car was broken"],[7811,7966,"yet you let Ethan drive it"],[7966,8083,"to pick up his parents."],[8083,8229,"You did this on purpose!"],[8229,8383,"That crash is on you!"],[8383,8504,"No, I... I... I didn't..."],[8541,8692,"I didn't... I swear I didn't!"],[8725,8875,"I'm Ethan’s fiancée,"],[8875,9009,"why would I hurt his parents?"],[9009,9121,"I wouldn't do that!"],[9121,9355,"I work closely with Mr. Wilson."],[9388,9484,"I heard her complain"],[9484,9584,"plenty of times."],[9622,9755,"She always hated his parents"],[9755,9889,"for looking down on her,"],[9889,9980,"coming from nothing."],[10022,10130,"She even said"],[10130,10276,"I wish they'd just disappear."],[10276,10364,"That's not true, I can't..."],[10393,10510,"No, Ethan!"],[10543,10631,"Ethan..."],[10660,10848,"Ethan I didn't, I didn't, Ethan."],[10848,10981,"Ethan, I love you!"],[11019,11156,"Ethan, please!"]],"2":[[0,200,"Ethan, I didn't do it, I swear..."],[200,346,"I didn't do it."],[404,454,"Ethan,"],[454,675,"that other woman's finally gone."],[675,800,"Now, you're mine."],[1009,1176,"Ethan, you're awake!"],[1217,1347,"How do you feel?"],[1347,1451,"You..."],[1451,1559,"Who are you?"],[1559,1643,"Where am I?"],[1668,1764,"God! I feel like"],[1764,1926,"my head's going to explode."],[1926,2064,"I don't remember anything..."],[2147,2360,"He's lost his memory..."],[2360,2494,"at this very moment?"],[2523,2631,"Perfect."],[2631,2740,"This couldn't have worked out"],[2740,2819,"any better."],[2944,3069,"Don't worry."],[3069,3203,"You're Ethan Wilson."],[3203,3411,"And... I'm your fiancée,"],[3411,3528,"Sarah Miller."],[3528,3682,"You're my fiancée?"],[3682,3795,"Yeah, we've been together"],[3795,3933,"since we were kids."],[4058,4179,"Our wedding was supposed to be"],[4179,4229,"tomorrow,"],[4229,4287,"but then"],[4287,4441,"the accident happened."],[4475,4621,"If she's my fiancée,"],[4671,4758,"then why do I feel like"],[4758,4913,"a part of me is still missing?"],[4971,5100,"This is going even better"],[5100,5255,"than I ever expected."],[5255,5417,"Ethan, forget that bitch."],[5417,5572,"Our families are the richest"],[5572,5659,"in this country."],[5659,5768,"We belong together."],[5768,5980,"From now on, I'm your only woman."],[5980,6085,"Forever."],[7094,7303,"My granddaughter is innocent."],[7303,7361,"Please!"],[7361,7557,"She could never kill anyone!"],[7786,7874,"Ethan,"],[7899,8041,"no matter what,"],[8041,8179,"I will protect our child"],[8179,8274,"until the three of us"],[8274,8441,"can be reunited."],[8541,8637,"Push!"],[8775,8875,"Almost there!"],[9129,9292,"She's losing too much blood!"],[9376,9484,"Deep breath!"],[10222,10364,"I have to steal that baby."],[10364,10531,"Only I can be mother"],[10531,10677,"to the Wilson heir."],[10677,10785,"It's a girl."],[10785,10906,"Perfectly healthy."],[10965,11056,"Good."],[11056,11119,"It would've been better"],[11119,11232,"if it was a boy."],[11232,11373,"But Nicole's not good at anything."],[11419,11486,"1 million,"],[11486,11586,"just like we agreed."],[11745,11982,"Keep your mouth shut."],[12729,12879,"Your daughter died from"],[12879,12983,"birth asphyxia."],[12983,13146,"She never took a breath."],[13200,13271,"Oh no..."],[13434,13601,"no, it’s impossible."],[13659,13805,"I heard her crying."],[13834,14030,"You have to check again, please!"],[14030,14105,"Please, check again."],[14105,14264,"We did everything we could."],[14451,14622,"The guards will come by"],[14622,14698,"in a few hours"],[14698,14823,"to take you back."],[15277,15436,"You have to bring her back to me."],[15502,15657,"No, you have to bring her back."],[15686,15774,"Please, please,"],[15774,15844,"please, please."]],"3":[[859,930,"Grandma?"],[996,1067,"Nicole?"],[1067,1188,"- Grandma! - Nicole!"],[1188,1297,"Oh my godness."],[1363,1526,"Oh you're free!"],[1572,1801,"You have no idea"],[1801,2027,"how long I've waited for this day."],[2027,2097,"Grandma..."],[2452,2485,"Grandma,"],[2485,2619,"what happened to your eyes?"],[2619,2861,"I cried so long."],[2861,3086,"There was nothing left,"],[3086,3261,"then I couldn't see anymore."],[3399,3478,"Grandma!"],[3532,3607,"Grandma!"],[3691,3774,"Grandma!"],[3791,3949,"Somebody help! Please!"],[4233,4437,"It's congestive heart failure."],[4496,4629,"Without a transplant,"],[4629,4842,"she has about six months left."],[4871,5042,"She's the only family I have left."],[5042,5146,"Whatever it costs,"],[5146,5238,"I'll find the money."],[7303,7382,"Ethan?"],[7515,7611,"He's awake!"],[7741,7836,"What are you doing?"]],"4":[[0,33,"No,"],[33,208,"I can't let him see me like this."],[208,304,"Lila! Get over here!"],[304,433,"Quit running around."],[433,496,"Stop!"],[513,563,"Lila..."],[696,817,"Wait, Ethan has a daughter?"],[846,980,"He didn't wait for me?"],[1388,1497,"As you all know,"],[1497,1680,"Lila will be choosing her own nanny."],[1680,1805,"Pay's ten thousand a month,"],[1805,1914,"and trust me,"],[1914,2018,"you'll work for it."],[2052,2227,"I have to get this job"],[2227,2318,"for grandma."],[2848,2923,"That kid..."],[2923,3094,"Why does she look so familiar?"],[3445,3516,"All right,"],[3516,3607,"turn on your phones."],[3607,3757,"Test is very simple."],[3757,3849,"Latest game."],[3849,3970,"First one to the finish"],[3970,4029,"wins!"],[4066,4170,"Maple Blox?"],[4170,4341,"I am obsessed with this!"],[4341,4508,"This is way too easy."],[4508,4608,"Get ready?"],[4658,4717,"Go!"],[4863,5038,"How do you even play this game?"],[5409,5480,"Cleared!"],[5543,5622,"I'm first!"],[5643,5747,"I cleared it too!"],[5759,5805,"Done!"],[5834,5922,"What's wrong?"],[5947,6064,"It's an easy game."],[6085,6160,"I'm so sorry."],[6160,6302,"I... I have never played this before."],[6302,6393,"I don't really know how."],[6956,7098,"You don't know how to play"],[7098,7282,"the coolest game?"],[7361,7486,"You're my new nanny."],[7716,7803,"Thank you."],[7907,8062,"If she can't even play"],[8062,8183,"an easy game,"],[8183,8416,"then she can't even catch me"],[8416,8554,"being naughty."],[8554,8712,"Daddy will never know"],[8712,8846,"what I'm up to."]],"5":[[254,479,"Oh my God, this is Ethan's house."],[479,642,"No wonder Lila looks so familiar."],[642,767,"She's Ethan's daughter."],[1255,1322,"Honey,"],[1322,1480,"did you pick your nanny yet?"],[1609,1751,"Sarah is..."],[1751,1889,"Lila's mom?"],[1901,2014,"Her and Ethan..."],[2014,2106,"Nicole?"],[2106,2160,"What the hell"],[2160,2281,"are you doing here?"],[2318,2402,"Ms. Miller..."],[2448,2560,"what a surprise."],[2590,2677,"Lila,"],[2677,2786,"this"],[2786,2869,"is your pick?"],[2869,2932,"Yes!"],[2932,3123,"She's the best one!"],[3361,3490,"Take Lila inside."],[3874,3937,"Ms. Miller..."],[4066,4250,"You relentless bitch!"],[4287,4458,"Are you stalking me?"],[4458,4533,"You think you could just"],[4533,4621,"waltz out of prison"],[4621,4713,"and come to my home"],[4713,4854,"as a nanny?"],[4854,4925,"I mean, I didn't even know"],[4925,5038,"this was your house."],[5038,5146,"And the agency already"],[5146,5180,"knows about"],[5180,5317,"my time in prison."],[5317,5384,"Plus Lila"],[5384,5513,"really seems to like me."],[5513,5822,"Well, I'm not letting a murderer"],[5822,5930,"into my home."],[6081,6164,"I'm not a killer."],[6260,6352,"Don't blame anyone"],[6352,6452,"but yourself."],[6452,6560,"Stop coming here"],[6560,6748,"and acting like a cheap liar"],[6748,6923,"trying to steal my husband!"],[6990,7132,"Her husband?"],[7695,7799,"What's going on here?"],[7841,7928,"Ethan!"],[7928,8020,"You're back!"],[8099,8262,"So Ethan's with Sarah now."],[8291,8416,"And they had a daughter together."],[8416,8508,"They're a family."],[8537,8779,"And I'm just an ex-convict nanny."],[8812,8954,"God, how can I face him?"],[9401,9480,"Why is my body"],[9480,9638,"reacting this way?"],[9638,9726,"My heart aches"],[9726,9884,"like I need to be close to her."],[10251,10331,"Who are you?"]],"6":[[304,400,"Daddy,"],[400,563,"this is my new nanny."],[563,817,"She's going to keep me safe at all times,"],[817,992,"so you don't have to worry anymore."],[992,1146,"This is my daddy."],[1146,1355,"He's going to be your new boss!"],[1355,1488,"Would he even recognize me"],[1488,1622,"if he saw me again?"],[1659,1847,"Maybe it's better he doesn't see me."],[1872,1947,"Not yet."],[2002,2122,"Mr. and Mrs. Wilson,"],[2122,2314,"it's an honor to work for both of you."],[2314,2477,"I'll take good care of Lila."],[2477,2694,"It's Ms. Miller still, actually."],[2727,2877,"Why won't you look at me?"],[2944,3019,"I..."],[3324,3374,"Ethan,"],[3407,3486,"this nanny doesn't"],[3486,3724,"even have basic manners."],[3724,3924,"Let's find Lila a better one."],[3924,4058,"No, I like her!"],[4095,4295,"She's the best one!"],[4295,4462,"You're the boss, boss."],[4767,4909,"They're so cute together."],[4950,5055,"Ethan's a great dad."],[5055,5167,"I knew he would be."],[5263,5359,"Let me be clear."],[5359,5668,"Ethan and I are family now."],[5668,5768,"Try seducing him"],[5768,5926,"like you did in the past,"],[5926,6076,"and I swear"],[6076,6168,"you'll regret it."],[6260,6418,"Miss Miller,"],[6418,6535,"I'm not a homewrecker."],[6535,6619,"I would never dream about"],[6619,6765,"breaking up your family."],[6765,6835,"Good."],[7169,7328,"You use your left hand."],[7357,7449,"You notice that?"],[7474,7640,"I use my left hand too,"],[7640,7766,"and my right."],[7816,7937,"My dad says I'm smart"],[7937,8087,"because I can use both."],[8087,8208,"And he must be right,"],[8208,8279,"because"],[8299,8487,"I think that you are very smart"],[8487,8583,"and very cute."],[8641,8804,"You can use your left too,"],[8804,8967,"but how come you"],[8967,9242,"can't play video games on a phone?"],[9242,9417,"Even I can do it."],[9417,9526,"Well, umm..."],[9592,9784,"Nicole!"],[9980,10143,"I haven't been around"],[10143,10281,"for a little while to learn."],[10335,10418,"She looks so much"],[10418,10527,"like her father."],[10577,10731,"If my daughter had lived,"],[10798,10998,"would she have looked like Lila..."],[10998,11069,"or Ethan?"]],"7":[[0,50,"It's okay"],[50,87,"if you don't"],[87,196,"know how to play."],[196,300,"Don't cry."],[321,375,"It's not that."],[375,462,"I was just thinking"],[462,558,"about my daughter."],[558,675,"You have a daughter?"],[717,817,"Do you miss her?"],[817,942,"How old is she?"],[942,1084,"What toys does she like?"],[1338,1597,"She would be about your age."],[1639,2010,"And yes, I miss her very much."],[2043,2268,"I wish my mommy misses me."],[2268,2369,"She doesn't?"],[2369,2531,"She doesn't care about me."],[2531,2623,"She only cares"],[2623,2811,"about making daddy happy."],[2857,3115,"Can you sing me a lullaby later tonight?"],[3115,3257,"I always ask my mommy,"],[3257,3432,"she always says no."],[3528,3678,"Of course, sweetheart."],[3849,3941,"Of course."],[4212,4266,"You’re so cute."],[4546,4675,"Is that Lila's laugh?"],[4675,4863,"She never laughs like that with Sarah."],[5034,5125,"Will you just stop?"],[5597,5743,"What's happening to me?"],[5743,5830,"I don't know her,"],[5830,5926,"and yet it feels like"],[5926,6101,"I've known her body forever."]],"8":[[354,504,"No matter how much time passes,"],[504,588,"my heart races"],[588,759,"whenever I see you, Ethan."],[892,1368,"Let me call you sweetheart."],[1368,1484,"-This song... -I’m..."],[1484,1622,"-so familiar... -in love..."],[1676,1739,"with..."],[1739,1768,"-Someone... -you."],[1768,1876,"sang this to me."],[1876,1993,"Someone I love."],[2156,2323,"Nicole,"],[2323,2481,"I really like you."],[2590,2794,"Well, I really like you too, Lila."],[2794,2998,"I wish you were my mommy."],[4112,4262,"Mr. Wilson, Lila's sleeping."],[4262,4371,"Can you turn off the light?"],[4500,4617,"That song that you were just humming,"],[4617,4696,"how do you know it?"],[4725,4767,"Umm..."],[4879,5050,"It's just an old song."],[5050,5167,"Everyone knows it."],[7399,7494,"Then why does it feel like"],[7494,7590,"there's something more?"],[7924,8116,"Ethan almost never comes home."],[8116,8258,"This is my chance."],[8487,8562,"That slut."],[8562,8683,"Always in my way!"],[8683,8771,"No way you're stealing"],[8771,8858,"Ethan back."]],"9":[[141,279,"You filthy bitch!"],[283,371,"Why were you and Ethan"],[371,500,"coming out of the same room?"],[508,663,"Were you trying to seduce him again?"],[725,855,"I was just putting Lila to bed."],[925,1042,"Mr. Wilson just popped in"],[1042,1088,"for a second."],[1134,1272,"For all I know, he wasn’t in there"],[1272,1397,"for that bastard child."],[1397,1547,"He was in there for you. You tramp!"],[1605,1697,"Ms. Miller,"],[1697,1805,"Lila is your daughter."],[1805,1935,"How could you call her that?"],[2031,2160,"A servant like you doesn‘t get to"],[2160,2218,"question me."],[2264,2431,"I was born a Miller,"],[2494,2598,"and now I'm"],[2598,2727,"the lady of this house."],[2781,2911,"But you..."],[2957,3161,"You were born worthless."],[3236,3424,"If you ever"],[3424,3557,"try to raise above your place,"],[3557,3682,"I'll make sure you end up"],[3682,3770,"back in prison."],[3858,4016,"You may have given Ethan a child,"],[4074,4220,"but you are still Miss Miller."],[4258,4446,"Not Mrs. Wilson!"],[4529,4650,"No wonder you're so afraid someone"],[4650,4817,"is going to take him. It’s Pathetic!"],[5176,5305,"Respectfully,"],[5305,5434,"Ms. Miller."],[5451,5626,"Lila chose me to be her nanny."],[5676,5885,"And Mr. Wilson approved it."],[5910,6189,"I’m here to work, to earn money."],[6231,6356,"And that does not"],[6356,6527,"give you the right to abuse me."],[6852,7044,"Ethan hates you,"],[7090,7232,"for killing his parents in that"],[7232,7378,"crash you caused."],[7378,7532,"Do you really want to hurt him again"],[7532,7732,"by reminding him of their deaths?"],[7845,7962,"So that's it?"],[7962,8049,"Ethan blames me"],[8049,8195,"so he doesn't want me anymore."],[8229,8362,"He wants her."],[8491,8700,"Maybe that's the ending"],[8700,8783,"we all deserve."],[8842,8979,"Wear this when you're in my house."],[9113,9271,"I don't ever want to see your face"],[9271,9401,"again."],[10310,10414,"I'm cutting sugar."],[10514,10685,"Who told you to bring me juice?"],[10860,10994,"Oh..."],[11265,11448,"Ms. Miller, the juice wasn't for you."],[11532,11590,"Oh,"],[11711,11845,"so you're talking back."],[11882,12037,"Hands off my mommy!"]],"10":[[16,137,"Lila!"],[137,283,"What did you just call her?"],[312,446,"I mean, nanny, mommy."],[721,846,"Good morning, daddy!"],[850,984,"Morning, sweetie."],[1238,1405,"Ethan, good morning."],[1922,1993,"What are you doing"],[1993,2122,"standing here?"],[2131,2293,"Go get Mr. Wilson his juice."],[2444,2573,"Yes, miss."],[2686,2857,"Ethan, you know, my mother said"],[2857,3007,"the sixth of next month"],[3007,3161,"is the perfect wedding."],[3257,3340,"You know,"],[3340,3499,"they've been waiting for years."],[3582,3678,"Yeah... Everyone says"],[3678,3787,"she's my fiance."],[3791,3933,"And we even have a kid together."],[3933,4195,"But why can't I seem to love her?"],[4346,4466,"I need to wait for this migraines to go"],[4466,4596,"away from the crash."],[4662,4829,"We'll talk when I’m fully recovered."],[4921,5050,"Lila’s six already."],[5576,5684,"Lila’s six?"],[5684,5814,"Just like my daughter..."],[5864,6076,"People are starting to ask..."],[6114,6218,"Enough!"],[6631,6756,"Mr. Wilson, I am so sorry."],[6756,6952,"I will clean this right now."],[7169,7332,"Why does seeing her hurt, make me"],[7332,7469,"want to protect and take care"],[7469,7545,"of her so badly?"],[7766,7895,"Stand up."],[8212,8341,"How come you never look at me?"],[8662,8858,"Why do you wear this stupid thing?"],[9955,10022,"Nicole?"]],"11":[[8,162,"Ni—Nicole?"],[212,287,"Wait,"],[287,421,"does he remember her?"],[667,796,"Guess who?"],[921,1051,"I don't know."],[1126,1276,"I mean, could it be"],[1276,1443,"the one and only..."],[1451,1530,"Nicole!"],[1893,1985,"Why did her name just"],[1985,2052,"slip out of my mouth like"],[2052,2177,"I've been saying it for years?"],[2231,2310,"It's like I know her,"],[2310,2439,"but I don't."],[2464,2644,"Every time I see her, my head throbs"],[2644,2773,"and my heart aches..."],[2861,2932,"Get out!"],[2965,3107,"Stop hanging around here"],[3107,3244,"begging for attention."],[3424,3557,"Have we ever met before?"],[3636,3720,"Met?"],[3720,3824,"Does he hate me that much?"],[3824,3920,"So he’s pretending not to"],[3920,3970,"know me?"],[4062,4129,"For a second,"],[4129,4208,"I thought his memory"],[4208,4258,"came back."],[4283,4412,"Thank god it didn’t."],[4412,4542,"He really did forget it."],[4546,4675,"Of course not, Ethan."],[4692,4821,"She's just a worthless nanny."],[4875,4984,"It's better this way."],[4984,5246,"He has a family and a child with Sarah."],[5246,5438,"I’m nothing to him now."],[5701,5768,"Oh, your headaches"],[5768,5830,"are back."],[5834,6010,"Let me help you lie down."],[6031,6202,"And you! Clean this up."],[7036,7190,"He has Sarah and Lila now."],[7286,7419,"I can't want him anymore."],[7503,7640,"I should leave him alone."],[8074,8237,"Here, let me help."],[8279,8412,"No. It's okay."],[8433,8546,"I don't want anyone"],[8546,8679,"saying I‘m mean to my nanny."],[8700,8829,"I'm a good girl,"],[8846,8996,"like my daddy tells me."],[9038,9167,"Here."],[9209,9263,"Now, don't"],[9263,9392,"get hurt again."],[9609,9663,"Thank you."],[9722,9859,"She’s so adorable."],[9905,10043,"I can’t help thinking..."],[10097,10193,"how nice it’d be"],[10193,10331,"if she were my baby girl."],[10623,10660,"Ethan."],[10660,10769,"Something's wrong."],[10769,10877,"Lila just fainted!"],[10902,10960,"What?"]],"12":[[66,116,"What?"],[137,279,"Upstairs! Come on!"],[588,717,"What the hell happened?"],[725,834,"It was Nicole."],[834,971,"Lila's allergic to pollen."],[1013,1163,"Nicole probably snuck into her room"],[1163,1263,"while she was napping"],[1263,1451,"and filled her room with flowers."],[1459,1597,"She should have known better."],[1601,1735,"I brought her here, Ethan."],[1793,1885,"She could have died."],[1935,2039,"Nicole did this?"],[2068,2114,"Yes. Sir,"],[2114,2318,"I swear, I've told her a thousand times."],[2331,2431,"She probably did this"],[2431,2606,"on purpose to hurt Lila."],[2635,2719,"She has a seven-year"],[2719,2806,"criminal record because she..."],[2911,3119,"I can't let Ethan know I set Nicole up"],[3119,3228,"for murdering his parents."],[3269,3449,"Or he'll figure out they've had a past."],[3449,3599,"Either way, she has a criminal record."],[3628,3787,"I knew leaving her alone with Lila"],[3787,3916,"is a bad idea."],[4074,4133,"Call the driver."],[4133,4250,"We're going to the hospital."],[4250,4346,"Keep cleaning the room right now."],[5401,5530,"Help..."],[5568,5697,"Help..."],[5897,6014,"What's going on?"],[6164,6260,"Baby's breath."],[6569,6677,"Ethan..."],[6677,6806,"Save me..."],[6865,6973,"Ethan..."],[7086,7219,"Did I just hear Nicole?"],[7257,7424,"Why is she calling my name?"]],"13":[[62,112,"Come on."],[112,212,"Lila’s getting sick."],[212,342,"We need to take her to the hospital."],[980,1059,"Daddy!"],[1059,1192,"Nicole didn’t hurt me."],[1259,1376,"How do you know that?"],[1376,1526,"She's allergic to pollen,"],[1526,1614,"just like I am."],[1618,1772,"She would never put flowers"],[1772,1851,"in my bed."],[1864,1993,"I trust her."],[2002,2064,"All right."],[2164,2302,"Daddy's gonna find out the truth though."],[2327,2385,"Okay?"],[2606,2715,"It's okay, daddy,"],[2715,2857,"you can go to the meeting."],[4433,4571,"What are you doing?"],[4604,4733,"What do you think I'm doing?"],[4771,4929,"You tried to kill my daughter."],[5000,5038,"What?"],[5171,5196,"No."],[5196,5376,"I would never hurt Lila."],[5472,5609,"I treat her like she's my own."],[5659,5755,"Well, you did."],[5797,5939,"And now you're going to pay,"],[5993,6081,"bitch!"],[6114,6193,"You and you!"],[6193,6235,"Don't stop"],[6235,6381,"until she's begging to die."],[6973,7119,"Now get her out of my house!"],[7469,7620,"Sluts like you should stay"],[7620,7749,"where they belong."],[7766,7866,"On the street!"],[8641,8708,"Ethan..."],[8712,8779,"Help..."],[8846,8913,"Ethan..."],[9009,9138,"Save me..."],[9196,9325,"Please..."],[10531,10694,"This aching feeling again."],[10706,10856,"Every time it just makes me"],[10856,11011,"want to protect her."],[11152,11207,"Ethan,"],[11240,11394,"you still care about me."],[11515,11644,"Nicole?"]],"14":[[154,291,"He might hate me,"],[325,475,"but he's keeping his promise"],[475,617,"to always protect me."],[671,713,"Nicole!"],[713,821,"Wake up!"],[821,950,"Nicole!"],[1751,1926,"Nicole, have I met you before?"],[2039,2135,"Did I know you..."],[2193,2289,"in my past life?"],[2348,2423,"How come I feel"],[2423,2552,"so connected to you?"],[3211,3340,"Am I dreaming?"],[3449,3578,"You again?"],[3628,3757,"You came back."],[3837,4054,"I've had so many dreams about you."],[4