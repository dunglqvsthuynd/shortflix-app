{"1":[[970,1083,"Honey, have you landed yet?"],[1196,1280,"We're on the way."],[1296,1480,"You're gonna meet your baby boy soon."],[3596,3740,"No. Let go of my baby."],[3883,3926,"No..."],[3926,4000,"Let go!"],[4760,4970,"I want my son to live a good life."],[5000,5213,"This is what your family owes me."],[5286,5510,"The son of the richest man is nothing but a lowlife."],[5540,5681,"After few years, we'll sell him."],[5760,5796,"Hey!"],[5880,6003,"He does look like our son."],[6050,6180,"Give me back my baby."],[7206,7370,"Let go of my son."],[7403,7493,"Give me back!"],[7633,7800,"How can this be?"]],"2":[[220,376,"Mommy, Mommy."],[376,468,"Please wake up."],[468,628,"Mommy, Mommy."],[772,852,"Rita!"],[1092,1212,"Can't you see me?"],[1332,1412,"Honey!"],[1648,1760,"Can't you hear me?"],[1800,1880,"Doctor."],[1948,2068,"When will my wife wake up?"],[2092,2304,"Sir, your wife's injuries are in complete control."],[2304,2348,"But..."],[2348,2420,"But what?"],[2440,2556,"When will she wake up?"],[2568,2676,"Depends on the patient."],[2692,2800,"In most cases,"],[2808,2924,"it can take a few months,"],[2952,3044,"even a year."],[3044,3164,"Possibly will never wake up."],[3308,3492,"Find the best doctors in the world,"],[3496,3616,"no matter the cost."],[3616,3708,"Cure her!"],[3708,3788,"Yes, sir."],[4016,4108,"Darling..."],[4116,4224,"Please wake up."],[4320,4536,"Rita, our son, and I,"],[4552,4716,"we're waiting for you to wake up."],[4760,4836,"Please..."],[4856,5036,"Mandel, go find our son!"],[5160,5396,"Find a nanny, specifically for the baby!"],[5404,5616,"I want our son well taken care of!"],[5628,5708,"Yes, sir."],[5856,5996,"This is not my son!"],[6000,6144,"Our son was taken!"],[6168,6296,"This is an imposter!"],[6376,6456,"Right..."],[6504,6584,"My son!"],[6980,7080,"Shut it up!"],[7096,7224,"Make it stop crying!"],[7336,7428,"What can I do?"],[8512,8780,"Is this something Memi left for him?"],[9736,9816,"Nick."],[9880,9976,"Don't cry."],[10000,10176,"Mom is always gonna be here with you."]],"3":[[1352,1560,"What's the use of reading that trash?"],[1560,1680,"Go clean the yard."],[1680,1800,"I already cleaned it."],[1816,1960,"Do as I say!"],[3156,3236,"Bravo."],[3264,3372,"It's his birthday,"],[3396,3644,"and I've booked him his favorite restaurant."],[3644,3792,"After I finish the meeting,"],[3796,4104,"I'm going to come and celebrate our little prince."],[5360,5432,"Mom,"],[5437,5543,"will you come back"],[5543,5744,"to celebrate my birthday today?"],[5796,5876,"Honey."],[5996,6188,"Mommy's always been here with you."],[6256,6396,"I just wish you could see me."],[6456,6516,"Mom!"]],"4":[[60,140,"Mommy!"],[368,448,"Mommy!"],[920,972,"Mom."],[980,1244,"Are you back to celebrate my birthday with me?"],[1340,1400,"Mom."],[1400,1560,"Shut up! Get out of my way!"],[1904,2084,"Who is making noise at this house?"],[2184,2304,"You filthy thing!"],[2312,2488,"That's my drinking money for tonight!"],[2544,2664,"I'll beat you to death!"],[2724,2856,"Don't bully my mom!"],[2896,3024,"This is none of your business!"],[3028,3088,"Get out!"],[3088,3208,"Nick! Move away!"],[3360,3452,"Trying to run?"],[3532,3818,"You're drunk, gambler, and you hit women."],[3912,4052,"You're no man."],[4320,4436,"Don't hurt my mom!"],[4436,4524,"Don't hurt my mom!"],[4524,4752,"Open the door!"],[4776,4836,"No, Nick..."],[4896,5012,"She's not your real mom."],[5156,5300,"You don't have to suffer for her."],[5436,5532,"You little brat!"],[5552,5672,"I'll show you something!"],[5976,6072,"Don't hurt my mom!"],[6216,6334,"Nick..."],[6334,6508,"Don't look. You shouldn't see this."],[6684,6784,"You beast!"],[6824,7036,"How can you do this in front of a child?!"],[7036,7173,"No! Don't hurt my mom!"],[7173,7308,"Don't hurt my mom!"],[7404,7484,"No! Nick!"],[7684,7764,"Ah!"],[8232,8276,"Hey!"],[8276,8372,"Get back here!"],[8392,8484,"Come back!"],[8500,8576,"Save Nick!"],[8584,8692,"You little rat!"],[8700,8820,"Ruining my fun?"],[8852,8992,"I'll teach you a lesson."],[8996,9052,"No!"],[9060,9172,"Don't hurt my son!"]],"5":[[20,128,"Don't hurt my son!"],[752,804,"Nick!"],[804,860,"Run!"],[1500,1772,"Is this my birthday gift from mom?"],[1772,1844,"Great!"],[1872,2100,"Mom is celebrating my birthday!"],[2104,2252,"I have to find her!"],[2336,2416,"Nick!"],[2724,2808,"Mom,"],[2812,2932,"where are you?"],[3180,3420,"Finally, mom got me a cake."],[3452,3600,"Mom, I'm right here!"],[3744,3812,"Mom!"],[4160,4232,"Nick!"],[4340,4404,"Nick!"],[4441,4528,"You're hurt!"]],"6":[[844,924,"Hey!"],[936,1024,"Back off!"],[1024,1136,"I just cleaned the windows."],[1136,1228,"Don't smear it."],[1228,1320,"Get out of here!"],[1320,1404,"Nick!"],[1408,1632,"How can you treat a child like this?"],[1632,1788,"Baby, I'm so sorry."],[1912,2292,"Happy birthday to Tommy."],[2296,2584,"Happy birthday to you."],[3032,3104,"Sis,"],[3104,3247,"you have to celebrate my birthday"],[3247,3364,"with me every year."],[3372,3520,"Okay, I promise."],[3532,3644,"My pumpkin."],[3644,3852,"I'll be by your side every year."],[3864,3944,"Always."],[4732,4840,"Who let you in here?"],[4840,4900,"Miss."],[4900,5032,"My mom is inside."],[5132,5224,"Your mom?"],[5388,5628,"Do you think your mom can even afford this place?"],[5628,5728,"Get out of here!"],[5908,6020,"Excuse me, waiter."],[6338,6465,"Nick, I'm sorry."],[6540,6699,"This is all my fault."],[7120,7200,"Rita!"],[7340,7520,"My babies can finally meet each other."]],"7":[[4,192,"Hey, little guy. Do you want some cake?"],[244,292,"Really?"],[292,380,"I can have it?"],[380,480,"Of course!"],[480,584,"Why you are here alone?"],[588,692,"Where are your parents?"],[692,860,"I came to find my mom,"],[956,1052,"That woman!"],[1052,1164,"She is my mom!"],[1220,1328,"You mean Aunt Paige?"],[1328,1440,"I'll go get her for you."],[1512,1652,"No, Rita, don't go."],[1660,1772,"He's your brother."],[1800,1868,"Why?"],[1944,2088,"Why can't you hear me?"],[2092,2260,"Is there really nothing I can do/"],[2284,2492,"So this is what cake tastes like?"],[2540,2660,"It's so sweet."],[2672,2852,"I should save some for my mom."],[2908,3072,"My sweet boy..."],[3080,3212,"Always thinking of others."],[3332,3560,"You think you deserve my cake!?"]],"8":[[0,184,"You think you deserve my cake!?"],[184,300,"My cake!"],[300,504,"What do you mean your cake?"],[504,724,"That's a birthday cake from my dad!"],[724,772,"I..."],[864,1160,"This cake was ordered personally by Mr. Franklin,"],[1160,1292,"for the young master."],[1326,1415,"Now look at you."],[1415,1580,"You don't deserve any cake!"],[1596,1808,"How dare you speak to my son like that!"],[1820,2060,"The person who doesn't deserve it is him!"],[2088,2332,"The cake should've been all for my son!"],[2352,2504,"That's my cake!"],[2508,2680,"I decide who gets to eat it,"],[2680,2992,"I'd rather give it to my dog than to a beggar like you!"],[2992,3120,"This is disgusting!"],[3120,3352,"What kind of a child did the Franklins raise?"],[3400,3532,"My dad will be here soon."],[3544,3884,"Make sure you get this little street rat out of here"],[3900,4104,"before he embarrasses us!"],[4104,4260,"My son is not a beggar!"],[4288,4428,"You are in character."],[4488,4688,"Don't you dare speak to my son like that!"],[4980,5320,"Do you even know who the young master is?"],[5328,5608,"He is the son of the richest man in town."],[5620,5736,"And you don't belong here!"],[5736,5848,"Now scram!"],[5880,6030,"No, my mom's inside!"],[6030,6160,"I won't leave!"],[6160,6272,"That's the Franklin kid."],[6308,6504,"Poor boy. He just messed with the wrong family."],[6584,6696,"What's going on?"],[6700,6860,"Who's bothering our young master?"],[6860,6936,"Mom..."]],"9":[[8,188,"Mom, he called me a beggar!"],[188,328,"What are you doing here?"],[328,532,"Apologize to young master Tommy now!"],[532,648,"You are a beggar!"],[648,864,"Apologize NOW!"],[864,992,"I'm sorry..."],[1004,1116,"What's going on here?"],[1152,1392,"I just wanna celebrate my birthday too..."],[1392,1652,"You think you can share the same birthday with me?"],[1656,1809,"You're not allowed to celebrate."],[1809,1932,"You hear that."],[1948,2108,"Do you even know your place?"],[2112,2340,"You want a birthday so badly, fine!"],[2340,2420,"You better go home"],[2420,2632,"and I'll give you a birthday to celebrate."],[2632,2960,"Why does mom celebrate his birthday"],[2960,3140,"but never mine...?"],[3148,3336,"Talking back now?"],[3336,3492,"You think you're on his level?"],[3492,3808,"She's pathetic—licking the boot sores like that."],[3808,3900,"Disgusting!"],[3908,4160,"Seriously, lost all the dignity!"],[4248,4384,"Come on. Go home now!"],[4444,4492,"Wait."],[4536,4684,"Yes, young master. What is it?"],[4684,4876,"What? You're still here?"],[4940,5384,"A maid's kid born on the same birthday as me?"],[5404,5536,"Ugh, what a joke."],[5560,5665,"But Tommy..."],[5665,5844,"I'm your real mother."],[5952,6056,"He hates you,"],[6064,6124,"your own son."],[6124,6264,"You didn't see that coming, did you?"],[6312,6412,"But it was worth it..."],[6444,6548,"I switched you at birth."],[6548,6696,"And now you're the richest"],[6696,6864,"young master in Golden City."],[6864,7056,"You're right, young master."],[7076,7236,"We're just lowly servants."],[7260,7492,"We don't deserve to share the same birthday as you."],[7496,7676,"Some mother she is?!"],[7712,7880,"Doesn't protect her kid."],[7952,8160,"Acts like he's not even hers!"],[8180,8480,"Seriously? Suck up to rich folks so hard—"],[8532,8696,"forget who her son is."],[8704,9040,"Actually, since it's your birthday too..."],[9052,9220,"I'll give you a little cake."],[9220,9332,"No, no!"],[9368,9469,"He doesn't need any."],[9469,9600,"He's just a stray kid."],[9600,9712,"I'll take him home."],[9724,9880,"He doesn't deserve your cake."],[9884,10220,"Wait, what a waste to perfectly good cake."],[10340,10472,"How can a person eat that?"],[10473,10549,"Here!"],[10571,10680,"Have a bite!"]],"10":[[4,200,"No? Don't want it?"],[200,348,"You've gone too far!"],[348,392,"Paige,"],[392,544,"we're not being disrespectful"],[544,720,"to the young master, are we?"],[732,856,"Young master,"],[912,1200,"it's not that we're disrespecting you."],[1200,1472,"It's just that the cake is a bit dirty."],[1476,1640,"I thought he left cake earlier."],[1640,1888,"What if it's being a little dirty?"],[1888,2020,"He's filthy as well!"],[2076,2308,"Mommy, Mommy. I'm sorry, I'm sorry."],[2308,2480,"I won't run off again."],[2496,2780,"I don't want to eat the cake. The dog ate it..."],[2944,3116,"Look at this little loser!"],[3140,3348,"Huh? Serves you right!"],[3348,3428,"Cole,"],[3440,3628,"bring out the leftover cake."],[3724,3896,"So Nick, how's the cake?"],[3904,4016,"I don't know..."],[4016,4200,"But you never had cake before."],[4204,4312,"You poor thing!"],[4312,4484,"I'll be generous today,"],[4520,4652,"Here. Have a bite."],[4760,5020,"You and my dog. Let's see who can eat faster."],[5020,5200,"That is too much! I can't take it anymore!"],[5200,5328,"We can't get involved!"],[5924,6092,"Eat it! Come on, eat up!"],[6096,6208,"Don’t touch him!"],[6228,6392,"Didn't you really want cake?"],[6392,6504,"Why stop now?"],[6564,6748,"A sewer rat like you"],[6760,7060,"is only meant to complete with dogs for scraps!"],[7084,7192,"Let go of my son!"],[7240,7388,"- Let go of my son! - Madam?"],[7388,7429,"Madam!"]],"11":[[28,188,"Look at what your son is saying!"],[444,628,"Go catch him and get him back!"],[632,912,"Young master, this... This isn't right."],[912,1136,"You poor people deserve this."],[1144,1264,"I... I..."],[1276,1584,"Aunt Paige, is your family not used to this?"],[1584,1868,"No, that's not it."],[1872,2036,"Fine. Cole!"],[2040,2224,"Tell my dad that"],[2224,2504,"Aunt Paige doesn't want to be our nanny anymore."],[2528,2616,"Fire her!"],[2616,2684,"Wait!"],[2684,2752,"No..."],[2784,2920,"I'll go bring him back."],[2984,3100,"Are you crazy?"],[3120,3280,"Why are you listening to a child?"],[3280,3396,"Oh my God."],[3400,3508,"I'm calling the police."],[3508,3644,"This is a family matter."],[3644,3744,"Don't get involved."],[3748,3905,"No! Mom, I'm sorry!"],[3905,4160,"I will never eat cake ever again."],[4188,4492,"And I'll not celebrate my birthday ever again."],[4524,4664,"I can't lose this job."],[4684,4868,"I have to stay close to my son."],[5060,5152,"Eat it!"],[5152,5268,"Eat all of this!"],[5268,5448,"No. Mom, I don't want to."],[5448,5580,"You beast!"],[5580,5732,"Are you even human?"],[5740,5844,"If I wake up,"],[5864,5996,"I'll never forgive you."],[6064,6168,"Come here!"],[6252,6352,"I'm telling you,"],[6364,6612,"neither my sister nor my cake"],[6612,6800,"is for you to touch!"],[6800,6972,"I didn't! I didn't!"],[6972,7116,"You dare to talk back!?"],[7116,7284,"I'll do it myself!"],[7540,7727,"This is too much! I cannot take it anymore!"],[7727,7832,"We can't get involved."],[7832,7920,"Please help my son!"],[7940,8104,"Please help my son!"],[8164,8308,"Please! Somebody help him!"],[8364,8590,"Memi, you're fucking useless!"],[8662,8846,"You can't even help your child!"],[8860,8984,"Don't hurt my son!"],[9076,9140,"Doctor!"],[9140,9312,"Someone call the doctor. Now!"]],"12":[[168,272,"Darling..."],[280,352,"Memi?"],[380,440,"Memi."],[472,540,"Are you okay?"],[644,792,"Stop it! What are you doing?"],[812,868,"Sis."],[868,976,"Why did you come out?"],[976,1068,"What's happening?"],[1068,1228,"He's hurting your little brother!"],[1248,1352,"Rita, help him!"],[1360,1470,"I... I don't know."],[1470,1767,"He was the one who wanted to fight the dog"],[1767,1900,"for the cake."],[1912,2136,"Aunt Paige was just trying to stop him."],[2152,2232,"Really?"],[2232,2348,"Yes. Yes."],[2360,2468,"My son is greedy."],[2468,2648,"He kept trying to fight with the dog."],[2660,2848,"You filthy brat! You go back home!"],[2848,3028,"It's not true! It's not like that!"],[3036,3092,"Sis."],[3092,3206,"This is an adult matter."],[3206,3372,"We should go back to our table."],[3512,3680,"Young master, wait for me."],[3716,3808,"It's all my fault."],[3808,4008,"I'm so sorry. I should've protected you."],[4184,4276,"Hey, little guy."],[4276,4372,"Are you okay?"],[4544,4724,"Rita, help your little brother!"],[4888,5016,"I'm sorry, Mom."],[5064,5296,"I won't have another birthday again."],[5304,5496,"I'll never eat cake again."],[5512,5668,"Where do you live? I'll take you home."],[5668,5764,"Home?"],[5788,5856,"Home!"],[5884,5984,"Where are you going?"],[6024,6236,"Rita, follow Nick. Quick!"],[6256,6336,"Mom?"],[6584,6676,"Wait for me."],[7128,7328,"Mom doesn't like me."],[7376,7556,"Dad doesn't like me."],[7584,7764,"No one likes me."],[8084,8192,"Silly boy."],[8284,8428,"Mom doesn't hate Nick."],[8484,8656,"Mom loves Nick the most."],[9508,9588,"You..."],[9612,9672,"Miss!"],[9672,9780,"What are you doing here!"],[9780,9900,"Madam is waking up!"],[9908,9976,"What?"],[9984,10088,"Mom has woken up?"]],"13":[[4,120,"Madam is waking up!"],[120,172,"Really?"],[172,240,"That's great!"],[240,348,"I wanna see Mom."],[352,512,"Rita, don't leave Nick."],[540,680,"Don't leave Nick behind."],[848,916,"Little boy."],[920,1080,"Let me bring you to your mom."],[1096,1244,"Mom doesn't like me."],[1244,1456,"I won't look for Mom anymore."],[1468,1640,"No, there isn't a mom in the world"],[1640,1780,"that doesn't love her child."],[1784,1848,"Really?"],[1848,1980,"Really. Let's go."],[2772,2856,"Madam is just"],[2856,3044,"experiencing a normal physical condition."],[3072,3208,"She might not just wake up."],[3284,3364,"Darling."],[3432,3536,"Wake up soon."],[3548,3664,"We all miss you."],[3880,3960,"Come in."],[4052,4120,"Mom!"],[4120,4216,"Is she awake?"],[4392,4516,"She's not awake...?"],[4596,4676,"Honey!"],[4760,4828,"It's your son."],[4828,4940,"Your real son!"],[5032,5112,"Who is this?"],[5168,5264,"This is the little boy we met"],[5264,5404,"at Tommy's birthday party today."],[5404,5508,"It's his birthday too."],[5524,5628,"This child..."],[5636,5740,"his features..."],[5748,5956,"they look so much like Memi."]],"14":[[50,88,"Dad!"],[88,228,"Dad, is Mom awake?"],[228,340,"Not yet, Tommy."],[396,488,"Do you miss Mom?"],[864,944,"Good."],[960,1068,"She didn't wake up."],[1124,1284,"Did I imagine it?"],[1344,1512,"Why are you here?"],[1524,1704,"I'm looking for my mom."],[1704,1904,"There's only my mommy here."],[1928,2088,"I don't have a son like you."],[2164,2312,"Why are you here?"],[2436,2540,"I brought him here."],[2568,2836,"It's not safe for him to be out alone at night."],[2932,3100,"You little brat!"],[3100,3252,"I told you to go home, right?"],[3252,3452,"Why didn't you listen? You can't just come here!"],[3452,3540,"Get home now!"],[3540,3652,"Let him go!"],[3700,3960,"Take your imposter son and get out of my house!"],[3960,4112,"Is this your son?"],[4192,4388,"Yes, I'm sorry, sir."],[4408,4588,"He's too disobedient,"],[4592,4693,"Running around everywhere,"],[4693,4820,"causing you trouble."],[4828,4976,"Don't worry. I'll take him home now."],[4992,5072,"Mandel."],[5148,5296,"You can't let her take our son."],[5388,5588,"If Nick is back, she'll abuse him."],[5600,5748,"No, no. It's fine."],[5780,5868,"He seems like a..."],[5932,6060,"well-behaved little boy."],[6096,6176,"Anyway,"],[6192,6456,"it's very dangerous for him to be going home alone"],[6460,6540,"at this time of night."],[6612,6752,"Let him stay here tonight."],[6752,6840,"No!"],[6976,7176,"Thank you for your kindness, sir."],[7212,7396,"But he's too mischievous."],[7396,7576,"He's dirty and smelly."],[7596,7808,"I'm afraid he'll affect Madame's recovery."],[7808,7912,"I'll take him home right now."],[7912,8008,"Well, indeed."],[8016,8148,"He's probably full of germs."],[8148,8268,"Don't let him infect Madam."],[8300,8364,"Cole."],[8364,8460,"Be quiet."],[8492,8572,"Let's go."],[8692,8852,"I can't let her take Nick."],[8972,9056,"Wake up!"],[9220,9300,"Quick!"]],"15":[[8,112,"Call the doctor!"],[184,368,"Memi, are you waking up?"],[536,644,"Impossible!"],[652,776,"How can she wake up?"],[788,868,"Mom!"],[1112,1260,"What are you doing here?"],[1260,1380,"How dare you touch Madam!"],[1392,1552,"You're so dirty and smelly."],[1552,1724,"Stay away from my mom."],[1724,1852,"You little rat!"],[1852,1992,"I'm not a rat!"],[1992,2196,"Your clothes are dirtier than our rags,"],[2196,2324,"you little unloved bug."],[2324,2492,"Stay away from my mom."],[2496,2604,"Well, indeed."],[2628,2712,"You're so dirty."],[2712,2876,"Who knows what nasty diseases"],[2876,2960,"you brought with you."],[2960,3096,"Just don't infect Madam."],[3104,3220,"I'm not sick!"],[3236,3320,"When I wake up,"],[3320,3532,"all of you're gonna get kicked out of this house!"],[3532,3684,"Stay away from my mom!"],[3712,3788,"Didn't you hear me?"],[3788,3940,"Stay away from my mom!"],[3940,4020,"Are you okay?"],[4087,4175,"Nick."],[4192,4308,"Are you okay?"],[4308,4380,"Tommy!"],[4416,4504,"That's not polite!"],[4524,4772,"Dad, I was just worried that he would infect Mom."],[4792,4932,"I know you care about Mom,"],[4940,5120,"but you don't go around pushing people."],[5120,5216,"Okay."],[5220,5400,"Stop pretending to be good!"],[5400,5632,"Hurry up and take your dirty child away."],[5640,5860,"Sir, I'm sorry. I'll take him away right now."],[6016,6140,"Nick can't leave."],[6188,6296,"Don't go!"]],"16":[[24,104,"Wait!"],[144,224,"Let him go!"],[996,1100,"Madam appears..."],[1124,1240,"seems very sensitive,"],[1240,1460,"especially to the little boy's simulation."],[1460,1664,"Could this little boy..."],[1664,1832,"really help Memi?"],[1888,1968,"What's your name?"],[1988,2240,"His name is Nick Kerry."],[2252,2352,"Well."],[2352,2500,"Ever since you've been here, Nick,"],[2556,2744,"my wife's condition has improved."],[2816,2880,"Paige."],[2892,2976,"I want you"],[2980,3220,"to allow your son to stay at the Franklin house,"],[3220,3380,"let him accompany Madam."],[3400,3540,"No, sir..."],[3582,3760,"If this brat stays here,"],[3760,3932,"his identity will be discovered."],[3972,4192,"No! Absolutely not!"],[4380,4552,"Here's a million dollars."],[4592,4784,"Consider it a gift for Nick."],[4864,5124,"And from now on, your salary will be doubled."],[5132,5404,"This isn't appropriate, sir."],[5420,5464,"Nick,"],[5488,5748,"would you like to stay at your uncle's house?"],[5756,5852,"And accompany Auntie?"],[5852,5940,"Nick!"],[6008,6108,"Please say yes."],[6108,6188,"Please say yes."],[6236,6316,"Okay."],[6416,6548,"Then it's settled."],[6660,6976,"My son is the rightful heir of the Franklin family."],[7020,7260,"This brat must never be recognized."],[7352,7648,"Sir, my son doesn't know anything."],[7672,7856,"He'll ruin Madam's recovery."],[7856,8004,"It's better not to..."],[8004,8076,"Dad, look!"],[8252,8464,"Mom is still holding Nick's hand."],[8496,8632,"Mom must like Nick too."],[8656,8716,"Paige."],[8740,8891,"Are you refusing because you think"],[8891,9148,"the Franklin family will treat your son badly?"],[9148,9328,"No. No."],[9328,9396,"Well then."],[9404,9524,"What are we waiting for?"],[9536,9584,"Cole!"],[9596,9704,"Make the arrangements."],[9708,9804,"Very well, sir."],[9892,9988,"Great!"],[10000,10188,"Dad will definitely recognize you."],[10192,10352,"Memi, you're really stubborn."],[10404,10624,"But too bad you'll never wake up."],[10636,10756,"As for your son,"],[10764,11044,"I'll make sure he's thrown out of the Franklin family."]],"17":[[932,1096,"Nick hasn't eaten all day."],[1132,1260,"He must be starving."],[1472,1592,"Don't touch this!"],[1744,1824,"Eat it!"],[1824,1960,"Are you even human?"],[1976,2128,"How can he eat this!?"],[2136,2292,"This bread is hard as a rock."],[2292,2440,"He can't chew it!"],[2596,2916,"Here's the young master's favorite dessert."],[2920,3048,"Oh, but please promise"],[3048,3256,"you finish your meal before you have your dessert."],[3256,3412,"I know."],[3476,3556,"Tommy!"],[3564,3728,"Don't speak to Karina like that."],[3740,3916,"Okay..."],[3936,4184,"I wonder where this child's personality comes from."],[4220,4448,"Have I spoiled him too much?"],[4616,4676,"Mom,"],[4676,4804,"I can't chew it."],[4808,4920,"You're so picky."],[4920,5028,"Eat it or don't!"],[5032,5228,"Mom, I want to eat it too."],[5232,5336,"Eat what?"],[5340,5436,"I'm telling you!"],[5476,5668,"Don't dream of a life that's not yours."]],"18":[[12,148,"How can you say that?"],[236,424,"If you hadn't switched my son,"],[424,796,"your son wouldn't have the right to sit here and eat."],[860,1200,"Your son stole my son's life!"],[1416,1596,"Dad, can Nick come and eat with us?"],[1636,1728,"Of course, darling."],[1728,1808,"Go and call him."],[2104,2280,"Come eat at the table with us, Nick."],[2284,2416,"This isn't appropriate."],[2416,2537,"We're just servants."],[2537,2780,"We can't eat at the master's table."],[2800,2873,"It's okay."],[2873,2973,"My dad approved."],[2973,3064,"Let's go, Nick."],[3280,3376,"Sit here, Nick."],[4484,4564,"Karina?"],[4564,4632,"What's wrong?"],[4680,4820,"Oh, I'm sorry, sir."],[4820,4904,"It's just that..."],[4912,5060,"when I look at this child,"],[5060,5332,"I see a lot of resemble with Madam"],[5348,5460,"when she was young."],[5648,5780,"Yes, Karina."],[5792,5996,"You remember me from when I was a child."],[6012,6296,"You have to help Mandel recognize our son."],[6308,6468,"Now I see it."],[6472,6796,"Nick does look more like Memi than Tommy."],[6820,6908,"Could it be..."]],"19":[[88,348,"Oh, Karina. You must be joking."],[408,544,"Nick is just an ordinary boy."],[544,760,"He can't possibly compare to Madam."],[784,868,"Ugh."],[900,1051,"What am I thinking?"],[1051,1146,"I'm sorry, sir."],[1146,1300,"I just spoke out of turn."],[1312,1392,"It's alright."],[1440,1580,"Let's get back to eating."],[1584,1680,"A shrimp!"],[1768,1960,"Nick is allergic to seafood too."],[2000,2200,"Rita, give Nick a shrimp."],[2200,2360,"Give Nick a shrimp."],[2664,2800,"You're too thin, Nick."],[2824,2904,"Have a shrimp."],[2944,3068,"Thank you, Rita."],[3248,3512,"Use this to wipe your hand, little rat!"],[3560,3788,"Karina, can we get Nick a towel, please?"],[3788,3860,"Of course."],[4210,4280,"Here you are."],[4280,4380,"Thank you."],[4400,4580,"Even if you wipe your hands,"],[4600,4804,"you can't hide your stench."],[4804,4992,"Tommy, what have I told you about"],[4992,5104,"talking and eating?"],[6024,6188,"Dad, what's happening to Nick?"],[6188,6412,"This must be an allergic reaction!"],[6412,6564,"- Allergic? - Yes!"],[6568,6808,"Back to when Madam was allergic to seafood,"],[6808,6984,"she used to have similar symptoms!"],[7020,7204,"That's right, Karina, you remember."],[7232,7448,"Mike has the same allergic reaction to me!"],[7484,7624,"You have to help Mandel"],[7624,7764,"recognize his child!"],[7816,7896,"Memi?"]],"20":[[8,252,"You said Memi was allergic to seafood too?"],[260,346,"Yes, sir."],[346,504,"Ever since Madam showed"],[508,732,"allergic reaction to the seafood back in childhood,"],[732,864,"she never tried it again."],[864,1008,"Mandel, think about it!"],[1040,1300,"Nick... he looks like me when I was a child,"],[1300,1492,"and he's also allergic to seafood!"],[1544,1688,"He's your real son!"],[1688,1892,"How can it be such a coincidence?"],[1892,2172,"This child comes and Mimi's condition improves,"],[2188,2400,"his features resemble Memi,"],[2412,2648,"and he's allergic to seafood too?"],[2648,2916,"No! They must not suspect!"],[2916,3180,"I must find a way to kick this brat out!"],[3210,3382,"Nick, are you okay?"],[3382,3604,"Let's go. Mom will take you to the hospital right now."],[3608,3832,"It will take too long to get him to a hospital now."],[3832,4124,"Karina, please go and get the allergy medication."],[4124,4244,"I'll help you find it."],[4312,4396,"No!"],[4432,4588,"I must send this brat away!"],[4624,4888,"Otherwise, everything will be exposed!"],[4908,5164,"Sir, this is the first time I've encountered this."],[5164,5324,"It's best if I take him to the hospital."],[5324,5476,"I'll feel more at ease like that."],[5508,5588,"Come on, let's go."],[5736,5932,"Honey, you can't let her take Nick!"],[5936,6108,"This woman has bad intentions,"],[6108,6312,"she definitely won't take Nick to the hospital!"],[6312,6572,"The nearest hospital is over a half an hour away."],[6612,6852,"By the time he gets there, he might be dead!"],[6896,6976,"Cole,"],[7016,7228,"go and call the doctor who's taking care of Madam!"],[7232,7312,"Yes, sir!"],[7336,7496,"Really, no need to trouble you!"],[7496,7652,"I'll get him to the hospital right now!"],[7768,7848,"Stop!"]],"21":[[172,388,"Isn't this my sister's pendant?"],[408,552,"Why do you have it?"],[560,724,"No, it's mine."],[740,840,"Dad, look."],[1060,1272,"It really is Rita's pendant."],[1288,1448,"It's not Rita's!"],[1468,1720,"Look closer, this is the pendant I left for Nick!"],[1720,2064,"This is the pendant from the swaddling clothes!"],[2112,2232,"Wasn't it hidden?"],[2280,2484,"How did it end up on this brat?"],[2492,2712,"So this is how you repay the master!"],[2712,2788,"He took you in,"],[2788,3068,"gave you a meal, and you have the audacity to steal!"],[3068,3144,"Cole."],[3168,3281,"Shut up!"],[3281,3500,"You have no right to say anything here."],[3504,3764,"It seems Rita also has a pendant."],[3800,3960,"If she brings out the other one,"],[4000,4180,"everything will be exposed!"],[4180,4376,"No. I must find a way."],[4376,4520,"You little brat!"],[4530,4633,"You're stealing again?"],[4633,4812,"You've always been up to no good."],[4820,5008,"Now you're even stealing from the Miss?"],[5052,5224,"Don't slender my child!"],[5240,5432,"You're the thief, stealing my son's life!"],[5432,5560,"I must've misjudged him."],[5644,5784,"I thought he was a good kid,"],[5812,6040,"but he's actually so dishonest."],[6040,6372,"Nick, why did you steal Rita's pendant?"],[6376,6612,"Mandel, how can you not believe your own son!?"],[6652,6772,"He wouldn't steal!"],[6772,6932,"I didn't steal it..."],[7012,7096,"It's mine..."],[7096,7212,"You're lying!"],[7216,7564,"This pendant was left by my mom for my sister."],[7572,7772,"How could you possibly have it?"],[7776,7876,"That's right."],[7936,8124,"Memi prepared an identical pendant"],[8124,8240,"for Tommy back then,"],[8272,8500,"but after the accident, it went missing."],[8512,8712,"I thought it was lost in the crash."],[8776,8900,"Could it be..."],[8904,9164,"Sir, I'll take him back and discipline him properly!"],[9180,9272,"Let's go!"],[9504,9540,"Wait! You have misunderstood Nick!"],[9564,9720,"Wait! You have misunderstood Nick!"],[9720,9884,"My pendant has always been on me!"]],"22":[[20,188,"My pendant has always been on me!"],[392,492,"Where's my pendant?"],[504,640,"Sister, where's your pendant?"],[732,892,"I don't know. I can't find it."],[892,972,"How?"],[1064,1180,"That's impossible!"],[1204,1348,"Then you must've stolen it!"],[1356,1476,"You little thief!"],[1480,1648,"Dad, I hate thief,"],[1656,1868,"I don't want to be friends with a thief!"],[1912,2040,"How could it be missing?"],[2040,2188,"Did you really steal it, Nick?"],[2204,2380,"No, I didn't steal it..."],[2396,2516,"I was wrong about you."],[2568,2796,"I didn't expect you to be this kind of child!"],[2848,2992,"You've really disappointed me!"],[3012,3228,"No, must be a misunderstanding."],[3228,3408,"Can't you think, Mandel?"],[3440,3764,"Aunt Paige, did you teach Nick to steal?"],[3788,4060,"Well, indeed. Your family is being so poor."],[4116,4280,"You have a drunk gambler husband."],[4280,4416,"You probably stole the Miss's things"],[4416,4528,"to sell for money!"],[4528,4724,"No, no, I didn't!"],[4744,4856,"You're dishonest,"],[4936,5176,"and your mother must not be any better!"],[5176,5416,"Sir, no. I really didn't!"],[5444,5604,"Sir, I found the medicine..."],[5768,5900,"You little brat!"],[5904,6002,"You stole this on your own!"],[6002,6156,"It has nothing to do with me!"],[6156,6288,"You better explain yourself."],[6288,6436,"Otherwise, no medicine for you!"],[6436,6704,"No! Nick will die without this medicine!"],[6724,6904,"Pick it up, quick!"],[7272,7464,"Wake up! Wake up!"],[7496,7588,"Please wake up!"],[7612,7751,"Nick, don't scare me!"],[7751,8032,"Mandel! Give him the medicine now!"],[8088,8244,"Is a pendant more important"],[8244,8356,"than a child's life?"],[8376,8504,"Give him the medicine!"],[8504,8684,"Why did you steal it? Say it!"],[8684,8872,"You did this on your own. Say it!"],[8876,9029,"I didn't steal it, Mom."],[9029,9260,"Believe me... I didn't steal it."],[9276,9492,"If you don't confess, I'll disown you!"],[9508,9676,"Mom, I didn't steal it."],[9676,9848,"I really didn't steal it."],[9848,9884,"Honey,"],[9884,10012,"give him the medicine now,"],[10012,10144,"and deal with this later, okay?"],[10208,10388,"Mandel! Do you even have a heart?"],[10388,10512,"How can you just stand there,"],[10512,10748,"and watch two adults bully a child!?"],[10752,10900,"What's wrong with you?"],[10900,11076,"Everyone, shut up!"]],"23":[[8,188,"Were you raised without a mother?"],[212,352,"Like mother, like son!"],[408,540,"Get out of my house!"],[572,756,"Mandel! Are you out of your mind!"],[800,1000,"You can't even recognize your son."],[1128,1296,"And even if he wasn't your son,"],[1296,1412,"how can you just stand there,"],[1412,1536,"watching him suffer!?"],[1580,1876,"I'm sorry, sir. Please don't fire me."],[1900,2172,"Please let me keep taking care of the young master."],[2172,2376,"I've been taking care of him since he was young,"],[2376,2496,"I watched him grow up."],[2496,2664,"Please don't fire me!"],[2664,2744,"Sir!"],[2812,3012,"Nick's allergy is getting really worse."],[3032,3232,"Can we give him the medicine first please?"],[3240,3332,"Fine."],[3552,3676,"Considering you've been looking after"],[3676,3824,"Tommy for so long,"],[3904,4004,"I'll let this slide."],[4042,4156,"You can stay."],[4156,4464,"But I never want to see your son again!"],[4480,4676,"Yes, I'll take him away right now!"],[4676,4772,"Get up!"],[5056,5196,"No, no!"],[5208,5444,"If she goes right now, he's gonna get beaten to death!"],[5656,5748,"The pendant..."],[6216,6352,"Okay, come on. Enough. Let's go."],[6352,6432,"Okay."],[6552,6632,"That's it!"],[6688,6888,"Rita's pendant... She lost it back then!"],[7092,7356,"Rita, your pendant's on the lawn!"],[7532,7678,"Your pendant's on the lawn, Rita."],[7678,7832,"Go find it, quick!"],[7956,8044,"The lawn...?"],[8244,8580,"Wait, you're just going to leave after stealing?"],[8608,8928,"Dad, doesn't he need to apologize for stealing?"],[8936,9080,"I didn't steal!"],[9124,9268,"Apologize now!"],[9271,9405,"You're still lying!"],[9405,9516,"Mom, believe me!"],[9516,9724,"I didn't steal that pendant!"],[9732,9896,"It isn't stolen..."],[9904,10068,"Shut up!"],[10068,10272,"But the pendant fell off you,"],[10308,10536,"and my sister's pendant is missing,"],[10576,10764,"If you didn't steal it,"],[10788,10876,"who did?"],[10884,11128,"It wasn't me... I didn't steal it,"],[11128,11336,"Why wouldn't you believe me?"],[11364,11524,"Still not admitting it, huh?"],[11536,11712,"Then I'll beat you till you confess!"],[12188,12416,"Oh no! Nick is about to be taken away."],[12464,12704,"Rita! The pendant is here!"]],"24":[[292,352,"Rita!"],[352,452,"Look here!"],[476,569,"Say it!"],[569,706,"I didn't do anything wrong!"],[706,872,"Why should I apologize?"],[872,1072,"The kid is so insistent."],[1116,1336,"Maybe he really didn't steal it?"],[1392,1668,"But Rita's pendant is really missing."],[1684,1928,"If you don't apologize, I'll disown you!"],[1934,2042,"Enough!"],[2042,2304,"Hitting him like this is just forcing him."],[2400,2720,"Nick, I'm going to give you one final chance."],[2720,3120,"Now, tell me, did you steal it or not?"],[3176,3280,"Little rat!"],[3312,3612,"If you don't apologize, I'll make dad fire her!"],[3612,3868,"Make your mom lose her job!"],[3912,4088,"Mom, I really didn't steal..."],[4264,4344,"Nick."],[4404,4592,"Please apologize now."],[4604,4732,"I can't lose this job."],[4732,4932,"If I lose this job, your dad will kill me!"],[4932,5216,"Nick, tell me. What's going on?"],[5216,5324,"I..."],[5486,5577,"Found it!"],[5577,5756,"I knew Nick wasn't that kind of person!"],[5760,6008,"I'll go tell dad, Nick really didn't steal the pendant!"],[6040,6160,"I'll apologize..."],[6160,6268,"I'm sorry..."],[6348,6512,"Just don't fire my mom..."],[6512,6640,"Don't fire her..."],[6672,6864,"Fine, you can go."],[6908,7020,"I won't fire your mom."],[7076,7336,"Paige, you better discipline your child."],[7348,7608,"Yes, yes, sir. I'll definitely discipline him."],[7622,7742,"Let's go."],[7864,8024,"Dad, I found my pendant!"]],"25":[[12,224,"Dad, this is my pendant."],[440,688,"Memi prepared two pendants back then,"],[700,928,"saying she give one to each child."],[952,1228,"But Tommy's pendant was missing after the accident."],[1230,1412,"Now the pendant is on Nick."],[1412,1520,"Could it be...?"],[1552,1720,"Dad, where's Nick?"],[1736,2004,"He admitted to stealing the pendant and left."],[2004,2120,"I lost my pendant"],[2120,2288,"while playing with you on the lawn."],[2288,2428,"How could he have stolen it?"],[2428,2700,"I don't know. He admitted it himself."],[2748,2928,"Dad, Nick really didn't steal."],[2960,3204,"I understand. We've wronged Nick,"],[3232,3344,"I'll handle this."],[3344,3480,"It's late now."],[3480,3680,"You should go to your room and get some sleep."],[3696,3844,"Take them to their rooms, please."],[3876,3956,"- Yes, sir. - Yes, sir."],[4080,4312,"Why is Tommy's personality like this,"],[4312,4452,"while Nick is more like Mom?"],[4492,4700,"And Nick has a pendant just like mine"],[4700,4784,"but Tommy doesn't."],[5244,5384,"This is Nick's hair."],[5436,5620,"Karina, this is my hair, and this is Nick's."],[5620,5764,"Take it and do a DNA test."],[5764,5900,"Miss, this..."],[5902,6091,"I suspect Nick is my real brother."],[6091,6168,"Don't tell dad."],[6168,6336,"I want to investigate things myself."],[6352,6440,"Yes, Miss."],[6556,6680,"Could these pendants"],[6680,6880,"be the one that Memi left for our son?"],[6904,7244,"Honey, those pendants are a pair. They match!"]],"26":[[20,100,"Darling!"],[160,260,"You have to wake up."],[302,456,"I'm gonna go and find Nick right now."],[456,568,"Hold on!"],[652,840,"Yes, bring Nick back!"],[1104,1192,"You brat!"],[1208,1348,"How dare you return!"],[1544,1756,"This brat just sold for a good price!"],[1764,2016,"The Johnsons family's Nicholas just lost an eye,"],[2016,2212,"and he wants one of this brat's eyes."],[2284,2456,"They've offered $2 million!"],[2464,2752,"What? You agreed?"],[2752,2996,"Of course, one of that brat's eyes"],[2996,3184,"is gonna make us rich!"],[3268,3512,"All those years of raising him weren't wasted!"],[3540,3672,"You beast!"],[3692,3872,"You don't dare touch my son!"],[3888,4156,"Mom, please! I don't want to. I'm scared."],[4156,4356,"You're really going to sell him?"],[4356,4444,"Of course!"],[4464,4664,"The Johnsons are close with the Franklin family,"],[4664,4832,"the richest family in the city."],[4926,5067,"Once I get close to Nicholas,"],[5067,5196,"I'll be set for life!"],[5196,5380,"The Johnson Group is nothing!"],[5428,5636,"You don't dare touch my son!"],[5644,5870,"Mom, please! I don't wanna go blind!"],[5870,6004,"Mom, please..."],[6004,6132,"There's nothing I can do now."],[6156,6228,"Come on!"],[6284,6480,"I'll personally deliver you to Nicholas!"],[6480,6700,"Mom, save me! Save me!"],[6700,6904,"It's all because you're Memi's child!"],[6908,7152,"This is what you and your mom owe me!"],[7156,7312,"You're worth so much."],[7328,7512,"Dad will give you a proper send-off."],[7720,7988,"Let him go! Don't take him!"],[8104,8348,"Mandel, where are you when I need you?"],[8400,8540,"Save our son!"],[8632,8712,"Miss..."],[9240,9336,"No! Mom!"],[9336,9477,"Save me! Please!"],[9482,9629,"I won't run again, Mom!"],[9629,9820,"Please, I don't wanna go blind!"],[9820,9988,"Don't take my son! You bastard!"]],"27":[[3,86,"Oh my!"],[104,250,"You came personally!"],[284,388,"This is my son."],[388,616,"Please take a look, and see if he suits your needs."],[852,1089,"These are very nice."],[1089,1348,"I like the clarity in these eyes."],[1348,1472,"But this is your son."],[1536,1636,"Are you certain"],[1636,1768,"you wanna part with him?"],[1788,1896,"Of course!"],[2000,2156,"It'll be his honor to help you!"],[2208,2376,"You're selling my son for profit?"],[2472,2616,"You're gonna pay for this!"],[2628,2752,"But this is your son!"],[2752,2964,"You really are willing to do this?"],[2964,3064,"As long as the money's right,"],[3064,3188,"I'll give you both eyes!"],[3280,3708,"You are inhuman, willing to do this to your son."],[3728,3872,"But a deal's a deal,"],[3908,4328,"the money will be banked into your account as soon"],[4348,4536,"as I have the cornyards,"],[4536,4924,"and there is no backing out."],[4964,5028,"Got it."],[5064,5228,"- No backing out. - Bring him."],[5364,5441,"No!"],[5441,5574,"No! Let me go!"],[5574,5688,"Let me go!"],[5732,5851,"No! Let me go!"],[5851,5973,"Let me go!"]],"28":[[76,140,"No!"],[140,279,"No, let me go!"],[279,388,"Let me go!"],[388,468,"No!"],[472,552,"No!"],[604,684,"No!"],[936,1104,"No! Don't take my son!"],[1104,1204,"You bastards!"],[1264,1436,"Mandel, where are you when I need you!?"],[1580,1784,"No! Nick! Nick!"],[1884,1916,"Nick!"],[2028,2096,"Rita!"],[2144,2276,"Nick!"],[2288,2368,"Rita!"],[2712,2792,"Rita, wake up!"],[2844,2908,"Wake up!"],[2936,3048,"Please wake up!"],[3108,3196,"Wake up!"],[3544,3628,"Rita, please wake up."],[3628,3720,"Mommy?"],[3720,3860,"Please wake up."],[4092,4288,"Please go and save my girl!"],[4440,4528,"Rita, wake up!"],[4612,4680,"No, Rita!"],[4720,4788,"No!"],[4848,5092,"Don't fall asleep. No! Rita hold on!"],[5092,5321,"Rita, please, open your eyes..."],[5349,5487,"Don't scare me."],[5552,5788,"God, please save my girl!"]],"29":[[420,672,"Sir, what are you doing here?"],[684,764,"Paige,"],[820,932,"I'm here for Nick."],[996,1156,"Rita found her pendant."],[1196,1300,"We've wronged Nick,"],[1336,1536,"I'm going to compensate him,"],[1564,1848,"and make sure that he gets the finest education."],[1924,2216,"No, I can't let him find Nick!"],[2228,2308,"Well,"],[2324,2644,"Nick and his dad just went out to buy some groceries."],[2644,2784,"They won't be back for a while."],[2832,2964,"Why don't you come back tomorrow?"],[2964,3164,"And I'll bring Nick to your house."],[3164,3328,"Buying groceries this late?"],[3328,3392,"Well,"],[3392,3596,"his dad made some money"],[3596,3784,"and they wanted to celebrate,"],[3812,3968,"cook something nice."],[4004,4112,"Ah, I see..."],[4184,4364,"Alright, fine. Tomorrow then."],[4536,4764,"There's a big bag of groceries here,"],[4784,4892,"clearly just bought."],[4928,5002,"Why is she lying?"],[5002,5188,"Sir, take care."],[5468,5548,"Cole,"],[5592,5756,"find out where Nick is."],[5780,5860,"Yes, sir."],[6052,6192,"Riita, please open your eyes."],[6268,6368,"Don't scare me!"],[6652,6896,"God, please save my girl!"]],"30":[[584,648,"Boss!"],[648,745,"Bad news!"],[745,864,"The front team says..."],[880,980,"I'm busy."],[980,1380,"Whatever it is, it can wait until I am finished!"],[1600,1760,"The doctor will be here soon."],[1804,2232,"And then finally, I will have my new eye."],[2300,2460,"Congratulations in advance."],[2460,2612,"Wishing you a successful surgery."],[2676,2916,"You've done well, and you will"],[2972,3156,"be handsomely rewarded."],[3200,3392,"Thank you, boss!"]],"31":[[61,160,"Damn it!"],[160,358,"Who's messing with my plans!?"],[467,583,"Who the hell are you?"],[583,767,"How dare you lay your hand on Nicholas?"],[767,900,"You have a death wish!"],[921,1146,"Nicholas? From the Johnson Group?"],[1167,1267,"Mr. Mandel."],[1338,1484,"Why are you here?"],[1514,1685,"That's the heir to the Johnson Group!"],[1685,1818,"You think you can mess with him?"],[1881,1997,"I can't mess with him."],[2014,2143,"But the Johnson Group?"],[2193,2335,"You've got some nerve!"],[2356,2502,"Why are you here?"],[2502,2581,"Why am I here?"],[2581,2761,"I'm here because of Nicholas!"],[2761,2857,"I'm here to save him!"],[2857,2948,"What's wrong with him?"],[2948,3073,"There's nothing wrong with him."],[3073,3549,"He's only just had anethesia and he's asleep."],[3624,3807,"Okay, better be nothing wrong with him!"],[3874,3937,"Guard,"],[4004,4083,"take him."],[4295,4421,"If I have to come back here,"],[4437,4608,"the Johnson family is finished."],[4608,4688,"You hear me?"],[4967,5230,"Boss, who is that guy and why'd you let him go?"],[5242,5463,"Just say the words and I'll go after him right now!"],[5467,5647,"Chase after him my ass!"],[5647,5876,"What have you gotten me into?"],[5876,6160,"If you've gotten Mandel, they're pissed off at you!"],[6264,6343,"Mandel?"],[6502,6702,"The CEO of the Franklin family?"],[6785,6977,"The richest family in the city?"],[7077,7165,"I didn't know."],[7207,7561,"If you've wronged the Franklin family that much,"],[7636,7816,"you're never getting off the hook!"],[8504,8687,"Did the Franklin family just find out"],[8687,8871,"about that brat's identity?"],[9305,9392,"Bitch!"],[9505,9609,"That cheap brat was just"],[9609,9805,"taken by the Franklin family!"],[9930,9959,"I don't know"],[9959,10210,"if they found out about that brat's identity!"],[10260,10343,"What?"]],"32":[[291,371,"Mandel!"],[554,633,"Rita?"],[658,767,"What's going on?"],[1418,1497,"Rita!"],[1509,1605,"What's going on?"],[1626,1789,"Sir, you're finally here."],[1789,1918,"Miss was in a car accident!"],[1918,1997,"What?"],[2052,2168,"You are the family member?"],[2173,2344,"The patient has lost so much blood."],[2344,2464,"And needs a transfusion!"],[2510,2665,"But we're out of the matching blood type."],[2715,2840,"Well, how can this happen?"],[2873,3090,"Find someone with the matching blood!"],[3111,3186,"Doctor,"],[3186,3336,"the patient's condition is worsening."],[3336,3474,"She needs surgery immediately."],[3486,3682,"Take her to the operation room now."],[4312,4521,"The patient has RH negative blood,"],[4596,4700,"which is very rare."],[4783,4925,"Our blood bank doesn't have that type."],[5009,5146,"Your blood bank doesn't have that?"],[5146,5284,"Well, go find someone!"],[5388,5547,"What did I do to deserve this?"],[5630,5880,"If anybody has to be punished, let it be me,"],[5880,6018,"not my children."],[6156,6297,"They did nothing wrong."],[6473,6610,"I'll pay any amount!"],[6865,7161,"Karina, why were you out so late with Rita?"],[7161,7453,"Sorry, sir. But Miss had done a DNA test with Nick."],[7453,7582,"When she received the report,"],[7582,7728,"she wanted to go and find Nick."],[7741,7941,"But then, the accident happened."],[8002,8101,"A report?"],[8101,8244,"What is this gonna tell me?"],[8244,8349,"Nothing!"],[8387,8696,"The priority is finding the right blood type for Rita!"],[8712,8762,"Yes, sir."],[8762,8879,"What are you waiting for?"],[8879,8942,"Go!"],[8942,9038,"Yes, sir!"],[9396,9460,"Dad!"],[9460,9655,"Dad, what's wrong with this?"],[9676,9801,"Tommy, come here."],[10001,10243,"Your sister has lost a lot of blood."],[10268,10418,"And she's unconscious."],[10456,10552,"We need to find someone"],[10552,10727,"who has the same blood type as her"],[10727,10835,"to revive her."],[10877,11177,"Dad, are you going to take my blood for sis?"],[11236,11361,"No, no. I'm scared..."],[11361,11498,"I'm scared of pain!"],[11544,11686,"It's okay. Silly boy."],[11724,11995,"You are a direct relative of your sister."],[12016,12103,"It means that,"],[12128,12379,"direct relatives can't give each other blood."],[12395,12479,"You understand?"],[12633,12725,"Say it — you understand."],[12725,12791,"Okay."],[12791,12958,"Okay, good, good."],[12979,13171,"Is this boy just selfish?"],[13213,13417,"Or does he not care much for Rita?"],[13475,13705,"Sir, we found someone with the blood type."]],"33":[[27,314,"Sir, we found a person with the right blood type,"],[314,392,"but..."],[467,575,"But what?"],[642,846,"The Franklin family can get anything!"],[846,984,"Is the person unwilling?"],[1011,1111,"No, sir."],[1111,1380,"But that person is Nick."],[1447,1530,"Him?"],[1589,1668,"No, Mandel."],[1726,1851,"Nick is your son."],[1876,2034,"You can't use him to save Rita."],[2034,2164,"Don't be stupid."],[2394,2652,"Karina, this is the report you dropped earlier."],[2886,3023,"Why does it have to be him?"],[3061,3182,"Ever since he showed up,"],[3182,3407,"my family has been in chaos."],[3440,3545,"If it wasn't for him,"],[3553,3749,"Rita wouldn't have gone out searching"],[3749,3953,"and the accident would never have happened."],[4020,4325,"But sir, maybe you should take a look at this first."],[4688,4863,"Yes, honey. Have a look!"],[4917,5046,"You'll find out the truth."],[5046,5167,"Nick is your son."],[5401,5576,"Good thing I forged a report."],[5593,5814,"Mandel, you'll never find your real son."],[5976,6235,"I knew it, I knew there was no way that"],[6235,6460,"this boy could be related to a Franklin."],[6473,6627,"Tommy is my son!"],[6835,6961,"How is this possible?"],[7127,7207,"No..."],[7244,7323,"No..."],[7323,7453,"There must be some mistake."],[7607,7695,"It's you!"],[7745,8045,"Think you can fake this and deceive everyone?"],[8204,8337,"Once I awaken,"],[8366,8608,"I'll make sure everybody knows what you did."],[8975,9138,"The patient's condition is worsening."],[9138,9242,"Have you found a donor?"],[9355,9480,"Bring Nick here."],[9513,9718,"Use his blood to save my daughter."],[9784,9964,"Take as much of it as you need,"],[9964,10164,"as long as you save my daughter."],[10226,10364,"Mandel, Nick is your son!"],[10435,10602,"Sir, he's still unconscious."],[10602,10877,"Take him in, even if it costs him his life."],[10877,11036,"Save Rita."],[11065,11144,"Right."],[11265,11498,"No! Mandel, don't do this!"]],"34":[[688,891,"How is this possible?"],[891,1042,"This... this can be!"],[1088,1167,"What's wrong?"],[1188,1363,"They are showing signs of rejections."],[1363,1493,"I think they might be siblings."],[1493,1701,"You can't even control your son."],[1755,2018,"And now my daughter has been in a car accident."],[2039,2198,"If anything happens to her,"],[2239,2360,"I'll make you pay."],[2391,2573,"As long as my son remains"],[2573,2820,"the Franklin family's young master,"],[2820,3110,"it doesn't matter if that brat’s blood is drained!"],[3503,3599,"What's going on?"],[3599,3812,"The patient showing signs of rejection."],[4346,4537,"Get out of here with your son!"],[4537,4771,"I never want to see your face in my house again."],[5238,5321,"Doctor."],[5342,5484,"What is happening?"],[5551,5784,"We suspect the boy is your son."],[5860,6031,"We recommend you get a DNA test."],[6031,6185,"How is that possible?"],[6218,6314,"We already did a test."],[6314,6464,"He is not my son!"],[6464,6639,"You need to do another DNA test."],[6806,7007,"Mandel, do another test quickly!"],[7048,7240,"Bring our son back to us."],[7273,7449,"Don't make another mistake."],[7582,7741,"What about my daughter's blood?"],[7949,8020,"Doctor."],[8020,8366,"Another hospital has the RH negative blood in stock."],[8370,8512,"They can send it over now."],[8533,8612,"Oh, okay."],[8612,8689,"Good."],[8732,8883,"Do everything you can"],[8883,9029,"to save my daughter's life."],[9250,9567,"Cole, do a DNA test for me and Nick."],[9567,9897,"Also, investigate Paige thoroughly."],[9947,10231,"Sir, something I've always found strange."],[10285,10510,"Well, go on then. Speak it out."],[10510,10589,"Well, back then,"],[10589,10869,"one of your secretaries was Paige's sister-in-law."],[10890,10969,"What?"],[11440,11628,"Investigate everything from back then."],[11649,11966,"Dig up everything on Paige and her husband."],[12003,12116,"And the young master, sir?"],[12166,12258,"Send him home."],[12258,12333,"Noted, sir."]],"35":[[275,437,"Seems the truth is out..."],[692,888,"My son is the young master."],[1001,1213,"I can't let him come back home with us."],[1434,1534,"Cole, wait!"],[1555,1634,"What?"],[1672,1876,"The master said that you have urgent business to do."],[1876,2060,"He asked me to take the young master home."],[2369,2489,"Come on, I'll take you home."],[2489,2748,"Don't touch me. You're so disgusting."],[3165,3249,"Let go with me!"],[3249,3457,"Let go! Cole..."],[5363,5442,"God."],[5505,5651,"Please save my daughter."],[5901,6076,"I wonder if Nick is safe."],[6439,6519,"Nick?"],[6760,6856,"Where's Nick?"],[7098,7261,"Mama had to do this."],[7311,7482,"Everything I did was for you."],[7603,7736,"Did you take care of it?"],[7757,7871,"Don't worry."],[7885,7999,"Brat's in the trunk."]],"36":[[91,221,"I have no choice."],[258,383,"I have no other option."],[383,525,"He has no choice either."],[542,738,"I'll make Mandel kill his own son."],[867,1151,"Even if he finds out the brat is his real son,"],[1213,1322,"it'll be too late."],[1334,1484,"My child will still be"],[1505,1685,"the young master of the Franklin family."],[1697,1818,"What are you gonna do?"],[1926,2081,"What are you gonna do to my child?"],[2147,2212,"I mean..."],[2238,2316,"What do you mean?"],[2316,2372,"You're crazy."],[2372,2485,"You're really crazy!"],[2506,2702,"If Mandel finds out, he won't let us go!"],[2748,2898,"And he won't let Tommy go either!"],[2952,3099,"I am crazy!"],[3099,3222,"I'm a mother."],[3222,3420,"For my child, I'll do anything!"],[3582,3720,"But my child..."],[3795,4008,"What did he do to deserve this?"],[4016,4258,"Why can't you just let him go!"],[4316,4637,"Mandel raised Tommy for seven years!"],[4646,4775,"Seven years!"],[4775,5055,"Even a dog would develop feelings after seven years!"],[5080,5226,"He'll never abandon Tommy."],[5305,5395,"And you!"],[5395,5538,"Don't think about running!"],[5547,5668,"You are a part of this too!"],[5668,5801,"You have to help me!"],[5822,5916,"Fine,"],[5916,6097,"but if this works, you have to give me money."],[6185,6360,"The last time that brat ran away,"],[6360,6535,"Nicholas wouldn't let me hear the end of it."],[6581,6691,"Fine."],[6691,6819,"Once the brat is dead,"],[6819,7019,"you can have as much money as you want."],[7073,7152,"No!"],[7186,7353,"Don't hurt my child."],[7394,7520,"Once you're dead,"],[7595,7807,"my son will always be the"],[7807,8074,"high and mighty Franklin Tommy."],[8083,8366,"He inherited everything from the Franklin family."],[8500,8637,"What did you two just say?"]],"37":[[104,221,"Young master?"],[392,754,"I was the one who switched you and Nick."],[838,1026,"I'm actually your mother."],[1055,1234,"No, you're not my mom!"],[1234,1418,"I don't have a mom like you."],[1426,1705,"I don't want a poor woman like you to be my mom."],[1718,1860,"Get away from me!"],[2181,2314,"You deserve this."],[2364,2615,"Somebody like you doesn't deserve to be a mother!"],[3582,3732,"I wanna go home!"],[3732,3899,"How dare you do this to me!"],[3899,4087,"I'll have my dad kill you!"],[4095,4320,"You refuse to acknowledge me..."],[4483,4688,"You refuse to acknowledge me?!"],[4783,5030,"Do you know what I've sacrificed for you?"],[5088,5276,"All these years?"],[5455,5534,"And now,"],[5613,5747,"you look down on me!?"],[5847,5951,"What are you doing?"],[5960,6060,"You're crazy!"],[6151,6293,"There's no going back now."],[6427,6548,"I have to see this through."],[6865,7065,"Since you refuse to acknowledge me,"],[7102,7315,"that the truth is about to be exposed,"],[7403,7545,"then let's die together!"],[7770,7907,"You crazy woman!"],[7949,8137,"You do this to your own child?"],[8375,8458,"Mom?"],[8817,8900,"No!"],[8996,9275,"Brat, your life ends today!"],[9317,9509,"In the hands of your own father!"]],"38":[[58,187,"I will make"],[304,500,"your high and mighty"],[500,738,"billionaire father kill you himself!"],[917,1222,"Why? Why?!"],[1263,1434,"After everything I've done,"],[1501,1655,"I'm still left with nothing!"],[1743,1822,"You..."],[1914,2056,"You all deserve to die!"],[2389,2627,"You already gave your son a good life."],[2677,2815,"Let my son go."],[2907,3030,"Are you crazy, woman?"],[3030,3132,"Keep it down!"],[3143,3218,"Damn it!"],[3218,3340,"Do you want a beating?"],[3420,3653,"If you weren't such a useless bump,"],[3670,3837,"would I have given my own child"],[3837,4029,"to be raised by somebody else?"],[4208,4483,"Whoa! Calm down. Calm down!"],[4507,4641,"Put the knife down."],[4641,4783,"Let's talk."],[4842,5113,"You useless scum!"],[5213,5476,"I wish I could cut you into pieces."],[5559,5872,"Your whole family deserves to rot in hell!"],[5939,6247,"Just let my child go, you vicious snake!"],[6327,6527,"Call Mandel now!"],[6986,7507,"If Nick is really my son, then what about Tommy?"],[7545,7799,"Could the test result have been wrong?"],[7836,7916,"Sir!"],[7957,8087,"The young master is missing!"],[8137,8279,"What? What happened?"],[8287,8450,"Well, Paige sent me away."],[8454,8641,"She said she'd return with the young master."],[8641,8737,"When I got back,"],[8737,8822,"there's no sign of them"],[8822,8938,"and I can't reach Paige."],[9029,9113,"Paige..."],[9526,9688,"Hello, who is this?"],[9734,9939,"Mandel, if you want your son to live,"],[9939,10108,"bring 15 million to the abandoned building"],[10108,10257,"on the outskirts of the city."],[10302,10453,"Come alone."],[10453,10543,"Don't call the police,"],[10543,10789,"or else you will never see your son's body again!"],[10839,10969,"You have half an hour."],[11023,11123,"Don't be late!"],[11269,11536,"What? Who is this?"],[11536,11715,"Hello? Hello?"],[12270,12383,"Mr. Mandel,"],[12483,12662,"the test results are already out."],[12733,12867,"Nick is really your son!"]],"39":[[62,145,"Where is he?"],[183,296,"The results are already out!"],[325,621,"- Help! Help! - Help me!"],[621,863,"- Help! Help! - Help!"],[871,975,"You wretch nanny!"],[975,1242,"My dad won't let you get away with this!"],[1249,1363,"Mom, I'm scared."],[1363,1580,"I don't wanna be here. Mom!"],[1589,1747,"Don't call me Mom!"],[1747,1985,"You're just as disgusting as your mother!"],[2060,2143,"Damn it!"],[2223,2381,"Where is that bastard?"],[2414,2527,"Why isn't he here yet?"],[2544,2655,"Shut up!"],[2672,2857,"Mandel loves his wife so much,"],[2857,3023,"he won't let their son die."],[3140,3361,"Oh my God! Boys."],[3445,3560,"The money's here."],[3560,3661,"Let them go!"],[3661,3745,"Dad! Dad!"],[3745,3883,"Save me!"],[3908,3987,"Don't move!"],[4137,4216,"Give me the money."],[4283,4454,"Okay, okay."],[4988,5255,"So much money. I'm finally rich!"],[5334,5513,"You see, money's all there."],[5513,5609,"Now let them go!"],[5633,5733,"Grab him!"],[5733,5885,"Don't let him come closer."],[6085,6168,"Get down!"],[6381,6493,"You've got the money."],[6498,6627,"What else do you want?"],[6627,6740,"Just let them go!"],[6815,6940,"Sure!"],[6940,7140,"Then, maybe you should guess,"],[7140,7290,"which one is your son?"],[7340,7419,"What?"]],"40":[[25,108,"What?"],[158,246,"What do you mean?"],[283,446,"You wanna save your son, right?"],[471,567,"Then choose!"],[567,717,"Choose which one you wanna save!"],[825,950,"You're insane!"],[1059,1157,"Choose!"],[1157,1300,"You can only pick one!"],[1447,1651,"Listen, don't be rash!"],[1651,1768,"Save Nick!"],[1856,1964,"Nick is your son,"],[1964,2173,"Mandel, think carefully."],[2214,2456,"Dad! Dad! Save me!"],[2489,2719,"If you don't choose, I'll kill them both!"],[2731,2844,"Neither will live!"],[2848,3032,"No, save Nick!"],[3094,3228,"Nick is your son!"],[3386,3632,"Please spare my child! I beg you!"],[3674,3899,"Dad! Dad, I'm scared!"],[3912,4117,"Mom, no! please let us go."],[4117,4243,"I'm scared!"],[4275,4358,"Paige,"],[4371,4537,"why are you doing this?"],[4558,4800,"I'll give you as much money as you want,"],[4800,4954,"just let Tommy go."],[4979,5171,"Nick is your son too."],[5171,5334,"How can you do this?"],[5413,5651,"Your daughter lost so much blood."],[5651,5851,"You were ready to drain Nick dry."],[5868,6068,"So don't act like you're the good guy."],[6089,6327,"I hate you! I hate you!"],[6331,6499,"You already abandoned Nick once."],[6499,6641,"Don't do it again."],[6731,6898,"I know, I'm sorry."],[6919,6998,"It was my fault."],[6998,7090,"Look, let's..."],[7094,7176,"Let's just stop this"],[7176,7353,"and we'll figure something out, okay?"],[7386,7536,"Cut the nonsense!"],[7536,7674,"Make your choice now!"]],"41":[[33,208,"Mom, Nick was wrong."],[208,375,"Please let us out, Mom."],[496,754,"Dad! Dad, save me! Dad!"],[959,1159,"Your time is running out!"],[1234,1355,"I give you"],[1472,1643,"10 seconds, choose now!"],[1697,1901,"What should I do? What should I do!"],[1901,2064,"Who is my real child?"],[2118,2348,"We suspect the boy is your son."],[2431,2598,"We recommend you get a DNA test."],[2598,2756,"How is that possible?"],[2781,2882,"We already did a test."],[2882,3028,"He is not my son!"],[3028,3207,"You need to do another DNA test."],[3386,3724,"10... 9... 8..."],[3724,3803,"Choose Nick!"],[3803,3912,"You have to choose Nick!"],[3933,4045,"He's your son."],[4066,4183,"Choose now!"],[4220,4521,"7... 6... 5..."],[4521,4679,"Nick! Pick Nick!"],[4704,5038,"3... 2... 1..."],[5038,5196,"Alright! Alright!"],[5305,5409,"I choose."],[5488,5693,"Good, who do you choose?"],[5860,5943,"Him!"]],"42":[[45,125,"No..."],[212,291,"Mandel."],[317,414,"Nick is your son"],[414,571,"and you choose the son of our enemy?"],[754,942,"Now can I have my son back?"],[1067,1397,"Mandel, you finally met your match."],[1438,1614,"Give me Tommy back! Give me my son!"],[1676,1830,"Do you even have a heart!?"],[1839,2039,"I hate you! I hate you!"],[2060,2210,"I'll never forgive you!"],[2231,2310,"Hughes,"],[2348,2472,"come take Tommy."],[2472,2625,"Grab our son and then the money,"],[2625,2756,"and you leave first."],[2844,2923,"What?"],[2973,3057,"What do you mean?"],[3791,3870,"Help!"],[3941,4008,"Help!"],[4008,4066,"Tommy!"],[4066,4108,"Help!"],[4108,4237,"Tommy!"],[4262,4421,"Didn't expect that, did you?"],[4491,4650,"Nick is your son."],[4704,4821,"But you didn't save him."],[4879,4959,"What?"],[4964,5057,"No!"],[5057,5167,"How can this be?"],[5226,5447,"If I hadn't swapped my child back then,"],[5480,5705,"would Tommy have lived such a good life?"],[5714,5851,"Why did you do this?"],[5870,5971,"Why?"],[6012,6256,"Why did Memi live such a good life"],[6256,6502,"while my son had to suffer with me!?"],[6552,6777,"Why did Memi marry the richest man"],[6777,7002,"while I was stuck with a bastard like Hughes?"],[7015,7161,"You're insane!"],[7194,7361,"What has this got to do with Nick?"],[7361,7665,"Anyone who stands in my child's way"],[7665,7807,"will get eliminated!"],[7841,7932,"No!"]],"43":[[41,141,"No!"],[291,371,"No!"],[688,813,"Help me! Help me!"],[813,984,"I don't want to die!"],[1138,1317,"Nick, I was wrong."],[1335,1436,"It was my fault."],[1436,1572,"I didn't recognize you!"],[1572,1705,"Dad will save you!"],[1785,2089,"Memi, you were born a noblewoman."],[2164,2243,"While I"],[2335,2485,"was the daughter of a mistress."],[2485,2573,"And now,"],[2640,2853,"Your son, your daughter,"],[2853,2989,"and your husband"],[2989,3203,"have all fallen."],[3203,3407,"What do you have left to compete with me now?"],[3445,3524,"What?"],[3561,3641,"You're..."],[3687,3862,"You're Memi's half-sister?"],[3928,4300,"Back then, that old bastard from the Vivian family"],[4304,4466,"only cared about having children"],[4466,4571,"but not raising them."],[4637,4783,"My mother was abandoned."],[4929,5038,"And because of that,"],[5040,5180,"I was left with no choice"],[5180,5388,"but to marry scumbags like Hughes!"],[5413,5714,"Your mother drugged my father to climb into his bed"],[5714,5797,"and have you."],[5893,6101,"Because of that, my mother died of depression,"],[6181,6335,"and you still think you're the victim?"],[6381,6523,"You're insane!"],[6560,6756,"You can't just take it out on the children!"],[6756,6865,"This is murder!"],[6886,7015,"So what?"],[7015,7269,"I was the one who caused the car accident."],[7269,7486,"If I can't have it, then I'll destroy it!"],[7494,7778,"You're the one who tried to murder my wife?"],[7899,8124,"All those years, your comatose wife"],[8124,8220,"hasn't woken up."],[8270,8420,"I put a lot of effort into that."],[8512,8704,"You murderous bitch!"],[8733,9013,"Blame the Vivian family for not accepting me."],[9029,9184,"This is their own doing!"]],"44":[[133,383,"You've raised my son for so many years."],[446,563,"I should thank you!"],[692,955,"Please, just let my son go."],[1038,1192,"Mandel, please hold on!"],[1308,1516,"This is your choice."],[1516,1720,"Your son appeared before you"],[1720,1885,"time and time again."],[1918,2118,"And you drove him away!"],[2122,2260,"You abandoned his life."],[2260,2347,"You!"],[2347,2506,"You killed him in your own hands!"],[2506,2644,"Mandel, you have to hold on."],[2723,2823,"I hurt Nick."],[2890,3003,"I let him down."],[3053,3148,"Sorry, Nick..."],[3274,3353,"Sorry..."],[3549,3628,"Mandel!"],[3682,3807,"Please hold on!"],[3920,4066,"Paige, I beg you!"],[4120,4270,"Please let my child go!"],[4283,4441,"I'll give you anything you want."],[4491,4571,"Paige,"],[4633,4788,"just let Nick go."],[4842,5080,"I'll treat Tommy like I always did."],[5092,5367,"He can still continue being the Franklin master."],[5388,5467,"Just..."],[5509,5693,"Please, just let Nick go."],[5768,5893,"I don't believe you!"],[5914,6076,"You'll never let Tommy go!"],[6291,6379,"Nick!"],[6448,6602,"Why am I still sleeping?"],[6602,6752,"Wake up! Wake up!"],[6794,7007,"Miss! Miss, you're awake!"],[7032,7248,"My brother! Nick is my brother!"],[7290,7457,"I dreamed that Nick was kidnapped,"],[7469,7645,"Dad was hurt and Mom was there too!"],[7957,8051,"Mom, wake up!"],[8051,8158,"Mom, I found my brother!"],[8158,8270,"Mom, wake up!"],[8283,8554,"Wake up, Mom! Mom!"]],"45":[[12,92,"Mom!"],[248,328,"Mom..."],[744,824,"Madam?"],[896,1008,"Madam is awake!"],[1152,1284,"I had a long dream..."],[1300,1424,"Mom, you have to save Nick!"],[1424,1572,"Karina said Nick and Tommy"],[1572,1712,"were kidnapped by Paige!"],[1740,1912,"My dream actually happened?"],[1960,2052,"Oh, God!"],[2096,2176,"Nick!"],[2240,2380,"Mommy's coming to save you!"],[2408,2572,"Karina, prepare the car now!"],[2572,2652,"Yes, Madam."],[3372,3464,"Mom, are you okay?"],[3936,4064,"I'll take care of Tommy."],[4088,4252,"I'll treat him as my own son."],[4388,4460,"Shut up!"],[4575,4666,"Nick!"]],"46":[[312,424,"Let go of me!"],[924,1076,"Why are you awake?"],[1076,1392,"I'm so sorry you had to go for all of this."],[1500,1640,"I failed to protect you."],[1640,1780,"But I'm here now,"],[1832,2040,"nobody's ever gonna hurt you again, okay?"],[2072,2260,"Mom? Are you my mom?"],[2268,2372,"Yes, honey!"],[2428,2540,"I'm your real mom!"],[2604,2724,"And as long as I'm breathing,"],[2724,2920,"nobody's gonna ever hurt you again."],[2920,2996,"No!"],[3064,3192,"This can't be..."],[3208,3448,"How could you wake up after all these years?"],[3972,4064,"All of you!"],[4140,4252,"Just die!"],[4300,4380,"No!"],[4796,4888,"Mandel,"],[4900,4992,"are you okay?"],[4992,5048,"Memi..."],[5124,5292,"Is that you? Am I dreaming?"],[5332,5500,"You're really here! You're awake!"],[5568,5692,"So good to see you..."],[5732,5920,"Mandel. Mandel, wake up!"],[5920,6132,"Wake up! Please! No, Mandel..."],[6220,6360,"No! Wake up!"],[6408,6528,"I will kill you!"],[6528,6624,"I will kill you!"]],"47":[[260,408,"Let go of me!"],[1236,1408,"Who dares to tie me up!"],[1436,1536,"I've got money."],[1536,1680,"I'll give you whatever you want!"],[2600,2668,"Help!"],[2668,2764,"Help!"],[2764,2844,"Help!"],[3000,3140,"If you want to kill me, just do it!"],[3140,3236,"And get it over with!"],[3252,3512,"After abusing my son for 7 years,"],[3552,3736,"dying would be too easy for you."],[3740,3944,"So what? You just want to humiliate me?"],[4060,4276,"I waited for this for 7 years!"],[4332,4532,"This is for Nick, and this is for Rita!"],[4612,4732,"How do you know all this?"],[4760,4856,"What do you want?"],[4880,5002,"I've got friends in high places."],[5002,5120,"You can't kill me!"],[5160,5460,"I will not stoop to your level and commit murder!"],[5580,5708,"But I have a better idea."],[5784,5964,"You love alcohol, don't you?"],[6420,6636,"This is industrial alcohol."],[6700,6788,"Drink up!"]],"48":[[1364,1537,"You plotted the car accident"],[1537,1764,"against my wife and my son."],[1796,1912,"You abused him,"],[1932,2052,"and you kidnapped him."],[2092,2380,"So, now I'm gonna settle the debts one by one!"],[2760,2880,"Take a good look at this."],[2948,2980,"No!"],[3012,3090,"I won't sign!"],[3176,3388,"When my son begged you for 7 years"],[3388,3516,"to stop hurting him,"],[3536,3704,"did you ever think this day would come?"],[3728,3820,"Nicholas,"],[3924,4040,"he's all yours."],[4048,4396,"Hold him down, and make him sigh."],[5520,5628,"What are you doing, Memi?"],[5628,5760,"You shameless woman!"],[5760,5908,"Let my son go!"]],"49":[[96,232,"Seven years!"],[260,504,"You let me rot in bed for seven years!"],[580,716,"And you abused my son."],[752,892,"You even tried to kill him!"],[964,1232,"Did you ever think of letting him go?"],[1300,1424,"Just for once?"],[1608,1736,"I did those things,"],[1748,1828,"I know."],[1872,1995,"I'm not innocent."],[1995,2236,"but please don't hurt my son."],[2664,3024,"You think everybody's as cruel as you to hurt a child?"],[3056,3292,"If your son acknowledges you as his mother,"],[3340,3472,"I'll let you and Tommy go."],[3484,3684,"Tommy, my son."],[3732,3840,"Please, help me."],[3872,4100,"Shut up! You're not my mother!"],[4132,4372,"I'm the son of the richest man in town."],[4372,4552,"I don't have a maid for a mother!"],[4606,4729,"No, Tommy."],[4729,4992,"I'm your mother. I gave birth to you!"],[4996,5160,"Mommy, Mommy. You're my only mommy."],[5160,5392,"I don't want anyone else to be my mommy."],[5520,5756,"See? Even your own son"],[5756,5908,"refuses to acknowledge you!"],[5920,6020,"And he hates you!"],[6028,6120,"How does it feel?"],[6120,6292,"I was wrong, Tommy,"],[6308,6432,"I'm your mother."],[6432,6644,"Everything I did was for you."]],"50":[[0,172,"I was wrong, Tommy."],[188,312,"But I'm your mother."],[312,524,"Everything I did was for you."],[540,668,"I'm the young master."],[668,820,"Nick's not the young master!"],[824,990,"My mom's not a maid!"],[990,1172,"I hate you!"],[1172,1432,"You're tormenting my very soul!"],[1560,1716,"I hate you!"],[1716,2036,"I hope both you and your son burn in hell!"],[2036,2200,"You dare curse my son!"],[2304,2384,"Men,"],[2452,2544,"beat her up."],[2712,2844,"Beat her up hard!"],[2900,3132,"Women like her don't deserve to live on this planet!"],[3136,3236,"Stop!"],[3320,3464,"Have the police take them away!"],[3584,3692,"Hey!"],[3760,4004,"Mr. Mandel, didn't you say that you'd let me go?"],[4004,4152,"Oh, did I?"],[4216,4480,"Well , since you wanted these eyes so badly,"],[4492,4684,"you can enjoy them in prison."],[4712,4868,"No..."],[4868,4915,"Take him."],[4915,5045,"I'm sorry about everything!"],[5045,5168,"Let me go!"]],"51":[[500,604,"It's all my fault."],[752,920,"I almost got you killed."],[920,1044,"It's all in the past, Mom."],[1112,1304,"Make sure to reform yourself well in there."],[1632,1712,"Nick,"],[1860,2132,"I wanted to ask about Tommy."],[2184,2540,"All these years, he hasn't visited me."],[2624,2828,"- Does he still hate me? - He..."],[2984,3252,"I'm the young master! I want a big cake!"],[3340,3464,"He broke another bowl."],[3560,3680,"I'm the young master!"],[3740,3924,"I want a big cake!"],[3992,4180,"Big cake! I want a young master!"],[4180,4340,"Madam, the young master..."],[5060,5140,"Here..."],[6412,6524,"- Let's go. - Let's go."],[7840,7964,"Young Master Tommy,"],[8020,8268,"if you hadn't tried to push Young Master Nick,"],[8280,8556,"and didn't end up falling and injuring your brain,"],[8600,8756,"you wouldn't be in this state."]],"52":[[0,124,"Young 