{"1":[[1751,1872,"Boss, we found the girl."],[3319,3424,"As I already said,"],[3486,3591,"it's not my problem."],[3591,3707,"Criminal injuries aren't covered."],[3720,3895,"Please...okay?"],[3895,4041,"I just need 200k,"],[4099,4233,"just for my mom's operation."],[4233,4408,"I am begging you, please."],[4425,4562,"Your dad is a drug dealer."],[4658,4763,"Your mom is in the hospital"],[4763,4842,"because of him."],[4867,4975,"You guys are all the same."],[5042,5176,"Just like those ring-wearing,"],[5176,5313,"suit-wearing mafia."],[5476,5576,"Parasites."],[5905,5955,"Damn,"],[5985,6093,"you insurance guys sure know"],[6093,6151,"how to run your mouth."],[6151,6297,"Who the hell do you think you are?"],[6431,6535,"Sounds like you've got a problem"],[6535,6652,"with how we do business."],[6677,6727,"Oh, shit..."],[6831,6877,"Hey."],[6919,6977,"Sorry, man."],[7474,7545,"Lily Wingrove?"],[7615,7661,"Uh-huh?"],[7774,7887,"If you want your mom to live,"],[8033,8153,"meet at this address tomorrow."],[8183,8229,"Alone."],[8433,8504,"Who are you?"],[8504,8583,"Don't talk to me."],[8621,8700,"Talk to my boss."],[9659,9709,"Hello?"],[9759,9830,"It's Lily."],[9868,9926,"I'm here."]],"2":[[621,671,"Name?"],[767,821,"Lily."],[880,1005,"Lily Wingrove..."],[1288,1409,"You got some nerve,"],[1472,1597,"selling in my streets."],[1626,1735,"I thought losing a finger would've"],[1735,1860,"taught you some manners."],[2348,2394,"What?"],[2519,2615,"Never seen blood before?"],[3570,3616,"So,"],[3695,3787,"you know why you're here?"],[3937,4079,"Someone said that you can help me."],[4170,4270,"My mom's in the hospital."],[4316,4416,"Do you know who I am?"],[4750,4817,"I'm a..."],[4867,4929,"businessman."],[5042,5217,"I run a legit operation."],[5321,5476,"So I have to ask as a businessman,"],[5476,5626,"what are you willing to give"],[5647,5718,"for your mother?"],[5880,5943,"Anything."],[5985,6118,"Even if what I want..."],[6118,6289,"is a submissive servant who will"],[6289,6431,"anything I tell them to do?"],[6560,6602,"What?"],[6848,6906,"For starters,"],[7524,7607,"drink this."],[7691,7736,"All of it."],[8078,8137,"What I want"],[8170,8350,"is absolute obedience."],[9772,9805,"Good."],[10214,10289,"Now what about my mom..."],[10289,10422,"Did I say you could speak?"],[10648,10694,"Jake,"],[10760,10814,"bring it in."],[11215,11423,"That is 500k."],[11423,11624,"I need your help to do some jobs."],[11640,11740,"Every job that you complete,"],[11740,11853,"you...you get 100k."],[11945,12020,"It's pretty simple."],[12658,12808,"Are you ready for your next task?"],[13296,13363,"Strip."],[13438,13484,"What?"],[13534,13584,"Now."]],"3":[[29,145,"You heard what I said?"],[250,350,"It is a demand,"],[350,454,"not a request."],[521,575,"Now remember,"],[604,688,"you beat a job,"],[784,846,"you get the money."],[1034,1155,"Let's say it's a fair trade."],[4137,4220,"That's enough."],[4621,4750,"That wasn't so hard now, was it?"],[6527,6606,"I'ma need you to..."],[6635,6744,"take this gun,"],[7048,7178,"and shoot him in the head."],[7228,7332,"Please, no..."],[7661,7728,"Please..."],[7782,7836,"no..."]],"4":[[145,308,"I made you take off your clothes,"],[337,442,"so you wouldn't have to deal with"],[442,517,"blood stains."],[588,700,"Thoughtful, right?"],[813,859,"Please..."],[938,992,"please, no..."],[1192,1251,"Now I don't need you"],[1251,1351,"to be smart, Lily."],[1397,1597,"I need absolute obedience."],[1926,1989,"Do it."],[3144,3253,"I can't..."],[3311,3440,"I can't do it..."],[3670,3707,"Can't?"],[3728,3803,"Because your daddy"],[3803,3895,"was a dealer, too."],[5267,5330,"Please..."],[5376,5434,"Please..."],[6694,6773,"See her out."],[7069,7115,"Wait!"],[7169,7315,"Give her the 20k at first."],[7378,7449,"Like I said,"],[7515,7657,"legit businessman."],[8571,8679,"She is perfect."]],"5":[[229,379,"This is for my mom's operation."],[379,467,"Please just take it."],[513,633,"Whoa there, miss."],[692,896,"That is a hell of a lot of cash"],[896,959,"you're flashing."],[1059,1292,"Mind if I ask where a girl like you"],[1418,1518,"got all that green?"],[1593,1659,"Um..."],[1772,1885,"It's my family savings."],[1885,1981,"I...I..."],[2031,2122,"It's for my mom, okay."],[2122,2193,"She is dying in there,"],[2193,2310,"and I really need to get it to her."],[2310,2427,"It's super urgent, so can you..."],[2427,2619,"You are carrying your savings"],[2635,2727,"dressed like that?"],[3374,3495,"Easy there, Detective Harlan."],[3603,3787,"Last I checked carrying cash"],[3787,3853,"isn't a crime."],[3899,3953,"Unless you've got"],[3953,4049,"some probable cause"],[4049,4158,"stuck in that coffee cup."],[4517,4600,"DA Hayes,"],[4667,4800,"what's your angle on this?"],[4984,5063,"My angle?"],[5138,5276,"This young woman is exercising"],[5276,5488,"her right to medical privacy,"],[5534,5651,"unless she was jaywalking"],[5651,5726,"with that blanket."],[5726,5855,"I don't think there's a problem here."],[6861,6940,"Why did you do that?"],[6990,7115,"Lily Wingrove,"],[7215,7428,"top of her Torts back in law school."],[7515,7615,"You probably don't remember me."],[7645,7741,"I was a couple years ahead."],[7857,7928,"Daniel Hayes."],[8058,8128,"Figured you could..."],[8128,8183,"use a hand"],[8212,8299,"for old times' sake."],[8516,8554,"Listen,"],[8600,8742,"life throws curve balls,"],[8742,8842,"but if you ever need help,"],[8913,8971,"come find me."]],"6":[[54,145,"I came from a family"],[145,237,"that wasn't rich."],[304,421,"But I didn't let them down."],[529,617,"I was in law school,"],[679,775,"top of my class."],[829,959,"But the police found cocaine,"],[996,1163,"pounds of it stashed in our home."],[1205,1297,"Heavy charges."],[1363,1455,"Dad went to prison."],[1497,1614,"He said he was framed,"],[1676,1835,"but our family was broken for good."],[2002,2160,"Now Mom's fighting for her life,"],[2206,2335,"attacked out of nowhere."],[2385,2498,"She is all I have left,"],[2548,2698,"and I can't lose her, too."],[4120,4245,"You disappointed me, Lily."],[4316,4491,"And I don't like being disappointed."],[4637,4721,"What is this?"],[5046,5146,"You never told me"],[5146,5288,"you had a DA friend..."],[5330,5359,"hmm?"],[5442,5538,"Daniel Hayes,"],[5538,5659,"ring any bells?"]],"7":[[20,137,"I don't even know him."],[204,308,"He was just helping me."],[358,492,"What did you tell him about me?"],[492,546,"Nothing!"],[633,696,"Okay, I..."],[717,767,"I don't..."],[834,988,"He was just helping my mom."],[1055,1184,"Who sent you?"],[1213,1334,"No one!"],[1509,1605,"Last chance, Lily."],[1697,1835,"You lied to me again,"],[1835,2010,"you are not walking out of here."],[2356,2394,"Fine."],[2473,2519,"Fine."],[2610,2702,"Okay, you want a confession?"],[2948,3128,"All I wanted to do"],[3128,3282,"was keep my mom alive,"],[3382,3541,"but I am so..."],[3582,3757,"done playing your games."],[3795,3862,"So you..."],[3899,4004,"can either bury me"],[4045,4112,"or burn..."],[4137,4250,"in hell!"]],"8":[[900,959,"You did good."],[1618,1710,"What do you want from me?"],[1735,1856,"What I want"],[1856,1922,"is..."],[2056,2143,"a spy,"],[2298,2385,"a servant."],[2631,2665,"Why me?"],[2719,2811,"Sharp minds,"],[2861,2961,"law school background..."],[2961,3044,"Father is in prison."],[3044,3244,"Mother is barely clinging onto life."],[3244,3353,"You need money,"],[3440,3524,"protection..."],[3557,3657,"and I need someone"],[3657,3803,"who will never run away."],[3803,3908,"No matter what."],[4233,4304,"You're perfect."],[4371,4471,"You're my perfect..."],[4496,4550,"possession."],[4646,4704,"This was..."],[4754,4859,"all just a trap."],[5013,5055,"Hmm..."],[5134,5167,"trap..."],[5255,5301,"test,"],[5359,5455,"call it whatever you want."],[5622,5701,"From now on,"],[5809,5885,"you're mine."],[5951,6006,"Who are you?"],[6085,6222,"The name is Eric Moretti."],[6314,6452,"Etch it into your bones."],[6585,6698,"Because from this day forward,"],[6698,6806,"that name owns you."],[6848,7073,"That name seals your fate."],[7111,7186,"Let's walk."],[7273,7440,"The real work begins now."],[8370,8479,"That's the guy from earlier."],[8533,8633,"Why are you going to kill him?"],[8687,8721,"Well,"],[8762,8854,"he was one of the men that"],[8854,8975,"put your mother in the hospital."],[9129,9284,"Consider this a free gift."],[9951,10068,"I need it all from you,"],[10197,10256,"your body,"],[10285,10360,"your mind,"],[10418,10523,"and your loyalty."],[10977,11127,"Show me you belong to me."]],"9":[[16,183,"Show me you belong to me."],[4287,4462,"I've got your law license sorted out."],[4496,4658,"You're officially an attorney."],[4875,4938,"What?"],[4959,5025,"Why?"],[5030,5096,"Because tomorrow"],[5096,5234,"you have a job interview"],[5234,5363,"with Daniel Hayes,"],[5463,5530,"and you will become"],[5530,5630,"his assistant."],[5651,5814,"And from the inside of his office,"],[5814,5947,"you'll be my eyes."],[6081,6189,"He hides behind a wall"],[6189,6381,"of so-called kindness."],[6448,6523,"Use it."],[6756,6927,"And you are not allowed to fail."]],"10":[[1251,1380,"Lily Wingrove?"],[1497,1584,"What are you doing here?"],[1626,1760,"The last I heard, your dad was still"],[1760,1922,"slinging dope on the streets."],[2143,2227,"Figures you'd crawl out"],[2227,2344,"for a gig like this."],[2344,2473,"That's not true!"],[2473,2540,"Please..."],[2615,2727,"everyone knows,"],[2794,2882,"your dad's mess was"],[2882,2990,"all over the news."],[3015,3211,"You think they want trash like you?"],[3332,3399,"Do us a favor,"],[3399,3586,"and quit before you humiliate yourself."],[4371,4475,"You being here"],[4475,4662,"is disrespectful to the system."],[5217,5326,"Mind telling me what's happening?"],[5518,5643,"It's Fallon's daughter, Sir."],[5668,5780,"She came for an interview,"],[5818,5960,"so, I figured I'd help you out."],[6014,6122,"And she should leave."],[6506,6544,"Well,"],[6544,6648,"you're right about one thing."],[6831,7032,"This office values respect."],[7140,7257,"From what I just saw,"],[7311,7403,"you're the one who forgot that."],[7482,7578,"If anyone's leaving,"],[7578,7640,"it should be you."]],"11":[[29,141,"I'm sorry you had to deal with that."],[496,550,"Also,"],[592,713,"at the hospital, I was worried."],[779,829,"Are you okay?"],[942,988,"Yeah,"],[1059,1096,"I'm okay."],[1096,1222,"I just really need this job..."],[1272,1338,"save my mom."],[1543,1609,"I wish I could help."],[1634,1722,"Lily, I really do."],[1743,1843,"There is a freeze right now."],[1931,2006,"With new applicants,"],[2006,2102,"I can't decide today."],[2218,2435,"I hate Eric's methods."],[2485,2577,"But if I want this job,"],[2644,2802,"I'll have to use Daniel's kindness."],[2919,2998,"I understand."],[3098,3207,"I know that people like me"],[3207,3286,"don't really get this"],[3286,3403,"kind of opportunities."],[3678,3728,"Wait,"],[3883,3949,"freeze or not,"],[3999,4062,"I make the call."],[4225,4283,"You're hired."],[4387,4429,"Really?"],[4487,4600,"You kept your dignity"],[4600,4729,"when others tried to break it down."],[4821,5000,"That's the strength I need in this office."],[5580,5663,"I remember now."],[5764,5910,"She was in Eric's house."],[6101,6239,"This was all Eric's setup,"],[6289,6435,"using Daniel's kindness."],[6514,6589,"Eric Moretti,"],[6664,6790,"such a dangerous man."],[7111,7161,"Daniel,"],[7182,7336,"you are kind like an angel,"],[7374,7503,"and I'm deceiving you."],[7557,7611,"Forgive me."]],"12":[[775,859,"It's...normal?"],[950,988,"Oh,"],[988,1046,"that's fair. -Thief!"],[1046,1105,"Get him!"],[1222,1276,"Oh my God!"],[1276,1326,"Are you okay?"],[1372,1401,"I..."],[5242,5313,"Your arm!"],[5455,5505,"It's nothing."],[5551,5597,"Are you okay?"],[5622,5672,"Yeah, but..."],[5672,5743,"your arm..."],[5764,5855,"Oh my God!"]],"13":[[137,179,"Okay..."],[212,258,"Okay,"],[258,375,"my house is really close to here."],[375,425,"Let's go there."],[425,504,"I can help you, okay?"],[546,596,"Come on."],[596,650,"Let's go."],[684,717,"Okay."],[1247,1330,"I like your place."],[1359,1409,"It's cozy."],[1451,1518,"It feels..."],[1601,1647,"safe."],[1810,1868,"Thank you."],[1889,2014,"It's not much, but..."],[2527,2665,"You should just take off your shirt."],[2877,3090,"Be...uh...because..."],[3153,3240,"it's ruined,"],[3257,3378,"and I need to wash it."],[3378,3432,"Is..."],[3432,3649,"Right, of course. -I meant...by that."],[5755,5855,"Sorry, can you hold this?"],[5855,5901,"Totally."],[6018,6085,"Is everything okay?"],[6085,6147,"Is it your mom?"],[6272,6343,"Uh...yeah."],[6343,6398,"No, it's..."],[6660,6710,"I can..."],[6819,6877,"You can go."],[6877,6948,"I'll be fine."],[6956,7023,"I'll get home."],[7036,7077,"No,"],[7090,7140,"it's okay."],[7140,7194,"Let me help."]],"14":[[529,613,"I told you to come"],[613,721,"as soon as possible."],[859,921,"Daniel got hurt,"],[980,1088,"so I took him to my place."],[1272,1409,"I don't want your excuses."],[1526,1605,"You got the job."],[1718,1764,"Good."],[1922,2089,"I've already sent your money."],[2635,2715,"What is your read"],[2744,2811,"on Daniel?"],[2890,2940,"Um..."],[2986,3073,"he is kind,"],[3119,3182,"and..."],[3228,3299,"intelligent,"],[3449,3511,"and reliable."],[3687,3787,"So he trusts you."],[3832,3870,"Good."],[3958,4066,"This will make your next job"],[4145,4191,"easy."],[4237,4279,"What is it?"],[4817,4959,"Daniel has a party this weekend."],[5125,5234,"You will go to that party."],[5351,5484,"You'll slip one of those"],[5484,5563,"into his drink."],[5655,5822,"No, I...I'm not gonna poison him."],[5822,5960,"Who said anything about poison?"],[6035,6081,"No..."],[6126,6247,"he has to live for now."],[6306,6406,"Just going to..."],[6510,6631,"loosen him up a little bit,"],[6677,6760,"make him stumble,"],[6861,6977,"humiliate him."],[7069,7178,"You promise it's not deadly..."],[7232,7353,"I promise"],[7353,7424,"nothing!"],[8049,8162,"What I want"],[8179,8312,"is obedience."],[8408,8525,"No questions."],[8700,8746,"Now,"],[8892,8971,"get on your knees."]],"15":[[25,95,"Get on your knees."],[921,984,"Look at me."],[1117,1159,"Tell me,"],[1222,1326,"why do you obey me?"],[1393,1443,"Because I..."],[1484,1597,"don't have another choice."],[1760,1818,"So tell me..."],[1901,2106,"that you are willing to give everything"],[2106,2152,"to me."],[2348,2414,"I'm willing..."],[3440,3524,"Remember your mission."],[3628,3687,"You need the money"],[3687,3766,"to help your family."],[3945,3978,"I know."],[4116,4158,"I'll do it."]],"16":[[880,1088,"You had a late night last night, so..."],[1101,1197,"I thought you could use this."],[1288,1363,"You read my mind."],[1443,1488,"Thank you."],[1488,1572,"Please, sit."],[1584,1647,"Oh, okay."],[2081,2143,"Remember,"],[2143,2302,"don't stay here too long tonight."],[2356,2452,"You've got big event tomorrow."],[2602,2656,"Careful."],[2852,2977,"You're starting to sound like my boss."],[3207,3319,"Actually I got you something"],[3319,3378,"for tomorrow."],[3937,3999,"Daniel,"],[4024,4116,"you didn't have to..."],[4116,4200,"I want to."],[4254,4312,"Please,"],[4404,4446,"open it."],[5155,5196,"It's..."],[5326,5451,"it's beautiful, but..."],[5676,5780,"I can't accept this."],[5780,5880,"It's too much."],[5997,6072,"It's perfect."],[6147,6306,"You're gonna shine in it."],[6489,6602,"Besides, I want everyone"],[6602,6677,"to see you."],[6798,6844,"Eric,"],[6927,7086,"you want me to use Daniel's trust"],[7086,7161,"against him."],[7365,7499,"But the more he trusts me,"],[7528,7624,"the more it hurts."],[9688,9743,"Daniel?"],[9897,10030,"Who's this stray kitten?"]],"17":[[79,120,"Allow me,"],[216,316,"my new assistant, Lily."],[871,980,"That explains it."],[1009,1096,"For the moment,"],[1117,1301,"I thought my party has no standard."],[1447,1505,"So,"],[1559,1730,"you slipped in on Daniel's arms,"],[1768,1805,"hmm?"],[2018,2118,"Pretty assistant you've got."],[2139,2243,"I never took you for a man"],[2243,2356,"of indulgence, Daniel."],[2394,2540,"Don't mistake professionalism"],[2540,2648,"for indulgence."],[2790,2848,"She works for me."],[2886,2932,"That's all."],[3119,3169,"Lily,"],[3169,3299,"this is Eric Moretti."],[3399,3486,"His family..."],[3728,3799,"manages"],[3849,4016,"certain businesses around the city."],[4070,4220,"It's a pleasure, Miss Lily."],[4346,4400,"Lily,"],[4683,4763,"could you please bring me"],[4763,4867,"a glass of champagne?"],[4867,4921,"Take your time."],[5005,5050,"Okay."],[5321,5530,"A lady's touch makes the wine"],[5530,5601,"finer."],[5789,5864,"Much better."],[5889,5960,"Now,"],[5960,6064,"the floor belongs to"],[6064,6131,"grown-ups."],[6235,6327,"Daniel Hayes,"],[6327,6464,"golden boy prosecutor."],[6464,6569,"Everyone says he's headed"],[6569,6660,"for City Council."],[6690,6831,"And Eric Moretti,"],[6873,7048,"the Morettis own half the docks,"],[7048,7178,"just like old times."],[7215,7424,"Both want Tracy Wang's blessing."],[7424,7520,"Her family"],[7561,7695,"runs the elections."]],"18":[[8,45,"Tracy,"],[116,271,"I know your family is looking for"],[271,387,"someone you can trust."],[433,579,"Support me in this race,"],[579,650,"and together..."],[821,909,"we'll build something"],[909,1076,"this city has never seen before."],[1142,1209,"Tracy..."],[1238,1359,"doesn't need trust."],[1509,1676,"What she needs is someone"],[1676,1772,"she can lean on."],[1830,1989,"Someone she can hand herself to..."],[1989,2052,"completely."],[2414,2548,"You both sounds convincing."],[2594,2635,"But..."],[2677,2848,"isn't this just about using me?"],[2923,2969,"You're right."],[3065,3161,"Every guest here"],[3161,3311,"wants a piece of your family."],[3536,3636,"But the difference is..."],[3687,3782,"I don't just take."],[3824,3962,"I also protect what's mine."],[4145,4275,"So stand beside me,"],[4275,4429,"and no one would dare hurt you."],[4521,4567,"Protect?"],[4742,4779,"Is that..."],[4804,4859,"what you call it?"],[4938,5071,"Because in your neighborhoods,"],[5080,5209,"the drugs keep spreading."],[5284,5409,"Families keep breaking."],[5459,5597,"That doesn't sound like protection."],[5726,5855,"That sounds like betrayal."],[6464,6552,"Aw..."],[6623,6756,"Before we argue about..."],[6756,6873,"the future of the city,"],[7040,7198,"let's have a toast to the present."],[7219,7257,"Shall we?"],[7315,7440,"To our gracious host,"],[7515,7586,"and to tonight."],[7736,7799,"To tonight."]],"19":[[342,508,"Why is he still standing?"],[608,663,"I..."],[663,779,"I didn't give him the pill."],[1030,1088,"I see."],[1234,1380,"So that wolf in sheep's clothing"],[1380,1534,"has you wrapped around his finger."],[1568,1605,"Hmm?"],[1947,2072,"If you want my help"],[2072,2198,"with your mother's bills,"],[2293,2414,"you have to obey me."],[2523,2656,"Daniel goes down tonight."],[3103,3157,"Lily?"],[3236,3290,"You in there?"],[3849,3899,"Eric..."],[3949,4029,"Eric, please..."],[4225,4341,"Are you okay, Lily?"],[4362,4475,"You've been in there a while."],[4721,4792,"Please..."],[4829,4879,"Lily?"],[5284,5351,"I'm worried."],[5351,5417,"I'm coming in."]],"20":[[250,358,"No, Daniel, I'm fine."],[621,709,"Do you need help?"],[754,825,"No, no, I..."],[825,892,"No, no."],[892,980,"Daniel, I, I'm..."],[1013,1151,"I'm just a little drunk."],[1209,1259,"Okay."],[1401,1463,"Take your time."],[1463,1593,"I just wanna make sure you're alright."],[2227,2335,"Remember your mission,"],[2456,2544,"or you'll regret it."],[3453,3503,"Oh..."],[3541,3616,"Oh, there she is."]],"21":[[125,179,"Lily?"],[379,433,"So..."],[433,558,"this is the assistant"],[558,663,"you are so proud of?"],[900,1021,"She's had too much."],[1034,1163,"Please, forgive the scene."],[2323,2360,"Lily!"],[2435,2489,"Enough..."],[2489,2573,"There are people watching..."],[2727,2836,"Daniel, please..."],[2836,2944,"Okay, I just wanna forget."],[2944,3019,"Just help me..."],[3036,3111,"forget, just..."],[3148,3269,"just once, okay?"],[3290,3449,"Please just help me forget everything."],[3757,3799,"Please."],[7294,7344,"Let's go."],[7415,7520,"I don't wanna waste my night"],[7520,7620,"on this circus."],[7707,7774,"Of course."],[8558,8600,"Well..."],[8825,8913,"that was unexpected."],[9134,9192,"Daniel, I'm..."],[9255,9355,"I'm so sorry."],[9355,9442,"I ruined everything."],[9442,9488,"I just..."],[9697,9801,"I messed everything up."],[9876,9939,"Hey,"],[9972,10030,"relax."],[10080,10143,"You're drunk."],[10168,10281,"Besides, I'm not as fragile"],[10281,10335,"as I look."],[10439,10477,"So..."],[10489,10527,"you're not..."],[10585,10681,"you're not gonna fire me?"],[10727,10785,"Fire you?"],[11052,11106,"No."],[11186,11232,"Lily,"],[11336,11511,"you're more than an assistant."],[11882,11941,"I like you."],[12128,12199,"You're kind."],[12241,12316,"You're different."],[12654,12741,"I wanna be with you."],[13075,13113,"I..."],[13409,13513,"Uh, yeah..."],[13513,13551,"I don't know."],[13551,13659,"I...I need more time."],[13659,13697,"I'm..."],[13697,13730,"I don't..."],[13730,13822,"I'm drunk and it's..."],[13822,13888,"It's kind of night..."],[13888,13909,"I just..."],[13909,13993,"Then I'll wait,"],[14239,14347,"for as long as it takes."]],"22":[[1343,1434,"Where am I?"],[1651,1705,"My place."],[2002,2118,"You passed out last night."],[2139,2177,"Here."],[2644,2727,"How do you like your eggs?"],[2794,2877,"I'm not the best cook,"],[2877,3023,"so don't say something fancy..."],[3078,3136,"but I'll try."],[3299,3420,"Thank you, Daniel."],[3495,3566,"Whenever you're ready,"],[3566,3691,"just come down to the kitchen, okay?"],[6227,6285,"Looks like you've found"],[6285,6381,"some of my homework."],[6460,6523,"Ugh..."],[6523,6581,"I'm sorry, I..."],[6581,6652,"I didn't mean to."],[6652,6706,"It was here,"],[6706,6773,"Don't worry about it. -and just..."],[6894,6977,"Eric Moretti..."],[7040,7132,"isn't just trouble."],[7152,7236,"He is the most dangerous man"],[7236,7290,"in the city."]],"23":[[421,525,"He was the one..."],[571,629,"at the party?"],[796,884,"All you need to know"],[884,1009,"is this person is deadly,"],[1059,1126,"ruthless."],[1230,1317,"These gangs..."],[1472,1547,"I swear,"],[1593,1668,"I'll wipe them out."],[1726,1830,"You know they're the cancer"],[1830,1901,"of the city."],[1901,2027,"They deal drugs"],[2043,2131,"to teenagers."],[2131,2185,"Matter of fact,"],[2185,2394,"I think your father's case is involved,"],[2394,2452,"somehow."],[2498,2573,"I never..."],[2602,2702,"tolerate drug dealers."],[3645,3741,"Come to me now,"],[3741,3949,"if you still wanna save your family."],[4350,4433,"I'm sorry, Daniel."],[4433,4487,"I just..."],[4550,4654,"I have to go figure something out."],[4871,4921,"Okay."],[6064,6197,"Eric Moretti..."],[6452,6614,"I will get whatever I want."],[6706,6848,"You won't do a damn thing."]],"24":[[767,938,"Eric, things have changed."],[1109,1201,"Daniel asked me out."],[1259,1330,"Is that so?"],[1893,2039,"Do you think I care"],[2081,2193,"that Daniel asked you out?"],[2364,2489,"You think I would let someone"],[2489,2585,"take what's mine?"],[2660,2698,"Hmm?"],[2844,3003,"Nobody touches you but me."],[3574,3628,"Eric..."],[3716,3887,"You belong to me."],[4175,4241,"Announcement."],[4300,4475,"Prosecutor Daniel has arrived."]],"25":[[166,271,"Don't move."],[308,408,"Stay quiet."],[1280,1393,"You've been making some"],[1393,1493,"big moves lately."],[1810,1881,"So have you,"],[1926,2127,"Mr. District Attorney."],[2527,2581,"So,"],[2702,2798,"ask what you want."],[4104,4187,"I know why you want"],[4187,4295,"Tracy's support."],[4596,4779,"You wanna expand your little gangs."],[4825,4938,"And what does that have to do"],[4938,4992,"with you?"],[5601,5705,"If you cross a line,"],[5705,5834,"I'll be the first to make you pay."]],"26":[[216,350,"This isn't your fight, Daniel."],[400,508,"We both know that."],[538,596,"How long..."],[608,688,"do you think"],[738,875,"your little gang is gonna last?"],[1689,1730,"Yeah."],[2940,3040,"You're playing with fire."],[4279,4400,"Can I talk to you about something?"]],"27":[[321,429,"You seem to have forgotten"],[429,513,"your place."],[583,675,"You're mine, Lily."],[767,850,"Your loyalty,"],[871,934,"your body,"],[988,1096,"and your life..."],[1176,1263,"all mine."],[1384,1430,"I know."],[1543,1651,"But Daniel is a good guy."],[1685,1735,"Okay?"],[1772,1839,"He helped me,"],[1839,1947,"and he brought my mom flowers"],[1947,2056,"at the hospital,"],[2056,2160,"and he stayed up with me."],[2185,2264,"I don't need you"],[2264,2439,"to tell me how to get things done."],[3044,3103,"I'm sorry."],[3319,3353,"I just..."],[3353,3424,"Don't"],[3424,3591,"question me anymore."],[3712,3762,"I understand."],[4262,4425,"I didn't say you could leave."],[4462,4554,"I'll do what you say,"],[4596,4717,"because you saved my mom."],[4771,4929,"But you're making me lose who I am."],[4996,5171,"Can I please go to the hospital"],[5171,5251,"to visit her now?"],[5305,5367,"First,"],[5480,5776,"put this in Daniel's office desk drawer."],[6310,6368,"What is this?"],[6398,6452,"What did I say"],[6452,6564,"about asking questions?"],[6669,6719,"Don't worry."],[6748,6877,"Our DA friend is going to"],[6877,6994,"love this gift."],[7136,7253,"Let me know when you get it done."]],"28":[[437,487,"Hey, Mom."],[554,642,"You're still holding on."],[1113,1176,"Lily,"],[1330,1484,"the surgery fees, the..."],[1547,1639,"hospital bill,"],[1814,1931,"where did you get the money?"],[2077,2152,"It's okay, Mom."],[2281,2373,"Okay, I just..."],[2506,2681,"I pulled some extra shifts at the bar."],[2715,2894,"And some really kind people"],[2894,2973,"helped me out."],[3386,3524,"Some kind people..."],[3670,3728,"Your dad..."],[3787,3878,"said the same."],[4029,4175,"Don't go down his path."],[4329,4425,"Don't go astray."],[4583,4683,"It's not like that, Mom."],[4863,4967,"That's my daughter."],[5271,5422,"Don't do bad things, Lily."],[5555,5701,"No amount of money"],[5739,5851,"can buy you back."],[6135,6189,"I know, Mom."],[6327,6435,"Just rest, okay?"],[6806,6927,"I'll be back really soon, okay?"],[6952,6994,"Okay."],[7027,7057,"Okay."],[7057,7111,"I love you."]],"29":[[316,362,"Thank you."],[517,617,"You know the muffins here,"],[667,775,"they were my favorite,"],[775,834,"as a kid."],[892,959,"Whenever I was down,"],[959,1076,"my mom used to bring me here."],[1134,1267,"She really knows how to pick a place."],[1434,1493,"My mom died,"],[1547,1618,"when I was fifteen."],[1814,1981,"Cancer dragged on for years and..."],[2022,2097,"drained all the money."],[2160,2189,"So,"],[2248,2427,"I promised myself when I grew up,"],[2502,2585,"I'd help people."],[2640,2761,"You're a really good man, Daniel,"],[2815,3053,"better than a lot of people that I know."],[3219,3253,"Lily,"],[3474,3616,"I told you I wanna be with you."],[3666,3724,"No, I know..."],[3749,3807,"you have"],[3837,3991,"a lot going on right now,"],[3991,4095,"bills, work..."],[4166,4262,"I wanna help you carry it."],[4316,4487,"I appreciate you so much."],[4562,4587,"But..."],[4621,4683,"I can't."],[4729,4879,"My life is such a mess right now."],[4879,4913,"I..."],[4992,5100,"I'm not gonna push you, Lily."],[5171,5238,"Whenever you're ready,"],[5305,5359,"I'll be here."],[5576,5693,"The better you are,"],[5693,5751,"Daniel,"],[5784,6026,"the more I feel like I don't deserve this."]],"30":[[4,145,"What are you afraid of, Lily?"],[262,421,"Your warmth makes me want to break"],[421,525,"free from Eric."],[558,671,"But the hospital bills..."],[717,809,"Eric's threats..."],[842,959,"What choice do I have?"],[975,1001,"Lily?"],[1071,1117,"Are you okay?"],[1326,1480,"Don't do bad things, Lily."],[1580,1722,"No amount of money"],[1764,1872,"can buy you back."],[2027,2106,"Daniel, you..."],[2239,2314,"you make me feel like"],[2314,2464,"someone actually cares about me."],[2540,2677,"I already told you, Lily."],[2727,2873,"I wanna help carry your burdens."],[2873,3011,"You don't have to carry it alone."],[3111,3324,"Eric...only controls me."],[3411,3453,"Okay."],[3557,3712,"Yeah, I... I wanna try."],[3787,3953,"I wanna try and be together and just..."],[3991,4066,"have a fresh start."],[4483,4512,"Lily,"],[4558,4608,"it's okay."],[4700,4796,"One step at a time."],[4850,4934,"One step at a time."]],"31":[[45,250,"This place is beautiful."],[304,450,"I really wish I could bring my mom here."],[1322,1372,"Um..."],[1430,1555,"I'm gonna run to the restroom,"],[1555,1593,"really quick."],[1634,1664,"Okay."],[1693,1730,"I'll wait here."],[2218,2327,"Having fun shopping"],[2327,2389,"with Daniel?"],[2502,2577,"Have you forgotten"],[2577,2681,"about the flash drive?"]],"32":[[166,271,"Eric, I..."],[342,392,"tried to,"],[392,550,"but Daniel has been so kind to me,"],[550,692,"and I don't know if I can..."],[692,788,"Remember,"],[921,1055,"you don't have a choice."],[1167,1242,"I'll get it done."],[1422,1509,"Don't disappoint me."],[1614,1685,"I won't, Eric."],[2310,2360,"Daniel,"],[2439,2515,"I'm sorry."],[2902,2977,"Coffee's cold."],[3061,3103,"Um..."],[3144,3244,"Daniel, I'm really sorry"],[3244,3332,"but I have to get going."],[3361,3403,"What's wrong?"],[3411,3557,"Nothing, I just..."],[3557,3611,"My mom."],[3737,3832,"She texted me and"],[3832,3970,"she told me she's not feeling well."],[3999,4079,"You want me to drive you?"],[4087,4149,"No."],[4149,4216,"No, it's..."],[4270,4308,"it's okay."],[4362,4475,"but thank you, for..."],[4579,4629,"everything."],[4658,4700,"Okay."]],"33":[[2606,2660,"Daniel,"],[2731,2836,"your kindness makes me"],[2836,3028,"want to escape from all of this."],[3153,3382,"But Mom's life is in Eric's hands."],[3453,3570,"Doing these tasks,"],[3645,3741,"am I betraying you,"],[3795,3878,"or saving her?"],[4112,4208,"Don't disappoint me."],[4316,4383,"I won't, Eric."],[4583,4692,"What am I even doing?"],[4758,4804,"Who's there?"]],"34":[[33,79,"Come out."],[296,354,"Oh..."],[354,425,"It's you, Lily."],[533,617,"You scared me!"],[654,763,"You really work hard, man."],[763,850,"You scared me, too."],[909,996,"You know, we appreciate"],[996,1096,"your dedication."],[1096,1222,"Don't stay up too late tonight."],[1259,1368,"Go home and get some rest."],[1426,1484,"Yeah, I..."],[1514,1572,"I won't until..."],[1614,1718,"I'll leave when I'm done this."],[1760,1801,"Okay."],[4054,4104,"Hey,"],[4158,4229,"morning, Daniel."],[4262,4333,"Um, I just have a..."],[4354,4479,"quick question about..."],[4479,4617,"your investigation on Eric's crew."]],"35":[[75,120,"Hey,"],[171,250,"morning, Daniel."],[283,354,"Um, I just have a..."],[375,500,"quick question about"],[500,638,"your investigation on Eric's crew."],[767,829,"Do they..."],[888,971,"do they deal drugs?"],[1005,1046,"Lily?"],[1142,1222,"Early morning call."],[1272,1326,"We are..."],[1347,1593,"still investigating, but very likely."],[1618,1710,"Why the sudden question?"],[1805,1881,"I was just..."],[1901,1960,"curious."],[1985,2122,"These cases must be stressful."],[2181,2235,"It's tough,"],[2289,2406,"but with you around,"],[2423,2519,"I feel a bit lighter."],[2598,2669,"Dinner again tonight?"],[2865,2990,"Don't do bad things, Lily..."],[3023,3107,"No, I know..."],[3107,3165,"you have"],[3199,3340,"a lot going on right now."],[3382,3474,"I wanna help you carry it."],[3616,3724,"You're always so kind, Daniel."],[3782,3870,"I'll tell you tonight, okay?"],[3933,4004,"Don't rush, Lily."],[4291,4446,"You've tied me with Mom's life."],[4571,4688,"I'm doing your tasks,"],[4750,4813,"not for you,"],[4854,4909,"but for her."],[6289,6406,"I did what you asked, Eric."],[6473,6635,"I put the flash drive in Daniel's desk."]],"36":[[75,129,"Good."],[291,383,"You didn't disappoint me."],[575,642,"Whenever you're ready,"],[729,775,"I'll be here."],[804,967,"Don't do bad things, Lily."],[1121,1347,"I just want my mom to live, Eric."],[1434,1505,"That's the only reason"],[1505,1568,"I'm helping you."],[1689,1772,"I know that your gang"],[1772,1864,"doesn't do drugs."],[1918,2056,"My mom had..."],[2106,2210,"needles in her arm..."],[2268,2331,"when she died."],[2598,2694,"And I swore..."],[2694,2811,"that in my territory,"],[2886,3061,"no one would ever get hurt"],[3061,3161,"by that stuff again."],[3240,3390,"Who should I believe?"],[3586,3774,"Do you still care for me?"],[3837,3933,"Of course I care."],[4658,4733,"I care"],[4779,4950,"about all of my possessions."],[5009,5067,"I know..."],[5096,5226,"that I owe you, Eric."],[5276,5347,"But I don't wanna keep"],[5347,5438,"hurting everyone."],[5455,5518,"Hurt?"],[5597,5764,"Lily, you don't have a choice."],[5951,6051,"Keep an eye on Daniel."],[6122,6181,"Tomorrow,"],[6385,6544,"he is going to have a surprise visit,"],[6560,6740,"and that flash drive is going to"],[6740,6810,"put him away"],[6848,6990,"for a long time."],[7394,7528,"You got what you want, Eric."],[7720,7816,"You belong..."],[7857,7932,"to me,"],[8078,8166,"remember that."]],"37":[[533,633,"This is Robert's file."],[692,725,"Thank you."],[1159,1192,"Lily,"],[1284,1388,"you look exhausted."],[1430,1480,"What's going on?"],[1576,1618,"Um,"],[1760,1810,"Daniel,"],[1839,1901,"I, um..."],[1956,1985,"Hey,"],[2097,2156,"no stress."],[2210,2248,"I know you've been"],[2248,2352,"having a hard time lately."],[2352,2398,"I just..."],[2502,2594,"wanna help carry the load."],[3061,3153,"You belong..."],[3199,3257,"to me."],[3399,3432,"Thank you."],[3503,3674,"You're always so kind to me."],[3774,3820,"How's your mom?"],[3853,3933,"Well, she is um..."],[3983,4029,"she is okay."],[4175,4295,"Then how is the gang case going?"],[4379,4583,"It's....slow going."],[4646,4725,"I have to step it up."],[4754,4859,"Honestly, he is..."],[4992,5063,"these gangs..."],[5121,5380,"can't let them ruin any more families."],[5559,5597,"Um..."],[5743,5793,"Ruthless?"],[5793,5830,"Eric..."],[5897,6039,"are they all really that bad?"],[6085,6122,"You know,"],[6506,6639,"some gangster, some people,"],[6752,6869,"might seem a certain way..."],[6969,7102,"But...underneath,"],[7173,7248,"they're all filthy."],[7365,7403,"Lily,"],[7528,7578,"your mom,"],[7732,7924,"I looked into her hospital bills."],[7957,8162,"Those surgery costs and meds..."],[8266,8375,"Eric has been transferring money"],[8375,8470,"into your mom's account,"],[8495,8537,"right?"]],"38":[[4,75,"How did you know?"],[87,166,"Are you helping him,"],[237,350,"or is he forcing you?"],[500,583,"I'm sorry..."],[629,796,"I didn't know how to tell you,"],[796,917,"and I didn't mean to hide anything."],[917,963,"It just..."],[1076,1184,"happened really fast."],[1322,1443,"Lily, I don't"],[1443,1668,"want you dragged any deeper."],[1714,1876,"And Eric is dangerous."],[1901,1997,"Lily, he is..."],[2043,2206,"he's ruined so many lives."],[2331,2444,"If you love me,"],[2548,2627,"tell me everything."],[2740,2815,"I'll protect you."],[2815,2944,"I'll protect your mom."],[2998,3044,"I..."],[3228,3340,"I don't even know how to say it."],[3653,3732,"Think about your mom."],[3870,3978,"If you're helping him,"],[4020,4108,"how can I trust you?"],[4600,4654,"I'm sorry."],[4738,4788,"I'm sorry,"],[4788,4954,"I was a little harsh back there."],[4992,5055,"Lily, I..."],[5117,5284,"I just care about you, okay?"],[5284,5376,"I don't wanna see you..."],[5409,5576,"involved in this mess."],[5676,5714,"I don't..."],[5876,5943,"I don't even know"],[5943,6031,"who to trust, Daniel..."],[6031,6064,"Just..."],[6231,6318,"just trust me."],[6473,6548,"That's all you need."]],"39":[[300,337,"Okay."],[646,700,"Eric"],[800,921,"told me to put the flash drive"],[921,1005,"in your desk."],[1076,1146,"I'm sorry."],[2414,2473,"What is this?"],[2573,2656,"What does that scum..."],[2756,2823,"want with this?"],[3332,3399,"I don't know..."],[3974,4099,"Thank you..."],[4099,4212,"for trusting me."],[4312,4466,"I'll talk to the accounting office,"],[4466,4533,"and we'll see if we can"],[4533,4633,"make any advance payments"],[4633,4779,"for your mom's bill."],[5005,5055,"Thank you."],[5217,5313,"Thank you so much."],[5376,5413,"You know,"],[5480,5551,"Eric's probably gonna"],[5551,5626,"track you down."],[5714,5797,"You're gonna be safer"],[