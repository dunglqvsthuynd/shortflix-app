wrong?"],[3353,3399,"I don't know"],[3399,3482,"anything wrong I do."],[3578,3674,"Why won't you eat it?"],[3966,4091,"Daniel, can I please just go?"],[4191,4225,"Yeah!"],[4308,4366,"Yeah, yeah!"],[4366,4416,"We can leave."],[4454,4562,"We can leave just after you..."],[4562,4621,"after you..."],[4621,4692,"eat your breakfast."],[7207,7278,"It's been a while."],[7328,7378,"Eric..."],[7469,7553,"please help me."],[7628,7711,"What are you talking about?"],[7711,7757,"What's wrong?"],[7891,7991,"I'm scared."],[8033,8070,"Okay."],[8087,8145,"Alright, you know what,"],[8145,8199,"don't worry."],[8199,8366,"I will send someone over right away!"],[8425,8516,"You have to come."],[8516,8629,"Daniel is crazy."],[8712,8767,"I...I knew..."],[8767,8804,"Lily..."],[8846,8921,"Where are you?"],[9175,9221,"Lily..."],[9221,9267,"Lily?"],[9642,9676,"No, you..."],[9734,9805,"idiot."],[9909,10005,"What have you done?"],[11540,11753,"Don't forget our promise."],[11774,11853,"I won't."]],"44":[[158,196,"Come."],[337,400,"Come here, you can't go."],[713,759,"You know,"],[796,934,"I'd burn the world for you."],[1001,1046,"Right, Lily?"],[1409,1643,"Don't play innocent!"],[1739,1822,"I know"],[1822,1922,"you've been scheming"],[1922,1989,"behind my back."],[1989,2081,"All of you!"],[2281,2431,"I...I wasn't, I swear."],[2431,2481,"Come on, Lily..."],[2606,2706,"I'm protecting you."],[2761,2869,"Don't forget that!"],[3782,3903,"Your phone kept ringing."],[4070,4137,"Where were you?"],[4137,4212,"Who were you with?"],[4212,4304,"It...It was my mom."],[4304,4375,"I promise..."],[4375,4425,"She was..."],[4425,4596,"Don't you lie to me!"],[4667,4754,"I'm not"],[4754,4879,"someone you wanna mess with!"],[4942,5009,"I'm warning you."],[5447,5518,"I'm warning you."],[6227,6297,"All I wanted"],[6335,6564,"was to destroy Eric, that son of a bitch!"],[6644,6694,"But now..."],[7007,7140,"you've become my everything."],[7257,7311,"You don't..."],[7332,7378,"Don't leave."],[7449,7532,"Don't leave me, Lily..."],[7599,7640,"Don't leave."]],"45":[[25,112,"Don't leave me, Lily."],[171,225,"Don't leave."],[475,563,"Lily, go."],[684,734,"Tracy?"],[817,921,"What brings you here?"],[934,1009,"Eric sent me."],[1121,1222,"Why are you helping me?"],[1272,1476,"Eric and I are allies now."],[1543,1597,"Daniel,"],[1630,1760,"you have gone too far."],[1768,1810,"Oh, it's..."],[1939,1997,"She is fine."],[2081,2173,"She is not going anywhere."],[2331,2419,"Step aside!"],[2452,2606,"My family stands with Eric now."],[2648,2727,"You touch her?"],[2773,2911,"You declare war on me!"],[2911,3078,"Don't threaten me in my own house,"],[3078,3123,"please."],[3123,3169,"Threat?"],[3215,3265,"No."],[3299,3399,"This is a warning."],[3566,3611,"Lily,"],[3661,3699,"let's go."]],"46":[[838,917,"Hey, hey, hey..."],[1363,1438,"Hey, okay..."],[1476,1572,"Okay...Lily,"],[1626,1685,"Look at me."],[1701,1755,"Look at me."],[1822,1906,"You're safe now."],[1951,1993,"Okay..."],[2093,2210,"Eric, I've known..."],[2235,2373,"everyone who insulted my mom,"],[2373,2469,"my dad,"],[2469,2548,"and Tracy she..."],[2548,2598,"Tracy..."],[2627,2898,"Tracy stands with me now, okay?"],[2973,3086,"Her whole family does."],[3178,3257,"And as for Daniel?"],[3332,3495,"Everyone sees his corruption."],[3574,3678,"His time has come."],[3728,3766,"Okay?"],[3766,3824,"It's over."],[3883,4008,"I should have never"],[4008,4108,"let you stay there."],[4149,4241,"You belong to me."],[4312,4408,"And what's mine,"],[4450,4671,"I protect and no one touches."],[4733,4779,"But..."],[4842,4950,"Daniel he..."],[4950,5100,"he said that you were a monster."],[5113,5184,"The monster..."],[5221,5367,"is the one that lied to you."],[5543,5718,"I'm the one who kept you breathing."],[5964,6072,"And I promise,"],[6072,6189,"I will protect"],[6189,6310,"you and your mother."],[6377,6452,"No matter what."],[6731,6794,"Eric..."],[6869,6998,"you're all that I have."],[7119,7357,"And I will always...be here."]],"47":[[237,316,"Did you sleep okay?"],[546,633,"Do you think Daniel is"],[633,713,"coming after me?"],[754,867,"Daniel runs"],[900,1059,"one of the biggest drug cartels"],[1059,1109,"in the city."],[1255,1384,"But I will do my best"],[1447,1547,"to protect what's mine."],[1643,1714,"Why didn't you tell me?"],[1910,2027,"I didn't wanna tell you,"],[2027,2198,"because I wanted to protect you."],[2243,2398,"And I was afraid that if you knew"],[2398,2498,"who Daniel was,"],[2535,2619,"you wouldn't be able to do"],[2619,2694,"your tasks."],[2886,2923,"But,"],[3003,3086,"Daniel's"],[3128,3319,"cartel dream blew up in his face."],[3361,3486,"Tracy made sure of that."],[3574,3645,"You're nothing"],[3645,3795,"but a liability to him now."],[4054,4141,"Let's forget about Daniel."],[4187,4333,"I want to show you my world,"],[4458,4533,"my real world."],[4625,4671,"Okay."],[4804,4871,"I want to see it."],[5693,5814,"Morning, Mr. Moretti."],[5814,5955,"Thank you so much"],[5955,6089,"for hosting these events"],[6089,6268,"to help recovering drug addicts."],[6327,6410,"My son,"],[6448,6673,"is recovering well, and should be..."],[6715,6790,"pretty good soon."],[6894,7061,"He and I wanted you to have this."],[7090,7152,"It's a lemon."],[7198,7294,"We grew it organically"],[7294,7353,"in our garden."],[7695,7753,"Thank you."],[7807,7899,"That's why I do what I do."],[7928,8045,"Tell you son to keep fighting."],[8045,8145,"And if you need anything,"],[8145,8204,"let me know."],[8224,8283,"Absolutely."],[8591,8704,"This place is not"],[8704,8871,"what I expected from a gang turf."],[9000,9075,"No drugs,"],[9075,9142,"no filth."],[9163,9284,"Gambling is on a leash."],[9355,9455,"It's a place my mother always"],[9455,9505,"dreamed of..."],[9693,9768,"a place where"],[9768,9901,"people can thrive together."],[9959,10039,"I built it for her."],[10176,10264,"They respect you here,"],[10322,10414,"and not out of fear."],[10548,10702,"They respect me because I care."],[10839,10906,"Lily, I am..."],[10952,11069,"so sorry."],[11115,11232,"I acted like a monster."],[11373,11494,"This place isn't as corrupt"],[11494,11594,"as Daniel said it was."]],"48":[[588,629,"Lily,"],[784,942,"I want to give you everything,"],[1005,1080,"safety,"],[1126,1213,"a future..."],[1363,1484,"But I need one more thing"],[1484,1539,"from you."],[1639,1730,"Another task?"],[1764,1818,"No,"],[1893,2014,"I want you to stay with me."],[3178,3261,"You know, Cabrón,"],[3294,3449,"we're very disappointed in you."],[3511,3870,"You let Eric Moretti push you around."],[3920,3978,"Relax."],[4133,4270,"The cartel will get what it wants."],[4366,4491,"Eric Moretti is finished."],[4575,4646,"Okay, homie."],[4708,4854,"You better figure this shit out,"],[4875,4959,"otherwise,"],[4992,5125,"it's gonna be your ass"],[5150,5267,"on the chopping block, okay?"],[5380,5455,"I'll handle..."],[5488,5588,"everything."],[5747,5801,"First,"],[5980,6164,"I need you to do me a favor."],[7011,7102,"There you are, my love."]],"49":[[900,988,"Where the hell is she?"],[1034,1105,"Is she okay?"],[1197,1234,"Hello?"],[1272,1355,"Eric..."],[1368,1518,"Lily is in my hands now."],[1534,1626,"You want her breathing?"],[1664,1760,"Drop everything,"],[1785,1843,"and kneel."],[1889,2014,"If you touch her,"],[2014,2193,"I will make you beg for death."],[2360,2460,"Sentimental fool."],[2481,2573,"Scrap your empire,"],[2602,2698,"I own this street now,"],[2727,2823,"or say goodbye forever."],[2923,3065,"Using her against me, hm?"],[3148,3307,"What makes you think I give a damn?"],[5359,5430,"It's okay, Lily..."],[5447,5484,"It's okay."],[5505,5551,"It's okay."],[5601,5655,"It's okay..."],[6001,6051,"Welcome."],[6318,6414,"It's our house of love."],[6443,6506,"This"],[6506,6598,"is sick!"]],"50":[[4,58,"I'm sorry."],[58,104,"I know,"],[104,196,"it's a little dirty."],[246,379,"The cartel once used it,"],[450,575,"to kill"],[575,650,"and bury people."],[713,817,"But I told them,"],[829,909,"never again."],[980,1138,"No one is allowed to use this room,"],[1192,1263,"except for us."],[1405,1459,"Oh..."],[1589,1689,"when Eric arrives,"],[1810,1889,"I'll finish"],[1931,1989,"everything,"],[2093,2248,"and then it'll only be us."],[2389,2427,"Oh!"],[2469,2540,"I almost forgot."],[3090,3190,"Where the fuck is it?"],[3357,3395,"Okay."],[3445,3482,"Okay,"],[3566,3599,"hey,"],[3774,3874,"I got this for you!"],[3958,4083,"You can hit me with this."],[4095,4183,"Hit me with this."],[4245,4304,"Yes,"],[4325,4491,"it'll make up for the time that I hurt you."],[4608,4675,"You hit me,"],[4713,4813,"and you'll feel happy,"],[4813,4992,"and then we can be together, right?"],[5267,5309,"Lily,"],[5422,5618,"are you using my guilt against me,"],[5880,5947,"based on that?"],[6377,6498,"Why are you so cruel to me?"],[6560,6852,"Why are you so cruel to me, Lily?"],[7077,7136,"Why?"],[7161,7353,"You don't have to be so cruel to me."],[7394,7507,"I'm not gonna hurt you..."],[7640,7686,"Why?"],[7791,7899,"Daniel Hayes!"],[8120,8299,"I didn't expect you to be here on time."],[8400,8429,"Okay."],[8491,8583,"We'll go outside,"],[8583,8666,"and finish this,"],[8746,8833,"and then we can come back in."]],"51":[[41,141,"Daniel Hayes!"],[759,921,"Let her go."],[984,1046,"Now!"],[1080,1259,"You should have stayed away."],[1576,1693,"We were fine!"],[1801,1893,"I fixed her."],[1960,2072,"I fixed this city!"],[2106,2206,"Your filth"],[2239,2385,"has ruined the city,"],[2427,2581,"and it ruined her family."],[2594,2648,"Bullshit!"],[2731,2790,"Without me"],[2790,2915,"cutting deals with the cartel,"],[2915,3048,"this place would be ashes!"],[3107,3186,"Without me,"],[3282,3340,"who protects her?"],[3436,3520,"You?"],[3578,3720,"Your filthy gang?"],[3753,3858,"I never claimed"],[3920,4024,"to save the city."],[4104,4200,"But I do claim"],[4229,4366,"to protect what's mine."],[4433,4483,"Really?"],[4579,4654,"Stay."],[5050,5105,"Prove it."],[5155,5209,"Pick it up."],[5255,5321,"No, no..."],[5492,5584,"Pick it up!"],[6081,6193,"Relax."],[6235,6356,"I'm not gonna hurt her."],[6452,6564,"Anything happens to her,"],[6852,6952,"I'm going with her."],[7457,7503,"Now..."],[7691,7749,"cut your arm."],[7816,7903,"Right here, right here."],[8016,8137,"I took a cut for her once."],[8137,8187,"Can you?"],[8337,8454,"Stay, stay!"],[9325,9380,"Oh, no..."],[9580,9642,"No..."],[9642,9730,"No, Eric, don't..."],[9755,9897,"Don't, don't, no..."],[10810,10877,"Well, well..."],[10902,11023,"I really underestimated"],[11023,11106,"you, Eric..."],[11165,11244,"I really did."],[11294,11332,"Okay,"],[11382,11440,"next game."],[11574,11682,"Lose the ring."],[11795,11928,"No ring, no command,"],[11928,12016,"no family,"],[12057,12116,"no power."],[12116,12199,"You're nothing without it."],[12199,12295,"You're nothing"],[12295,12395,"without that ring!"],[12604,12708,"Why don't we just"],[12708,12883,"cut that finger clean off?"]],"52":[[66,179,"Why don't we just"],[179,342,"cut that finger clean off?"],[621,696,"Is that fine by you?"],[1409,1501,"I just wanna make sure"],[1501,1643,"you can put that ring back on."],[1643,1676,"That's all."],[1705,1772,"No hard feelings."],[1810,1868,"Stop!"],[2268,2323,"Fine."],[2569,2623,"No..."],[2723,2761,"no..."],[2811,2857,"no..."],[3161,3257,"Eric, no, Eric..."],[3257,3411,"stop, stop!"],[3465,3549,"What did I tell you?"],[3712,3845,"Don't make my decisions for me."],[4045,4154,"Don't tell me how to act."],[4300,4354,"No..."],[4400,4487,"Just let me..."],[4504,4592,"protect you."],[5447,5501,"No!"]],"53":[[1714,1843,"Daniel's mess is buried."],[1868,1989,"You owe me, Eric."],[2043,2093,"I know."],[2185,2277,"That's why I'm letting you"],[2277,2352,"run my family"],[2352,2414,"while I'm gone."],[2460,2502,"So..."],[2540,2619,"reconsider."],[2660,2756,"If we were married,"],[2790,2923,"my parents keeps everything"],[2923,3015,"under control."],[3974,4062,"Morning, love."],[4216,4283,"How are you feeling?"],[4608,4646,"Good."],[4888,4967,"Ignore Tracy."],[5038,5159,"She jokes around too much."],[5217,5372,"I am already spoken for."],[5438,5501,"Relax."],[5580,5747,"I'd make a terrible bride anyway."],[5926,6035,"She is just jealous."],[6101,6210,"Because you belong to me."],[6247,6289,"Maybe."],[6306,6343,"But..."],[6377,6485,"you belong to me now, too."],[6602,6777,"Her parents are in safe hands now."],[6806,6927,"I'll handle what's left."],[6927,7011,"Consider it done."],[7057,7127,"Thank you, Tracy."],[7411,7570,"You are the real danger, girl."],[7607,7732,"Got him to walk away from"],[7732,7811,"his kingdom."],[8095,8233,"Are you ready to disappear with me?"],[8787,8883,"Only if you won't let me go."]]}