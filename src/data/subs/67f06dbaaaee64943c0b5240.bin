{"1":[[208,400,"Thank you all for being here tonight"],[400,613,"to celebrate our rehearsal dinner."],[629,738,"Tomorrow,"],[796,975,"James and I will officially be..."],[1046,1176,"husband and wife!"],[1355,1447,"Cheers!"],[1559,1730,"Cheers."],[2481,2665,"I am ready to make payment, Nolan."],[3148,3307,"Where are the rest of my guns?"],[3307,3557,"I'm not selling one single bullet to you."],[3557,3716,"The deal is off."],[3716,4008,"I fly all the way to your shitty country,"],[4008,4229,"and you disrespect me like this!"],[4229,4362,"Do you know who I am?"],[4642,4821,"I am a general,"],[4871,5125,"and you are just an arms dealer,"],[5125,5317,"spoiled businessman."],[5317,5559,"I am an arms dealer,"],[5559,5751,"but I have my rules."],[5751,5910,"And I told you many times,"],[5910,6064,"my guns go anywhere"],[6064,6352,"but the child army in your country."],[6373,6673,"Killing and get killed,"],[6702,6844,"that's all those little maggots"],[6844,6927,"are good for."],[6944,7115,"I had one line,"],[7228,7344,"and you crossed it."],[7528,7778,"And I said,"],[7778,7953,"the deal is fucking off!"],[8354,8546,"God, I'm so sorry Mia."],[8546,8746,"My period just hit."],[8746,8850,"Do you mind grabbing me some"],[8850,8983,"tampons from downstairs?"],[8983,9071,"Of course."],[9071,9255,"Come take a seat."],[9384,9626,"I'm dying here..."],[9626,9738,"Thanks girl."],[9738,9943,"Of course, what are best friends for?"],[9943,10014,"Honey,"],[10014,10097,"I'll be right back."],[10097,10239,"Will you stay and take care of Lucy?"],[10239,10310,"Of course."],[10310,10427,"Okay."]],"2":[[50,166,"Honey, I'll be right back."],[166,308,"Will you stay and take care of Lucy?"],[308,396,"Of course."],[396,462,"Okay."],[1059,1188,"So James."],[1188,1322,"How was my acting?"],[1322,1422,"It was 10/10."],[1422,1551,"She didn't have a clue."],[1551,1785,"Well, I did my part."],[1785,1910,"Now it's your turn."],[1910,1997,"Fuck me good"],[1997,2223,"before your bride comes back."],[2594,2886,"You want to cancel the deal?"],[2886,3144,"Well... then..."],[3257,3520,"What use are you to me now?"],[3628,3795,"You are a dead man."],[3862,4049,"Boss! Get down!"],[4704,4842,"Bring him to me!"],[4884,5021,"Dead or alive!"],[5330,5509,"Sorry, excuse me."],[6493,6627,"Don't scream."]],"3":[[467,563,"What are you doing?"],[563,700,"It's just a couple people getting it on."],[700,784,"Come on."],[1055,1251,"What the hell is wrong with you?"],[1568,1710,"You're bleeding."],[1764,1864,"I'll live."],[3111,3207,"Ugh."],[3303,3428,"You seem to know what you're doing."],[3465,3624,"I'm a kindergarten teacher."],[3670,3941,"Playground scrapes are my specialty."],[4037,4091,"There."],[4091,4304,"Now, I have to go."],[4337,4617,"My fiancé is waiting for me."],[4617,4742,"Fiancé?"],[4813,5113,"Yes! I'm getting married tomorrow."],[5113,5238,"Is this your thing?"],[5238,5438,"Going around, kissing other people's brides?"],[5497,5626,"What if it is?"]],"4":[[233,367,"So..."],[412,525,"you're getting married tomorrow?"],[525,658,"Yes,"],[658,859,"thank God he's not a creep like you."],[859,1013,"Creep?"],[1013,1109,"Is that what you think I am?"],[1117,1292,"Psycho..."],[2022,2314,"If you ever find the right girl, son,"],[2314,2515,"promise me,"],[2515,2681,"you'll never let her go."],[2681,2794,"Mommy..."],[2794,2982,"how do I know who's the right girl?"],[3032,3182,"You'll know, sweetie."],[3574,3649,"Boss."],[3674,3812,"Boss, hey, sorry we're late."],[3812,3862,"We got caught -"],[3862,4033,"Dig into the hotel records, Marcus."],[4033,4120,"See which guest is getting"],[4120,4191,"married tomorrow."],[4229,4358,"Yeah, alright boss, you got it."]],"5":[[684,892,"You just can't get your hands off me,"],[892,975,"James."],[1005,1084,"You know,"],[1172,1292,"it's not too late to dump Mia"],[1292,1397,"and marry me."],[1447,1530,"Our families have known"],[1530,1593,"each other for decades."],[1593,1747,"I can't just walk away from this."],[1847,2022,"But I do love your body more."],[2035,2177,"I might be marrying Mia"],[2177,2335,"but I'll still keep fucking you."],[2523,2861,"You naughty boy, James."],[3478,3620,"We gather here today"],[3620,3757,"to witness the love"],[3799,3995,"between Mia and James."],[4070,4187,"Together,"],[4237,4450,"they are bonded in holy matrimony."],[4508,4808,"Trusting, cherishing each other."],[4917,5025,"The maid of honor"],[5025,5100,"and the groom?"],[5100,5155,"Shhhhh!"],[5242,5367,"Poor Mia,"],[5367,5526,"she's the only one that doesn't know."],[5526,5718,"If anyone has reason these two"],[5718,5847,"should not be married..."],[5943,6243,"speak now or forever hold your peace."],[7140,7240,"I object!"]],"6":[[421,558,"From the moment I first saw you,"],[558,721,"I knew you were mine."],[980,1105,"Hey, you're in my spot."],[1330,1484,"If you want to shoot him,"],[1522,1664,"you'll have to go through me first!"],[1814,1972,"You'd risk your life for him?"],[2102,2168,"Let's see if he'd do"],[2168,2243,"the same thing for you,"],[2243,2356,"Mia Parker."],[2489,2723,"Come on, come on. - No, no!"],[2852,3065,"Here's how we settle this."],[3065,3178,"I loaded this gun"],[3178,3361,"with two real bullets."],[3361,3482,"See one I..."],[3482,3611,"I already fired."],[3611,3853,"That leaves one left in this chamber."],[3853,3966,"All the others"],[3966,4070,"are blanks."],[4162,4354,"You say you really love her,"],[4354,4483,"and you really want to marry her,"],[4517,4675,"I'll pull the trigger."],[4675,4817,"You live through it."],[4879,4988,"She's yours."],[5071,5267,"I'll play! I'll play with you."],[5292,5397,"Come on."],[5659,5784,"This game isn't for you."],[6001,6106,"I just..."],[6106,6268,"Please don't shoot me."],[6268,6406,"I do not want to die..."],[6406,6535,"Please."],[6535,6648,"And you dare make a vow"],[6648,6748,"trying to make this"],[6748,6835,"woman your wife?"],[6881,6981,"It's pathetic."],[6990,7061,"Mia, this is the man"],[7061,7127,"you're going to marry?"],[7127,7236,"Stop this, please!"],[7311,7549,"See you would take a bullet for him, Mia."],[7549,7716,"Just like I would do it for you."],[7774,7870,"That's love."],[7891,8033,"See, you and I understand it."],[8120,8199,"But not him."],[8199,8370,"He doesn't know love like we do."],[8566,8704,"Say you love her,"],[8704,8913,"I'll pull the trigger and you can prove it."],[9104,9163,"What's it going to be?"]],"7":[[66,221,"Just take her!"],[221,316,"She's yours!"],[412,492,"Just don't kill me."],[934,1046,"You just failed the test."],[1096,1180,"Wow."],[1234,1388,"But don't worry,"],[1388,1509,"I'm a reasonable man."],[1793,1918,"Now it's your turn."],[2623,2711,"Don't."],[2852,2961,"You..."],[3023,3182,"You sure about this?"],[3249,3390,"You love Mia?"],[3507,3624,"Damn sure."],[3928,4049,"You think I won't do it?"],[4179,4308,"You think I won't pull the trigger?"],[4396,4517,"You stole my fiancé!"],[4596,4704,"She isn't yours anymore."],[4804,4871,"She's mine!"],[5046,5088,"So, go on."],[5201,5326,"Pull the goddamn trigger!"],[5455,5689,"But if I live through it..."],[5689,5818,"you better leave town"],[5818,6043,"and never come back for her again."]],"8":[[258,350,"It's a blank!"],[684,838,"Looks like I proved myself."],[1159,1267,"You're coming with me."],[1351,1447,"Now!"],[1447,1576,"And as for you all,"],[1601,1668,"don't even think about"],[1668,1760,"trying to play hero."],[1814,1918,"I'm through playing games."],[2072,2185,"Put me down!"],[2243,2327,"Stop!"],[2410,2544,"Help!"],[3374,3424,"No!"],[3457,3599,"Let me go!"],[3749,3870,"I told you Mia,"],[3891,4020,"I always get what I want."]],"9":[[846,1046,"I've been collecting these for months."],[1084,1267,"Diamonds from Paris,"],[1267,1430,"Sapphires from Monaco."],[1497,1735,"Everything fit for my wife."],[1826,1939,"I don't want anything from you!"],[1997,2164,"I did my research on you."],[2223,2385,"You're an arms dealer!"],[2385,2469,"So?"],[2489,2686,"I don't steal, I don't rob."],[2719,2827,"I'm an honest businessman."],[2861,2961,"Honest?"],[3032,3136,"Do you know how much blood"],[3136,3244,"is on your hands?"],[3294,3395,"On these gifts?"],[3516,3762,"People buy your weapons to kill innocents!"],[3807,3920,"Children!"],[3970,4066,"I'm a teacher,"],[4095,4308,"what I hate the most are men like you."],[4846,4921,"Give it time,"],[4921,5038,"Mia Parker."],[5276,5455,"You might just change your mind."],[5659,5759,"Come here."],[6151,6252,"Look at yourself."],[6302,6602,"A queen deserves more than a coward."],[6690,6865,"See, I can give you everything."],[6956,7152,"The world at your feet."],[7152,7236,"Power."],[7236,7323,"Freedom."],[7453,7703,"All you have to do is accept it,"],[7795,7874,"and be mine."]],"10":[[663,821,"I'll never be yours."],[971,1105,"Get away from my stepson!"],[1134,1192,"Gladly,"],[1226,1359,"I want nothing to do with him."],[1438,1505,"You know I've seen"],[1505,1664,"too many women like you,"],[1664,1906,"sluts who think they can just walk in here"],[1906,1985,"and take everything"],[1985,2072,"that my daughter and I"],[2072,2164,"worked hard for."],[2206,2327,"Well..."],[2327,2452,"I spent ten years"],[2452,2669,"playing mother to this one,"],[2669,2765,"and I will not"],[2765,2977,"let somebody like you just ruin it all."],[3032,3094,"That's"],[3115,3353,"no way to talk to my fiancé, Victoria!"],[3378,3486,"So quit the barking."],[3591,3687,"It hurts my ears."],[3687,3820,"I'm marrying Mia,"],[3887,4095,"and you know I hate repeating myself,"],[4095,4220,"so don't test me."],[4220,4391,"Nolan, Mom is just saying"],[4391,4554,"that you're not thinking straight."],[4583,4704,"I mean, what would Dad say if -"],[4704,4813,"Dad's dead!"],[4838,4946,"Just like my mother."],[4992,5138,"And if you get in my way"],[5192,5330,"you'll both join them."],[5422,5476,"Come,"],[5530,5618,"let me give you the tour"],[5618,5676,"of where you'll be"],[5676,5793,"spending the rest of your days."],[6139,6231,"That little witch"],[6231,6414,"thinks she can just swoop in here"],[6414,6589,"and take half our family money."],[6606,6777,"I didn't marry that crime lord"],[6819,6948,"just to lose everything"],[6948,7052,"to someone like her."],[7082,7236,"Don't worry, Mom."],[7236,7353,"We'll destroy her"],[7411,7628,"piece by piece."]],"11":[[66,246,"How did this happen?"],[275,429,"This morning I was supposed to be"],[429,533,"Mrs. Brennan."],[567,654,"Trusting,"],[654,788,"cherishing each other..."],[992,1134,"Now I'm trapped in a mansion"],[1134,1363,"with a lunatic who thinks he owns me!"],[1443,1609,"I need to get out of here,"],[1609,1705,"far away"],[1705,1906,"from this prison he's kept me locked in."],[2702,2902,"Ah shit!"],[4767,4896,"I can't take two steps"],[4896,5025,"without those bodygaurds"],[5025,5092,"catching me!"],[5288,5380,"I can't give up,"],[5409,5501,"there must be something"],[5501,5555,"in this room"],[5555,5655,"that I can use."],[5872,6064,"A maid's uniform!"],[6064,6285,"Someone must have forgotten it here."],[6364,6610,"I can walk right out the front door,"],[6610,6777,"no one will look twice..."],[6844,6969,"but Nolan might."],[7244,7382,"Before I make this escape,"],[7444,7674,"I need to make sure Nolan isn't onto me."]],"12":[[842,896,"Can't sleep?"],[980,1021,"Or,"],[1067,1192,"plotting your next escape?"],[1272,1497,"A little seduction to get you drunk,"],[1497,1668,"and I'll walk right past you"],[1668,1789,"in that maid's uniform."],[1839,1951,"You know it gets"],[2018,2093,"very lonely"],[2093,2273,"in that big room all by myself."],[2331,2435,"Does it now?"],[3457,3532,"Have a drink with me?"],[3603,3707,"You don't seem like a"],[3766,3883,"whiskey girl to me."],[3945,4191,"Usually a bourbon girl, but..."],[4191,4333,"one can make exceptions."],[4433,4521,"So, you're"],[4583,4725,"drinking with the enemy now?"],[4829,4954,"I thought we could celebrate."],[5125,5246,"To us..."],[5338,5501,"being together."],[5772,5910,"Alright, Mia."],[5910,6056,"I'll drink with you..."],[6143,6260,"on one condition."],[6368,6460,"What's that?"],[6610,6785,"For every drink I take..."],[6956,7157,"you lose something"],[7157,7311,"you're wearing."],[7457,7515,"Deal."]],"13":[[4450,4629,"I think I've had enough to drink."],[4746,4879,"I'm so close!"],[4921,5034,"I need to get him drunk"],[5034,5138,"so I can escape!"],[5313,5422,"Well then,"],[5422,5584,"why don't we play one bonus round"],[5584,5680,"to end the game?"],[5709,5830,"Right, Nolan?"],[7469,7645,"I'll drink this all..."],[7724,7845,"if you let me remove"],[7845,8024,"one piece of my choosing."],[8179,8345,"What did you have in mind?"]],"14":[[1176,1338,"A bet is a bet, Mia."],[1543,1726,"And I'm a man of my word."],[3962,4120,"He's finally passed out."],[4158,4454,"Time to leave this place once and for all."],[4992,5163,"Did you really think you could get me"],[5163,5338,"drunk that easily, Mia?"],[5488,5572,"Now I'm curious"],[5572,5772,"to see what this master escape plan is."],[6898,7073,"It's just a maid, come on."],[8091,8137,"Hey, you!"]],"15":[[0,116,"Stop right there!"],[125,221,"I'm caught!"],[271,400,"Did he recognize me?"],[450,613,"Or, did he think I'm someone else?"],[1647,1780,"You should know, Mia,"],[1780,2018,"I have a very high tolerance,"],[2081,2310,"for alcohol and games."],[2452,2702,"So if you want to keep playing..."],[2831,2907,"I'm in."],[2919,3023,"Let me make something"],[3023,3119,"clear Nolan."],[3190,3349,"You don't own me,"],[3349,3507,"and you can't keep me here"],[3507,3620,"like some prisoner!"],[3837,3928,"I'll keep you wherever"],[3928,3995,"I want,"],[4041,4116,"but not for long."],[4162,4300,"Because you'll want to stay."],[4404,4508,"Trust me."],[4608,4754,"We'll see about that."],[6886,6969,"Going somewhere?"],[7011,7140,"I'm going to work, Nolan."],[7152,7273,"And you can't stop me."],[7353,7574,"I have my life, and the kids need me."],[7632,7807,"Who said I was going to stop you?"],[7857,7982,"But I thought you..."],[7982,8053,"wanted me -"],[8053,8120,"That I'd..."],[8191,8274,"keep you locked away"],[8274,8333,"twenty-four seven."],[8362,8466,"I mean, you said it yourself"],[8466,8591,"you're not a prisoner, right?"],[8758,8929,"Oh I see, you still don't trust me."],[8975,9192,"Alright well, to prove I mean it..."],[9459,9601,"I'll drive you myself."]],"16":[[300,454,"The board's decision is final."],[508,709,"They're pulling all our funding!"],[829,980,"Without that money"],[1042,1155,"we will have to shut down"],[1155,1267,"by the end of the year!"],[1284,1380,"But why?"],[1380,1576,"Why would they do that to us now?"],[1576,1705,"Because someone"],[1705,1826,"convinced the board that"],[1826,1947,"we're not worth saving."],[1981,2327,"A woman named Victoria Sterling"],[2327,2427,"made sure of that."],[2523,2656,"Nolan's Stepmother!"],[2702,3003,"She's using innocent children as pawns,"],[3023,3228,"destroying their entire future"],[3228,3324,"just to hurt me."],[3332,3536,"We've cut every corner possible!"],[3536,3691,"Canceled field trips,"],[3691,3853,"stopped buying new books,"],[3853,4066,"some of us are even paying for supplies"],[4066,4154,"out of pocket."],[4154,4262,"Including you Mia-"],[4262,4416,"Then I'll work with no pay!"],[4416,4625,"These children need us!"],[4625,4796,"Your heart's in the right place, Mia."],[4796,4833,"But,"],[4892,5096,"Victoria made sure we need millions"],[5096,5276,"to keep these doors open!"],[5409,5538,"We need a miracle,"],[5538,5772,"but sadly, we don't have that."],[6619,6744,"First his stepmother"],[6744,6848,"attacks our school"],[6848,7057,"and now Nolan himself shows up?"],[7057,7257,"What twisted game is he planning?"],[7361,7469,"I'm here to make a donation"],[7469,7565,"to your school."],[8103,8274,"Five million dollars!"],[8274,8350,"Is that enough?"]],"17":[[0,37,"What?"],[175,283,"This will definitely keep"],[283,375,"the school running!"],[404,592,"Mia, do you know this gentleman?"],[642,709,"I..."],[709,829,"Of course she does."],[875,980,"I'm her fiancé!"],[1539,1676,"What do you think you're doing?"],[1676,1801,"Excuse us everyone,"],[1801,1947,"looks like my fiancée"],[1947,2060,"wants to have a chat with me."],[2168,2310,"In private!"],[2877,3019,"You think saving the school"],[3019,3174,"changes anything between us?"],[3219,3365,"After kidnaping me,"],[3399,3499,"and threatening to kill"],[3499,3628,"my actual fiancé?"],[3678,3766,"This isn't a game"],[3766,3862,"you solve with money,"],[3862,3908,"Nolan."],[4083,4220,"Is that what you think this is?"],[4275,4337,"A game?"],[4433,4575,"What else would you call it?"],[4792,4896,"I call it..."],[4896,5063,"trying to prove I'm not the monster"],[5063,5163,"you think I am."]],"18":[[496,592,"What you did..."],[592,796,"changes nothing between us."],[1009,1172,"I don't care what I have to do, or"],[1172,1309,"how long it takes, Mia."],[1368,1488,"I'll make you mine."],[2185,2298,"So you're Nolan Sterling's"],[2298,2414,"stepmom and stepsister?"],[2444,2594,"And you want me to get Mia back?"],[2635,2752,"I don't care how you do it."],[2806,3098,"I just want her away from my stepson."],[3098,3219,"If they get married,"],[3219,3403,"she'll take away half our family fortune!"],[3503,3753,"I mean, I'm not dying to get back with Mia,"],[3770,3832,"especially since she's a"],[3832,3883,"hand-me-down"],[3883,3987,"from some other man now."],[4016,4158,"So if you want my help,"],[4229,4337,"you're gonna have to pay."],[4337,4446,"Two million"],[4491,4558,"cash."],[4621,4733,"That should cover the cost"],[4733,4921,"of your new life with your new girlfriend,"],[4971,5134,"once you've dumped Mia in"],[5134,5271,"whatever dumpster you choose."],[5292,5401,"That's music to my ears."],[5860,5939,"James!"]],"19":[[521,592,"James!"],[684,784,"How did you get in here?"],[784,946,"This is Nolan's house!"],[946,1117,"If he finds you, he'll kill you."],[1117,1234,"That's why we have to go now, Mia!"],[1234,1297,"You've no idea"],[1297,1363,"what I went through to find you."],[1363,1413,"Come on!"],[1430,1505,"What happened?"],[1643,1705,"James..."],[1705,1780,"There's no time to explain."],[1780,1801,"Wait!"],[1801,1864,"Let's go now!"],[1968,2014,"Mia..."],[2248,2327,"What are you waiting for?"],[2919,3015,"I call it..."],[3086,3169,"trying to prove"],[3169,3357,"I'm not the monster you think I am."],[3991,4108,"Where do you think you're going?"]],"20":[[45,204,"Nolan, let him go!"],[246,379,"Sneaking around my house"],[379,513,"like a filthy rat."],[646,763,"You're going with him?"],[804,942,"After what happened at your wedding?"],[1088,1280,"If you want to shoot him,"],[1280,1459,"you'll have to go through me first."],[1559,1634,"Just take her."],[1718,1793,"She's yours."],[1893,2018,"You kidnaped me!"],[2052,2248,"To show you have a better choice,"],[2273,2364,"a better life,"],[2427,2535,"a better man!"],[2965,3207,"I'm going to say this one last time, Mia."],[3253,3345,"You're mine."],[3465,3649,"From the moment I first saw you,"],[3649,3849,"you have been mine!"],[3920,4083,"I'm not yours, Nolan,"],[4083,4262,"and I've never been yours!"],[4358,4446,"And you're his?"],[4608,4696,"Very well then."],[5451,5509,"Do it!"],[5622,5705,"Pull the trigger!"],[5768,5935,"Shoot me to prove that you love him!"],[6051,6135,"Not me."],[6861,6919,"Go on!"],[7065,7111,"Shoot me!"]],"21":[[905,1026,"I'm letting you go"],[1026,1126,"because I don't want a coward's"],[1126,1230,"blood on my hands."],[1247,1493,"Never let me see your face again,"],[1493,1609,"or I will shoot you"],[1609,1801,"right in the head."],[2565,2681,"Look at that."],[2752,2865,"It's a miracle!"],[2911,3053,"Leg seems just fine."],[3144,3307,"Don't forget who you belong to."],[4220,4287,"We should have known"],[4287,4429,"that spineless coward"],[4429,4554,"would ruin everything."],[4604,4729,"Don't worry Mom."],[4804,4909,"Remember that contractor"],[4909,5030,"we used in Dubai?"],[5080,5217,"The one who made accidents"],[5217,5380,"look natural..."],[5484,5551,"Make the call."],[5618,5747,"The girl has to go."]],"22":[[508,558,"What are you..."],[571,646,"What are you doing Boss?"],[688,784,"Making the place feel like home"],[784,829,"for Mia."],[855,955,"I want to show her how perfect"],[955,1051,"her life can be here."],[1105,1138,"Let me know"],[1138,1217,"when she gets back from work."],[1217,1292,"I want to see her face"],[1292,1380,"when she walks in."],[1409,1451,"Yes boss."],[2669,2819,"Is James okay?"],[2819,2973,"I just want to talk to him."],[2973,3119,"He's my fiancé!"],[3219,3324,"I'm sorry, Ms. Parker."],[3324,3415,"You know I can't."],[3470,3516,"Now please,"],[3566,3636,"the boss is waiting."]],"23":[[45,166,"It's done, Miss Sterling."],[246,321,"Good work."],[367,529,"You'll get the money tomorrow."],[646,750,"Thank God."],[779,871,"I thought that parasite"],[871,938,"would never die."],[1009,1376,"Now all the Sterling money is ours."],[2085,2164,"Boss!"],[2235,2314,"There was an accident."],[2339,2423,"Mia's car was hit."],[2469,2523,"What?"],[2548,2610,"Where is she?"],[2786,2848,"Take me to her."],[2898,2948,"Now!"],[3061,3165,"Sir, stay back!"],[3307,3374,"Let me go!"],[3390,3482,"It could blow any minute!"],[3561,3724,"That's my wife! I have to get her!"],[4308,4383,"Mia!"],[4621,4692,"Mia!"],[6410,6502,"Find out who did this."],[6773,6865,"I'm gonna kill them."]],"24":[[4487,4567,"Was she really going"],[4567,4646,"to shoot that man for you?"],[4646,4700,"James?"],[4821,4954,"I told you she's madly in love"],[4954,5063,"with me like an idiot."],[5347,5388,"James?"],[5472,5576,"Mia, Jesus!"],[5634,5701,"James?"],[5822,5910,"What is this?"],[6101,6243,"You're sleeping with my best friend?"],[6327,6423,"Every night,"],[6473,6585,"in your bed."],[6639,6810,"While you were playing hostage"],[6810,6931,"with your kidnaper."],[7007,7127,"He never loved you."],[7228,7336,"Isn't that right baby?"]],"25":[[104,154,"I don't know what"],[154,233,"you want me to say, Mia."],[333,437,"I mean, everybody knew."],[525,588,"It took you long enough"],[588,654,"to figure it out."],[729,838,"I trusted you,"],[971,1042,"both of you."],[1105,1159,"Well,"],[1188,1347,"then that's kind of"],[1347,1580,"on you, isn't it girlie?"],[1689,1939,"I trusted you."],[1972,2143,"Listen to yourself."],[2160,2264,"You want to know why"],[2264,2435,"I took James from you?"],[2464,2669,"Because you had everything."],[2686,2861,"And watching you prance around"],[2861,2969,"made me sick!"],[3019,3153,"Your perfect job."],[3178,3336,"Your perfect love life."],[3336,3395,"Ow!"],[3586,3782,"Take a good look, princess!"],[3824,4087,"Not so perfect now, are you?"],[4216,4375,"Even your kidnapers"],[4375,4592,"couldn't stomach keeping you around."],[4621,4875,"Threw you back like rotten meat."],[4988,5146,"Shut your mouth."],[5146,5213,"That's it!"],[5230,5313,"If you're gonna hurt Lucy"],[5313,5413,"like a loose animal,"],[5413,5488,"then you're out of the house!"],[5505,5580,"James!"],[5626,5826,"After so many years, I stood by you"],[5826,5905,"when you had nothing."],[5960,6026,"How could you do-"],[6026,6206,"Oh, get over it Mia!"],[6227,6414,"He doesn't want you anymore!"],[6535,6690,"Two men."],[6748,6948,"Two men took one"],[6948,7102,"look at what you really are and"],[7132,7261,"ran for the hills."],[7428,7682,"Guess there's only one thing"],[7682,7782,"perfect about you now."],[7782,7953,"And that's your track record"],[7953,8083,"of being abandoned."],[8320,8479,"Take her out, sweetie."],[8579,8658,"Let me go."]],"26":[[25,83,"Let me go!"],[83,304,"This is the house my parents left me."],[342,500,"Oh, yeah."],[563,771,"They have horrible taste, you know?"],[880,996,"Hideous paint job."],[1092,1234,"I'm thinking of changing it."],[1234,1347,"I won't let you!"],[1347,1505,"This is my house!"],[1547,1805,"Wrong again, sweetie."],[1805,1956,"Check the deed."],[2289,2439,"It's amazing what money can buy"],[2439,2540,"you these days."],[2594,2769,"Lawyers, documents,"],[2894,3032,"fiancés..."],[3182,3261,"See?"],[3294,3407,"By tomorrow,"],[3407,3549,"everything here will be mine"],[3549,3707,"and I can do whatever"],[3707,3832,"the hell I want!"],[3866,3978,"You forged these, I..."],[4058,4145,"I'll prove it-"],[4145,4291,"You'll prove nothing!"],[4291,4525,"Because you are nothing"],[4537,4671,"but a sad"],[4671,4838,"little girl who couldn't keep her"],[4838,5138,"man or her house."],[5167,5284,"That's enough talking."],[5342,5422,"I'm going to show you out"],[5422,5651,"and don't bother coming back. Ever!"],[5651,5726,"No!"],[6427,6577,"Buh-bye, bestie!"],[7090,7152,"Stop the car."]],"27":[[400,529,"I saw everything."],[563,717,"They're gonna pay for what they did."],[1334,1493,"Please get her somewhere safe."],[1655,1768,"Okay."],[2952,3028,"Oh God!"],[3090,3294,"Get the fuck out of my house!"],[3870,4012,"Let go of me!"],[4012,4120,"You."],[4120,4216,"Please."],[4216,4325,"We can talk about this."],[4333,4562,"Oh, you're all going to get arrested!"],[4562,4863,"All this for that pathetic little skank."],[4875,5021,"Oh!"],[5146,5238,"Take them away."],[5296,5513,"Wait. What? No."],[5513,5643,"I'm sorry! Please!"],[5643,5734,"Please!"],[5734,5926,"I'm sorry!"]],"28":[[0,158,"Help!"],[221,296,"Stay in here"],[354,504,"and think about what you did."],[554,725,"Maybe if you behave,"],[825,917,"I'll let you out."],[1096,1338,"But hey, at least you have each other."],[1338,1459,"You can stay here together."],[1647,1747,"Forever."],[2156,2218,"Wow."],[2273,2389,"This is beautiful."],[2464,2598,"James never bought me"],[2598,2765,"anything like this before."],[2852,3086,"Actually, he never bought me"],[3086,3215,"anything at all."],[4020,4091,"Here."],[4408,4650,"Thank you for everything today."],[4821,4996,"Anything for you, Mia."],[5880,5985,"Marry me."],[6101,6256,"I appreciate everything"],[6256,6373,"he's done today,"],[6389,6523,"but he kidnaped me."],[6544,6673,"I need a way out,"],[6715,6806,"to be free."],[6869,7069,"Get my father's blessing first."],[7157,7278,"That's my condition."],[7419,7540,"Father's blessing?"],[7724,7820,"Take it or leave it."],[8012,8108,"Consider it done."],[8333,8529,"I know exactly what you're doing, Mia."],[8591,8779,"But your father will give his blessing"],[8846,8996,"whether he wants to or not."]],"29":[[79,266,"Henry, here are your pills for your heart."],[300,446,"The doctor said to take them with food."],[517,679,"Yeah, yeah, yeah."],[1593,1664,"Mia!"],[1664,1772,"Oh, my baby!"],[1810,1872,"Mr. Parker,"],[1968,2077,"I'm Nolan Sterling."],[2122,2218,"I'm here to formally ask"],[2218,2364,"for your daughter's hand in marriage."],[2398,2469,"Marriage?"],[2494,2644,"You're the bastard who took her!"],[2673,2811,"Get away from my daughter!"],[2865,3023,"Now, let's be civilized"],[3023,3136,"and talk about this, shall we?"],[3190,3361,"I don't know who you think you are."],[3428,3582,"A man in love with your daughter."],[3661,3795,"Ten million for your blessing."],[3908,4129,"My daughter is not for sale."],[4295,4408,"Twenty million then."],[4533,4704,"I would give everything I own"],[4725,4838,"to make her my wife!"],[4892,5005,"You're a kidnaper,"],[5067,5155,"a criminal!"],[5230,5380,"I'm the man who can destroy"],[5380,5518,"your construction company"],[5518,5651,"with a single phone call."],[5739,5843,"But I'd rather be family."]],"30":[[8,141,"I'd rather die"],[162,308,"than see my daughter with you-"],[437,487,"Oh,"],[521,650,"it's the ulcer."],[650,809,"It's ruptured!"],[809,896,"Mia!"],[1076,1197,"Please, save him!"],[1230,1376,"Get an ambulance here now!"],[2940,3107,"The perforated ulcer caused"],[3107,3228,"massive internal bleeding."],[3557,3753,"We're critically low on his blood type,"],[3816,3908,"AB negative."],[4066,4233,"Without a transfusion soon-"],[4233,4346,"I'm AB negative."],[4400,4487,"Take my blood."],[4575,4767,"Nolan, I'm not sure about this."],[4767,4909,"Mia, he's your father."],[4909,5009,"I want to help."],[5196,5259,"Help?"],[5309,5405,"You're the one who took me"],[5405,5492,"away from him."],[5526,5655,"Mia, that's enough."],[5793,5880,"Mr. Sterling,"],[5926,6110,"are you really willing to help my husband?"],[6151,6348,"For Mia, whatever it takes."],[6468,6752,"We'd need a significant amount."],[6848,6986,"It could be dangerous if"],[6986,7082,"we gain the blood from one"],[7082,7148,"single donor."],[7178,7236,"I said,"],[7344,7440,"whatever it takes."]],"31":[[1188,1242,"That's enough."],[1276,1347,"We need to stop."],[1372,1447,"Keep going!"],[1497,1559,"Nolan,"],[1593,1664,"that's enough."],[1664,1722,"You heard me."],[1793,1864,"Keep going."],[2289,2385,"Stop it! He-"],[2406,2498,"He's fainting!"],[2569,2681,"We need help in here!"],[2777,2869,"Ma'am, you can't be here,"],[2869,2907,"you have to leave."],[2907,3015,"Nolan, can you hear me?"],[3078,3103,"No!"],[3119,3249,"I'm not leaving without him."],[3490,3616,"Nolan!"],[3778,3849,"Nolan!"]],"32":[[458,538,"Your father's going to make"],[538,613,"a full recovery."],[746,813,"Thank God."],[905,1017,"And what about Nolan?"],[1121,1213,"He's been discharged"],[1213,1309,"to recover at home."],[1451,1555,"But he's still quite weak"],[1555,1659,"from the blood loss."],[2665,2715,"Dad?"],[2998,3094,"Hey, sweetheart."],[3215,3324,"How are you feeling?"],[3324,3561,"Oh, like I've been hit by a truck."],[3632,3832,"Wait, are you okay?"],[3891,3995,"Did that monster hurt you?"],[3995,4116,"We need to call the police right now!"],[4116,4229,"Henry, please."],[4229,4371,"You need to rest."],[4446,4517,"Dad stop."],[4571,4821,"Nolan, he's at home recovering."],[4875,4934,"What?"],[5005,5092,"What happened to him?"],[5146,5205,"Did he-"],[5205,5367,"He nearly died giving you blood."]],"33":[[66,221,"After what he did to you,"],[221,437,"I'd rather have died than"],[437,604,"owe that man anything!"],[604,859,"Dad, it's complicated."],[859,1009,"Henry, please."],[1009,1172,"He saved your life."],[1230,1468,"People can change, Henry."],[1468,1751,"Maybe we were too quick to judge."],[1751,2006,"You can put a wolf in sheep's clothing,"],[2006,2160,"but it's still a wolf."],[2168,2435,"He could have turned his back on us, Henry."],[2435,2623,"But he chose to help."],[2623,2886,"Even if it meant risking his own life."],[2969,3269,"We all know why he did that."],[4854,5084,"I told you you'd want to stay here with me."],[5238,5413,"Don't be cocky."],[5522,5764,"I'm here because you saved my father."],[5864,5993,"Of course you are."],[6548,6723,"You lost a lot of blood."],[6844,7011,"It was worth it."],[7173,7361,"Why, Nolan?"],[7419,7720,"Why did you risk your life like that?"],[8249,8445,"You know the answer, Mia."]],"34":[[2318,2423,"It's Marcus."],[2560,2681,"I have to answer this."],[3574,3641,"Everything we've"],[3641,3724,"tried has failed."],[3762,3912,"That little skank has her claws"],[3912,3995,"in him, still."],[4112,4149,"Mom,"],[4200,4312,"we can't give up yet."],[4346,4529,"We still have tricks up our sleeves..."],[4696,4754,"Come in."],[4942,5142,"Olivia, my niece!"],[5259,5426,"The only woman Nolan"],[5426,5509,"should be with."],[5509,5630,"Aunt Victoria,"],[5663,5822,"you know I've always wanted Nolan,"],[5880,6026,"but I heard he's seeing someone."],[6072,6218,"A kindergarten teacher who will take"],[6218,6348,"everything we've built"],[6348,6452,"once they marry."],[6468,6610,"One signature,"],[6610,6781,"and the sterling fortune goes to her."],[6802,7023,"But you, Olivia,"],[7023,7194,"you already have your family's empire."],[7219,7361,"You don't need our money."],[7382,7432,"Your father's"],[7432,7520,"shipping company and"],[7520,7695,"our real estate holdings,"],[7736,7841,"the merger"],[7841,7916,"would keep everything"],[7916,8003,"in the family."],[8078,8291,"Help us save what's ours."],[8324,8537,"You and Nolan belong together."],[8591,8696,"We'll help him see that if"],[8696,8821,"it's the last thing we do."]],"35":[[1459,1564,"Thought you could use a little"],[1564,1634,"pick me up."],[1747,1868,"What the hell are you doing here?"],[2085,2202,"I heard you adopted"],[2202,2344,"a puppy named Mia."],[2344,2540,"Where is she? I wanted to say hi."],[2602,2719,"Get the fuck out of my house!"],[2719,2869,"Ow, Nolan you're hurting me!"],[2957,3048,"Nolan..."],[3157,3261,"What's wrong?"],[3274,3378,"Let me help you."],[3937,4149,"You need a real woman, Nolan."],[4241,4404,"What can a school teacher do"],[4404,4542,"for a man like you?"],[4608,4758,"Get you milk and cookies?"],[4804,5038,"Get off me!"],[5246,5326,"Nolan..."],[5388,5538,"I want to tell you I'm sorry for"],[5538,5689,"judging you too soon."],[5726,6006,"And you're not who I thought you were."],[6056,6156,"And I'm willing to see"],[6156,6343,"if we can have a future together."]],"36":[[45,158,"What's going on?"],[629,759,"Why does he look like that?"],[867,980,"Not so fun finding"],[980,1109,"out like this, is it?"],[1238,1388,"Oh, did the kindergarten teacher"],[1388,1476,"bake a cake?"],[1555,1668,"Let me guess..."],[1768,1881,"Betty Crocker?"],[2035,2093,"There!"],[2093,2293,"Now your outsides match your insides."],[2293,2423,"A filthy mess."],[2585,2744,"You stupid bitch!"],[2882,3061,"You actually thought Nolan Sterling"],[3061,3165,"wanted a pathetic teacher"],[3165,3420,"like you who wipes snotty noses all day?"],[3574,3699,"You drugged him."],[3770,3870,"I didn't!"],[3983,4079,"Marcus!"],[4175,4300,"Do you know who I am?"],[4400,4575,"Don't you dare touch me!"],[4600,4758,"I'm Nolan's woman!"],[4758,4979,"All the guards in this house obey me."],[5030,5113,"Get out now"],[5113,5267,"or you'll find out what he'll do to you"],[5267,5451,"when he wakes up and realizes"],[5451,5568,"you drugged him."],[5584,5809,"Please no, he'll kill me! No!"]],"37":[[679,913,"Mia, what happened?"],[984,1151,"You were drugged."],[1343,1497,"Olivia."],[1747,1972,"I spent all morning on this"],[2068,2369,"before she smeared it all over my face."],[2394,2510,"She did what?"],[2510,2740,"No, I handled it."],[2740,3128,"But seeing her with you like that..."],[3357,3653,"I never felt so scared of losing you."],[4045,4279,"Listen to me."],[4279,4579,"From the moment I first saw you..."],[4596,4850,"nothing else mattered."],[4850,5109,"You're the only one for me, Mia."],[5109,5271,"You always will be."]],"38":[[5789,6081,"He...he didn't fall for it."],[6256,6389,"You useless bitch!"],[6477,6614,"You had one job."],[6614,6777,"Get out of here!"],[6848,7032,"Give me that fake pregnancy report."],[7173,7511,"Now, get someone to bring James from that"],[7545,7728,"basement Nolan locked him in."],[7782,8008,"We need him for what comes next."],[8604,8712,"Look at you,"],[8712,8829,"living the dream."],[8829,8954,"James!"],[9221,9376,"What are you doing here?"]],"39":[[8,129,"I came to apologize."],[129,266,"Apologize?"],[266,429,"After what you did?"],[880,1121,"I never want to see you again!"],[1647,1847,"What the hell do you two want?"],[1847,2027,"We have something that might"],[2027,2189,"pique your interest."],[2606,2794,"Your precious Mia..."],[2794,3032,"She's carrying James' baby."],[3032,3157,"They've been sneaking around"],[3157,3294,"behind your back."],[3482,3645,"Think we're lying?"],[3899,4037,"Go see for yourself."],[4037,4241,"They're in your living room as we speak."],[4792,5030,"I never want to see you again!"],[5088,5217,"Don't let her go..."],[5217,5305,"think about the money."],[5534,5709,"Let me go!"],[5885,5972,"No!"]],"40":[[116,237,"Nolan don't!"],[237,358,"Please, just listen to me."],[358,429,"Listen to what?"],[429,525,"Your lies?"],[525,692,"You're carrying his baby!"],[692,796,"What?"],[996,1084,"That's impossible."],[1084,1238,"James is infertile."],[1355,1497,"How do you know that?"],[1701,1847,"You think I didn't know?"],[1922,2031,"I loved you so much"],[2031,2239,"I was ready to never have children."],[2356,2656,"But you couldn't even be faithful with me."],[2982,3123,"Dr. Rodrick?"],[3199,3432,"I need you to verify something for me..."],[3432,3607,"He really doesn't believe me?"],[3678,3820,"I can't believe this..."],[3912,4049,"I see."],[4137,4346,"Thank you, Dr. Rodrick."],[5338,5501,"What's your part in all this?"],[5618,5830,"Victoria and Claire"],[5830,6031,"were gonna pay me to come get Mia back."],[6031,6231,"Marcus,"],[6231,6481,"bring Victoria and Claire to me now."]],"41":[[346,446,"You know what's funny?"],[554,800,"Money really does talk."],[900,1088,"See, one of your contacts was"],[1088,1197,"very eager"],[1197,1326,"to tell me all about your schemes"],[1326,1514,"to get rid of Mia."],[1985,2068,"You two really thought"],[2068,2181,"you could get away with it, huh?"],[2348,2473,"We have no idea"],[2473,2594,"what you're talking about."],[2748,2923,"You really want the Sterling fortune"],[2923,3023,"that badly?"],[3244,3499,"By morning, you'll both be penniless."],[3499,3607,"Every account frozen,"],[3607,3737,"every property seized."],[3887,4041,"Please, you can't!"],[4049,4158,"You..."],[4262,4391,"can spend the rest of your lives"],[4391,4487,"watching Mia"],[4487,4700,"enjoy every cent of my fortune."],[4800,4917,"Strip them of everything."],[4917,4996,"Leave them with nothing"],[4996,5125,"but the clothes on their back."],[5205,5451,"No, no, get off me!"],[5518,5643,"It's Chanel!"],[5689,5784,"It's Chanel!"],[5955,6056,"As for you..."],[6247,6464,"You have 24 hours to leave the city."],[6589,6694,"And trust me,"],[6731,6835,"I'll know if you don't."],[6927,7007,"My men..."],[7107,7223,"they're everywhere."]],"42":[[179,308,"Don't touch me."],[342,425,"Let me explain."],[425,529,"Explain what?"],[600,738,"That you didn't trust me?"],[738,925,"You actually think"],[925,1071,"I was carrying James' baby?"],[1142,1276,"I know I should have trusted you."],[1405,1589,"But seeing you with him, I..."],[1664,1818,"I couldn't think straight."],[1993,2035,"Do you know why"],[2035,2235,"I could never do that to you?"],[2293,2523,"Because I know how much it hurts"],[2523,2635,"to be cheated on."],[2886,3144,"I would never put you through that pain."],[3495,3611,"I'm sorry."],[3732,3974,"How can I ever make it up to you?"],[4054,4295,"Well..."],[4295,4692,"my students do need new art supplies."],[4771,5005,"The... pencils"],[5005,5205,"are all broken and worn down."],[5347,5459,"Done."],[5459,5605,"I'll buy the whole store."],[5968,6147,"And I'll spend every day making sure you"],[6147,6322,"never doubt how much I love you."],[6360,6523,"Every day?"],[6573,6773,"Every single day."]],"43":[[675,788,"How are you feeling?"],[1605,1710,"You're still burning up..."],[1843,1931,"The chefs told me that"],[1931,2081,"you haven't eaten in days."],[2198,2302,"You don't like their food, huh?"],[2302,2448,"No, the food is perfect."],[2498,2798,"I just uh, I don't feel like eating."],[2936,2990,"Well..."],[3094,3395,"Maybe these two can change your mind."],[3503,3595,"Oh sweetheart!"],[3595,3762,"We were so worried."],[3820,3949,"Why haven't you been eating?"],[3974,4108,"You need to get your strength back."],[4258,4391,"I'll let you guys catch up."],[5038,5142,"This is all his fault!"],[5217,5309,"You wouldn't be sick"],[5309,5409,"if it wasn't for him."],[5409,5601,"Henry, please stop it!"],[5601,5714,"It's just a cold, Dad."],[5747,5868,"He's a good man."],[5939,6110,"He's been taking very good care"],[6110,6197,"of our Mia."],[6289,6439,"He even risked his own life"],[6439,6548,"to save yours."],[6648,6760,"Can't you see?"],[6802,6986,"They love each other."],[7140,7332,"It's time that we let them be."]],"44":[[354,408,"What are you doing?"],[513,709,"Trying to make Mia some rice porridge,"],[709,771,"and..."],[1021,1146,"Yeah, maybe not that."],[1255,1338,"You know, when she's sick,"],[1338,1422,"all she ever wants is"],[1422,1609,"her mother's chicken and rice soup."],[1685,1776,"But she'd never ask,"],[1876,1976,"wouldn't want to be a bother."],[2214,2289,"This..."],[2414,2552,"is her grandmother's ring."],[2752,2873,"I've been waiting for the right man"],[2873,2965,"to give it to."],[3182,3290,"You're a good man, Nolan."],[3516,3649,"I was wrong about you."]],"45":[[362,475,"Anna, sweetie?"],[579,746,"I think we need to give these two a moment."],[905,1030,"Oh, oh!"],[1084,1234,"Of course!"],[1868,2089,"I have something to show you."],[2348,2648,"Oh, grandma's ring?"],[3269,3570,"My mother once told me that"],[3682,3799,"if I found the right girl"],[3878,4049,"to promise that I would never let her go."],[4220,4512,"If you ever find the right girl, son,"],[4512,4713,"promise me..."],[4713,4909,"you'll never let her go."],[5271,5397,"Now I know exactly what she meant"],[5397,5505,"by those words."],[5943,6072,"Mia Parker..."],[6189,6318,"will you marry me?"],[6493,6585,"Yes..."],[6585,6673,"Yeah?"],[6673,6785,"Yes, I will!"]],"46":[[329,517,"This place is revolting!"],[563,754,"We used to own half the city!"],[754,959,"Well, Mother..."],[959,1105,"you don't have to thank me just yet,"],[1105,1334,"but I might have just found"],[1334,1455,"a way out of this mess."],[1735,1864,"Come in."],[2535,2644,"You called?"],[2644,2781,"Yes."],[2781,2902,"We need your help"],[2902,3032,"luring Mia."],[3048,3153,"There's an underground auction"],[3153,3345,"happening tomorrow night, and-"],[3345,3536,"And who better to lure her out"],[3536,3657,"than her best friend"],[3657,3820,"who knows all her weaknesses?"],[3883,4049,"Genius."],[4049,4287,"One auction, and she disappears."],[4358,4504,"Nolan loses everything"],[4504,4621,"he loves..."],[4704,4884,"And we get our empire back!"]],"47":[[583,729,"What are you doing here?"],[729,875,"It's my grandma!"],[942,1113,"She's in the hospital!"],[1113,1230,"Grandma Deedee?"],[1230,1317,"Yes."],[1376,1488,"She's really sick!"],[1488,1705,"And she keeps asking for you."],[1856,2156,"I wouldn't be here if it wasn't serious."],[2252,2427,"She needs you."],[2644,2802,"I don't know..."],[2802,3044,"Please, Mia."],[3119,3294,"Don't do it for me,"],[3294,3595,"do it for her."],[3774,3945,"I'll get my things."],[6840,7069,"She fell for it."]],"48":[[50,150,"Money is not an issue."],[150,312,"I want this wedding perfect."],[375,475,"As soon as possible."],[475,563,"Make sure her parents"],[563,684,"get the VIP treatment."],[934,980,"Boss,"],[1051,1126,"Mia's gone!"],[1163,1251,"We checked the school"],[1251,1372,"and she is nowhere to be found!"],[1543,1639,"Get every man to search"],[1639,1760,"the entire city."],[1818,1889,"Find her!"],[2944,3086,"You tricked me!"],[3086,3249,"Of course I did!"],[3912,4012,"Perfect."],[4270,4375,"Tonight,"],[4375,4742,"this ballroom hosts a very special event."],[4817,5005,"An auction."],[5005,5188,"And you're our star attraction."],[5188,5363,"Rich men pay very well"],[5363,5480,"for a pretty little thing"],[5480,5572,"like you."],[5572,5651,"Aww..."],[5893,6047,"Without his precious Mia,"],[6085,6239,"Nolan will crumble..."],[6423,6614,"And we'll take back what's ours!"]],"49":[[212,513,"The guests are arriving."],[663,767,"Lighter on the eyes."],[767,934,"We want her looking like a virgin."],[934,1063,"Go to hell!"],[1063,1234,"Oh, such fire!"],[1251,1472,"The buyers will love that."],[2085,2177,"Gentlemen,"],[2218,2356,"thank you for joining us."],[2464,2656,"Let's cut to the chase, shall we?"],[2706,2944,"We know you're all here for one thing."],[3128,3465,"Oh, yes."],[3490,3753,"Bidding starts at one million."],[3753,4008,"Ohh ya!"],[4008,4137,"Eight million!"],[4137,4295,"Yeah!"],[4454,4621,"No...no, no, no, no, no."],[4621,4771,"This...this isn't real."],[4771,4984,"This can't be happening..."],[5138,5305,"Stay still,"],[5305,5434,"or mommy and daddy's car"],[5434,5543,"might crash."],[5543,5814,"And this time, there will be no survivors."],[5885,6001,"Twelve million!"],[6001,6256,"Oh! Oh."],[6256,6439,"Twenty million!"],[6439,6560,"Oh, yeah."],[6560,6656,"Going once..."],[6656,6827,"going twice..."],[6827,6923,"Sold!"],[6986,7144,"Yeah!"],[7365,7553,"My wife's not for sale!"],[7782,7891,"Nolan!"]],"50":[[0,91,"Going once..."],[91,262,"going twice..."],[262,358,"Sold!"],[433,613,"Yeah!"],[813,1001,"My wife's not for sale!"],[1267,1334,"Nolan!"],[1597,1689,"Nolan!"],[1985,2047,"Take her away!"],[2047,2106,"Now!"],[2189,2289,"Mia!"],[2481,2627,"No, no please!"],[2627,2790,"Oh no, please."],[2823,2882,"No-"],[2882,2948,"Get in the car!"],[3269,3386,"No!"],[3470,3649,"Let me go!"],[4141,4233,"Let me go!"],[4233,4383,"Get your hands off of me!"],[4496,4550,"What do you want me to do"],[4550,4633,"with her now, boss?"]],"51":[[246,404,"Please Nolan..."],[404,563,"let us go!"],[621,738,"We'll do anything..."],[738,955,"Please!"],[955,1138,"You tried to destroy"],[1138,1301,"everything that I care about."],[1401,1601,"We're sorry!"],[1601,1768,"How can we make it up to you?"],[1847,2018,"You really want to know how?"],[2018,2160,"You have two choices."],[2202,2331,"First..."],[2898,3107,"So maybe not that one."],[3215,3415,"Your other option..."],[3415,3553,"Let us go..."],[3649,3820,"A cartel boss in Miami needs"],[3820,3928,"new servants."],[3966,4070,"The last ones..."],[4124,4245,"well, let's just say they made"],[4245,4333,"too many mistakes."],[4558,4779,"He's expecting you both tomorrow."],[4779,5000,"No, you didn't!"],[5000,5192,"Your flight leaves tomorrow morning."],[5192,5242,"No!"],[5292,5434,"We'll do anything else!"],[5459,5626,"Please, please, please!"],[5672,5885,"Not so fun being sold, is it?"],[5939,6022,"Maybe you should have thought"],[6022,6072,"about that"],[6072,6227,"before trying to auction off Mia."],[6343,6473,"Enjoy your flight."],[6931,7061,"Come back!"],[7061,7323,"No!"]],"52":[[342,479,"Come in."],[738,875,"Hey."],[1226,1326,"How are you feeling?"],[1409,1522,"Better."],[2210,2423,"I'm so glad you found me when you did."],[2590,2890,"I would have torn apart the whole city."],[3036,3244,"I was so scared..."],[3307,3532,"when they had me up there."],[3611,3912,"All those men bidding."],[3928,3991,"Hey,"],[4300,4362,"it's okay now."],[4362,4517,"You're safe."],[4783,5025,"What happened to Victoria and Claire?"],[5226,5367,"Let's just say they"],[5367,5593,"won't be a problem anymore."],[5709,5834,"And Lucy?"],[5935,6051,"Disappeared."],[6101,6264,"But, I'll find her."],[6990,7186,"Stay with me?"]],"53":[[2314,2565,"You look beautiful, Miss Mia."],[2652,2869,"The way Mr. Sterling looks at you..."],[2869,3069,"in all the years I've been here,"],[3069,3370,"I've never seen him smile so much."],[3403,3624,"He's changed my whole world."],[3707,3791,"Wait here."],[3791,4016,"I have something perfect for you."],[4016,4175,"My grandmother's pearl earrings"],[4175,4316,"from her wedding day..."],[4320,4550,"they'll look lovely-"],[4646,4771,"Rosa?"],[4863,4950,"Oh my gosh."],[4950,5105,"Rosa?"]],"54":[[846,1005,"Not exactly the wedding day"],[1005,1146,"you planned, is it?"],[1184,1267,"Lucy?"],[1317,1593,"I haven't heard from James since"],[1593,1926,"your precious fiancé made him disappear."],[2260,2360,"Guess I"],[2406,2610,"have to make his bride disappear, too."],[2652,2719,"Lucy..."],[2719,2781,"Please!"],[2781,2898,"You know what they say..."],[3311,3611,"Weddings are better with fireworks!"],[3678,3732,"No!"],[4016,4099,"Goodbye Mia."],[4162,4425,"I hope to never see you again!"],[4575,4629,"No!"],[4671,4783,"Oh, God!"],[4783,4888,"Lucy!"],[5013,5096,"Help!"],[5159,5242,"Help!"]],"55":[[58,158,"Boss!"],[158,283,"They just saw Lucy's car outside"],[283,354,"by the old factory."],[396,475,"They saw them dragging a woman"],[475,558,"in a white dress inside."],[613,675,"That's her."],[704,759,"Let's move!"],[2498,2769,"Boss, that building's coming down!"],[2769,2936,"If you go in there, you'll die."],[2936,3053,"Then I die with her!"],[3374,3486,"God!"],[3486,3670,"Mia!"],[4233,4320,"Mia!"],[4375,4462,"Mia!"],[4696,4783,"Mia..."],[4825,4942,"Mia."],[6977,7077,"Call an ambulance!"],[7115,7165,"Mia."]],"56":[[725,775,"Hey boss!"],[842,984,"Caught her trying to skip town."],[1284,1409,"You were her best friend."],[1543,1680,"She trusted you like family."],[1743,1864,"And how do you repay that trust?"],[1935,2097,"You sleep with her fiancé,"],[2302,2473,"you try to burn her alive"],[2519,2623,"on her wedding day!"],[2694,2790,"Please..."],[2790,2915,"I can explain!"],[3090,3236,"She's all yours."],[3274,3395,"Have fun trying to explain"],[3395,3478,"attempted murder."],[3511,3703,"No, please. I can't go to jail!"],[3703,3849,"Nolan! Please!"],[3849,4099,"You can't do this to me. No!"],[4671,4788,"Next time you want to"],[4788,4875,"get out of marrying me"],[4875,5000,"just say so."],[5092,5276,"And miss my dramatic exit?"],[5509,5663,"Think we could try again?"],[5805,5960,"Maybe without the fire this time."]],"57":[[45,346,"I now pronounce you husband and wife!"],[4884,5017,"She has your eyes..."],[5155,5246,"And your smile."],[5376,5497,"It's perfect,"],[5572,5689,"just like her mother."],[6089,6247,"Remember our first kiss?"],[6456,6585,"Best moment in my life..."],[6639,6756,"until now."],[6806,6915,"My whole world..."],[6973,7115,"right here in my arms."],[7432,7565,"Who knew one kiss"],[7565,7695,"could lead to all of this?"]]}