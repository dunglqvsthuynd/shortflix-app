,[7304,7440,"My dear little brother."],[7600,7664,"You know better"],[7664,7779,"than anyone, right?"],[7820,7979,"Human nature cracks"],[7979,8076,"under pressure!"]],"47":[[416,512,"Hey, boyfriend."],[596,696,"Cheese-salt."],[696,811,"I made them by my own."],[827,911,"Wanna try?"],[1364,1456,"We're breaking up."],[1488,1580,"What's wrong?"],[1580,1671,"Why are you pissed at me?"],[1692,1787,"I will do it right."],[1844,1980,"I'm over it."],[1980,2064,"Done playing."],[2112,2196,"We're through."],[2376,2512,"Confessing to me yesterday."],[2512,2603,"Today is dumping."],[2603,2732,"Why are you toy with me, Leo?"],[2776,2883,"Just testing."],[2883,3016,"You're as dull as I thought."],[3871,3992,"That's not that simple."],[4571,4703,"This changes nothing."],[7143,7223,"Say it, I'm dull."],[7284,7392,"Say I'm dull again!"],[8264,8377,"You're really really"],[8377,8462,"dull!"]],"48":[[32,136,"Logic,"],[136,227,"you're really really"],[256,300,"dull!"],[396,487,"You disgust me,"],[516,596,"bore me."],[2112,2228,"Get off me now!"],[3388,3467,"Remember?"],[3524,3600,"You made me your"],[3600,3684,"week-long lover."],[3764,3924,"Everyone knows it's my pickup game."],[3971,4067,"It's nuts, but"],[4171,4235,"what's crazier,"],[4235,4343,"I fell for you."],[4496,4596,"Maybe you're just a"],[4596,4679,"rich spoiled kid who"],[4692,4788,"got my love and"],[4788,4907,"got tired of it."],[5111,5224,"I said it's just a game."],[5320,5454,"We shouldn't get too attached."],[5543,5643,"I've found that girl."],[5879,5971,"Why aren't you with her?"],[6035,6167,"Because my heart is yours,"],[6167,6279,"at least right now."],[6379,6459,"Give it up."],[6612,6731,"I said we're done."],[7064,7123,"Fine,"],[7159,7256,"I'm out."],[7771,7856,"Either way,"],[7856,7984,"I'm glad that I met you,"],[8207,8320,"I loved you."],[8700,8879,"Sorry, this game is not fun anymore."],[8931,9000,"Doesn't matter."],[9059,9187,"I'll leave Golden Feather."],[9264,9343,"I'm out."]],"49":[[255,360,"I am Logic,"],[375,455,"your student"],[455,535,"council president."],[570,683,"Today is my last day."],[735,872,"I will be leaving tomorrow"],[872,943,"in Golden Feather."],[1000,1143,"He's bailing quick."],[1164,1311,"Semester is not done yet."],[1416,1524,"He doesn't belong here."],[1648,1764,"You dumped him,"],[1792,1907,"but didn't crush him."],[1955,2039,"I'm not"],[2039,2123,"thrilled."],[2339,2448,"What're you up to now?"],[2623,2707,"Miss Celine,"],[2707,2839,"may I have this dance?"],[2887,3032,"I assume your bodyguards"],[3032,3119,"are gonna show up."],[3144,3284,"Today no bodyguards."],[3315,3384,"I'm a guy who"],[3384,3484,"refused to do this."],[3484,3607,"Let me blend in, okay?"],[3656,3739,"Of course."],[4103,4300,"So, what do you need from me?"],[4367,4479,"What do you mean?"],[4515,4647,"I'm sorry I caused a trouble"],[4647,4775,"between you and Leo."],[4807,4896,"So I'm leaving"],[4896,5007,"and I want you two to"],[5007,5088,"patch things up."],[5107,5275,"You really love my brother, huh?"],[5300,5450,"So, name your price."],[5460,5539,"Well,"],[5539,5698,"crawl around this hall"],[5698,5828,"like a dog,"],[5856,5932,"right now!"],[5992,6096,"You and Leo"],[6096,6279,"never gonna fail to shock me!"],[6296,6420,"Debts get paid."],[6420,6604,"That's the Howard family rule."],[6607,6706,"And this is for your"],[6706,6823,"opening ball stunt."],[6956,7083,"Wanna have some fun,"],[7083,7171,"Mr. First Son?"],[7179,7295,"I'm not your prey, Celine."],[7304,7456,"Nor your next conquest."],[9704,9746,"Logic,"],[9746,9871,"are they threatening you?"],[10087,10284,"Sis, please don't do this."],[10364,10523,"This is how I let it go, Leo."],[10556,10629,"If you want to"],[10629,10730,"stay as my brother,"],[10730,10854,"back me up."],[11775,11911,"Golden Feather,"],[11920,12056,"burn in hell!"]],"50":[[724,880,"Golden Feather,"],[880,1000,"burn in hell!"],[1000,1108,"Go, I'll distract him."],[1108,1208,"No, I'm not leaving you."],[1208,1235,"We're in this-"],[1235,1328,