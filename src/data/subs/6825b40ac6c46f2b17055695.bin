{"1":[[1559,1634,"Moon Goddess,"],[1693,1755,"please,"],[1801,2002,"help me escape from this nightmare."],[3019,3169,"How the hell did she run that fast"],[3169,3303,"after all that wolfsbane?"],[3432,3549,"Alpha Roland ordered us"],[3549,3657,"to get that maid back"],[3682,3774,"at all costs."],[3837,3874,"Oh,"],[3899,3945,"no."],[4033,4179,"That's Moonshadow pack territory."],[4204,4316,"Let's find another way around."],[6944,7019,"Alpha Alfred."],[7073,7190,"This place is secure."],[7240,7357,"You won't be disturbed here."],[7378,7449,"Please,"],[7469,7553,"rest and recover."],[7561,7665,"Make sure no one knows that"],[7665,7786,"my wounds are acting up."],[7820,7899,"Understood."],[9446,9522,"Who's there?"],[9993,10064,"Who are you?"],[10172,10218,"I-"]],"2":[[279,371,"How'd you get in here?"],[513,625,"He feels"],[700,842,"so good."],[1172,1230,"I, I,"],[1242,1363,"I've been drugged."],[1397,1534,"Will you please help me?"],[2047,2243,"My wounds healed at her touch?"],[2756,2948,"Fuck, I'm so attracted to her."],[3073,3178,"Is she my Mate?"],[4888,5034,"Are you sure you want this?"],[5221,5334,"Because once we start,"],[5334,5438,"there's no stopping."],[5501,5584,"I don't know,"],[5776,5901,"but I don't want you to stop."],[5980,6064,"I want you."],[6147,6214,"Please."],[7907,8124,"Sit back and enjoy the ride."]],"3":[[1088,1180,"Oh no."],[1205,1330,"I slept with a stranger"],[1330,1518,"after being poisoned?"],[2527,2660,"I just managed"],[2660,2831,"to escape the wolfsbane pack."],[2907,3115,"I can't let them catch me again."],[4517,4600,"That girl,"],[4763,4884,"she made me feel something"],[4884,5025,"I've never felt before."],[5513,5601,"James,"],[5601,5739,"a woman broke in last night."],[5780,5855,"Go find her."],[6594,6652,"Lyra!"],[6969,7257,"This is the tenth time you've run off."],[7257,7303,"No."],[7374,7486,"Alpha Roland's gonna make you"],[7494,7607,"pay for it when we get back."]],"4":[[684,771,"Alpha Roland,"],[884,1001,"we've brought Lyra back."],[2569,2902,"If you try to seduce Alpha Roland,"],[2940,3048,"I'll kill you."],[3136,3370,"That disgusting man is all yours."],[3399,3478,"Selena!"],[4821,4979,"A wolf-less maid like you"],[4979,5109,"should've just laid there,"],[5121,5305,"and taken it after the wolfsbane."],[5359,5572,"How dare you run away from me?"],[5588,5784,"I'm not anyone's maid, you asshole!"],[6156,6272,"This tattoo"],[6335,6523,"marks you as my maid."],[6765,6802,"No."],[6823,6869,"Please."],[6919,6952,"No."],[7036,7115,"No, no, no."],[7615,7803,"There's no way out!"],[8124,8283,"You disgust me!"],[8358,8454,"Shit!"],[8658,8883,"You've got a fiery mouth on you."],[9034,9242,"How about I fuck you speechless?"],[10226,10306,"Why do I smell"],[10306,10427,"another werewolf on you?"],[10614,10794,"Did you lose your virginity?"]],"5":[[20,187,"Did you lose your virginity?"],[196,333,"That's none of your business."],[450,521,"I'd rather give it"],[521,709,"to any man on Earth than you."],[834,921,"Congrats."],[1009,1167,"Now you've really pissed me off!"],[1197,1309,"No!"],[1405,1572,"Let go of me, you asshole!"],[1601,1685,"Alpha Roland."],[1726,1881,"What is it?"],[1901,2014,"We have a visitor."],[2081,2173,"Alpha Alfred is here"],[2173,2306,"from the Moonshadow pack."],[2402,2510,"Moonshadow pack?"],[2556,2715,"The largest wolfpack?"],[2936,3023,"We've never crossed"],[3023,3128,"paths with them before."],[3128,3274,"What, what are they doing here now?"],[3516,3636,"Let's see what this is about."],[3687,3887,"I'll deal with you when I'm done."],[3983,4158,"Go make yourself presentable."],[4204,4291,"And bring some tea"],[4291,4441,"for our distinguished guest."],[5488,5622,"You clumsy,"],[5668,5747,"worthless"],[5755,5826,"maid."],[5901,6068,"Do you even know who our guest is?"],[6185,6239,"He's"],[6277,6427,"Alpha Alfred."],[6539,6610,"One of the Alphas"],[6610,6798,"from the biggest wolfpacks."],[6923,7015,"If you mess up,"],[7123,7186,"you're dead."],[8158,8391,"Roland is as bad as it gets, Lyra."],[8429,8591,"It can't get any worse than this."]],"6":[[383,604,"Alpha Alfred, our clues indicate"],[604,767,"that the girl you met last night"],[788,988,"was captured by the Wolfsbane pack."],[1234,1434,"So they dare touch one of my people."],[1643,1714,"Let's keep our plans"],[1714,1801,"under wraps for now."],[3073,3203,"Well, well."],[3299,3499,"So this is the Alpha"],[3499,3691,"of the largest wolfpack."],[3799,4112,"You're as ravishing as expected."],[4275,4391,"Do you have"],[4425,4512,"a Luna?"],[4788,4921,"Alpha Alfred,"],[4942,5130,"to what do I owe the pleasure"],[5192,5351,"of your sudden visit?"],[5397,5555,"I'd like to discuss the peace treaty"],[5555,5668,"between our packs."],[7007,7086,"It's you."],[7257,7357,"It's him,"],[7415,7540,"the guy from that night."],[7582,7711,"What is he doing here?"]],"7":[[529,608,"Alpha Alfred,"],[746,880,"this is our pack's maid."],[942,1038,"Do you know each other?"],[1088,1134,"No."],[1288,1418,"You've got the wrong person."],[1488,1568,"I don't know you."],[2106,2206,"Alpha Roland,"],[2289,2531,"that bitch was definitely trying to"],[2531,2627,"seduce"],[2656,2765,"Alpha Alfred."],[3153,3386,"My apologies, Alpha Alfred."],[3465,3632,"Please excuse me for a moment."],[3999,4058,"You!"],[4104,4212,"Filthy whore!"],[4258,4421,"You think you could get away"],[4425,4537,"with seducing someone"],[4558,4700,"right under my nose?"],[4700,4796,"What are you talking about?"],[4804,4913,"Let go of me!"],[5518,5622,"She's in trouble."],[5643,5755,"This is what you get"],[5755,5901,"for disobeying me."],[5910,5951,"No-"],[6727,6931,"Have you learned your lesson yet?"],[7019,7102,"Go to hell."],[7319,7449,"How about I send you there"],[7474,7578,"myself?"],[8375,8441,"God."]],"8":[[0,66,"God."],[158,200,"Who-"],[250,437,"Oh my, Alpha Roland, I'm sorry."],[513,596,"My apologies."],[596,738,"I didn't realize that was you."],[788,959,"I thought you were some nobody"],[988,1130,"harassing the staff."],[1209,1317,"How kind of you!"],[1393,1651,"We were only joking around, of course."],[2619,2723,"He's an Alpha,"],[2907,3061,"but how can I trust him?"],[4312,4504,"When will this nightmare ever end?"],[4600,4708,"Have you been living like this"],[4708,4779,"all along?"],[5009,5080,"Sir."],[5196,5334,"What are you doing in my room?"],[5380,5538,"I'm sorry, I didn't mean to startle you."],[5597,5759,"Let me formally introduce myself."],[5822,5926,"I'm Alpha Alfred,"],[5939,6039,"the Alpha"],[6089,6197,"of the Moonshadow Pack."],[6410,6502,"Do you remember me?"],[6781,6998,"How could I ever forget the alpha"],[6998,7144,"that took my virginity?"],[7511,7607,"I remember you."],[7761,7828,"But that night,"],[7962,8066,"it was a mistake."],[8291,8400,"It wasn't for me."],[8587,8737,"I've been looking for you ever since."]],"9":[[145,312,"Please don't play with me, Alpha."],[408,521,"I'm just a maid."],[592,738,"You're more than just a maid."],[884,980,"You have a name,"],[1080,1201,"and a life behind it."],[1430,1539,"Tell me, what is your name?"],[1943,2006,"Lyra."],[2198,2277,"Lyra."],[2702,2806,"How many times?"],[2998,3057,"What?"],[3315,3465,"How many times did they hurt you?"],[4099,4162,"I,"],[4354,4446,"I lost count."],[4746,4854,"I'm so sorry."],[5121,5263,"Pain is all you've ever known."],[5751,5939,"When was the last time"],[5939,6118,"someone held me like this?"],[6581,6635,"No,"],[6669,6752,"I can't."],[6952,7077,"He's an Alpha."],[7152,7311,"I'm just a maid."],[7469,7636,"It's getting late, Alpha Alfred."],[7749,7828,"You should go."],[7828,7949,"Lyra, if you come with me,"],[7949,8016,"I'll protect you."],[8016,8141,"I'll do everything in my power to"],[8141,8249,"protect you, I swear."],[8366,8512,"Please come to my pack."],[8850,8971,"You want me in your pack"],[8971,9134,"so I can continue being a maid?"],[9142,9188,"No."],[9288,9421,"You'll never be a maid."],[9601,9647,"And..."],[10018,10160,"You're pregnant with my pup."],[10377,10427,"What?"],[10456,10502,"That-"],[10543,10673,"That's impossible."],[10702,10823,"It's real, Lyra."],[10956,11052,"Can you feel that?"],[11357,11478,"Our pup's in there."]],"10":[[196,271,"How?"],[325,437,"We were only together a"],[437,500,"few nights ago."],[500,638,"How can I be pregnant?"],[654,763,"I'm an Alpha."],[863,1005,"Which means my seed takes root"],[1005,1184,"faster than an ordinary wolf."],[1622,1780,"I can smell it, Lyra."],[2002,2114,"You're carrying my pup."],[2127,2206,"Our pup."],[2268,2348,"I'll talk to Roland."],[2348,2456,"I'll have him release you."],[2560,2694,"I'll protect you and our pup."],[2694,2861,"Come with me to the pack, please."],[3003,3232,"I can't deny the pull between us."],[3294,3390,"He's different."],[3390,3486,"I feel it."],[3570,3841,"But I'm a maid and he's an Alpha."],[3928,4058,"Can I really trust him?"],[4571,4650,"I don't know."],[4700,4817,"I can't decide yet."],[4859,4959,"I need more time."],[5055,5192,"I'll wait for your answer."],[6502,6669,"That slut is pregnant"],[6669,6819,"with Alpha Alfred's pup?"],[6840,7061,"I need to tell Alpha Roland."],[7265,7336,"Take her."],[7361,7440,"Now!"],[7620,7653,"No."]],"11":[[183,283,"Alpha Alfred,"],[308,421,"I thought we wrapped up"],[421,642,"these treaty talks yesterday."],[646,734,"Is there something"],[763,921,"else you wanted to discuss?"],[946,1051,"Yes, actually."],[1067,1113,"I'm looking for"],[1113,1234,"one of your pack members."],[1263,1368,"You can set the conditions"],[1368,1459,"for handing them over."],[1509,1622,"Who's the lucky person"],[1622,1739,"who caught your attention?"],[1764,1839,"Lyra."],[1939,2106,"The girl I saw at the pool yesterday."],[2118,2314,"But she's just the maid."],[2335,2448,"No, no, let me, let me think."],[2711,2802,"Lyra?"],[2902,3057,"I don't know anyone by that name."],[3123,3290,"We do have a girl we like to call"],[3307,3399,"Bitch."],[3524,3636,"Maybe it's her?"],[4667,4742,"Lyra!"],[4767,4846,"Alfred."],[4938,5013,"Help me."],[5030,5150,"What did you do to her?"],[5163,5397,"She opened her legs for some guy,"],[5413,5551,"and got pregnant."],[5563,5834,"I'm just doing what she deserves."],[6135,6189,"Lyra!"],[6318,6373,"Lyra!"],[6485,6556,"Don't worry."],[6614,6723,"Don't worry, I'm here now."],[6769,6831,"You're safe."],[6835,6923,"Alpha Alfred-"],[6927,7027,"I'm gonna get you out of here."],[7290,7407,"Alpha Alfred,"],[7457,7649,"this is my territory!"],[7665,7832,"This is my servant."],[7832,7962,"I'm teaching her a lesson."],[7982,8120,"You have no right!"],[8120,8304,"I'll decide what right I have!"],[8395,8516,"I'm done asking."],[8579,8700,"She's pregnant with my pup,"],[8700,8783,"and I'm taking her with me,"],[8783,8863,"and that's final!"],[9355,9559,"You can't take her with you,"],[9609,9734,"because..."],[10039,10260,"she's my Mate!"]],"12":[[29,129,"I'm your Mate?"],[191,396,"Roland, you disgusting bastard,"],[396,542,"how dare you bind me to you?"],[563,629,"Lyra,"],[667,825,"you're just a maid."],[921,1067,"Don't tell me you actually think"],[1067,1205,"you can be a Luna."],[1393,1597,"I refuse to be your Mate."],[1760,1830,"What?"],[2014,2114,"I, Lyra White,"],[2168,2293,"reject Roland Hill,"],[2293,2439,"Alpha of the Wolfsbane Pack,"],[2439,2523,"as my Mate."],[2827,3061,"Oh, you fucking bitch!"],[3107,3303,"You think you can break our bond?"],[3332,3411,"Well, I,"],[3411,3516,"Roland Hill,"],[3528,3712,"reject your rejection!"],[4162,4229,"That's it."],[4241,4387,"None of you are leaving today!"],[4387,4475,"Keep her safe."],[4917,5038,"Come at me!"]],"13":[[20,196,"Let me teach you a lesson."],[2473,2660,"She's just a fucking maid!"],[2706,2890,"You want her this bad?"],[3111,3265,"How dare you call her that!"],[3762,3841,"You're hurt."],[3887,3949,"I'm fine."],[4029,4099,"Let's get out of here."]],"14":[[70,141,"No!"],[842,1017,"You think you can take her away"],[1017,1105,"from me?"],[1201,1434,"As long as she has that branding"],[1459,1593,"on her face,"],[1647,1826,"I can track her down."],[2085,2122,"No."],[2139,2181,"Please."],[2227,2273,"No."],[2356,2427,"No, no."],[3357,3499,"You sure about that?"],[5980,6106,"She's no longer a maid."],[6122,6181,"From now on,"],[6181,6368,"she belongs to no one but herself."]],"15":[[33,83,"From now on,"],[83,275,"she belongs to no one but herself."],[483,692,"No one's ever cared for me like this."],[855,913,"Let's go."],[1138,1255,"This isn't over,"],[1338,1501,"Alpha Alfred."],[2744,2944,"You got hurt because of me."],[3140,3199,"I,"],[3265,3420,"I don't even know how to thank you."],[3420,3557,"There's no need to thank me."],[3578,3624,"I promised"],[3624,3745,"I was gonna take you with me."],[5509,5555,"Go on."]],"16":[[646,721,"What's wrong?"],[2352,2431,"Did I hurt you?"],[2502,2602,"I'll be more gentle."],[2648,2723,"No need."],[3174,3282,"You're doing great."],[4496,4621,"Do you want me?"],[4675,4783,"Alpha Alfred, I-"],[5993,6131,"Sorry, Alpha Alfred, I-"],[6790,6886,"You can heal me?"]],"17":[[16,50,"I,"],[100,254,"I, I don't know what's happening."],[387,513,"How do I have this power"],[513,721,"when I don't even have my own wolf?"],[1080,1226,"Alpha Alfred, we need to talk."],[1263,1338,"It's urgent."],[1376,1430,"Speak."],[1593,1634,"Stay."],[1901,2014,"Whatever he has to say,"],[2014,2118,"you deserve to know too."],[2394,2469,"We're approaching"],[2469,2615,"Moonshadow Pack territory."],[2665,2815,"How do you plan to introduce"],[2831,2936,"Ms. White"],[2948,3053,"to the Elders?"],[3098,3194,"Get to the point."],[3224,3282,"She's"],[3390,3440,"a maid."],[3516,3649,"The Elders will never accept her"],[3649,3737,"as one of us."],[3853,3962,"I'm not going back with you."],[4112,4270,"I'm grateful you saved me."],[4329,4391,"Truly."],[4562,4725,"But I won't cause you any more trouble."]],"18":[[0,87,"Where are you gonna go?"],[200,300,"I mean, Roland's not gonna stop"],[300,379,"anytime soon,"],[379,508,"and you're pregnant with my pup."],[633,700,"But I-"],[700,834,"I'll disguise you as my Luna."],[959,1026,"Alfred,"],[1080,1255,"I don't even have my own wolf yet."],[1343,1443,"A Luna this weak,"],[1543,1618,"it won't take long"],[1618,1722,"for people to notice."],[1739,1835,"Don't worry about that."],[1926,1993,"I'll handle it."],[2173,2227,"Alpha,"],[2248,2402,"you just secured your position"],[2402,2464,"as Wolf King."],[2477,2585,"If the Elders find out"],[2585,2731,"your Luna was a maid, you'll,"],[2786,2886,"you will lose everything."],[2894,2990,"She's not a maid."],[3090,3178,"And all you have to do is"],[3178,3265,"keep that secret."],[3766,3828,"Lyra,"],[3887,4016,"your safety and our child's"],[4016,4116,"mean everything to me."],[4179,4300,"The best way to protect you is"],[4300,4387,"if you stay with me."],[4387,4446,"Trust me."],[4546,4642,"Please come back with me."],[4825,5005,"Don't get carried away, Lyra."],[5063,5321,"He's only doing this because of the pup."],[5392,5476,"You were lucky enough"],[5476,5588,"to escape Roland,"],[5638,5793,"don't start hoping for more."],[5918,5964,"Alright."],[6076,6193,"Teach me how to be a Luna."]],"19":[[880,1001,"These fabrics were imported"],[1001,1109,"from the Far East."],[1130,1259,"Each piece handcrafted"],[1259,1443,"by our finest artisans,"],[1443,1689,"tailored exactly to your measurements."],[1968,2198,"These are inlaid with moonstone."],[2248,2389,"They glow softly at night."],[2473,2623,"There's nothing like it in the world."],[2765,2973,"I, I just need a place to sleep."],[3044,3194,"You've given me too much."],[3699,3803,"You deserve it all."],[4016,4074,"Come on."],[4154,4233,"Let's go try it on."],[6585,6815,"My god, she's so beautiful."],[7261,7319,"Thank you."],[7386,7545,"I've never worn anything"],[7545,7628,"this beautiful."]],"20":[[350,425,"Are you alright?"],[517,579,"I'm fine."],[642,813,"Just not used to wearing heels."],[3524,3703,"Shouldn't a Luna wear heels?"],[3937,4045,"I wasn't thinking."],[4137,4245,"You should wear whatever makes you"],[4245,4329,"feel comfortable."],[4504,4583,"But first,"],[4612,4675,"as my Luna,"],[4675,4792,"you need to take my blood."],[4950,5025,"Your blood?"],[5860,5926,"Yes."],[6051,6193,"That way I can sense your presence..."],[6322,6406,"wherever you are."]],"21":[[16,79,"Go on."],[133,246,"You don't have to be afraid."],[1931,2022,"How are you feeling?"],[2339,2394,"My heart,"],[2460,2585,"it's beating really fast."],[2631,2786,"Well, my blood has no such effect."],[2944,3057,"But I can sense you now,"],[3219,3345,"wherever you may be."],[3507,3607,"If you need me,"],[3657,3724,"I'll be there."],[3849,4012,"I don't even know how to thank you."],[4029,4095,"There's no need."],[4446,4558,"You're free now."],[4725,4804,"Free."],[4875,4959,"I'm free."],[4971,5105,"This is amazing!"],[5284,5422,"Stop, Lyra."],[5447,5576,"He'll never be your real Mate."],[5576,5701,"He's an Alpha,"],[5718,5872,"you're nothing compared to him."],[5910,5964,"Hey."],[6060,6143,"Get some rest."],[6239,6402,"I have matters I need to go handle."],[6485,6569,"Ok?"],[7999,8083,"Alpha Alfred,"],[8274,8366,"is that you?"]],"22":[[33,204,"You think you're safe now, bitch?"],[271,333,"Soon,"],[346,487,"your pathetic past"],[500,613,"will come to light."],[642,675,"No."],[759,838,"You're mine."],[934,1063,"My Mate."],[1117,1238,"Forever!"],[1618,1789,"Looks like I found the bitch"],[1789,1997,"who seduced Alpha Alfred."],[2102,2177,"Who are you?"],[2281,2556,"You don't deserve to know who I am."],[2602,2748,"The only thing you need to know"],[2802,3032,"is that I am the real Luna of this pack."],[3240,3319,"Guards!"],[3432,3645,"How about we introduce her"],[3645,3749,"to the Elders?"],[4346,4383,"No,"],[4416,4441,"no."],[4458,4550,"Don't touch me."],[4688,4800,"Dear Elders,"],[4833,4975,"I present to you"],[4975,5096,"the woman responsible"],[5096,5196,"for all the chaos"],[5196,5334,"between the two packs."],[5609,5843,"So you are the one behind this mess."],[5843,5960,"She's also the reason why"],[5960,6101,"Alpha Alfred was injured."],[6231,6368,"Alright, enlighten us."],[6414,6489,"Who are you?"]],"23":[[29,91,"Who are you?"],[179,271,"Stay calm."],[346,521,"Don't let them see your fear."],[621,746,"What did Alfred say?"],[809,996,"The Elders are extremely sharp."],[1113,1242,"The only way they're gonna believe you"],[1242,1418,"is if you act like a true Luna."],[1539,1655,"How do I make them believe"],[1655,1760,"I'm a true Luna?"],[1780,1843,"By going in there"],[1843,1943,"and truly believing it."],[2052,2210,"Forget that you don't have your wolf."],[2264,2318,"You go in there"],[2318,2444,"and you look him in the eye."],[2456,2552,"Hold your head up high."],[2656,2773,"Make them question their place,"],[2773,2844,"not yours."],[2907,3036,"Power's about more than strength."],[3036,3115,"It's about presence."],[3115,3207,"And Lyra, you have it."],[3269,3328,"Own it."],[3878,3983,"Did anyone bother"],[3983,4104,"checking with Alpha Alfred"],[4104,4208,"before tying me up?"],[4408,4550,"Alpha Alfred is a busy man."],[4550,4804,"He doesn't have time to devote to such"],[4842,4984,"insignificant matters."],[5017,5113,"Exactly."],[5138,5338,"As Elders, we are doing him a favor,"],[5338,5530,"handling this trash for him."],[5726,5772,"Wow,"],[5784,5860,"trash?"],[6089,6185,"Then tell me this."],[6235,6381,"Do you really think Alpha Alfred"],[6381,6510,"would let just anyone"],[6510,6602,"sleep in his room?"]],"24":[[8,187,"Alpha let you stay in his room?"],[408,617,"So, you're telling me that Alpha,"],[617,921,"who doesn't even let us in his room,"],[959,1151,"just let you stay there?"],[1217,1388,"You've got to be joking."],[1589,1680,"More likely,"],[1697,1843,"you're some kind of spy,"],[1856,2093,"here to steal our pack's secrets."],[2173,2318,"This is a very serious matter"],[2318,2369,"for all of us."],[2369,2481,"Guards, take her to prison."],[2481,2619,"We're gonna let Alpha deal with her."],[2635,2694,"Elders,"],[2752,2902,"it's clear you're all determined"],[2902,2952,"to accuse me"],[2952,3061,"of crimes I didn't commit."],[3157,3349,"But why not just ask Alpha himself"],[3349,3449,"who I really am?"],[3566,3749,"Don't be so full of yourself."],[3749,3841,"Do you really think"],[3841,3991,"you're important enough for that?"],[3991,4070,"Well, I know the Alpha"],[4070,4145,"won't appreciate"],[4145,4279,"the warm welcome you've given me."],[4371,4508,"You've made a huge mistake."],[4562,4788,"Don't fuck with us, you piece of shit!"],[5284,5388,"Touch me again,"],[5388,5484,"and you'll regret it."],[5509,5576,"Oh?"],[5576,5705,"You think I won't?"]],"25":[[246,379,"Don't touch my Luna."],[433,538,"Alpha."],[950,1063,"I'm sorry I'm late."],[1142,1209,"Are you hurt?"],[1255,1326,"I'm fine."],[1484,1580,"Alpha Alfred,"],[1580,1735,"did you just call her your Luna?"],[1897,2018,"You got a problem with that?"],[2047,2135,"Well, you never mentioned"],[2135,2193,"her before."],[2193,2289,"What's her background?"],[2289,2477,"Is she capable or even qualified"],[2477,2560,"to be our Luna?"],[2569,2736,"Are you questioning my decision?"],[2819,2857,"Alpha,"],[2857,2994,"you fought with the Wolfsbane pack"],[2994,3069,"over her?"],[3148,3336,"No Luna would ever put the Alpha"],[3336,3415,"in danger."],[3474,3641,"I'm only gonna say this once."],[3778,3941,"Lyra had nothing to do with that."],[4045,4250,"I'd better not see anything like this"],[4279,4425,"ever happen again."],[4433,4575,"Do I make myself clear?"],[4984,5117,"Lyra's pregnant with my pup."],[5413,5488,"We'll be getting married"],[5488,5576,"in a few days."]],"26":[[8,129,"Lyra's pregnant with my pup."],[150,233,"We'll be getting married"],[233,296,"in a few days."],[329,513,"She's pregnant with your pup?"],[542,700,"Alpha, how can you let some"],[734,838,"unknown wolf"],[838,971,"give birth to your child?"],[988,1109,"That's a good question."],[1126,1255,"Is she capable enough"],[1255,1334,"to be our Luna?"],[1343,1509,"We simply cannot have a wolf"],[1509,1697,"from an outside pack as our Luna."],[1710,1772,"Cindy here,"],[1772,1943,"is exceptionally qualified."],[2318,2510,"I request a challenge against her."],[2698,2836,"If she loses,"],[2952,3103,"then she is not qualified"],[3103,3228,"to be our Luna."],[3228,3340,"You better back off."],[3353,3432,"Alpha Alfred,"],[3461,3595,"if an outside female wolf"],[3595,3741,"desires to be our Luna,"],[3741,3874,"she must face a challenge"],[3874,4020,"with one of our wolves."],[4054,4250,"If she cannot pass that test,"],[4300,4491,"our wolfpack will never obey her."],[4600,4675,"Exactly!"],[4688,4779,"An incompetent of Luna"],[4779,4925,"would endanger our pack!"],[5021,5180,"Alfred rescued me."],[5230,5392,"If the pack rejects me,"],[5392,5563,"he'll also be implicated."],[5584,5747,"I absolutely cannot become"],[5747,5864,"a burden to Alfred."],[5939,6068,"I have to try."],[6089,6235,"I accept your challenge."]],"27":[[279,379,"Are you angry?"],[592,671,"Why did you accept"],[671,792,"this meaningless challenge?"],[792,934,"Do you not believe I could protect you?"],[980,1088,"I believe in you."],[1197,1338,"But if I'm acting as your Luna,"],[1338,1505,"I can't be hiding behind you."],[1643,1801,"It's the least I can do"],[1801,1981,"after everything you've done for me."],[3107,3236,"I won't let you lose."],[3753,3807,"Don't worry,"],[3849,3949,"when it comes to archery,"],[4004,4145,"I'm not a total lost cause."],[4888,5009,"Alpha Alfred,"],[5009,5184,"I'll show you that I'm the Luna"],[5184,5301,"who's really meant for you."]],"28":[[596,800,"I've never lost at archery before."],[917,1042,"If you forfeit now,"],[1084,1247,"you'll save yourself the embarrassment."],[2907,3073,"As expected from my daughter."],[3136,3345,"Cindy's archery skills are unmatched"],[3345,3516,"in the entire werewolf community."],[3586,3653,"Your turn."],[4312,4462,"You don't think stalling will help,"],[4462,4542,"do you?"],[4550,4612,"Give up,"],[4612,4758,"don't embarrass yourself!"],[4758,5042,"Boo!"],[5042,5246,"Go home!"],[5246,5697,"Leave, leave, leave!"],[6502,6723,"You didn't even hit the fucking target!"],[6723,6848,"What a fucking joke!"],[7111,7173,"Look again."]],"29":[[75,141,"Look again."],[150,200,"What?"],[479,692,"Look, the arrow on the ground is red."],[759,892,"Is that Cindy's arrow?"],[917,1121,"Alpha really chose a worthy Luna,"],[1163,1468,"she actually shot down Cindy's arrow!"],[1597,1726,"While I may not have a wolf,"],[1726,1839,"my archery skills"],[1839,1968,"are nothing to scoff at."],[2281,2385,"She wasn't strong enough"],[2385,2552,"to fight back that time."],[2577,2861,"Maybe she has a very weak wolf."],[2907,3182,"I have plenty of ways to deal with you."],[3261,3328,"Round two."],[3365,3424,"Let's go."],[3432,3653,"Wait, isn't this match getting boring?"],[3653,3791,"How about we spice it up?"],[4058,4237,"We'll blindfold ourselves,"],[4275,4487,"and use our wolves to find the target."],[4633,4846,"Whoever hits closest to the bullseye"],[4900,4988,"is the winner."]],"30":[[0,208,"And use our wolves to find the target."],[346,404,"Indeed,"],[404,613,"one's wolf is a part of one's power."],[642,859,"A Luna must have perfect harmony"],[859,1105,"between her human and wolf selves."],[1126,1213,"Damn it."],[1234,1368,"What should I do?"],[1397,1543,"Lyra doesn't have a wolf."],[1543,1626,"Everyone will definitely"],[1626,1830,"question her legitimacy as Luna."],[1939,2018,"What's the matter?"],[2052,2160,"You were so eager"],[2160,2264,"just a moment ago."],[2306,2519,"Don't tell me your wolf is so weak"],[2519,2744,"that you're afraid you won't win."],[2798,2969,"Why don't you just give up now?"],[3132,3219,"Speak up!"],[3336,3382,"I..."],[3470,3578,"Lyra, I'm here."],[3732,3924,"Am I hearing Alpha Alfred's voice"],[3924,4024,"in my head?"]],"31":[[75,120,"Lyra,"],[175,250,"I'm here."],[316,508,"Am I hearing Alpha Alfred's voice"],[508,579,"in my head?"],[604,775,"Yes, Lyra, you can hear me."],[796,863,"Don't worry,"],[888,967,"stay calm."],[984,1067,"I'll help you."],[1488,1634,"If it's a competition you want,"],[1697,1851,"it's a competition you'll get."],[2231,2331,"You'd better watch out."],[2435,2590,"My wolf is ferocious."],[3524,3720,"Cindy's wolf is powerful."],[3720,3891,"My daughter is the best candidate"],[3899,3983,"for Luna."],[4416,4508,"Spectacular."],[4508,4704,"Cindy's shot will be hard to top!"],[5167,5280,"Don't be nervous."],[5309,5413,"I can do it."]],"32":[[212,287,"Alfred?"],[454,529,"It's me."],[600,713,"Don't worry, you're the only one"],[713,800,"who can perceive me."],[1130,1247,"Follow my instructions."],[2335,2402,"Release."],[4662,4725,"Good girl."],[4871,5321,"Luna, Luna, Luna!"],[5321,5367,"Kate,"],[5422,5547,"how could this unknown werewolf"],[5547,5680,"have such powerful energy?"],[5718,5826,"Our daughter lost!"],[5826,5947,"Impossible!"],[5947,6101,"My daughter cannot lose!"],[7286,7361,"Lyra!"],[7386,7478,"Get out of the way!"],[8091,8162,"It hurts-"],[8291,8358,"my baby-"]],"33":[[112,183,"Lyra!"],[221,312,"Lyra, no!"],[467,533,"Lyra!"],[550,704,"Get the doctor now!"],[725,825,"Alpha Alfred!"],[850,967,"We were meant to be together!"],[967,1101,"How can you treat me like this"],[1101,1301,"just because of some outsider bitch!"],[1551,1693,"Execute Cindy,"],[1693,1805,"immediately!"],[1805,1889,"Alpha, no!"],[1889,2006,"Don't touch my daughter!"],[2093,2198,"No, Alpha, no!"],[2218,2348,"She's our only child!"],[2348,2456,"Think about what we've done"],[2456,2527,"for the pack!"],[2573,2736,"Please don't do this to Cindy."],[2844,2952,"Throw her in the dungeon."],[3053,3211,"If anything happens to Lyra,"],[3274,3407,"execute Cindy,"],[3445,3528,"immediately."],[3528,3620,"No, Alpha!"],[3620,3774,"I'm meant to be your Luna!"],[3807,4020,"She is not worthy!"],[4642,4767,"Code red, code red."],[4767,4838,"Ten cc's of -We're losing her."],[4838,4892,"adrenaline."],[4892,4929,"Come on."],[5442,5584,"What's the situation, Easton?"],[5584,5651,"Alpha,"],[5680,5759,"the Luna's body"],[5759,5943,"is rejecting all kinds of medicine."],[5980,6126,"We cannot treat her."]],"34":[[154,225,"Lyra!"],[258,367,"Lyra, I'm sorry!"],[383,554,"She was very badly injured."],[575,654,"Most people wouldn't have"],[654,738,"survived this,"],[788,934,"not to mention her resistance"],[934,1088,"to all kinds of medication."],[1105,1201,"I'm afraid,"],[1201,1380,"she won't be able to wake up."],[1476,1551,"Why does it feel like"],[1551,1685,"my heart is being torn out?"],[1726,1780,"Easton,"],[1839,1989,"there's one thing we haven't tried yet."],[2072,2143,"You mean-"],[2206,2323,"legend has it that"],[2323,2460,"the blood of the Alpha's heart"],[2460,2610,"can cure any disease."],[2660,2731,"You don't mean-"],[2865,2932,"Open my heart,"],[2932,3036,"feed my blood to Lyra."],[3036,3132,"No, it's too risky!"],[3132,3240,"You could die!"],[3240,3365,"Then I'll do it myself."],[4004,4079,"Alfred,"],[4120,4195,"Alfred."]],"35":[[50,129,"You're awake."],[350,450,"Your body wasn't responding"],[450,538,"to any medications."],[538,600,"This is the only way"],[600,717,"I could save you and our pup."],[817,859,"No,"],[917,984,"Alfred,"],[1192,1401,"I feel like there's a surge of energy"],[1401,1476,"in my body."],[1897,2064,"My belly no longer hurts."],[2348,2414,"Our pup,"],[2594,2761,"our pup is safe and sound."],[2990,3061,"Quickly, Easton!"],[3061,3123,"Check her out!"],[3724,3782,"Alpha,"],[3845,4070,"the wolf cub is indeed still intact."],[4091,4191,"And the Luna,"],[4216,4329,"she's recovering."],[4358,4429,"What do you mean, I thought"],[4429,4625,"she was resistant to all medications?"],[4708,4817,"This is the first time"],[4817,4971,"I've ever seen anything like this!"],[5447,5593,"Sorry, Alpha Alfred, I-"],[5926,5985,"Back then,"],[5985,6164,"Lyra's touch healed my wounds."],[6272,6460,"This matter is of utmost importance."],[6473,6606,"We must determine the reason,"],[6606,6690,"immediately."],[6694,6769,"Yes, Alpha."]],"36":[[275,446,"I could've come on my own."],[467,567,"You're recovering,"],[613,700,"let me help you."],[2802,2857,"Thank you."],[2919,3119,"I just don't want to be a burden to you."],[3186,3403,"You and our child are my responsibility,"],[3436,3516,"not a burden."],[5196,5309,"At each and every moment,"],[5392,5526,"my heart beats for you,"],[5626,5714,"yearns for you."],[7144,7215,"Alfred,"],[7282,7378,"don't stop."],[8587,8742,"Lyra, I want to mark you."],[8796,8996,"I want to make you mine forever."]],"37":[[83,141,"No,"],[158,287,"Alfred, wait."],[337,454,"We can't."],[600,767,"I'm just your fake Luna."],[942,1080,"You should save your mark for your"],[1080,1142,"real Mate."],[1238,1363,"No, I don't want just-"],[1455,1680,"Sooner or later you'll meet your real Mate."],[1814,1976,"Your Luna should be capable."],[2277,2381,"Not someone like me"],[2381,2523,"who doesn't even have a wolf."],[3044,3211,"I know exactly where I stand."],[3294,3457,"I know you're only taking care of me"],[3457,3603,"because of the child."],[3674,3791,"I won't be greedy"],[3791,3903,"and expect more from you."],[3920,4016,"But I want more than just"],[4016,4220,"a contractual relationship with you."],[6085,6310,"Only goddesses have that ability."]],"38":[[154,229,"Hey!"],[275,454,"Do you guys know who I am?"],[475,696,"Hurry up and call Alpha!"],[696,779,"Go!"],[1055,1213,"You look wretched, darling."],[1338,1438,"Is this how someone"],[1438,1543,"who wants to be a Luna"],[1543,1655,"is supposed to look like?"],[1676,1730,"Me?"],[1776,1885,"Become a Luna?"],[1926,2068,"They're about to have a wedding"],[2068,2235,"while I'm rotting here,"],[2248,2485,"waiting to be exiled under Alpha's orders!"],[2502,2619,"All because of that bitch!"],[2619,2698,"Calm down."],[2740,2848,"The position of Luna"],[2848,3040,"still belongs to you."],[3395,3553,"That woman-"],[3595,3824,"not only is she a wolf-less loser,"],[3824,4008,"but she's also a Wolfsbane pack"],[4008,4070,"maid?"],[4091,4279,"Mom, let's go tell Alpha Alfred!"],[4279,4375,"Think about it."],[4471,4604,"If she doesn't have a wolf,"],[4604,4796,"how did she win the competition?"],[5000,5092,"He helped her?"],[5296,5505,"So he knew that she didn't have a wolf"],[5559,5726,"and that she's a worthless maid?"],[5759,5847,"Right now,"],[5864,5980,"the best thing to do"],[6051,6106,"is to find"],[6106,6272,"the Alpha of the Wolfsbane pack."],[7157,7278,"Alpha Roland,"],[7386,7582,"I can take you to see this maid,"],[7653,7778,"just as long as you"],[7778,7941,"take her away from her wedding."],[8721,8792,"Deal."],[8904,9121,"Lyra, you're my Mate."],[9150,9280,"I'll never let you be"],[9280,9446,"anyone else's bride!"]],"39":[[158,246,"We gather here"],[246,379,"with the Moon Goddess as"],[379,608,"our witness to observe the union"],[608,821,"between Alpha and Luna."],[850,1046,"Will the Luna please come to the altar?"],[3353,3611,"Let's see how long she keeps smiling."],[3611,3745,"Soon, it'll be our Cindy up there"],[3745,3862,"in a wedding dress."],[3928,4083,"You look exquisite, my Luna."],[4175,4320,"A grand wedding with the person"],[4320,4387,"I love."],[4512,4688,"How I wish I was the real Luna."],[4688,4854,"Do you two promise"],[4879,5080,"to remain loyal to your partner"],[5080,5321,"and to use your strength and wisdom"],[5321,5447,"to protect the pack?"],[5447,5647,"To never betray each other"],[5663,5776,"and stand firm"],[5776,5951,"in the face of life or death?"],[6177,6260,"That bitch"],[6260,6368,"doesn't have a wolf!"],[6393,6602,"She doesn't deserve to be Luna."]],"40":[[4,87,"That bitch"],[87,196,"doesn't have a wolf."],[350,421,"How does she know"],[421,558,"that I don't have a wolf?"],[642,700,"Hey, hey, hey."],[829,896,"Don't worry."],[1526,1659,"Wasn't Cindy exiled?"],[1659,1851,"She said Lyra doesn't have a wolf."],[1864,1976,"That's impossible."],[2027,2248,"We all saw it during the archery match."],[2277,2419,"You guys don't believe me?"],[2464,2656,"Have any of you seen her"],[2656,2761,"turn into a wolf?"],[2831,2982,"Cindy, I spared you last time"],[2982,3028,"because of your"],[3028,3132,"parents' contributions"],[3132,3194,"to the pack."],[3207,3307,"And now you come in here"],[3307,3436,"starting trouble?"],[3457,3528,"Guards!"],[3553,3687,"Throw her in the dungeon."],[3762,3841,"Oh,"],[3841,3983,"Alpha Alfred,"],[4033,4258,"are you really gonna treat me like this"],[4275,4446,"over some worthless bitch?"],[4567,4625,"Everyone!"],[4658,4775,"Take a close look."],[4833,4934,"That woman"],[4934,5201,"isn't only a wolf-less loser,"],[5230,5347,"she's also a maid!"],[5359,5497,"Wolfsbane pack's maid?"],[5526,5651,"How is that even possible?"],[5668,5889,"Is that wanted poster actually real?"],[5914,6143,"Cindy almost killed our Alpha's child."],[6143,6356,"How can we believe anything she says?"],[6368,6506,"I brought someone"],[6506,6635,"who can prove it!"],[7178,7344,"Long time no see,"],[7344,7432,"maid."],[7586,7799,"Playtime is over."]],"41":[[0,79,"The Luna?"],[145,241,"A maid?"],[675,771,"Alpha Alfred,"],[771,963,"what do you see in that woman?"],[1001,1267,"I mean, she's lower than a maid,"],[1284,1430,"and doesn't even have a wolf."],[1430,1685,"And you want her to be a Luna?"],[1830,1968,"Our pack has never had"],[1985,2173,"a maid as a Luna."],[2173,2427,"He said Lyra doesn't even have a wolf."],[2439,2540,"How can someone like that"],[2540,2719,"be responsible for the pack's future?"],[2740,2827,"Guards!"],[2852,3044,"Destroy everything!"],[3061,3278,"Capture that maid on the altar!"],[3649,3828,"Looks like you came here to die."],[3828,4104,"You really love that maid, don't you?"],[4337,4550,"She's not a maid, she's my Luna!"],[4859,4979,"Alpha Alfred-"],[5013,5176,"You should have thought of yourself"],[5176,5242,"first!"]],"42":[[62,241,"Your first mistake"],[271,525,"was getting pregnant with Alpha's child."],[525,579,"No."],[658,763,"Let me go!"],[763,1030,"No, you're an ill-bred maid"],[1030,1121,"who doesn't even have"],[1121,1234,"the blood of a wolf."],[1242,1422,"Who knows what kind of disgusting"],[1438,1584,"creature you'll give birth to?"],[1672,1864,"If it's anything like its mother,"],[1960,2114,"then we can't let it live."],[2485,2652,"You'll always be inferior,"],[2652,2806,"you worthless maid!"],[2806,2831,"No."],[3007,3061,"No!"],[3340,3407,"No!"],[3853,4041,"What a powerful force!"],[4054,4233,"Is that Lyra's wolf?"],[4733,4796,"Impossible..."],[4900,5017,"This can't be possible!"],[5075,5138,"No."],[5296,5347,"No!"],[5839,6056,"I won't allow you to hurt my pup!"]],"43":[[29,212,"She really has a wolf."],[212,321,"And not just that,"],[321,575,"her wolf is extremely powerful!"],[588,717,"This kind of power"],[734,942,"is indeed worthy of a Luna."],[996,1059,"Lyra,"],[1084,1188,"I am your wolf,"],[1205,1276,"Marie."],[1309,1551,"I apologize for appearing late."],[1551,1614,"Marie?"],[1730,1789,"I thought,"],[1906,2072,"I, I thought I wouldn't have a wolf."],[2160,2231,"Lyra,"],[2239,2423,"you must believe in yourself."],[2452,2565,"Your abilities"],[2565,2744,"are far greater than you think."],[2769,2940,"I will always be here for you"],[2940,3036,"when you call."],[3757,3866,"Lyra, are you alright?"],[3945,4083,"I, I feel amazing."],[4137,4200,"Our pup"],[4200,4295,"is safe and sound."],[4437,4500,"Are you hurt?"],[4554,4675,"It's nothing, it's nothing."],[4921,4988,"Bitch!"],[5025,5171,"Do you think you can be Luna"],[5171,5334,"just because you have a wolf?"],[5417,5555,"It's none of your business!"],[6081,6272,"None of my business?"],[6481,6569,"Don't forget,"],[6681,6961,"we haven't broken our Mate bond."],[7077,7273,"You can't marry him!"]],"44":[[0,154,"Oh, you whore!"],[154,300,"You're still Alpha Roland's Mate,"],[300,458,"but you seduced Alpha Alfred?"],[458,629,"How can this depraved woman"],[629,750,"be our Luna?"],[821,1051,"I'm against someone like her"],[1051,1176,"becoming our Luna."],[1217,1297,"Seconded!"],[1305,1413,"We cannot approve,"],[1438,1572,"and we do not approve."],[1572,1805,"We do not accept her as our Luna."],[1805,1914,"The child inside her"],[1914,2022,"must be terminated!"],[2039,2289,"Who dares touch my Luna and my pup?"],[2540,2598,"Alfred,"],[2723,2869,"I don't want to burden you anymore."],[2886,3023,"I can just leave."],[3023,3069,"No."],[3132,3240,"I won't let you go."],[3382,3490,"Lyra, you're my Luna."],[3536,3645,"Whatever happens to us,"],[3645,3770,"we're gonna face it together."],[3866,3916,"But,"],[3970,4045,"I-"],[4066,4145,"Alpha!"],[4154,4400,"I won't accept a slut like her"],[4400,4491,"as our Luna!"],[4491,4567,"I agree."],[4567,4717,"The future of our pack"],[4717,4913,"cannot be ruined by this woman!"],[4925,4988,"Lyra,"],[5038,5134,"don't be afraid."],[5234,5438,"I know where you heart truly lies."],[5492,5622,"You love Alfred."],[5684,5872,"You don't have to accept Roland"],[5872,5947,"as your Mate."],[6006,6126,"But I already refused him,"],[6126,6247,"and he rejected it."],[6281,6331,"No."],[6402,6510,"You are special."],[6564,6760,"He has no right to reject your refusal."],[6844,7069,"Roland is not your only Mate."],[7069,7232,"You actually have two."],[7290,7390,"You have the power"],[7390,7557,"to select who you want."]],"45":[[166,254,"Alfred,"],[342,421,"you're my Mate."],[596,763,"I never thought we'd get to be together."],[796,1017,"Lyra, I've never cared about your past."],[1092,1263,"I chose you because of you."],[1284,1372,"You're my Luna."],[1480,1685,"What the hell is this, bitch?"],[1718,1897,"How do you have two Mates?"],[2027,2085,"Lyra,"],[2127,2348,"now's the time to make your decision."],[2406,2510,"What are you gonna do now?"],[2560,2777,"Are you going to break our bond?"],[2898,3107,"I've kept you for ten years,"],[3132,3294,"and now you want to leave me?"],[3415,3520,"Of course I do,"],[3591,3778,"you abusive piece of shit!"],[3791,3949,"What did you just say?"],[4004,4116,"Lyra,"],[4116,4229,"if you listen to me,"],[4258,4441,"like a good little girl,"],[4508,4579,"I'll let you be"],[4579,4713,"my Luna."],[4979,5092,"I, Lyra White,"],[5092,5213,"solemnly inform you,"],[5213,5292,"Roland Hill,"],[5292,5447,"Alpha of the Wolfsbane pack,"],[5459,5630,"that I refuse to be your Mate."],[6143,6331,"No fucking way!"],[6348,6506,"You have no right to refuse me!"]],"46":[[804,1042,"You pathetic maid!"],[1059,1305,"I will not let you gloat over me."],[1322,1497,"You should be bowing at my feet"],[1497,1609,"like my maid!"],[1609,1822,"I'm gonna fucking kill you!"],[2339,2552,"I'm gonna annihilate all of you!"],[2623,2686,"No!"],[2711,2761,"No!"],[2873,3007,"Don't even think about hurting"],[3007,3111,"the people of this pack."],[4312,4679,"I'm gonna kill every single one of you!"],[5342,5434,"Now you."]],"47":[[246,296,"Alfred,"],[358,450,"Alfred, no!"],[492,596,"You've been hit!"],[754,825,"It's alright."],[896,1017,"As long as you're okay."],[1197,1259,"Alfred,"],[1388,1501,"Alfred, please."],[1647,1714,"No,"],[1714,1789,"Alfred."],[1826,1964,"Alfred, please."],[2035,2077,"No!"],[2081,2139,"Quick,"],[2181,2364,"get Alpha to a doctor now!"],[3207,3349,"Where do you think you're going?"],[3395,3553,"Don't think we've accepted you"],[3553,3707,"just because you're his Mate!"],[3728,3903,"Who's to blame for him getting hurt?"],[3912,3974,"You!"],[4004,4083,"Let me go!"],[4104,4204,"Alfred needs me!"],[4208,4358,"You're a curse upon us!"],[4379,4550,"Look at all the havoc you've created!"],[4550,4646,"When has the pack"],[4646,4796,"ever been so unstable?"],[4821,4909,"We need a doctor!"],[4929,5059,"We have injured people here!"],[5630,5910,"Mom, wake up, wake up."],[5939,6051,"Wake up."],[6181,6252,"Elder,"],[6314,6435,"we can't treat this."],[6456,6502,"What?"],[6519,6869,"Roland's claws is laced with poison."],[6956,7127,"Anyone injured will die"],[7127,7232,"within the hour."],[7282,7361,"What?"]],"48":[[16,79,"See?"],[120,287,"This is all your fault!"],[383,538,"It is all her fault!"],[571,704,"If she hadn't appeared,"],[704,867,"our lives wouldn't be in danger,"],[867,942,"and our Alpha"],[942,1076,"wouldn't have gotten hurt!"],[1088,1163,"You're right!"],[1213,1313,"She wreaked havoc"],[1313,1497,"and brought disaster to our pack!"],[1497,2223,"Kill her, kill her!"],[2223,2360,"She's a curse!"],[2360,2523,"My mom wouldn't have been hurt"],[2523,2660,"if it wasn't for her!"],[2673,2765,"Kill her,"],[2790,2865,"now!"],[2965,3082,"No, I, I'm not."],[3082,3174,"Kill her!"],[3174,3324,"I, I just saved you. -Kill her!"],[3324,3390,"Kill her!"],[3390,3465,"Do you hear them?"],[3465,3545,"Kill her!"],[3545,3753,"We don't need a filthy,"],[3770,3933,"cursed maid like you."],[3962,4120,"No one wants you!"],[4120,4587,"Kill her, kill her!"],[4708,4796,"My baby,"],[4842,4954,"it's okay."],[4979,5100,"I can handle this."]],"49":[[296,433,"You're still thinking about that"],[433,650,"disgusting creature inside you?"],[650,717,"Guards!"],[738,892,"Capture and kill her!"],[1084,1146,"No!"],[1397,1472,"Stop!"],[1518,1647,"You cannot kill her!"],[1776,1826,"What?"],[1826,1972,"What's the meaning of this?"],[1972,2118,"Hasn't she wreaked enough havoc"],[2118,2181,"on the pack?"],[2193,2339,"Why shouldn't I kill her"],[2339,2469,"right here, right now?"],[2540,2656,"You can't kill her!"],[2694,2915,"Lyra is a divine wolf goddess,"],[2915,3098,"which only appears maybe"],[3098,3269,"once every thousand years."],[3290,3511,"Her blood can heal everything,"],[3570,3816,"including everyone's poison injuries."],[3895,3941,"I..."],[4062,4183,"I'm a divine wolf?"]],"50":[[16,129,"A divine wolf?"],[166,291,"How is that possible?"],[308,517,"This isn't another one of her tricks,"],[517,579,"is it?"],[621,767,"Hasn't she hurt us enough?"],[867,1038,"But what if it's real though?"],[1038,1180,"Stop wasting our time with your"],[1180,1322,"crazy theories, Easton."],[1343,1518,"You think this piece of trash is a"],[1526,1593,"Goddess?"],[1630,1755,"Have you lost your mind?"],[1764,2022,"I am speaking the absolute truth!"],[2335,2385,"This"],[2423,2594,"is a sample of her blood."],[2652,2773,"If you don't believe me, you-"],[3490,3557,"You're right."],[3586,3699,"I don't believe you!"],[3795,3941,"This maid-wolf,"],[3949,4016,"a Goddess?"],[4045,4108,"Please."],[4279,4371,"If she's a Goddess,"],[4371,4521,"then we're all Goddesses!"],[4542,4671,"Cindy has a point!"],[4683,4817,"Hurry up and deal with her!"],[4817,4963,"Eliminate her."],[4963,5055,"We don't wanna"],[5055,5263,"see that woman anymore!"],[5301,5422,"You may not believe it,"],[5451,5680,"but that woman is about to die."],[5718,5780,"Mom,"],[5826,5889,"please,"],[5930,6060,"don't fall asleep."],[7432,7486,"Look!"],[7515,7570,"This blood"],[7570,7728,"can really revive everything!"]],"51":[[12,150,"Could it be that Lyra"],[187,425,"really isn't an ordinary wolf?"],[442,654,"But hasn't she harmed us enough?"],[784,1067,"Mom, wake up, wake up,"],[1117,1217,"please."],[1443,1639,"What if we use my blood and try it out?"],[1856,1931,"No!"],[2006,2047,"But,"],[2114,2260,"but what if my blood is useful?"],[2260,2310,"Child,"],[2310,2469,"please let her try."],[2481,2660,"That poison is uncurable"],[2660,2806,"with our medicine skills."],[2815,3044,"Only the blood from a Goddess"],[3044,3144,"can cure it."],[3403,3482,"All right, then."],[3486,3645,"But if anything happens to my mom,"],[3657,3749,"you're dead."],[3849,3978,"If her blood doesn't work,"],[4016,4124,"kill her immediately!"],[6443,6606,"Easton, you liar!"],[6606,6690,"Guards!"],[6702,6810,"Off with her head!"]],"52":[[358,513,"Mom, you're awake."],[529,638,"You're awake."],[763,921,"Thank Goddess, it worked."],[1080,1167,"She did it!"],[1201,1280,"By the Goddess,"],[1309,1501,"her blood can really heal anything!"],[1501,1605,"We're saved!"],[1647,1730,"Thank you."],[1743,1860,"I just did what I could."],[1964,2039,"Goddess!"],[2089,2202,"Please forgive us!"],[2218,2356,"Save us with your blood."],[2356,2435,"Please!"],[2460,2606,"You are our savior!"],[2623,2794,"Forgive our ignorance!"],[2831,2890,"Lyra,"],[2915,3028,"are you willing to help them?"],[3053,3157,"You're already injured,"],[3157,3361,"and a lot of people need your blood."],[3395,3574,"You'll have to overextend yourself."]],"53":[[104,175,"I'll do it."],[3028,3128,"Please save my wife."],[3161,3228,"She's dying."],[3315,3449,"Our children need you too!"],[3474,3545,"Please,"],[3611,3720,"save me too."],[3887,3962,"Enough!"],[4045,4233,"Your body can't take anymore!"],[4475,4579,"Please save my wife!"],[4612,4754,"Our children need you too!"],[4779,4842,"Please,"],[4842,4929,"save me too."]],"54":[[458,513,"Lyra,"],[596,679,"thank you for not harboring"],[679,779,"any resentment towards me"],[788,875,"for doubting you."],[967,1105,"And for generously giving your blood"],[1105,1276,"to save our people."],[1380,1522,"I just did what I needed to."],[1630,1780,"It's all water under the bridge now."],[1797,1864,"No,"],[1914,2077,"you gave us hope for the future."],[2164,2260,"So therefore,"],[2285,2431,"on behalf of the entire pack,"],[2515,2585,"I thank you."],[2802,2944,"And I also acknowledge"],[3003,3123,"that you are"],[3199,3324,"our rightful Luna."],[3532,3649,"Thank you, Goddess."],[3707,3878,"Thank you for saving my life."],[3974,4104,"Thank you, Goddess."],[4104,4283,"Thank you, Luna."],[4704,4825,"This is impossible!"],[4879,5025,"This can't be happening!"],[5518,5647,"I only did what I could,"],[5705,5905,"but if you're all willing to accept me,"],[5930,6168,"I will do my best to protect this pack."],[6222,6335,"She's our Luna!"],[6343,6506,"Only she can protect our pack!"],[6694,6798,"It's an emergency!"],[6798,7023,"Everyone evacuate immediately!"]],"55":[[41,108,"What's wrong?"],[116,221,"It's an emergency."],[233,333,"The Wolfsbane poison in"],[333,404,"Alpha Alfred"],[404,575,"has triggered his manic mode."],[575,696,"If we can't cure him-"],[734,804,"What?"],[980,1042,"Spit it out!"],[1042,1105,"What will happen?"],[1121,1263,"He'll kill everyone."],[1401,1505,"He's already in the forest"],[1505,1689,"and it could appear at any time!"],[1755,1985,"Everyone, follow me to the safe zone!"],[2198,2243,"Hurry up."],[2519,2581,"Alfred."],[2686,2836,"No, no, it can't be."],[3011,3094,"Dr. Easton,"],[3236,3365,"can my blood cure him?"],[3415,3520,"Goddess,"],[3520,3628,"leave now in a hurry!"],[3628,3803,"You're, you're way too exhausted."],[3820,3933,"And, and he might not even"],[3933,4070,"recognize you at this point."],[4116,4341,"You could die if you go now."]],"56":[[4,208,"You could die if you go now."],[254,342,"I'm not afraid."],[458,592,"I will not abandon him."],[629,734,"He is my Alpha."],[1013,1076,"Alfred."],[1076,1226,"It's me, Lyra."],[1476,1584,"I know you're still in there."],[1722,1830,"You won't hurt me, right?"],[2035,2106,"Go!"],[2147,2369,"Go, I can't control myself!"],[2540,2602,"No!"],[2669,2781,"I won't leave you."],[2831,2936,"You're my Mate."],[2973,3111,"I am prepared to follow you"],[3128,3261,"through sickness or health,"],[3269,3378,"life or death!"],[4137,4279,"I believe in you, Alfred."],[4320,4454,"Please come back."],[5472,5526,"Lyra."]],"57":[[12,83,"Lyra."],[425,475,"Lyra."],[663,838,"Lyra, Lyra, I'm so sorry, I-"],[838,938,"God, I hurt you."],[1126,1188,"I didn't know that"],[1188,1317,"I was gonna become manic again."],[1317,1447,"You just have to leave me here."],[1447,1626,"No, you don't have to apologize."],[1693,1839,"We will get through this together."],[2206,2273,"Lyra,"],[2289,2510,"the wolfsbane is too deep in his system."],[2540,2702,"If you want to completely cure him,"],[2702,2911,"you must finish the marking ceremony."],[2936,3015,"You mean-"],[3028,3094,"Yes."],[3128,3340,"Marking is not only the union of souls,"],[3340,3545,"but also the union of bodies."],[3611,3720,"He needs you,"],[3757,3945,"and only you can save him."],[4124,4287,"Lyra, what are you still doing here?"],[4491,4642,"I can't control myself anymore."],[4642,4742,"You have to leave."],[4758,4863,"I won't leave you,"],[4929,5088,"no matter what happens."],[5805,5947,"I want you to mark me."]],"58":[[392,504,"Are you sure you about that?"],[763,905,"Of course, my Alpha."],[1105,1238,"I've longed for this moment."],[1330,1418,"Me too."],[1593,1705,"I'm gonna mark you now."],[3870,4004,"We'll be together eternally."]],"59":[[633,750,"Alfred, you're awake."],[1071,1167,"How do you feel?"],[1217,1309,"I feel great."],[1455,1576,"I've never been better."],[1939,2014,"Alfred,"],[2110,2235,"before I met you,"],[2289,2385,"I was broken."],[2569,2719,"I didn't think I could ever heal"],[2719,2811,"from that pain."],[2986,3082,"But you"],[3128,3315,"showed me unconditional love."],[3386,3465,"And..."],[3666,3820,"my heart started beating again."],[3933,4191,"Actually, my heart starts beating faster"],[4191,4341,"every time you're near."],[4550,4642,"I didn't reject you"],[4642,4800,"because I don't love you."],[4959,5088,"I rejected you because"],[5088,5226,"I didn't think I was good enough"],[5226,5342,"to stand by your side."],[5434,5584,"Lyra, I knew that you were my Luna"],[5584,5647,"from the moment"],[5647,5768,"that I laid eyes on you."],[5889,5960,"I don't care about"],[5960,6147,"your identity or your past."],[6264,6423,"You're simply just you,"],[6539,6702,"and that's more than enough for me."],[6777,6844,"Thank you."],[7040,7286,"Now I can finally stand by your side"],[7411,7499,"as your partner,"],[7574,7674,"as your Luna."],[8441,8516,"Thank you."],[8817,9013,"Lyra, you'll always be my full moon."]],"60":[[4008,4074,"We didn't get a chance"],[4074,4212,"to finish our vows last night."],[4304,4408,"I wanted to hold this wedding"],[4408,4562,"to make up for past regrets,"],[4675,4833,"and to celebrate new beginnings."],[5305,5576,"Aw!"],[5584,5651,"Thank you"],[5651,5830,"for coming into my world, Alfred."],[5939,6114,"We've gathered here today"],[6114,6277,"to witness the marriage of"],[6277,6594,"our Alpha Alfred and his Mate Lyra,"],[6631,6831,"our Luna and our guardian."],[6919,7132,"Alpha Alfred, are you willing to"],[7132,7369,"form a sole contract with Lyra,"],[7415,7640,"promising to stay together forever,"],[7640,7753,"through good or bad?"],[7816,7874,"I do."],[8012,8116,"Luna Lyra,"],[8141,8224,"are you willing"],[8224,8412,"to spend the rest of your life"],[8441,8616,"next to Alpha Alfred's side?"],[8654,8883,"Promising to protect your people,"],[8954,9117,"regardless of the turns of fate?"],[9317,9367,"I do."],[9859,10222,"Long live the Luna, long live the Luna!"],[10243,10614,"Long live the Luna, long live the Luna!"]],"61":[[62,204,"This is your home now, Lyra."],[383,504,"This is your pack."],[592,688,"You don't need to doubt yourself"],[688,767,"ever again."],[1001,1159,"You're the one who gave me the strength"],[1159,1288,"and the courage, Alfred."],[1393,1539,"Choosing you is the best decision"],[1539,1647,"I've ever made, Lyra."],[1780,1872,"And nothing in the world"],[1872,2002,"is ever gonna change that."],[2227,2444,"My heart belongs to you, Alfred."],[2585,2690,"Whatever lies ahead,"],[2852,2973,"we'll face it together."],[3420,3586,"Aw."],[3586,3720,"So sweet."],[4170,4350,"Can I really become a worthy Luna?"],[4471,4579,"You already have, Lyra."]]}