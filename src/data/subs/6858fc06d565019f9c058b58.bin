et us"],[6544,6631,"in the backyard?"],[6681,6827,"Oh my god,"],[6827,6944,"he’s so whipped."],[7111,7169,"That's right."],[7211,7307,"He can act as stubborn"],[7307,7490,"as he wants, but at the end of the day,"],[7524,7620,"I own him."]],"50":[[29,120,"Stella, you gotta teach me"],[120,179,"how to whip a"],[179,262,"simp into place."],[279,342,"Mm-hmm."],[379,437,"It's just like"],[437,554,"training a stray dog."],[613,721,"Shower them with attention"],[721,871,"and then rip it away until"],[871,1005,"they whine for it back."],[1297,1388,"Amazing."],[1418,1530,"Okay, can everyone"],[1530,1597,"listen up please?"],[1664,1722,"Make sure to get"],[1722,1793,"my good side,"],[1793,1939,"the viewers are gonna love this!"],[1976,2093,"Could we please show off"],[2093,2214,"the gifts I prepared?"],[2419,2489,"Oh my god."],[2831,2977,"Are those the Harry Winston"],[2977,3057,"Crystal Shoes?"],[3082,3215,"They're like three million dollars."],[3224,3349,"Someone in the chat said the"],[3349,3574,"Imperial Blue necklace was"],[3574,3636,"originally owned"],[3636,3770,"by the Royal Family."],[3807,3920,"Damn, Tony,"],[3920,4020,"kid’s dropping stacks"],[4020,4108,"on your girl."],[4108,4212,"What’d you get her?"],[4287,4462,"I don’t need to pay for her attention."],[4491,4654,"She knows who the real prize is."],[4717,4884,"Oh, since you did such a good"],[4884,5017,"job on my gifts, I'll forgive"],[5017,5080,"you for acting"],[5080,5217,"like a total spaz."],[5259,5363,"Tony, help me with the necklace."],[5497,5568,"Uh, no."],[5676,5726,"What?"],[5743,5814,"Stella, you think"],[5814,5893,"these gifts are for you?"],[5947,6047,"Jesus Christ, you are"],[6047,6222,"so full of yourself."],[6247,6339,"How about this, get these"],[6339,6464,"party crashers out of here"],[6473,6548,"before the real"],[6548,6664,"birthday girl comes."]],"51":[[12,141,"Get these party crashers out"],[141,258,"of here before the real"],[258,383,"birthday girl comes."],[400,433,"What?"],[433,613,"The real birthday girl?"],[813,913,"Let me dumb this down for you."],[959,1209,"This is not your"],[1247,1359,"birthday party."],[1413,1438,"What?"],[1488,1584,"Having second thoughts"],[1584,1634,"because I was"],[1634,1755,"sitting on Tony's lap?"],[1864,1943,"You're gonna punish"],[1943,2031,"me like a little bitch?"],[2206,2352,"God, I thought women were catty,"],[2352,2444,"I mean,"],[2444,2544,"this is some"],[2544,2731,"straight petty bullshit."],[2911,3086,"I don't give a shit what"],[3086,3211,"either of you two do."],[3253,3374,"Stella,"],[3386,3561,"I am done."],[3607,3674,"Okay?"],[3691,3791,"You and your dad can go"],[3791,3853,"back to your"],[3853,4054,"miserable, slum life."],[4124,4254,"Kiss all this goodbye!"],[4337,4437,"What a joke."],[4475,4567,"All this?"],[4633,4738,"You mean the pool,"],[4738,4842,"the mansion,"],[4892,5050,"the gifts, the servants?"],[5084,5251,"Those are all Stella’s."],[5296,5392,"Shit, I don't know what's up"],[5392,5505,"with Enzo, but Tony might"],[5505,5626,"push him over the edge."],[5626,5818,"I can't lose this."]],"52":[[25,196,"The only thing you can"],[196,300,"take away from her"],[300,554,"is your creepy ass obsession."],[596,663,"That's right, Tony."],[738,913,"So why don’t you see yourself out."],[988,1117,"Or I guess I have to,"],[1197,1347,"and I’m not exactly gentle."],[1384,1443,"Whoa."],[1568,1726,"I’d like to see you try."],[1789,1960,"Oh my God, Enzo, you're literally"],[1960,2102,"ruining Stella's day."],[2110,2189,"Taking all of the"],[2189,2306,"attention like a dick."],[2385,2469,"Quit with the lies."],[2510,2615,"If Stella's not the real"],[2615,2702,"birthday girl,"],[2702,2794,"then who is?"],[4004,4079,"Lily?"],[4079,4233,"What is she doing here?"],[4441,4604,"Happy birthday, Ms. Lily."],[4646,4683,"Thank you."],[4996,5238,"Wow, you look incredible."]],"53":[[37,225,"Babe, is this how your staff"],[225,321,"always treats you?"],[342,421,"Why are they saying it's"],[421,504,"Lily's birthday?"],[809,905,"Did you invite her?"],[942,1042,"If you don't make her leave"],[1042,1172,"in the next few seconds, I'm"],[1172,1413,"never speaking to you again."],[1422,1501,"Who says I wanna celebrate"],[1501,1630,"your birthday, okay?"],[1718,1805,"Happy birthday, Lily."],[1805,1993,"I'm so sorry, Stella totally"],[1993,2081,"ruined your party,"],[2081,2202,"but Mr. Blake, he's on his way."],[2202,2293,"He's gonna make everything"],[2293,2456,"perfect for your big day."],[2481,2552,"You didn't have"],[2552,2635,"to do this, Enzo."],[2673,2915,"This is, it's just amazing."],[2948,3128,"Kindly, leave,"],[3207,3349,"this party has standards."],[3482,3570,"Now why don't you get the"],[3570,3716,"fuck out of here, Stella?"],[4008,4137,"Do you really think,"],[4137,4266,"that after all"],[4266,4475,"these years of treating me"],[4475,4575,"like shit,"],[4575,4629,"that I would"],[4629,4779,"wanna celebrate your birthday?"],[4888,4934,"I'm gonna say"],[4934,5021,"this one last time."],[5063,5267,"This is not your party."],[5351,5484,"This is Lily's party."],[5605,5772,"This is fucking wild,"],[5772,5922,"making up accusations"],[5922,6139,"just to try and get my attention."],[6331,6481,"How did you even get here?"],[6502,6589,"The guard was only supposed"],[6589,6752,"to let in people on the list."],[6810,6856,"You forgot"],[6856,6986,"your bag in the back."],[6986,7048,"Dad?"],[7478,7599,"Babe, did you just call the"],[7599,7716,"chauffeur your dad?"]],"54":[[0,175,"Wait, didn't you call him dad"],[175,308,"the other night at the sleepover?"],[354,425,"Stella, is this"],[425,550,"chauffeur your dad?"],[621,725,"No, my dad is not"],[725,938,"some loser chauffeur."],[984,1017,"Wow."],[1088,1197,"Stella, you would really"],[1197,1330,"put down your own dad"],[1330,1493,"just to cover your own façade?"],[1518,1676,"Mind your fucking business."],[1676,1805,"If I say it's not my dad,"],[1835,1968,"it's not my dad!"],[1968,2135,"When have I ever lied to you guys?"],[2135,2344,"Kevin, look at what you created."],[2344,2527,"A stubborn brat,"],[2527,2644,"so self obsessed"],[2644,2765,"she won’t even acknowledge you"],[2765,2898,"as her own father."],[2952,3057,"Enzo, I think you should"],[3057,3169,"watch your tone,"],[3169,3219,"and remember"],[3219,3374,"that you are speaking"],[3374,3511,"to Ms. Stella Quinn."],[3557,3687,"Keep pushing and she'll cut"],[3687,3766,"you off for good."],[3812,4016,"Shit, I thought that"],[4016,4237,"the chauffeur was her dad for a second."],[4358,4533,"Enzo is fucking psycho."],[4554,4700,"Yes!"],[4792,4900,"Honestly, man,"],[4900,5059,"at least have the decency"],[5059,5167,"to show Stella"],[5167,5413,"some respect in her own house."],[5459,5551,"Man, if I was a Quinn,"],[5605,5680,"I would have kicked you out"],[5680,5776,"a long time ago."],[5997,6135,"Thanks for the idea, Tony."],[6289,6414,"What do you say, Kevin?"],[6468,6573,"Should I throw out my"],[6573,6669,"stubborn staff"],[6669,6823,"and his narcissistic daughter?"],[6873,6994,"No, please, no."],[7040,7107,"Kevin,"],[7207,7286,"you’re fired!"]],"55":[[0,95,"You’re fired!"],[166,254,"You can't do this."],[287,342,"You have no right"],[342,450,"to fire me, Enzo."],[483,554,"Yes, I do."],[554,867,"And someone's on his way right now,"],[905,975,"who’s gonna tell you"],[975,1059,"the exact same thing."],[1071,1155,"Your dad?"],[1192,1301,"He is coming back early?"],[1401,1509,"No, that's impossible."],[1551,1639,"Uh, you guys?"],[1651,1764,"As of today,"],[1764,1876,"Kevin and his daughter are"],[1876,2064,"no longer employees of the Quinn Estate."],[2064,2156,"Please see to it that"],[2156,2264,"their rooms are cleared out."],[2339,2527,"If you so much as throw out our things,"],[2527,2673,"I’ll have you thrown out to the streets"],[2673,2777,"in seconds."],[2861,2957,"That’s it,"],[2957,3140,"I’m never talking to you again."],[3182,3278,"I hope you're happy."],[3541,3703,"I’m over the fucking mood."],[3820,3974,"Let's go clear our business."],[3978,4158,"