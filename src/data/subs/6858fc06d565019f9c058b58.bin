0,5668,"your face, huh?"],[5864,6031,"Finally, that idiot just let"],[6031,6206,"me have my cake and eat it too."],[6289,6368,"Now I just need to get Enzo"],[6368,6560,"to shut up before anyone else"],[6560,6664,"questions me again"],[6664,6785,"as the rightful Quinn heir."],[6810,6944,"I hope you're happy with your party."],[6969,7098,"I've never worked this hard"],[7098,7203,"on an event before."],[7240,7482,"It was passible."],[7615,7753,"I believe the arrangement was"],[7753,8028,"to settle the bill after the event, correct?"],[8441,8637,"Two million dollars, right?"],[8758,8883,"Enzo will take care of it."],[8913,8967,"Oh, no."],[9042,9184,"Stella, this is your party, right?"],[9225,9330,"I mean, shouldn't have any"],[9330,9392,"problem paying."],[9446,9526,"You're the daughter of the"],[9526,9667,"richest family in town."]],"57":[[4,125,"Shouldn't have any problem paying."],[171,254,"You're the daughter of the"],[254,367,"richest family in town."],[458,613,"Why are you being so smug?"],[667,796,"Stella is a Quinn heir"],[825,975,"Two million, I mean, that's"],[975,1096,"basically her weekly allowance,"],[1096,1163,"right, Stella?"],[1242,1393,"Yeah, totally."],[1539,1705,"Oh my God, I can't pay for this."],[1705,1805,"Two million dollars just"],[1805,1897,"for one night?"],[1956,2135,"Wait, Enzo gave me one of his"],[2135,2248,"dad's blank checks before he"],[2248,2398,"started acting like such a jerk."],[2690,2777,"Why reach into my own"],[2777,2890,"allowance when I have access"],[2890,3123,"to my daddy's personal account?"],[3169,3303,"Stella can get whatever she wants."],[3357,3545,"She doesn't need you simping after her."],[3570,3591,"Mm."],[3724,3887,"Forgot about my dad's checkbook."],[3933,4062,"But luckily, I know"],[4062,4216,"the number of the family accountant."],[4308,4325,"Hi."],[4441,4517,"Someone is trying"],[4517,4671,"to impersonate the Quinn heir."],[4696,4738,"Could you please"],[4738,4842,"freeze all my accounts?"],[4909,4942,"Thank you."],[5171,5334,"He's just trying to scare me."],[5334,5497,"He gave me that check himself."],[5497,5647,"I know he wants me to beg for"],[5647,5768,"him in front of everyone."],[5780,6081,"But this power trip of his needs to end."],[6126,6281,"Mr. Blake, ignore him."],[6310,6410,"We've been having some problem with"],[6410,6598,"the help recently."],[6702,6806,"Why don't you scan that check"],[6806,6890,"here and now in front of"],[6890,6981,"everyone and show them that"],[6981,7157,"I'm the real Quinn heir?"],[7415,7553,"Right away, Ms. Stella."],[8591,8662,"I'm sorry."],[8679,8825,"This is a bad check."]],"58":[[4,79,"I'm sorry."],[108,246,"This is a bad check."],[250,342,"What are you talking about?"],[342,508,"That account has billions."],[554,654,"Oh my god."],[654,850,"Did Enzo really freeze the account?"],[909,980,"No, no, no."],[980,1076,"In order for him to do that,"],[1076,1209,"he had to really be a member"],[1209,1405,"of the Quinn family."],[1526,1689,"I have no idea what's going on."],[1730,1910,"But the viewers love it."],[1964,2052,"Clearly, there's something"],[2052,2135,"wrong with your phone."],[2168,2235,"It's not used to"],[2235,2469,"such large transactions."],[2506,2698,"Ms. Stella, I organize"],[2698,2923,"events worth tens of millions."],[2969,3098,"My bank handles transactions"],[3098,3299,"like this every single day."],[3299,3420,"You're scanning it wrong."],[3420,3503,"Give me that."],[3803,3974,"Are you trying to get out of paying?"],[3974,4079,"No, of course not."],[4592,4700,"If you can't pay now,"],[4700,4900,"I'm gonna call the police."],[4950,5042,"Pay up,"],[5109,5313,"or pay the price."]],"59":[[16,108,"Pay up,"],[175,379,"or pay the price."],[813,925,"Of course, will you"],[925,1155,"just give me a moment?"],[1634,1747,"What do I do?"],[1764,1843,"You need to make"],[1843,1972,"that little punk pay up."],[1985,2143,"We can't afford a bill like that."],[2143,2310,"I know, but he's being a jerk."],[2331,2485,"He’s on your finger, right?"],[2565,2686,"You do whatever it takes to"],[2686,2815,"make him happy."],[2857,2990,"Hey guys, sorry to interrupt."],[2990,3136,"If you come clean right now,"],[3136,3274,"I might let you stay one more"],[3274,3365,"night while you figure out"],[3365,3461,"where to go next."],[3561,3703,"It doesn't have to be like this."],[3841,4024,"Enzo, you know we can't afford that."],[4024,4237,"Why did you freeze the account?"],[4258,4404,"I thought Mr. Quinn was your dad."],[4433,4487,"That's what you've been"],[4487,4567,"telling everybody."],[4600,4750,"God, can you just be serious"],[4750,4884,"for a moment, please?"],[5096,5242,"Fine, seriously,"],[5242,5342,"you're neither my girlfriend"],[5342,5476,"nor my friend and the two of you"],[5476,5584,"have been taking advantage of"],[5584,5743,"my family for far too long."],[5780,5880,"We just talked about this"],[5880,5997,"after your father-"],[5997,6227,"Dad, shut up."],[6368,6464,"What do you want?"],[6485,6602,"To embarrass me in front of"],[6602,6731,"everyone with my birthday?"],[6756,6952,"Is that gonna get you off, you freak?"],[7015,7182,"For the last time, this isn't"],[7182,7290,"your birthday party, but"],[7290,7474,"you're too egotistical to"],[7474,7640,"realize that, Stella."],[7832,7978,"I cannot believe I ever saw a"],[7978,8058,"future with you."],[8162,8333,"Payment, please."]],"60":[[16,191,"Payment, please."],[408,771,"Enzo, I hate how things have been"],[771,988,"between us recently."],[1021,1113,"How about this?"],[1146,1313,"If you pay for this party,"],[1363,1497,"we can make things official and"],[1497,1672,"we can finally be together,"],[1672,1918,"but if I'm locked up for not paying them,"],[2122,2243,"I'll never see you again."],[2640,2698,"Enzo,"],[2815,2907,"Enzo, Enzo."],[2907,3069,"You’re the heir to the Quinn Corporation,"],[3069,3211,"if you plead guilty"],[3211,3378,"they will let you out of this slap on wrist."],[3411,3553,"I am just the daughter of"],[3553,3678,"your family chauffeur,"],[3678,3858,"a low class nobody."],[3903,3995,"They'll take me to jail and"],[3995,4099,"then I'll never see you again."],[4099,4195,"I'll never see you again."],[4892,5030,"That won't work twice."],[5150,5338,"You spineless simp,"],[5338,5488,"you fucking lap dog,"],[5488,5638,"if you think you can live without me,"],[5638,5693,"you're a joke."],[5764,6001,"Don't take it easy on that crybaby, Stella."],[6035,6160,"I know what happened."],[6160,6410,"he stole your dad’s actual checkbook"],[6410,6581,"and that’s why your check bounced."],[6961,7011,"You're right."],[7061,7190,"He must’ve switched the checks"],[7190,7399,"at the last minute as in last ditch effort"],[7399,7532,"to get my attention."],[7832,7882,"Tony,"],[7932,8095,"will you be a dear and get back for me?"],[8283,8354,"Yes."]],"61":[[433,704,"Of course, I can't"],[704,875,"just let Enzo fire me."],[913,1005,"We'd have nothing."],[1005,1180,"But if this muscle-head steals"],[1180,1393,"Enzo's checkbook, we'd have"],[1393,1739,"access to the Quinn's endless pile of cash."],[1739,1939,"We can make off with billions"],[1939,2114,"before they even know it's missing."],[2160,2406,"You know, we're not in school anymore."],[2419,2598,"There's no one here to save you buddy."],[2744,2852,"You're such a meat head,"],[2852,2915,"you don't even know when you're"],[2915,3015,"getting played."],[3065,3190,"We'll see how well you talk back"],[3190,3332,"when I beat your face to a bone."],[3607,3712,"Stop right there!"],[4008,4266,"Oh my god, it's Jerry Quinn,"],[4266,4421,"the head of Quinn Court."],[4508,4725,"He's the richest guy in the whole country."],[4954,5105,"It's over now, he wasn't supposed"],[5105,5255,"to come back early."],[5255,5384,"Pull it together, we'll find"],[5384,5480,"the way out of this."],[6085,6243,"Dad, finally back."],[6285,6343,"Dad?"]],"62":[[29,241,"Stop pretending, Enzo, okay?"],[241,479,"We all know that your father"],[479,650,"is just one of Stella's servants."],[671,788,"Shut up."],[930,1076,"Pardon me, did you just say that the"],[1076,1363,"Enzo's father works for Stella's family?"],[1380,1530,"Has she been telling all of you that"],[1530,1651,"she's Quinn?"],[1672,1747,"No, this is all"],[1747,1914,"a misunderstanding, sir."],[1951,2031,"Stella would"],[2031,2143,"never say anything like that!"],[2168,2289,"What the fuck old man?"],[2402,2544,"Leave now or I'll have Stella"],[2544,2665,"fire your ass."],[2886,3028,"Shut up."],[3353,3470,"Kevin,"],[3470,3595,"I’m gone for a couple of days"],[3595,3691,"and you and your daughter try to"],[3691,3803,"take over my estate?"],[3816,3878,"No,"],[3891,3991,"of course not sir."],[4149,4220,"Stella,"],[4333,4412,"what's going on?"],[4512,4625,"Are you not a Quinn?"],[5422,5663,"Playtime is over, Stella."],[5905,6122,"Give up on your little heiress fantasy"],[6122,6235,"before you embarrass yourself"],[6235,6314,"any further."]],"63":[[70,196,"Dad, I've already taken the"],[196,312,"initiative to remove Kevin"],[312,479,"and Stella from our payroll."],[521,613,"But it seems they"],[613,804,"don't understand that I have the"],[804,913,"authority to do so."],[1009,1172,"Kevin, 10 years ago"],[1172,1297,"we showed pity on you."],[1434,1547,"Struggling father trying to"],[1547,1639,"raise his daughter."],[1659,1760,"Is this how you repay us?"],[1901,2035,"We brought you into our home."],[2110,2193,"Feeded your daughter like a"],[2193,2256,"princess."],[2364,2585,"Gave you a great way to move on."],[2610,2744,"And then this is what it comes down to?"],[2815,2911,"The both of you,"],[3011,3107,"ungrateful leeches."],[3165,3324,"Are you really the driver's daughter?"],[4079,4170,"Stop filming!"],[4312,4600,"All of you, put your phones away."],[4617,4746,"This is a private property."],[4746,4967,"You don't have my permission to film,"],[4967,5046,"do you hear me!"],[5046,5113,"Yes!"],[5113,5338,"But this is not your property."],[5397,5518,"Enzo, I give you full"],[5518,5618,"authority to do whatever you"],[5