{"1":[[679,846,"Do you know what it's like to watch"],[846,1055,"someone you love endure constant,"],[1055,1205,"senseless pain?"],[1393,1514,"Of course you don't."],[1580,1764,"You're incapable of empathy."],[2181,2398,"I tried to do it the right way,"],[2473,2585,"but you"],[2585,2727,"made it impossible."],[3007,3082,"And now,"],[3115,3240,"I understand suffering."],[3532,3828,"All I feel is rage in my chest."],[4416,4646,"I live with a hole in my heart,"],[4975,5092,"and soon you will too."],[5296,5405,"This is for you, sis."],[5555,5684,"This is for all of us."]],"2":[[25,175,"Her chemotherapy is supposed to start"],[175,225,"today."],[258,333,"Please, please,"],[333,467,"just check one more time."],[475,563,"I mean, you should calm down."],[563,608,"I will check"],[608,709,"one more time for you, okay?"],[709,759,"Okay."],[788,917,"Your insurance denied her claim."],[963,1038,"Treatment is canceled."],[1388,1443,"Canceled?"],[1472,1497,"But-"],[1851,1897,"So you're telling me"],[1897,1997,"there's nothing we can do?"],[2047,2168,"You want to continue treatment?"],[2264,2373,"Then pay out of pocket."],[3232,3361,"She will die."],[3420,3570,"I've done all that I can."],[3611,3716,"You still got a problem?"],[3757,3837,"You can appeal,"],[3874,4024,"or take it up with the CEO"],[4024,4162,"of your insurance company."],[5221,5355,"I have to appeal,"],[5405,5576,"or Emilia's gonna die."],[5964,6039,"Matteo,"],[6076,6181,"I don't feel-"],[6289,6335,"Oh my God!"]],"3":[[204,342,"I still believed"],[342,517,"someone up there might listen."],[2097,2227,"They denied the appeal?"],[2777,2936,"No, no, I don't want to die."],[2936,3015,"I don't want to die,"],[3015,3090,"Matteo. -It's okay, Emilia."],[3111,3186,"You're okay, you're okay."],[3207,3269,"You'll be okay."],[3269,3303,"No."],[3303,3361,"Someone help!"],[3411,3482,"Someone help!"],[3570,3666,"Doctor, hello?"],[3841,3899,"Please."],[3941,4016,"She's all I have left."],[4016,4108,"Please someone save her!"],[4842,5000,"Your sister's leukemia has spread."],[5055,5155,"And I gave her an emergency"],[5155,5259,"stem cell transplant."],[5296,5363,"But without continuing"],[5363,5447,"the treatment,"],[5505,5609,"she has no chance."],[7699,7832,"I'm done bowing down to these"],[7832,7953,"money-hungry assholes."]],"4":[[100,141,"You're gonna cover"],[141,258,"my sister's treatment or I'll-"],[417,529,"Insurance trouble?"],[775,971,"DB Health is killing my little sister."],[1071,1163,"She's only 9."],[1217,1343,"Evil snakes."],[1380,1555,"My husband's gone because"],[1555,1739,"they denied every last claim."],[1797,1868,"It would've been his"],[1868,2047,"63rd birthday today."],[2214,2360,"They were his favorite..."],[2414,2519,"Now I can't"],[2519,2631,"have one in his honor."],[2631,2811,"Because DB Health wouldn't cover"],[2811,2869,"my tremor"],[2869,2982,"medications anymore."],[3528,3628,"Thank you, young man."],[3716,3849,"Sorry about your sister."],[4033,4162,"I'm sorry about your husband."],[4504,4642,"Those greedy bastards don't care"],[4642,4750,"if any of us live or die"],[4750,4892,"as long as their pockets are lined."],[5021,5146,"Don't let them get you down."],[5176,5317,"We've got to fight back."],[6072,6235,"You know, you owe me from the last bet."],[6252,6310,"What are you talking about?"],[6310,6389,"I thought I paid you."],[6389,6594,"If I could just meet him face-to-face."],[6669,6777,"If I could just tell him."],[6902,7019,"Check your notes there."],[7019,7132,"I'll show you right now."],[7132,7269,"All right, you know the drill."],[7344,7444,"Bet on your horses, boys!"],[7549,7665,"I'll take $100,000 on the"],[7674,7811,"cryptkeeper's wife over there."],[7849,7974,"She won't last a week."],[8024,8141,"I'm gonna get $200,000"],[8141,8249,"on the cancer kid."],[8383,8554,"Those little coffins are so cute."],[8733,8879,"Don't you talk about my sister!"]],"5":[[83,225,"Don't you talk about my sister!"],[279,362,"You asshole!"],[362,500,"You go apologize to her right now!"],[538,596,"Make me."],[696,825,"What do you want, dipshit?"],[825,909,"Mr. Thornwald,"],[909,1021,"your company denied my sister's"],[1021,1105,"leukemia treatment."],[1121,1247,"I want you to do the right thing."],[1247,1343,"Save her life!"],[1355,1438,"You come near me again,"],[1438,1559,"you're gonna be very sorry."],[1609,1764,"It's you who will be sorry."],[3737,3862,"If you won't hear me out,"],[3999,4129,"I'll make you."],[5238,5292,"Hey."],[5417,5501,"Who are you?"],[5622,5759,"Stop, get back here!"],[5822,5993,"Security, catch him!"],[7369,7474,"What the fuck is this?"],[7545,7695,"You underestimated me."]],"6":[[41,171,"You underestimated me."],[300,408,"I'm sorry, who are you?"],[504,592,"The guy whose sister"],[592,734,"you're slowly killing!"],[771,930,"She's only 9 years old!"],[959,1105,"She has her whole life ahead of her!"],[1288,1447,"You want a bottle, cry baby?"],[1547,1680,"You think I give a fuck about some"],[1680,1893,"snotty kid's wasted potential?"],[1918,1989,"It was denied!"],[1989,2060,"So what?"],[2081,2193,"That's business."],[2285,2344,"It's not my fault"],[2344,2419,"you're too broke"],[2419,2560,"to save your sister's life."],[2565,2748,"You heartless son of a-"],[2957,3048,"When the world finds out"],[3048,3153,"what you've done,"],[3153,3224,"to children..."],[3269,3336,"how many people"],[3336,3495,"your business has killed-"],[3495,3561,"They'll what?"],[3749,3899,"Nobody's gonna listen to you."],[4216,4462,"You're not even a pimple on my ass."],[5384,5480,"Randall!"],[5538,5651,"Randall!"],[6210,6339,"Shouldn't have done that."],[6994,7157,"Gallons of blood on your hands,"],[7203,7369,"but soon yours will be on mine."]],"7":[[104,204,"Don't give up, Emilia."],[291,367,"Keep fighting."],[417,521,"I'll find another way."],[1818,1876,"No,"],[1947,2010,"keep this."],[2168,2281,"I'll tell Mama and Daddy"],[2281,2352,"you love them."],[2748,2802,"No."],[2865,2965,"No, Emilia!"],[2986,3040,"No!"],[3073,3153,"Emilia!"],[3386,3445,"Doctor!"],[3461,3536,"Doctors!"],[3661,3753,"Emilia!"],[4371,4575,"I hate how quiet it is without you."],[4646,4775,"You were just a kid."],[4859,5071,"You had a whole life unlived."],[5155,5242,"A future."],[5351,5497,"But they took it from you."],[5622,5734,"They denied you."],[7432,7545,"Almost enough to pay"],[7545,7615,"for the treatment"],[7615,7736,"that would've saved your life."],[7841,7937,"A sick joke."],[8220,8462,"How naive to trust the system."],[8512,8633,"To believe that a rich"],[8633,8767,"health insurance CEO"],[8767,8971,"would actually care about people."],[9234,9346,"It's unjust."],[9434,9597,"I'm done being a pawn."],[10481,10614,"You think you're untouchable."],[10794,10994,"You hide behind your billions"],[10994,11227,"while the rest of us fight for scraps."],[11632,11811,"But all that's gonna change."],[11932,12162,"Because you're not a God."],[12266,12424,"When my bullet hits you,"],[12533,12637,"you'll bleed."]],"8":[[2794,2907,"She'll never get to see"],[2907,3036,"this amazing place."],[4295,4521,"You took everything away from her"],[4521,4679,"and she's not the only one."],[4817,4967,"You'll pay for it all."],[5505,5609,"You have a reservation?"],[5676,5797,"Mario Lanciotti."],[5922,6093,"Why so serious,"],[6106,6193,"Batman?"],[6406,6531,"If only she knew."],[6773,6881,"So,"],[6881,6973,"Mario,"],[7294,7578,"are you here for business or"],[7811,7891,"pleasure?"]],"9":[[408,487,"Off to work,"],[542,638,"off to school,"],[759,884,"just an ordinary day."],[1463,1614,"We should be celebrating."],[2218,2310,"But you're gone."],[2414,2736,"And now everything is about to change."],[5205,5347,"Remember me, Mr. Thornwald?"],[5543,5668,"Out of my way, scum!"],[6210,6339,"You'll never deny"],[6339,6431,"anyone else"],[6431,6556,"ever again."]],"10":[[800,892,"Now, run!"],[3244,3365,"I thought I'd regret it."],[3899,4104,"But this feels like justice."],[4662,4817,"Now time for phase two."],[6026,6085,"Chief,"],[6085,6160,"it's over here."],[6185,6247,"Let's go."],[6769,6852,"Who would murder"],[6852,7044,"the CEO of DB Health?"],[7144,7265,"What happened here, Chief?"],[7499,7670,"Randall Thornwald was"],[7670,7803,"murdered in cold blood."],[7849,7916,"Hey Chief,"],[7932,8012,"check this out."],[8187,8258,"And there's two more."],[8366,8525,"Defend and Depose?"],[8612,8671,"You don't think it's some"],[8671,8800,"whack-job vigilante?"],[9104,9200,"Mere moments ago,"],[9200,9409,"a man now identified as"],[9409,9601,"54-year-old Randall Thornwald,"],[9601,9784,"CEO of DB Health,"],[9784,9914,"has been shot dead"],[9914,10026,"using bullets labeled"],[10026,10260,"Deny, Defend, and Depose."],[10289,10410,"Police are speculating that"],[10410,10602,"the assailant might be a vigilante."],[10865,10990,"Whoever did this,"],[10990,11136,"enjoy your freedom."],[11186,11394,"Because we will hunt you down."],[11444,11578,"And when I catch you,"],[11615,11811,"you'll never see the light of day again."]],"11":[[29,162,"I need to walk free long enough"],[162,300,"to make sure my message is heard,"],[300,396,"loud and clear."],[462,563,"The shooter who unalived"],[563,700,"billionaire Randall Thornwald."],[700,880,"Pop, pop, didn't give a fuck!"],[880,1021,"Legend."],[1455,1609,"I did this so others won't die"],[1609,1714,"like my sister did."],[1830,1985,"But what would she think of me now?"],[2865,2952,"I have to go back."],[3574,3649,"Yes, Mr. Mayor,"],[3649,3782,"I know Randall Thornwald"],[3782,3949,"was a close personal friend."],[3949,4099,"He was a goddamn visionary!"],[4133,4300,"And we're doing everything we can"],[4300,4379,"to catch him."],[4379,4504,"Find the psychopath that murdered him,"],[4504,4650,"or you'll never work again!"],[4688,4875,"Sir, we'll squash this cocky fucker"],[4875,4984,"faster than you can-"],[5084,5196,"I'll call you back, Mr. Mayor."],[5467,5618,"CCTV caught the perp"],[5618,5734,"biking into Central Park."],[5830,5876,"Hit it!"],[6485,6610,"I shouldn't have come back,"],[6623,6710,"but I can't let this go."],[6827,6886,"Over there!"]],"12":[[58,179,"They're faster than I thought."],[367,483,"Search the area,"],[483,567,"I have an email."],[1334,1384,"Where could it-"],[2915,3011,"Could this be a clue?"],[3336,3395,"Lieutenant!"],[3620,3820,"I knew there would be sacrifices."],[3970,4070,"I have to get out of here."],[4400,4491,"This will keep them busy."],[4575,4675,"Let's see how long it"],[4675,4804,"takes them to fix that."],[5009,5134,"Y'all already know my struggle."],[5180,5292,"So when I heard Deny, Defend-"],[5309,5409,"On the bullets?"],[5455,5630,"Like, unaliving is wrong,"],[5630,5793,"but I am on the edge."],[5801,5947,"DB Health is corrupt."],[5989,6122,"And karma's a bitch, hunty."],[6206,6335,"So I'm rooting for Matteo."],[6752,6827,"Excuse me, Officer?"],[6981,7061,"I just found this."]],"13":[[304,383,"Yeah, it was over there."],[487,692,"You contaminated evidence, you idiot!"],[771,825,"My bad."],[825,884,"Hey, Chief."],[996,1092,"We found the backpack."],[1876,1964,"Get the fuck out of here."],[2394,2452,"Give me that."],[3716,3770,"There's a note!"],[4108,4291,"How much paper for a life?"],[4354,4550,"And you keep raising the price."],[4608,4742,"Who gave them"],[4742,4871,"the right to choose?"],[4917,5171,"Time to adjust and pay their dues."],[5384,5526,"Take this to forensics."],[5547,5593,"Got it."],[5726,5851,"The plot is thickening."],[5864,6014,"And I think our vigilante"],[6014,6181,"has just earned his nickname,"],[6202,6314,"The Adjuster!"],[6331,6406,"Let me know what you think"],[6406,6531,"in the comments below."],[7244,7394,"I won't be made a fool of!"]],"14":[[79,179,"Have you seen this man?"],[321,483,"Tell us what you know, dickwad!"],[817,950,"Look, I don't see nothing."],[996,1080,"My, my insurance"],[1080,1188,"wouldn't cover new glasses."],[1188,1351,"So with or without these glasses,"],[1351,1476,"everything is a big blur."],[1584,1714,"Then get out of my face!"],[1868,2118,"This Adjuster will pay with his life."],[2990,3123,"People are rooting for this guy"],[3123,3340,"just shows how sick our society is."],[3361,3403,"Okay,"],[3403,3561,"but the Adjuster can get it done."],[3812,3966,"He's too hot to convict."],[3966,4033,"Some loser"],[4033,4162,"who wanted to be famous."],[4204,4346,"All of this is pointless if they"],[4346,4517,"don't understand why I did it."],[4596,4708,"But they will soon."],[4871,5005,"Claims is inhumane!"],[5025,5221,"Denying claims is inhumane!"],[5242,5447,"Denying claims is inhumane!"],[5467,5663,"Who gave them the right to choose?"],[5676,5885,"Adjust things now, or pay your due!"],[5905,6093,"Who gave them the right to choose?"],[6093,6185,"Adjust things now,"],[6185,6331,"or pay your due! -Holy shit!"],[6331,6385,"Who gave-"]],"15":[[133,291,"This is what I wanted."],[333,479,"The people rising up."],[496,638,"Shouting back at the system"],[638,767,"that tried to silence them."],[767,959,"Who gave them the right to choose?"],[959,1084,"Adjust things now, or-"],[1088,1263,"Denying claims is inhumane!"],[1284,1455,"Denying claims is inhumane!"],[1468,1580,"Denying claims is inhumane!"],[1580,1814,"You should be ashamed of yourself."],[1830,2052,"Harassing people at your age."],[2052,2231,"I'm proud to fight for what's right."],[2231,2339,"For what we all deserve."],[2339,2556,"You're defending a murderer!"],[2660,2831,"Give, give that back."],[2831,2940,"Or what?"],[2940,3157,"Look at you, shaking like a leaf."],[3157,3203,"You're nothing but a weak-"],[3203,3374,"Don't lay a hand on her."],[3516,3636,"How dare you touch me?"],[3636,3778,"Who's touching my wife?"],[3995,4170,"You better apologize, punk."],[4179,4245,"Your wife's the one who"],[4245,4346,"should apologize."],[4366,4437,"She stole something"],[4437,4542,"that doesn't belong to her."],[4567,4742,"You loud-mouthed maggots"],[4763,4996,"are stealing our precious time."],[5005,5084,"Leave"],[5125,5251,"before I make you."],[5276,5367,"Go ahead and try."],[6022,6139,"You shouldn't have done that, Ron."],[6168,6239,"Oh, yeah?"],[6297,6373,"How about this?"]],"16":[[33,216,"Do you realize you just assaulted"],[216,392,"the CEO of Purple Cross?"],[392,546,"I was defending myself."],[546,633,"What you did,"],[671,821,"what you did to my friend Patty here,"],[913,967,"that"],[967,1030,"was assault."],[1030,1113,"Who's gonna believe"],[1113,1259,"some decrepit old woman"],[1280,1430,"and her rat-faced sidekick"],[1455,1622,"over a CEO and his wife?"],[1634,1747,"Everyone here."],[1789,1893,"They all saw what happened."],[1893,2089,"You mean these lazy invalids"],[2106,2323,"who'd rather shout themselves hoarse,"],[2344,2531,"demanding money from us"],[2544,2740,"than work an honest job?"],[2777,2911,"I worked night shift"],[2927,3153,"for 35 years in a warehouse"],[3153,3269,"until the insurance company"],[3269,3420,"denied my back surgery."],[3440,3599,"I was trained to become a pilot"],[3599,3728,"until Purple Cross"],[3728,3891,"denied my insulin prescription."],[3928,4066,"Now I'm blind in one eye,"],[4079,4187,"and had to give up on everything"],[4187,4283,"I worked for."],[4371,4554,"All they want is a chance to live."],[4713,4871,"You're done taking that away."],[4879,4963,"I'm done?"],[5038,5134,"Newsflash,"],[5134,5242,"the one who has the gold"],[5242,5372,"makes the rules, asshole."],[5372,5605,"Aw, did no one tell you?"],[5734,5901,"This protest is pointless."],[5930,6197,"You'll all stay poor and sick,"],[6218,6302,"begging for money,"],[6302,6423,"you're never gonna get."],[6489,6610,"Like diseased hamsters"],[6610,6752,"stuck in a broken wheel."],[6765,6898,"It's how the world works."],[6906,7069,"You can't do it without money."],[7082,7265,"It's always about money."],[7286,7344,"You're right."],[7453,7557,"When money talks,"],[7907,7987,"people listen."]],"17":[[75,246,"Here's Emilia's insurance money."],[312,446,"They need it more than I do."],[533,625,"For your medication."],[792,913,"There's enough here for everyone,"],[938,975,"okay?"],[975,1017,"Hey!"],[1226,1409,"There's over $200,000 in here."],[1430,1568,"Either you stole this,"],[1651,1785,"or you're a drug dealer."],[1814,2006,"Let's go out for a real nice dinner"],[2006,2093,"tonight, honey."],[2168,2348,"Stealing from the sick once again."],[2369,2502,"That's what you greedy CEOs"],[2502,2565,"do best, isn't it?"],[2565,2615,"Stealing?"],[2719,2861,"I bet half these leeching"],[2861,3053,"phlegm buckets owe me money."],[3395,3566,"Pricks like you don't scare me anymore."],[3566,3599,"Yeah?"],[3707,3816,"How about the cops?"],[3899,4008,"They'll get me eventually,"],[4087,4170,"but not today."],[4245,4333,"What makes you think"],[4333,4441,"you're so invincible?"],[4454,4612,"You're a scrawny little nobody."],[4692,4896,"I'm the CEO of a billion-dollar"],[4896,4996,"healthcare company."],[5009,5251,"You have no idea who I am,"],[5338,5459,"and you don't want to find out."],[5730,5885,"Who gave you the right to choose?"],[5930,6110,"Adjust things now, or pay your due!"],[6147,6322,"Who gave you the right to choose?"],[6322,6527,"Adjust things now, or pay your due!"],[6539,6715,"Who gave you the right to choose?"],[6723,6923,"Adjust things now, or pay your due!"],[6948,7119,"Who gave you the right to choose?"],[7119,7319,"Adjust things now, or pay your due!"],[7349,7515,"I'm shutting this down!"],[7624,7745,"We're not going anywhere!"]],"18":[[0,125,"We're not going anywhere!"],[250,404,"Who gave you the right to choose?"],[454,633,"Adjust things now, or pay your due!"],[658,825,"Who gave you the right to choose?"],[838,913,"Adjust things now-"],[913,1038,"Cops aren't gonna be enough."],[1080,1176,"We need the Mayor."],[1330,1409,"Mayor Camden,"],[1434,1568,"there are violent protestors"],[1568,1672,"in front of the DB Health"],[1672,1864,"intimidating pedestrians."],[1893,1968,"Protesters."],[2077,2264,"Those chanting morons are a virus"],[2264,2402,"infecting the minds of our youth."],[2585,2731,"I'll send more officers over."],[2865,2940,"Mr. Mayor,"],[2969,3061,"their leader"],[3061,3174,"is the Adjuster!"],[3349,3428,"I'll be there in five."],[3520,3599,"For you."],[3645,3712,"This is for you."],[3862,3928,"Thank you."],[4124,4170,"And"],[4170,4233,"one more for you."],[4279,4325,"Please."],[4333,4421,"I want you to have it."],[4491,4529,"Take it."],[4662,4758,"It's a miracle."],[4838,4917,"But how?"],[5013,5080,"It's my sister's"],[5080,5184,"life insurance money."],[5276,5380,"She'd want me to help people out"],[5380,5501,"while they still have a fighting chance."],[5722,5839,"Consider it an adjustment."],[5980,6043,"There he is!"],[6097,6197,"The Adjuster!"],[6464,6531,"That's the Mayor,"],[6564,6660,"now you'll be sorry."],[6690,6773,"Mayor Camden,"],[6773,6840,"he's here!"],[7069,7261,"This pathetic guy is the Adjuster?"],[7273,7453,"The calculated terrorist"],[7453,7653,"who murdered my dear friend Randy?"],[7749,7887,"I can't let them take me in yet."],[7928,8033,"My work isn't done."]],"19":[[354,417,"No,"],[487,613,"I am the Adjuster."],[638,692,"No,"],[725,850,"I'm the Adjuster."],[942,1017,"It's me."],[1017,1105,"I'm the Adjuster."],[1130,1251,"No, it's me."],[1251,1380,"I'm the Adjuster."],[1547,1618,"Go!"],[1643,1718,"Now!"],[1780,1864,"Get him!"],[1922,1968,"Let's go!"],[1968,2043,"He's getting away!"],[2077,2122,"Hey."],[2214,2260,"Take this."],[2289,2344,"Get him!"],[2394,2494,"He's getting away."],[2552,2648,"He's over there."],[2727,2773,"My name's Cole."],[2773,2944,"Don't let him go, don't let him go!"],[2944,3015,"Come on."],[3144,3549,"Denying claims is inhumane!"],[3599,3653,"There!"],[3737,3795,"There!"],[3883,3928,"Get him!"],[4091,4170,"Get him, get him, get him!"],[4187,4233,"Get him, get him!"],[4250,4287,"Get him!"],[4404,4600,"Not so clever after all."],[5851,5901,"Hey, man."],[6464,6493,"Hey,"],[6523,6581,"you cold?"],[6660,6740,"Could use a jacket?"],[7082,7152,"I got you."],[7328,7432,"God bless you."],[8033,8120,"Take care of it, man."],[8158,8229,"Stay safe."]],"20":[[12,229,"26-year-old, Matteo Leone"],[229,333,"has been identified"],[333,483,"as the CEO's shooter."],[483,721,"A $10,000 reward is being offered"],[746,825,"for any info"],[825,988,"that comes into our office."],[988,1113,"My name is out there now,"],[1134,1276,"but I won't hide for much longer."],[3691,3874,"I wish someone didn't have to die"],[3874,3987,"to make them listen."],[4104,4287,"I wish I could hear my sister's laugh"],[4287,4429,"just one more time."],[4521,4717,"But life isn't fair."],[5109,5184,"Do you need some help?"],[5292,5367,"Do you mind?"],[5409,5497,"I, I don't mind."],[5497,5659,"I have to put her on these walks"],[5659,5743,"so she can sleep"],[5743,5847,"and then when she's asleep,"],[5847,5993,"I can never lift this up."],[6302,6377,"Have a good night."],[6377,6443,"Bye."],[6564,6710,"The healthcare system has"],[6710,6848,"failed the people,"],[6873,7061,"and it needs to be taken down."],[8149,8333,"This won't bring Emilia back,"],[8696,8929,"but it will save millions."]],"21":[[850,992,"I'm not a monster."],[1042,1255,"Accountability is part of the plan."],[2035,2110,"Have a good one!"],[2293,2473,"And I'm almost ready to take it."],[5726,5860,"I can't run forever."],[6085,6373,"One last thing to check off the list."]],"22":[[241,392,"Let me get a"],[392,617,"McCrazy with Oreos, please."],[617,684,"It's fire."],[796,859,"Can I have a bite?"],[988,1034,"What?"],[1067,1138,"You want a bite?"],[1138,1188,"Yeah."],[1322,1522,"If you pay for your own, I guess, sure."],[1593,1672,"Maybe I'll get it, sure."],[1672,1747,"Can I get two, then?"],[2164,2289,"And you can keep the change."],[2314,2348,"Thank you."],[2523,2677,"No fucking way!"],[3069,3119,"Hey."],[3249,3386,"I got the guy you're looking for."],[3449,3624,"My time as a free man is ending."],[3732,3795,"But"],[3795,3933,"are any of us really free?"],[4704,4825,"Come on, come on, come on."],[4863,4979,"Come on, come on, come on-"],[4979,5188,"Well, well, well."],[5288,5434,"Matteo Leone."],[5447,5505,"Please,"],[5513,5638,"don't do anything stupid."],[5843,5976,"Is there a problem, officers?"],[6389,6502,"You little shit!"],[6527,6598,"Chief,"],[6677,6756,"it's all here."],[7057,7207,"You're under arrest, motherfucker."],[7862,8012,"You have the right to remain silent."],[8049,8170,"Go ahead and arrest me."],[8249,8391,"The people are about to wake up."]],"23":[[50,150,"No way."],[225,325,"If you're reading this,"],[354,504,"I am in police custody."],[554,663,"I won't stop fighting,"],[663,788,"but I can't do it alone."],[867,959,"Will you join me?"],[1480,1735,"Matteo Leone is a cold blooded killer"],[1735,1918,"who brutally murdered CEO"],[1918,2006,"Randall Thornwald."],[2035,2114,"For his crimes,"],[2127,2214,"we are seeking"],[2214,2314,"the death penalty."],[2444,2527,"How do you plead?"],[2619,2806,"They have it all wrong."],[2890,2986,"Not guilty."],[3503,3574,"Answer me,"],[3574,3762,"you shit-eating cockroach."],[4054,4208,"Or should I pull the teeth out"],[4208,4421,"from your pretty little smile?"],[4562,4637,"Don't you realize"],[4637,4792,"you're gonna get the death penalty?"],[4792,4859,"Don't you realize"],[4859,5038,"nobody's free until everybody's free?"],[5513,5605,"Let him go, Chief."],[5701,5776,"Let him go."],[6068,6202,"Can't let this sad-sack"],[6202,6306,"have all the fun."],[6861,6994,"You think you're a hero?"],[7102,7219,"You are a terrorist."],[7307,7432,"And I won't rest"],[7457,7607,"until you're on death row."],[7728,7803,"And you're afraid of me"],[7803,7982,"because you can't stop what I started."],[8137,8308,"You're losing control, Mayor Camden."],[8337,8416,"Oh, is that what you think?"],[8500,8596,"We'll see what the streets"],[8596,8696,"have to say, huh?"],[8742,8796,"Get him out of here."],[9446,9538,"After you, gentlemen."]],"24":[[1042,1146,"Hang in there, Matteo!"],[1146,1259,"We're all on your side!"],[1259,1351,"We're fighting for you!"],[1714,1818,"You're going down."],[2268,2373,"Great use of resources, guys."],[2373,2460,"No talking."],[2531,2660,"The system is designed"],[2660,2852,"to annihilate scum like you."],[3086,3186,"Burn in hell,"],[3203,3345,"you filthy criminal."],[3361,3503,"You'll fry in that chair!"],[3536,3682,"You scared of me, Mr. CEO?"],[3682,3737,"Scared?"],[3770,3887,"Where's your money now?"],[3899,4004,"Your empty threats?"],[4020,4070,"You think you're"],[4070,4208,"some sort of superhero?"],[4233,4412,"You're shit on the bottom of a shoe."],[4412,4575,"A fly about to be swatted."],[4583,4688,"Easy for you to say."],[4746,4829,"Surrounded by cops"],[4829,4963,"in your bulletproof vests."],[4988,5046,"Cowards,"],[5167,5234,"all of you."],[5242,5372,"I could rip you apart!"],[5993,6143,"You're nothing but a filthy criminal."],[6297,6385,"Powerless."],[6418,6523,"Stupid."],[6573,6664,"Pathetic."],[6706,6769,"You're no one-"],[6823,6886,"Back off!"],[6927,7044,"Let the court decide!"],[7077,7269,"Innocent until proven guilty!"],[7286,7482,"Innocent until proven guilty!"],[7490,7707,"Innocent until proven guilty!"],[7707,7857,"Innocent until proven guilty!"],[7857,7999,"That's completely unjust."],[8020,8091,"It's an insult to the"],[8091,8241,"intelligence of the American people,"],[8266,8408,"and their lived experience!"]],"25":[[12,175,"It's an insult to the American people"],[175,316,"and their lived experience!"],[333,450,"They can yell all they want,"],[450,550,"but they can't keep you"],[550,688,"from rotting in jail."],[717,767,"Come on."],[905,963,"Hear me!"],[1084,1197,"See you in court."],[1276,1835,"Innocent until proven guilty!"],[2097,2285,"No one can protect you in here."],[2565,2765,"Let's see how long you last."],[3228,3319,"Maybe I deserve everything"],[3319,3420,"that's coming to me."],[3732,3887,"What are you in here for, princess?"],[3941,4058,"What's your name, boy?"],[4233,4358,"Better start answering me, son,"],[4358,4533,"before I fuck you up, boy."],[4575,4704,"I'm gonna fuck you up so bad,"],[4704,4838,"they ain't gonna be able to recognize you"],[4838,4959,"when I'm fucking through."],[4959,5188,"Now what's your fucking name, boy?"]],"26":[[58,141,"Matteo"],[191,283,"Leone."],[650,742,"Oh, shit,"],[821,930,"you're the Adjuster."],[1522,1576,"Dixon."],[1643,1735,"You see, the brothers in here,"],[1735,1826,"they all gonna test you,"],[1826,1951,"and they gonna fuck with you."],[2010,2164,"But they gotta get through us first."],[2239,2352,"Now my man Terrence over here"],[2352,2481,"is gonna get you cleaned up."],[2527,2598,"Yo, T,"],[2598,2690,"clean this man up."],[2777,2857,"Take a seat, bro."],[3720,3849,"The denial letter came"],[3870,4008,"a week after we buried her."],[4250,4396,"I'm so sorry that happened."],[4429,4521,"And what you did"],[4533,4675,"made a lot of guys in here"],[4700,4817,"feel a lot better."],[4896,4929,"Just"],[5038,5150,"feel less hopeless."],[5484,5588,"There's no going back."],[5747,5864,"I'll fight to the death."]],"27":[[246,312,"Janet here,"],[312,417,"but the man of the hour"],[417,525,"hasn't shown yet."],[525,629,"If you didn't know,"],[629,775,"today is the first day"],[775,930,"of the trial of the century."],[942,1192,"The United States vs. Matteo Leone,"],[1192,1309,"also known as"],[1309,1401,"The Adjuster."],[1493,1701,"You saw the wanted posters!"],[1718,1997,"Corrupt CEOs' time is running out."],[1997,2135,"You crusty plebeians"],[2135,2331,"could never get past security."],[2331,2394,"Oh, yeah?"],[2394,2498,"You sure about that?"],[2540,2681,"It's called survival of the fittest."],[2873,3028,"The vibes are giving,"],[3028,3153,"pressure cooker."]],"28":[[633,779,"The people are waking up."],[913,1055,"Enjoy it while it lasts."],[1088,1209,"Our case is airtight."],[1251,1338,"After this,"],[1380,1526,"nothing but prison and death for a"],[1526,1689,"sadistic monster like you."],[1743,1839,"We'll see about that."],[1997,2139,"Talk to my client again,"],[2160,2293,"and I'll have you disbarred."],[2335,2444,"I'll see you in court."],[2444,2506,"Alright."],[4975,5042,"Ladies and Gentlemen"],[5042,5109,"of the Jury,"],[5150,5301,"Matteo Leone"],[5321,5547,"viciously targeted Randall Thornwald."],[5613,5818,"Rather than grieve with dignity"],[5818,5989,"when his sister died of cancer,"],[5989,6168,"he cruelly premeditated"],[6168,6385,"the murder of a loving family man,"],[6435,6556,"a successful,"],[6556,6823,"visionary CEO worth billions."],[6835,6940,"Who purposely"],[6940,7132,"profited off of people's pain."],[7403,7574,"These witnesses will paint a picture"],[7611,7770,"of just how dangerous"],[7770,7924,"Matteo Leone is."]],"29":[[0,158,"He could have saved his sister,"],[229,383,"but he was too broke to pay."],[400,517,"He had motive."],[533,679,"He was aggressive from the start."],[734,800,"He's a bully!"],[875,980,"He pushed me,"],[1017,1167,"and threatened my husband."],[1167,1326,"He wanted them to suffer."],[1413,1534,"That's not true."],[1534,1701,"He thought he was so smart"],[1701,1864,"with all his messages."],[1864,2052,"Mr. Leone is entitled,"],[2081,2181,"manipulative,"],[2193,2293,"and frankly,"],[2364,2531,"psychotic."],[2752,2877,"Thank you, Mayor Camden."],[3023,3207,"For my final witness, I call"],[3207,3324,"Brady Thornwald,"],[3386,3516,"Randall Thornwald's son."],[4859,4925,"Brady,"],[5030,5263,"how has the death of your father,"],[5263,5409,"your hero,"],[5505,5597,"affected you?"],[5655,5843,"Will this kid be the nail in my coffin?"]],"30":[[350,583,"My father's not my hero."],[996,1101,"You mean-"],[1138,1217,"I mean,"],[1247,1476,"I was incredibly devastated"],[1601,1822,"when that cold-blooded"],[1851,1931,"killer"],[1968,2202,"took my father's"],[2277,2427,"life away from me."],[2652,2765,"You know what, fuck that."],[2790,2961,"My dad enjoyed hurting people."],[2998,3274,"His entire vision as CEO"],[3274,3470,"was built on keeping people sick."],[3470,3528,"And I'm not just"],[3528,3641,"gonna sit here and lie"],[3641,3782,"because some company paid me to."],[3782,4029,"You disrespect your own father,"],[4029,4225,"after everything he did for you?"],[4225,4350,"You know what, lock me up."],[4350,4425,"I, I don't care."],[4425,4525,"Objection!"],[4542,4625,"He can't just-"],[4625,4717,"Sit down!"],[4717,4763,"You're nothing,"],[4763,4825,"lower than"],[4825,4896,"sewage sludge!"],[4896,5005,"Mr. Mayor,"],[5005,5080,"first"],[5080,5217,"you treat him like some kind of"],[5230,5334,"zoo event-"],[5409,5467,"Order!"]],"31":[[16,116,"Mayor Camden,"],[116,225,"one more word"],[246,425,"and you'll be held in contempt."],[492,563,"Yeah, yeah, yeah."],[600,738,"No further questions."],[913,1046,"Based on the evidence"],[1084,1146,"provided,"],[1284,1463,"Matteo Leone undoubtedly is"],[1463,1664,"guilty of murder in the first degree."],[1768,1914,"Prosecution rests."],[2089,2168,"Ms. Weinhardt?"],[2510,2623,"Judge O'Shine,"],[2652,2773,"People of the Jury,"],[2861,3078,"as the prosecution detailed,"],[3086,3190,"my client"],[3190,3311,"Matteo Leone"],[3319,3611,"shot and killed the CEO of DB Health,"],[3791,3903,"Randall Thornwald,"],[3924,3987,"dead."],[4512,4642,"Someone had to do it."]],"32":[[33,91,"That's right."],[91,183,"My client"],[183,421,"does not deny killing Mr. Thornwald."],[437,558,"What he does deny,"],[583,704,"it was unwarranted."],[796,888,"Mr. Leone"],[888,1063,"had to act drastically"],[1063,1180,"to save lives."],[1197,1476,"And today, we're here to defend his right,"],[1484,1601,"so he can defend"],[1626,1789,"himself and others"],[1797,1914,"from becoming victims"],[1914,2089,"of a murderous corporation."],[2873,2965,"Order!"],[3078,3261,"I call Patty Sinclair to the stand."],[4579,4642,"Please,"],[4642,4729,"tell us what happened"],[4729,4808,"to your husband."]],"33":[[79,308,"Clay and I, we had just found out that"],[367,533,"we were gonna be grandparents."],[600,713,"Then one night,"],[942,1071,"Clay had a heart attack."],[1230,1430,"A doctor prescribed a treatment plan,"],[1430,1580,"but DB Health said no,"],[1580,1760,"not medically necessary."],[1760,1818,"It would cost"],[1818,1926,"hundreds of thousands"],[1926,2014,"out of pocket,"],[2035,2173,"so we appealed,"],[2173,2243,"but"],[2281,2448,"all of our claims were denied."],[2506,2635,"I was denied a walking boot"],[2635,2773,"for my fractured ankle."],[2806,2965,"It got so bad they had to amputate"],[2965,3028,"but they couldn't"],[3028,3215,"because they don't make prosthetics."],[3215,3411,"I got addicted to pain medication,"],[3449,3549,"but denied"],[3549,3728,"the surgery to cure my pain for good."],[3728,3849,"We went bankrupt,"],[3891,4008,"and now we're homeless."],[4008,4108,"Couldn't afford it,"],[4216,4316,"so he died."],[4316,4425,"Appealed,"],[4458,4650,"but now she's paralyzed."]],"34":[[54,141,"If DB Health"],[141,350,"had approved my husband's surgery"],[358,483,"he would still be alive."],[567,663,"This young man,"],[700,754,"Matteo,"],[754,834,"saw how"],[880,975,"so many of us"],[975,1117,"were being taken advantage of"],[1117,1313,"by DB Health's predatory"],[1363,1459,"business."],[1539,1722,"And he did what no one else"],[1722,1830,"had the courage"],[1843,1951,"or actually,"],[1964,2056,"the balls"],[2072,2147,"to do."],[2189,2285,"He stood up."],[2635,2702,"Thank you."],[2773,2836,"Thank you."],[2836,2994,"I couldn't have said it any better."],[3069,3140,"Thank you."],[3265,3353,"Your Honor,"],[3353,3432,"I call"],[3432,3674,"Mr. Matteo Leone to the stand."],[4850,4996,"This isn't a circus!"],[5034,5150,"Order in the court."],[5609,5730,"Do you swear to tell the truth,"],[5739,5855,"and nothing but the truth?"],[6297,6402,"If you swear to listen."]],"35":[[229,342,"I swear to tell the truth."],[700,813,"Mr. Leone,"],[875,980,"what drove you"],[980,1192,"to kill the CEO of DB Health?"],[1897,1964,"Your honor,"],[1985,2110,"it'll be better if I show you."],[2160,2281,"Objection!"],[2281,2410,"This is new evidence not validated-"],[2410,2523,"Sit down, Counselor."],[2706,2769,"Go ahead."],[3532,3624,"Thanks for being here."],[3716,3870,"While I still have a voice,"],[3924,4037,"I want to tell you why."]],"36":[[158,250,"This is Emilia,"],[358,487,"my 9-year-old sister."],[675,784,"She was just a baby"],[784,909,"when our parents died."],[992,1088,"And it's been the two of us"],[1088,1242,"against the world ever since."],[1347,1426,"The doctor said"],[1426,1539,"she could beat Leukemia,"],[1539,1701,"if she started treatment right away."],[1835,2081,"But DB Health wouldn't cover it."],[2131,2256,"Even with a decent job,"],[2256,2464,"I couldn't afford to pay out of pocket."],[2510,2619,"So I appealed."],[2640,2752,"I was optimistic."],[2819,2994,"I didn't know that there are almost"],[2994,3228,"200,000 health insurance-related"],[3228,3361,"deaths per year."],[3403,3582,"As we waited for a response,"],[3632,3824,"I watched my amazing little sister"],[3824,3920,"get sicker."],[4087,4312,"And then DB Health denied her appeal."],[4529,4788,"I did everything I could to fight back."],[4892,5138,"I even pleaded with the CEO himself"],[5167,5259,"to save her life."],[5476,5630,"He told me it was nothing personal,"],[5747,5860,"it's just the business"],[5860,6018,"of keeping people sick."],[6322,6423,"Then he smiled."],[6752,6873,"Emilia died."],[7027,7215,"And I found out our story is"],[7278,7340,"very,"],[7432,7520,"very common."]],"37":[[62,150,"I'm talking"],[183,358,"mass corruption leading to"],[358,588,"massive amounts of lives ruined."],[621,679,"Hundreds of"],[679,825,"thousands of lives ruined!"],[921,1109,"All to fill their pockets!"],[1230,1368,"But we're bigger than them!"],[1463,1593,"Alright, we're bigger than them"],[1614,1789,"if we stand up together!"],[1881,1997,"Who's with me?"],[2081,2323,"Denying claims is inhumane!"],[2344,2590,"Denying claims is inhumane!"],[2610,2894,"Denying claims is inhumane!"],[2998,3161,"The defense rests!"]],"38":[[212,333,"Nothing more to do but wait."],[504,638,"After thorough consideration,"],[675,850,"Purple Cross Health will discontinue"],[850,1042,"our limited anesthesia policy."],[1084,1217,"Our company will end its"],[1217,1334,"wait and see policy"],[1334,1476,"beginning at the first of the month."],[1543,1630,"We will be halting our"],[1630,1751,"lottery policy effectively."],[1760,1893,"Whatever happens today,"],[1976,2056,"you did this."],[2744,2969,"We the jury find Matteo Leone..."],[3103,3174,"Dear Tracy,"],[3244,3361,"your letter made me tear up."],[3395,3511,"I am so sorry"],[3511,3582,"you and your daughter"],[3582,3770,"had to go through such senseless pain."],[3795,3912,"No one should have to experience"],[3912,4049,"that kind of systemic failure."],[4079,4254,"You are an inspiration."],[4254,4396,"And your daughter's lucky to have"],[4396,4542,"a mother who didn't back down."],[4579,4662,"All my best,"],[4692,4779,"Matteo Leone."],[5851,6001,"Death or life in prison?"],[6122,6260,"At least I said my piece."]]}