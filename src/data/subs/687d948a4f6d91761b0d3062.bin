{"1":[[1852,1996,"#What are you doing here?#"],[2180,2404,"I'm sorry. I have no choice."],[3076,3324,"—Hey! Stop! —I can't."],[3832,3984,"Are you out of your mind?"],[3984,4256,"No... I beg you. Help me. Help me. I beg you."],[4304,4456,"I'm being forced into a blind marriage!"],[4572,4620,"Please!"]],"2":[[256,544,"No... No... Help! Help me!"],[768,996,"Please! Please! He wants to take me away."],[1212,1388,"No, Diana, he doesn't."],[1460,1640,"How do you know my name?"],[1688,1880,"Because I'm the one who's taking you."],[1880,2028,"He's just the best man."],[2068,2380,"So, it's you I'm supposed to marry?"],[2380,2648,"You got into the wrong car, Diana."],[2648,2760,"I'll never—"],[2760,2892,"I'll never be yours."],[2892,3040,"I'll never be yours!"],[3040,3220,"She seems really headstrong."],[3416,3608,"I know how to change your mind."],[4442,4622,"Hands off! Hands off!"],[4776,4892,"Don't touch me!"],[4940,5140,"I won't lay a finger on you."],[5280,5464,"Then why did you bring me to your bedroom?"],[5464,5584,"This is your bedroom."],[5584,5772,"You'll live here, separate from me."],[5820,5932,"No... No..."]],"3":[[160,480,"No matter where you run, I will always find you."],[884,1001,"Change your clothes."],[1001,1188,"I'll be waiting in the living room."],[1948,2066,"I was caught in the trap"],[2066,2340,"of a cruel and powerful beast..."],[2456,2760,"not knowing what game he was playing."],[3176,3432,"Mom? Mom, please save me."],[3492,3592,"I can't."],[3712,3804,"What?"],[3860,3960,"Mom..."],[4108,4208,"After the wedding,"],[4208,4379,"your family business and mine"],[4379,4469,"will become one."],[4512,4632,"Everyone wins."],[4796,5060,"Did you hear him? Everything's gonna be fine."],[5060,5204,"You have to sign it yourself..."],[5288,5560,"so that another wedding doesn't fall apart like today."],[5560,5704,"No... No!"],[5704,5828,"Don't be a child, Diana."],[5920,6040,"Think about the family."],[6040,6272,"Like you thought of me? I'm not the only one"],[6272,6480,"who wasted all our money after Dad died."],[7208,7320,"Sign it..."],[7370,7536,"or never call me Mother again."],[9452,9552,"Mom..."],[9600,9784,"Mom, I'm so sorry!"]],"4":[[1072,1288,"After all this, are we supposed to pretend"],[1288,1464,"to have a warm family dinner?"],[1464,1640,"We are not a family."],[1796,1980,"And I don't want you here"],[1980,2244,"when I have breakfast, lunch, or dinner."],[2392,2538,"No wonder you can't find a bride"],[2538,2692,"like normal people."],[2692,2964,"You're impossible to love. You're a haughty monster."],[3444,3864,"And you are a spoiled, bankrupt princess."],[4528,4777,"Enjoy your meal, honey."]],"5":[[84,184,"Where are you going?"],[300,428,"Where are you going?"],[832,980,"We are not done talking!"],[980,1224,"You are forbidden from entering this room."],[1224,1456,"What? Another restriction?"],[1456,1740,"Yes. Go to your room now."],[1740,1916,"I don't wanna see you near this door."],[1980,2180,"I don't wanna see you either. Ever!"],[2608,2788,"What is he hiding in there?"],[2852,2952,"Maybe..."],[3008,3120,"just maybe..."],[3204,3452,"his secrets were the key to my freedom."],[3720,3891,"This house was cold and foreign,"],[3891,4001,"just like its owner."],[4256,4504,"The days spent all alone were killing me."],[4748,4924,"I felt like a ghost..."],[5104,5448,"forced to wander a castle where no one could see me."],[5708,5820,"Why did he choose me?"],[6100,6212,"Just to ignore me?"]],"6":[[4848,4948,"Please."],[6064,6160,"And who are you?"],[6300,6397,"Diana."],[6432,6592,"The fiancée of the house owner."],[6592,6692,"And you?"],[6776,7070,"Well, I'm the former owner. His father."]],"7":[[8,136,"He never mentioned you..."],[136,480,"My son is a monster. He left me here"],[480,696,"as if he's waiting for me to die."],[836,1032,"My God, I'm so sorry..."],[1059,1379,"No, I'm sorry for you, young lady."],[1379,1508,"You have no idea"],[1508,1633,"what you've gotten yourself into."],[1633,1892,"Run! If you can still run."],[2280,2564,"If he could be so cruel to his own father..."],[2612,2764,"what would he do to me?"],[3592,3684,"Dinner is ready."],[3776,3896,"What is he up to?"],[3996,4081,"You said you didn't want"],[4081,4156,"to eat with me."],[4268,4460,"I still don't. It's all for you."],[5292,5384,"Do you like it?"],[5676,5876,"What kind of stupid joke is this?"]],"8":[[108,436,"Go ahead. Take whatever you want."],[436,740,"Thanks, but I'm on a diet."],[1112,1265,"Don't you like diamonds?"],[1280,1427,"Then what do you like?"],[1427,1612,"Tell me everything about you."],[1612,1724,"You avoid me,"],[1724,2000,"but now you suddenly need to know everything?"],[2124,2216,"Are you bipolar?"],[2324,2464,"I said talk."],[2536,2624,"Maybe you should explain"],[2624,2855,"why you abandoned your sick father to die."],[2856,3089,"I told you not to go into that room!"],[3089,3208,"Don't I have a right to know..."],[3256,3368,"who I'm marrying?"],[3368,3624,"—You drive me crazy! —You drive me mad."],[4140,4339,"Here. Entertain yourself."],[4339,4527,"Tomorrow, the driver will take you out."],[4527,4669,"Buy yourself a gift."],[5224,5472,"He was an impenetrable fortress."],[5528,5669,"But at that moment..."],[5712,5958,"I had a plan on how to conquer him."],[6604,6756,"Camilla, I'm hungry!"],[7060,7144,"Dinner is ready."],[7216,7660,"Diana. Did you buy yourself a nice little trinket?"],[7716,7816,"Yeah."],[7928,8028,"For you."],[8154,8404,"I noticed you wear an old, simple watch."],[8512,8632,"Strange for a millionaire."],[9700,9788,"Return it."],[9812,9928,"You were supposed"],[9928,10109,"to buy something for yourself."],[10120,10220,"No."],[10304,10488,"If you want me to have something..."],[10596,10812,"then buy it for me yourself."],[10812,11072,"That's what couples do."]],"9":[[148,356,"We are not a couple."],[460,652,"Start behaving like the fiancée"],[652,740,"of a millionaire."],[926,1067,"That was the last straw."],[1103,1214,"He wanted to change me?"],[1288,1359,"Fine."],[1394,1606,"Now, we would play by my rules."],[3972,4128,"What the hell is this?"],[4240,4404,"It's my birthday, Will."],[4404,4636,"And if you actually cared, you'd know that."],[4744,4888,"—Wait. —Don't touch me."],[5018,5128,"I'm just trying to act like"],[5128,5280,"a millionaire's fiancée."],[5280,5408,"Isn't that what you wanted?"],[5576,5676,"Then watch."]],"10":[[112,440,"What does he see in her? Just a pretty face."],[580,730,"I heard her family paid off"],[730,869,"their debts with her."],[900,1041,"—Really? —Yeah."],[1041,1148,"I don't believe it."],[1220,1428,"She literally screams \"worthless\"."],[1628,1828,"I think she heard us. Let's go."],[2464,2712,"I was at a ball full of monsters."],[2800,2952,"And the worst one..."],[3008,3160,"was my fiancé."],[3216,3352,"I had a choice..."],[3400,3540,"Run from humiliation."],[3648,3788,"Or strike back."],[4856,4956,"Can you help me?"],[5700,5800,"Tighter."],[6204,6288,"What are you doing?"],[6288,6437,"Isn't this what you wanted?"],[6509,6650,"Don't play innocent."],[6824,6968,"Let's have some fun."],[6968,7080,"Let me go."]],"11":[[0,108,"Did he pay for you?"],[108,208,"I can double it."],[632,906,"You bunch of parasites."],[906,1006,"Get lost."],[1025,1144,"The party's over."],[3312,3412,"Thank you."],[3796,4084,"I'm so sorry. I did it on purpose."],[4188,4340,"I wanted to make you angry."],[4500,4612,"You succeeded."],[4940,5164,"When I was a child, my father..."],[5210,5355,"would always bring me cocoa"],[5355,5500,"when I was upset."],[5684,5812,"My mother did the same."],[5972,6064,"You smiled..."],[6220,6320,"for the first time..."],[6452,6564,"and mentioned your mother."],[7384,7682,"This belonged to my mother."],[7812,8060,"Amethyst is a protective stone."],[8300,8440,"Happy birthday, Diana."]],"12":[[256,432,"It will protect you when I'm not around."],[648,816,"But you'll always be around, right?"],[928,1112,"You're my future husband."],[1696,1832,"No, please don't leave me."],[2052,2152,"Not now."],[2780,2880,"Dance with me."],[3372,3608,"He remained cold, like a mountain."],[3692,3812,"But tonight..."],[3868,4200,"I realized he was my mountain."],[4404,4700,"My shield against every storm."],[5106,5178,"Will?"],[5392,5512,"Why did you choose me?"],[5716,5860,"I didn't choose you."],[6008,6280,"Of course. I'm worthless."],[6352,6646,"No. You're priceless."],[6980,7092,"I don't believe you."]],"13":[[452,589,"I shouldn't have done that."],[701,760,"I'm sorry."],[916,1016,"What was that?"],[1072,1217,"He lifts me to the heavens"],[1217,1389,"where my heart touches the sky..."],[1484,1600,"then..."],[1600,1794,"shoves me back into the abyss."],[2784,2896,"I brought you coffee."],[2914,3037,"And I wanted to talk."],[3124,3312,"I don't drink coffee."],[3648,3872,"Don't come near my room again."],[3952,4384,"What? This one too?"],[4440,4514,"Yes."],[4598,4705,"And this time,"],[4705,4896,"you will regret it if you disobey me."]],"14":[[0,120,"I wasn't afraid of him..."],[176,383,"but I was afraid of being left in the dark"],[383,509,"about his secrets."],[604,928,"I could no longer live surrounded by mysteries."],[1492,1740,"The beauty visits the old man again."],[1900,2096,"What's your plan, young lady?"],[2784,2884,"Thank you."],[2984,3216,"I just want to talk about your son."],[3400,3598,"He keeps hiding things from me."],[3655,3788,"What's his secret?"]],"15":[[0,339,"Well, the fact is, he is..."],[364,493,"in a way..."],[603,888,"Well, a punishment."],[888,1089,"He's my punishment."],[1244,1436,"My greatest sin."],[1600,1960,"A secret that is killing me."],[2084,2228,"What are you talking about?"],[2275,2387,"Well..."],[2416,2680,"My son is a mirror of my youth."],[2772,3004,"Tall, brown eyes..."],[3208,3392,"No, no. Your son has blue eyes."],[3392,3545,"No, dear."],[3598,3889,"You don't even know who you are marrying."],[3948,4030,"And...."]],"16":[[48,312,"And suddenly, I realized..."],[464,548,"Wait."],[548,830,"There were no photos of Will in this house."],[875,979,"Who was he?"],[980,1165,"I have something to tell you."],[3408,3544,"It's a different person..."]],"17":[[28,244,"My fiancé wasn't in any of the photos."],[320,474,"I didn't even know"],[474,672,"who I was getting married to."],[1212,1412,"So, you didn't listen to me after all..."],[1440,1551,"Tell me!"],[1575,1743,"Tell me who the hell you are!"],[1796,1908,"It doesn't matter."],[1971,2084,"He's already here."],[2322,2385,"Who?"],[2756,2916,"Sorry for the theatrics, darling."],[3016,3304,"I'm Carl, your real fiancé."]],"18":[[368,456,"Him?"],[720,872,"Just my servant."],[1112,1283,"He was supposed to protect you."],[1572,1732,"After all this, are we supposed to pretend"],[1732,1932,"to have a warm family dinner?"],[1988,2204,"We are not a family."],[2204,2484,"I noticed you wear an old, simple watch."],[2484,2620,"Strange for a millionaire."],[2808,2968,"If you want me to have something..."],[3016,3208,"then buy it for me yourself."],[3208,3380,"That's what couples do."],[3500,3732,"We are not a couple."],[3780,3900,"Why did you choose me?"],[4280,4380,"I didn't choose you."],[4548,4700,"It was all a lie..."],[4700,4956,"right when I finally started to believe"],[4956,5120,"that we could be together..."],[5148,5330,"that I could actually be happy..."],[5380,5480,"with him."],[5576,5964,"And then, the truth ruined everything."],[6060,6236,"How could I have believed him?"],[6308,6523,"How could I have been so blind?"],[6620,6819,"I was doomed from the start."],[6884,7167,"So, this was all about money?"]],"19":[[16,400,"—No, Diana. I can explain. —No need for explanations."],[450,578,"Just leave me."],[616,1014,"Leave me with my new fiancé."],[1348,1406,"Come on."],[1772,2020,"I fell in love with the man who'd just betrayed me."],[2132,2264,"But I had no idea..."],[2349,2550,"that the secrets of this family..."],[2642,2904,"would be my ticket to hell."],[3148,3676,"I will make your life a paradise."]],"20":[[1260,1396,"Am I finally perfect?"],[1444,1592,"You're now my perfect bride."],[1684,1812,"Which one?"],[1884,2036,"—Honey? —The wedding's off."],[2300,2550,"No, you can't run away from me."],[2550,2622,"Well."],[2648,2829,"Then I'll kiss one of your servants."],[2869,2921,"What?"],[4185,4255,"Ma'am?"],[4548,4756,"Everything's ready for the wedding, dummy."],[4756,4948,"There's nothing you can do about it."],[4948,5100,"I wouldn't be so sure about that."]],"21":[[257,407,"Have you lost your mind?"],[407,570,"If you can cheat on me with a servant,"],[570,681,"then I can too!"],[681,778,"You filthy—"],[924,1092,"What the hell do you think you're doing?"],[1092,1185,"You're going to ruin"],[1185,1358,"your beautiful bride's makeup."],[1404,1592,"Give me 15 minutes, and she will be ready"],[1592,1756,"to walk down the aisle to you."],[2020,2168,"That's my servant."],[2197,2444,"Because everything here belongs to me."],[2540,2640,"Including you."],[2728,2896,"Just give me 15 minutes."],[3084,3184,"Fine."],[3228,3380,"I'm gonna put on my tuxedo."],[3380,3483,"Get her dressed."],[3496,3639,"We still have a wedding photoshoot"],[3639,3698,"to do."]],"22":[[124,296,"Stop! Don't you understand?"],[296,469,"It's impossible to escape from here."],[469,650,"You're a good dog of your master."],[658,1040,"But I'm not going to listen to you!"],[1480,1640,"You're a monster. Just like him."],[1868,2100,"I will prove to you that you're mistaken."],[2324,2621,"I know it seems like the biggest idiotic mistake..."],[2631,2901,"to trust someone who serves a monster."],[2940,3293,"And yet a part of me wanted to believe him."],[3368,3517,"And you think I'll trust you?"],[3824,3949,"Undoubtedly."],[3949,4108,"Because I'm in love with you, ma'am."]],"23":[[0,126,"Do you think only you can kiss me"],[126,234,"without permission?"],[336,456,"I'm confused."],[479,588,"What's going on?"],[588,762,"I can't explain everything now."],[779,1016,"Especially because I have to abduct you."],[1676,1788,"Why are we here?"],[1836,1956,"Because this is the only place"],[1956,2180,"where Carl refuses to stick his nose in."],[2699,2809,"What are you doing?"],[2819,2980,"This is everything I've earned..."],[3008,3185,"during my years working for Carl."],[3185,3320,"Now, it's yours."],[3320,3474,"But why?"],[3485,3609,"It's too late for me."],[3660,3800,"This money should be enough for you"],[3800,3940,"to start a new life."],[3944,4216,"Don't you understand there's no escape"],[4216,4368,"from this mansion?"],[4368,4488,"There is one way."],[4488,4694,"But you have to put on the wedding dress."],[4735,4843,"Are you kidding me?"],[4853,5145,"You still want to marry me off to him?"],[5145,5288,"Listen to me carefully."],[5288,5472,"This is your only chance."],[5472,5713,"Your salvation lies in Carl's hands."],[5748,5861,"Remember that."],[6528,6744,"Will, where's my bride?"],[6836,7056,"Sir, she—"],[7104,7188,"I'm here."]],"24":[[0,224,"Sorry about this morning, darling."],[296,480,"I got a bit too nervous about the wedding."],[480,756,"It seems I've tamed not only the finest stallion..."],[864,1024,"but also the best bride."],[1144,1300,"Will, call the photographer."],[1504,1899,"Your trophy would look even better"],[1899,2004,"on your stallion."],[4426,4504,"Damn!"],[4550,4744,"How does she know how to ride a horse?"],[5054,5190,"Good thing at least someone here"],[5190,5276,"obeys me."],[5368,5480,"She won't escape."]],"25":[[428,588,"If that witch survives..."],[636,756,"take her back to the house."],[1152,1252,"Diana..."],[1604,1704,"Diana!"],[2452,2564,"So?"],[2564,2756,"When is the wedding finally starting?"],[2756,2852,"I don't know."],[2928,3080,"Maybe it won't happen at all."],[3142,3248,"Let me guess."],[3248,3588,"Maybe the girl couldn't bear the thought"],[3588,3968,"of spending her life with you and ran away."],[3968,4050,"Shut up!"],[4074,4269,"That silly girl is entirely to blame."],[4269,4594,"And who's to blame for you being a monster?"]],"26":[[240,376,"If I were a monster..."],[448,629,"you'd have been dying out on the street"],[629,732,"a long time ago."],[804,1068,"—Not in my house. —This is my house!"],[1224,1699,"As long as I'm alive, I own your assets!"],[2168,2359,"If you want to live here 'til the end,"],[2424,2600,"you'd better not anger me."],[2672,2944,"Just as always, our saintly Will."],[3136,3256,"Do you have to save everyone?"],[3348,3513,"The doctor has examined Diana."],[3540,3652,"She wants to talk to you."]],"27":[[924,984,"Well..."],[984,1152,"When will she be able to get married?"],[1276,1368,"After such a fall,"],[1368,1548,"she might never be able to stand again."],[1576,1693,"Damn witch!"],[1699,1852,"The wedding has to happen now!"],[1852,2087,"I'll only be able to examine her again"],[2087,2202,"in a few days."],[2416,2490,"Sir,"],[2490,2636,"we need to cancel the wedding."],[2684,2948,"Nah. That's not gonna happen."],[2976,3087,"You witch—"],[3087,3245,"whether you're in a wheelchair"],[3245,3368,"or crawling—"],[3414,3598,"you'll be with me at the altar."],[3712,3829,"Understand, darling?"],[3852,4064,"Sir, I beg you. Please…"]],"28":[[0,316,"—Don't do this. —Do you feel sorry for her?"],[380,580,"As a servant, you should know best…"],[680,952,"Bad things get tossed out."],[952,1148,"She's not a thing…"],[1272,1475,"I don't need another cripple in my house."],[1537,1631,"Take care of her."],[3020,3164,"I heard everything."],[3164,3460,"Diana, I'll get you out of here."],[3491,3642,"Just say yes."],[3788,3884,"No."]],"29":[[0,128,"I'm going to marry Carl."],[128,285,"He will destroy you."],[304,580,"At least I'll save my family from bankruptcy."],[592,723,"Think about yourself."],[723,828,"I don't care anymore."],[966,1118,"No one needs someone like me."],[1156,1304,"I need you."],[1508,1653,"He was telling the truth."],[1676,1924,"His feelings for me were real,"],[1980,2183,"painful, and broken."],[2204,2356,"Just like I now was."],[2420,2561,"And he had no idea..."],[2612,2860,"that it would destroy him too."],[3980,4260,"The days became a kaleidoscope of pain."],[4340,4542,"Every time I lost faith,"],[4600,4720,"he was right there."],[5016,5100,"Leave me alone."],[5258,5447,"No, I'm not going anywhere."]],"30":[[42,151,"He saved me,"],[211,316,"yet in doing so,"],[316,499,"he was destroying his own life..."],[560,824,"bound to me as I was bound to this bed."],[888,1216,"I had to do something to set him free."],[1972,2156,"Thank you for taking such good care of me."],[2204,2370,"It's the least I can do for you."],[2480,2580,"Please forgive me."],[2800,2933,"Don't blame yourself."],[3006,3118,"You're not at fault."],[3264,3456,"I once dreamed of dancing"],[3456,3808,"on the world's finest ocean beach"],[3808,3948,"until dawn."],[4212,4628,"Now, that dream feels lost."],[4892,5188,"Close your eyes and count to 100."]],"31":[[3148,3348,"My heart was wild with love..."],[3484,3788,"yet I knew that this dance..."],[3880,3980,"would be our last..."],[4164,4332,"and Will had no idea."],[5046,5201,"I love you, Diana."],[5216,5355,"Against all odds,"],[5386,5651,"I'll fulfill every one of your wishes."],[5824,5908,"Carl!"],[6060,6160,"Carl!"],[6336,6448,"Did you hear everything?"]],"32":[[48,148,"You see, Carl?"],[148,528,"Your so-called loyal servant isn't so loyal. Like I told you."],[724,838,"You jerk."],[838,932,"Did you really believe"],[932,1244,"that a pathetic loser like you could take my place?"],[1300,1412,"She's mine!"],[1660,1840,"She will never be yours."],[1992,2116,"What are you doing?"],[2116,2352,"You must forget about me! Forever!"],[2800,3140,"At that moment, I betrayed the one I loved..."],[3232,3472,"and destroyed us both."]],"33":[[608,784,"Oh my God, who is this?"],[932,1140,"—Sir? —Shall we have some fun?"],[1140,1340,"—No, please... —Right on these sheets."],[1390,1624,"You can wear one of my wife's dresses."],[1624,1836,"She has no need for them, but they would suit you."],[1884,2128,"Sir, her dresses will never fit me again."],[2316,2426,"How much?"],[2524,2666,"How much will it take"],[2666,2876,"for you to rid yourself of this trouble?"],[2912,3112,"Sir, I don't wanna do this. Please..."],[3144,3349,"I will never acknowledge this child!"],[3368,3476,"Get outta my house!"],[3476,3615,"No, please... I need this job..."],[3615,3728,"I need this for survival."],[3728,3889,"Well, I no longer need you!"],[4088,4518,"Carl, you can't really do this."],[4628,4798,"Have you forgotten how you used to"],[4798,5012,"fool around with the maid when you were young?"],[5050,5204,"I'm sick of all of you."],[5240,5326,"After the wedding,"],[5326,5524,"I'll get rid of the bride and you."]],"34":[[964,1232,"They are very beautiful. Thank you."],[1232,1508,"Why did you bury yourself?"],[2096,2412,"Diana, I know there is strength within you"],[2412,2533,"to get back on your feet."],[2533,2609,"What?"],[2675,2931,"To walk down the aisle to your son, that monster?"],[2931,3020,"No."],[3054,3340,"To walk towards the one you truly love."],[3360,3664,"It's impossible. Nothing can change."],[3664,4056,"My secret will change... everyone's fate."],[4204,4336,"What are you talking about?"],[4336,4500,"I will tell you everything"],[4500,4696,"once you get on your feet again."],[4744,4856,"But what if I can't?"],[4856,4970,"Sunshine..."],[4970,5455,"But what else is worth fighting for, if not love?"],[5790,6060,"All I could do was believe that I had a chance."]],"35":[[136,266,"And from that day on,"],[321,614,"I repeated Philip's words to myself."],[708,933,"Standing on your own two feet"],[945,1269,"is the only way to reclaim love."],[1320,1696,"Every day, I fought against myself."],[2132,2232,"You smiled..."],[2336,2484,"for the first time..."],[4350,4472,"Will."],[4536,4664,"Why did you choose me?"],[4712,4828,"I didn't choose you."],[4966,5238,"Of course. I'm worthless."],[5248,5548,"No. You're priceless."],[6164,6356,"No one needs someone like me."],[6438,6548,"I need you."],[7732,7926,"Now, we have something to celebrate."],[7926,7987,"Yeah."],[8048,8301,"Don't run away. I'll be right back."],[8632,8724,"I did it."],[8752,8930,"In that moment, I wished that"],[8930,9108,"Will was there with me..."],[9165,9237,"But..."],[9260,9611,"Every step filled me with the hope"],[9611,9776,"of bringing him back."],[10456,10746,"Thank you, Father, for the surprise."]],"36":[[28,260,"It looks like we need to start preparing for the wedding."],[316,546,"Now, you'll do what we agreed on."],[546,748,"You'll bring Will back home."],[828,1024,"And I'll conduct your wedding."],[1024,1124,"Fine. You've got it."],[1178,1401,"But I don't want to delay any longer."],[1401,1592,"The wedding will be tomorrow."],[1864,1941,"You lied to me!"],[1941,2178,"Sunshine, I have never lied to you."],[2198,2416,"Now, just put on your dress."],[2456,2614,"And don't mix them up."],[2648,2721,"What?"],[3580,3914,"It's time now for you to learn my secrets."],[4502,4582,"What?"]],"37":[[1536,1920,"Does the groom agree to become the lawful husband?"],[2012,2380,"Does the bride agree to become the lawful wife?"],[3854,3965,"Okay..."],[3990,4239,"Now, you can kiss each other."],[5060,5348,"What the hell? That's the maid!"]],"38":[[0,128,"What have you done?"],[150,324,"You just married a woman…"],[388,576,"who is pregnant with your child."],[640,852,"And this marriage won't last long."],[1360,1552,"When she divorces you,"],[1552,1784,"she'll take every crumb you have left."],[1868,1980,"As for me…"],[2064,2296,"I'm depriving you of everything."],[2296,2588,"You can't do this! I'm your only child!"],[2644,2912,"I can. And you're badly mistaken here."],[2950,3183,"Once, I made the same mistake."],[3183,3517,"I abandoned the maid who carried my child."],[3527,3912,"All my life, I've been regretting that sin."],[3965,4321,"Will, I'm so sorry."],[4348,4590,"The past cannot be changed."],[4590,4878,"But I can change something right now."],[4878,5016,"What are you talking about?"],[5016,5208,"You are my son."]],"39":[[0,480,"And now, all my assets and this house… are yours."],[906,1116,"As for you, it's all over."],[1116,1256,"It's not over!"],[1275,1399,"Where's my Diana?"],[1840,2184,"I have never been… and will never be yours."],[3554,3656,"I love you."],[3786,3900,"I love you more."],[3972,4150,"Hey, lovebirds."],[4150,4354,"Am I standing here for nothing?"],[4792,4960,"You may kiss each other."]],"40":[[600,728,"Love..."],[728,1016,"Sometimes it throws us into the harshest of trials."],[1820,1968,"What are you doing here?"],[2063,2208,"And you can't believe it,"],[2208,2340,"but the one you now love"],[2340,2488,"with every beat of your heart..."],[2536,2737,"once felt like your greatest enemy..."],[2752,3000,"You got into the wrong car, Diana."],[3000,3100,"I'll never—"],[3100,3216,"I'll never be yours."],[3344,3557,"...once seemed like a stranger,"],[3585,3832,"so distant, so cold."],[3832,4120,"You're impossible to love. You're a haughty monster."],[4192,4616,"And you are a spoiled, bankrupt princess."],[4748,5052,"But from the very start, there was something."],[5136,5236,"A spark."],[5300,5420,"Deep down, you knew..."],[5484,5756,"somehow, someday... you'd end up together."],[6116,6304,"Because love does test us."],[6332,6498,"You're a good dog of your master."],[6525,6898,"But I'm not going to listen to you!"],[7108,7280,"Oh yes, it does."],[7424,7536,"But only to make sure..."],[7600,7817,"the two souls are meant to be..."],[7817,8028,"to become one forever."]]}