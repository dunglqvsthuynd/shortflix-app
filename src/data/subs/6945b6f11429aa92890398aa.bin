{"1":[[20,266,"It's our third month trying for a baby,"],[296,383,"and tonight is also"],[383,513,"our third year anniversary."],[746,1001,"Three is my lucky number, I can feel it."],[1042,1142,"Maybe tonight's the night"],[1142,1276,"it finally happens."],[1351,1501,"He'll love my new set."],[2948,3036,"Candice?"],[3115,3311,"Evan's secretary?"],[3820,4158,"Is he...cheating on me?"],[4254,4466,"Honey, I'm all cleaned up."],[4517,4738,"Should we do it on the bed,"],[4825,4913,"or the couch?"],[5659,5751,"How about I choose?"],[5926,6081,"Let's do it on the bed."],[6644,6694,"Hey."],[6861,6923,"What's wrong?"],[7082,7140,"Evan..."],[7444,7557,"explain yourself."]],"2":[[12,229,"I have no idea what's going on,"],[271,342,"I swear."],[784,971,"Mr. Sumner, what can I do for you?"],[980,1130,"You realize you just violated"],[1130,1276,"company policy, right?"],[1305,1418,"That photo you sent"],[1426,1630,"was extremely inappropriate!"],[1664,1760,"Sir, what?"],[1856,1972,"Oh my goodness,"],[1972,2164,"Mr. Sumner, I'm so sorry."],[2164,2352,"I meant to send that to my boyfriend."],[2414,2565,"I figured it was just a mistake,"],[2594,2711,"but if it happens again,"],[2731,2923,"you can kiss your job goodbye!"],[3445,3549,"Your secretary"],[3549,3682,"seems pretty careless."],[4087,4175,"I'm sorry, baby."],[4291,4483,"If you're still upset,"],[4575,4683,"I'll fire her tomorrow."],[4738,4817,"Now,"],[4921,4988,"where were we?"],[5584,5647,"Come on,"],[5705,5839,"I've been away on business"],[5839,5914,"for a week."],[6118,6214,"I need you, Nina."],[6435,6623,"You would never betray me,"],[6723,6840,"would you, Evan?"],[8266,8324,"Evan?"],[12854,13054,"I'm fucking your husband."]],"3":[[179,404,"I never thought Evan would betray me."],[1051,1176,"They finally said yes,"],[1247,1380,"and nothing will touch us now."],[1459,1576,"I'll be by your side"],[1576,1730,"for the rest of your life."],[1764,1835,"No lies,"],[1889,1968,"no betrayal."],[2014,2177,"He once stood against his