,3732,"He can't keep doing - Don't, don't."],[3732,3787,"this to you."],[3787,3845,"Don't."],[4120,4212,"They're not worth it."],[4287,4416,"They're not worth my tears."]],"22":[[467,646,"Evan, please."],[775,934,"Your tears mean nothing to me."],[984,1109,"If you won't get rid of it,"],[1117,1167,"I'll make sure"],[1167,1297,"you don't carry it to term, hm?"],[1338,1505,"That baby will not live."],[1589,1843,"Please, don't say that."],[1889,2031,"I care about you."],[2164,2306,"I love you."],[2748,2852,"What's your love worth?"],[2940,2998,"What?"],[3807,3949,"$300,000."],[4054,4225,"Take it and get an abortion."],[4375,4458,"Otherwise,"],[4466,4683,"I will personally drag you to a hospital"],[4692,4859,"and carve that baby out."],[5084,5163,"Your choice."],[6181,6243,"What do you want?"],[6277,6335,"Nothing."],[6381,6519,"I just wanted to hear your voice."],[6589,6648,"Are you eating?"],[6886,6961,"If there's nothing else,"],[6961,7007,"I'm hanging up."],[7007,7073,"Oh, okay."],[7165,7290,"I won't work late tonight."],[7336,7520,"So, let's eat dinner together"],[7520,7590,"when I get home."],[8204,8291,"At least she answered."],[8387,8475,"Without Candice,"],[8475,8596,"Nina and I can go back"],[8596,8712,"to the way we were."]],"23":[[95,246,"He is such a scumbag."],[291,346,"Calling you"],[346,492,"while having lunch with his mistress?"],[513,579,"Forget him."],[642,704,"The only thing"],[704,800,"I care about right now"],[800,950,"is getting that job at Park Pharma."],[1026,1155,"Speaking of Park Pharma,"],[1226,1384,"would it be weird working for his uncle"],[1384,1488,"if you divorce Evan?"],[1651,1797,"Even if I join Park Pharma,"],[1797,1951,"I'll just be a regular pharmacist."],[2060,2185,"It's not like he'd notice me."],[2348,2394,"Besides,"],[2394,2460,"Evan and his uncle"],[2460,2594,"aren't close anyway, so."],[2690,2840,"If they aren't close,"],[2898,3019,"do you think his uncle could help"],[3019,3090,"with the divorce?"],[3236,3365,"They're both still Sumners."],[3453,3578,"Do you really think he'd help me?"],[4387,4650,"8pm? Nina should be home by now."],[5943,6018,"Where have you been?"],[6164,6256,"I went job hunting."],[6435,6569,"With which companies?"],[6673,6731,"If you want,"],[6731,6881,"I can call and put in a good word."],[6881,7148,"I don't, I don't want you involved."],[7332,7440,"This is my business."],[7457,7682,"Nina, please let me help."],[7728,7841,"Let me do something"],[7857,7999,"to make up for my mistakes."]],"24":[[25,125,"I hate roses."],[296,392,"You used to love them."],[608,700,"I love you, Nina."],[1130,1209,"I promise"],[1217,1388,"my love will be like these roses,"],[1472,1580,"the everlasting kind."],[1776,1918,"Key word, used to."],[2002,2143,"Now they only remind me of,"],[2218,2298,"your betrayal."],[2406,2489,"I'm going to sleep."],[2631,2769,"Nina, wait."],[3078,3148,"Are you gonna stay"],[3148,3269,"this cold to me forever?"],[3307,3403,"We're supposed to spend"],[3403,3536,"the rest of our lives together."],[3536,3682,"If I were the one who cheated,"],[3720,3878,"would you forgive me so easily?"],[4208,4425,"If you cheated on me, I..."],[4696,4796,"I don't know what I'd do."],[5188,5351,"Fine, I'll give you some time."],[5488,5559,"I'm leaving"],[5618,5759,"on a two-week business trip."],[5851,6051,"That should give you plenty of time"],[6064,6164,"to get over this."],[6348,6535,"I'll be reclaiming"],[6606,6902,"our bedroom and you"],[7082,7173,"when I get back."],[8395,8646,"Thank God, I got the job!"]],"25":[[667,871,"Mr. Sumner, it's Clarice."],[925,1063,"I think your wife is leaving."],[2189,2285,"I didn't give you permission"],[2285,2356,"to move out."],[2473,2656,"I can't believe you'd stoop low enough"],[2656,2806,"to have me spied on."],[2873,2990,"But it doesn't matter."],[3011,3098,"I'm a free woman."],[3098,3161,"I'm leaving."],[3232,3470,"Remember, if you leave me, Nina,"],[3524,3607,"I'll terminate"],[3620,3753,"your father's medical care."],[3807,3924,"He'll die without it."],[3928,4099,"His blood will be on your hands!"],[4646,4792,"You really think"],[4804,4942,"you could hold that over me?"],[5017,5242,"Newsflash, I have a job now."],[5280,5472,"From now on, I pave my own path."],[5492,5726,"Oh, and don't test me,"],[5747,5855,"unless you want the world"],[5868,6031,"to find out about your little affair."],[8020,8074,"Get in."]],"26":[[33,79,"Get in."],[91,216,"It's okay, Uncle Damon."],[216,346,"The rain will stop soon."],[367,450,"Get in the car,"],[504,579,"unless you want everyone"],[579,667,"to see your bra."],[2235,2298,"Thank you."],[2360,2656,"He smells so good,"],[2715,2831,"just like that night."],[3194,3249,"Wait,"],[3286,3390,"snap out of it."],[3390,3549,"Stop thinking about that night!"],[4412,4704,"Evan actually got her pregnant."],[4704,4754,"What,"],[4783,4875,"what does that make me?"],[4875,4950,"A joke?"],[5080,5159,"Is everything okay?"],[5313,5392,"Why did you move out?"],[5555,5638,"Everything's fine."],[5726,5926,"It's just that I got the job,"],[5926,6018,"and, and living here"],[6018,6231,"is closer to the company."],[6669,6856,"Sir, ma'am, we've arrived."],[7165,7303,"Thank you for the jacket."],[7303,7357,"I'll return it"],[7357,7457,"once I get it dry-cleaned."],[7478,7540,"There's no..."],[7603,7703,"That'll give me a reason"],[7703,7791,"to see her again."],[8008,8091,"There's no rush."],[8174,8245,"Take your time."],[8837,8963,"What's with the newfound interest"],[8963,9092,"in your nephew's wife, boss?"],[9192,9263,"Don't know yet."],[9413,9446,"I want you"],[9446,9613,"to look into their relationship for me."],[9697,9734,"I wanna know"],[9734,9813,"what's really going on"],[9813,9918,"in that marriage of theirs."]],"27":[[29,137,"Good morning, everyone."],[225,316,"I'd like you all to meet"],[321,458,"our new lead pharmacist,"],[483,563,"Nina Jayston."],[629,704,"Great."],[725,913,"As if dealing with Lucia isn't enough,"],[913,1076,"her lackey Mabel is here too."],[1146,1238,"Lead pharmacist?"],[1355,1522,"Someone's sleeping with the right people."],[1555,1743,"Nepotism at its finest."],[2252,2435,"It's great to see you both too."],[2477,2585,"Let's hit the ground running."],[2623,2761,"Half of this lab's focus is on"],[2761,2927,"cardiovascular drug development,"],[2927,3107,"so let's prep for mouse trials."],[3165,3228,"Well, it looks like"],[3228,3294,"you've got everything"],[3294,3424,"under control here, Nina."],[3478,3607,"I'll let you guys get back to work."],[4124,4191,"Don't worry."],[4279,4329,"We'll make sure"],[4329,4441,"she doesn't last the week."],[5530,5701,"I canceled my trip to see you."],[5751,5814,"I miss you."],[5910,5989,"Come home with me."],[6010,6118,"This is my home."],[6168,6206,"Leave."],[6206,6314,"I don't wanna see you here."],[6523,6660,"I won't leave you."],[6735,6819,"You're my wife."],[6894,7090,"Wherever you are, I'll be there."],[7511,7636,"Nina, it's your father."],[7661,7682,"He,"],[7720,7836,"he suddenly collapsed."],[7870,7970,"Please come to the hospital."],[8066,8124,"I'm coming."]],"28":[[137,337,"Nina, Evan, so glad you're here."],[362,529,"Harrison's in emergency surgery."],[538,600,"What happened?"],[600,804,"I just spoke to him yesterday evening!"],[838,959,"He collapsed suddenly,"],[959,1117,"he started coughing up blood."],[1222,1484,"Oh no, please don't let him die!"],[1676,1818,"Harrison is stable,"],[1981,2114,"but he'll need a kidney transplant"],[2114,2173,"in two months."],[2173,2344,"For the meantime, make sure he rests"],[2398,2544,"and absolutely experiences"],[2544,2619,"no stress."],[3061,3232,"Sweetheart, you're here."],[3261,3395,"Of course I am, Daddy."],[3457,3591,"Don't scare me like that."],[3712,3862,"Don't worry about me, sweetie."],[3953,4033,"I'll be fine."],[4387,4625,"You focus on your own little family"],[4658,4729,"with Evan."],[4813,4925,"I can't tell Dad"],[4925,5075,"about my failing marriage yet."],[5109,5246,"Not when he's like this."],[5342,5484,"Don't worry, Dad,"],[5526,5630,"I'll take good care of her."]],"29":[[262,421,"Thank you for today,"],[458,729,"but I don't need you to come with me"],[729,834,"to the hospital again."],[913,1076,"And I'm tired of you"],[1076,1276,"going on and on about divorce."],[1280,1443,"I said it is not an option."],[1472,1622,"You've tested my limits long enough."],[1680,1889,"Now, I'm gonna teach you a lesson."],[2431,2485,"What are you"],[2485,2531,"doing? - Come on!"],[3019,3207,"Since you won't come to your senses,"],[3224,3432,"I'm locking you in here until you do."],[3574,3670,"You're not going anywhere."],[3678,3774,"Then I hope you nailed"],[3774,3874,"the window shut,"],[3891,4045,"because you can't keep me in here."],[4333,4433,"The problem is,"],[4529,4604,"I spoiled you."],[4721,4975,"I let you get away with too much,"],[5121,5313,"which is why you think"],[5313,5447,"leaving me is an option"],[5480,5655,"when it is not!"],[6143,6297,"You really want me to hate you,"],[6297,6360,"don't you?"],[6406,6560,"I'd rather you hate me than nothing."],[6981,7040,"Stop."],[7094,7152,"Stop."],[7265,7344,"Mr. Sumner,"],[7349,7478,"your Uncle Damon is here."]],"30":[[37,204,"What's my uncle doing here?"],[262,396,"He's never visited before."],[467,550,"Wait here for me."],[1826,2010,"This is the only way."],[2160,2235,"Uncle Damon."],[2652,2794,"What a surprise."],[2915,3015,"What do I owe the pleasure?"],[3169,3278,"What's going on between you"],[3278,3440,"and the secretary of yours?"],[3532,3582,"What?"],[3632,3728,"Cut the bullshit."],[3799,3924,"Okay, I know she's pregnant,"],[3966,4074,"and I won't tolerate"],[4074,4237,"any tarnish of the Sumner name."],[4266,4408,"You know I hate cheaters."],[4437,4504,"Uncle Damon,"],[4542,4708,"I promise I will handle it."],[4725,4867,"Please don't tell Grandpa and Dad."],[4871,5000,"It's your wife you should be begging"],[5000,5071,"for forgiveness,"],[5071,5121,"not me."],[6181,6281,"Treat her better,"],[6306,6452,"or suffer the consequences."],[7340,7390,"Mom?"],[7440,7649,"Evan, come to my place right now."],[7670,7745,"Don't bring Nina."],[7753,7916,"Your pregnant secretary, Candice,"],[7920,8041,"is here with me."],[8358,8462,"Spencer, what's wrong with you?"],[8462,8683,"Sir, you need to see this for yourself."],[9255,9317,"Please,"],[9430,9496,"save me."]],"31":[[16,79,"Please,"],[196,266,"save me."],[855,971,"What the hell is she doing in here?"],[1009,1172,"Sir, she came to me so upset."],[1222,1276,"I didn't have the heart"],[1276,1351,"to turn her away."],[1422,1484,"Dammit."],[1647,1735,"This is getting messy."],[1843,1964,"Drive, now."],[1993,2068,"You got it, boss."],[2364,2494,"Nina, what happened to you?"],[2510,2556,"You look like"],[2556,2677,"you've been through hell and back."],[3816,4045,"I...have been."],[4116,4320,"Evan locked me in our bedroom."],[4425,4533,"I jumped out of a window"],[4533,4604,"to escape him."],[4604,4813,"I, I saw your car and I had no choice."],[4863,5100,"She's so delicate, so helpless,"],[5188,5409,"so beautiful, even now."],[5442,5643,"You're the only person"],[5643,5797,"who could protect me from Evan."],[6035,6281,"Thank you for helping me."],[6393,6456,"Careful,"],[6577,6715,"my help comes at a price."]],"32":[[104,162,"Careful,"],[296,421,"my help comes at a price."],[663,717,"What,"],[813,900,"what are you saying?"],[900,1038,"I'm not that kind of woman."],[1368,1480,"What kind of woman are you?"],[2118,2235,"Spencer, why are we stopping?"],[2831,2907,"Oh shoot..."],[2907,3053,"Please, don't let him take me."]],"33":[[663,721,"What do you want, Evan?"],[721,809,"I have somewhere to be."],[1017,1063,"Sorry,"],[1126,1180,"seems like"],[1180,1347,"I'm interrupting something."],[1434,1526,"I've heard rumors"],[1526,1685,"that Uncle Damon likes to walk"],[1685,1847,"on the wild side with his women."],[1956,2256,"Wait, she looks familiar."],[2352,2419,"Well, is there something"],[2419,2477,"you need?"],[2740,2786,"Look,"],[2836,2915,"I just want to make sure"],[2915,3023,"you and I are good."],[3094,3190,"I'll do as you ask"],[3203,3436,"and fix things with my wife."],[3516,3586,"She's innocent,"],[3653,3774,"didn't deserve what I did to her."],[3849,3995,"As long as you behave with dignity"],[3995,4058,"from here on out,"],[4058,4120,"we'll be fine."],[4175,4233,"That's all."],[4295,4375,"Goodbye, Uncle."],[5034,5088,"Thank you,"],[5176,5238,"Uncle Damon,"],[5238,5447,"for helping me."],[6089,6206,"Oh my God, I'm,"],[6214,6381,"oh my God, I'm, I’m so sorry."],[6381,6431,"I..."],[6631,6827,"Did you just fall on my lap on purpose?"],[6848,6994,"To get back at your husband"],[7061,7148,"through his uncle?"]],"34":[[20,91,"You're trying to get back"],[91,158,"at your husband"],[158,237,"through his uncle?"],[296,471,"No, that's not what I was trying to do."],[471,513,"I-"],[517,571,"Good."],[688,792,"Because if it was,"],[888,971,"you'd regret it."],[1105,1184,"Regret it?"],[1234,1305,"Really?"],[1368,1493,"Are you serious?"],[1597,1726,"I'm the one who was betrayed,"],[1726,1893,"yet somehow I'm the villain here?"],[1956,2118,"You Sumner men have a real talent"],[2118,2248,"for turning things around, don't you?"],[2481,2531,"Hey."],[2815,2877,"What?"],[2890,3061,"Don't lump me in with your husband,"],[3061,3253,"I would never sink down to his level."],[3290,3390,"If you were my wife,"],[3390,3578,"I would not let you walk away from this."],[3645,3787,"Why is he even saying that,"],[3799,4066,"like it's about me?"]],"35":[[87,141,"I'm"],[308,404,"sorry, Uncle Damon."],[404,521,"I wasn't trying anything."],[521,617,"It won't happen again."],[771,825,"Good."],[2223,2298,"That's the last time"],[2298,2410,"I come to your rescue."],[2444,2623,"Keep me out of your marriage drama."],[2665,2806,"It's like he hates me."],[3265,3386,"Sir, may I speak freely?"],[3570,3632,"Why do you treat her"],[3632,3699,"like you don't care"],[3699,3828,"when it's so clear that you do?"],[3945,4020,"I want her."],[4066,4250,"She's the one woman I can't have."],[5330,5463,"Spencer, you talk too much."],[5960,6122,"But if she's so unhappy with Evan,"],[6181,6293,"why can't I have her?"]],"36":[[12,141,"She's already pregnant"],[141,250,"with my grandchild."],[271,483,"I'm ready to accept her into the family."],[667,838,"Mother, do you hear yourself?"],[884,1013,"That child is a bastard!"],[1051,1105,"Yeah,"],[1134,1267,"and whose fault is that?"],[1326,1505,"Evan, please."],[1564,1718,"Don't treat me this way."],[1755,2077,"I love you and I love our unborn child."],[2168,2369,"If Nina can't give you a baby,"],[2427,2544,"then let me."],[2769,2923,"You're just a mistress."],[2990,3086,"What right do you have"],[3094,3278,"to compare yourself to her, hm?"],[3399,3449,"Evan,"],[3570,3699,"when we were together,"],[3753,4029,"did you love me, even a little?"],[4245,4308,"Do you know any man"],[4308,4400,"who falls for a whore?"],[4400,4504,"Okay, that's enough!"],[4621,4804,"I just want a grandchild."],[4838,5009,"I don't care who's its mother."],[5075,5284,"And if you dare take her away today,"],[5305,5459,"I am going to die"],[5492,5601,"right here in front of you."],[6068,6156,"What is it, Clarice?"],[6206,6285,"Mr. Sumner,"],[6310,6381,"Nina is gone."],[6427,6544,"Security footage showed her"],[6544,6719,"getting into your Uncle Damon's car."],[6898,7094,"Was that Nina?"],[7515,7678,"Evan, is everything okay?"],[7899,8041,"Evan, come back!"]],"37":[[133,354,"This jacket smells so nice."],[404,625,"Feels like a nice, warm blanket."],[1101,1167,"That day,"],[1222,1288,"l can't believe"],[1288,1388,"he did this for me."],[1463,1593,"He saved me from Evan."],[1664,1701,"I..."],[1789,1985,"can't stop thinking about him."],[3361,3570,"You hate me, don't you?"],[3628,3703,"That's why you're always"],[3703,3778,"so cold to me."],[4024,4141,"Does it feel like I hate you?"],[4537,4629,"Just because you're hard"],[4629,4742,"doesn't mean you like me."],[5926,5972,"Fine."],[6106,6185,"You want me to show you"],[6185,6264,"how much I like you?"],[6439,6506,"I'm gonna fuck you"],[6506,6602,"right here in this car."]],"38":[[1576,1634,"Damon,"],[1726,1885,"I want you to come inside of me."],[2352,2402,"Nina!"],[2427,2477,"You're mine,"],[2477,2598,"how could you be with my uncle?"],[2627,2798,"Nina, come out right now!"],[3174,3228,"Nina,"],[3299,3415,"come out right now!"],[3636,3749,"Evan is outside?"],[3812,3958,"I can't let him know I'm home."],[4241,4329,"Is she not home?"],[4362,4471,"Where could she be?"],[4596,4692,"With my uncle?"],[5109,5205,"Find out where Nina works"],[5205,5347,"and investigate her movements."],[5405,5501,"I need to know if she's involved"],[5501,5597,"with Damon Sumner."]],"39":[[283,379,"Watch this."],[412,475,"We're gonna prove"],[475,658,"it was a mistake to hire her."],[2043,2089,"Damon?"],[2089,2256,"I, I mean, Mr. Sumner."],[2277,2364,"What are you doing here?"],[2410,2585,"Mr. Ross, our top investor,"],[2610,2727,"wanted to check out the lab."],[2748,2865,"Thought I'd show him our best"],[2865,3028,"and brightest hard at work."],[3094,3311,"Mr. Ross, this is our lead pharmacist,"],[3378,3453,"Nina Jayston."],[3495,3570,"Mrs. Jayston,"],[3628,3749,"it's a pleasure to finally meet you."],[3812,3912,"What's this you're working on?"],[3966,4162,"Oh, uh, I was just about to neutralize"],[4162,4275,"this sodium bicarbonate"],[4275,4466,"with a sulfuric acid and get started"],[4466,4562,"creating a compound."],[4704,4750,"Well,"],[4808,4863,"carry on."],[4875,4938,"Of course."],[5184,5372,"This is gonna be good."]],"40":[[871,1084,"I don't know how this happened."],[1084,1272,"I've never made a mistake like that."],[1359,1488,"Forget that for now, okay?"],[1488,1597,"These burns are bad."],[1597,1722,"We need to get you to the hospital."],[2202,2256,"Fuck."],[2268,2310,"I never thought"],[2310,2398,"the head of the company"],[2398,2489,"would get involved."],[2548,2644,"What's gonna happen to us"],[2644,2765,"if they find out what we did?"],[3436,3582,"You were lucky, Mrs. Jayston."],[3674,3862,"Had you taken the blast to the face,"],[3920,4024,"you could have been blinded."],[4120,4212,"Uncle Damon,"],[4262,4471,"he risked himself for me."],[4583,4817,"It was like, I meant more to him"],[4817,4934,"than his own safety."],[5013,5067,"Why?"],[5125,5251,"Why would he do that?"]],"41":[[700,775,"Just got off the phone"],[775,855,"with Genevieve."],[900,1030,"Had her look at the security footage"],[1030,1101,"from the lab,"],[1138,1276,"showed Lucia and Mabel"],[1276,1401,"switching the chemicals."],[1447,1564,"How could they do that?"],[1618,1789,"They put everyone at risk."],[1793,1914,"Well, that's why I fired them."],[1993,2122,"We're considering legal action."],[2122,2273,"I mean, those women tried to hurt you."],[2318,2356,"But,"],[2435,2506,"you saved me."],[2690,2773,"After what happened"],[2773,2873,"between us the other day,"],[2873,3048,"I didn't think you cared."],[3236,3349,"Of course I saved you."],[3390,3445,"You're my,"],[3620,3703,"my niece-in-law."],[3820,4045,"Of course he only sees me as family."],[4079,4216,"But why,"],[4341,4637,"why does it feel like something more?"],[5092,5146,"Don't."],[5693,5843,"It feels so wrong,"],[5855,6193,"but I love the way he looks at me."],[6297,6535,"I feel seen."],[6598,6752,"I'll always look out for family."]],"42":[[1480,1593,"Boss, there's something you need"],[1593,1639,"to see."],[1664,1789,"Emailing it over now."],[4325,4404,"It can't be."]],"43":[[58,133,"It can't be."],[191,333,"There has to be some explanation"],[333,396,"for this."],[638,938,"You asshole, stay away from my wife!"],[971,1059,"You have no right-"],[1059,1192,"No right to protect your wife"],[1192,1263,"when you fail?"],[1317,1376,"Did you even see"],[1376,1484,"the bandage on her hand?"],[1572,1676,"You've neglected her,"],[1722,1847,"but that's between you two."],[1906,2027,"I wash my hands of it."],[2110,2168,"Drive."],[2786,2836,"Hey,"],[2973,3048,"I saw you."],[3098,3294,"You were at a hotel 