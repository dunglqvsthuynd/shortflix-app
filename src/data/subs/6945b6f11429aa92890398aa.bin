"Ah!"],[5505,5601,"Damon, watch out!"],[5822,5876,"Nina!"],[5918,5972,"Nina."],[6064,6135,"Nina, no!"],[6222,6431,"Damon's helped me so many times,"],[6439,6614,"it's my turn to pay him back."]],"65":[[975,1092,"Doctor, she's been unconscious"],[1092,1226,"for almost 24 hours."],[1263,1380,"When is she going to wake up?"],[1438,1559,"She lost a lot of blood,"],[1605,1685,"but she's strong."],[1739,1843,"All we can do is wait."],[2898,3011,"Why won't Nina answer?"],[3048,3140,"Is she with my uncle?"],[3174,3290,"How dare she ignore me?"],[3307,3399,"She's trying to leave me again,"],[3399,3461,"isn't she?"],[4270,4500,"Why haven't you answered my calls?"],[4583,4771,"Evan, I need you."],[4875,4963,"My father"],[5046,5142,"needs a kidney."]],"66":[[12,129,"Your father needs a kidney?"],[133,191,"Yes!"],[233,379,"And without it, he'll die."],[421,500,"Come on, Nina,"],[508,600,"call me back."],[613,709,"How dare you"],[709,817,"abandon me this way?"],[829,984,"You're my wife, don't you get it?"],[1176,1347,"Please, Evan,"],[1388,1551,"please just do this for him."],[1551,1785,"I would do anything for you,"],[1785,1964,"just help him."],[2106,2231,"Sir, I checked"],[2231,2389,"the old estate's security footage."],[2410,2531,"The night at the family dinner,"],[2552,2706,"Nina and Damon met in private."],[3073,3182,"Your father needs a kidney?"],[3228,3282,"Fine,"],[3324,3399,"I'll give it to him."],[3407,3570,"Sir, Nina's father also needs a kidney."],[3570,3670,"I don't care!"],[3745,3966,"The kidney I found goes to who I say!"],[4045,4124,"Nina won't listen?"],[4250,4362,"This is her punishment."]],"67":[[888,946,"You're awake,"],[1080,1146,"finally."],[1255,1384,"What happened?"],[1509,1730,"Some crazy ex-Park Pharma lab tech"],[1730,1797,"stabbed you."],[1826,1951,"He missed your major organs,"],[1951,2114,"but you lost a lot of blood"],[2143,2264,"and fell into a coma."],[2419,2473,"God,"],[2656,2806,"that knife was meant for me,"],[2877,2994,"and you jumped in front of it."],[3061,3174,"I knew you cared for me."],[3574,3707,"Before I can even think about"],[3707,3791,"being with someone else,"],[3791,3958,"I need to finalize my divorce."],[3999,4120,"I can't be like Evan,"],[4183,4325,"I have to do this the right way."],[4387,4471,"Do what you gotta do."],[4512,4629,"But I'm not giving up on you."]],"68":[[321,487,"Let me at least walk you up the stairs."],[838,909,"No,"],[959,1142,"it'll only cause more drama with Evan."],[1205,1330,"If he's gonna grant me this divorce,"],[1330,1430,"he can't think there's anything"],[1430,1539,"going on between us."],[1693,1743,"Fine."],[1851,1918,"Call me later?"],[3707,3878,"Nina? Your father is fading fast."],[3912,3999,"lf he doesn't get that"],[3999,4124,"kidney transplant soon-"],[4124,4187,"Don't worry,"],[4220,4358,"Evan has a lead on a kidney."],[4396,4466,"As soon as we get"],[4466,4550,"the appointment scheduled,"],[4550,4617,"I'll let you know."],[5259,5305,"Nina?"],[5359,5430,"Where were you?"]],"69":[[16,79,"Where were you?"],[120,187,"Were you with him?"],[225,287,"Because..."],[592,679,"What happened to you?"],[717,892,"A crazy ex-Park Pharma employee"],[892,963,"stabbed me."],[1330,1376,"See?"],[1405,1522,"Working for my uncle"],[1530,1718,"is hazardous to your health."],[1751,1839,"If you were with me,"],[1872,1947,"I would have protected-"],[1947,2177,"Evan, I don't have time for this."],[2252,2427,"My father, he needs the kidney."],[2477,2594,"His life is on the line."],[2706,2915,"I'm doing everything I can"],[2915,3023,"to make the arrangements."],[3036,3098,"I should know more"],[3098,3169,"in a couple of days."],[3169,3324,"He doesn't have a few days!"],[3365,3599,"Nina, I love you."],[3607,3762,"I promise I will get your father"],[3762,3837,"that kidney."],[3870,3928,"Trust me."]],"70":[[29,125,"How could he do this to me?"],[246,342,"To my father?"],[621,675,"Nina?"],[742,800,"What's wrong?"],[905,1051,"Your girlfriend called."],[1142,1501,"How sweet of you to give the kidney"],[1522,1705,"you promised my father"],[1718,1897,"to her father instead!"],[1943,2152,"Nina, let me explain."],[2152,2202,"No!"],[2248,2452,"Keep your explanation!"],[2510,2660,"The only thing I want from you"],[2677,2765,"is a divorce."],[2786,3078,"We are done, and I mean it this time!"],[3203,3374,"We are through,"],[3453,3666,"you disgusting bastard!"],[3745,3832,"If you think"],[3895,4016,"you can keep threatening me"],[4016,4095,"with divorce"],[4133,4233,"and I'll just take it,"],[4279,4346,"you're wrong."],[4350,4550,"It's not a threat."],[4637,4867,"We are done."]],"71":[[0,237,"We are done."],[287,342,"Why?"],[392,483,"So you can walk off"],[483,658,"to the sunset with my uncle?"],[729,1021,"I will never let that happen!"],[1121,1463,"You've always been jealous"],[1497,1689,"of your Uncle Damon,"],[1726,1889,"and I mean, I get it."],[1956,2248,"He's more of a man than you'll ever be."],[2302,2452,"He's better at business,"],[2498,2631,"a better protector,"],[2673,2827,"likely a better lover."],[3545,3599,"Nina,"],[3803,4062,"I told you to never think about"],[4062,4166,"leaving my side."]],"72":[[1455,1514,"Evan,"],[1655,1830,"what did you do to me?"],[2022,2077,"Nothing,"],[2135,2198,"you're fine."],[2268,2369,"Everything is fine."],[2431,2569,"Evan, what are you doing?"],[2644,2748,"Let me out of here!"],[3003,3098,"Evan, please!"],[3244,3319,"I love you"],[3336,3470,"too much to lose you, Nina."],[3524,3653,"You'll never leave me again."]],"73":[[200,304,"It’s been two days, and you"],[304,521,"haven't returned any of my calls, Nina."],[579,684,"Where are you?"],[963,1038,"Did you find Nina?"],[1080,1205,"I just got off the phone with Evan,"],[1209,1317,"he said she already left."],[1368,1447,"I don't believe him."],[1472,1555,"I didn't find Nina,"],[1555,1705,"but I looked into her family"],[1705,1780,"like you asked."],[1810,1860,"And?"],[1864,2006,"Turns out her father is on his deathbed"],[2006,2097,"waiting for a kidney."],[2143,2310,"A kidney that Evan promised him."],[2427,2556,"I talked to Nina's friend, Valerie,"],[2590,2748,"she said that Evan is forcing Nina"],[2748,2811,"to stay with him"],[2811,2927,"in exchange for the kidney."],[3011,3078,"So you're just going to"],[3078,3174,"play around with me,"],[3207,3294,"seduce me,"],[3303,3415,"and then go running back to Evan?"],[3415,3616,"I'm sorry, but I have no choice."],[3678,3828,"So that's why she went back to him,"],[3891,4020,"why she keeps pulling away."],[4112,4187,"Apparently,"],[4229,4308,"Evan never came through"],[4308,4375,"with the kidney."],[4454,4575,"Her father isn't going to make it."],[4700,4825,"If Evan's capable of that,"],[4884,4979,"he's capable of anything."],[5013,5184,"I want you to call Dr. Farrow Banks."],[5184,5276,"She owes me a favor."],[5313,5463,"Get her in touch with Nina's father"],[5497,5609,"and get him that kidney."],[5668,5726,"I'm on it."],[5822,5905,"Sir, where are you going?"],[5930,6026,"I'm going to find Nina."],[6089,6227,"I know exactly where she is."]],"74":[[529,588,"What the fuck"],[588,700,"are you doing here, Uncle?"],[700,759,"Where's Nina?"],[784,959,"Like I told you when you called,"],[975,1130,"she's not here."],[1155,1255,"She's not my responsibility"],[1255,1288,"anymore."],[1288,1372,"Oh, she's not?"],[1401,1472,"Then who is,"],[1526,1597,"that secretary"],[1597,1664,"you've been banging?"],[1672,1826,"I don't know what you're talking about."],[1826,1947,"Jesus, save the innocent act"],[1947,2081,"for someone who's going to fall for it."],[2193,2314,"But I think we both know"],[2314,2398,"that it's going to be hard"],[2398,2523,"to cover your dirty deeds"],[2523,2669,"once Candice has your child."],[3570,3616,"None of this"],[3616,3770,"is any of your damn business!"],[3778,3874,"You know, you're right."],[3887,3974,"It's yours."],[4024,4208,"And when I tell every sort of detail"],[4208,4358,"to the big hitters in our industry,"],[4383,4504,"and Mom and Dad find out"],[4504,4654,"how you've been conducting yourself,"],[4692,4750,"you're done."],[4813,4900,"Disinherited!"]],"75":[[29,91,"You're done."],[129,216,"Disinherited!"],[421,563,"What do you want in return"],[563,679,"to keep your mouth shut?"],[709,796,"I want Nina,"],[909,1001,"and that's not all."],[1347,1501,"Sign these divorce papers."],[1589,1651,"Free her,"],[1705,1801,"let Nina go."],[1901,1956,"No."],[1985,2143,"She's my wife,"],[2189,2256,"I love her."],[2302,2419,"She belongs to me!"],[2548,2602,"Well, I guess"],[2602,2723,"you have a decision to make."],[2756,2869,"What's it going to be, Nephew?"],[2915,2969,"Money,"],[3048,3119,"or love?"]],"76":[[362,404,"Nina."],[437,608,"Nina, please wake up."],[788,838,"Damon?"],[859,946,"What are you doing here?"],[988,1071,"I came for you."],[1121,1222,"I'm getting you out of here."],[1263,1393,"For your nephew's wife?"],[1497,1680,"You would risk turning against him,"],[1689,1810,"against your whole family?"],[1843,2022,"Nina, if you say yes,"],[2064,2160,"I'll risk everything."],[2202,2389,"I'll pay any price to get you out of here."],[2456,2527,"Tell me, Nina."],[2635,2711,"What's your answer?"],[2819,2944,"I will, Damon."],[3795,3866,"You're stupid"],[3874,4016,"if you think he really loves you."],[4099,4212,"You'll come running back to me,"],[4233,4287,"just wait."],[4350,4412,"Ignore him."],[4517,4667,"You'll never have to listen to him again."],[4917,5071,"If you think this is over, Uncle,"],[5100,5213,"you're dead wrong!"],[5246,5417,"If you try to hurt her again, Nephew,"],[5472,5580,"you'll have to go through me."],[6381,6481,"I'll get you back!"],[6573,6715,"One way or another!"]],"77":[[408,496,"Evan, don't!"],[583,650,"Hey, hey,"],[734,788,"it's okay."],[888,950,"You're safe."],[1046,1117,"Where am I?"],[1134,1197,"My place,"],[1292,1355,"my bedroom."],[1659,1860,"I shouldn't be here."],[1868,1935,"Relax,"],[2014,2081,"I'm going to stay"],[2081,2198,"in the guest room tonight."],[2243,2385,"I just came in here to check on you."],[2410,2473,"Last thing I knew,"],[2473,2673,"I laid down and I fell asleep."],[2927,3044,"I should go."],[3215,3332,"If you want to go, go."],[3445,3674,"But first, I have something for you."],[5121,5309,"Is this real?"],[5505,5634,"I put things into perspective"],[5634,5680,"for Evan."],[5739,5901,"He was so afraid of going bankrupt,"],[5922,5980,"he signed."],[6022,6131,"Didn't fight the terms."],[6343,6489,"I'm finally free."]],"78":[[246,425,"I can't believe it's finally over."],[583,638,"Believe it."],[1151,1238,"I don't want to rush you."],[1317,1438,"I care about you, Nina."],[1493,1580,"I want to be with you,"],[1697,1793,"that hasn't changed."],[1835,1997,"Please tell me you feel the same."],[2398,2656,"Damon, we, we can't be together,"],[2656,2798,"we're not right for one another."],[2798,2915,"What would your family think?"],[2915,2977,"Your parents-"],[2977,3090,"Don't worry what they think."],[3186,3278,"You're divorced now."],[3345,3465,"I'm not your uncle anymore."],[3574,3641,"Plus, how do you know"],[3641,3757,"we're not right for each other"],[3787,3891,"if you haven't really tried?"],[3995,4104,"I have tried."],[4175,4258,"Then try again."],[4341,4562,"Keep trying until it feels right."],[4754,4921,"I don't want to make the same mistake"],[4921,5034,"like I did with Evan."],[5105,5188,"I'm not Evan."],[5843,5926,"See for yourself."]],"79":[[1630,1739,"I'm so sorry,"],[2064,2143,"it's my fault."],[3841,3937,"I want you, Damon,"],[4033,4187,"but I've only ever been with Evan."],[4325,4396,"Then let me show you"],[4396,4491,"what you've been missing."]],"80":[[550,646,"What are you doing tomorrow?"],[709,767,"Nothing,"],[771,821,"why?"],[1038,1109,"Let's get married."],[1359,1418,"Damon,"],[1493,1593,"that's not appropriate."],[1593,1743,"I'm your nephew's ex-wife."],[1881,1989,"I'm serious about you."],[2047,2243,"And I can't wait to make you my wife."],[2323,2473,"I've wanted this for a long time."],[2627,2777,"What do you mean for a long time?"],[2898,3015,"It was love at first sight."],[3094,3190,"Well, that's for me to know,"],[3190,3286,"and you to find out."],[3945,4095,"Nina, you're mine."],[4145,4379,"This isn't over!"]]}