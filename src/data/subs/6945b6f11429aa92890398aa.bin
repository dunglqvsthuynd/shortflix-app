're wrong, Evan."],[3507,3724,"I can live with or without you."],[3945,4070,"Get dressed."],[4141,4266,"We're going to family dinner."],[4404,4804,"I told you I'm not going."],[4863,5005,"Tell them I'm sick."],[5180,5251,"What are you doing?"],[5251,5355,"Let me go!"],[5563,5814,"I am running out of patience."]],"10":[[33,266,"I'm running out of patience, Nina."],[358,450,"Two choices."],[504,646,"Change your damn clothes,"],[679,838,"or I'm cutting off"],[850,992,"your father's medical treatment,"],[1017,1284,"and he'll never get the kidney he needs."],[1338,1501,"You're crossing a line, Evan."],[1722,1776,"Hey,"],[1918,2043,"I don't want to hurt you."],[2135,2235,"I never did."],[2414,2515,"But leaving me?"],[2631,2731,"That's not an option."],[2815,2944,"I'll make sure you remember"],[2944,3044,"who you belong to."],[3090,3203,"So don't fight with me."],[3724,3933,"I got you a new ring."],[4033,4208,"It's an upgrade."],[4479,4554,"You deserve it."],[5180,5242,"Now,"],[5313,5397,"be a good girl"],[5480,5576,"and get changed,"],[5638,5693,"or"],[5759,6089,"I can't promise your father will make it"],[6089,6214,"to see the new year."]],"11":[[1326,1388,"Remember,"],[1409,1547,"your father's life is on the line."],[1601,1755,"You're just worried Uncle Damon"],[1755,1881,"will find out you're cheating."],[1926,2072,"He won't tolerate your bullshit"],[2072,2135,"and you might risk"],[2135,2281,"losing your family inheritance."],[2344,2531,"The only reason I want the inheritance"],[2590,2811,"is so I can take better care of you."],[2877,3069,"I love you too much to lose you."],[3995,4158,"Uncle Damon never shows up"],[4158,4275,"at family gatherings."],[4688,5013,"Is he coming straight to me?"],[5442,5651,"He won't tell anyone about that night,"],[5689,5751,"will he?"],[5885,6006,"It's good to see you again, Nina."],[6902,6965,"Uncle Damon,"],[7011,7119,"Grandma and Grandpa"],[7119,7228,"are waiting inside."]],"12":[[312,483,"Why are you staring at my uncle?"],[513,667,"