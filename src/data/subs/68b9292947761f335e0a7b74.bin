{"1":[[58,258,"Sorry I had to leave that meeting early."],[333,487,"Ah, man."],[513,650,"I only had one drink."],[675,896,"One drink that I drugged, big bro."],[1080,1217,"Something's not right."],[1618,1743,"By tomorrow,"],[1743,1993,"I will be the new CEO of Larco."],[2002,2077,"And you"],[2077,2156,"will be dead."],[3361,3449,"It's ok."],[3511,3599,"You’re gonna be ok."],[3987,4095,"You saved me."],[4141,4245,"You're an angel."],[4245,4320,"You must have hit"],[4320,4383,"your head pretty bad."],[4383,4504,"You're so beautiful."],[4504,4571,"No one’s ever"],[4571,4658,"called me that before."],[5155,5276,"You're so soft"],[5363,5455,"like velvet."],[6056,6151,"Am I dreaming"],[6151,6222,"right now?"],[6439,6548,"Please don’t stop."],[6731,6844,"I won’t, my angel."],[7374,7507,"Oh my God,"],[7507,7695,"is he drunk?"],[8166,8224,"Hey!"],[8224,8420,"The pool closed at 6 p.m., sir."],[8470,8679,"There's no sleeping in the cabanas."],[8696,8875,"Where did she go?"],[8875,8992,"Fuck, I don’t even remember"],[8992,9092,"her name."],[9092,9225,"Was she even real?"],[9905,9980,"It's hers."],[10051,10193,"I'll give it back to her when I find her."]],"2":[[129,246,"This can't be happening."],[350,400,"Scarlett,"],[408,496,"quit hogging the bathroom."],[496,600,"What are you doing in there?"],[742,884,"You’ve been acting weird lately."],[938,1021,"Or weirder."],[1071,1155,"What gives?"],[1180,1351,"I've just been really busy with school."],[1960,2143,"You stupid bitch!"],[2181,2260,"You're pregnant?"],[2331,2389,"Whose is it?"],[2444,2494,"Tell me it's someone"],[2494,2627,"with money that we can squeeze."],[2652,2748,"I don't know who he is."],[2765,2898,"You can't dig your claws into him."],[2911,3003,"So, you're fat"],[3036,3119,"and a skank."],[3286,3470,"Fucking worthless."],[3707,3870,"You're so beautiful."],[3995,4095,"Look in the mirror, Mitch."],[4162,4304,"You're a 30-year-old man"],[4304,4437,"living off his little sister."],[4475,4592,"You don’t get to call anybody names."],[4592,4708,"Now, give it to me, give it to me!"],[4733,4775,"Mom."],[4842,4946,"Scarlett's knocked up."],[5171,5351,"I'm not spending a dime"],[5351,5480,"on the little bastard."],[5555,5680,"You are getting an abortion,"],[5680,5822,"or you're out of this house for good!"],[5910,6076,"I'm keeping my baby."],[6147,6264,"And she will know every day"],[6264,6360,"that she is loved."],[6731,6815,"Charging!"],[7027,7082,"Clear!"],[7161,7219,"Again!"],[7540,7628,"It’s okay."],[7761,7824,"Clear!"]],"3":[[12,191,"You died, Miss Haynes,"],[191,296,"but we brought you back."],[296,375,"Quite frankly,"],[421,496,"it's a miracle."],[704,846,"You're my little miracle, Lily."],[846,1009,"An OBGYN would have caught"],[1009,1163,"the gestational hypertension."],[1192,1297,"And with proper bed rest"],[1297,1384,"and medication,"],[1384,1514,"you wouldn't have almost bled out"],[1514,1618,"during your delivery."],[1634,1768,"I don't have insurance."],[1851,1922,"I don't even know how"],[1922,1993,"I'm gonna pay for this"],[1993,2081,"emergency room stay."],[2122,2223,"Look, your baby girl"],[2223,2364,"almost lost her mother."],[2364,2502,"I know this isn't easy,"],[2502,2619,"but you have to"],[2619,2727,"manage your stress,"],[2786,2915,"and you have to prioritize"],[2915,3007,"your health."],[3061,3128,"I will."],[3265,3328,"I'm gonna be there"],[3328,3428,"for every moment"],[3428,3507,"of Lily’s life."],[3870,3949,"Your first word,"],[4049,4158,"your first step,"],[4258,4396,"your first day at school,"],[4475,4587,"your first crush."],[4629,4717,"I'm going to be there"],[4750,4838,"when you graduate college,"],[4838,4909,"like I didn't."],[4917,5038,"Mommy's not giving up."],[5059,5167,"When you fall in love"],[5184,5271,"and walk down the aisle."],[5409,5497,"Lily, I'm going to be there"],[5497,5647,"when you have your first baby."],[5701,5809,"I'm going to do whatever it takes"],[5809,5880,"to get healthy"],[5880,5972,"and to be a great mom."],[6093,6143,"I promise."]],"4":[[129,266,"Mother, now's not a good time."],[312,521,"Don't you dare blow me off, Brandon."],[521,617,"Look, I'm meeting with the new"],[617,729,"private investigator right now."],[729,771,"He's going to-"],[771,834,"Clearly,"],[834,980,"that fall you took into the pool"],[980,1067,"five years ago"],[1067,1176,"harmed your brain."],[1188,1338,"You need to stop this."],[1338,1409,"She saved me."],[1409,1509,"I have to find her."],[1509,1780,"You don't even know her name."],[1893,2106,"There are plenty of respectable"],[2106,2256,"rich curvy girls out there,"],[2256,2389,"if that's your type."],[2452,2715,"Forget the mystery waitress."],[3119,3211,"I can't."],[3324,3465,"She's out there somewhere."],[3465,3695,"It's my job as your mother"],[3695,3903,"to knock some sense into you."],[3920,4087,"Just remember,"],[4087,4229,"you forced me to do this."],[4229,4404,"Mother, what have you done?"],[4454,4592,"I'm stepping down next month."],[4592,4746,"And if you haven't found yourself"],[4746,4854,"a wife by then,"],[4854,4971,"I'm naming your brother"],[4971,5192,"as the next CEO of Larco industries."],[5192,5263,"Reggie?"],[5309,5463,"Oh my God, are you nuts?"],[5501,5609,"I mean, he's just going to come in"],[5609,5676,"and destroy everything"],[5676,5768,"that I built here."],[5768,5876,"Well, then,"],[5876,6051,"you'd better find yourself a wife."],[6093,6193,"Fast."],[6510,6627,"Hey, Brandon, it's Tom,"],[6627,6731,"the private investigator"],[6731,6765,"you hired."],[6765,6827,"Listen,"],[6827,6890,"I'm not going to make"],[6890,6956,"the meeting today."],[6956,7161,"I can't find any leads on this girl."],[7161,7294,"I think it's a dead end."],[7294,7386,"Sorry."],[8028,8174,"Are you ready to place your order?"]],"5":[[250,446,"Lily, what are you doing here?"],[446,667,"Uncle Mitch brought me to see you."],[684,863,"I love seeing Lily, but,"],[913,996,"Mitch, you know I can’t"],[996,1117,"have visitors at work."],[1251,1347,"Lily, why don't you go"],[1347,1418,"to your favorite corner"],[1418,1476,"and go color."],[1476,1534,"Okay?"],[1551,1639,"Fuck this job."],[1639,1764,"Max Grimes is willing to"],[1764,1914,"take this all the way for you."],[1943,1997,"The Grimes family"],[1997,2068,"is one of the wealthiest"],[2068,2156,"in this city,"],[2210,2327,"second to only the Larson’s."],[2406,2531,"I already told you,"],[2531,2727,"I'm not marrying that old creep"],[2727,2836,"just because he has money."],[2861,2940,"You better start counting"],[2940,3019,"your blessings."],[3069,3211,"You caught Grimes' eye."],[3278,3319,"Now,"],[3340,3449,"you may not be fat anymore,"],[3449,3624,"but men aren't exactly lining up"],[3624,3737,"to get with you"],[3737,3862,"and your little bastard here."],[3941,4095,"Do not talk about my daughter"],[4095,4158,"like that."],[4258,4404,"I'll talk any way I want."],[4537,4621,"Grimes is willing to"],[4621,4746,"raise your little mistake."],[4746,4884,"I'm not a mistake."],[4909,4975,"Shut up, kid!"],[4975,5042,"Lily!"],[5163,5288,"Get out of here, Mitch."],[5288,5430,"I have to get back to work."],[5430,5522,"How dare"],[5522,5630,"you raise your voice to me."],[5630,5730,"You're coming with me."],[5730,5847,"And you're going to meet Max Grimes"],[5847,5893,"this time,"],[5893,5989,"and you're going to marry him."],[5989,6072,"Stop it, Mitch."],[6147,6210,"Don't do this."],[6664,6794,"She feels familiar."],[6831,6911,"Have we met before?"]],"6":[[0,175,"You stupid bitch!"],[175,283,"That shit is hot!"],[312,458,"I'm so sorry, sir."],[542,684,"She doesn't recognize me."],[684,771,"I must be mistaken."],[809,846,"It's fine."],[846,913,"It's not your fault."],[955,1051,"I saw everything."],[1422,1509,"Thank you."],[1785,1943,"Mama, this one's funny."],[1943,2143,"Where's the other half?"],[2198,2252,"It's missing,"],[2252,2335,"baby girl."],[2335,2452,"Your daddy has it."],[2665,2765,"Mama, look,"],[2765,3028,"that man has the other earring."],[3098,3169,"Lily."],[3169,3274,"Mama, look."],[3274,3428,"The other earring."]],"7":[[120,171,"Enough of this"],[171,308,"delaying shit, Scarlett."],[308,371,"You're wasting my time."],[371,437,"Let's go."],[646,725,"Grimes is waiting."],[763,850,"He promised me a position"],[850,905,"in his company"],[905,996,"after you marry him."],[1017,1222,"How many times do I have to tell you?"],[1222,1372,"I'm not marrying anyone"],[1372,1488,"until I find Lily's dad."],[1505,1659,"She deserves an entire family."],[1705,1793,"I want to give her that."],[1947,2010,"Hey, buddy."],[2010,2097,"Stay out of it."],[2181,2264,"Even if you find"],[2264,2373,"your bastard's father,"],[2373,2481,"he's probably still a deadbeat."],[2911,3044,"Who the fuck are you?"],[3044,3169,"It doesn't matter who I am."],[3169,3274,"You never hit a woman."],[3428,3474,"What are you,"],[3474,3607,"some kind of fucking saint?"],[3682,3832,"My future brother-in-law"],[3837,3949,"is Max Grimes."],[3966,4074,"He can buy anyone in this city"],[4074,4170,"except for the Larsons."],[4170,4450,"So, unless you're the Larson heir,"],[4508,4654,"I suggest you back the fuck up."],[4654,4746,"Mitch, this is between"],[4746,4783,"you and me."],[4783,4904,"Leave innocent bystanders"],[4904,4963,"out of this."]],"8":[[0,133,"Oh, you'll pay for this!"],[429,508,"If I ever see you"],[508,600,"hit a woman again,"],[625,734,"not even the precious Grimes"],[734,817,"is going to be able to save you,"],[817,921,"do you understand me?"],[975,1213,"There'll be nowhere in this fucking city"],[1213,1372,"that you can hide from me, buddy!"],[1372,1559,"Who the hell do you think you are?"],[1710,1797,"This isn't over."],[1835,1893,"It is over."],[1893,2052,"I'm never marrying Grimes."],[2081,2173,"Now get out of here!"],[2477,2598,"Daddy, you did it!"],[2852,2898,"Lily,"],[2898,3036,"you can't call perfect strangers"],[3036,3098,"daddy."],[3207,3328,"He's not a stranger."],[3328,3445,"He's my daddy."],[3445,3570,"I'm so sorry, sir."],[3570,3661,"I have no idea"],[3661,3799,"why she's calling you that."],[3941,4074,"Thank you for stepping in today."],[4237,4379,"My brother and I were"],[4446,4517,"nothing alike."],[4562,4667,"I can see that."],[4742,4850,"No, seriously,"],[4850,4984,"I'm really sorry"],[4984,5117,"that I didn't step in any sooner."],[5251,5367,"Daddy! Daddy!"],[5367,5547,"It's my birthday in a few days."],[5547,5764,"I really want you to be there."],[5764,5872,"I'm so sorry."],[5872,6064,"Lily just misses her dad so much."],[6064,6172,"I'd actually love to join"],[6172,6285,"the birthday celebration,"],[6348,6431,"if that's alright?"],[6552,6677,"Under one condition, though."],[6752,6931,"That you marry me."],[7002,7061,"What?"]],"9":[[29,141,"You want me to marry you?"],[141,271,"And we just met."],[296,454,"It's just a business proposal, okay?"],[475,517,"You see,"],[517,650,"I need to be married by next week,"],[650,742,"or my mom's gonna"],[742,850,"do something awful."],[867,930,"And..."],[938,996,"your brother can't"],[996,1088,"marry you off to Grimes"],[1088,1180,"if you're married to me, right?"],[1247,1438,"Why is he being so nice to me?"],[1438,1580,"And where have I seen that"],[1580,1693,"smile before?"],[1735,1835,"What awful thing"],[1835,1935,"would your mom do?"],[1964,1997,"Look,"],[1997,2081,"we don't need to get into"],[2081,2181,"the details, alright?"],[2235,2298,"The point is,"],[2298,2381,"I need to get married"],[2381,2448,"by next week,"],[2448,2515,"or my mom's going to"],[2515,2594,"do something crazy."],[2719,2811,"And Lily's right."],[2994,3128,"You've been raising her by yourself"],[3128,3215,"your entire life."],[3274,3361,"Let me help you out."],[3407,3524,"The thing is,"],[3707,3866,"I'm still searching for Lily's dad."],[3912,4033,"When we met it was just a brief"],[4033,4120,"encounter, and"],[4120,4250,"he doesn't know about her."],[4304,4425,"I can't marry someone else"],[4425,4579,"with the possibility of him in my heart."],[4692,4783,"I respect that."],[4863,5025,"Isn't mommy great?"],[5025,5242,"Mommy's so pretty and so nice"],[5242,5405,"and so beautiful."],[5467,5630,"Lily, stop it!"],[5668,5889,"I'm so, so sorry."],[5935,6010,"I, uh…"],[6010,6235,"I'm actually looking for someone too."],[6277,6477,"This is a marriage in name only."],[6477,6631,"It's a business proposal."],[6631,6760,"If you happen to find Lily's dad,"],[6760,6881,"then I'll step out of the picture."],[6927,6986,"Alright?"],[6986,7144,"The choice is yours, no pressure."],[7236,7361,"I'm Scarlett Haynes."],[7407,7532,"I look forward to doing business"],[7532,7578,"with you."],[7645,7741,"I'm Brandon."],[7799,7924,"It's a pleasure to meet you, Scarlett."]],"10":[[646,742,"Lily, be careful!"],[742,842,"That couch is expensive."],[842,917,"You could break something."],[917,1005,"You can let her play around."],[1005,1080,"It's not a problem."],[1259,1326,"Brandon,"],[1363,1530,"this neighborhood is full of rich"],[1530,1639,"and powerful people."],[1639,1856,"And, this house is amazing."],[1997,2089,"What exactly is it"],[2089,2193,"that you do for a living?"],[2223,2323,"Nothing shady."],[2339,2431,"I promise."],[2669,2769,"Scarlett, I'm actually-"],[3065,3132,"What is it, Frank?"],[3311,3461,"Don't let Reggie touch anything."],[3461,3541,"Alright?"],[3541,3632,"I'll be right there."],[3937,4016,"Sorry about that."],[4049,4162,"There's a security breach"],[4162,4225,"down at the office."],[4225,4341,"I need to go check it out."],[4429,4483,"Alright?"],[4483,4596,"We'll talk when I get back."],[4675,4804,"You guys can make yourselves at home,"],[4804,4846,"alright?"],[5125,5296,"So, he's a security guard."]],"11":[[896,1021,"CEO Larson,"],[1080,1209,"your private entrance is ready,"],[1209,1238,"sir."],[1284,1347,"Thank you."],[1572,1714,"We've been working here for four years,"],[1714,1793,"and we've never seen"],[1793,1860,"that guy's face."],[1860,2114,"CEO Larson likes to keep a low profile."],[2147,2264,"Apart from company directors,"],[2264,2352,"not even managers"],[2352,2423,"of various departments"],[2423,2502,"have met him."],[2573,2656,"Back to our post."],[2681,2765,"Act natural."],[3520,3712,"Daddy forgot his phone."],[3712,3778,"You're right."],[3778,3962,"He must be very anxious."],[3962,4074,"Should we go bring it to him?"]],"12":[[241,325,"Excuse me."],[325,442,"I'm here to drop something off."],[454,642,"Deliveries use the service elevator."],[642,717,"You'll have to go around"],[717,771,"through the back."],[825,996,"Larco prides itself on its looks."],[996,1088,"Get out of the lobby"],[1088,1201,"before someone sees you,"],[1201,1305,"and your little brat."],[1351,1405,"Oh..."],[1434,1576,"I'm not a delivery person."],[1605,1776,"My husband just left his phone at home."],[1776,1835,"I just…"],[1835,1964,"I figured he might need it at work."],[2002,2106,"You expect us to believe"],[2106,2189,"you're married to someone"],[2189,2281,"who works at Larco?"],[2298,2394,"What's his name?"],[2469,2527,"His name is-"],[2527,2619,"We'll have to look it up."],[2619,2773,"We only know the names of people"],[2773,2890,"who are actually important"],[2890,2961,"to this company."],[3003,3073,"Not someone who'd"],[3073,3207,"be married to the likes of you."],[3265,3424,"His name is Brandon."],[3532,3703,"She's Brandon Larson's wife?"]],"13":[[246,392,"More like his cleaning lady."],[417,575,"How do you expect us to believe you?"],[663,779,"I just wanted to return it,"],[779,900,"and I'll take my daughter"],[900,988,"and be on my way."],[1009,1134,"You probably stole that phone"],[1134,1209,"and are returning it"],[1209,1338,"to get into his good graces."],[1338,1430,"Security!"],[1576,1726,"Get your hands off me!"],[1780,1826,"Oh, good."],[1851,1947,"Here comes Manager Zeller."],[2064,2135,"Okay."],[2135,2239,"What is all the commotion?"],[2268,2373,"You know this is Larco"],[2373,2469,"not a circus, right?"],[2565,2627,"Jenny?"],[2656,2823,"Thank you so much, Scarlett."],[2827,2907,"You know, people at this school"],[2907,3023,"are such assholes."],[3053,3161,"What are best friends for?"],[3244,3290,"Besides,"],[3349,3495,"I know what it's like to be belittled."],[3703,3828,"White trash!"],[4337,4383,"Scarlett?"]],"14":[[4,158,"Jenny, you look incredible."],[258,379,"And congratulations"],[379,504,"on working at Larco."],[608,792,"Lily, everything's going to be alright."],[792,867,"This is mommy's"],[867,975,"good friend from school."],[996,1101,"Why don't you go say hi?"],[1247,1418,"You want a lollipop"],[1418,1618,"Aunty Jennifer?"],[2252,2331,"Jenny?"],[2331,2452,"I…I don't understand."],[2452,2598,"Okay, only my friends"],[2598,2681,"call me Jenny."],[2848,2940,"You know, I almost didn’t"],[2940,3044,"recognize you."],[3123,3190,"I guess having another"],[3190,3265,"mouth to feed"],[3265,3382,"keeps you from stuffing your own?"],[3495,3557,"You know, you guys should've"],[3557,3653,"seen her in high school."],[3712,3945,"Everyone called her curvy, but"],[3945,4112,"we all know that's code for fat."],[4275,4408,"Why are you being so cruel?"],[4433,4512,"Because"],[4575,4708,"you don't belong here."],[4746,4804,"What did you hear"],[4804,4909,"that I moved up in the world?"],[4929,4967,"And you just wanted"],[4967,5071,"to come pay me a visit?"],[5096,5176,"You brought me down"],[5176,5251,"in high school,"],[5251,5372,"and I won't let you do it again."],[5397,5705,"You're ugly when you frown like that."],[5705,5834,"You little shit!"],[5834,5943,"Don't you dare raise your hand"],[5943,6001,"at my daughter."],[6001,6143,"I just want to give"],[6143,6314,"my daddy his phone."],[6335,6552,"Your daddy is probably a janitor,"],[6589,6669,"a handyman,"],[6669,6848,"trailer trash like you."],[7094,7211,"Don't listen to her."],[7211,7315,"Take this lollipop"],[7315,7399,"and go sit on the bench,"],[7399,7457,"okay?"],[7707,7845,"Let's see who your"],[7845,8128,"husband has in his contacts."],[8166,8224,"Then we can find out"],[8224,8345,"who the bastard really is."],[8504,8550,"Wait."],[8608,8692,"How can this be?"],[8737,8817,"How does he have all the numbers"],[8817,8967,"for all these high level people?"]],"15":[[0,95,"How does he have all the numbers"],[95,258,"for all these high level people?"],[300,408,"I think he works in security."],[462,542,"And I think that he stole"],[542,646,"this sensitive information"],[646,809,"to make himself look like a big shot."],[888,988,"You know, my cousin"],[988,1172,"is a chief secretary at Larco."],[1284,1376,"Why don't we give her a call"],[1376,1484,"and see if she picks up"],[1484,1609,"from this nobody’s phone."],[2027,2152,"Make sure those quarterly reports"],[2152,2289,"are in by noon tomorrow, alright?"],[2448,2544,"Sorry, boss."],[2827,2882,"Yeah."],[2882,3011,"Of course, she declined the call."],[3286,3374,"No wedding ring."],[3436,3495,"Should've known"],[3495,3624,"that the kid was a bastard."],[3691,3766,"What'd you get knocked up"],[3766,3887,"by some guy on the street?"],[3933,4074,"Oh, that's why you got skinny."],[4141,4295,"Skinny girls make more money,"],[4295,4383,"don't they?"],[4454,4575,"How much do you charge?"],[4646,4792,"That'll be all for today."],[4813,4913,"Thank you, Jackie."],[5434,5509,"Boss?"],[5597,5705,"That call I got earlier,"],[5789,5905,"it’s from your cellphone."]],"16":[[41,95,"Call it back."],[95,141,"Right now."],[437,517,"There's no crime"],[517,696,"in being poor or overweight."],[729,930,"I got healthy for my daughter."],[1159,1213,"What?"],[1330,1397,"Who is this?"],[1501,1609,"It must be the janitor"],[1609,1835,"impersonating a Larco employee."],[1856,1931,"I can already tell by your voice"],[1931,2027,"you sound like a nobody."],[2052,2210,"I want to talk to Scarlett Haynes."],[2239,2352,"Your bastard child"],[2352,2498,"and baby mama are in the lobby."],[2531,2619,"If I were you,"],[2619,2669,"I'd hurry up"],[2669,2794,"before I throw them out on the street"],[2794,2869,"where they belong."],[2894,2969,"You have no idea"],[2969,3078,"who you're messing with."],[3182,3374,"If Scarlett or Lily get harmed in any way,"],[3374,3440,"I swear to God,"],[3440,3524,"I'm going to come down there-"],[3524,3820,"I am so scared, Mr. Janitor."],[3820,3912,"What are you gonna do?"],[3941,4012,"Mop me to death?"],[4141,4229,"Now hurry up."],[4270,4371,"I'm sick of looking at them."],[4704,4863,"Just let them wait here."],[4892,5055,"Then we can catch the loser"],[5055,5213,"pretending to be a Larco employee."],[5263,5422,"Just be ready to call the police."],[5580,5634,"Find out who"],[5634,5743,"just answered my phone."],[5789,5855,"Whoever it is"],[5855,5926,"is never going to work in"],[5926,6022,"this business ever again."]],"17":[[0,104,"Your little janitor"],[104,171,"is going to spend"],[171,287,"the rest of his life in jail"],[287,429,"if you don't get on your knees,"],[475,704,"and beg me not to press charges."],[880,1030,"Come on, Scarlett."],[1092,1188,"It's not like you have any"],[1188,1359,"pride left you little whore."],[1409,1634,"Every cent that I ever earned,"],[1634,1730,"I worked for."],[1797,1926,"I worked to get healthy."],[1947,2056,"I worked to earn a living."],[2097,2231,"And I'm not asking for any favors"],[2231,2352,"from you or from anyone."],[2352,2423,"Shut up."],[2644,2840,"Daddy's gonna make you pay!"],[2932,3073,"And you're getting on my nerves,"],[3073,3232,"you little bastard."],[3249,3294,"Let's go"],[3294,3482,"for a time out in the janitor's closet."],[3499,3536,"Lily."],[3536,3720,"Get your hands off of her, you bitch!"]],"18":[[483,567,"Step away from my"],[567,629,"wife and daughter!"],[629,796,"Well, well, well."],[796,892,"Hello, handsome."],[1130,1267,"I only wanted to return your phone."],[1267,1363,"I'm sorry for causing"],[1363,1459,"so much trouble here."],[1459,1539,"No, Scarlett."],[1609,1772,"I thought I told you over the phone"],[1772,1876,"that there would be hell to pay"],[1876,2022,"if you touch my wife and daughter."],[2043,2122,"Wife?"],[2198,2360,"I don't see a ring on her finger."],[2473,2640,"Not that you could afford one."],[2640,2765,"Look at this suit."],[2806,2927,"You know, next time you want to pretend"],[2927,3107,"to be an employee at Larco,"],[3144,3261,"probably should steal a suit"],[3261,3390,"with a designer label on it."],[3503,3616,"You got a nice face though."],[3737,3912,"How about you take me to dinner"],[3912,3987,"and I could put in a"],[3987,4129,"good word for you at Larco."],[4212,4300,"You're right."],[4333,4458,"This suit is unwearable."],[4625,4688,"You know why?"],[4792,5071,"It is absolutely filthy,"],[5071,5192,"now that you touched it."],[5355,5434,"You know, I-"],[5722,5789,"What now?"],[5805,5897,"Miss Zeller,"],[5897,6031,"this is HR calling"],[6031,6106,"to inform you"],[6106,6222,"that you are no longer"],[6222,6389,"a sales manager at Larco."],[6402,6489,"You've been transferred"],[6489,6652,"to the janitorial department."],[6652,6790,"It’s effective immediately."]],"19":[[33,112,"Who are you?"],[141,204,"And what kind of game"],[204,279,"are you guys playing?"],[408,554,"Did you steal my phone number"],[554,709,"and get someone to pretend to be HR?"],[709,821,"Enough, cousin."],[942,1105,"Thanks for carrying out my orders."],[1267,1380,"Although, I don't think this one's"],[1380,1488,"even worthy enough to wipe"],[1488,1589,"the floors at Larco."],[1689,1843,"Scarlett, let's get out of here, alright?"],[1843,1926,"Get some ice cream maybe,"],[1926,2010,"on the way home?"],[2031,2139,"Yay, ice cream!"],[2348,2481,"Jackie, are you just going to let them"],[2481,2644,"get away like that?"],[2781,2852,"That's enough."],[2965,3186,"That man is untouchable"],[3186,3265,"at this company."],[3278,3361,"Do you hear me?"],[3461,3578,"As for the rest of you,"],[3624,3728,"you have five minutes"],[3728,3858,"to pack your things"],[3858,4012,"and leave Larco Industries,"],[4041,4116,"forever!"],[4867,4929,"Shit."],[4992,5046,"When did my brother"],[5046,5109,"get married?"],[5146,5246,"I've got to break them up"],[5246,5334,"before mother gets back and"],[5334,5459,"I lose the company to him forever."]],"20":[[150,283,"There's extra towels and pillows"],[283,450,"in the closet if you need anything."],[508,617,"Don't hesitate to ask."],[638,696,"Thank you."],[729,767,"And,"],[825,971,"thanks again for stepping in today."],[1109,1222,"What exactly is it"],[1222,1330,"that you do at Larco?"],[1497,1551,"Well-"],[1551,1722,"Are mommy and daddy fighting?"],[1956,2022,"What?"],[2047,2173,"Why would you say that?"],[2198,2289,"Why are you sleeping"],[2289,2427,"in different beds?"],[2477,2598,"Well, don't you want mommy"],[2598,2694,"to sleep with you?"],[2694,2731,"Nope."],[2731,2786,"I'm fine."],[3098,3194,"Okay."],[3370,3453,"Boss' orders."],[5280,5359,"Poor thing must be having"],[5359,5451,"a nightmare."],[5972,6026,"Are you okay?"],[7524,7661,"I haven't let anyone hold me"],[7661,7778,"since Lily's dad."],[7899,8049,"Why does this feel so safe?"]],"21":[[442,571,"Looks like we both really slept"],[571,688,"like babies last night."],[804,1009,"God, she's really soft."],[1276,1409,"You’re so soft."],[1972,2039,"Oh my God."],[2398,2473,"Good morning."],[2510,2615,"I'm so sorry."],[2615,2731,"You were having a nightmare,"],[2731,2840,"and I just-"],[2986,3065,"Good morning, mommy."],[3065,3194,"Good morning, daddy."],[3194,3303,"You have no idea how long"],[3303,3420,"she's been waiting to say that."],[3474,3628,"I'm glad she can finally say it."],[3716,3791,"Lily, honey."],[3791,3970,"We got to get ready to go to grandma's."],[4412,4625,"Hey, Brandon, can I ask you a favor?"],[4688,4783,"Yeah, shoot."],[4804,4892,"Would you come with us"],[4892,4996,"to my mom's today?"],[5071,5171,"She's sick, and"],[5209,5276,"I want her to see me"],[5276,5372,"with a good man."],[5392,5480,"She always wanted me to"],[5480,5576,"marry for money,"],[5609,5668,"and"],[5730,5780,"I want to show her that"],[5780,5880,"that doesn't matter to me."],[5918,6047,"Yeah, I'd love to, but"],[6076,6189,"I have this really important meeting"],[6189,6310,"I have to go to, I can’t miss it."],[6310,6423,"Can I just meet you there?"],[6448,6498,"Of course."],[6573,6664,"Grandma's mean."],[6664,6911,"I don't want to go without daddy."],[6911,6994,"I'm sorry, Lily,"],[6994,7111,"but I promise I'm going to be there."],[7111,7211,"Don't worry,"],[7211,7248,"alright?"],[7319,7482,"In the meantime,"],[7482,7574,"do you want to see a present"],[7574,7682,"I got your mom?"]],"22":[[225,425,"Brandon, this is too much."],[425,475,"You didn't have to—"],[475,629,"You can't go to your mom's house"],[629,859,"married without a ring on your finger."],[921,992,"Come here."],[2006,2064,"Hi, mom."],[2235,2410,"Where is this husband of yours?"],[2410,2548,"He had an emergency at work."],[2577,2652,"Work?"],[2731,2898,"I thought he was a coffee shop bum."],[3203,3315,"You look thinner."],[3345,3557,"Well, thinner for you."],[4033,4204,"What’s the point of losing weight"],[4204,4295,"if you're not even going to marry"],[4295,4358,"a rich man?"],[4404,4592,"I got healthy to give Lily and I"],[4592,4704,"the best lives possible."],[4859,4917,"Meanwhile,"],[4917,5063,"you smoke four packs a day"],[5063,5180,"just to avoid eating."],[5296,5401,"I'm curvy and fit."],[5401,5513,"My baby girl loves it."],[5513,5618,"My husband loves it."],[5618,5734,"And I'm damn proud of it."],[5789,6001,"Mommy's so pretty and so nice"],[6001,6068,"and so-"]],"23":[[91,208,"If you're not careful,"],[221,337,"you'll end up chubby,"],[337,417,"just like your mother."],[442,533,"You're lucky she's alright."],[533,633,"Oh, please."],[646,779,"That little mistake"],[779,921,"ruined all of our lives."],[921,1146,"Do not call my daughter a mistake."],[1197,1280,"Lily is the best thing"],[1280,1426,"that's ever happened to me."],[1438,1605,"She doesn't expect anything from me"],[1605,1697,"other than love."],[1764,1872,"Unlike you and Mitch,"],[1872,2010,"who clearly just see my marriage"],[2010,2097,"as a transaction"],[2097,2214,"that you should benefit from."],[2214,2406,"I finally found happiness."],[2452,2573,"Now leave me alone."],[2723,2798,"It's true."],[2798,2952,"It may be a contract marriage,"],[2952,3128,"but Brandon makes me so happy."],[3128,3228,"Even if he's searching for"],[3228,3319,"someone else."],[3436,3674,"You ungrateful whore!"],[3691,3803,"Do you know how hard I work"],[3803,3899,"to raise you?"],[3899,4004,"More like how hard you work"],[4004,4083,"to abuse me."],[4208,4258,"I know what being"],[4258,4512,"a good mother is because I am one."],[4512,4671,"I spent the last five years"],[4671,4800,"trying to do everything"],[4800,4909,"the opposite of you."],[5046,5184,"You will divorce this bum"],[5184,5309,"and marry Grimes."],[5309,5459,"Just his wedding gift alone"],[5459,5643,"would be enough to set us for life."],[5718,5818,"Excuse me."],[5897,6010,"What makes you so sure"],[6010,6168,"that my present isn’t as good as his?"]],"24":[[162,412,"Daddy, you're finally here."],[454,525,"Sorry I'm late."],[855,1034,"You must be my mother-in-law."],[1080,1159,"Not for long."],[1192,1326,"You're getting a divorce."],[1413,1630,"Even if my wedding gift is double"],[1630,1743,"the value of Grimes'."],[1760,1810,"Brandon,"],[1810,1885,"you don't have to make"],[1885,1968,"promises like that."],[1968,2043,"It's okay."],[2139,2306,"Enough with the lies."],[2877,3178,"A check for 5 million dollars?"],[3257,3345,"A key to a house"],[3345,3470,"and a brand new Rolex."],[3516,3624,"Now tell me, loser."],[3624,3674,"How on earth"],[3674,3774,"are you going to double that?"],[3791,3903,"Because the only thing more valuable"],[3903,4029,"than this is the Larson family"],[4029,4133,"jewel collection."],[4133,4320,"The Larson family jewel collection huh?"],[4341,4475,"I mean, if you like that so much,"],[4475,4629,"I'll just have them send it right over."],[4913,5055,"Stop insulting us."],[5075,5226,"Those jewels are locked up in a bank"],[5226,5313,"with a secret code"],[5313,5417,"no one has even seen them."],[5618,5768,"Can I borrow your phone?"],[5768,5822,"Trust me."],[6368,6448,"Sentinel bank."],[6468,6552,"Hey, it's BL."],[6552,6760,"My passcode is 7884."],[6873,6994,"Can you have the jewels"],[6994,7165,"sent over to my mother-in-law's"],[7165,7269,"house as a wedding gift?"],[7269,7453,"Certainly, Mr. Larson."],[7469,7645,"Wedding present, congratulations."],[7645,7820,"I'll have the jewels sent over"],[7820,7895,"right away."],[8016,8103,"If this little bitch"],[8103,8220,"thinks Brandon is poor,"],[8220,8316,"she'll divorce him"],[8329,8391,"and I'll be"],[8391,8600,"the new CEO of Larco Industries."],[8600,8717,"I can't let those jewels"],[8717,8812,"leave this building."]],"25":[[116,308,"The champagne is just the start."],[308,412,"Because after Scarlett marries"],[412,513,"Grimes,"],[513,688,"we'll be eating and drinking like royalty."],[909,1076,"Oh, where are my manners?"],[1076,1146,"Want some?"],[1226,1313,"Probably never had any"],[1313,1426,"before in your life."],[1488,1551,"No, thank you."],[1551,1655,"I only drink good wine."],[1689,1789,"Not this cheap stuff."],[1939,2077,"You promised us jewels, hot shot,"],[2077,2189,"so where the hell are they?"],[2189,2352,"Just another one of your lies."],[2369,2435,"Brandon."],[2535,2602,"I don't care"],[2602,2711,"if the jewels aren't coming."],[2756,2902,"I don't care if you're not rich."],[2902,3103,"You're ten times the man that Grimes is."],[3153,3324,"Let's get out of here and go home."],[3374,3511,"Thank you, Scarlett,"],[3561,3770,"but trust me, they're going to be here."],[3770,3837,"Okay?"],[3883,4020,"But how is that possible?"],[4204,4333,"Scarlett, I'm actually-"],[4333,4504,"Aw, how touching."],[4554,4692,"I guess you wouldn't mind that"],[4692,4884,"if the jewels don't arrive"],[4884,4992,"in ten minutes,"],[5092,5192,"you'll marry Grimes?"],[5392,5551,"I've put Brandon through enough,"],[5551,5734,"maybe if I stall he can get away."],[5734,5826,"I swear."],[6373,6544,"Jackie, I need the jewels here now."]],"26":[[0,50,"Hey,"],[104,262,"I'm the real Larson in charge here."],[304,387,"My brother has no right to"],[387,504,"give those jewels away."],[504,679,"And if you do, I'll put a lawsuit"],[679,813,"so far up your fucking ass,"],[813,917,"you'll be shitting subpoenas"],[917,1034,"the rest of your miserable life."],[1034,1117,"Do you understand me?"],[1146,1197,"Yeah? Yeah."],[1197,1313,"Am I making sense to you?"],[1313,1368,"Yes, Mr. Larson- Good."],[1368,1468,"There's only one"],[1493,1576,"Mr. Larson,"],[1576,1747,"in control of the family trust,"],[1810,1951,"and it's Brandon Larson."],[2022,2181,"Would you like to see the paperwork"],[2181,2344,"giving him this authority?"],[2681,2790,"Time's up."],[2831,2948,"Come on, Lily,"],[2948,3065,"smile,"],[3128,3215,"we're rich!"],[3215,3311,"Don't make me teach you"],[3311,3420,"another fucking lesson."],[3420,3541,"I fucking dare you."],[3807,3953,"Sorry for the delay, sir."],[4975,5067,"Impossible!"],[5067,5176,"There's no way those are real,"],[5176,5259,"they can't be."],[5321,5380,"Wait,"],[5417,5576,"when the collection was on the news,"],[5576,5701,"they mentioned each piece"],[5701,5801,"has a serial number."],[5897,5989,"We'll call the bank"],[5989,6106,"and verify each one."]],"27":[[0,91,"Okay, last one."],[125,291,"A diamond necklace,"],[358,558,"2333?"],[558,633,"That's incorrect."],[633,763,"It says 2233."],[763,825,"Aha!"],[825,905,"See, I knew it!"],[905,1055,"Divorce this lying asshole"],[1055,1188,"right now, Scarlett."],[1405,1438,"Wait,"],[1438,1555,"you lost connection?"],[1555,1718,"2233 is correct?"],[1826,1893,"That's it."],[1893,2014,"That's the last of it."],[2014,2135,"It's all real."],[2210,2285,"He probably borrowed it from"],[2285,2598,"his boss at Larco, just to show off."],[2598,2744,"Shut up, you idiot!"],[2756,2802,"Do you know how"],[2802,2948,"valuable this stuff is?"],[2977,3107,"Just let it go."],[3144,3232,"Why?"],[3232,3461,"So this crook can frame us?"],[3532,3728,"No, no."],[3791,3920,"I'll get to the bottom of this."]],"28":[[33,171,"Alright, Mrs. Haynes."],[212,342,"Sign here please."],[663,717,"Yes."],[717,871,"As soon as I sell these babies,"],[871,1101,"I'm moving to a mansion in Florida."],[1188,1317,"I thought you needed that money"],[1317,1422,"for your medical bills."],[1422,1509,"Scarlett,"],[1509,1643,"you may not be fat anymore,"],[1643,1793,"but you're still stupid."],[1793,2010,"You'll believe anything I say."],[2156,2306,"Our business here is concluded."],[2306,2381,"That's it."],[2406,2535,"They're mine."],[2535,2681,"They're all mine."],[2815,2961,"Well, not quite."],[3128,3219,"See, Mrs. Haynes,"],[3219,3374,"you just signed a Parental Severance"],[3374,3449,"Agreement."],[3482,3632,"Meaning that Scarlett here"],[3632,3737,"owes you nothing."],[3737,3799,"And seeing that"],[3799,3908,"these are her assets."],[3908,4137,"Well, I think a Florida mansion"],[4137,4266,"isn't really feasible anymore."],[4304,4533,"You son of a bitch!"],[4533,4688,"And you little slut."],[4688,4900,"You're no blood of mine."],[4900,5025,"You never loved me."],[5117,5347,"The only family I need is right here."],[5347,5480,"Mama. You rock!"],[5593,5684,"Let's go home, baby."],[5889,5960,"Jackie,"],[6010,6093,"pack this up and have it"],[6093,6189,"sent to our house."],[6202,6310,"On it, boss."],[6489,6598,"Scarlett, please."],[6639,6790,"I'm your mother."],[6844,6998,"You're no blood of mine."],[7102,7278,"Scarlett is now an associate of"],[7278,7399,"Larco Industries"],[7399,7557,"and has access to the security"],[7557,7720,"and funds to protect her and Lily."],[7736,7874,"If you ever come looking"],[7874,8012,"for trouble in the future,"],[8012,8195,"I strongly advise against it."],[8283,8404,"Larco Industries?"]],"29":[[150,262,"Sweet dreams, Lily."],[316,421,"We'll see you in the morning."],[421,554,"Daddy, can you take me"],[554,738,"to the park tomorrow?"],[754,871,"I'd love to."],[913,1109,"Hey, did you forget about mommy?"],[1109,1226,"Never."],[1226,1497,"Mommy, can you sing me to bed?"],[1497,1609,"Of course."],[3407,3528,"Surprise!"],[3703,3787,"I didn't know what you like."],[3787,3916,"So I had the chef make"],[3916,3983,"one of everything."],[4045,4175,"This looks amazing."],[4429,4525,"Thank you, Brandon."],[4525,4675,"This was so delicious."],[4767,4859,"I mean I figured we should"],[4859,5009,"get to know each other better, right?"],[5009,5150,"We are married after all."],[5330,5438,"Can I ask you something?"],[5451,5543,"Anything."],[5609,5755,"I couldn't help but overhear"],[5755,5864,"your mom mentioned earlier"],[5864,5964,"that you used to be, um…"]],"30":[[25,154,"Of course you noticed."],[204,308,"My family brings it up"],[308,387,"any time I don't get them"],[387,471,"what they want."],[471,563,"You know, I used to be"],[563,688,"into a curvy girl once."],[804,934,"I think everyone is beautiful"],[934,1051,"just the way that they are."],[1197,1376,"Something seems so familiar"],[1376,1463,"about her."],[1543,1730,"Could she be the one that saved me?"],[1810,1947,"You're okay, it's going to be okay."],[2089,2273,"You saved me."],[2544,2698,"He's remembering her."],[2698,2848,"I wish he'd look at me that way."],[2869,3015,"This girl you were with,"],[3082,3290,"were you together for long?"],[3290,3407,"Not long."],[3470,3628,"People used to tell me that"],[3628,3770,"I needed to look a certain way,"],[3832,4037,"but I tried to block that part"],[4037,4183,"out of my life as much as possible."],[4291,4400,"There was one time that I felt"],[4400,4525,"good about myself."],[4579,4729,"That was when I met Lily's dad."]],"31":[[183,312,"You're so beautiful."],[433,525,"Inside and out."],[658,771,"You're so soft,"],[859,959,"like velvet."],[1668,1755,"Now, my high school"],[1755,1914,"reunion is next week and..."],[2185,2314,"part of me wants to go and"],[2314,2414,"stick it to them."],[2414,2644,"But part of me just wants to avoid it"],[2644,2719,"entirely."],[2719,2994,"No, that's exactly why you should go."],[2994,3186,"They can't hurt you anymore."],[3186,3370,"I'll even go with you if you want."],[3370,3465,"You'd do that?"],[3624,3778,"What are husbands for?"],[4254,4400,"I wonder if he's awake."],[4400,4558,"I wonder if he wants me."],[4558,4675,"Stop it, Scarlett!"],[4675,4763,"You're both searching"],[4763,4850,"for other people."],[4892,5025,"God, I wish I could just hold"],[5025,5188,"Scarlett in my arms."],[5205,5309,"But am I really ready"],[5309,5451,"to give up on my mystery girl?"]],"32":[[91,296,"If I go in there without a husband,"],[296,437,"who knows what my high school bullies"],[437,558,"are going to do to me?"],[558,738,"What's taking Brandon so long?"],[884,992,"Who's that?"],[1030,1205,"Did he go to our highschool?"],[1401,1568,"You look incredible."],[1568,1710,"You don't look too shabby yourself."],[1755,1864,"Shall we?"],[2761,2882,"So far, so good."],[2882,2944,"I don't even think"],[2944,3048,"anyone recognized me."],[3065,3174,"Hey, there's nothing to be"],[3174,3278,"nervous about, you look great."],[3278,3432,"Well, well, well,"],[3470,3578,"look who it is."],[3616,3720,"Be careful everyone."],[3720,3874,"Scarlett Haynes is here."],[3874,4004,"Don't let her near the cake"],[4016,4154,"or there won't be any left for us."]],"33":[[37,196,"Did I mention my brother is dating"],[196,321,"my high school nemesis"],[321,442,"and current boss?"],[479,621,"Fiona owns the cafe that we met at."],[646,813,"Yeah, the Green family."],[850,946,"I know who they are."],[971,1080,"I want to know why you caused"],[1080,1234,"such a ruckus at my business."],[1263,1393,"I'm only letting you work there"],[1393,1530,"because you're Mitch's sister."],[1647,1810,"It was all this loser's fault."],[1856,1956,"Then he had the balls"],[1956,2118,"to borrow the Larson jewels."],[2143,2268,"Just to impress my mom."],[2402,2540,"Grimes found out you got married."],[2540,2610,"Guess who has to"],[2610,2765,"clean up this mess now, huh?"],[2777,2815,"Me!"],[2844,2973,"I didn't borrow"],[2973,3144,"the Larson family jewels."],[3144,3324,"Your mother's just a lowlife who tried"],[3324,3490,"to steal it when it belongs to Scarlett."],[3545,3687,"I just prevented her from doing it."]],"34":[[83,162,"We're not going to have another"],[162,258,"incident, are we?"],[325,546,"If you didn't borrow the jewels,"],[546,784,"that would make you a Larson, right?"],[955,1067,"I'm going to go make a phone call,"],[1067,1101,"okay?"],[1647,1822,"Listen here, you little bitch."],[1822,1914,"I own you."],[1956,2060,"And unless you want to feed"],[2060,2185,"that worthless man of yours"],[2185,2310,"with food stamps,"],[2310,2414,"you'll do as I say."],[2927,3044,"Eat it."],[3044,3157,"Or you're fired."],[3374,3461,"Everyone,"],[3495,3757,"Scarlett is accepting dessert donations."],[3757,3912,"Eat up, porky."],[3912,4145,"Eat! Eat! Eat!"],[4166,4362,"Eat! Eat! Eat!"],[4396,4579,"Eat! Eat! Eat!"],[4596,4738,"Eat! Eat! Eat!"],[4758,4879,"Eat! Eat! Eat!"],[4904,5017,"Eat! Eat! Eat!"],[5038,5155,"Eat! Eat! Eat!"],[5171,5288,"Eat! Eat! Eat!"]],"35":[[0,79,"Eat! Eat!"],[79,216,"I've come so far for my baby"],[216,333,"and for myself."],[346,554,"If I lose my job, I lose everything."],[554,658,"This is for you, Lily."],[658,817,"Eat! Eat! Eat!"],[825,967,"Eat! Eat! Eat!"],[1226,1313,"Did you think it was going to be"],[1313,1397,"that easy?"],[1451,1555,"On your knees."],[1647,1705,"Now!"],[2339,2573,"Eat it out of my hand, like a dog."],[3069,3232,"Oh! My shoe!"],[3232,3382,"You stupid cow!"],[3382,3507,"You're fired!"],[3632,3807,"Scarlett!"],[3807,3933,"Let's just get out of here, Brandon."],[3933,4033,"I want to go home."],[4179,4391,"What is my family's lawyer doing here?"],[4421,4508,"Ms. Green."],[4587,4888,"You have to sign the deed"],[4959,5125,"to transfer ownership"],[5125,5255,"of the cafe"],[5255,5321,"immediately."],[5321,5376,"What?"],[5376,5497,"You sold the cafe?"],[5547,5693,"Well, it's my inheritance."],[5693,5789,"You have no right."],[5789,5939,"Not me, your father,"],[5939,6210,"and he is, waiting for your signature, so"],[6256,6339,"if you would."],[6339,6481,"Well, who did he sell it to?"],[6544,6581,"Well..."],[6735,6785,"them."]],"36":[[0,158,"This is some kind of joke."],[158,321,"I can get you fired for this."],[321,458,"Brandon, what's going on?"],[579,688,"You don't deserve to work"],[688,817,"for someone like Fiona."],[963,1088,"You're your own boss now."],[1259,1330,"But how did you-"],[1330,1434,"I'll explain when we get home,"],[1434,1568,"let's just get this deal done."],[1722,1864,"Your father got an offer"],[1864,1993,"from LARCO Industries,"],[1993,2127,"he couldn't refuse."],[2177,2327,"LARCO is giving us one hour"],[2327,2452,"to close this deal."],[2452,2594,"I'm so sorry, Ms. Fiona."],[2686,2802,"So you're telling me"],[2802,2894,"this man"],[2894,2986,"is a Larson?"],[3111,3303,"Like a Larson of LARCO?"],[3370,3516,"No, no, no, it can't be."],[3516,3582,"But..."],[3607,3716,"maybe he is."],[3716,3816,"Hell, no."],[3832,3999,"Don't even entertain for a second"],[3999,4254,"that this lowlife scum is a Larson."],[4341,4600,"I actually work at LARCO Industries,"],[4633,4733,"and there's no way"],[4733,4846,"that this man is a Larson."],[4846,5125,"Nor does he have the authority"],[5171,5292,"to use funds like that."],[5313,5455,"Is that a fact?"],[5455,5618,"You work at LARCO Industries."],[5618,5822,"Jennifer, why don't you share with"],[5822,6006,"everyone what department you work"],[6006,6093,"in at LARCO."],[6093,6197,"Why don't you shut up?"],[6231,6335,"You know you can't con your way"],[6335,6435,"out of this one, right?"],[6435,6544,"Did you hear that?"],[6544,6648,"He's not even a Larson."],[6781,7011,"Perhaps I've made a mistake."]],"37":[[479,608,"Biggest loser in high school."],[608,721,"Still the biggest loser"],[721,834,"ten years later."],[834,930,"Go figure."],[946,1180,"Where is your bastard child?"],[1180,1334,"You tell anybody about how you got"],[1334,1480,"knocked up on a one night stand?"],[1493,1668,"At least I don't scrub toilets now"],[1668,1760,"like Jennifer."],[1760,1893,"And at least I'm not dating a huge"],[1893,2043,"asshole like my brother."],[2043,2110,"Who the fuck"],[2110,2210,"are you calling an asshole?"],[2210,2331,"You ungrateful little bitch!"],[2548,2686,"Did you all see that?"],[2765,2852,"Assault!"],[2898,3032,"I'm calling the cops!"],[3115,3286,"Have them arrested for impersonation"],[3286,3382,"and assault."],[3858,3912,"That man"],[3912,4045,"threatened my wife first."],[4083,4245,"My own sister? Please."],[4245,4350,"I would never."],[4433,4554,"Let me make one phone call."],[4554,4642,"I'll clear this all up."],[4642,4721,"Make it at the station."],[4942,5050,"Hold it right there."],[5100,5171,"Mr. Green,"],[5171,5230,"thank goodness you're here, sir."],[5230,5376,"Daddy, these crooks are trying to"],[5376,5497,"con us out of our cafes"],[5497,5580,"in order to give them"],[5580,5759,"to his little whore."],[5818,6031,"I'm so sorry, sir."],[6072,6168,"Sorry?"],[6168,6322,"This man doesn't deserve to breathe"],[6322,6448,"the same air as you."],[6523,6614,"Enough, Fiona!"],[6806,7069,"Arthur, you're an absolute moron"],[7069,7261,"for listening to my ignorant daughter."],[7261,7344,"You're fired!"]],"38":[[0,129,"There's been a mistake, officers."],[129,241,"This man is innocent."],[396,500,"Anything you say, Mr. Green."],[575,650,"Mr. Green,"],[667,875,"this man is an imposter,"],[992,1176,"and my sister is just a slut"],[1176,1259,"who doesn't even know who"],[1259,1443,"the father of her own kid is."],[1597,1755,"Open your mouth again"],[1755,1910,"and I'll break your legs!"],[1910,2068,"You piece of trash."],[2068,2227,"Now get out of here!"],[2227,2281,"Shoe!"],[2414,2585,"I hope I'm not too late."],[2681,2869,"And we can still close the deal"],[2869,3011,"on our agreed upon terms."],[3174,3294,"Our deal's still on, Green."],[3411,3549,"Who is this man I married?"],[3895,4129,"Hey, do you really want to"],[4129,4229,"take him out?"],[4229,4379,"I know exactly who to talk to."],[4421,4550,"The real Larson in charge."]],"39":[[0,75,"But daddy,"],[75,171,"Scarlett's husband"],[171,367,"is nothing more than a dirty lowlife."],[567,850,"This man is Brandon Larson,"],[850,1151,"CEO of LARCO Industries."],[1155,1347,"You foolish girl!"],[1388,1601,"God, what have I done?"],[1705,1889,"Wait, Brandon, is this true?"],[1956,2218,"My daughter will sign immediately,"],[2218,2327,"Mr. Larson."],[2327,2548,"Pick up the deed from the floor,"],[2581,2740,"or I'll cut you off"],[2740,2927,"for the rest of your life."],[3490,3595,"As of now,"],[3595,3803,"the chain of cafes"],[3803,3974,"belongs to Mrs. Larson."],[3974,4087,"Congratulations."],[4158,4312,"Green, I have one more request."],[4312,4458,"Tonight your daughter"],[4458,4592,"humiliated my wife."],[4592,4717,"I demand that she eat"],[4717,4884,"the rest of that cake"],[4884,4988,"right here, right now,"],[4988,5080,"in front of everyone."],[5134,5242,"Yes, Mr. Larson."],[5251,5292,"No."],[5430,5484,"Come on."],[6035,6197,"Mr. Larson."],[6197,6352,"How can you be married to someone"],[6352,6514,"so beneath you?"],[6581,6723,"She used to be a hotel maid."],[6723,6840,"I bet she didn't tell you that."],[6840,6911,"Quiet!"],[6911,7057,"You'll ruin everything."],[7102,7219,"A hotel maid?"],[7240,7332,"Is Scarlett the one"],[7332,7407,"that saved me from"],[7407,7515,"the pool that night?"],[7645,7711,"It's okay."],[8124,8216,"Could she really be the girl"],[8216,8341,"that I've been looking for?"]],"40":[[191,279,"I can't believe I thought"],[279,421,"you were just a security guard."],[508,675,"This mansion makes sense now."],[767,838,"You're like"],[838,980,"the wealthiest man in town."],[1059,1226,"I bet this isn't even your only house."],[1238,1334,"You're right."],[1334,1430,"I have ten,"],[1484,1618,"but it is my smallest."],[1618,1726,"I will say that."],[1906,2185,"Look, I'm so sorry, Scarlett."],[2185,2352,"Brandon, why didn't you tell me"],[2352,2464,"you were a Larson?"],[2464,2573,"I don't like to live"],[2573,2686,"like the rest of my family."],[2719,2898,"They love flaunting their wealth off"],[2898,2998,"in garish displays,"],[2998,3153,"like my brother, Reggie does."],[3165,3332,"Who's the worst, by the way."],[3382,3545,"But Scarlett..."],[3674,3870,"Were you really a hotel maid?"],[3903,3991,"Oh, no."],[3991,4074,"He's going to leave me"],[4074,4250,"if he thinks I was a maid."],[4250,4391,"No, Fiona was just trying"],[4391,4471,"to humiliate me."],[4508,4633,"I need to stop comparing her"],[4633,4721,"to the mystery girl."],[4742,4863,"It's not fair to Scarlett."],[4896,5067,"God, I've been such an asshole."],[5134,5397,"Look, I know this is a contract marriage,"],[5397,5430,"you know?"],[5430,5547,"And I didn't want to complicate things"],[5547,5701,"by getting money involved."],[5701,5885,"But you're unlike anyone"],[5885,5955,"I've ever met."],[5955,6122,"I learned that very, very quickly."],[6256,6377,"I can see it in your eyes that you"],[6377,6514,"really care about me."],[6514,6677,"Who I really am."],[6677,6844,"I don't know how it happened, but..."],[6927,7077,"this isn't just a contract marriage"],[7077,7165,"for me either."],[7357,7474,"Me either."],[7532,7678,"I never want to lose you."],[8654,8733,"Brandon."],[8825,8938,"I've got to take you to bed now,"],[8938,9013,"Mrs. Larson."],[9059,9159,"I thought you'd never ask,"],[9159,9255,"Mr. Larson."],[9321,9455,"I've always dreamed of a man"],[9455,9563,"carrying me to bed."],[9563,9642,"I didn't think it would"],[9642,9718,"ever come true."]],"41":[[650,821,"I've wanted to do this for so long,"],[821,1038,"I just didn't know if you wanted it too."],[1051,1151,"I want this."],[1151,1255,"I've been wanting this."],[2064,2227,"You're so soft."],[3324,3490,"Why do you feel so familiar?"],[3507,3591,"I don't know."],[3716,3812,"I don't care."],[4371,4542,"You're so damn beautiful."],[4567,4750,"You make me feel so sexy."],[4846,5000,"I want to make you feel everything."],[5130,5221,"Say it."],[5338,5442,"I want you."],[5501,5638,"I want you, too."],[5789,5897,"I always have."]],"42":[[575,642,"Ready?"],[1138,1259,"Oh my goodness."],[1259,1438,"Did you make my favorite breakfast"],[1438,1626,"in the whole entire world?"],[2214,2256,"You know what?"],[2256,2381,"I think you need some right"],[2381,2419,"here."],[2419,2506,"Okay."],[2577,2627,"Yeah."],[2665,2736,"Got you back."],[2736,2823,"Oh my gosh."],[2869,3028,"I don't want this breakfast to end,"],[3090,3328,"but I have to go to work."],[3328,3436,"You own the cafe now,"],[3436,3586,"you can turn it into whatever you want."],[3624,3741,"You don't have to go to work."],[3741,3816,"Pinch me."],[3816,3878,"Please."],[4058,4183,"I can't wait to incorporate"],[4183,4312,"some new changes to the menu."],[4312,4487,"I want to add some healthier options."],[4579,4725,"Come on, Lily, let's get your things."],[4725,4825,"We've got to go to preschool."],[4838,4963,"Hey, I was actually thinking"],[4963,5138,"Lily could come to work with me today."],[5221,5321,"She's my stepdaughter now."],[5321,5467,"She's going to be CEO someday."]],"43":[[87,171,"Scarlett,"],[287,496,"were you really a hotel maid?"],[688,896,"Brandon's the richest man in town."],[896,971,"He's not going to want to"],[971,1096,"stay with me when he finds out"],[1096,1242,"I was actually a maid."],[1242,1376,"I have to protect my heart."],[1434,1601,"That's sweet of you, Brandon."],[1614,1814,"But Lily's father is still out there,"],[1814,1947,"and I can't give up on him entirely."],[1976,2139,"But what about last night?"],[2139,2318,"I'll still run the cafe for you."],[2318,2427,"While you look for that woman"],[2427,2544,"you're searching for."],[2544,2715,"She's pulling back."],[2715,2811,"I guess she's not over"],[2811,2990,"Lily's biological father."],[3090,3148,"Alright,"],[3148,3240,"I'm still going to take Lily"],[3240,3361,"to work with me though."],[3361,3503,"That way you can get started."],[3557,3620,"Thanks."],[3753,3958,"Wait, isn't your brother, Reggie?"],[3958,4120,"He also has claims to company?"],[4120,4191,"No."],[4279,4383,"He won't be CEO."],[4579,4708,"At least not while I'm around."],[4975,5134,"Thank you so much for seeing us, sir."],[5134,5267,"We knew we could count on you."]],"44":[[45,179,"That lowlife"],[204,300,"is not"],[346,471,"an executive at LARCO."],[542,629,"Your cousin Jackie has"],[629,725,"got a crush on him."],[725,834,"And that is why"],[859,963,"she lets him off the hook."],[963,1067,"I knew it."],[1067,1263,"That criminal married my sister."],[1272,1413,"I can't let this loser"],[1413,1509,"know it's Brandon."],[1534,1672,"He'd be over the moon"],[1672,1814,"that his sister's already married"],[1814,1935,"to the richest man in the city."],[1935,2143,"But, I can play this to my advantage."],[2168,2285,"I understand"],[2285,2398,"she was supposed to marry"],[2398,2540,"Maxwell Grimes?"],[2540,2640,"Well,"],[2640,2802,"I know Grimes quite well."],[2827,2994,"In fact, I can make this whole"],[2994,3128,"misunderstanding disappear."],[3128,3215,"If you,"],[3278,3382,"take that piece of trash out,"],[3382,3470,"if you know what I mean."],[3520,3566,"If..."],[3620,3720,"If you're sure that's the only-"],[3720,3787,"I am sure."],[3874,3953,"And you."],[3966,4033,"I'll..."],[4183,4325,"I'll give you your cousin's job"],[4325,4412,"if you help him."],[4412,4479,"With pleasure."],[4913,5005,"Thanks for saving me the trouble"],[5005,5109,"of a severance package."]],"45":[[729,779,"Hey!"],[779,875,"They're here, they're here."],[875,925,"You're sure we have to"],[925,1021,"eliminate the kid?"],[1051,1142,"You said it yourself."],[1159,1234,"She's got to go."],[1234,1288,"Plus,"],[1288,1426,"Grimes won't take Scarlett with her."],[1726,1868,"Hi, Lily."],[1881,1989,"I am really sorry"],[1989,2093,"that I threw your lollipop"],[2093,2198,"on the ground the other day."],[2248,2515,"So I bought you two more,"],[2515,2619,"so you can share with daddy."],[2619,2744,"You were really mean"],[2744,2823,"to my mommy."],[2823,3165,"But mama said to forgive people."],[3165,3269,"That's right, kid."],[3299,3415,"So, just make sure."],[3449,3499,"There you go."],[3528,3687,"But, just don't tell your daddy"],[3687,3799,"where you got it from, okay?"],[3908,4008,"There you go."],[4120,4220,"Go ahead."]],"46":[[1255,1330,"I wish Brandon"],[1330,1459,"were Lily's real father."],[1789,1981,"Is it lollipop time?"],[2185,2302,"Of course, sweetie."],[2348,2419,"Here you go."],[2998,3257,"Look, it's momma's earring."],[3415,3528,"What did you just say?"],[3770,3953,"It's mama's earring."],[4012,4099,"Lily, did you just say"],[4099,4204,"this is mommy's earring?"],[4225,4475,"That's how I knew you were my daddy."],[4625,4713,"Momma look,"],[4733,4975,"that man has the other earring."],[5096,5234,"You were right, sweetheart."],[5518,5659,"If Scarlett's my mystery girl,"],[5659,5793,"then that means..."],[5826,6010,"Lily's my biological daughter."]],"47":[[346,483,"Is Lily okay?"],[483,650,"She's doing just fine, Mama bear."],[663,846,"She's actually doing better than fine."],[971,1142,"Scarlett, I need you to get over to LARCO"],[1142,1301,"right now. I need to tell you something."],[1301,1355,"Right now?"],[1359,1497,"I'm kind of needed here."],[1497,1622,"I'm the new boss."],[1622,1755,"Yeah, you're the new boss"],[1755,1856,"which means you can ditch"],[1856,1926,"in the middle of the day."],[1926,2039,"Please, just get over here"],[2039,2139,"as soon as you can."],[2139,2314,"You're being so mysterious."],[2385,2460,"Is Lily okay?"],[2460,2560,"Lily's doing fine."],[2560,2686,"She's doing better than fine."],[2686,2756,"I'm doing amazing."],[2756,2898,"Just get over here."],[2898,3007,"I need to tell you something"],[3007,3119,"and I can't tell you over the phone,"],[3119,3169,"please."],[3169,3307,"Okay, I'll leave right now."],[3386,3478,"Scarlett,"],[3528,3616,"I love you."],[3728,3933,"Brandon, did you just say-"],[3933,4020,"I did."],[4116,4262,"See you soon."],[4446,4529,"Hey, Scarlett,"],[4529,4654,"they said there's a supplier outside"],[4654,4754,"who wants to talk to you."],[4767,4871,"They said it's urgent."],[4938,5075,"Okay, I'll be right out."]],"48":[[150,262,"The caller you are trying to reach"],[262,362,"is unavailable."],[379,467,"Please hang up-"],[467,546,"Let's head downstairs."],[604,663,"Let's go."],[955,1071,"That's the lady"],[1071,1276,"who gave me the lollipop."],[1313,1401,"Momma's friend."],[1455,1609,"That's not momma's friend, Lily."],[1643,1768,"Stay here with Jackie, okay?"],[2014,2089,"Just one lick"],[2089,2210,"to prove that you're innocent."],[2352,2494,"Where's my wife?"],[2686,2831,"Where's Mrs. Larson?"],[2998,3107,"Mrs. Larson?"]],"49":[[133,204,"Thank you again."],[379,496,"She better come this time."],[533,725,"No one rejects me twice."],[925,1096,"It's your lucky day, sis."],[1155,1263,"Grimes here has offered us"],[1263,1384,"a second chance."],[1534,1735,"I strongly suggest you take it."],[2018,2097,"This bitch's phone"],[2097,2198,"hasn't stopped ringing."],[2790,2915,"Your brother really wasn't lying,"],[2915,2969,"was he?"],[3053,3224,"You really are a gorgeous girl."],[3470,3624,"I like it when they put up a fight."],[3749,3891,"This is pointless."],[3941,4058,"I'm already married."],[4058,4220,"There's nothing you can do about it."],[4233,4346,"See, that's where you're wrong."],[4379,4496,"Your asshole husband"],[4496,4683,"had a little bit of an accident"],[4683,4775,"this afternoon."],[4833,4988,"You're a widow now, sis."],[5038,5105,"No."],[5296,5388,"No, you're lying."],[5492,5543,"No."],[5647,5697,"No."],[5847,5897,"No."]],"50":[[33,87,"Hey!"],[175,304,"Pull yourself together."],[321,513,"That scum isn't worth crying over."],[513,679,"You have two options, Scarlett."],[717,838,"Either marry Grimes"],[884,1026,"and never worry about money again."],[1038,1138,"Or wind up homeless"],[1138,1209,"on the street."],[1213,1267,"Your choice!"],[1267,1317,"No!"],[1434,1643,"You sold my wife to Grimes?"],[1643,1701,"Brandon, what?"],[1701,1830,"What the fuck are you talking about?"],[2043,2106,"Someone help!"],[2106,2185,"Security, please!"],[2185,2260,"Anyone help!"],[2260,2364,"Don't you worry."],[2364,2506,"The police are already on their way"],[2506,2665,"to arrest you for attempted murder."],[3136,3224,"Five years ago"],[3224,3324,"you're the one that drugged me"],[3324,3415,"and threw me in that pool."],[3415,3545,"It's so clear to me now."],[3557,3607,"Get off me."],[3607,3707,"You're imagining things."],[3741,3837,"You can't even remember the girl"],[3837,3941,"you fell in love with that night."],[4016,4175,"I do now, but she's in danger"],[4175,4258,"because of you."],[4258,4529,"Where the fuck is Grimes?"],[4529,4617,"Okay, okay, okay, I'll tell you."],[4617,4679,"I'll tell you."],[4679,4754,"I'll tell you, I swear."]],"51":[[300,350,"Now,"],[383,500,"I know you don't deserve it,"],[571,684,"but you’ll wear this"],[817,917,"for my sake."],[996,1238,"I want to be able to rip it off"],[1238,1380,"after the ceremony."],[2264,2473,"You stupid bitch!"],[2723,2907,"I'm so sorry about this, sir."],[2907,3032,"She’ll pay for this."],[3136,3307,"You're going to kiss Grimes' feet,"],[3307,3420,"do you hear me?"],[3420,3507,"Do it!"],[3586,3670,"Mr. Grimes."],[3687,3757,"A man has just entered"],[3757,3807,"the building."]],"52":[[4,120,"Impossible."],[120,254,"How did he get past the guards?"],[271,346,"Could it be..."],[383,433,"You."],[475,583,"Go and help now."],[650,800,"If he makes it up one more level,"],[821,946,"you are fired!"],[2640,2773,"You told me he was dead."],[2773,2869,"I, I..."],[2869,2982,"I poisoned the candy."],[2982,3132,"We saw the brat take it to him."],[3165,3240,"Candy?"],[3311,3449,"What did you do to my daughter?"],[3532,3620,"If you touched her,"],[3620,3737,"I swear to God!"],[3745,3807,"You'll what?"],[3903,3958,"Kill me?"],[4083,4220,"I'd like to see you try."],[4504,4633,"They must have gotten him."],[4721,4833,"Come in, come in."],[4833,5038,"Let's see that scumbag's body."],[5409,5605,"I assure you, this blood isn't mine."],[5605,5789,"Who the fuck do you think you are?"],[5789,6010,"I'm Brandon Larson,"],[6010,6181,"CEO of Larco Enterprises."]],"53":[[0,166,"He's lying, Mr. Grimes."],[329,404,"Are you okay?"],[404,471,"Did they hurt you?"],[471,529,"I'll be alright."],[529,617,"But, Lily, is she okay?"],[617,675,"She's fine."],[675,800,"She's fine. She's with Jackie."],[859,909,"Okay?"],[1001,1105,"I think you might be missing this,"],[1105,1155,"though."],[1476,1597,"But how did you?"],[1797,1868,"It was you."],[2010,2110,"It was always you."],[2331,2456,"Do you really expect me"],[2456,2573,"to believe that you are the richest"],[2573,2660,"man in the city?"],[2660,2777,"You've already met me once,"],[2777,2844,"Mr. Grimes."],[2844,2936,"Don't you remember?"],[3269,3436,"Please, Mr. Larson,"],[3486,3599,"only you can save"],[3599,3695,"Grimes incorporated."],[3832,4037,"Our stock is tanking by the minute."],[4074,4179,"If we crash,"],[4275,4567,"all business in the city will suffer."],[4567,4658,"I know I'm young,"],[4658,4788,"but I don't need an economics lesson"],[4788,4909,"from a failing business man,"],[4909,4996,"Mr. Grimes."],[4996,5192,"Time's a ruthless thing, isn't it?"],[5251,5426,"Looks like you don't have much left."],[5497,5605,"Unless a man 30 years"],[5605,5759,"your junior saves your ass."],[5839,5922,"Admit it."],[6473,6610,"Your time's out, old man."]],"54":[[0,108,"This is a pretty shitty way"],[108,191,"to treat someone"],[191,296,"who you're in debt to."],[371,571,"Well? Is he actually a Larson?"],[804,921,"I can't know for sure,"],[1009,1101,"but I am good friends with"],[1101,1180,"Reggie Larson."],[1276,1405,"I'll just send your picture to him"],[1405,1505,"and we'll know for sure."],[1539,1643,"No, no, it can't be."],[1655,1755,"Why would Reggie"],[1755,1843,"set up his own brother?"],[1868,1981,"Plenty of reasons."],[2022,2168,"His envy for my position"],[2168,2323,"as CEO being the main one."],[2348,2419,"But then,"],[2502,2565,"that would mean"],[2565,2665,"Scarlett, you're..."],[2694,2848,"you're richer than Grimes."],[2848,2940,"If it's true."],[2957,3078,"I'm sending this to Reggie."],[3078,3182,"It's going to be a little tough"],[3182,3303,"for him to respond right now."],[3303,3374,"You see,"],[3436,3620,"he's currently in police custody"],[3636,3741,"for attempted murder."],[3787,3912,"The only reason I didn't call them"],[3912,3995,"on you criminals"],[3995,4108,"is to check on Scarlett."],[4108,4200,"Because if anything"],[4200,4300,"would have happened to her,"],[4300,4396,"I swear to God,"],[4396,4525,"I would have ended you both."],[4558,4617,"He's lying."],[4617,4754,"He's trying to stall."],[4875,4979,"We'll know soon enough."]],"55":[[0,91,"Enough talking"],[125,204,"and enough of these"],[204,291,"fucking games."],[300,371,"Prove to me"],[371,475,"that you’re Brandon Larson"],[475,538,"Right now,"],[583,725,"or I'm going to pull this trigger."],[725,809,"Scarlett."],[821,992,"Scarlett, just listen to my voice, okay?"],[992,1076,"It's going to be all right."],[1076,1230,"I wouldn't be so sure."],[1372,1463,"Hello, mother."],[1463,1547,"You can come up now."],[1601,1676,"Mother?"],[1755,2014,"Oh, now you are screwed."],[2014,2139,"I know Phyllis Larson."],[2139,2331,"In fact, I've got a meeting"],[2331,2439,"with her next week."],[2469,2631,"There is no way in hell-"],[2706,2794,"Drop your gun."],[2911,2952,"Now!"],[3641,3749,"Mrs. Larson."],[3749,3841,"Phyllis."],[3841,3962,"Welcome back to town. I-"],[3962,4237,"It’s not completely your fault, Maxwell."],[4258,4408,"Well, you are a crook."],[4471,4575,"But,"],[4596,4704,"my son, Brandon."],[4742,4992,"He prefers to stay out of the spotlight."],[4992,5180,"Could have saved us all a lot of trouble"],[5180,5334,"if he just showed his handsome face"],[5334,5447,"every now and then."],[5476,5580,"Mother, please."],[6010,6243,"Consider our meeting next week."],[6243,6356,"Cancelled."],[6627,6785,"Why didn't you tell me he was rich?"],[6785,6894,"That would have changed"],[6894,6990,"everything."],[6990,7173,"Because my husband's money"],[7173,7357,"has nothing to do with you."],[7374,7486,"I'm your brother."],[7624,7745,"And I'm your sister."],[7770,7857,"That never saved me"],[7857,7937,"from your cruelty."]],"56":[[4,87,"So,"],[183,283,"you must be my new"],[283,367,"daughter-in-law."],[412,521,"Nice to meet you, ma'am."],[558,725,"No need to be formal."],[863,963,"I want to thank you"],[963,1163,"for saving my son's life."],[1255,1380,"It was an honor, Mrs. Larson."],[1380,1539,"Call me Phyllis."],[1539,1685,"I had a chance to meet my"],[1685,1860,"adorable granddaughter."],[1947,2173,"You know, all I ever wanted for you"],[2173,2327,"was to be with somebody"],[2327,2577,"who is beautiful inside and out."],[2577,2694,"Well done, son."],[2748,2865,"So proud of you."],[2919,3048,"Thanks, mom."],[3136,3249,"Lily's downstairs."],[3290,3411,"Let's go."],[4245,4400,"Mommy!"],[4496,4562,"Lily!"],[4596,4717,"You knew the whole time?"],[4838,5080,"I was calling him daddy, wasn't I?"],[5080,5259,"You're my genius, baby."],[5309,5597,"I’m going to be a CEO of LARCO."]],"57":[[392,475,"Brandon,"],[475,600,"what is all this?"],[600,784,"We keep doing things out of order."],[821,955,"First, we had a baby..."],[1238,1313,"Stop it, Mitch."],[1313,1405,"Don't do this!"],[1722,1851,"I'm Scarlett Haynes."],[1893,1972,"I look forward to doing"],[1972,2056,"business with you."],[2131,2243,"I'm Brandon,"],[2293,2435,"it's a pleasure to meet you, Scarlett."],[2973,3115,"Eat it out of my hand"],[3115,3194,"like a dog."],[3445,3524,"Scarlett!"],[3862,3966,"Will you marry me?"]],"58":[[108,212,"Will you marry me?"],[316,383,"Again?"],[583,734,"Say yes, momma!"],[846,963,"Of course I will."],[3098,3219,"Oh, Brandon."],[3532,3632,"I chose something that I knew"],[3632,3716,"would show you off."],[3757,3970,"Alright, Jackie helped me,"],[4041,4187,"but I'm taking credit for it."],[4871,4967,"Now get out of here."],[4979,5075,"It's bad luck to see the bride"],[5075,5150,"before the wedding."],[5150,5205,"Okay."],[5259,5347,"I'll see you at the altar,"],[5347,5430,"Ms. Larson."]],"59":[[346,442,"Now get out of here."],[454,550,"It's bad luck to see the bride"],[550,625,"before the wedding."],[625,679,"Okay."],[734,821,"I'll see you at the altar,"],[821,905,"Ms. Larson."],[3407,3578,"Do you promise to love,"],[3578,3837,"protect and cherish each other"],[3874,4054,"as long as you both shall live?"],[4124,4183,"I do."],[4266,4316,"I do."],[4333,4421,"I do, too."],[4771,4917,"Then, I now pronounce you"],[4917,5009,"man and wife."],[5009,5184,"You may as well kiss the bride."]]}