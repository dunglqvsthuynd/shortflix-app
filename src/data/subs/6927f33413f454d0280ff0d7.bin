{"1":[[204,371,"Before my mom died,"],[371,471,"she arranged my marriage"],[471,608,"to Elliott Hargrove,"],[608,834,"to secure my future as Prima Ballerina"],[834,992,"of the Hargrove Ballet Company."],[1067,1180,"Against her wishes,"],[1180,1359,"my father and my step-mom"],[1359,1589,"sent me to live on a farm in Indiana,"],[1589,1760,"but I never stopped training,"],[1760,1976,"waiting for the day I'd marry Elliott,"],[1976,2131,"and finally live the dream"],[2131,2268,"that was stolen from me."],[2460,2585,"Dad's calling me to New York City"],[2585,2740,"to break off my engagement"],[2740,2844,"but I won't"],[2844,3003,"let him ruin my dreams again."],[3899,4045,"Hey, what are you-"],[4045,4166,"Shh."],[5130,5338,"Nobody move!"],[5818,5947,"Viper!"],[5989,6135,"Where are you?"],[6406,6448,"What?"],[6752,6835,"Shh, shh..."],[7032,7094,"Good."],[7165,7294,"Now moan for me."],[7365,7424,"Huh?"],[7432,7745,"Or, I slit your pretty little throat."],[7745,7970,"But I can't. I don't... I don't know how."],[7982,8083,"How old are you?"],[8083,8183,"22."],[8254,8333,"Then don't act like"],[8333,8466,"you don't know what you're doing."],[9138,9409,"He's not getting away again!"],[9409,9559,"Boss, he's the Viper,"],[9559,9672,"the deadliest assassin"],[9672,9801,"on the planet."],[9801,9914,"He slaughtered fourteen"],[9914,10005,"of our best guys"],[10005,10126,"before we even had eyes-"],[10126,10314,"If you can't do it,"],[10331,10523,"then fifty million to whoever brings me"],[10523,10623,"the Viper's head!"],[10723,10756,"Okay."],[10756,10877,"Go, get out the way!"],[10906,10969,"Come on!"],[11319,11407,"I said,"],[11436,11720,"moan, or I'll make you."],[11861,11961,"Okay, okay."]],"2":[[25,95,"What are you doing?"],[95,183,"Get out of here!"],[183,358,"Oh, well maybe don't fuck in public"],[358,525,"if you don't want people to watch."],[525,688,"All right, keep it fucking moving."],[688,742,"Come on!"],[742,871,"He's gotta be here somewhere."],[871,946,"Get going!"],[946,1076,"I protected you,"],[1134,1292,"now your gun will help me"],[1292,1413,"protect myself."],[1901,1993,"Thank you,"],[2014,2143,"Miss..."],[2168,2260,"Nobody."],[2281,2506,"Well, Miss Nobody."],[2506,2602,"I owe you my life."],[2602,2731,"How much do you want in return?"],[2731,2886,"I don't want your dirty money."],[2907,3065,"I want you to get out of my room."],[3065,3136,"Dirty?"],[3240,3445,"You have no idea who you're talking to."],[4679,4925,"See you around, Miss Nobody."],[6122,6318,"There was blood on his face,"],[6364,6560,"and those mobsters were after him."],[6598,6852,"He had a hidden gun, a gun I stole."],[6915,7023,"What kind of deadly trap"],[7023,7144,"have I fallen into?"],[8654,8771,"Hannah!"],[8825,9025,"You were such an ugly baby."],[9025,9129,"But look,"],[9129,9330,"you grew into that nose."],[9405,9476,"Do you remember"],[9476,9634,"your half-sister, Valerie?"],[9634,9730,"We'll take you"],[9730,9947,"to the Hargrove Studio tomorrow."],[9947,10176,"Ew, do they not have running water"],[10176,10306,"in bumfuck, Indiana?"],[10389,10568,"Be nice, Valerie."],[10568,10756,"You know Hannah grew up"],[10756,10923,"in foster care."],[11052,11165,"Still dancing?"],[11165,11227,"I didn't know"],[11227,11436,"they taught ballet on the farm."],[11436,11544,"I wouldn't call pirouetting"],[11544,11678,"through pig shit"],[11678,11778,"dancing."],[11795,11911,"My stepmom's the reason"],[11911,12020,"my dad sent me away."],[12091,12224,"Just wait until I become"],[12224,12437,"prima ballerina of the Hargrove Ballet"],[12474,12662,"and take back what belongs to me."],[12696,12892,"Valerie will dance circles"],[12892,13088,"around this farm animal."],[13088,13234,"She really thinks"],[13234,13421,"she has a chance with a Hargrove?"],[13442,13563,"Pathetic."],[13580,13784,"As soon as Elliott sees Valerie,"],[13784,13897,"it's game over."],[13897,13968,"If you embarrass me"],[13968,14118,"in front of the Hargroves tomorrow,"],[14139,14280,"I'll scratch your eyes out."],[14710,14810,"Got it."],[14935,15094,"Hello, little thief."],[15127,15281,"You're in my city now."],[15331,15490,"Things are about to get interesting."]],"3":[[154,262,"Picked off a dozen of"],[262,383,"Rivalchek's best guys,"],[383,575,"but the head of the beast"],[575,671,"still needs slaying."],[892,1051,"Looks like those dirtbag mobsters"],[1051,1238,"don't appreciate you cleaning house."],[1238,1397,"The bounty on your head just went up."],[1397,1534,"Any intel on that woman?"],[1576,1747,"Ah, the train records show nothing."],[1780,1889,"Checked them myself."],[1935,2035,"And the little thief"],[2035,2189,"swiped my favorite gun."],[2264,2369,"Find her for me."],[2498,2627,"I wanna thank her,"],[2798,2877,"properly."],[3490,3595,"Again."],[3862,4037,"You are hopeless."],[4179,4316,"Loyola!"],[4316,4558,"Stunning, as always."],[4642,4833,"This is Hannah."],[4900,5063,"Elliott's betrothed."],[5063,5255,"Clearly they weren't compatible,"],[5255,5434,"so how should we handle"],[5434,5572,"breaking off the engagement?"],[5643,5793,"Elliott is out of the country,"],[5793,5939,"but if you want to"],[5939,6072,"break off the engagement,"],[6072,6235,"I'm absolutely- - Madam Hargrove,"],[6293,6427,"may I speak with you"],[6427,6477,"um..."],[6740,6835,"privately?"],[6915,7069,"This should be interesting."],[7173,7244,"Come."],[8149,8320,"What could a country girl like you"],[8320,8429,"have to say to me?"],[8612,8742,"Quite graceful."],[8742,8867,"I thought she grew up"],[8867,9100,"on a pig farm in Indiana."],[9100,9371,"Madam Hargrove, I refuse to break off"],[9371,9505,"my engagement to your son."]],"4":[[12,229,"You've got a lot of nerve, farm girl."],[229,496,"My son Elliott stands to inherit"],[496,646,"the Hargrove Ballet Company"],[646,863,"and everything that goes with it."],[863,1055,"You're not even good enough"],[1055,1184,"to be his whore."],[1184,1355,"With all due respect,"],[1355,1518,"you made a promise to my mother"],[1518,1676,"that I would marry Elliott"],[1676,1830,"and I need you to keep it."],[1830,2010,"My life depends on this marriage"],[2010,2147,"and I am good enough"],[2147,2252,"to be Prima Ballerina."],[2252,2306,"I just need"],[2306,2402,"the Hargrove Ballet Company"],[2402,2452,"behind me."],[2452,2556,"Hannah Thatcher!"],[2590,2761,"You will never dance"],[2761,2952,"for the Hargrove Ballet Company,"],[2952,3236,"and you will never marry my son."],[3236,3499,"You can try to get rid of me,"],[3524,3699,"but it's gonna be a lot harder"],[3774,4016,"to get rid of all of this evidence."],[4066,4179,"My mom gave me these"],[4179,4433,"before she died as an insurance policy"],[4433,4675,"just in case my future mother-in-law"],[4675,4804,"forgets her promise."],[4804,4946,"I thought I destroyed"],[4946,5171,"every trace of the affair,"],[5171,5442,"but she has photos, letters,"],[5484,5680,"even the abortion record."],[5739,5855,"If my husband finds out"],[5855,6001,"I slept with his enemy,"],[6001,6164,"I'll lose the company."],[6206,6377,"If he doesn't murder me first."],[6448,6614,"This is blackmail!"],[6614,6798,"I have done nothing to you"],[6798,6961,"and you're ruining my life"],[6990,7161,"just to marry my son?"],[7173,7240,"This,"],[7303,7528,"this is a dangerous game you're playing."],[7528,7807,"This isn't a game, Madam Hargrove."],[7807,8124,"All I want is to be Prima Ballerina"],[8124,8283,"and marrying your son,"],[8291,8429,"that is my way in."],[8429,8721,"Give me one year to prove myself,"],[8721,8963,"and then, then, we can get a divorce."],[9342,9451,"Give me the originals and"],[9451,9542,"we have a deal."],[9542,9622,"Don't worry."],[9663,9780,"Bringing down the whole company"],[9780,9951,"would ruin my career too,"],[9951,10089,"so I won't say anything"],[10089,10251,"about your little scandal"],[10276,10447,"unless you break your promise."],[10447,10794,"And why would I trust you?"],[10810,10981,"Because you have no other choice."],[11031,11152,"I need you to host a party"],[11152,11244,"tomorrow night."],[11286,11411,"Tell all of the ballet's"],[11411,11507,"elite benefactors"],[11507,11795,"that I will be Elliott's wife."],[12053,12162,"Blackmailing the most"],[12162,12320,"powerful woman in the city?"],[12395,12570,"It's a bold move, little thief."],[12620,12804,"There's more to you than meets the eye."]],"5":[[417,679,"Then I guess you give me no choice."],[738,896,"Glad that you see it my way."],[917,1042,"Feel free to keep the copies."],[1042,1247,"I have many, many more."],[2310,2590,"Well, is the engagement off?"],[2644,2877,"No, actually Loyola is throwing a party"],[2877,2957,"tomorrow night."],[2957,3069,"All the ballet's benefactors"],[3069,3119,"are coming"],[3119,3253,"and she's making"],[3253,3453,"a very important announcement."],[3453,3691,"I guess Madam Hargrove wants"],[3691,3924,"to end the engagement publicly."],[3924,4200,"Don't worry, New York's a big city."],[4212,4350,"I'm sure you'll find somebody"],[4350,4437,"more suitable."],[4437,4625,"There are plenty of lonely Doordashers"],[4625,4733,"looking for love."],[4909,5201,"Once this mess with Hannah is resolved,"],[5201,5355,"you will swoop right in"],[5355,5472,"and take her place"],[5472,5647,"as Elliott's fiancée."],[5647,5860,"You better go enjoy your free trip"],[5860,6051,"to the city while you can."],[6051,6168,"After the party tomorrow,"],[6168,6377,"you'll be back to shucking corn"],[6377,6535,"and shoveling pig shit."],[6535,6627,"You can find your own"],[6627,6760,"way home, right?"],[6781,6940,"Mom, I need a new outfit"],[6940,7027,"for the party tomorrow!"],[7027,7073,"Yeah."],[7803,7953,"They think my engagement is off,"],[7953,8074,"and Valerie's in."],[8074,8291,"I can't wait to see their faces"],[8291,8429,"when Madam Hargrove announces"],[8429,8704,"that I'm the future Mrs. Elliott Hargrove."],[8725,8875,"And once I'm a Hargrove,"],[8888,9129,"I'll take my place as Prima Ballerina."],[9993,10135,"We meet again, little thief."],[10335,10481,"Oh my God, it's him."],[10723,10885,"Come on, we're going for a ride."]],"6":[[104,166,"No!"],[208,283,"Help, somebody,"],[283,371,"please help me, please!"],[371,475,"A stranger is kidnapping me,"],[475,575,"please, somebody."],[608,700,"Get me out of here."],[900,1005,"Stranger?"],[1026,1105,"I thought I made more"],[1105,1184,"of an impression."],[1609,1743,"You stole my gun."],[1797,1951,"I don't know what you're talking about."],[1997,2189,"It took me no time to track you down,"],[2189,2302,"so don't lie to me."],[2302,2385,"Or you'll find out"],[2385,2506,"what else I'm capable of."],[2506,2623,"What do you want from me?"],[3165,3319,"I want to know your real name."],[3682,3757,"Yeah?"],[3787,3933,"And I want to know if all the city boys"],[3933,4041,"go around kidnapping women,"],[4041,4154,"or is that just you?"],[4154,4212,"Hm?"],[4350,4466,"You stole from me."],[4533,4688,"I can't just let you walk away."],[4904,5059,"I don't have your gun."],[5138,5363,"Go ahead, check me."],[7090,7161,"See?"],[7265,7415,"I don't have your gun."],[7520,7678,"And I don't belong to you."],[7732,7899,"But I bet you wish you did."]],"7":[[825,905,"You busy?"],[930,1088,"I got a present for you."],[1105,1317,"Rivalchek's right-hand man."],[1347,1530,"And another one of his goons."],[1693,1839,"It's my lucky day."],[1910,2139,"21st and Lex, drive."],[2335,2527,"Come, see how I work."],[2990,3061,"Is this the old"],[3061,3199,"Hargrove Ballet Studio?"],[3282,3499,"Today, it's my office."],[3724,4037,"Oh, look, he brought his little slut."],[4329,4512,"Your last words better be an apology,"],[4512,4633,"or I'll make this last."],[4633,4792,"Oh, fuck you."],[4946,5042,"Have you ever seen a life"],[5042,5180,"leave a man's eyes before?"],[5280,5426,"Then you might wanna look away."],[6101,6193,"How much was Rivalchek"],[6193,6306,"paying for my head?"],[6385,6481,"Fifty million."],[6610,6769,"Seems kind of low, don't you think?"],[6769,6931,"Please, Jack, can we just go, please?"],[6936,7094,"I'd say tell Rivalchek"],[7094,7240,"he's a cheap bastard, but..."],[9054,9125,"Come on."]],"8":[[784,846,"You're tougher than I"],[846,980,"thought you were, little thief."],[980,1134,"You gonna kill me too?"],[1192,1322,"Or can I leave now?"],[1363,1501,"East 23rd Street."],[1559,1768,"Roy Thatcher and Kim Parrish's place."],[1768,1868,"How do you know?"],[1889,2068,"I know more than where you live,"],[2139,2231,"Hannah Thatcher."],[2289,2394,"I also know you're engaged"],[2394,2523,"to Elliott Hargrove."],[2581,2756,"And you almost kissed me?"],[2756,2852,"The Hargroves run"],[2852,3015,"the most elite ballet company"],[3015,3111,"in the country."],[3111,3353,"Their family is rich and powerful,"],[3353,3595,"and I heard that the older brother"],[3595,3787,"is the most deadliest assassin"],[3787,3891,"in the world."],[3891,4016,"Aren't you scared of him?"],[4508,4667,"She has no idea"],[4667,4842,"it's me she's talking about."],[4842,5075,"I could sleep with you on stage"],[5075,5242,"at the opening night of the ballet,"],[5242,5538,"and no one would say a thing to me."],[7102,7390,"Who the hell are you?"],[8166,8316,"How bad do you wanna know?"],[9751,9980,"I'll see you around, Hannah Thatcher."],[11369,11524,"Track the little thief for me."],[11628,11774,"Tell me everywhere she goes."],[11895,12003,"I find that girl"],[12003,12228,"strangely fascinating."],[12324,12383,"She won't be"],[12383,12566,"my brother's fiancée for long."]],"9":[[200,333,"He's not afraid of the Hargroves,"],[333,538,"and he knows where I sleep."],[1234,1480,"Why did I steal his stupid gun?"],[1943,2239,"Whoever he is, whatever he wants,"],[2239,2381,"I won't let him stop me"],[2381,2510,"from securing my husband"],[2510,2777,"and my spot as Prima Ballerina."],[4312,4433,"Yes..."],[5021,5176,"Yes, Jack."],[6414,6477,"Yes, Jack."],[6556,6631,"Yes!"],[7073,7240,"Out of bed now!"],[7273,7494,"We have a party to go to."],[7628,7811,"It's the night of my engagement party,"],[7849,7966,"and I'm dreaming about a man"],[7966,8158,"who, who kidnapped me."],[8245,8420,"I'm here to marry Elliott Hargrove"],[8420,8596,"and become Prima Ballerina,"],[8596,8821,"not fall for a criminal."]],"10":[[300,663,"Hannah, let me be very clear."],[663,863,"The only reason"],[863,1038,"you're coming with us to this party"],[1038,1247,"is so we can see the pitiful look"],[1247,1355,"on your face,"],[1355,1518,"when Madam Hargrove"],[1518,1701,"decides to end your engagement"],[1701,2052,"with her son in front of all the richest,"],[2052,2327,"most powerful people in New York."],[2469,2598,"Face it, Hannah."],[2627,2977,"The city's no place for a farm girl."],[2994,3073,"I know you're desperate"],[3073,3144,"for a rich man"],[3144,3357,"to save you from your sad life"],[3357,3474,"in the slums,"],[3474,3616,"but the Hargroves?"],[3853,3941,"They'll never let"],[3941,4304,"an untalented hick like you"],[4320,4479,"tarnish their family name."],[5138,5313,"That's what you think."],[7478,7749,"Oh, there she is, Baron."],[7824,8153,"Elliott's fiancée, the farm girl."],[8258,8521,"Well, there is a certain elegance"],[8521,8612,"about her."],[8612,8792,"As long as she can dance,"],[8792,8921,"I don't see the problem."],[8983,9029,"Hm."],[9509,9672,"Have Hannah perform"],[9672,9855,"the crowd favorite pas de deux."],[10193,10410,"If she can dance, then we'll know"],[10410,10648,"that she's worthy of marrying our son."],[10744,10890,"That hillbilly thinks"],[10890,11052,"she could blackmail me?"],[11094,11298,"I might not be able to kill her,"],[11327,11632,"but I can still end this engagement."],[11720,11920,"Do not let that farm girl"],[11920,12153,"perform on stage tonight."],[12233,12391,"Break her legs if you have to."],[12479,12758,"You tell anyone that this came from me,"],[12800,12904,"you're dead."],[13133,13267,"After tonight,"],[13267,13467,"Hannah will never dance again."]],"11":[[145,250,"Hannah Thatcher."],[312,588,"As the Hargrove's VIP guest,"],[588,696,"they insist you perform"],[696,804,"Act II pas de deux"],[804,896,"from the Black Swan"],[896,1105,"for our guests tonight."],[1105,1368,"Um, and is Elliott going to be"],[1368,1484,"dancing with me?"],[1484,1559,"He's away"],[1559,1714,"performing for the Royal Ballet."],[1743,1868,"But, I'm sure you can find"],[1868,1997,"another suitable partner."],[2364,2510,"Does Loyola really think"],[2510,2648,"no one's going to dance with me?"],[2656,2794,"Or that I'm not talented enough"],[2794,2894,"to pull this off?"],[2927,3157,"She's gonna see how wrong she is."],[3178,3261,"These are two"],[3261,3457,"of the very best male dancers"],[3457,3570,"the company has to offer."],[3791,4041,"I hear you're from Indiana."],[4074,4195,"I bet you can't even pronounce"],[4195,4254,"pas de deux,"],[4254,4408,"much less dance it."],[4441,4583,"I'm Hargrove best dancer."],[4612,4704,"No way I'm gonna dance"],[4704,4888,"with some flat-footed farm girl."],[4988,5100,"You're only here"],[5100,5196,"because you're engaged"],[5196,5305,"to Elliott Hargrove."],[5321,5543,"But I'm sure he's not in it for love."],[5543,5638,"Clearly, he just wants"],[5638,5789,"his own personal milk maid."],[6047,6277,"You have no idea why I'm here"],[6277,6398,"or what I'm capable of."],[6398,6685,"Okay, sorry about my idiot half-sister."],[6702,6819,"What she lacks in talent"],[6819,6969,"she makes up for in ego."],[7107,7253,"We all know you don't belong"],[7253,7403,"in the Hargrove family."],[7403,7570,"In fact, you'd be more fit"],[7570,7766,"to dance in a cage for tips."],[8041,8091,"At least then"],[8091,8254,"you could afford new pointe shoes."],[8445,8591,"What's so funny? Hm?"],[8612,8783,"The only dance you can pull off"],[8812,8958,"is a lap dance."],[9217,9359,"I'll be your first customer."]],"12":[[8,145,"What's the matter, Hannah?"],[196,304,"I mean, you'd make more money"],[304,371,"in one dance"],[371,583,"than you ever made slinging pig shit."],[729,859,"Let me go, or else-"],[859,934,"Or what?"],[1001,1155,"Heard of the Reaper Assassins?"],[1172,1309,"You're one of them?"],[1309,1438,"I got paid to do a job."],[1476,1614,"So perform a show for me."],[1735,1947,"Or I'm gonna break your legs."],[3028,3207,"You think you can humiliate me?"],[3219,3399,"Let me put on a real show."],[6352,6581,"Baron, how can Hannah be"],[6581,6664,"Prima Ballerina"],[6664,6827,"or even marry our son"],[6827,6965,"when she is straddling"],[6965,7119,"rich guys for cash?"],[7186,7253,"You're right."],[7253,7365,"It's disgraceful."],[7411,7536,"She could ruin"],[7536,7703,"the Hargrove Ballet's reputation."],[7703,7803,"Absolutely."],[7853,7928,"Maybe we should"],[7928,8070,"call off the engagement."],[8124,8291,"You ride horses, farm girl."],[8354,8500,"I know you can do better than that."],[9688,9797,"How about this?"],[9930,9989,"Ow."],[9989,10043,"Fuck!"],[10080,10168,"Fuck!"],[10489,10635,"You fucking bitch!"],[11498,11803,"Pretty little Prima Ballerina."],[11945,12028,"You thought tonight"],[12028,12174,"was gonna be your night, didn't you?"],[12212,12320,"I warned you."],[12379,12604,"Now with one beautiful swing,"],[12666,12917,"those beautiful legs of yours"],[12917,13050,"will never be able to dance"],[13050,13184,"across the stage again."],[13200,13350,"Please don't do this."],[13350,13538,"Please, dance is all that I have."],[13621,13767,"Please don't hurt my legs."],[13901,14130,"You know, I like it when you beg."],[14139,14239,"Please don't."],[15269,15394,"You touch her again,"],[15394,15473,"and the next one"],[15473,15590,"goes through your skull."]],"13":[[834,896,"Viper."],[942,1005,"Oh my god,"],[1005,1142,"I heard he's the deadliest assassin"],[1142,1217,"in the world."],[1247,1388,"Is he here to kill someone?"],[1526,1605,"I didn't mean to."],[1605,1735,"I heard he slit a guy's throat"],[1735,1830,"with a poker card."],[1830,1956,"I heard it was three."],[2823,2977,"That's why they call him the Viper."],[3015,3294,"If he's after you, you're already dead."],[4429,4650,"Oh my God, the man whose gun I stole,"],[4650,4879,"the man who I almost kissed,"],[4904,5134,"is the world's deadliest assassin?"]],"14":[[2214,2348,"Anyone else touch her?"],[2360,2410,"What the hell"],[2410,2569,"is my eldest son doing here?"],[2569,2706,"He knows better than"],[2706,2886,"to walk into a crowded club"],[2886,3048,"with a multi-million dollar bounty"],[3048,3136,"on his head."],[3136,3265,"The bigger question is,"],[3303,3536,"what is he doing protecting Hannah?"],[3536,3707,"Hey boss, check this out."],[3941,4099,"A Reaper Assassin,"],[4133,4237,"targeting his leader's"],[4237,4371,"future daughter-in-law."],[4387,4454,"Who hired you to do"],[4454,4587,"something so stupid?"],[4904,5009,"You're going to have to kill me..."],[5822,6001,"He saved me in the nick of time."],[6001,6135,"Has he been watching over me"],[6135,6252,"this whole time?"],[6252,6464,"Maybe he's not as evil as I thought."],[6614,6865,"You know what, just leave me alone."],[6865,7023,"I came here to dance,"],[7023,7190,"to prove myself to everyone"],[7190,7319,"that I can be Prima Ballerina"],[7319,7449,"and I have no interest"],[7449,7528,"in getting mixed up"],[7528,7657,"with a guy like you."],[7720,7882,"It's a little too late for that."],[8091,8162,"This is it."],[8183,8333,"This is how he gets me back"],[8333,8458,"for stealing his gun."],[8491,8579,"He only saved me"],[8579,8729,"so he could end me himself."],[8883,8946,"Oh my God,"],[8946,9196,"is he gonna finish the other guy's job?"],[11098,11236,"You wanna prove yourself?"],[11511,11599,"Then dance with me."]],"15":[[717,1030,"No, let them dance, Loyola."],[1042,1121,"If Jack thinks Hannah"],[1121,1213,"is worth saving,"],[1213,1372,"then maybe there's more to her"],[1372,1476,"than we think."],[1476,1710,"Jack might've saved Hannah's legs,"],[1735,1843,"but he can't save her"],[1843,2052,"from making a fool of herself."],[2089,2356,"She's no Prima Ballerina."],[2444,2544,"You dance?"],[2585,2715,"Only with death."],[3858,3949,"You're good."],[3987,4116,"Those jackasses who doubted you"],[4116,4266,"have no idea what they're talking about."],[4320,4396,"Say the word"],[4396,4521,"and I'll break all their legs."],[4733,4854,"Violence is not"],[4854,5042,"always the answer, Viper."],[5088,5230,"So you know who I am now."],[5334,5588,"Yeah, the world's deadliest assassin."],[5689,5764,"You definitely are"],[5764,5885,"as bad as your reputation."],[5939,6106,"Well, I'm not just a killer, you know."],[6131,6264,"I'm also a Hargrove."],[6619,6685,"You're..."],[6981,7236,"Jack, your fiancée's brother."],[8124,8254,"I know you want me."],[8345,8504,"Your body doesn't lie."],[9075,9305,"I know you've been dreaming about me."],[9855,10026,"How are you gonna marry my brother?"]],"16":[[154,304,"You broke into my train car,"],[321,429,"you kidnapped me,"],[429,554,"and I never wanted anything"],[554,629,"to do with you."],[629,767,"Then why steal my gun?"],[3561,3753,"You're so desperate to get away from me,"],[3820,3933,"but where would you be tonight"],[3933,4033,"if I didn't save you?"],[4767,4950,"You owe me for rescuing you."],[5125,5338,"But I'll collect my fee another time."]],"17":[[254,450,"Well, I haven't seen talent like that"],[450,583,"since you were Prima."],[809,1067,"Impossible, I set her up to be destroyed,"],[1092,1301,"and she gets a standing ovation?"],[1301,1438,"How did this farm girl"],[1438,1651,"learn to dance so gracefully?"],[1672,1801,"What the fuck, Mom?"],[1801,1989,"I was supposed to be the star tonight."],[1989,2181,"How did she steal my spotlight?"],[2181,2327,"And why in the world"],[2327,2515,"would the Viper help her?"],[2544,2623,"I taught you better"],[2623,2798,"than to come into a crowded club"],[2798,2994,"with a price like that on your head."],[2994,3103,"Thank God I did,"],[3128,3278,"or one of your own assassins"],[3278,3420,"would have maimed an innocent woman."],[3578,3824,"Well, that was quite a recovery,"],[3824,3937,"Miss Thatcher."],[3937,4158,"You are a talented dancer."],[4158,4346,"Thank you very much, Mr. Hargrove."],[4362,4579,"You know, our son, Elliott,"],[4579,4917,"must marry a promising ballerina."],[4946,5138,"We happen to have auditions"],[5138,5301,"for the lead in Swan Lake,"],[5301,5538,"tomorrow at Hargrove Studios."],[5580,5709,"Would you care to audition?"],[5743,5926,"It would be an honor,"],[5926,6097,"Mr. Hargrove, thank you."],[6118,6218,"Wonderful."],[6218,6327,"If you get the part,"],[6327,6510,"you'll join the company,"],[6510,6756,"and then when Elliott gets back,"],[6756,6881,"we'll plan the wedding,"],[6956,7152,"if that's what you want."],[7665,7749,"Yes."],[7891,8249,"Mr. Hargrove, I want to marry Elliott."]],"18":[[12,208,"Well, you better get some rest."],[208,271,"We'll see you"],[271,462,"at Hargrove Studios tomorrow."],[513,713,"I'll escort Miss Thatcher home."],[742,959,"Jack, do you and Hannah"],[959,1076,"know each other?"],[1076,1134,"Forgive me,"],[1134,1384,"but it seems so out of your character"],[1384,1580,"to be so attentive."],[1609,1705,"Well, she's my,"],[1705,1922,"my little brother's fiancée,"],[1951,2102,"and she's a talented ballerina"],[2102,2223,"whose leg's were almost crushed"],[2223,2389,"by a hired assassin tonight."],[2435,2577,"She deserves my protection,"],[2577,2648,"don't you think?"],[2648,2790,"Is there something going on"],[2790,3057,"between Hannah and the Viper?"],[3094,3199,"I could use this"],[3199,3378,"to end Hannah's engagement"],[3411,3545,"and take the Hargrove name"],[3545,3636,"for myself."],[3770,3974,"Jack, Mr. Hargrove,"],[3999,4170,"can Valerie and I come along?"],[4187,4358,"We're all going to the same place."],[4404,4521,"No way in hell."],[4608,4729,"You're the ones who threw Hannah"],[4729,4846,"to the wolves tonight."],[4846,5013,"Hannah is our family."],[5013,5234,"We would never betray her."],[5234,5367,"This is a mistake."],[5367,5505,"Careful, ladies."],[5563,5860,"A mistake like that can get you killed."],[6473,6819,"Oh my God, I do not need an escort."],[6961,7040,"So you'd rather go home"],[7040,7140,"with your stepmom"],[7140,7294,"and her sniveling little daughter?"],[7490,7590,"I didn't think so."],[7720,7807,"Jack!"]],"19":[[20,183,"Your son is too hot-headed."],[183,396,"One of these days, he's gonna snap,"],[396,600,"and he's gonna turn that gun on us."],[600,759,"He almost did tonight"],[759,888,"when he was defending"],[888,988,"that farm girl,"],[988,1188,"and she's not even his fiancée."],[1188,1326,"Jack would never compromise"],[1326,1438,"the Hargrove name."],[1488,1693,"Reaper Assassins live"],[1693,1856,"by a strict moral code."],[1897,2031,"Besides, the bounty on his head"],[2031,2189,"just hit a hundred million."],[2189,2439,"Any woman that Jack claims"],[2439,2552,"is as good as dead."],[2665,2748,"Fine."],[2890,2952,"But it would have been"],[2952,3032,"more appropriate"],[3032,3165,"if Hannah turned him down."],[3207,3307,"Have you tried"],[3307,3503,"saying no to the Viper?"],[3724,3991,"I told you, put me down!"],[3991,4079,"Now!"],[4079,4166,"Come on!"],[4237,4371,"You had no right-"],[4371,4458,"No right?"],[4504,4713,"You looked me, a deadly assassin,"],[4713,4783,"right in the eye"],[4783,4846,"and said that you'd rather"],[4846,4967,"marry my brother."],[4992,5075,"You think you got me"],[5075,5217,"wrapped around your finger, don't you?"],[5217,5359,"You're just playing games with me."],[5397,5547,"What was I supposed to say?"],[5547,5689,"That you want me?"],[5689,5868,"That you're gonna propose to me?"],[5868,5985,"Do you have any idea"],[5985,6039,"how dangerous"],[6039,6160,"being my wife would be?"],[6322,6544,"Love is an assassin's greatest weakness."],[6727,6906,"So you're saying that I"],[6990,7098,"am your weakness?"],[7098,7182,"Hm?"],[7207,7382,"I'm saying you'll never be happy"],[7382,7490,"with my brother."],[7620,7841,"And being with me is a death sentence."],[7887,7953,"You're better off"],[7953,8083,"going back to Indiana."],[8112,8466,"You don't know what's best for me."],[8521,8616,"Maybe not."],[8946,9050,"But I know"],[9159,9284,"that you want me."],[9530,9659,"What I want..."],[9901,10076,"is for you to take me home."],[10231,10318,"Then kiss me."]],"20":[[12,196,"I know I shouldn't kiss him,"],[246,500,"but why is my body betraying my mind?"],[504,663,"Why in hell would I kiss you?"],[675,821,"I'm engaged to your brother."],[821,950,"You've never even met him."],[1209,1380,"Kiss me or I'm not taking you home."],[1468,1622,"I can wait here all night,"],[1697,1864,"all morning,"],[1910,2135,"until you miss that precious audition."],[2669,2861,"Who's playing the games now, huh?"],[3424,3661,"Is it a game, Hannah?"],[3832,4004,"Or,"],[4004,4191,"am I finally giving you"],[4592,4729,"what you really want?"],[5117,5251,"I can't fight it."],[5301,5442,"And I can't fight him."],[5497,5830,"I shouldn't want this, but I do."],[7086,7248,"That ungrateful peasant"],[7248,7432,"treated her own family like trash."],[7432,7553,"And she turned the world's"],[7553,7761,"deadliest assassin against us."],[7761,7912,"I was trying to help that shady bitch"],[7912,8078,"and she almost got me killed."],[8099,8162,"God."],[8375,8521,"Mom, is that Hannah's dress?"],[8900,9121,"That skank is stepping out"],[9121,9246,"on her fiancée."],[9246,9467,"Let's see her land a Hargrove"],[9467,9630,"after we expose her."]],"21":[[37,116,"Don't move."],[1059,1197,"If you don't want to be with me,"],[1197,1397,"then why kiss me?"],[1443,1543,"What if someone saw us"],[1543,1622,"and told Madam Hargrove"],[1622,1701,"or your father,"],[1701,1864,"they would literally have me killed!"],[1864,1918,"Hey,"],[1976,2118,"as long as you're with me,"],[2239,2356,"they won't touch you."],[3382,3470,"Careful."],[3528,3645,"Hannah Thatcher,"],[3757,3862,"falling in love with me"],[3862,4020,"is a dangerous game."],[4066,4145,"He's right."],[4187,4312,"He kidnapped me."],[4312,4525,"He kills people for a living."],[4558,4637,"He's playing with me"],[4637,4842,"like an animal plays with its prey."],[4900,5263,"I could never love a monster like you."]],"22":[[54,166,"But you could love my brother?"],[279,454,"I will be Prima Ballerina"],[454,629,"at the Hargrove Ballet Company."],[688,759,"Marrying your brother's"],[759,859,"how I'll do it."],[859,1046,"You gonna stand in my way too?"],[1305,1530,"Can't make any promises, little thief."],[1555,1680,"Oh my God."],[4124,4295,"There's the little slut."],[4320,4400,"Dad I told you"],[4400,4487,"she was dancing"],[4487,4833,"all over the Viper, at the club."],[4896,5000,"I can only imagine"],[5000,5251,"what she let him do on the ride home."]],"23":[[200,412,"How dare you cheat on your fiancé"],[412,542,"with a deadly assassin?"],[542,684,"Are you trying to get us killed?"],[684,796,"I thought farm girls"],[796,934,"were supposed to be innocent."],[934,1001,"And you're just"],[1001,1205,"a dirty, ungrateful whore."],[1205,1380,"Jack was just dropping me off."],[1380,1480,"I'm engaged to his brother."],[1480,1609,"We're about to be family."],[1609,1693,"Stupid girl,"],[1693,1839,"you're not gonna be a Hargrove."],[1839,1956,"The engagement is off!"],[1993,2131,"So you didn't tell him?"],[2198,2318,"Baron Hargrove thinks"],[2318,2477,"I'm a very talented dancer."],[2510,2656,"He invited me to audition for the"],[2656,2836,"Hargrove Ballet Company, tomorrow."],[2836,3115,"And, and if I get the lead in Swan Lake,"],[3115,3207,"then we can start planning"],[3207,3299,"Elliot and I's wedding"],[3299,3382,"when he returns."],[3395,3837,"Well, this is excellent news."],[3903,4012,"Soon you'll be a,"],[4066,4270,"member of the richest family"],[4270,4358,"in the country."],[4387,4662,"And their wealth will change our lives."],[4771,4954,"I need you to seal the deal."],[5046,5205,"When I was nine,"],[5205,5401,"you said that I was worthless."],[5422,5668,"You shipped me off to a farm like trash."],[5693,5793,"You'll never see"],[5793,5997,"a cent of Hargrove money."],[6531,6690,"What are you two thinking?"],[6715,6869,"If you wrongly accuse her"],[6869,6940,"of sleeping with"],[6940,7077,"the most dangerous assassin"],[7077,7152,"in the country,"],[7152,7298,"it will be a death sentence!"],[7298,7357,"No, but Dad,"],[7357,7570,"it's obvious Hannah is keeping secrets!"]],"24":[[58,287,"And she doesn't even have a ring yet."],[383,508,"Are you just gonna let her-"],[613,721,"Unless you get a ring"],[721,867,"from Elliot Hargrove himself,"],[867,1009,"I don't wanna hear another word"],[1009,1126,"about your sister."],[1176,1347,"If you ruin this for me, Valerie,"],[1347,1443,"I swear to God,"],[1443,1593,"I will disown you!"],[2544,2748,"You know what you have to do."],[2819,3111,"Tomorrow, you go into that audition"],[3111,3315,"and you steal the lead from Hannah."],[3340,3511,"That way when she falls,"],[3511,3807,"Madam Hargrove has no other option"],[3807,3953,"but to end the engagement."]],"25":[[12,112,"I'm interested to see"],[112,254,"how Christina does this year."],[471,642,"Jack, don't you have"],[642,759,"anything better to do"],[759,938,"than crash my auditions?"],[938,1126,"You may be the most feared assassin"],[1126,1226,"in the country,"],[1242,1355,"but when it comes to ballet,"],[1355,1468,"you know nothing."],[1468,1664,"I'm here representing"],[1664,1818,"the Reaper Assassin Guild,"],[1868,1960,"Hargrove Ballet's"],[1960,2081,"most generous benefactors."],[2081,2260,"Without us, there is no ballet."],[2310,2606,"I will have final say in the decision."],[2673,2794,"You were too generous"],[2794,2973,"with that farm girl last night."],[3007,3249,"I won't have you give her the spot"],[3249,3311,"just because"],[3311,3453,"she's your little pet project."],[3828,3912,"Have you forgotten"],[3912,4041,"who you're speaking to?"],[4099,4225,"Step-mother?"],[4262,4379,"We both know she doesn't belong"],[4379,4537,"in this company or this family."],[4625,4825,"I want her gone just as badly as you do."],[5130,5276,"She is my weakness."],[5276,5580,"Keeping her around is too big of a risk."],[5626,5689,"Fine."]],"26":[[1897,2160,"What is my evil half-sister"],[2160,2268,"doing here?"],[2268,2494,"That bitch is going down."],[2535,2627,"It doesn't matter."],[2669,2865,"The judges are the only ones"],[2865,2990,"that I need to impress."],[3591,3803,"Ladies, we have a very special"],[3803,3862,"guest judge"],[3862,3966,"joining us today,"],[3966,4091,"and he will be deciding"],[4091,4270,"who gets to play our Swan Queen."],[4333,4412,"His name..."],[4433,4604,"Once I win this judge over,"],[4629,4717,"I'll secure the role"],[4717,4796,"and my place"],[4796,4954,"as Elliot Hargrove's fiancée,"],[5005,5267,"one step closer to Prima Ballerina."],[5342,5438,"... is Jack Hargrove."]],"27":[[225,421,"You gonna stand in my way too?"],[496,709,"Can't make any promises, little thief."],[792,1013,"Jack is the guest judge?"],[1038,1159,"He doesn't want me to join the company"],[1159,1313,"nor marry his brother."],[1313,1384,"Would he really"],[1384,1555,"sabotage my audition?"],[1593,1710,"I have to get on that stage"],[1710,1972,"and prove that I deserve this part."],[2156,2389,"I know there's something going on"],[2389,2510,"between Hannah and Jack."],[2877,3190,"If she's, Jack, the Viper's favorite,"],[3190,3403,"then there's no way I can compete."],[3424,3645,"I can't let Hannah get on that stage."],[4004,4137,"Who the hell is that?"],[4154,4258,"I've never seen extensions"],[4258,4354,"like that before."],[4404,4558,"What is she wearing, though?"],[4596,4700,"Those shoes look like"],[4700,4767,"they got shredded"],[4767,4884,"in a lawn mower."],[4917,5221,"That is my reject stepsister"],[5221,5372,"from the pig farm."],[5401,5543,"She came all the way from Indiana"],[5543,5630,"to steal my dream"],[5630,5793,"of being the lead in Swan Lake."],[5876,6051,"She's always been a jealous bitch."],[6106,6297,"That's so messed up, Val."],[6297,6527,"You're obviously way more talented."],[6527,6698,"Yeah, you should confront her."],[6719,6869,"You deserve this role."],[7415,7565,"She hit me,"],[7565,7749,"did you just see what she did?"],[7778,7949,"She's trying to sabotage me."],[8016,8158,"I told you she's been jealous."]],"28":[[16,166,"How dare you touch her?"],[166,304,"I didn't do anything,"],[304,442,"you did that on purpose."],[462,558,"You better shower"],[558,704,"before you get swine flu."],[792,871,"Wow, Val."],[934,1105,"your friends are so rude,"],[1105,1288,"but I guess it's true what they say."],[1326,1468,"We are the company we keep."],[1501,1639,"Do you know who she is?"],[1659,1793,"She's Elliott Hargrove's"],[1793,1906,"future fiancée."],[1989,2135,"That's what she told you?"],[2164,2214,"Hm?"],[2285,2406,"This might come as a shock,"],[2406,2602,"but I'm engaged to Elliott."],[2748,2869,"Then where's the ring?"],[3169,3390,"And I don't need a custom leotard"],[3390,3503,"to compensate"],[3503,3645,"for my lack of talent."],[3682,3849,"You bitch!"],[3903,4008,"Get her, girls."],[4008,4054,"What?"],[4124,4212,"What are you doing?"],[4212,4375,"No, get off of me!"]],"29":[[179,358,"I am here to show you once and for all"],[358,588,"that you don't belong here, Hannah!"],[588,679,"What?"],[704,813,"No, no, no."],[1447,1559,"Aww."],[1597,1647,"Don't tell me"],[1647,1789,"you don't have a backup pair."],[1830,1960,"Let me guess."],[2085,2373,"This is your only leotard too, huh?"],[2373,2460,"No!"],[2957,3111,"Now this is the ballet,"],[3111,3319,"not a topless dance club."],[3319,3486,"Maybe you're at the wrong audition."],[3699,3828,"You're really that desperate"],[3828,3974,"to send me back to the farm?"],[4008,4216,"We both know that there is no chance"],[4216,4396,"that you can have Elliott while I'm here."],[4479,4742,"You and Elliott haven't even met yet."],[4742,4842,"As soon as he sees"],[4842,5017,"he's engaged to pig-sty Barbie,"],[5021,5146,"he'll run the other way."],[5217,5280,"No!"],[5476,5672,"I would say break a leg, but..."],[5780,5834,"I don't think"],[5834,5964,"you're going to audition anymore."],[8316,8495,"I am not giving up that easily."]],"30":[[813,971,"Congratulations, Valerie."],[1076,1159,"You won."],[1242,1401,"Don't be sad, Hannah."],[1601,1814,"The big city life isn't for everyone."],[1814,1976,"I'm sure the pigs will love to"],[1976,2106,"have you back in the sty."],[7077,7161,"Next."]],"31":[[1376,1451,"Whoa!"],[1451,1680,"Right on time."],[1680,1822,"All right, it's time for you"],[1822,1943,"to go nighty-night."],[4754,4879,"I'll take this."],[5655,5826,"If Jack can't recognize me,"],[5826,5926,"then he can't sabotage"],[5926,6093,"my chances of landing the part."],[6840,6965,"I thought this was supposed to be"],[6965,7115,"the best ballet in the country."],[7157,7307,"Where are all the good dancers?"],[7494,7640,"Dancer number 10."],[8249,8324,"Who is that?"]],"32":[[3119,3315,"Her form is impeccable."],[3315,3428,"She's perfect."],[3557,3645,"I've made my decision,"],[3645,3803,"she is our lead."],[3924,4208,"Now I hate to say it, but I agree."],[4346,4483,"No one else can compare."],[4650,4984,"Congratulations, you are"],[4984,5271,"Hargrove Ballet's Swan Queen."],[6314,6377,"Come here."],[6652,6731,"Who are you?"],[8533,8812,"You're gonna pay for this, little thief."]],"33":[[45,133,"Jack will take"],[133,271,"any chance to torture me,"],[291,433,"to play with me."],[487,709,"Did I finally push him too far?"],[959,1213,"This deceitful little farm girl"],[1213,1451,"does not deserve to be Swan Queen!"],[1451,1672,"Madam Hargrove, Jack,"],[1801,1960,"you made your decision."],[1960,2143,"I earned that role."],[2173,2348,"You swindled us!"],[2360,2477,"You cheap little- - Hannah's right."],[2606,2781,"No one else was good enough."],[2836,3003,"He protected me again?"],[3003,3236,"What sick game is he playing this time?"],[3424,3595,"Rehearsals begin tomorrow."],[3678,3970,"One screw up, and you are out."],[4400,4604,"What kind of sick game"],[4604,4708,"are you playing?"],[4708,4792,"I thought you were gonna"],[4792,4938,"make me pay, hm?"],[5021,5163,"There's still time."],[5334,5580,"Thank you for giving me the role."],[5776,5930,"I'm not done with you yet."]],"34":[[104,254,"Have you forgotten who I am?"],[312,400,"Have you forgotten"],[400,567,"what I can do with a knife?"],[675,792,"You are the Viper,"],[859,1051,"the world's deadliest assassin."],[1101,1201,"But I don't think that you're"],[1201,1297,"gonna hurt me."],[1363,1476,"Are you sure about that?"],[1530,1618,"You tricked me."],[1668,1847,"I've killed people for much less."],[2035,2110,"Then do it."],[2206,2314,"Kill me."],[2369,2552,"I dare you."],[2648,2794,"You don't think I'll do that?"],[4600,4692,"You may think that"],[4692,4871,"you're a cold-blooded killer,"],[4909,5067,"but if you wanted me dead,"],[5117,5226,"I'd already be dead."],[5284,5434,"I can always change my mind."],[5467,5622,"I am not getting tangled up"],[5622,5809,"in your deadly assassin game."],[6022,6093,"But..."],[6239,6418,"so much fun to play with you."]],"35":[[442,658,"You don't get it, do you?"],[696,842,"Before my mom died,"],[842,1009,"she secured my future."],[1055,1180,"A place in the city,"],[1217,1405,"a spot in this ballet company,"],[1476,1739,"an engagement to your brother."],[1826,2060,"But your stepmom, my family,"],[2060,2239,"they wanna rip it all away from me."],[2302,2485,"I can not back down now,"],[2485,2669,"or I will never have another chance."],[2798,2936,"You may be the Viper,"],[2977,3082,"and I don't care"],[3082,3249,"how many people you've killed,"],[3340,3482,"but you're not gonna"],[3482,3611,"stand in my way, too."],[3903,4007,"I shouldn't let her go."],[4068,4187,"She's a distraction."],[4267,4410,"She almost got the best of me,"],[4460,4600,"but I can't hurt her."],[4600,4778,"She will be the death of me."]],"36":[[241,412,"That bitch stole my part,"],[412,504,"and now she's cheating"],[504,579,"on her fiancé"],[579,788,"with his assassin brother?"],[880,1167,"She's going down."],[2360,2452,"This was the last thing"],[2452,2560,"that my mother gave me"],[2560,2665,"before she died."],[3461,3674,"You psycho bitch!"],[3674,3812,"You drugged me!"],[3999,4208,"I was supposed to be Swan Queen."],[4216,4391,"You destroyed my shoes"],[4391,4475,"and my leotard."],[4475,4625,"You plotted to take my role away,"],[4625,4708,"just like you were plotting"],[4708,4779,"to end my engagement."],[4779,4859,"What was I supposed to do?"],[4859,4954,"You were supposed to quit"],[4954,5071,"and go back to the farm!"],[5071,5230,"My mom didn't raise a quitter."],[5463,5768,"You are a fugly duckling,"],[5768,5897,"pretending to be a swan."],[5960,6101,"Do you think Madam Hargrove"],[6101,6202,"will keep you around"],[6202,6293,"when she realizes"],[6293,6448,"you cheated on her son"],[6510,6685,"with a deadly assassin?"]],"37":[[25,179,"A deadly assassin?"],[250,333,"Do you mean..."],[333,404,"The Viper."],[500,671,"Her fiancé's brother."],[792,863,"How does Valerie"],[863,992,"know about me and Jack?"],[1017,1151,"Did she see us together?"],[1334,1501,"Oh my God."],[1572,1697,"The Viper's hot."],[1718,1889,"He's a literal killer."],[1972,2185,"Looks like our little farm girl"],[2193,2410,"is a secret freak."],[2477,2577,"No wonder she got the part"],[2577,2794,"of Swan Queen."],[2915,3094,"She's the fuck buddy"],[3094,3182,"of the ballet's"],[3182,3445,"most dangerous benefactor."],[3545,3778,"You don't know what you're talking about."],[3820,3958,"I bet if we all threw ourselves"],[3958,4041,"at the Viper,"],[4041,4187,"we could be next in line"],[4187,4325,"for Prima Ballerina."],[4421,4650,"I mean, what do you have"],[4704,4804,"that we don't?"],[4896,4996,"Look at this."],[5372,5497,"No, please."],[5497,5588,"Put that down, please."],[5822,5893,"Hannah?"],[6026,6110,"Is this the only thing"],[6110,6289,"you brought with you from the farm?"],[6310,6418,"Val, come on."]],"38":[[20,125,"No, no no no-"],[379,496,"No, no."],[617,938,"First I cut your pointe shoes,"],[963,1113,"then I broke your ballerina."],[1172,1284,"But I'll make it up to you."],[1284,1343,"Hm?"],[1580,1897,"Oh, what gorgeous shoes."],[1897,1968,"Hm?"],[2060,2202,"Let me help you break them in."],[2535,2660,"Please, what are you doing?"],[2660,2744,"No, please, please."],[2777,2927,"What's wrong, Hannah?"],[2990,3032,"No!"],[3307,3399,"I thought you were sleeping"],[3399,3578,"with an assassin, aren't you?"]],"39":[[241,383,"What the hell is wrong with you?"],[429,729,"It was... just a, a joke, I-"],[729,842,"A, a joke?"],[2043,2118,"It's a joke?"],[2156,2310,"Then let's see all of you"],[2310,2531,"dance with glass in your shoes."],[2552,2627,"Do it!"],[2719,3136,"Or I slice her jugular."],[3762,3828,"No!"],[3916,4004,"Stop."],[4408,4475,"Please."]],"40":[[225,604,"I could never love a monster like you."],[1092,1322,"You three, out."],[1710,1772,"You've been cut"],[1772,1943,"from the Hargrove Ballet Company."],[1989,2118,"And if anything like this"],[2118,2285,"ever happens again,"],[2364,2569,"you'll be lucky to leave with your life."],[2627,2698,"Out!"]],"41":[[829,955,"It's not an assassin's nature"],[955,1272,"to be so... gentle."],[1322,1401,"He could have killed"],[1401,1518,"Valerie and her minions,"],[1518,1747,"just like he's killed so many others,"],[1747,1960,"but, he didn't."],[2031,2252,"Was it really for my sake?"],[2469,2631,"Why did you help me?"],[2660,2819,"You wanted to dance with glass"],[2819,2915,"in your shoes?"],[3144,3207,"Ms. Thatcher,"],[3207,3591,"does pain turn you on?"],[3591,3912,"No, I'm not twisted like you."],[3999,4112,"But I thought that you wanted me"],[4112,4237,"to go back to Indiana."],[4270,4404,"You know that if I can't dance,"],[4404,4575,"then I can't stay here"],[4575,4696,"and I can't marry your brother,"],[4696,4904,"so why keep protecting me?"],[5351,5476,"Maybe there's something about you"],[5476,5605,"I just can't resist."],[5822,5939,"Or maybe,"],[6093,6235,"my problem."],[6393,6548,"I wanna handle you myself."]],"42":[[779,913,"Your engagement with my brother"],[913,1080,"will go up in flames."],[1184,1338,"But you'll be the one to end it."],[1368,1430,"Yeah?"],[1522,1622,"Why is that?"],[1655,1776,"Because you don't want him."],[2152,2235,"Admit it."],[2410,2544,"You would rather have me."]],"43":[[408,487,"Jack."],[571,633,"You should know better"],[633,813,"than to sneak up on an assassin."],[850,917,"I told your father"],[917,1063,"you were trigger happy."],[1113,1418,"I'm looking for my Swan Queen."],[1659,1760,"What are you two doing here"],[1760,1843,"in the old auditorium?"],[1906,2135,"Um, nothing, madam."],[2193,2335,"It better be nothing."],[2335,2452,"If they're sneaking around,"],[2452,2677,"then I will ruin Hannah's reputation"],[2723,2798,"the same way"],[2798,2994,"she threatened to ruin mine."],[3015,3182,"Where are my ensemble dancers?"],[3228,3370,"Are they hiding here too?"],[3370,3482,"They tried to sabotage"],[3482,3599,"your Swan Queen."],[3599,3745,"So I did what you should have done"],[3745,3878,"as director of this ballet"],[3878,3991,"and I fired them."],[3991,4074,"What?"],[4104,4212,"You have no place."],[4304,4408,"This ballet is funded"],[4408,4579,"by the Reaper Assassin Guild."],[4579,4746,"I'm the guild's deadliest assassin."],[4746,4800,"You really think"],[4800,4934,"you can tell me my place?"],[5013,5084,"Hannah."],[5171,5301,"I need you in my office."],[6172,6318,"Does she know I kissed Jack?"],[6343,6439,"Is she gonna force me"],[6439,6539,"to end the engagement"],[6539,6623,"because of it?"],[6769,7015,"Elliott's stint at the Royal Ballet"],[7044,7165,"has finally ended"],[7165,7336,"and he's coming home tonight."],[7411,7761,"You finally get to meet your fiancé."]],"44":[[37,196,"You and your family"],[196,371,"are invited to dinner tonight."],[542,658,"Come just as you are."],[884,1113,"I can't risk Elliot falling for Hannah."],[1176,1422,"When he sees his farm girl fiancée"],[1422,1601,"and her fame seeking family,"],[1659,1864,"he'll beg me to get rid of her."],[1926,2072,"My sister's been hell bent on"],[2072,2202,"sabotaging my engagement"],[2202,2314,"since I arrived."],[2314,2531,"I'm sure this is Loyola's plan."],[2531,2681,"Get my family to humiliate me"],[2681,2773,"in front of Elliott"],[2773,2836,"so she can prove that"],[2836,2936,"I am no match for her son,"],[2936,3211,"but I am not going to let that happen."],[3432,3741,"Thank you so much for your invitation."],[3807,3920,"We'll be there."]],"45":[[50,137,"Elliott."],[321,408,"Who is this Hannah woman"],[408,513,"I've been promised to?"],[525,638,"I was Premier Danseurs"],[638,767,"of the Royal Ballet, Mother."],[796,921,"I have an image to protect."],[930,1084,"You'll see soon enough."],[1447,1780,"Loyola, your home is stunning."],[1818,1893,"Where's Hannah?"],[1931,2106,"She insisted on coming alone."],[2114,2339,"Not surprised she hasn't shown up yet."],[2389,2535,"She has no manners."],[2590,2777,"Mother, you know I hate"],[2802,2957,"when women keep me waiting."],[2957,3103,"If she's gonna waste my time,"],[3132,3324,"she better be drop dead gorgeous."],[3340,3424,"Gorgeous?"],[3603,3691,"Hardly."],[4054,4329,"Ms. Hannah Thatcher has arrived."]],"46":[[70,342,"You must be my fiancé, Elliott."],[387,550,"You are a vision."],[608,817,"It's an honor to meet you."],[1192,1430,"He's supposed to be disgusted by her,"],[1451,1597,"not kissing her."],[1922,2168,"What the hell happened to her?"],[2198,2389,"And why does she look so good?"],[2431,2752,"Don't let Elliott fall under her spell."],[2806,2923,"Humiliate her."],[2977,3178,"Show him she's nothing"],[3178,3357,"but a backwards gold-digger."],[3820,3953,"Thank God you're hot."],[3991,4112,"Otherwise I would've dumped you"],[4112,4225,"on the spot."],[4262,4454,"I was voted sexiest male dancer"],[4454,4633,"three years in a row."],[4633,4792,"I can't be married to a butterface."],[4821,4909,"Jack was right."],[4909,5059,"Elliott's a pompous brat."],[5067,5163,"But I have to put up with him"],[5163,5359,"if I want to become Prima Ballerina."],[5693,5851,"Happy to please you."],[5872,5968,"I'm sure you are."],[6018,6289,"You're a pro at pleasing Hargroves,"],[6289,6398,"aren't you, Hannah?"],[6398,6514,"What's that supposed to mean?"],[6535,6644,"It means she's cheating."],[6681,6769,"Cheated?"],[6769,6865,"That's right."],[6877,7119,"Little Miss Prima Ballerina"],[7119,7332,"has been sleeping her way to her top."]],"47":[[421,638,"Did she see me with Jack?"],[709,804,"Is this true?"],[963,1146,"I'm sure that my sister's"],[1146,1330,"just a little bit jealous."],[1347,1468,"You see, she got fired"],[1468,1618,"from the Hargrove Ballet Company,"],[1618,1939,"while I got the role of Swan Queen."],[1976,2106,"I'm not jealous!"],[2106,2331,"Hannah, I just"],[2531,2781,"don't want Elliott to get hurt."],[2827,2990,"Are you fucking another guy?"],[3028,3244,"I'm not marrying some used-up slut."],[3470,3674,"This is going even better than I hoped."],[3703,3795,"And I'd rather not"],[3795,3949,"marry an elitist snob."],[3958,4137,"But I need this engagement."],[4266,4354,"I don't know"],[4354,4475,"what Valerie's talking about,"],[4475,4579,"I promise."],[4683,4854,"Do you wanna tell him, Hannah?"],[4925,5088,"Or should I say his name?"],[5184,5288,"I don't know, Val."],[5347,5505,"Do you wanna die tonight?"],[5626,5718,"Hannah!"],[5718,5905,"Your father paid your way"],[5905,6026,"into the big city"],[6026,6227,"out of the kindness of his heart."],[6256,6619,"And since the moment you arrived,"],[6690,6790,"you've been acting like"],[6790,6919,"an ungrateful bitch!"]],"48":[[992,1105,"You weren't about to touch her,"],[1105,1184,"were you?"],[1192,1276,"No."],[1297,1559,"Are, are you gonna kill me?"],[1680,1897,"Only if Miss Thatcher asks me to."],[2268,2381,"Jack's playing games like"],[2381,2498,"he always does."],[2498,2598,"He might've saved me"],[2598,2702,"from my family,"],[2723,2886,"but is he only here to sabotage"],[2886,3023,"my engagement himself?"],[3107,3370,"No, that's not necessary."],[4183,4358,"Do you two know each other?"]],"49":[[116,187,"Do we?"],[575,675,"Um."],[867,984,"Barely."],[1034,1213,"Jack, what the hell are you doing here?"],[1238,1426,"I'm part of this family too, aren't I?"],[1443,1539,"Couldn't miss the chance"],[1539,1680,"to see my baby brother,"],[1722,1797,"and his"],[1964,2060,"fiancée."],[2139,2198,"You've got a"],[2198,2302,"one-hundred million dollar"],[2302,2527,"bounty on your head, big brother."],[2585,2660,"Do you know how much"],[2660,2773,"this face is worth?"],[2819,2915,"I'm not trying to get maimed"],[2915,3069,"by a mafia thug tonight."],[3069,3282,"So you uh, you care about protecting"],[3282,3420,"yourself but not your fiancée?"],[3607,3774,"I see you haven't changed a bit."],[3782,3866,"What would you know"],[3866,3974,"about protecting women?"],[3974,4087,"You use and lose them faster"],[4087,4245,"than the bullets in your guns."],[4245,4375,"I see that's where you're wrong,"],[4375,4437,"little brother."],[4458,4642,"There's one little thief"],[4788,5000,"I can't seem to get off my mind."],[5793,5868,"What are you doing"],[5868,6039,"under the table, Hannah?"],[6377,6552,"Did you forget your manners?"]],"50":[[4,150,"Did you forget your manners?"],[905,1076,"Did you forget your manners?"],[1197,1343,"Spying isn't polite."],[1876,2035,"What are you doing here anyway?"],[2077,2160,"Didn't I fire you"],[2160,2289,"from the ballet today?"],[2369,2594,"I, I was just-"],[2606,2811,"Mr. Viper, Jack, uh,"],[2831,2952,"Valerie was just"],[2952,3078,"acting out of concern"],[3078,3211,"for your brother."],[3228,3440,"Hannah grew up on a farm."],[3440,3574,"She doesn't know how to act."],[3574,3657,"Hannah's not the one"],[3657,3787,"that I'm concerned about."],[3862,4012,"You and your family are the one"],[4012,4191,"who behave like barn animals."],[4329,4592,"Is he standing up for me?"],[4621,4738,"Jack, the Thatchers"],[4738,4929,"are your future in-laws."],[4938,5159,"Please, show some respect."],[5159,5234,"I will."],[5280,5384,"When they show Hannah"],[5384,5463,"some respect."],[5547,5684,"You talk like my fiancée"],[5684,5847,"is yours to protect."],[5847,5989,"Too bad you can't have her."],[6206,6314,"Oh."],[6393,6489,"Oh."],[6835,7002,"I'll announce our engagement"],[7002,7194,"opening night of Swan Lake."],[7436,7682,"And then she'll be my wife."],[8028,8216,"Jack's probably loving this."],[8224,8333,"I got what I wanted,"],[8354,8441,"a ring from his brother."],[8441,8679,"But I had to be humiliated to get it."],[9017,9184,"Is that all she is to you?"],[9230,9463,"A tool to make me jealous?"]],"51":[[20,141,"I think I need to get some air."],[392,567,"I'm suddenly not feeling very well."],[567,688,"Um, I'm gonna..."],[946,1063,"Thank you for the dinner,"],[1063,1163,"it was wonderful, and"],[1309,1459,"thank you so much for the ring,"],[1459,1639,"it is very beautiful."],[1722,1822,"I need to go."],[1931,2035,"I'm not feeling very hungry"],[2035,2156,"anymore either."],[2523,2648,"Very happy for you and Hannah."],[2923,3019,"At least the"],[3019,3165,"engagement's still on."],[3474,3582,"Something's going on"],[3582,3699,"between Jack and Hannah."],[3699,3878,"I have to end her"],[3878,4154,"before he ruins all of my plans."],[4667,4763,"Told you my brother was"],[4763,4896,"a spineless idiot."],[5397,5509,"Now you can see"],[5509,5734,"why you'd never want him,"],[5776,5935,"the way you want me."]],"52":[[8,145,"I should hate Jack."],[183,275,"I should push him away"],[275,387,"once and for all."],[404,508,"He ruins everything,"],[508,642,"every plan that I make,"],[642,813,"every step that I take, and yet,"],[829,959,"when he looks at me like this,"],[959,1201,"everything else just falls away."],[1359,1593,"I saw the way you squirmed for me."],[1889,2039,"Just like you're doing now."],[2072,2227,"I couldn't help it."],[2306,2414,"You're a deadly assassin"],[2414,2560,"and I can't fight you."],[2594,2690,"That's a lie."],[2827,3007,"You've fought me plenty of times,"],[3032,3148,"little thief."],[3215,3361,"You can't stand to see me"],[3361,3511,"with your brother, can you?"],[3707,3791,"You know,"],[3849,4095,"you are just as bad as him."],[4250,4479,"You don't actually want me."],[4537,4692,"You just like playing with me."],[4771,4888,"You're the one kissing me"],[4888,5005,"while you're insisting that"],[5005,5155,"you're engaged to my brother."],[5167,5417,"I am not like you, okay?"],[5417,5563,"You enjoy the hunt."],[5563,5772,"You like having me as prey."],[5901,6093,"Is that all that you think this is?"],[6185,6381,"What else would it be, huh?"],[6435,6602,"You finally falling for me?"],[6639,6810,"Am I finally melting"],[6810,6981,"the cold heart of the Viper?"],[9305,9413,"You know what?"]],"53":[[842,942,"No."],[1201,1334,"What if I said yes?"],[1472,1589,"Do you mean that?"],[1634,1947,"You've hypnotized me, little thief."],[2139,2364,"I chose this life. The hunt,"],[2364,2569,"the chase, the kill."],[2585,2744,"But I look into your eyes and..."],[2902,2969,"it makes me think"],[2969,3103,"I could give it all up."],[3153,3282,"You would do that for me?"],[3411,3495,"Jack."]],"54":[[20,179,"Oh my God, oh my God."],[179,342,"We need to call an ambulance."],[425,517,"You know how big the bounty"],[517,604,"is on my head?"],[688,829,"If I'm in a hospital, you might as well"],[829,996,"hand deliver me to Rivalchek yourself."],[996,1155,"But Jack, you're bleeding out!"],[1309,1476,"Hey, hey, hey,"],[1476,1634,"you still owe me for saving you."],[1735,1893,"I'm cashing in on the favor now."],[1893,1989,"Get me to a safe house."],[1989,2122,"Okay, okay, come on, come on."],[3044,3186,"We gotta get the bullet out."],[3249,3319,"Yeah."],[3578,3628,"Okay."],[3937,4145,"Oh my God, you're bleeding out."],[4208,4308,"First aid kit."],[4308,4412,"Okay."],[4608,4775,"It's the second drawer on the left."],[4775,4850,"Okay."],[5121,5167,"Okay."],[5397,5497,"Tweezers."],[5663,5759,"Here."],[6085,6247,"You might wanna look away."],[6314,6398,"Oh."],[6760,6869,"Ooh."],[6869,6940,"Mm."],[7236,7528,"There's a, a needle and thread in there."],[7528,7603,"Okay."],[7849,8024,"You're gonna have to do this part."]],"55":[[150,354,"No, no, no. I, I can't."],[354,483,"Hannah, please."],[1359,1609,"Okay, I can do this."],[1643,1743,"Remember,"],[1876,1997,"you're tougher than you look,"],[1997,2085,"little thief."],[2177,2268,"Okay?"],[3219,3294,"Okay."],[3395,3670,"Now we're even, Hannah Thatcher."],[3908,4133,"You look beautiful tonight, you know?"],[4354,4521,"I hate that you got all dressed up"],[4521,4629,"for my brother."],[4838,5025,"I knew you that were jealous."],[5384,5451,"Okay."],[5451,5505,"Wait."],[5814,5918,"Stay with me."]],"56":[[8,329,"My family's already suspicious."],[354,563,"One of my enemies saw us together."],[646,850,"You're not safe out there alone."],[917,1180,"Did you really mean what you said?"],[1343,1543,"That you're falling for me?"],[1659,1764,"This is why I told you to"],[1764,1939,"go back to Indiana."],[2085,2198,"To protect you"],[2248,2331,"from this."],[2456,2527,"I knew that you would"],[2527,2615,"be my weakness."],[2615,2660,"I knew that"],[2660,2823,"I would put a target on your back."],[3094,3228,"You're right, Hannah."],[3315,3465,"I am a monster."],[3561,3670,"And I can't fight the way"],[3670,3812,"that I feel about you anymore."],[3858,3945,"If you want to run,"],[3945,4166,"you should just, you should do it now."]],"57":[[158,354,"This man opened up his heart to me."],[383,513,"He took a bullet for me."],[688,859,"Ever since my mom died,"],[1001,1188,"no one has ever protected me."],[1518,1668,"Running away from you is the last thing"],[1668,1801,"that I want to do right now."],[1918,2052,"Hannah, you're the first person"],[2052,2131,"I've ever met"],[2131,2223,"who fights for someone"],[2223,2369,"that I can't even name."],[2519,2698,"You fight for your freedom,"],[2727,2861,"for a dream,"],[2986,3199,"for a life beyond bloodshed"],[3199,3299,"and shadows."],[3403,3582,"When I look at you, for the first time,"],[3745,3837,"I wonder if I could be"],[3837,4012,"more than just a weapon."],[4437,4508,"Jack,"],[4650,4733,"you're right."],[4804,4917,"I want you."],[5801,5914,"Then tonight,"]],"58":[[196,312,"You're mine."]],"59":[[775,1055,"I slept with Jack, the Viper,"],[1076,1197,"my fiancée's brother,"],[1197,1388,"the world's deadliest assassin."],[1426,1568,"What was I thinking?"],[1597,1726,"I don't want to marry his brother,"],[1726,1851,"but I have to."],[2006,2177,"If I let Jack consume me,"],[2189,2369,"it will ruin everything."],[3232,3357,"You could've stabbed me."],[3474,3620,"Only if I wanted to."],[4141,4241,"Why are you so desperate"],[4241,4341,"to wear this again?"],[4341,4483,"What happened last night"],[4483,4592,"doesn't change the fact that"],[4592,4758,"I'm engaged to your brother."],[4829,4900,"Then why the hell"],[4900,5034,"did you sleep with me?"],[5046,5192,"I didn't force you to do that, Hannah."],[5192,5301,"I told you to walk away."],[5372,5563,"Why did you sleep with me, huh?"],[5630,5768,"Are you gonna propose?"],[5789,5868,"No?"],[6064,6243,"I want her to be mine, forever."],[6277,6410,"But every killer who wants a cut"],[6410,6514,"of the bounty on my head"],[6514,6694,"would go after her first."],[7044,7173,"You were almost shot,"],[7173,7340,"and it could've been a lot worse."],[7403,7515,"My enemies will do anything"],[7515,7678,"to get close enough to kill me."],[7724,7832,"If I married you, you'd be my"],[7832,8008,"greatest weakness, don't you get that?"],[8062,8162,"If I'll never be your wife,"],[8162,8274,"then what am I to you?"],[8487,8675,"What am I to you, Jack?"]],"60":[[150,287,"A liability."],[333,542,"Then stay the hell away from me."],[784,1038,"You know, I am so, so sick of you"],[1038,1155,"tracking my every move"],[1155,1255,"and screwing with every"],[1255,1397,"single plan that I make and..."],[2298,2481,"You wouldn't have survived one night"],[2481,2648,"in this city if it wasn't for me."],[2648,2736,"And if you didn't wanna be"],[2736,2790,"tracked down,"],[2790,2902,"then you never should've stolen"],[2902,3036,"an assassin's gun."],[3053,3365,"God, you are so, so selfish!"],[3461,3611,"You know why I had to"],[3611,3724,"marry your brother."],[3741,3953,"To take back what my family"],[3953,4049,"stole from me."],[4137,4320,"And if you're not gonna help me do it,"],[4346,4550,"then you can stay away from me."],[4550,4829,"Elliott doesn't love you, Hannah."],[4863,5025,"You'll never be happy with him."],[5046,5242,"Yeah, well, you don't love me either."],[5292,5380,"At least with him,"],[5380,5555,"I can be Prima Ballerina."],[5588,5805,"I can live my dream."],[5964,6131,"I'll finally be free from you."],[6264,6364,"Look, you're putting yourself"],[6364,6535,"in danger going out there alone."],[6564,6740,"I'm more in danger here with you."],[6877,7094,"It's not like you love me either."],[8320,8470,"I should let her walk away."],[8504,8675,"I should let her believe that."],[8692,8792,"But I can't."]],"61":[[917,1113,"Why are you here, Jack?"],[3065,3232,"What the hell are you doing?"],[3240,3428,"You told me that you didn't want me."],[3428,3549,"You walked away from me!"],[3549,3762,"I never said that I didn't want you."],[4091,4258,"Run away with me, Hannah."]],"62":[[145,291,"Are you serious?"],[358,592,"I am engaged to your brother."],[613,654,"He's making"],[654,742,"an announcement tonight"],[742,880,"in front of everyone at the opening."],[880,1005,"I can't let you marry him."],[1092,1197,"But there are still men"],[1197,1313,"hunting you down."],[1313,1555,"You have a bounty on your head!"],[1601,1805,"You said it yourself, I am a liability."],[1851,1989,"I don't wanna be the reason that you die"],[1989,2135,"and I don't wanna die because I love-"],[2831,2902,"You won't."],[3007,3153,"I'll slaughter all of them."],[3199,3319,"I'll kill a thousand men"],[3319,3474,"if it means that I can be with you."],[3474,3611,"Do you hear yourself?"],[3670,3787,"I don't want any more blood"],[3787,3920,"on my hands."],[3937,4037,"Then come with me."],[4099,4254,"Hannah, there are ballet companies"],[4254,4354,"all over the world."],[4354,4491,"I can hide out, I can pick those-"],[4491,4554,"No."]],"63":[[29,250,"My mom used her dying breath"],[250,367,"to secure my engagement"],[367,446,"to your brother."],[563,658,"She knew that"],[658,775,"being Prima Ballerina"],[775,838,"was my dream"],[838,1080,"and I, I can't give it up."],[1622,1751,"Not even for love?"],[2373,2515,"Then pull the trigger, little thief."],[2723,2882,"Kill me and you get a hundred million."],[2882,2932,"You can buy"],[2932,3044,"the Hargrove Ballet Company"],[3044,3128,"with that money."],[3228,3336,"Better you than any of those"],[3336,3495,"Russian mafia bastards."],[3607,3774,"He'd rather sacrifice himself"],[3774,3883,"than let me go,"],[3908,4037,"but I couldn't kill him"],[4037,4212,"for all of the money in the world."],[4237,4312,"Come on!"],[4917,4979,"Take it."],[5276,5380,"If you're not gonna come with me,"],[5380,5451,"then at least let me help you"],[5451,5551,"protect yourself."],[8233,8329,"Break a leg tonight."]],"64":[[279,442,"Is everything ready for tonight?"],[750,942,"As soon as the ballet ends,"],[971,1134,"the real show begins."],[1247,1488,"And both of them will go down, yes?"],[1488,1589,"The ballerina will be easy"],[1589,1693,"to take out for my men"],[1747,2035,"and I will kill Jack Hargrove myself."],[2127,2223,"Excellent."],[3887,3983,"Rivalchek and his men"],[3983,4079,"are on the move."],[4112,4320,"They're headed to the ballet."],[4358,4429,"Hannah."],[5138,5246,"Before she died,"],[5288,5447,"my mom did everything she could"],[5447,5555,"to make sure that one day"],[5555,5747,"I'd become Prima Ballerina"],[5747,5889,"of the Hargrove company."],[5889,6131,"Tonight, I will dance as a Swan Queen."],[6151,6348,"Eliott will announce our engagement."],[6348,6623,"And my mom's dreams, my dreams,"],[6623,6781,"will become my reality."],[6781,6977,"I will make her proud."],[7686,7757,"Jack?"],[7853,7962,"What are you doing sneaking around"],[7962,8128,"in my fiancee's dressing room?"]],"65":[[25,120,"Is it a crime to wish"],[120,250,"my future sister-in-law"],[250,342,"good luck?"],[412,542,"With that bounty on your head,"],[542,588,"you should be"],[588,717,"a hundred miles from here."],[738,813,"What are you doing,"],[813,967,"endangering everyone's lives?"],[984,1101,"This is perfect."],[1113,1255,"If Baron thinks Jack"],[1255,1438,"drew Rivalchek's men here,"],[1438,1601,"then he'll never suspect"],[1601,1810,"that I hired him myself."],[1810,1997,"Well, Jack is selfish."],[2077,2185,"He knows how much"],[2185,2373,"today means for the ballet,"],[2389,2523,"but he insists on"],[2523,2681,"turning my opening night"],[2681,2819,"into his war zone."],[2819,2890,"Are you here"],[2890,2994,"because you're jealous?"],[2994,3128,"You really can't stand"],[3128,3240,"that I'm getting the girl,"],[3240,3403,"so you're here to sabotage me."],[3403,3486,"Is that it?"],[3620,3737,"Don't flatter yourself,"],[3737,3832,"little brother."],[3908,4129,"I'm very happy for you two."],[4700,4813,"Don't worry, son."],[4846,4942,"After tonight,"],[4967,5088,"Jack won't be a problem"],[5088,5230,"for us anymore."],[5588,5747,"A Reaper Assassin"],[5747,5897,"should stay in the shadows."],[5947,6110,"One wrong move, you could be dead."],[6177,6410,"Do not die tonight."]],"66":[[95,325,"Your strap is horribly twisted."],[567,638,"Turn."],[817,934,"Places, everyone."],[1672,1864,"Your entire life"],[1922,2147,"rests on this performance."],[2348,2444,"Break a leg."],[2781,2898,"You've got this, Hannah."],[2957,3065,"Eye on the target,"],[3103,3219,"find the trigger."],[8754,8913,"She's incandescent."],[8913,9054,"I can't take my eyes off her."],[9125,9259,"Where did the Hargroves find"],[9259,9442,"such an exceptional Prima?"],[9672,9809,"If all goes well tonight,"],[9830,9930,"Eliott and I will start"],[9930,10026,"planning our wedding,"],[10026,10105,"and my place"],[10105,10247,"as Hargrove Ballet Company's"],[10247,10456,"Prima Ballerina will be solidified."],[11736,11974,"This is everything I've ever wanted."],[12020,12208,"So why does it feel like,"],[12299,12458,"like something's missing?"],[12650,12783,"Hannah's talented."],[12821,12979,"She deserves to live her dream."],[13092,13284,"I'll take Rivalchek down tonight,"],[13313,13492,"even if it means I go down too."],[13651,13792,"And if I live through this,"],[13859,14055,"then I'm finally making her mine."]],"67":[[1543,1655,"Thank you all for being here"],[1655,1747,"for Hannah Thatcher's"],[1747,1868,"big debut."],[1901,2010,"She's a rising star"],[2010,2173,"at the Hargrove Ballet Company,"],[2214,2327,"but she's more than that."],[2402,2519,"I want the whole world to know"],[2519,2702,"that Hannah and I are engaged."],[4275,4433,"Kill the Swan Queen!"],[4462,4662,"Then bring me the Viper's head."],[6598,6785,"Hey, hey, stay behind me."],[6785,7048,"Viper, come out, come out,"],[7048,7219,"wherever you are."],[7390,7494,"You can't take all these guys on"],[7494,7590,"by yourself."],[7661,7791,"Don't worry, I'm not dying today,"],[7791,7878,"little thief."],[7928,7991,"Still haven't gotten a chance"],[7991,8099,"to propose to you yet."]],"68":[[141,321,"Wait, wait, you wanna marry me?"],[383,579,"But I thought that I was your weakness,"],[579,700,"a liability."],[700,779,"Hannah,"],[809,896,"this war started"],[896,1026,"long before you and I met,"],[1076,1180,"and I'd rather finish it with you"],[1180,1280,"by my side."],[1422,1530,"Jack."],[2669,2944,"Does he really love her?"],[2990,3169,"With the bounty on Jack's head,"],[3169,3299,"no one will be surprised"],[3299,3399,"when he and Hannah"],[3399,3641,"are tragically killed in the ambush."],[3641,3791,"No one will suspect"],[3791,4066,"I hired Rivalchek to take them out."],[4404,4466,"Jack!"],[5025,5192,"Come on, come on, come on."]],"69":[[229,375,"We're never gonna make it out of here."],[379,563,"Hey, hey, hey, I'm not gonna let you die."],[600,650,"Alright?"],[650,746,"I'll tear them limb from limb"],[746,892,"with my bare hands if I have to."],[1026,1172,"I will protect you."],[1292,1447,"You're not my weakness, Hannah."],[1514,1626,"You make me wanna fight harder"],[1626,1785,"than I ever have before."],[1826,1897,"You're the first person"],[1897,1976,"that's made me believe"],[1976,2147,"that there's a life outside of killing,"],[2193,2327,"and that terrifies me"],[2327,2439,"more than any bullet."],[2519,2756,"Jack, I love you."]],"70":[[108,221,"How fast can you run?"],[241,300,"I'm out of bullets"],[300,437,"and Rivalchek brought the big guns."],[521,588,"Let's go."],[638,750,"That's my little thief."],[1272,1539,"So this is the great, mighty Viper."],[1689,1897,"You look more like a rat to me."],[2052,2181,"You shouldn't have said that."],[4992,5096,"Hey."],[5121,5238,"Nice shot, little thief."],[5296,5434,"Well, I learned from the best."],[5518,5588,"Come on."],[5609,5676,"Okay."]],"71":[[20,154,"How are they still alive?"],[179,350,"Rivalchek must be dead."],[396,492,"What do I do?"],[492,658,"Have I sealed my own fate?"],[700,909,"Jack can never know I set him up."],[909,1167,"Thank God dead men can't speak."],[1501,1668,"Where do you think you're going, Loyola?"],[1714,1847,"I thought you were smarter than this."],[1876,2018,"I don't know what you're talking about."],[2168,2369,"I, you almost got us all killed."],[2369,2590,"You called Luka Rivalchek."],[2590,2731,"You wanted us all dead."],[2731,2932,"Loyola would never do anything"],[2932,3053,"to hurt our family."],[3061,3253,"Your wife was sleeping"],[3253,3361,"with Rivalchek,"],[3445,3495,"sworn enemy"],[3495,3616,"of the Reaper Assassin Guild."],[3616,3707,"She called him here tonight"],[3707,3807,"for another favor."],[3807,3995,"No, that can't be true."],[4037,4275,"Actually, I have proof."],[4312,4404,"No!"],[4637,4746,"He threatened me!"],[4746,4892,"He threatened our family!"],[4917,5050,"He's a killer, Baron."],[5171,5317,"I had no choice!"],[5347,5459,"Doesn't look like that."],[5484,5659,"It looks like you begged for it."],[5659,5830,"It was a mistake, Baron."],[5830,6031,"How dare you use"],[6031,6214,"me to hurt our family?"],[6381,6577,"Just destroy everything"],[6577,6681,"that I've built."],[6777,6881,"I'll kill you myself! - No!"],[6881,6952,"No!"],[7069,7211,"After everything she did to Hannah,"],[7323,7461,"she deserves to suffer."]],"72":[[16,162,"But, but, but, who's"],[162,308,"gonna run the ballet company?"],[308,462,"I think Hannah can."],[542,738,"Well, what do you say, Miss Thatcher?"],[767,913,"Are you up for the challenge?"],[1180,1288,"I won't let you down."],[1388,1472,"No!"],[1493,1601,"Take her to my office."],[1680,1780,"Every ounce of pain"],[1780,1897,"she inflicted on Hannah,"],[1897,2006,"I want her to feel it"],[2085,2152,"tenfold."],[2181,2248,"No!"],[2293,2377,"No!"],[2644,2719,"I swear I didn't know"],[2719,2865,"my mother would do that to you."],[2977,3094,"We're still getting married, right?"],[3094,3178,"You're the most talented person"],[3178,3265,"I've ever met."],[3265,3407,"I believe you, okay?"],[3407,3620,"But, but I don't love you."],[3620,3853,"And, and I'm sorry, but I can't marry you."],[4041,4145,"Are you kidding me?"],[4233,4316,"You know you're nothing"],[4316,4462,"without my name, right?"],[4462,4550,"She's a hell of a lot more"],[4550,4683,"than you'll ever be."]],"73":[[575,738,"You fought your way from nothing"],[825,988,"to become Prima Ballerina."],[1055,1226,"You suffered the abuse of your family,"],[1226,1413,"and you still fought for your dreams."],[1501,1689,"And you're one cunning little thief"],[1705,1835,"who stole my heart."],[1910,2056,"You don't need the Hargrove name,"],[2056,2177,"but if you still want it,"],[2431,2510,"you can have mine."],[2877,2986,"Hannah Thatcher,"],[3111,3244,"will you be my wife?"],[3482,3603,"Yes, I will."],[4279,4441,"You're all mine now, little thief."],[5146,5209,"What is it?"],[5397,5568,"It's the bounty on Rivalchek's head."],[5689,5826,"I think this belongs to you."],[5943,6026,"What are you gonna do with it?"],[6360,6452,"I have an idea."],[6531,6656,"Come on."]],"74":[[742,846,"Go back to the farm"],[846,992,"where you came from."],[1001,1155,"This is our home!"],[1155,1401,"Actually, this was my mother's home,"],[1401,1547,"and she wanted me to have it,"],[1547,1751,"so I bought it out from under you."],[1935,2131,"You can't put us out in the streets!"],[2131,2223,"I'm your father."],[2223,2431,"Well, you should have acted like it."],[2556,2736,"Don't worry if you guys get desperate."],[2736,2840,"I know a farm in Indiana"],[2840,3032,"who could use some extra hands."],[3144,3278,"You're ruthless, you know that?"],[3357,3632,"Yeah, well, I learned from the best."]]}