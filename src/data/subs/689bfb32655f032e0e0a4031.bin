{"1":[[41,341,"Ten years of loving you in silence."],[341,537,"Five years of marriage."],[537,812,"I gave you fifteen years of my life, Eric."],[900,1079,"And not once did you look at me."],[1145,1200,"The doctor said"],[1200,1362,"I don't have much time left."],[1408,1658,"And our baby is gone."],[1758,1883,"I never blamed you."],[1929,2079,"But I'm tired now."],[2120,2283,"I won't bother you anymore."],[2337,2425,"You're free now."],[2795,2920,"Happy anniversary."],[2920,3033,"You two have shared"],[3033,3220,"five amazing years together."],[3258,3458,"So, come on, cut the cake already,"],[3458,3545,"so we can cheers"],[3545,3695,"to many more to come."],[3895,4020,"If you ever drag my mom"],[4020,4145,"into something this stupid again,"],[4145,4220,"we're done."],[4237,4308,"You hear me?"],[4320,4420,"She was the one who told me-"],[4420,4495,"Stop!"],[4708,4908,"I can't bear to watch this anymore."],[5095,5308,"Five years ago,"],[5383,5708,"Eric begged you to save my life,"],[5770,5908,"forced him to marry you,"],[5945,6183,"locked him up like some prisoner."],[6258,6533,"Don't you think it's about time"],[6608,6845,"that you gave me back my fiancé?"]],"2":[[8,154,"Isn't that Amanda Blackburn?"],[154,254,"The evil, spoiled brat"],[254,366,"of the Blackburn family?"],[416,554,"I can't believe she has the audacity"],[554,691,"to show her face here."],[791,945,"Amanda, I think you've had"],[945,1079,"a little bit too much to drink."],[1079,1141,"Oh."],[1141,1279,"Eric is my husband,"],[1279,1379,"I think you should leave."],[1379,1441,"No, no!"],[1441,1616,"He was supposed to be my husband."],[1616,1741,"You stole him from me!"],[1741,1879,"Amanda, he's not your husband."],[1991,2129,"And if he hadn't married me,"],[2129,2254,"you'd be rotting in jail right now."],[2254,2379,"Okay, that's enough, Grace."],[2379,2504,"Don't make things up."],[2641,2816,"I'm not making anything up."],[3129,3304,"Eric can't ever find out"],[3304,3416,"what happened back then."],[3429,3566,"Eric, tell me."],[3666,3754,"Right now,"],[3754,3891,"in front of everyone!"],[4104,4241,"Who do you really love?"],[4266,4404,"Amanda, put the knife down."],[4429,4458,"No."],[4466,4504,"No!"],[4504,4641,"I want an answer."],[4833,4908,"Is it me?"],[4966,5104,"Or is it Grace?"],[5441,5504,"It's you."],[5554,5666,"Oh, no."],[6425,6483,"Eric."],[6554,6641,"Eric, look at me."],[6679,6841,"In our five years together,"],[6841,6916,"was there ever,"],[6966,7079,"was there ever a moment"],[7079,7316,"or like even a second"],[7466,7554,"where you loved me?"],[8116,8166,"No."],[8279,8329,"Never."],[8754,8866,"No, just, I can't-"],[8879,8979,"Eric."],[9129,9241,"He chose me."],[9316,9379,"Oh!"],[10141,10216,"Grace."],[10241,10341,"Call 911!"],[10366,10516,"Someone call 911!"]],"3":[[20,120,"Call 911!"],[120,283,"Someone call 911!"],[370,595,"If anything happens to Grace"],[595,708,"or my grandchild,"],[745,904,"I will make sure you and your family"],[904,1070,"go straight to hell."],[1258,1370,"Eric, I didn't mean to."],[1370,1458,"I, I wasn't"],[1483,1520,"I-"],[1520,1583,"Eric."],[1770,1833,"Eric."],[1908,2033,"Eric, it hurts."],[2833,2958,"Eric, please!"],[2958,3033,"Eric."],[3083,3158,"Eric."],[4095,4320,"Hazel, Mom, take care of Grace."],[4320,4470,"I gotta get Amanda to a hospital."],[4608,4708,"No, Eric!"],[4933,4995,"Eric."],[5333,5433,"Eric!"],[5470,5595,"Eric, please!"],[5804,5900,"Once again,"],[5900,6050,"you left me for her,"],[6075,6141,"I give up,"],[6183,6312,"I can't do this anymore."],[6320,6358,"Grace."],[6358,6433,"Grace!"],[6433,6495,"Grace!"]],"4":[[70,320,"We were unable to save the baby."],[383,470,"And it's unlikely"],[470,620,"you'll be able to conceive again."],[633,733,"I'm so sorry."],[745,895,"Thank you, Doctor."],[1133,1258,"Baby or no baby,"],[1383,1520,"you will always be family."],[1595,1683,"You will always be"],[1683,1783,"the only daughter-in-law"],[1783,1895,"I ever recognize."],[2033,2158,"Besides, you're still young."],[2233,2358,"There'll be options for you."],[2483,2595,"Thank you, Maria,"],[2795,2895,"but it's fine."],[2920,3045,"I'm so sorry."],[3545,3708,"Ma'am, I'm sorry to inform you."],[3754,3812,"The miscarriage"],[3812,3941,"has worsened your cancer."],[4000,4195,"You have less than a month to live."],[4295,4370,"Let's get you home."],[4445,4508,"Can I,"],[4575,4670,"can I have a minute?"],[4754,4920,"I, I just need some time alone."],[4983,5045,"Of course."],[5120,5258,"Take as much time as you need."],[6858,7183,"I knew that when the time was right,"],[7220,7345,"you'd choose me."],[7645,7745,"I love you."]],"5":[[391,533,"While I was losing our baby,"],[562,687,"my husband was in another woman's"],[687,745,"hospital room."],[754,816,"Eric."],[916,1241,"Nobody treats me the way you do."],[2475,2554,"You once promised"],[2554,2675,"to love me forever,"],[2804,2908,"to protect me,"],[3037,3116,"but now I see"],[3191,3258,"some promises"],[3258,3395,"are made to be broken."],[4966,5079,"We lost the baby."],[5366,5441,"Then it's gone."],[5591,5729,"It's probably for the best anyway."],[5729,5866,"It's not like I ever wanted it."],[5916,5991,"If you hadn't crawled"],[5991,6079,"into my bed that night"],[6079,6141,"when I was drunk"],[6141,6254,"and tricked me into sleeping with you"],[6254,6304,"there never even"],[6304,6416,"would have been a baby."],[6841,6916,"Sign it."],[6979,7066,"Let's end this."]],"6":[[37,137,"Let's end this."],[775,887,"Grace, what game are you playing"],[887,950,"at this time?"],[962,1037,"No games."],[1137,1212,"No tricks."],[1300,1375,"I was wrong."],[1450,1516,"I never should have"],[1516,1625,"come between you and Amanda"],[1625,1700,"five years ago."],[1837,2050,"I took advantage of your pain."],[2150,2250,"I was selfish."],[2312,2400,"But I see it."],[2587,2662,"I see it now."],[2887,2950,"Sign that,"],[2987,3125,"and you never have to see me again."],[3212,3287,"I'm surprised someone"],[3287,3387,"as shameless as you"],[3387,3475,"can have regrets."],[3475,3662,"Even someone as shameless as me,"],[3854,4012,"still has a shred of dignity."],[4062,4137,"Divorce,"],[4166,4362,"it's my last attempt to Eric."],[4404,4537,"Will he really sign it?"],[4550,4587,"Fine."],[5337,5379,"There,"],[5387,5450,"it's done."],[5562,5604,"Not sure who's going to"],[5604,5687,"want you after this,"],[5687,5750,"but good luck."],[5750,5837,"And remember your promise."],[5837,5925,"Don't ever show your face"],[5925,5975,"around me-"],[5975,6037,"You won't."],[6262,6350,"This time I'll make sure"],[6350,6462,"you never find me."],[6600,6775,"You better stand by your words."],[7375,7437,"Grace."],[7537,7687,"All of these years you were just"],[7687,7825,"lying to yourself."],[7875,8037,"You thought if you held on long enough,"],[8087,8187,"he might love you."],[8287,8400,"But he never did."],[9062,9250,"What the hell is going on with her?"],[9337,9512,"She's never acted like this before."]],"7":[[66,166,"No way."],[191,379,"Grace, divorce me?"],[379,491,"She's obsessed."],[491,666,"She'd rather die than let go of me."],[675,816,"Ah, I get it now."],[904,966,"Is this your way of"],[966,1091,"getting my attention, Grace?"],[1220,1354,"I'm not falling for it."],[2200,2425,"I once thought that if I tried hard enough."],[2445,2650,"Someday you would love me back."],[2883,2954,"You're home."],[3166,3241,"I missed you."],[4429,4529,"I'll take the couch."],[5266,5416,"Eric, dinner's ready."],[5479,5604,"It's best if you eat it hot."],[5604,5816,"You can drop the doting wife act."],[6029,6141,"I'm not gonna touch that."],[6241,6354,"I've lost my appetite."],[7191,7304,"What was I thinking?"],[7404,7566,"He told me everything back then."],[7691,7795,"God, I really made a fool"],[7795,7916,"out of myself, didn't I?"],[8054,8179,"Thought that if I wanted something"],[8179,8279,"badly enough,"],[8354,8529,"I could wish it into existence."],[8579,8766,"Ma'am, everything's packed up."],[8804,8904,"Is there anything else?"],[8966,9091,"Take this wedding portrait."],[9291,9341,"Burn it."],[9416,9466,"You,"],[9491,9679,"you want us to burn your wedding photo?"],[9716,9779,"Are you sure?"],[9929,9979,"Yes."],[10229,10354,"Burn it to ashes."]],"8":[[41,170,"This is it."],[237,400,"This is only until I'm grown up enough"],[400,487,"to marry you."],[1033,1166,"I was so foolish."],[1270,1379,"Turns out I'm the only one"],[1379,1450,"who ever took our"],[1450,1620,"childhood promises seriously."],[2475,2600,"Was there ever a moment"],[2600,2700,"where you loved me?"],[2700,2754,"No."],[2837,2900,"Never."],[2962,3087,"He chose me."],[3187,3383,"How could I not see that?"],[3687,3762,"Eric."],[3800,3912,"Eric!"],[4012,4100,"Eric!"],[4150,4237,"Help!"],[4312,4475,"So many dreams..."],[4487,4737,"We were unable to save the baby."],[4800,4887,"And it's unlikely"],[4887,5037,"you'll be able to conceive again."],[5037,5125,"You didn't even care"],[5125,5237,"when we lost the baby."],[5412,5562,"Five years of marriage, Eric."],[5700,5812,"Five years."],[5937,6075,"And not once did you ever"],[6075,6175,"look me in the eyes."],[6304,6450,"I won't bother you anymore."],[6554,6662,"You're free now."],[6741,6866,"If you knew I wasn't"],[6866,7008,"in this world anymore,"],[7125,7312,"would you feel even a little regret?"],[7525,7595,"Grace?"]],"9":[[529,591,"You're home."],[679,766,"I missed you."],[1058,1129,"Amy."],[1229,1366,"How can I help you, Mr. Watson?"],[1366,1441,"Where's Grace?"],[1445,1558,"Mrs. Watson left the house"],[1558,1641,"a few days ago."],[1679,1779,"I'm not sure where she went."],[3154,3304,"Neither of us are photogenic."],[3304,3441,"That is an awful picture."],[3879,4016,"She took down the wedding photo"],[4016,4116,"to spite me."],[4304,4358,"You're desperate"],[4358,4504,"for me to reach out to you."],[4620,4720,"Not a chance."],[5054,5150,"Thought l would sleep well"],[5150,5300,"without Grace by my side."],[5354,5554,"Damn it, why can't I fall asleep?"],[5879,6004,"This will help you breathe easier."],[6141,6279,"You're going to get a good night's sleep."],[6666,6741,"Amy!"],[6829,6929,"Sir, are you alright?"],[6991,7129,"Where is my aromatherapy"],[7129,7191,"set up?"],[7204,7316,"I can't sleep without it."],[7329,7541,"Sir, Mrs. Watson personally prepared"],[7541,7654,"your aromatherapy equipment"],[7654,7716,"every night."],[7716,7841,"When I went to look for it earlier,"],[7841,7979,"I noticed all the essential oils"],[7979,8041,"were gone."],[8241,8304,"So you're going to"],[8304,8416,"deprive me of my sleep"],[8416,8529,"to get me to see you."],[8641,8766,"You thought ahead, Grace."]],"10":[[1133,1270,"Okay, this is disgusting."],[1320,1458,"What's wrong with this coffee?"],[1495,1587,"Mrs. Watson didn't bring"],[1587,1670,"any coffee today"],[1670,1745,"and no one knows"],[1745,1858,"where she used to get it from."],[1920,1945,"What?"],[2070,2170,"Are you saying Grace is the one"],[2170,2308,"that usually brings my coffee?"],[2670,2733,"Sam!"],[2983,3070,"Mrs. Watson,"],[3108,3220,"your husband already said-"],[3220,3283,"I know,"],[3333,3470,"he doesn't want anything from me."],[3483,3595,"Can you please help me?"],[3645,3708,"Can you?"],[3808,3845,"This is"],[3845,4045,"Jamaican Blue Mountain coffee."],[4120,4308,"And it took me forever to find,"],[4308,4420,"but I know he's gonna love it."],[4445,4533,"Can you please just,"],[4533,4600,"I don't know, just say"],[4600,4725,"it's from, it's from you,"],[4725,4795,"not me,"],[4795,4908,"because I just don't want"],[4908,4995,"his disdain for me to"],[5083,5245,"sour the taste for the coffee."],[5345,5408,"Okay."],[5408,5558,"Your wife sure loves you."],[5604,5704,"It was Grace?"],[5808,5995,"You know nothing about my wife."],[6445,6508,"Get out."],[6983,7133,"I can't even escape you at work."],[7170,7300,"Grace, control freak"],[7300,7383,"looking to dominate"],[7383,7520,"every aspect of my life"],[7520,7658,"down to the last detail."],[8170,8345,"Eric, no one can find Grace."],[8345,8508,"She's, she's gone."],[8570,8695,"Wait, Grace is missing?"]],"11":[[12,100,"She's gone."],[116,262,"Eh, call me when she's dead."],[387,533,"And now you've made yourself"],[533,625,"a perfect victim"],[625,787,"and dragged my mother into it."],[900,1012,"Did you guys hear the news"],[1012,1104,"from a couple days ago"],[1104,1212,"about that woman's body"],[1212,1350,"that washed up on the shore?"],[1350,1537,"Apparently her face was so decayed"],[1537,1687,"they couldn't even ID the corpse."],[1687,1787,"That's awful."],[1837,2075,"Wait, have you guys noticed"],[2075,2200,"how Mr. Watson's wife"],[2200,2287,"hasn't been in the office"],[2287,2412,"the whole week?"],[2462,2616,"I mean, she's never been"],[2616,2812,"out of the office this long before."],[2900,3225,"You think the corpse could be..."],[3362,3450,"Could be what?"],[3462,3550,"Mr. Watson!"],[3625,3750,"You're not all stupid enough"],[3750,3862,"to believe in fake death"],[3862,4000,"Grace orchestrated for herself,"],[4000,4050,"are you?"],[4100,4225,"Tell me, how much did she pay you,"],[4225,4337,"all of you, for this stuff?"],[4337,4362,"Huh?"],[4375,4425,"What?"],[4475,4662,"Mrs. Watson didn't pay us for anything."],[4662,4712,"My husband,"],[4712,4862,"he's a search and rescue officer."],[4862,5000,"I just heard the news from him."],[5000,5087,"He said his team"],[5087,5250,"found an unidentified body on the beach"],[5250,5312,"a couple days ago."],[5312,5375,"Stop."],[5400,5475,"That's enough."],[5550,5687,"I don't need to listen to this."],[5762,5837,"You're all fired."],[5887,5987,"Effective immediately."],[6800,6862,"Eric!"],[6887,7075,"Oh, we can finally be together."],[7100,7287,"Oh, I can't wait for our lives to start."],[7287,7512,"Amanda, I'm married."],[7512,7662,"I thought you got divorced."],[7687,7787,"Like, a week ago?"],[7825,7862,"What?"],[7875,7925,"Divorced?"],[7925,8037,"No, who, who told you that?"],[8100,8387,"Grace sent an update to the group chat"],[8387,8525,"like ten days ago."],[8550,8587,"See?"],[8662,8800,"She said you got divorced."],[8812,8925,"Her words, not mine."],[8975,9087,"There's no way"],[9087,9237,"that she would actually divorce me."],[9275,9350,"Eric."],[9375,9462,"Who cares?"],[9512,9637,"This is finally our chance"],[9637,9725,"to be together."],[9812,9925,"It's time for you to leave her."],[9925,10087,"You know that as well as I do."],[10175,10200,"What?"],[10200,10400,"You, you, you don't miss her, do you?"],[10400,10462,"Miss what?"],[10587,10687,"A living hell?"],[10737,10925,"Grace, you always hated"],[10925,11037,"Amanda and me together."],[11050,11125,"Since you want to"],[11125,11250,"put on a show for attention,"],[11250,11325,"little victim,"],[11350,11425,"let's see how long"],[11425,11550,"you can keep up the act."],[12512,12687,"Grace, I'm the winner this time."],[12712,12800,"I'm not gonna let you"],[12800,12962,"steal Eric from me again."]],"12":[[8,104,"You know I really heard"],[104,245,"it's hard to get a reservation here."],[370,470,"Earth to Eric."],[570,620,"Eric!"],[620,670,"Huh?"],[720,833,"This is like the third time"],[833,945,"you've dozed off today."],[970,1083,"What is with you?"],[1158,1233,"It's nothing."],[1295,1495,"Work's just been busy recently."],[1608,1758,"I just got my nails done."],[1820,1908,"And I don't really want to"],[1908,2133,"get mussels in my nails."],[2133,2258,"They're nasty."],[2308,2408,"No, they aren't."],[2433,2558,"They're a delicacy."],[2845,2920,"Your mom told me"],[2920,3045,"you love mussels,"],[3045,3183,"but you hate peeling them."],[3295,3370,"I don't mind."],[3408,3570,"I'm happy to peel them for you"],[3570,3683,"if you want to eat them."],[3812,3970,"They're too delicious to miss out on."],[4383,4445,"Eric?"],[4958,5045,"What are you waiting for?"],[5045,5145,"Aren't you gonna peel them?"],[5433,5479,"Ow."],[5645,5733,"What happened?"],[5937,6037,"Uh, give me a second."],[6333,6458,"You better heal quickly."],[6708,6875,"Because I don't know if you know this,"],[6875,7145,"but you belong to the greatest,"],[7170,7420,"richest, man in America."],[7495,7645,"Even though he's surly,"],[7758,7908,"sometimes he has a gentle touch."],[7983,8183,"And he needs all of his digits working."],[8245,8370,"Do you want me to kiss it better?"],[8383,8433,"No."],[8545,8733,"Stop talking to me like I'm a child."],[8929,9120,"Eric, do you want me to leave you alone"],[9120,9220,"with your thoughts?"],[9258,9416,"It doesn't seem like you're mentally"],[9416,9533,"where you're supposed to be,"],[9558,9645,"which is here"],[9720,9808,"with me."],[9862,9995,"Well, well, well,"],[10145,10308,"if it isn't Ms. Amanda Blackburn."]],"13":[[25,150,"You must have a pair of balls"],[150,287,"to show your face here"],[287,450,"after causing someone"],[450,550,"to lose their kid."],[550,662,"You're just gonna turn around"],[662,837,"and try to steal her husband too."],[887,1000,"You are shameless."],[1029,1162,"Eric, excuse me."],[1175,1250,"You're not going to"],[1250,1362,"let him speak to me like this-"],[1362,1512,"Are you gonna say that I'm wrong?"],[1512,1625,"Lucas, knock it off."],[1675,1737,"It was an accident."],[1737,1850,"Amanda didn't mean to."],[1950,2075,"Don't disrespect her like that."],[2100,2150,"Wow."],[2237,2375,"You're gonna take the side of this,"],[2437,2562,"this fucking bitch,"],[2600,2812,"who terrorized your wife?"],[2850,3000,"How can you even call yourself a man?"],[3000,3100,"Lucas, don't forget."],[3125,3187,"Grace is the one"],[3187,3325,"who forced me to marry her."],[3375,3487,"She brought this on herself."],[3487,3600,"She's the one to blame."],[3625,3675,"No."],[3787,3837,"No."],[3900,3950,"You're the one"],[3950,4062,"who seems to be forgetting, buddy."],[4150,4275,"You begged Grace"],[4275,4487,"to marry you to save Amanda."],[4487,4650,"But after Amanda recovered,"],[4650,4912,"she threatened to jump off a cliff."],[4912,5050,"You nearly lost your sight"],[5050,5162,"trying to save her."],[5162,5300,"You were almost paralyzed."],[5350,5412,"You remember this?"],[5437,5537,"Who was there to tend to you?"],[5537,5787,"That is none of your business."],[5900,6112,"I wasn't in the right headspace."],[6112,6287,"I was going through a lot at the time."],[6512,6662,"Shut your fucking mouth."],[6775,6825,"Listen to me."],[6825,6987,"Just listen to me, okay?"],[6987,7087,"When the doctors told you"],[7087,7237,"that you were going to be blind"],[7262,7350,"in both of your eyes,"],[7350,7462,"and that you might be in a wheelchair"],[7462,7575,"for the rest of your life,"],[7575,7675,"where was Amanda?"],[7762,7862,"She was gone."],[7887,8100,"And the person who stayed by your side"],[8100,8287,"day and night was your wife!"],[8337,8412,"Grace!"],[8450,8525,"What did you say?"]],"14":[[37,100,"What did you say?"],[1783,1870,"Come on!"],[2591,2675,"Eric."],[2745,2845,"Eric, stop."],[2870,2970,"You're, you're okay."],[4579,4629,"Eric."],[4745,4870,"Shh, shh, shh."],[4904,4954,"It's okay."],[5070,5195,"Eric, you're the strongest."],[5220,5370,"You're the strongest man I've ever known."],[5370,5483,"You're going to get through this."],[5483,5645,"The doctors have no idea"],[5645,5708,"what they're talking about."],[5708,5858,"You're going to see again, okay?"],[5908,6183,"Until then, I'm going to be your eyes."],[6633,6695,"No."],[6745,6833,"No, that's not right."],[6833,6970,"The person who was by my side"],[6970,7045,"was Amanda."],[7145,7270,"Stop telling me it was Grace."],[7270,7345,"It was Amanda."],[7358,7458,"You're a fucking idiot."],[7520,7708,"Grace let you think that"],[7758,7870,"she was Amanda"],[7870,8020,"because it gave you a reason"],[8020,8095,"to get better."],[8095,8145,"She's the one"],[8145,8270,"who wanted us to play along."],[8345,8533,"As soon as Eric hears my voice,"],[8608,8708,"he freaks out."],[8708,8858,"He refuses any treatment."],[8908,9108,"But the other day,"],[9108,9220,"he thought I was Amanda."],[9320,9420,"And he started cooperating"],[9420,9558,"with the doctors fully."],[9583,9708,"And I really want him"],[9708,9845,"to get the best treatment possible."],[9845,10020,"So could you please, could you help me?"],[10045,10195,"Could you just pretend"],[10195,10270,"that I'm Amanda?"],[10408,10487,"Just let him believe"],[10487,10595,"whatever he needs to."],[10708,10770,"Please."],[10883,10983,"just, it's for him."],[10987,11045,"I,"],[11083,11208,"I want him to get better."],[11358,11508,"I need him to get better."],[11508,11745,"Grace, you deserve better than this."],[11795,12020,"My brother treats you like trash."],[12033,12158,"Worse than trash."],[12204,12308,"I don't understand"],[12308,12458,"why you're so good to him."],[12533,12770,"God, this really, really makes me"],[12770,12908,"so fucking mad."],[12908,13033,"He's a bastard."],[13095,13233,"He saved my life once."],[13233,13345,"Even if that's true,"],[13345,13445,"you've done more than enough"],[13445,13533,"to repay it."],[13570,13662,"Eric's never going to acknowledge"],[13662,13783,"how fortunate he is."],[13795,13983,"Grace, if you do this,"],[14008,14133,"he's not gonna be grateful."],[14158,14195,"Okay?"],[14195,14358,"He's still the same guy"],[14370,14483,"we've always known."],[14533,14670,"I don't need his gratitude."],[14695,14845,"I just need him to get better."],[14895,15133,"Eric is a, he's a natural born leader."],[15133,15245,"And he needs to get better"],[15245,15370,"and return to leading."],[15420,15495,"He's powerful."],[15495,15608,"He's awe-inspiring."],[15608,15658,"He needs,"],[15833,15945,"he needs to recover."],[16020,16145,"People depend on him."],[17095,17195,"So after I recovered,"],[17195,17320,"why didn't anyone tell me?"],[17358,17458,"Not a single person."]],"15":[[0,125,"Why didn't anyone tell me?"],[325,425,"Thank you for coming."],[550,612,"Amanda?"],[675,762,"Amanda, is that you?"],[1375,1550,"Amanda, you're quiet, sweetheart."],[1550,1662,"Why aren't you saying anything?"],[1712,1875,"Is it, is it because I can't see?"],[1925,2000,"Because I'm paralyzed?"],[2000,2137,"Is it, is it too much for you?"],[2612,2750,"Dude, she loves you so much,"],[2750,3012,"but every time she tries to speak,"],[3012,3162,"she starts to cry."],[3754,3850,"She's so worried about you,"],[3850,3950,"but she really needs to"],[3950,4062,"conserve her energy."],[4075,4300,"She hasn't spoken in days."],[4587,4662,"That's right."],[4712,4825,"Amanda's"],[4887,5000,"been taking care of you"],[5000,5112,"the last few days."],[5400,5637,"You should know that you have a real"],[5712,5787,"connection."],[6112,6187,"Is she still here?"],[6287,6325,"Amanda?"],[6362,6412,"Yes,"],[6462,6600,"she's just feeding you some soup."],[6600,6675,"Relax."],[6900,6975,"It was Grace."],[7037,7125,"She wanted your focus"],[7125,7225,"to be on getting better."],[7250,7337,"And nothing else."],[7337,7437,"She didn't want you to feel like"],[7437,7537,"you owed her anything."],[7537,7662,"So we all just agreed"],[7662,7762,"to keep our mouths shut."],[7975,8150,"So Grace hasn't said a word to me"],[8150,8225,"in all these years,"],[8225,8362,"and you're bringing this up now."],[8400,8537,"In this exact moment."],[8562,8650,"She's probably just waiting for"],[8650,8708,"the right time to tell me,"],[8708,8787,"wasn't she?"],[8825,8937,"For when it had the biggest impact,"],[8937,9050,"hoping it would win me over."],[9050,9112,"Eric,"],[9150,9312,"are you insane?"],[9362,9512,"All of your friends and family,"],[9512,9687,"we have all been trying to tell you"],[9687,9825,"that Grace was the one"],[9825,10037,"who's been by your side this entire time."],[10100,10287,"So what are you still doing with Amanda?"],[10304,10450,"Grace is a manipulator."],[10541,10612,"She's even got you"],[10612,10737,"and everyone else lying for her."],[10737,10862,"That's what you just told me."],[11112,11187,"And you."],[11562,11687,"You told me that you were the one"],[11687,11825,"by my side each day."],[11925,12062,"So I want the truth."],[12175,12275,"Are you the one"],[12275,12412,"who nursed me back to health?"]],"16":[[8,108,"Are you the one"],[108,262,"who nursed me back to health?"],[358,483,"Grace stole you from me."],[508,633,"What was I supposed to do?"],[745,845,"You hear that, Eric?"],[945,1033,"Amanda lied."],[1070,1220,"She's still a liar."],[1220,1333,"And to think that"],[1333,1558,"you gave up the only woman"],[1558,1758,"who loves you more than anything"],[1845,1908,"for her."],[2333,2408,"Enjoy your meal."],[2783,2920,"Why did you lie to me?"],[3020,3108,"There's nothing I hate"],[3108,3245,"more than being lied to."],[3325,3387,"Eric."],[3458,3508,"No, I-"],[3508,3583,"Good evening, sir."],[3583,3670,"Are you Eric Watson?"],[3720,3770,"I am."],[3833,3995,"Is your wife's name Grace Watson?"],[4033,4195,"She is my legal wife, yes."],[4220,4283,"We've been trying to"],[4283,4370,"get in contact with you"],[4370,4458,"for some time now."],[4458,4583,"So, officers, what trouble did she"],[4583,4695,"get herself into this time?"],[4695,4733,"And no,"],[4733,4883,"I'm not coming to bail her out."],[4920,5083,"Sorry to inform you, but your wife,"],[5170,5283,"she drowned herself in the ocean"],[5283,5358,"ten days ago."],[5608,5695,"We need you to come with us"],[5695,5845,"to the station to identify the body."]],"17":[[70,137,"Body?"],[400,529,"What, Grace is dead?"],[629,704,"No, I, I thought"],[704,829,"that was a total fabrication."],[866,929,"Are you sure?"],[929,1079,"I'm deeply sorry for your loss, sir."],[2054,2204,"It's not bad for a knockoff."],[2316,2491,"The badge is pretty convincing."],[2491,2541,"Where'd you buy it?"],[2616,2741,"Grace really went through the work"],[2741,2879,"of putting on a convincing show."],[2929,2983,"Don't you boys know"],[2983,3112,"that impersonating an officer"],[3112,3191,"is a crime?"],[3191,3350,"Mr. Watson, while I sympathize with"],[3350,3454,"what you're going through,"],[3504,3645,"I highly suggest you watch your words."],[3645,3779,"Look, my wife is not dead."],[3779,3929,"That is completely out of the question."],[3929,4079,"So the only logical conclusion is that"],[4079,4166,"she hired the two of you"],[4166,4316,"to act in her silly little game"],[4316,4429,"to try to win me back."],[4479,4654,"So you want me to find you first, Grace?"],[4766,4879,"Well, I'm not falling for it."],[4916,4954,"By the way,"],[4954,5066,"how much did she pay you two?"],[5079,5129,"Ten?"],[5166,5241,"One hundred grand?"],[5241,5479,"Mr. Watson, maintain some decency."],[5479,5604,"Should be plenty on here"],[5604,5741,"for you two to have a good time,"],[5741,5891,"party, buy a car or two."],[5904,6016,"You tell Grace that"],[6016,6154,"if she doesn't come back home tonight,"],[6154,6279,"she better never come back at all."],[6641,6716,"Eric?"],[6991,7129,"I just saw Mr. Watson"],[7129,7233,"sitting across the table"],[7233,7295,"with a woman"],[7295,7554,"who is definitely not his wife."],[7641,7854,"How do you know his wife, Mr. Lee?"],[7866,7966,"I know her very well."],[8029,8141,"So five years ago,"],[8204,8404,"Watson stock tanks, right?"],[8404,8516,"They have no cash flow."],[8516,8604,"So his wife,"],[8629,8791,"she comes running to me for help."],[8854,8916,"Grace."],[8966,9254,"Now, she is pretty."]],"18":[[12,87,"Everyone is sure that"],[87,187,"the Watson Corporation"],[187,300,"is just finished."],[337,462,"So she comes running to me."],[487,587,"Me being me, I want to see"],[587,737,"how far she's gonna take it"],[750,862,"to save her husband."],[862,1012,"So I say, you know, you want a hand up?"],[1037,1150,"Come drink with me."],[1150,1425,"She proceeds to drink so much"],[1437,1712,"that she throws up blood."],[1887,1975,"No, no, no, no."],[1975,2112,"It's not even the best part."],[2212,2320,"You know what she does afterward?"],[2600,2750,"She keeps fucking drinking."],[2787,2975,"Now, that is commitment"],[2975,3075,"to your man."],[3075,3237,"I mean, she is a keeper."],[3237,3475,"Watson is an idiot for how he treats her."],[3475,3800,"Just tight body, fiery temper."],[3862,4087,"I, uh, even slipped a little something"],[4087,4175,"into her drink."],[4200,4262,"This broad."],[4333,4495,"She's so stubborn"],[4575,4737,"that she still has the willpower"],[4737,4912,"to get up and run out on me."],[4912,5137,"And that part, that was the real shame."],[5200,5300,"Because, man,"],[5300,5400,"the things that I was gonna"],[5400,5470,"do to that woman."]],"19":[[33,91,"Ah!"],[120,200,"He-hey!"],[212,287,"It's Mr. Watson."],[287,337,"I-"],[2375,2512,"Hey, use everything in our arsenal"],[2512,2662,"to bankrupt Lee Corporation"],[2675,2800,"by tomorrow at the latest."],[3041,3175,"Gonna wanna put some ice on that."],[3425,3475,"Eric?"],[3516,3600,"Eric?"],[3825,3912,"Eric!"],[4137,4275,"Oh, my god, you're bleeding."],[4375,4425,"What the hell?"],[4425,4587,"You're acting like a neanderthal."],[4625,4800,"Why are you still defending Grace?"],[4812,4954,"Do you still love her or something?"],[4954,5062,"Grace is my wife."],[5125,5300,"As my wife, she represents the face"],[5300,5412,"of Watson Corporation."],[5412,5537,"If someone is messing with her,"],[5562,5650,"they're messing with me."],[5687,5812,"She's not your wife."],[5887,5975,"Not anymore."],[6012,6150,"She's out of the way now."],[6187,6387,"And as long as I can marry Eric"],[6387,6587,"and use his love to my advantage,"],[6625,6800,"I'll have complete control"],[6800,7025,"over the Watson Corps in no time."],[7025,7100,"Eric,"],[7200,7262,"baby..."],[7362,7575,"let's, let's get married."],[7625,7800,"I want to hold my head high"],[7800,7937,"while I tell the whole world"],[7937,8125,"that I'm your wife."],[8125,8262,"I don't care what Grace told you."],[8262,8450,"Her and I aren't officially divorced."],[8600,8775,"Grace is infatuated with me."],[8825,8987,"How could she want to divorce me?"],[9075,9212,"The number you are trying to dial"],[9212,9337,"is no longer in service."],[9350,9387,"What?"],[9525,9641,"No longer in service?"]],"20":[[337,500,"Sir, what are you looking for?"],[525,662,"Where is all of Grace's stuff?"],[662,800,"Why can't I find any of her things?"],[850,987,"Mr. Watson, I told you."],[987,1062,"Ten days ago,"],[1062,1175,"Mrs. Watson packed up"],[1175,1275,"all of her belongings"],[1300,1462,"except for the donation boxes."],[1487,1587,"And then she left."],[1687,1800,"All of her things?"],[1875,1987,"Every single item?"],[2062,2162,"Wow, Grace."],[2187,2337,"You're being quite thorough this time."],[3237,3362,"Darling, it's time to eat."],[3775,3900,"This will help you breathe easier."],[4050,4187,"You're gonna get a good night's sleep."],[4437,4679,"She loves me so much."],[4679,4862,"Why would she do this to me?"],[6075,6175,"I hope when you see these,"],[6175,6275,"they brighten your day."],[8000,8112,"Grace, do you actually"],[8112,8237,"wanna divorce me?"]],"21":[[983,1108,"Maybe this isn't a joke."],[1358,1495,"Do you really want to leave me?"],[1870,1908,"No."],[2145,2245,"I can't let that happen."],[2345,2450,"I won't allow it."],[3045,3195,"Hazel, I know Grace is with you."],[3270,3395,"Tell her that she left two boxes"],[3395,3475,"to donate behind."],[3475,3520,"And she has"],[3520,3633,"until the end of the day tomorrow"],[3633,3733,"to come get them in person"],[3733,3895,"or I'm gonna send them to the landfill."],[4045,4195,"I can't believe you're my brother,"],[4195,4408,"you fucking piece of shit."],[4408,4620,"You did nothing but push her away."],[4620,4783,"And now she left,"],[4783,4983,"and you're still treating her like this?"],[4983,5070,"Treating her like what?"],[5145,5245,"If I believe all the gossip,"],[5245,5333,"she's dead anyway."],[5408,5483,"Tell her that she better"],[5483,5558,"crawl out of the grave"],[5558,5645,"and come grab her crap"],[5645,5795,"before she heads to the afterlife."],[6145,6325,"Alright, Grace, you win."],[6350,6416,"When you come back,"],[6416,6545,"I'll do whatever you want."]],"22":[[779,841,"Here,"],[866,1004,"I hope you feel better soon."],[2662,2712,"Grace."],[2795,2879,"You wouldn't actually"],[2879,3004,"leave me, would you?"],[3079,3200,"She'll come back."],[3220,3345,"Just give her time."],[4229,4279,"Okay."],[4304,4391,"Okay, calm down."],[4441,4529,"Don't scare her off."],[4529,4604,"You want her to stay."],[4704,4779,"Be nice."],[4829,4891,"Be nice."]],"23":[[891,929,"I can't believe"],[929,1054,"she sent you to get her things."],[1054,1141,"Was she too cowardly"],[1141,1254,"to face me in person?"],[1391,1491,"Oh my God."],[1491,1616,"I came to see you."],[1954,2129,"She's not a coward, Eric."],[2129,2216,"She can't come."],[2216,2304,"Yes, she can."],[2304,2454,"She's choosing not to."],[2516,2666,"She's probably plotting"],[2666,2791,"some new underhanded trick"],[2791,2854,"to trap another man"],[2854,2991,"into a loveless marriage."],[3216,3304,"That's enough!"],[3466,3629,"You're a fucking bastard."],[3691,3845,"She loved you for years"],[3845,4054,"and you can't even let her die in peace?"],[4091,4204,"I hope you burn in hell."],[4204,4316,"God, this again?"],[4391,4479,"It's all for show"],[4479,4604,"to make her out to be a victim."],[4604,4716,"She's not dead."],[4754,4866,"God, what does she have on you"],[4866,4979,"to make you play along?"],[5029,5229,"Grace is dead."],[5304,5566,"Ten days ago, your wife, Grace,"],[5579,5679,"the person who loved you"],[5679,5891,"more than anyone else in this world,"],[5891,6016,"ended her life."]],"24":[[0,100,"The person who loved you"],[100,312,"more than anyone else in this world"],[312,450,"ended her life."],[450,637,"Why is everyone siding with Grace"],[637,812,"and making me out to be the bad guy?"],[837,912,"What, you really think"],[912,1037,"that she just up and died?"],[1137,1225,"Come on, this is obviously"],[1225,1325,"some kind of sick joke."],[1325,1475,"God damn it, Eric!"],[1525,1625,"Do you even realize"],[1625,1737,"how much she loved you?"],[1762,1975,"She was overjoyed when she found out"],[1975,2150,"she was pregnant with your child."],[2187,2275,"But what did you do?"],[2312,2500,"You let Amanda hurt your baby"],[2500,2600,"and didn't even bother"],[2600,2750,"to check if your wife was okay."],[2750,2837,"That's on you."],[2925,3100,"You're the reason she's dead."],[3137,3220,"But she was never"],[3220,3375,"even supposed to get pregnant."],[3400,3550,"She's the one that forced me"],[3550,3625,"to marry her."],[3650,3800,"And then when I was drunk that night,"],[3800,3925,"she took advantage of me. She-"],[3925,4162,"You're the one who wanted her to stay."],[4200,4275,"But as usual,"],[4275,4350,"you don't remember the"],[4350,4475,"important details."],[4550,4633,"Okay, careful."],[4645,4754,"Okay, here"],[4787,4837,"for a second."],[4958,5062,"Okay good, here."],[5337,5487,"For somebody who's such an ice king"],[5487,5600,"when he's sober,"],[5612,5825,"he sure does melt when he drinks."],[5925,6012,"Who would have thought"],[6025,6100,"my brother,"],[6137,6200,"helpless?"],[6312,6462,"Between you and I, actually..."],[6575,6750,"I actually really love when he's like this."],[6812,6937,"It makes me feel needed."],[7137,7200,"Let's go."],[7500,7562,"Don't leave."]],"25":[[125,200,"Don't leave."],[725,825,"Did you hear that?"],[887,987,"Don't leave."],[1025,1162,"Congrats, Grace."],[1237,1437,"You've finally won his affections."],[1600,1725,"I'll let myself out."],[1750,1937,"Leave you two lovebirds alone."],[2737,2875,"I'm not going anywhere."],[3062,3200,"You're beautiful, you know that?"],[3970,4058,"I love you."],[5175,5312,"Do you understand now?"],[5475,5650,"Grace loved you so much,"],[5650,5775,"it killed her."],[5837,6012,"She was my best friend, Eric."],[6050,6237,"She was dead to you a long time ago."],[6237,6412,"And you should be dead to me."],[6533,6675,"Grace didn't lie to me."],[6720,6900,"I was the one who made her stay."],[6925,7158,"How could I forget something like that?"]],"26":[[600,675,"She's not dead."],[812,887,"Not Grace."],[887,975,"It's not possible."],[1025,1100,"She could hardly bear"],[1100,1225,"to leave me for one night."],[1225,1287,"There's no way"],[1287,1450,"that you'd leave me for a lifetime."],[1775,1825,"Mom."],[1875,1925,"Where have you been?"],[1925,1987,"Look, it doesn't matter."],[1987,2162,"Has Grace been here in the past few days?"],[2162,2225,"No."],[2225,2325,"What is going on?"],[2362,2475,"Everyone is saying that"],[2475,2650,"you and Grace are already divorced."],[2700,2800,"In the five years"],[2800,2937,"that Grace was married to you,"],[2937,3125,"she was devoted to our family"],[3125,3237,"and the Watson Corp."],[3250,3375,"What does that pretentious"],[3375,3554,"hussy Amanda have over you?"],[3554,3620,"Look, if, if"],[3620,3762,"If Grace was so devoted,"],[3762,3837,"why didn't she tell you"],[3837,3925,"where she was going?"],[4137,4287,"No one has seen her in the past ten days"],[4287,4475,"and are all of you scheming together?"],[4500,4662,"What are you talking about, Eric?"],[4725,4900,"You, you haven't seen her either?"],[4900,5000,"Go find her!"],[5000,5137,"You are such a disgrace"],[5137,5225,"to our family!"],[5312,5475,"Do not show your face here again"],[5475,5587,"without your wife."],[5850,6037,"She didn't tell my mom or sister"],[6037,6137,"where she was going."],[6187,6325,"Hazel is saying she's dead"],[6325,6425,"and my mom thinks"],[6425,6562,"that we can work things out."],[6650,6812,"Maybe it was for real this time."],[6900,6950,"No."],[6962,7075,"No, that's impossible."],[7100,7212,"It's impossible."],[7912,7987,"Okay!"],[8012,8075,"Okay."],[8075,8162,"Quit banging."],[8162,8262,"I'm coming."],[8312,8362,"Geez."],[8450,8525,"Is Grace here?"]],"27":[[100,175,"Is Grace here?"],[175,350,"Oh, Eric, I-"],[512,562,"No."],[587,700,"No, Grace is not here."],[700,787,"Why would she be here?"],[787,900,"Grace, I know you're in here."],[900,962,"If you're hiding,"],[962,1112,"quit the nonsense and come out."],[1487,1550,"Grace!"],[1775,1962,"Eric, I'm getting sick of this."],[1962,2100,"Grace, I know you're hiding."],[2100,2175,"I'm not going to ask you"],[2175,2275,"to come out again."],[2587,2650,"Eric!"],[2662,2737,"Come out right now."],[2737,2850,"I won't ask again."],[3237,3287,"Grace?"],[3487,3537,"Grace?"],[4500,4825,"Did Grace really live in a place like this?"]],"28":[[1258,1345,"Grace."],[1433,1533,"Is that your mom?"],[2345,2433,"Eric,"],[2570,2695,"you need to stop."],[2708,2808,"She's gone."],[2858,2933,"Accept it,"],[2933,3120,"it's useless to look for her."],[3183,3295,"Is this Grace's room?"],[3695,3770,"Answer me!"],[3870,3958,"It is."],[4033,4183,"But, uh, so what?"],[4208,4283,"When her mother died,"],[4283,4445,"she didn't want to live with us anymore."],[4445,4533,"She grabbed all her things."],[4533,4608,"She brought them up here."],[4608,4708,"We never touched them!"],[4708,4783,"Amanda, you,"],[4895,5245,"you told me that Grace bullied you"],[5245,5370,"and your mother relentlessly"],[5370,5545,"because she blamed the two of you"],[5545,5620,"for her mother's death."],[5620,5745,"You told me that you were the one"],[5745,5908,"forced to live in a closet."],[5908,6070,"So why are all of her things in here?"]],"29":[[58,108,"No."],[120,170,"No."],[183,258,"It's true."],[258,508,"Grace is the real bully."],[533,608,"When she left,"],[608,758,"my dad wanted a better life"],[758,895,"for all of us."],[895,1020,"So when she was here"],[1108,1220,"in this pitiful room,"],[1220,1383,"living with you and without her mother,"],[1383,1445,"she's the one"],[1445,1558,"that bullied the two of you?"],[1883,1970,"Amanda, I'm going to ask you"],[1970,2058,"one more time."],[2070,2170,"When you told me"],[2208,2370,"that Grace abused her power"],[2408,2533,"and made things difficult for you"],[2533,2583,"and your mother,"],[2583,2695,"were you telling me the truth?"],[2920,3108,"I can't believe you right now."],[3108,3220,"You were the one lying to me"],[3220,3308,"this whole time?"],[3308,3358,"No."],[3383,3420,"No."],[3420,3495,"It wasn't a lie."],[3495,3608,"It was all true!"],[3645,3883,"It's been Grace's life mission"],[3883,4008,"to make mine miserable."],[4108,4270,"And her grand finale,"],[4295,4658,"her final play was to steal away you."],[4658,4858,"The one person that I loved."],[4895,4983,"You lied to me"],[4983,5145,"so that I'd feel bad for you."],[5245,5370,"Planting little seeds of doubt"],[5370,5433,"along the way."],[5458,5583,"No."],[5695,5745,"No."],[5770,5833,"Eric, I-"]],"30":[[395,508,"Young Master Eric."],[695,783,"Is that really you?"],[958,1058,"Sorry, you are?"],[1058,1220,"Oh, well, I suppose it has been"],[1220,1320,"a while now, hasn't it?"],[1358,1470,"It's me, Charles."],[1483,1658,"I'm the Blackburn household butler."],[1658,1808,"I've been the butler here for years."],[1808,1958,"And I do remember you being here"],[1958,2045,"when you were little."],[2120,2333,"I have heard that you and Grace"],[2333,2445,"are married now."],[2558,2633,"I should have guessed."],[2695,2858,"That always was her childhood dream."],[2945,3083,"She was in love with you"],[3083,3183,"since you were children."],[3245,3308,"What do you mean?"],[3408,3558,"I barely knew her as a child."],[3558,3658,"Barely knew her?"],[3670,3720,"Yeah."],[3745,3858,"Oh, no."],[3883,4020,"You two were as thick as thieves."],[4058,4133,"You were constantly"],[4133,4258,"into one thing or another."],[4433,4558,"You really don't remember."],[4658,4733,"Well, you would always come"],[4733,4845,"bearing gifts for her."],[4895,4983,"You were her protector"],[4983,5108,"against that Amanda."],[5233,5295,"Wait."],[5445,5545,"Amanda was the one"],[5545,5658,"I doted on back then."],[5770,5920,"It, it wasn't Grace."]],"31":[[66,166,"Amanda was the one"],[166,291,"I doted on back then."],[416,541,"It, it, it wasn't Grace."],[604,716,"Good heavens."],[741,791,"No!"],[854,979,"I might be getting old,"],[1004,1179,"but my memory is still sharp."],[1229,1379,"The little girl that you held hands with"],[1379,1429,"as a child,"],[1429,1591,"that was Ms. Grace."],[1654,1866,"Amanda was her tormentor."],[2304,2429,"Mommy, they said"],[2429,2591,"you had to go to heaven,"],[2591,2741,"but you forgot me here."],[2791,2891,"Now I'm with Amanda"],[2891,3016,"and her mommy."],[3016,3129,"They hate me."],[3604,3729,"Hey, give it back."],[3766,3879,"Say please."],[3879,4041,"Please, give it back!"],[4604,4766,"Daddy doesn't even want you anymore."],[4779,4829,"And Mommy says"],[4829,4966,"you're nothing but an orphan!"]],"32":[[0,50,"Mommy says"],[50,175,"you're nothing but an orphan."],[1850,1975,"I bet she'd rather be an orphan"],[1975,2087,"than be like you."],[2087,2212,"You're nothing but a bully."],[2375,2487,"Mind your business, Eric."],[2487,2587,"No one asked you."],[2937,3000,"Are you okay?"],[3500,3800,"Back then, Ms. Grace's standing"],[3800,3937,"in the Blackburn household,"],[3937,4075,"it was very low."],[4150,4237,"Everyone attacked her"],[4237,4337,"except for you, Eric."],[4387,4637,"Only you stood up and helped her."],[4650,4825,"She always adored you for that."],[4825,5025,"You were a hero in her eyes."],[5287,5537,"That was Grace?"]],"33":[[341,404,"Don't worry."],[404,529,"I'll always protect you."],[541,704,"I promise I won't let anything"],[704,779,"happen to you."],[854,1041,"My mom said that she's dead now."],[1066,1266,"There's no one to protect me anymore."],[1366,1491,"I promise I'll protect you."],[1516,1579,"Always."],[1579,1741,"I'll look after you for your mom."],[1779,1966,"And when we grow up, I'll marry you."],[2141,2291,"You'll do that for me?"],[2529,2666,"Keep this as my promise."],[2791,2891,"Don't take it off."],[3241,3391,"When we grow up, we'll get married."],[3404,3491,"And I'll take care of you"],[3491,3641,"for the rest of our lives."],[4241,4341,"Ms. Amanda."]],"34":[[141,241,"Ms. Amanda."],[441,554,"What are you doing here?"],[741,841,"Charles!"],[854,1041,"It's not your business what I'm doing here."],[1341,1479,"But if you need to know,"],[1541,1641,"I'm not letting Grace"],[1641,1766,"take Eric that easily."],[1854,1979,"Not without a fight."],[2991,3141,"I thought it was sweet back then."],[3216,3316,"How could I have known"],[3316,3429,"that the two of you"],[3429,3529,"would eventually end up"],[3529,3641,"marrying each other?"],[3691,3829,"It's a beautiful thing to see, you know."],[3866,3954,"Grace is the one"],[3954,4116,"that I promised to marry back then?"],[4279,4441,"No, my mind keeps telling me"],[4441,4629,"that it was Amanda, not Grace,"],[4629,4704,"all those years ago."],[4704,5066,"I can remember distinctly, I..."]],"35":[[20,183,"No, my mind keeps telling me"],[183,370,"that it was Amanda, not Grace,"],[370,433,"all those years ago."],[433,529,"I, I, I can..."],[641,820,"I can remember distinctly, I-"],[883,945,"No, sir."],[970,1108,"Your memory is failing you."],[1170,1320,"When you went abroad to study,"],[1320,1408,"I imagine it felt like"],[1408,1483,"you were having to start your life"],[1483,1570,"all over again."],[1620,1695,"It's probably the reason"],[1695,1808,"why you rarely ever came home."],[2370,2458,"Eric!"],[2520,2633,"Oh, Eric!"],[3183,3458,"You finally found your way back to me,"],[3545,3633,"Look, see..."],[3808,3945,"Keep this as my promise."],[3945,4045,"Don't take it off."],[4183,4333,"I never took it off"],[4383,4545,"all those years."],[4620,4820,"Yeah, I'm back."],[6033,6108,"Ah, but-"],[6283,6458,"Time has the way of playing tricks"],[6458,6583,"on the best of us, you know."],[6658,6958,"Anyway, it is wonderful"],[6958,7095,"to see you again, Eric."]],"36":[[1133,1245,"Hey, give that back!"],[1245,1395,"Stop taking Amanda's stuff."],[1395,1495,"I gave this to her."],[1508,1695,"I've had that bow since I was a child."],[1695,1820,"Okay, that's impossible."],[1845,1970,"I picked this bow out myself"],[1970,2058,"and I remember picking it out"],[2058,2133,"just for her."],[2133,2283,"She just doesn't care."],[2345,2483,"Always stealing things,"],[2483,2695,"always taking what isn't hers."],[2733,2933,"This doesn't belong to you."],[3220,3433,"Stop taking Amanda's stuff."],[3508,3608,"If you make her life hell,"],[3608,3695,"I'll make sure you have nothing"],[3695,3770,"but regret."],[4070,4133,"Amanda."],[4295,4408,"How have you deceived me"],[4408,4508,"for so long?"],[4720,4820,"Grace is the girl"],[4820,4933,"who stole my heart."],[5120,5333,"The only woman I ever truly loved."],[5958,6141,"What the hell have l done?"],[6183,6400,"How could I be such a monster?"],[6450,6662,"How could I be so blind?"]],"37":[[187,287,"Who the fuck is banging"],[287,425,"on my door so early?"],[537,612,"Okay."],[762,812,"Eric."],[1087,1187,"Look, I need your help."],[1250,1337,"You got connections,"],[1337,1425,"I need to find someone."],[1487,1562,"Who do you need to find?"],[1562,1662,"It's 6am."],[1662,1762,"Look, I need to find Grace."],[1800,1854,"Your wife."],[1866,1925,"Where is she?"],[1925,2000,"Well, if I knew that,"],[2000,2075,"I wouldn't be fucking"],[2075,2175,"barging through your door"],[2175,2250,"begging for help."],[2250,2312,"Okay, chill."],[2312,2462,"Look, I overheard a rumor"],[2462,2562,"from some idiots at work"],[2562,2725,"about how Grace is dead"],[2725,2837,"and I didn't pay much mind to it."],[2837,2950,"But I met with Hazel yesterday"],[2950,3012,"and she said the same thing."],[3012,3137,"I mean, she's gotta be lying, right?"],[3137,3183,"There's no-"],[3212,3283,"Sit down,"],[3354,3425,"chill out."],[3625,3675,"What's going on?"],[3675,4000,"Look, I've learned so many things"],[4000,4150,"about my wife over the past few days"],[4150,4262,"except for where she is."],[4350,4525,"I just, I gotta find her."],[4587,4812,"Okay, so, Hazel told you"],[4812,5025,"that Grace is dead"],[5087,5200,"and that she killed herself."],[5250,5312,"Do you believe that?"],[5312,5462,"I don't know what to believe."],[5550,5637,"I always thought that..."],[5875,5962,"Look, I was wrong."],[6025,6112,"I fucked up, okay?"],[6112,6275,"You gotta, you gotta help me find her."],[6350,6412,"We'll find her."],[6537,6637,"It's gonna be okay, man."],[6687,6837,"Grace is not dead."]],"38":[[20,120,"That's absurd."],[145,258,"There's no way she's dead."],[283,358,"We'll find her."],[395,483,"Make a couple calls."],[583,620,"Okay?"],[645,683,"Okay."],[683,733,"Alright."],[833,895,"Let me get my phone."],[2495,2537,"Fuck."],[3087,3125,"Yeah."],[3408,3470,"You found her."]],"39":[[116,179,"You found her."],[779,854,"Oh, where is she?"],[1216,1354,"Lucas, tell me where she is."],[2491,2566,"Your sister,"],[2816,3041,"she wasn't lying, Eric."],[3204,3279,"She's,"],[3329,3416,"she's gone."],[3491,3554,"Gone?"],[3816,3866,"Dead."],[4104,4204,"She, uh..."],[4204,4379,"she walked into the ocean"],[4379,4504,"and she never came out."]],"40":[[50,183,"Eric, I know this has"],[183,275,"gotta be hard to-"],[275,400,"There's no way that she's done that."],[475,587,"She would never do that."],[587,712,"You said so yourself."],[1037,1125,"You're lying."],[1300,1425,"You're fucking betraying me"],[1425,1525,"just like she did."],[1525,1612,"All of you are."],[1700,1825,"There's no way that she's dead."],[1825,1937,"You're covering for her."],[2062,2125,"Eric."],[2237,2287,"What?"],[2300,2362,"What the fuck"],[2362,2475,"are you talking about, man?"],[2487,2625,"You always looked down on me"],[2625,2737,"for the way that I treated her."],[2737,2900,"You could never put yourself in my shoes."],[2987,3087,"But you're my best friend."],[3087,3150,"I mean, how could you be"],[3150,3337,"plotting against me with her?"],[3425,3650,"Are you fucking insane?"],[3687,3825,"We grew up together."],[3879,4012,"What reason would I ever have"],[4012,4150,"to play some kind of sick game"],[4150,4200,"like that?"],[4200,4312,"There is no way she's dead."],[4312,4512,"I don't care what you or anyone else says."],[4575,4737,"Grace is the most determined woman"],[4737,4837,"I've ever met in my life."],[4837,4975,"She's the strongest."],[5050,5112,"There's no way that"],[5112,5250,"she would give up on herself"],[5275,5325,"or me."],[5437,5500,"Or us."],[5700,5850,"I mean, her fascination with me,"],[5850,5975,"it borders on obsession."],[6050,6125,"Five years ago,"],[6125,6262,"she used every trick up her sleeve"],[6262,6337,"to chain me down"],[6337,6462,"and she refused to let go."],[6587,6675,"There's no way she's dead."],[6675,6800,"I refuse to believe it."]],"41":[[216,354,"I don't want a divorce."],[504,579,"I miss her."],[766,916,"You got, you gotta, you gotta tell her."],[916,1079,"You gotta, you gotta beg her to listen."],[1079,1154,"Please, I don't,"],[1191,1279,"I can't lose her."],[1279,1391,"I wanna work it out."],[1391,1441,"Eric."],[1541,1616,"Dude, you..."],[1716,1904,"you gotta get a grip on reality."],[1954,2004,"Grace,"],[2104,2166,"Grace is dead."],[2216,2329,"You're, you're in denial."],[2329,2379,"You're in pain."],[2379,2429,"And that's,"],[2454,2541,"That's okay, man."],[2579,2666,"That is okay."],[2704,2816,"You're not gonna get to"],[2816,2916,"work it out with her."],[3016,3104,"She's gone."],[3141,3241,"I am sorry, I-"],[3241,3341,"It's lies!"],[3416,3529,"You're all lying!"],[3591,3641,"No."],[3691,3829,"You're lying to yourself."],[3841,3954,"You didn't cherish Grace"],[3954,4016,"when she was alive"],[4016,4116,"and now that she's dead,"],[4116,4204,"you're acting shocked"],[4204,4304,"and wounded?"],[4429,4516,"How dare you?"],[4554,4691,"And you don't even believe me."],[4779,4841,"Okay, fine."],[4879,4954,"Let's go get a copy"],[4954,5066,"of her death certificate then."],[5066,5266,"Don't you fucking touch me!"],[5354,5479,"You're the one that's crazy."],[5554,5641,"I'm gonna find her myself."],[5641,5729,"Thanks for nothing."],[6204,6291,"Officers!"],[6541,6704,"Wait, this isn't a joke anymore."],[6729,6816,"My wife is missing"],[6816,6941,"and you need to help me find her."],[7004,7229,"You're Mrs. Watson's husband?"],[7229,7279,"Yeah."],[7391,7529,"You're here to identify the body?"],[7604,7679,"Come on, this again?"]],"42":[[404,591,"We used DNA testing to verify"],[591,729,"the identity of the deceased."],[745,891,"Now all we need is confirmation"],[891,991,"from her next of kin."],[1991,2041,"Sir."],[2129,2279,"Sir, I know this is hard,"],[2279,2454,"but please step forward"],[2454,2529,"and take a look."],[2616,2754,"Tell us whether this is your wife."],[2816,3041,"Her body has been in the water"],[3041,3116,"for so long"],[3116,3408,"that her face is no longer identifiable."],[3408,3454,"But..."],[3529,3654,"A three inch long scar"],[3654,3829,"was found on her left wrist."],[4016,4066,"Scared?"]],"43":[[95,358,"The deceased also has two moles"],[445,545,"on her right shoulder."],[683,808,"About a centimeter apart."],[1833,1970,"Look, this isn't Grace."],[2070,2158,"My wife isn't dead."],[2158,2245,"She can't be."],[2320,2433,"Look, she just bribed you"],[2433,2633,"into staging this crazy elaborate lie."],[2695,2908,"Look, I know this is a lot"],[2908,3033,"to wrap your head around,"],[3058,3270,"but I can assure you DNA testing,"],[3320,3383,"it doesn't lie."],[3508,3633,"This is the death certificate."],[3845,3945,"The body in front of you"],[3970,4095,"belongs to your wife."],[4245,4333,"And you should also know"],[4333,4508,"that Mrs. Watson was suffering"],[4508,4620,"from late stage cancer."],[4758,4945,"And we also found clear signs"],[4945,5095,"of a previous miscarriage."]],"44":[[370,470,"No, I can't lose her."],[620,670,"No!"],[945,1033,"You fucking liar."],[1695,1758,"Where's Grace?"],[1833,1933,"Tell her to come out right now."],[2070,2233,"This is Mrs. Watson's company."],[2308,2433,"I can't believe you dare show your face"],[2433,2583,"after neglecting her for years."],[2833,2920,"None of us could ever figure out"],[2920,3020,"what she saw in you."],[3095,3270,"You're nothing but an ungrateful monster"],[3270,3458,"who chose her stepsister over her."],[3658,3720,"She's dead now."],[3870,3983,"Did you come to steal everything"],[3983,4070,"she left behind?"],[4133,4220,"I'm calling security."],[4245,4370,"My wife is not dead,"],[4370,4533,"so stop speaking nonsense."],[4570,4733,"Hey, hey, let go of her."],[4795,4958,"I'm the one who had the paperwork done"],[4958,5108,"for your divorce agreement."],[5145,5245,"I know it clearly states"],[5245,5395,"that you're not supposed to be here."],[5445,5570,"If you're going to cause a scene,"],[5583,5683,"I'll have to ask security"],[5683,5783,"to escort you out."],[5870,5995,"Aren't you Grace's assistant?"],[6020,6120,"Yes, I am."],[6120,6283,"Okay, take me to her office right now."],[6283,6383,"I need to speak with her."],[6408,6633,"Follow me, since you insist."],[6858,6983,"I told you she was playing me."]],"45":[[833,895,"She liked to look up"],[895,1070,"and see your face after a long day."],[1145,1195,"That's why"],[1195,1295,"she placed the picture there."],[1370,1520,"All she had to do was look up,"],[1570,1670,"and she'd see you."],[1820,1891,"Did she..."],[2075,2195,"did she look at it often?"],[2320,2362,"Yes,"],[2483,2683,"I'd often find her exhausted,"],[2720,2883,"yet gazing at it"],[2920,2995,"and daydreaming"],[2995,3108,"with a contented look."],[3183,3420,"One you didn't deserve."],[4583,4695,"Eric..."],[4970,5058,"I missed you."],[5812,5958,"Grace, where are you?"],[6033,6183,"I've been a fool for so many years."],[6183,6400,"Now I realize I've made a mistake."],[6470,6516,"You were the one"],[6516,6670,"I was always in love with."],[7883,8008,"You loved me a lot."],[8258,8395,"This is all my fault."],[8508,8683,"I'm the fool who hurt you."],[8845,9033,"The one too stupid to recognize"],[9033,9145,"that you were the one"],[9170,9408,"that I promised to protect and to love."],[9495,9683,"I didn't see how good you were to me."],[9883,10058,"That did nothing but hurt you."]],"46":[[87,275,"I didn't see how good you were to me."],[487,662,"That did nothing but hurt you."],[2066,2137,"Honey, you're home."],[2312,2450,"Eric, dinner's ready."],[2537,2662,"It's best if you eat it hot."],[2662,2762,"I'm not going to touch that."],[3350,3487,"We lost the baby."],[3537,3650,"It's probably for the best anyway."],[3650,3787,"It's not like I ever wanted it."],[3900,3987,"And remember your promise."],[3987,4087,"Don't ever show your face"],[4087,4162,"around me again."],[4162,4212,"This time,"],[4225,4375,"I'll make sure you never find me again."],[4475,4637,"You better stand by your words."],[4837,4900,"Grace."],[5037,5187,"I'm sorry that I let you down."],[5250,5450,"I promise to love you from now on."],[5450,5537,"Please just,"],[5612,5775,"please just come back to me."],[5900,6075,"I'm begging you, Grace, please."],[6225,6350,"Please don't abandon me."]],"47":[[170,320,"Grace?"],[770,908,"What the hell are you doing here?"],[945,1045,"You should leave."],[1120,1233,"Look, I'm her husband."],[1308,1370,"As her husband,"],[1370,1558,"I'm entitled to half of Hill Group."],[1620,1720,"You're telling me to leave?"],[1770,1945,"You're not getting a single cent."],[2020,2108,"Grace's last wish"],[2108,2308,"was that I manage Hill Group."],[2383,2520,"You're entitled to nothing."],[2583,2770,"I'm so ashamed to call you my brother."],[2770,2920,"No, I've had enough of your nonsense."],[3020,3220,"You take me to see Grace right now or,"],[3345,3520,"I'll make sure that this company sinks."],[3608,3720,"I will crush Hill Group."],[3720,3945,"Eric, all you did when Grace was alive"],[3945,4208,"was shower her in bitter resentment."],[4208,4433,"Blaming her for your shortcomings."],[4433,4545,"And now that she's gone,"],[4858,4958,"you're free."],[5033,5220,"There's nobody left to blame."],[5220,5520,"Yet here you are, still trying to torment her."],[5520,5625,"She can't even have peace"],[5625,5733,"in her memory."],[5741,5812,"No."],[5883,6050,"No, I don't resent her."],[6050,6225,"I'm not trying to torment her, Hazel."],[6225,6325,"I've wronged her."],[6395,6520,"I don't hate Grace at all."],[6520,6595,"I love her."],[6783,6845,"I love her."],[6845,6983,"I can't live without her."]],"48":[[25,137,"I don't hate Grace at all."],[137,212,"I love her."],[312,375,"I love her."],[375,500,"I can't live without her."],[575,712,"Why didn't you tell her that"],[712,925,"when she was alive, you idiot?"],[975,1100,"What's the fucking point"],[1100,1212,"in saying it now?"],[1212,1425,"Just, just take me to see her,"],[1425,1500,"Hazel, please."],[1750,1925,"It's too fucking late."],[2062,2175,"You have no idea"],[2175,2400,"how much she truly loved you."],[2462,2675,"No idea how much you've lost."],[2800,2937,"Ever since you saved her"],[2937,3087,"from drowning eight years ago,"],[3087,3262,"she has been in love with you."],[3287,3412,"I tried to tell her"],[3412,3637,"you weren't the same sweet boy"],[3637,3800,"who promised to marry her,"],[3862,4087,"but a cold-hearted brute instead."],[4437,4625,"But she was still so stubborn."],[4675,4887,"She believed her love"],[4887,5075,"could soften your heart."],[5162,5250,"Wait, what did you say?"],[5475,5587,"You said drowning?"],[5737,5975,"You jumped into the ocean and saved her."],[6050,6162,"She was depressed."],[6162,6325,"You pulled her out yourself."],[6325,6500,"Surely you haven't forgotten that."]],"49":[[2454,2566,"I'm sorry, Mom."],[2716,2854,"I know you wanted more from me,"],[2854,3004,"but I can't do this anymore."],[3104,3241,"It hurts too much."],[3316,3429,"It's too painful."]],"50":[[2679,2854,"Hey, hey, hey, hey, come on."],[2891,3029,"Come on, come on, stay with me."],[3066,3179,"Come on, come on, hey."],[3291,3454,"Hey, hey, hey."],[3579,3654,"You're okay."],[4179,4266,"Wait, don't I know you?"],[4316,4454,"No, you should just let me go."],[4504,4616,"I would have been better off."]],"51":[[183,270,"Wait, don't I know you?"],[333,458,"No, you should just let me go."],[508,620,"I would have been better off."],[783,970,"Look, I don't have any idea"],[970,1133,"what's going on in your life right now,"],[1133,1195,"and I'm not going to"],[1195,1308,"pretend like I do, but,"],[1420,1683,"look, I like to think about life"],[1708,1833,"like the ocean tides."],[1883,2058,"You know, it's got its highs and its lows,"],[2058,2208,"and sometimes they feel like"],[2208,2345,"they can swallow a person whole,"],[2345,2520,"but every tide has to rise."],[2633,2745,"You know, this will pass."],[2745,2870,"This is not gonna pass."],[3083,3195,"It's not that simple."],[3233,3358,"It is that simple."],[3458,3533,"You just have to learn"],[3533,3633,"how to tread water"],[3633,3783,"without letting it take you under."],[3920,4020,"And just so we're clear,"],[4020,4083,"I'm talking about"],[4083,4233,"the hypothetical waves of life,"],[4233,4495,"not jumping into an ocean."],[4545,4720,"You know, life can feel hard and lonely"],[4720,4833,"like you want to give up, but"],[4970,5058,"you always"],[5058,5208,"come out stronger and wiser"],[5208,5308,"on the other side."],[5620,5720,"Do you really think that?"],[5858,5920,"I do."],[6083,6183,"But you only get there"],[6183,6308,"by not giving up the fight."],[6708,6770,"Hey."],[6820,6870,"Hey!"]],"52":[[425,650,"Later, she told me that you,"],[825,1012,"my brother, saved her."],[1112,1225,"The same little boy"],[1225,1387,"who promised to marry her."],[1475,1562,"She was convinced"],[1562,1712,"that you were her destiny."],[2362,2550,"You were the only thing she had!"],[2637,2829,"Grace lost her mother so young"],[2829,3050,"and was made to feel small for years"],[3050,3237,"by her stepmother and Amanda."],[3337,3450,"She was depressed"],[3475,3737,"and you gave her a reason not to be."],[3812,4075,"She still battled with those feelings, Eric."],[4075,4287,"She just didn't have the courage"],[4287,4375,"to tell you."],[4425,4775,"But you gave up all that for Amanda."],[4962,5187,"A bitch, who wants nothing"],[5187,5300,"but to hurt you."],[5387,5537,"You didn't know that, did you?"],[5587,5700,"Maybe Grace would have been"],[5700,5912,"smart enough to give up on you"],[5937,6075,"and not waste her time"],[6075,6262,"trying to win your affection."],[6375,6512,"But she overheard Amanda"],[6512,6662,"planning to hurt you."]],"53":[[66,216,"She overheard Amanda"],[216,366,"planning to hurt you."],[416,591,"That's the real reason"],[591,779,"she insisted on marrying you."],[816,1016,"She was trying to help you."],[1129,1179,"But you,"],[1291,1604,"you were too stupid to realize it."],[1629,2016,"You're still too stupid to realize it!"],[2054,2216,"You made her feel like nothing"],[2216,2404,"for five years!"],[2441,2591,"You drove her to death!"],[2766,2816,"Death?"],[3141,3366,"Now, I've said it once, Hazel,"],[3379,3479,"but I'll say it again."],[3479,3716,"I don't believe you."],[3779,3929,"Now, you take me to see Grace"],[3991,4041,"or I'll make sure"],[4041,4179,"that no one can have Hill Group."],[4279,4429,"Eric, what are you on?"],[4429,4566,"Have you lost your mind?"],[4779,4904,"Three days, Hazel."],[4979,5129,"If I don't see Grace in three days,"],[5129,5304,"I will destroy Hill Group."],[5391,5554,"Eric, how are you trying to"],[5554,5691,"take us all down with you?"],[5691,5804,"You're spiraling!"],[5941,6029,"Notify everyone."],[6129,6304,"Within a week, we're acquiring Hill Group."],[6679,6741,"Three days."]],"54":[[212,350,"Did you hear Mr. Watson"],[350,525,"sent orders to suppress Hill Group?"],[575,725,"I can't believe he isn't even"],[725,875,"letting the dead rest in peace."],[875,937,"My god."],[937,1112,"He might still be bitter about his wife"],[1112,1275,"forcing him to marry her back then."],[1362,1512,"That guy can hold a grudge."],[1512,1587,"I know."],[1625,1762,"She treated him like a king."],[1787,1975,"And the only thing she got in return"],[1975,2150,"is that our company is trying to"],[2150,2300,"damage her mother's legacy."],[2350,2462,"He's going too far."],[2537,2675,"Who's going too far?"],[2775,2825,"Mrs. Blackburn."],[2825,2912,"Oh, Mrs. Blackburn."],[2912,2950,"I didn't-"],[2954,2987,"I didn't-"],[3350,3587,"How dare you slander the company"],[3587,3750,"and Mr. Watson's good name"],[3750,3862,"without him being here"],[3862,3962,"to defend himself."],[4012,4062,"I-"],[4237,4450,"You know what that tells me, Mia?"],[4500,4625,"That tells me that"],[4625,4812,"you don't really want your job here."],[4837,4962,"Is, is that correct?"],[4987,5125,"I'm sorry, Mrs. Blackburn."],[5125,5200,"I didn't mean to say-"],[5400,5500,"I'm going to teach you"],[5562,5800,"a very good lesson today."],[5800,5912,"You're going to learn to"],[5912,6100,"keep that little mouth of yours shut."],[6337,6437,"What the hell are you doing?"],[6575,6637,"Eric."],[6762,7087,"Your employees were talking about you"],[7087,7187,"behind your back."],[7225,7300,"They were saying"],[7300,7450,"how you should be ashamed of the way"],[7450,7575,"you treated Grace."],[7600,7900,"As if that's any of their business."],[7962,8087,"Well, they didn't say anything wrong."],[8250,8300,"It's true."],[8300,8395,"I should be ashamed."]],"55":[[12,137,"They were saying"],[137,262,"how you should be ashamed"],[287,450,"of the way that you treated Grace."],[500,637,"Well, they didn't say anything wrong."],[825,875,"It's true."],[875,975,"I should be ashamed."],[1262,1350,"Eric, what?"],[1362,1462,"You heard me."],[1537,1650,"My wife, Grace,"],[1650,1787,"deserves to be treated far better"],[1787,1887,"than the way I've treated her."],[1975,2075,"She's an invaluable part"],[2075,2187,"of Watson Corporation"],[2587,2662,"and my life."],[2875,2925,"Eric."],[3187,3287,"This isn't over."]],"56":[[141,204,"Eric."],[266,466,"You love me."],[604,754,"You chose me."],[754,816,"Amanda,"],[966,1041,"five years ago,"],[1041,1204,"why did you pretend"],[1229,1341,"to be the childhood sweetheart"],[1341,1429,"I'd been looking for?"],[1529,1679,"Why did you try to be her?"],[1791,1979,"Because I liked you first."],[2066,2191,"Grace has had everything"],[2254,2379,"ever since she was little,"],[2441,2566,"including you."],[2616,2904,"I told my mom that I liked you."],[2929,3154,"She pretended to be pitiful"],[3154,3329,"just to steal you away from me."],[3329,3579,"So everything you ever told me"],[3579,3629,"was all a lie."],[3629,3691,"No."],[3804,4041,"No, it wasn't a lie."],[4079,4316,"You assumed that I was her."],[4316,4454,"I never corrected you"],[4454,4729,"because I'm meant to be with you,"],[4754,4841,"not her."],[4841,4941,"It's all my fault."],[5004,5179,"God, how could I be so blind?"],[5504,5666,"Don't touch me."]],"57":[[62,125,"Eric."],[400,587,"I heard you want to take over Hill Group."],[687,800,"What's that got to do with you?"],[800,887,"Everything."],[975,1087,"The Blackburn family"],[1087,1250,"used to own Hill Group."],[1287,1462,"My family."],[1525,1725,"Until Grace's mom snatched it"],[1725,1837,"from under our noses."],[1875,2337,"Since you want to overcome Hill Group,"],[2362,2587,"why don't our families join hands?"],[2650,2837,"I could get my father to help you."],[3300,3437,"It could be a wedding gift."],[3550,3712,"From you to me."],[4000,4312,"First of all, Hill Group belongs to Grace."],[4387,4550,"Secondly, why on earth do you think"],[4550,4712,"that I would ever marry you?"],[4850,4975,"Because you love me."],[5037,5087,"No."],[5212,5425,"No, I love the illusion that you created."],[5462,5575,"The person I should have loved"],[5575,5700,"was the one who was real"],[5700,5875,"and right in front of me the whole time."]],"58":[[75,162,"Security."],[300,362,"Throw her out."],[387,450,"Eric."],[525,675,"Eric, you don't want to do this."],[675,762,"From this day forward,"],[762,887,"she's not allowed to step foot"],[887,1050,"inside of Watson Corporation."],[1112,1212,"Eric!"],[1287,1362,"No!"],[1375,1512,"I love you, Eric."],[1537,1800,"I've always loved you!"],[2350,2425,"Eric."],[2475,2675,"What the hell is wrong with you?"],[2900,2950,"Hey!"],[3012,3150,"Why are you messing with their business?"],[3187,3237,"Huh?"],[3300,3362,"What do you want with Hill Group?"],[3362,3512,"Look, I'm not trying to ruin them."],[3687,3800,"It's just a strategy"],[3800,3900,"to get Grace to come back."],[4100,4225,"Wake the fuck up!"],[4262,4412,"Grace is dead!"],[4425,4587,"Her funeral is tomorrow!"],[4650,4812,"Everyone seems to acknowledge that"],[4812,4900,"except for you!"],[4975,5137,"You're too busy catering to your ego"],[5137,5250,"and messing with her company!"],[5662,5737,"You neglect."],[5800,5912,"That's the reason she's gone."],[5962,6037,"You're the only one"],[6037,6137,"to blame for her death."],[6137,6225,"You're wrong!"],[6287,6337,"You're wrong."],[6337,6437,"She's not dead."],[6437,6550,"She's hiding from me!"],[6775,6837,"And when the news"],[6837,6950,"spreads about Hill Group,"],[7025,7175,"I'll finally be able to find her."],[7625,7712,"You're delusional."],[7862,7975,"You need help, Eric."],[8075,8162,"You really do."],[8337,8541,"Shes out there, and I will find her."],[8579,8737,"I have to."]],"59":[[900,1000,"Dinner's ready."],[1075,1162,"It's your favorite."],[1187,1387,"Okay, you can drop the doting wife act."],[1458,1583,"I'm not gonna touch that."],[1725,1850,"I lost my appetite."],[1908,1945,"Grace,"],[1945,2050,"you waited for me,"],[2100,2237,"day after day,"],[2275,2412,"and I never showed up."],[2537,2666,"I was so wrong."],[2708,2870,"Please, come back."],[2945,3095,"Don't leave me here alone."],[4687,4887,"Eric, you should pay your respects"],[4887,5000,"at your wife's grave."],[5012,5137,"It's the very least you can do."],[5225,5300,"Be a man."]],"60":[[429,625,"The tombstone is a clever touch, Hazel."],[691,770,"But you guys are going-"],[770,916,"you guys are going too far."],[1016,1133,"Why are you throwing"],[1133,1254,"a funeral for her?"],[1316,1404,"She isn't dead."],[1416,1554,"This is just, this is cruel."],[1566,1791,"Eric, you've seen her death certificate."],[1854,2041,"Her body is underneath your feet."],[2041,2204,"Why do you keep lying to yourself?"],[2204,2341,"Stop, it was forged."],[2404,2479,"It was forged."],[2479,2566,"Anyone can buy"],[2566,2754,"falsified documents online."],[2791,2966,"That certificate didn't belong to Grace."],[2966,3054,"She isn't dead."],[3079,3266,"My condolences, Mr. Watson."],[3354,3429,"We know how terrible"],[3429,3529,"you must feel,"],[3529,3741,"but the death certificate"],[3741,3904,"was issued a long time ago."],[4129,4366,"Please, take care of your health"],[4366,4441,"during this time."]],"61":[[104,179,"Oh, fu-"],[895,970,"She isn't dead,"],[970,1058,"you guys, leave."],[1070,1208,"Go home, now!"],[1208,1283,"Go home!"],[1283,1383,"What are you doing here?"],[1408,1470,"Go."],[1495,1545,"What?"],[1545,1595,"Eric. - What?"],[1595,1770,"She is dead, Eric. - No, she's not."],[1808,1920,"I'm so sorry."],[1966,2016,"No."],[2033,2133,"I'm so sorry."],[2133,2220,"No, no, no."],[2220,2270,"Please."],[2358,2458,"Please don't be dead, Grace."],[2458,2595,"I gotta see you one more time."],[2745,2841,"Why did you have to leave"],[2841,3033,"before I realized how wrong I was?"],[3120,3208,"What am I supposed to do?"],[3208,3358,"How am I supposed to go on?"],[3645,3795,"I should have told you, Grace."],[3845,4020,"I should have told you a long time ago"],[4020,4095,"that I love you."],[4595,4637,"Eric?"],[4720,4858,"Oh my god, Eric!"],[4895,4958,"Help!"]],"62":[[183,520,"You finally realized the treasure you lost."],[670,783,"But now that it's gone,"],[920,1150,"there's no point in regretting it now."],[1345,1495,"You bastard!"],[1558,1708,"Look at what you did to Grace!"],[1770,1983,"Not only are you responsible"],[1983,2170,"for your child's death,"],[2183,2370,"but you drove your wife,"],[2370,2545,"the woman who loved you so much,"],[2545,2683,"to take her own life."],[2733,2883,"You have both of their deaths"],[2883,3008,"on your hands!"],[3058,3133,"Mom, I know."],[3208,3283,"I'm sorry, it's..."],[3408,3508,"It's too late."],[3895,4045,"You were truly blind,"],[4083,4233,"and now you're paying the price."],[4333,4470,"How could you neglect a girl"],[4470,4595,"as sweet as Grace?"],[4720,4933,"There is not a single soul in this world"],[4933,5120,"who loved you as much as she did."]],"63":[[1008,1058,"Wait, Mom."],[1145,1283,"Mom, I lost my wedding ring."],[1283,1333,"Okay."],[1370,1470,"I gotta find it."],[2958,3037,"My ring."],[3087,3112,"My ring,"],[3112,3195,"I need to find it."],[3195,3279,"It's all I have left of her."],[3483,3595,"It's all that's left of her."],[3708,3820,"Where is it?"],[3908,4033,"Why can't I find it?"]],"64":[[229,466,"Eric, your missing ring"],[504,654,"is just the beginning."],[866,929,"Grace."],[1066,1166,"I'll take back everything"],[1166,1266,"you ever gave to him."],[1891,1966,"Mr. Watson!"],[2141,2229,"Mr. Watson!"],[2304,2429,"They're trying to buy Watson Corp stock"],[2429,2579,"at an outrageously high price."],[2629,2766,"They're trying to take over the company."],[2866,2929,"Mr. Watson."],[3104,3266,"Oh Dad, I still don't believe it."],[3291,3466,"There's no way you got Loki to visit."],[3504,3679,"He's the heir of the Young Group."],[3704,3791,"Believe it."],[3829,4004,"He should be here any second now."],[4041,4166,"They've already brought those."],[4316,4529,"These are the rest of the gifts"],[4554,4704,"prepared by the young master"],[4704,4866,"for the Blackburns."],[6141,6204,"Please."],[6454,6516,"Sorry."],[6616,6879,"May I ask what brings the great heir"],[6879,6954,"to the Young Group"],[6954,7104,"to our humble abode?"],[7154,7304,"If I may be so bold,"],[7304,7479,"have you come to discuss"],[7479,7716,"a collaboration with our family?"],[7791,7879,"Well, if we're talking about"],[7879,7991,"the Blackburn family,"],[8041,8104,"you're not even worth"],[8104,8241,"considering as shoeshiners."],[8316,8554,"But I come to repay a kindness."]],"65":[[66,154,"A kindness?"],[229,329,"Three years ago,"],[366,504,"I was in this area for business"],[504,691,"when I was in a terrible car accident."],[754,866,"A woman claiming to be"],[866,991,"from the Blackburn family"],[991,1066,"saved me."],[1129,1291,"My injuries were so severe"],[1341,1566,"that I had to go abroad for treatment."],[1704,1866,"I never got the chance to thank her."],[1929,2029,"After some investigation,"],[2029,2229,"I learned that the Blackburn family"],[2229,2316,"lives in this city."],[2441,2604,"I came back as soon as I recovered"],[2604,2841,"to extend my gratitude."],[2879,3129,"Well, I'm the one who saved you."],[3154,3404,"I'm just so glad that you're okay."],[3466,3516,"You?"],[3629,3704,"Is that right?"],[3845,4041,"You don't look the same."],[4066,4266,"Uh, well, I had,"],[4266,4479,"um, reconstructive surgery"],[4479,4579,"from a very,"],[4579,4804,"a very awful, awful condition."],[4804,4979,"So my face has changed"],[4979,5079,"around a little bit."],[5079,5541,"But, uh, here is what I used to look like."]],"66":[[141,254,"You've tortured Grace"],[254,404,"for her entire life."],[454,541,"And now you're even"],[541,666,"going to impersonate her"],[666,779,"to climb the ladder?"],[841,916,"Wonderful."],[1029,1166,"It must be a stroke of fate"],[1166,1241,"to be saved by a woman"],[1241,1379,"as beautiful as you."],[1429,1516,"Stop."],[1554,1616,"Don't worry."],[1629,1691,"I'll do my best"],[1691,1816,"to support the Blackburn family"],[1816,1891,"in the future."],[2016,2091,"Miss Blackburn,"],[2129,2229,"would you be interested"],[2229,2354,"in joining me for coffee tomorrow?"],[2379,2479,"Oh, I'd love to."],[2529,2591,"Great."],[2654,2716,"I'll see you then."],[2741,2879,"I look forward to it."],[4066,4116,"Sir?"],[4154,4266,"Don't worry, Grace."],[4329,4404,"I'll see to it"],[4404,4541,"that everyone who ever hurts you"],[4541,4629,"gets what they deserve."],[4704,4891,"Even your revolting husband."]],"67":[[83,370,"Dad, I've been keeping Eric"],[370,533,"on the hook for so long."],[583,833,"It'd be a shame to let him go now."],[833,920,"What shame?"],[958,1183,"Eric already knows that you lied to him."],[1220,1383,"If you keep your mouth shut,"],[1408,1620,"he'll never discover your other secrets."],[1683,1783,"But if you're not careful,"],[1845,1920,"and if certain events"],[1920,2058,"from the past come to light,"],[2083,2283,"we'd have no way of quelling his anger."],[2320,2395,"Loki Young?"],[2408,2583,"That's a different story, Amanda."],[2583,2833,"The Young family is far more powerful"],[2833,2920,"than Watson's."],[3020,3233,"Our family has plateaued."],[3270,3433,"Our climb to the top"],[3483,3620,"depends upon you"],[3670,3958,"being Loki's wife."],[4270,4483,"Oh, seducing men."],[4533,4733,"Well, Daddy, that's my specialty."],[4820,4983,"I'll bring you back some good news."],[5945,6008,"Really?"],[6058,6120,"You?"],[6233,6420,"You're the one that Grace chose?"],[6483,6645,"Wait, you knew Grace?"],[6720,6845,"You don't really believe"],[6845,7070,"that Grace is dead, do you?"]],"68":[[20,108,"Wait, what did you say?"],[195,345,"Yeah, Grace isn't dead, right?"],[395,533,"I know where Grace is."],[645,708,"Well, tell me."],[770,858,"Where is she?"],[970,1083,"Tell me where she is."],[1233,1295,"Tell me."],[1320,1458,"Tell me where the fuck she is!"],[1495,1612,"Who the fuck are you, huh?"],[1612,1670,"Speak!"],[1670,1795,"Speak, goddammit!"],[1958,2245,"Why don't you try begging?"],[3470,3570,"I am begging you."],[3645,3808,"Please, tell me where she is."],[3883,4045,"Look, I have to see her again."],[4383,4608,"Don't be in such a rush."],[4637,4783,"The show's just getting started."],[4908,5070,"You tortured Grace for so long."],[5070,5320,"Why should I let you off so easily?"],[5320,5383,"I'll give you,"],[5395,5508,"I'll give you whatever you want."],[5545,5608,"Anything."],[5745,5820,"Eric,"],[5900,5995,"what I want..."],[6408,6783,"is to make your life a living hell."]],"69":[[1191,1341,"Grace, please come back."],[1466,1641,"I've never been so scared or lonely"],[1641,1754,"in my entire life."],[2054,2216,"I need you like I need air."],[2341,2454,"I made a mistake."],[2704,2779,"Mr. Watson!"],[2791,2829,"Get up."],[2829,2879,"Hurry!"],[2879,2979,"The house is on fire."],[2979,3054,"Hurry."],[3054,3191,"Hurry, grab all of Grace's stuff."],[3216,3266,"Sir,"],[3266,3354,"Miss Watson doesn't have"],[3354,3441,"anything left in the house."],[3441,3479,"Come on."],[3483,3516,"Come on."],[4091,4166,"I'll make sure"],[4166,4404,"you have nothing left, Eric."],[4491,4629,"Not even the home"],[4629,4779,"that she made you with her love."]],"70":[[320,445,"Divorce papers."],[595,720,"That's all I have left of her."],[895,1058,"The only proof that she was mine."],[2470,2545,"Are you okay?"],[2708,2820,"Uh, just hold on, all right?"],[2908,3020,"I can smell gas."],[3120,3220,"The car is going to blow."],[3220,3320,"You have to leave."],[3333,3445,"forget about me!"],[3483,3583,"I'm not going to leave you here"],[3583,3683,"to die, okay?"],[3695,3770,"I got this."],[3783,3858,"And so do you."],[3858,3908,"Come on."],[3908,3995,"We're going to get you out of here."],[4033,4095,"Come on."]],"71":[[150,300,"You risked your life to save me."],[350,475,"A complete stranger."],[612,712,"Are you not afraid?"],[762,837,"No, I'm not afraid."],[837,1012,"The only thing I would be afraid of is"],[1037,1125,"is leaving you in there"],[1125,1262,"and regretting it for the rest of my life."],[1350,1487,"Somebody saved me once."],[1525,1650,"And I never forgot it."],[1675,1800,"At that moment,"],[1800,1950,"I thought I met an angel."],[2175,2362,"Whoa, whoa, woah, hey, hey, hey."],[2462,2512,"Wake up."],[2575,2625,"Wake up."],[2625,2712,"Open your eyes."],[2737,2812,"Help!"],[2862,2950,"Somebody!"],[3137,3212,"You have no idea"],[3212,3375,"how bad I wanted to whisk you away."],[3412,3550,"It's a shame you're already married"],[3550,3637,"and infatuated with"],[3637,3762,"that bastard of a husband."],[3800,3887,"I didn't want to"],[3887,4012,"destroy your happiness."],[4087,4162,"So I left."],[4312,4437,"I couldn't have expected"],[4437,4512,"that the news I would"],[4512,4575,"hear about you"],[4575,4800,"would be the news of your death."],[4850,4987,"If I would have known"],[4987,5137,"what you were going through earlier,"],[5187,5300,"I would have saved you."],[5637,5800,"I'm taking back everything"],[5800,5925,"you ever gave him."],[6025,6137,"I'll get revenge for you."]],"72":[[25,75,"Eric!"],[412,487,"Are you okay?"],[575,662,"I'm being punished"],[662,825,"and I deserve every bit of it."],[875,1012,"This is some kind of freak accident."],[1025,1075,"Nothing else."],[1075,1200,"Don't let your thoughts run wild."],[1237,1362,"You know, before Grace left,"],[1362,1437,"she wiped away"],[1437,1575,"every trace of her existence."],[1662,1850,"Except for a couple lousy boxes"],[1850,1975,"the housekeeper donated."],[2087,2362,"That house is the only thing"],[2362,2450,"that she left me"],[2450,2650,"and it's filled with our memories together."],[2887,3012,"And now that's gone too."],[3125,3325,"Lucas, the only thing that I have left"],[3325,3475,"to prove that she ever loved me"],[3475,3637,"are these divorce papers."],[3875,4175,"Why couldn't I let myself love her?"]],"73":[[179,304,"Because you were afraid to get hurt."],[329,404,"At least you're admitting"],[404,491,"that you love her now."],[554,654,"You may have been mad."],[654,741,"Maybe Grace wasn't"],[741,854,"who you thought she was,"],[854,1066,"but she devoted her life to you."],[1116,1216,"Day after day."],[1291,1341,"And day after day,"],[1341,1491,"she fell for you a little more."],[1529,1791,"And over time, you fell for her too."],[1816,2054,"Yeah, I fell for her a long time ago."],[2204,2304,"When we were kids."],[2391,2529,"And we didn't even realize it."],[2683,2754,"Fuck."],[2829,2941,"I miss her, Lucas."],[2954,3054,"You know, I'd give anything"],[3054,3154,"for one more day."],[3191,3279,"Things will get better."],[3529,3616,"It's gonna take some time."],[3691,3816,"I don't deserve better."],[4041,4229,"You know, I did so many horrible things"],[4229,4379,"to her, I deserve to suffer."],[4441,4495,"Grace would not want"],[4495,4579,"to see you suffer."],[4629,4766,"Eric, you know that."],[4804,4891,"She loved you so much"],[4891,5016,"more than anyone in this world."],[5166,5291,"She doesn't want to see you in pain."],[5291,5391,"Look, she is dead,"],[5416,5491,"Lucas."],[5541,5654,"She hated me enough to"],[5654,5741,"give up on living."],[5741,5941,"What right do I have to receive her love?"],[6179,6291,"Hazel gave this to me."],[6304,6466,"This was Grace's last message to you."]],"74":[[12,175,"This was Grace's last message to you."],[375,475,"I think you should hear this."],[1900,1962,"Eric?"],[2175,2262,"You came!"],[2312,2475,"Grace, please don't leave me all alone."],[2475,2612,"I'll make it better."],[2675,2737,"I'll do better."],[2737,2975,"Just come back home, alright?"],[2975,3025,"Home?"],[3275,3500,"Do we even have a home to go back to?"],[3575,3762,"There's nothing left for me in this world."],[3762,3887,"It doesn't matter."],[3887,4062,"Home is wherever you are, Grace."],[4087,4150,"Please."],[4150,4250,"I'm sick."],[4450,4550,"It's terminal."],[4612,4737,"I lost my child."],[4800,4950,"There's nothing here anymore"],[4950,5062,"tethering me to you."],[5075,5112,"No."],[5212,5250,"No, no."],[5250,5387,"I can't lose you, Grace."],[5425,5562,"Grace, I won't let you go."],[7862,7950,"Queen Cafe."],[8000,8087,"3 p.m."],[8150,8262,"You'll want to see this."]],"75":[[191,316,"That day you pulled me from the wreck,"],[316,416,"I fell for you."],[466,579,"It was love at first sight."],[666,741,"My angel,"],[904,1041,"you haunted my thoughts"],[1041,1154,"when I was in recovery."],[1179,1279,"But I was always worried."],[1329,1466,"What were you worried about?"],[1516,1616,"I heard the love story"],[1616,1729,"between you and Mr. Watson."],[1791,2029,"They say that he neglected his wife,"],[2029,2129,"Grace, for you."],[2241,2466,"So, his wife is gone."],[2566,2654,"Why aren't you with him?"],[2841,2979,"Eric means nothing to me."],[3066,3304,"I didn't know where to find you."],[3329,3454,"You've been on my mind"],[3491,3604,"since that day, too."],[3679,3879,"All day, every day."],[3941,4091,"Amanda, I feel like you're bluffing."],[4129,4241,"It's okay to admit your feelings"],[4241,4304,"for each other."],[4354,4479,"I don't want you to feel pressured"],[4479,4604,"to accept my feelings for you"],[4604,4654,"just because you think"],[4654,4791,"my family will retaliate."],[4791,4966,"I can't stand Eric!"],[5104,5179,"Do you remember"],[5229,5454,"that major accident he had"],[5454,5604,"all those years ago?"],[5754,5904,"I'm the one who pushed him."]],"76":[[0,112,"You pushed him on purpose?"],[250,550,"He was overbearing."],[662,812,"He was trying to pressure me."],[812,1050,"I was just trying to escape him."],[1750,1900,"Mr. Watson, did you hear that?"],[1912,1987,"Why don't you come over here"],[1987,2075,"and get a better listen?"],[2112,2158,"What did you do?"],[2162,2275,"A background check on me?"],[2275,2425,"You're far too vile to be accepted"],[2425,2537,"into my family, Amanda."],[2600,2712,"But here's your perfect match."],[2750,2962,"Mr. Watson, you two are a match"],[2962,3037,"made in heaven."],[3200,3387,"Mr. Watson, this is obviously"],[3387,3525,"a misunderstanding."],[3550,3662,"Where's your evidence?"],[3662,3737,"You want proof?"]],"77":[[100,175,"You want proof?"],[625,800,"Amanda faked having leukemia"],[800,900,"for two reasons."],[937,1075,"First, she played at your sympathy"],[1075,1187,"so you would marry her."],[1187,1312,"So she could use your money"],[1350,1512,"to solve her family's problems."],[1562,1712,"And to take the blame for her father,"],[1733,1825,"even went to jail for him."],[1900,2050,"Second, she was always"],[2050,2250,"planning on stealing Grace's"],[2250,2362,"inheritance money."],[2387,2500,"Donating bone marrow"],[2500,2625,"was the perfect opportunity"],[2625,2800,"to kill Grace on the operating table."],[2912,3000,"She would have got away with it"],[3000,3112,"if Grace had not stopped her."],[3175,3287,"Grace forced you"],[3287,3512,"to marry her to save you."],[3587,3812,"She made it off that operating table alive."],[3812,4050,"And she saved you and your company."],[4137,4325,"So everything Grace ever told me"],[4325,4462,"was all true."],[4512,4600,"After realizing that"],[4600,4712,"her plans were ruined,"],[4750,4887,"she intentionally pushed you,"],[4887,5025,"trying to kill you."],[5050,5100,"She hoped that"],[5100,5200,"once you were out of the picture,"],[5200,5300,"she could take over control"],[5300,5412,"of the Watson Corporation."],[5450,5650,"If Grace hadn't risked her life,"],[5687,6000,"you'd be a poor, simple bastard."],[6025,6100,"No!"],[6200,6312,"No!"],[6337,6450,"He's lying!"],[6550,6612,"Can't you see?"],[6612,6837,"You vile, sickening woman."],[6850,7037,"You're the reason Grace is dead."],[7075,7212,"You're the one that made me lose her."],[7212,7312,"I hate you."],[7437,7525,"I told you'd want to see this,"],[7525,7600,"Mr. Watson."],[7625,7737,"Here's the real face of the woman"],[7737,7950,"that you loved for five years."]],"78":[[250,400,"You finally have the chance to do"],[400,550,"right by your stepsister."],[1012,1062,"Look at me."],[1100,1162,"Hey!"],[1212,1400,"I will do whatever you want."],[1400,1550,"Just give her the marrow."],[1562,1712,"Amanda's lying about her illness!"],[1712,1887,"But I would do anything for Amanda."],[1887,2000,"I would go to prison for her."],[2000,2112,"I would die for her."],[2112,2212,"You really don't believe a word"],[2212,2275,"I'm saying, do you?"],[2275,2462,"You don't need to say anything more."],[2462,2625,"Just tell me what you want."],[2825,2887,"Marry me."],[3200,3375,"Marry me and I will save her."],[4175,4212,"Alright."],[4237,4375,"You've been over this so many times."],[4375,4462,"Ultimately all you want"],[4462,4562,"is to win me over."],[4587,4712,"As long as you agree to save her,"],[4712,4812,"I will marry you."],[5075,5225,"But there has to be some ground rules"],[5225,5312,"if we get married."],[5525,5850,"You have to agree to be faithful to me"],[5887,6012,"and forget about her."],[6062,6137,"I'm going to be the one"],[6137,6237,"you'll be married to,"],[6262,6600,"to be faithful and care about me"],[6600,6700,"and love me."],[6925,7050,"Do you think you can do that?"],[7075,7175,"I can be faithful."],[7262,7462,"But I can't ever promise to love you."],[7587,7675,"Not when my heart"],[7675,7812,"belongs to someone else."],[7887,8037,"Well maybe you can learn to."],[8200,8287,"One day."]],"79":[[304,429,"Grace was telling me the truth"],[429,504,"this whole time."],[641,941,"She married me to save me from you."],[1029,1254,"But I was too foolish to see it"],[1254,1391,"and too stubborn to believe it."],[1454,1541,"Eric."],[1716,1804,"Stop."],[1854,1954,"Please."],[2016,2116,"Listen to me."],[2129,2554,"I know that I have made mistakes."],[2554,2766,"And maybe I was wrong."],[2854,2929,"But please."],[2966,3116,"You can forgive me."],[3241,3429,"We can put all this behind us."],[3516,3741,"Have our happily ever after."],[4416,4495,"Amanda."],[4529,4679,"You're the last person"],[4679,4854,"I want anything to do with."],[4941,5091,"You're the reason that Grace is gone."],[5091,5266,"You and your mother bullied her."],[5266,5379,"Excluded her."],[5379,5454,"And now you're going to"],[5454,5566,"slander her in death?"],[5654,5729,"I'm going to make sure"],[5729,5979,"every member of your family suffers."]],"80":[[879,954,"Mr. Watson."],[991,1091,"The Blackburns have been forced"],[1091,1204,"to file for bankruptcy."],[1279,1354,"The police have found"],[1354,1429,"a lot of evidence"],[1429,1529,"of embezzling money."],[1541,1704,"And Amanda and her parents"],[1704,1779,"have been arrested."],[1829,1879,"Well done."],[2016,2091,"Thanks, Sam."],[3754,3854,"I miss you, Grace."],[4079,4254,"I don't even have the ring you gave me"],[4254,4354,"to symbolize your love."],[4354,4504,"Because I was a fool and threw it away."],[4891,4966,"Mr. Watson."],[5054,5329,"Are you looking for this?"],[5366,5416,"That's mine."],[5416,5491,"Give it back."],[5704,5791,"You've been hanging on"],[5791,5891,"to this divorce agreement"],[5891,6016,"like it's the last thing on earth."],[6016,6079,"And now you're worried"],[6079,6183,"about your wedding ring?"],[6204,6466,"Focus on the papers, Eric."],[6579,6704,"They tell the truth of your story."],[6704,6754,"They tell you that"],[6754,6916,"you're not half the man you used to be."],[6916,6979,"And you failed her"],[6979,7154,"as protector and husband."],[7191,7329,"No, no, that's not true."],[7329,7466,"Grace and I aren't divorced."],[7491,7604,"I would die first."],[8016,8091,"Mr. Watson."],[8204,8291,"That divorce agreement"],[8291,8354,"was the last thing"],[8354,8516,"that Grace ever left you."],[8579,8816,"And you just ripped it to shreds."]],"81":[[208,258,"No."],[320,470,"No, no, no, no, no."],[520,683,"No, sweetheart, please, no."],[808,908,"I need you, Grace."],[970,1045,"I love you."],[1045,1108,"You don't deserve"],[1108,1345,"to have a shred of her left,"],[1345,1433,"including the papers"],[1433,1545,"that finally set her free."],[1583,1720,"Grace's biggest misfortune"],[1783,1920,"was loving you."],[2145,2270,"I'm sorry, Grace."],[2283,2433,"Grace, I'm so sorry."],[2433,2533,"This is my fault."],[2670,2795,"It's all my fault."],[2858,3133,"I was given the truest, purest love"],[3133,3208,"in the world."],[3208,3345,"And I took it for granted."],[3383,3470,"I took her love"],[3470,3683,"and threw it in her face like a monster."],[3720,3858,"I lost you, Grace."],[3945,4045,"I lost the woman"],[4045,4233,"who loved me most on this earth."],[4433,4520,"I love you."],[4645,4733,"I'm sorry."],[4983,5183,"I'm so sorry."]]}