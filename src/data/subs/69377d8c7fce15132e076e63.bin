[2581,2715,"Naz is a dangerous man."],[2715,2869,"All he's gonna bring is danger"],[2923,3098,"into my life. No!"],[3628,3703,"Are you okay?"],[3745,3878,"Did you and Naz have a fight?"],[4066,4141,"Kind of..."],[4346,4500,"I just don't think it's gonna work out"],[4500,4617,"between the two of us."],[4617,4879,"He's not the man I thought he was."],[5050,5134,"Come on,"],[5134,5330,"all new couples have fights."],[5330,5488,"It's just growing pains."],[5488,5718,"It's so much more than growing pains."],[6677,6835,"You're giving me whiplash."],[6835,6977,"One minute you're sobbing and the next"],[6977,7040,"you're smiling."],[7040,7123,"What gives?"],[7557,7691,"Looks like Naz took care of me"],[7691,7774,"one more time."]],"54":[[1313,1363,"I like"],[1530,1601,"that you're innocent."],[1943,2093,"It means I can teach you things."],[3274,3420,"You're treating me like I'm a treasure."],[3582,3636,"Aren't you though?"],[3678,3791,"Come on, I hit the jackpot."],[4087,4320,"You are so special, Karissa."],[4425,4575,"Now be my dirty little secret"],[4575,4667,"and scream my name."],[4946,5201,"He's already etched himself into my soul."],[5330,5455,"Fuck what anyone says,"],[5455,5626,"I want him now more than ever."]],"55":[[12,204,"I know the real Naz,"],[204,354,"not the monster"],[412,579,"from the stories or the rumors."],[608,713,"I have to find him,"],[713,804,"I have to tell him."],[3749,3945,"Naz, tell him,"],[4129,4312,"you're the Mafia boss,"],[4383,4533,"exact person"],[4533,4683,"my mom warned me about for years."],[4796,4913,"A trap within a trap."],[5013,5138,"God, I'm so stupid."],[5280,5417,"I just, I can't control myself"],[5417,5488,"around you."],[5513,5551,"I..."],[5747,5935,"think I'm falling in love with you."]],"56":[[425,525,"Hey, you're back."],[1055,1130,"Did you hear all that?"],[1197,1263,"You have no"],[1368,1405,"idea"],[1530,1618,"what it means to me"],[1618,1722,"to see you here again."],[2256,2494,"Does this mean that you accept me"],[2581,2690,"for who I am?"],[2798,2915,"But I..."],[3036,3161,"I was so terrified"],[3261,3382,"of what my life would do to you."],[3511,3649,"Okay, I was worried that someone would"],[3737,3903,"track you down and find you just to get"],[3903,4033,"to me, but-"],[4191,4279,"But I had to tell you,"],[4304,4425,"You had to know the truth,"],[4425,4558,"even if it meant that..."],[4646,4721,"you could leave me."],[4788,4913,"He means it,"],[4913,4959,"I know it."],[5776,5860,"I would die for you."],[6010,6264,"You are literally everything to me."],[6348,6460,"Just promise you're not gonna"],[6460,6548,"to hurt me, okay?"],[6623,6731,"I'm not gonna to hurt you."],[6898,6965,"Even if fate,"],[7057,7182,"turns us against each other,"],[7182,7269,"I'm not going to hurt you."],[7507,7682,"What if fate tries to tear us apart?"],[7882,7945,"Now tell me,"],[8024,8103,"what's in your heart?"]],"57":[[33,216,"I knew you were dangerous all along,"],[321,392,"and I stayed."],[533,592,"Yeah, you did."],[809,850,"So?"],[1088,1217,"I think we're tied together."],[1372,1518,"Nothing can tear us apart."],[4158,4245,"God, I love you."],[4312,4416,"I love you too."],[5184,5313,"Give yourself to me."],[5313,5392,"Swear that you're mine,"],[5392,5451,"all of you."],[5538,5609,"I'm yours."],[5663,5814,"I've been yours since the second you"],[5814,5955,"saved me at that hospital."],[6164,6297,"Swear that you'll never betray me."],[6498,6552,"How?"],[6690,6781,"Your body"],[6986,7077,"and your blood."]],"58":[[729,850,"There's an old Mafia ritual"],[1013,1109,"where you spill blood"],[1192,1326,"on pictures of old saints."],[1480,1626,"Well, then you burn the cards."],[2047,2139,"It's dramatic."],[2902,3028,"Princess, it's not dramatic."],[3140,3211,"In my world,"],[3311,3490,"the most powerful oath"],[3574,3674,"is sealed in blood."],[4120,4258,"And I've never wanted to do this"],[4258,4366,"with anybody before."],[4421,4504,"But you said you burned"],[4504,4592,"the card afterwards."],[4688,477