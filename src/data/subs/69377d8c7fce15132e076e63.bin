],[2815,2944,"as a tuition payment."],[2944,2994,"God,"],[3028,3153,"this might have just cost me"],[3153,3319,"my entire college education."],[3628,3753,"Excuse me, Professor?"],[3832,3999,"I don't deserve the F you gave me."],[4162,4337,"You're lucky I'm failing you outright."],[4396,4521,"Dumbass girls like you..."],[4596,4754,"do not belong in sociology,"],[4754,4863,"let alone higher education"],[4863,4975,"for that matter, if you ask me."],[5000,5221,"The only reason you failed me"],[5221,5334,"is because I slapped you"],[5334,5472,"when you tried to grab my ass."],[5472,5647,"Change it to the grade I deserve,"],[5663,5726,"now!"],[6101,6239,"You listen to me, young lady."],[6264,6364,"I have tenure."],[6398,6498,"You know what that means?"],[6544,6685,"It means I'm untouchable."],[6698,6723,"Well..."],[6806,6865,"So,"],[7036,7278,"if you want to pass my class"],[7278,7515,"and keep that scholarship of yours."],[7536,7590,"You,"],[7682,7799,"need to make me"],[7836,7899,"happy."]],"22":[[479,600,"Cornel? It's me."],[617,658,"Yes?"],[767,846,"I understand."],[855,955,"I'm leaving now."],[1255,1422,"That sounds like Naz."],[2127,2298,"Everything is falling apart."],[2298,2502,"My mom is crazy protective."],[2502,2648,"Tommy won't leave me alone."],[2648,2840,"And Professor Cornel definitely"],[2840,2957,"has it out for me."],[2990,3103,"It's all too much."],[3161,3299,"I can't breathe!"],[3386,3511,"And why won't Naz call?"],[3511,3616,"Text? Anything?"],[3666,3791,"Doesn't he want to see me as much as"],[3791,3874,"I want to see him?"],[5184,5292,"Hello there, princess."],[5292,5372,"Is something wrong?"],[5405,5559,"Hey, shut the fuck up!"],[5559,5638,"Is something wrong,"],[5638,5705,"yeah, yeah,"],[5705,5814,"actually everything is wrong."],[5864,5960,"My professor hates me."],[5985,6143,"Tommy's a psycho and my mom"],[6143,6264,"won't stop meddling in my life."],[6406,6544,"Okay, now I'm starting to think that"],[6544,6627,"you're the problem."],[6760,6840,