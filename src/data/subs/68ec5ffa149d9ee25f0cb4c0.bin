{"1":[[491,654,"The girl's a straight-A student."],[683,758,"Gorgeous, too."],[820,920,"Genes like that?"],[945,1083,"She's worth more than the others."],[1204,1283,"What are you doing?"],[1320,1379,"Deal."],[1441,1508,"Thirty grand."],[1541,1704,"I'm glad you're not my foster mother."],[1954,2041,"What's happening?"],[2104,2233,"I fed and clothed you."],[2258,2341,"You owe me."],[2691,2879,"Relax, relax."],[2895,3058,"You're going to help a rich couple"],[3058,3158,"have a baby."],[3220,3370,"All we need from you"],[3583,3695,"is your eggs."],[3733,3816,"My eggs?"],[3833,3908,"What?"],[4295,4391,"I'd always dreamed of"],[4391,4508,"being a mother someday."],[4541,4670,"But when they took my eggs,"],[4704,4858,"they damaged my ovaries."],[4995,5129,"I'll never have children,"],[5179,5333,"except the ones stolen from me."],[5679,5854,"I didn't plan to end up a janitor"],[5854,5987,"in an elementary school,"],[6020,6220,"surrounded by kids"],[6220,6345,"when I can't have one."],[6416,6616,"But being around them helps a little"],[6616,6820,"to fill the emptiness inside me."],[6866,6979,"We raided the black market"],[6979,7079,"fertility clinic,"],[7079,7204,"but they were long gone,"],[7204,7333,"and the records destroyed."],[7370,7558,"All we could recover from your file"],[7558,7645,"was this."],[8004,8170,"Somewhere out there,"],[8170,8291,"I have a baby girl."],[8345,8479,"And I have no way to find her."],[8945,9158,"Get in the car, you little brat!"],[9183,9345,"No, I don't want to."],[9429,9645,"You are insufferable!"],[10216,10429,"Don't you dare touch that child."],[10445,10570,"I am her mother."],[10608,10795,"Then act like one!"],[10795,10908,"Shut up."],[10954,11083,"You're just a janitor."],[11145,11445,"Hannah, get in that car right now."],[11483,11583,"I'm calling the cops."],[11904,12045,"I'll be back, bitch."],[12145,12291,"You son of a..."],[12541,12779,"You scared my bad Mommy away."],[12779,12916,"You saved me."],[13045,13241,"Can you be my new Mommy?"],[13583,13629,"Hannah!"]],"2":[[233,391,"I got you, Hannah Banana."],[441,554,"My whole life,"],[570,679,"all I ever wanted"],[679,833,"was someone to hold me like that"],[858,1020,"and tell me I was going to be okay."],[1095,1316,"She tried to take me away from you."],[1345,1504,"You'll never live with Clarice."],[1541,1608,"Not ever."],[1670,1783,"Pinky promise?"],[1941,2045,"Pinky promise."],[2608,2683,"Excuse me."],[2870,3095,"My daughter tells me I have you to thank"],[3095,3316,"for stopping my crazy ex-wife."],[3433,3591,"I didn't do much."],[3670,3804,"You protected my daughter."],[3858,3979,"That means the world to me."],[4133,4216,"Mason Cain."],[4358,4408,"Uh..."],[4520,4579,"Bailey."],[4645,4733,"Bailey Addams."],[4845,5045,"So ask her already, Daddy."],[5083,5195,"Ask her what, Banana?"],[5229,5495,"Ask her for you to marry her."]],"3":[[170,395,"Hannah, we can't just ask a stranger that."],[495,658,"I'm flattered that you want me"],[658,745,"to be your mother, Hannah."],[833,954,"It means more than you know."],[1016,1166,"I'm glad I was there to stop your ex-wife."],[1220,1341,"Sorry you had to leave work."],[1366,1533,"Hopefully your boss cuts you some slack."],[1950,2058,"My boss?"],[2091,2283,"She thinks I'm a construction worker?"],[2320,2470,"She has no idea who I am."],[3808,3920,"Good morning, Mr. Cain."],[4345,4583,"Bro, that was the CEO, Mason Cain,"],[4583,4733,"one of the richest men in the country."],[4758,4858,"Try the world."],[4883,5145,"He just doesn't build towers, but empires."],[5604,5754,"Clarice made a grab for Hannah."],[5804,5870,"She doesn't care"],[5870,6020,"if she hurts my daughter, Roger."],[6058,6216,"I can't risk her getting custody."],[6291,6379,"What are you gonna do?"],[6445,6591,"Maybe Hannah's right."],[6591,6695,"I mean, a stepmom could"],[6695,6829,"tip the judge in our favor."],[6995,7108,"I need to get married."],[7145,7333,"Mason, women practically"],[7333,7458,"throw themselves at you."],[7508,7583,"Just pick one."],[7583,7733,"But they're all gold-diggers"],[7733,7854,"and social climbers."],[8054,8154,"I need a loving mother"],[8154,8250,"who will genuinely care"],[8250,8333,"for my daughter."],[8433,8516,"Say less."],[9245,9341,"Speed dating?"],[9383,9545,"What is this, 2002?"],[9545,9670,"No, it's back."],[9670,9795,"It's like vinyl, right?"],[9795,9995,"There's no swiping, there's no filters."],[9995,10116,"It's just vibes."],[10133,10233,"And there's tons"],[10233,10391,"of marriage-ready women there."],[10408,10570,"Although, they may still"],[10570,10695,"recognize you as a billionaire."],[10995,11133,"Then I won't go as a billionaire."],[11370,11454,"What are you...?"],[11554,11654,"Good luck."]],"4":[[395,595,"Look what the mop dragged in."],[858,950,"Just once,"],[950,1108,"I'd like to come home to the house"],[1108,1295,"not looking like a pigsty."],[1295,1400,"So clean it!"],[1437,1545,"It's what you do."],[1612,1825,"Sis, we've just been worried about you."],[1837,2012,"I mean, you don't date."],[2012,2150,"You've got no social life."],[2275,2387,"Maybe you should get out more."],[2412,2520,"I mean, Mr. Pitt,"],[2550,2687,"he was asking about you again today."],[2687,2958,"Danny, your boss is in his fifties"],[2958,3120,"and has three ex-wives."],[3137,3325,"Bailey, not many men"],[3325,3412,"are gonna want you"],[3412,3508,"when they learn about"],[3508,3662,"your busted ovaries."],[3662,3970,"Luckily, Mr. Pitt has grown-ass kids,"],[3975,4108,"so he doesn't mind"],[4108,4262,"that you're not a real woman."],[4325,4500,"You can't speak to me like that"],[4500,4620,"in my own home."],[4737,4933,"Danny, please."],[4987,5087,"You're my big brother."],[5145,5370,"The only family I have left."],[5387,5583,"Let's cut the crap, okay?"],[5583,5687,"We want you out."],[5708,5837,"That room you sleep in?"],[5837,6012,"It's gonna be a nursery"],[6025,6175,"for my baby!"],[6200,6312,"I'm due any day,"],[6312,6450,"and I'm not raising my baby"],[6450,6583,"around your pity parade."],[6625,6758,"The lease is in my name."],[6787,6925,"I pay the rent."],[6962,7133,"I keep the lights on."],[7137,7237,"Yeah, with your pathetic"],[7237,7350,"janitor wage."],[7408,7587,"Vanessa, you leech."],[7637,7850,"You're nothing more than a pathetic girl"],[7850,7979,"who peaked in high school"],[7979,8137,"and thinks the world owes her."],[8562,8775,"I want your loser sister gone!"],[8945,9075,"Clean that up, bitch."],[9325,9475,"Bailey, look."],[9495,9620,"I have a kid on the way."],[9687,9737,"Do you think"],[9737,9837,"that you can just give Vanessa"],[9837,9970,"some space to cool off?"],[10050,10116,"Alright, there's"],[10170,10362,"this speed dating thing downtown."],[10425,10500,"Now get out."],[10537,10625,"Meet someone."],[10625,10712,"Have some fun."],[10812,10870,"Okay?"],[10875,10937,"Yeah."],[10937,11012,"Okay."]],"5":[[1483,1545,"Well."],[1595,1729,"How did I get so lucky?"],[1770,1933,"You are easily the hottest girl here."],[2120,2308,"Well, let's skip the small talk."],[2320,2408,"I want kids."],[2408,2508,"Minimum three."],[2554,2729,"I can't have children."],[3029,3258,"Sorry, but, uh, hard pass."],[4416,4504,"Hello, Bailey."],[4608,4820,"Mr. Pitt, what are you doing here?"],[4895,5033,"I finally get my date with you."],[5058,5145,"Thanks to your brother."],[5258,5358,"Danny set me up?"],[5620,5683,"Whoa!"],[5716,5895,"You really like playing hard to get,"],[5895,6004,"now, don't you, honey, huh?"],[6029,6158,"Let me be clear."],[6195,6320,"I'm not interested."],[6379,6470,"Never was."],[6570,6666,"Never will be."],[7541,7633,"You think you're too good for me?"],[7633,7695,"Is that it?"],[7733,7945,"Get your hands off of me."],[7945,8020,"Shh!"],[8183,8416,"No one's coming to save you, sugar."],[8491,8808,"Your own brother, he gave you to me."],[8858,8920,"Ouch!"],[8941,9116,"You fucking bitch!"],[9229,9333,"You want it hard?"],[9370,9470,"That's fine."],[9520,9645,"The rougher, the better."],[9670,9829,"Don't come any closer."],[9829,9895,"Oh, yeah?"],[9941,10008,"Or what?"],[10020,10216,"No one gives a damn about you."],[10233,10316,"Look around."],[10354,10558,"No one's coming to your rescue."],[10816,10983,"Get your filthy hands off of her."]],"6":[[312,412,"Mind your own business,"],[412,537,"construction boy."],[1783,1908,"Alright, I got you."],[2358,2525,"Thank you, Mr. Cain."],[2600,2700,"It's Mason."],[2862,2958,"You okay, Bailey?"],[3062,3150,"I am now."],[3400,3550,"Who the fuck are you?"],[3687,3770,"I'm her date."],[3795,3900,"Oh, yeah?"],[3950,4050,"She got into the part"],[4050,4200,"where she's sterile, huh?"],[4245,4312,"That's right."],[4383,4462,"No kids."],[4512,4612,"No future."],[4625,4712,"Look at you."],[4737,4825,"You're young."],[4825,4975,"Take it from me, you don't want her."],[5000,5150,"She's damaged goods."],[5408,5575,"The only damaged goods here is you."],[5787,5937,"And if you come near her again,"],[6008,6145,"I'll kick you in the mouth and make you"],[6145,6250,"swallow your teeth."],[6900,6975,"Let's get out of here."]],"7":[[808,920,"I thought we were getting coffee."],[958,1087,"Hey, my kid swears that"],[1087,1312,"a rainbow sprinkle fixes everything."],[1337,1445,"No one's ever taken me"],[1445,1537,"for ice cream before."],[1570,1758,"Not even a boyfriend?"],[1850,2058,"I haven't dated all that much."],[2137,2245,"It was my brother's idea"],[2245,2337,"to go speed dating."],[2437,2562,"Now I know it was a setup."],[2745,2887,"I'm sorry, Bailey."],[2950,3083,"After my parents died,"],[3100,3220,"Danny was all I had."],[3387,3433,"He took me in"],[3433,3587,"after he aged out of foster care."],[3708,3875,"Most people with her past"],[3875,3987,"would turn bitter."],[4070,4158,"She didn't."],[5633,5870,"I have to be at work very early."],[5970,6112,"I'm a janitor."],[6175,6312,"I know, Bailey."],[6562,6637,"It's just,"],[6712,6883,"people aren't usually this nice to me."],[7000,7100,"Then they're idiots."],[7175,7254,"He's so sweet."],[7254,7420,"How is this man so kind to me?"]],"8":[[1037,1279,"God, he's so handsome."],[1366,1529,"God, she's beautiful."],[1679,2041,"Look, I'm not great at asking for help,"],[2041,2216,"but I'm out of options."],[2279,2466,"I need someone to be Hannah's mother"],[2466,2554,"or I could lose"],[2554,2679,"the upcoming custody battle"],[2679,2779,"with my ex-wife."],[2854,2966,"Why do you have sole custody?"],[3066,3229,"Clarice never wanted to be a mother."],[3229,3354,"Hannah was my idea."],[3391,3512,"Now she figures my daughter"],[3512,3816,"is her ticket to getting more money."],[3879,4079,"But you're a construction worker."],[4129,4262,"Paying extra child support, it's,"],[4300,4379,"it's crazy."],[4425,4529,"And you don't mind"],[4529,4754,"if I'm just a construction worker?"],[4912,5100,"No, of course not."],[5204,5500,"In that case, Bailey, would you marry me"],[5579,5691,"and be Hannah's mother?"],[5916,6029,"Have you ever wanted something"],[6029,6154,"so badly"],[6154,6266,"that you'd walk away?"],[6391,6591,"Because the loss of it would destroy you?"],[6816,6879,"I have to go."],[6904,6979,"Bailey!"],[7016,7254,"I get that I'm a nobody to you,"],[7254,7400,"but that doesn't give you the right"],[7400,7454,"to play me."],[7454,7554,"I'm not."],[7566,7691,"I want to marry you."],[7729,7816,"Don't lie."],[7829,7912,"I hate that."],[7954,8029,"I've been surrounded"],[8029,8200,"by liars my entire life."],[8200,8379,"Bailey, you can be a mother."],[8491,8566,"Oh my God."],[8629,8800,"This is because you heard I'm sterile."],[8850,8887,"Um."],[8900,9104,"Will you just hear me out, please?"],[9104,9166,"No."],[9229,9354,"You don't get to do this."],[9429,9554,"I have a life."],[9637,9854,"It isn't perfect, but it's mine."],[9941,10041,"What you want,"],[10075,10166,"if it isn't real,"],[10229,10341,"then I can't survive that."],[10412,10487,"Bailey, can I-"],[10900,10962,"Wait."],[11016,11195,"I'm being thrown out?"]],"9":[[62,120,"Danny."],[137,295,"What the hell are you doing"],[295,370,"to my shit?"],[404,570,"Danny, what have you done?"],[758,912,"Leave, Bailey."],[987,1070,"We warned you."],[1170,1320,"The lease is in my name."],[1337,1537,"You can't throw me out of my own place."],[1537,1737,"Oh, you did it to yourself, bitch."],[1737,1987,"Mr. Pitt is my boss."],[2012,2145,"What did you think would happen"],[2145,2258,"when you humiliate him?"],[2320,2520,"He tried to rape me."],[2650,2983,"Bailey, Mr. Pitt is rich as fuck,"],[2983,3083,"and Danny was gonna"],[3083,3175,"get a promotion."],[3200,3300,"All you had to do"],[3300,3462,"was let him spoil you"],[3462,3587,"and sleep with you."],[3587,3737,"And that was it."],[3737,3833,"Look where you ended up,"],[3833,4000,"back in the fucking gutter."],[4025,4133,"You know what, Danny?"],[4150,4358,"The high school reunion is next week."],[4358,4487,"And we still have to fill in"],[4487,4637,"an RSVP for Bailey."],[4687,4862,"What should we put next to her name?"],[4900,4987,"Homeless?"],[5220,5333,"Come on, Danny."],[5333,5470,"Fuck you, bitch."],[5737,5862,"Danny, you bitch!"],[6025,6087,"No!"]],"10":[[425,600,"All we could recover from your file"],[600,700,"was this."],[1241,1425,"This is all I have left of you,"],[1425,1550,"and I almost lost it."],[1550,1783,"I'm sorry, baby girl, wherever you are."],[2137,2212,"You okay?"],[2350,2433,"Look around you."],[2525,2687,"My life is a disaster."],[2737,2800,"You don't want to be"],[2800,2912,"dragged into my mess."],[3033,3225,"Look, I get that you think you're broken."],[3258,3375,"Mason, please."],[3400,3508,"Just walk away."],[3595,3795,"When Hannah was 18 months old,"],[3812,3950,"Clarice left her in the car"],[3950,4120,"for over an hour to get a pedicure."],[4170,4375,"My daughter almost died in the heat."],[4583,4712,"We're all broken."],[4775,4862,"I need you."],[4925,5045,"Hannah needs you."],[5137,5237,"Say yes."]],"11":[[1141,1241,"Miss Addams"],[1366,1579,"and Mr. Cain?"],[1587,1754,"As in Mason Cain,"],[1754,1966,"CEO of Apex Building Corp?"],[2012,2162,"Is there an issue, ma'am?"],[2416,2516,"Yeah, right."],[2516,2641,"No way this guy"],[2641,2841,"is the richest man in the country."],[2958,3016,"Nope."],[3062,3141,"Not at all."],[3650,3887,"You are officially husband and wife."],[4766,4929,"Roger, I don't want to overwhelm Bailey"],[4929,5041,"that I'm a billionaire."],[5041,5191,"Find me a modest apartment."],[5191,5241,"Fast."],[5716,5829,"I know it's not exactly"],[5829,5975,"the lap of luxury."],[5991,6254,"Mason, this is where you and Hannah live?"],[6316,6491,"Roger, you son of a bitch."],[6537,6750,"I said modest, not a freakin' dump."],[6854,6987,"Yeah, sorry."],[6987,7112,"It's just, it's temporary"],[7112,7266,"until I find us something better."],[7266,7441,"No, I didn't mean it like that."],[7479,7575,"We're in this together."],[7591,7741,"And it's pretty big,"],[7779,7916,"lots of natural light."],[7916,8041,"Plus, I'm a professional cleaner,"],[8041,8216,"so I'll have this place in shape"],[8216,8275,"in no time."],[8275,8454,"No cleaning on our wedding day."],[8466,8558,"I'm taking you and Hannah"],[8558,8641,"out to dinner."],[8641,8750,"You don't have to."],[8762,8841,"I want to."],[9141,9300,"I got you this dress."],[10166,10304,"It reminded me of you."],[10316,10491,"Sweet, but with hidden depths."],[10516,10616,"Oh, Mason,"],[10616,10754,"I didn't get you a wedding gift."],[10775,10941,"You're my gift, Bailey."],[11750,11829,"Mommy!"],[12241,12466,"You give me the best hugs."],[12466,12591,"Then I'll make sure to give you one"],[12591,12666,"every day."],[12800,12887,"Daddy,"],[12887,13129,"can we go back to our real home?"]],"12":[[29,108,"Daddy,"],[108,345,"can we go back to our real home?"],[520,645,"Bailey, why don't you"],[645,745,"make yourself at home?"],[745,858,"I'm just gonna have a quick word"],[858,958,"with my co-pilot."],[1379,1558,"This is your room now, Banana."],[1620,1804,"Why can't I have my old one?"],[1858,2079,"Because Bailey needs to"],[2079,2208,"get to know us first."],[2208,2383,"And we need to get to know her."],[2420,2533,"If she really is the Mom"],[2533,2620,"that you deserve,"],[2620,2808,"I need to know that she wants us for us."],[2808,2970,"Not the cars, or the mansion,"],[2970,3083,"or the bank account."],[3095,3195,"Just you and me."],[3245,3433,"But Bailey's not a gold digger"],[3433,3608,"like my bad Mommy."],[3645,3829,"Where did you learn that word?"],[3854,3991,"Mrs. Flannigan."],[4004,4216,"She calls all of your dates that."],[4270,4408,"Well, Bailey doesn't seem like"],[4408,4558,"a gold digger."],[4579,4695,"But wouldn't it be nice"],[4695,4808,"if we knew for sure"],[4808,4966,"that she liked us for us?"],[5008,5145,"She already does."],[5145,5370,"She gave me a real Mom hug."],[5370,5520,"I love her, Daddy."],[5558,5683,"Look, it won't be for long."],[5741,5820,"Just help me out."],[5883,5970,"Secret for now."],[5970,6070,"Pinky promise?"],[6170,6295,"Pinky promise."],[6345,6429,"Lock it."],[7020,7116,"Bailey, are you ready?"],[7808,7916,"I was just gonna"],[7916,8020,"grab my clothes over here."]],"13":[[770,841,"Mommy!"],[841,908,"Daddy!"],[908,1020,"I'm hungry!"],[1154,1379,"Wow, you look so magical, Hannah."],[1379,1458,"I know."],[1458,1529,"Look."],[1691,1833,"Daddy helped me find this"],[1833,2016,"on the Mommy and Me Styles"],[2016,2095,"from SHEIN."],[2129,2266,"We can wear it together."],[2341,2408,"I see."],[2508,2745,"Mason, that's so sweet."],[2808,2970,"The dinner reservation's at 7,"],[2970,3095,"so you girls should get ready."],[3095,3220,"Daddy, out."],[3220,3333,"No boys allowed."],[3333,3395,"Okay."],[3429,3495,"Okay."],[3533,3616,"So bossy."],[3933,4100,"They look so alike."],[4116,4237,"You'd think Bailey was"],[4237,4337,"Hannah's mother."],[4695,4816,"I'll go change."],[5270,5416,"What is this stuff?"],[5658,5883,"10-15-1-9?"],[5970,6145,"Mommy, what's this number?"],[6183,6404,"Oh, that's just my baby girl's birthday."],[6458,6683,"October 15, 2019."],[6783,6933,"That's my birthday, too."],[7083,7304,"Wait, what did you just say, Hannah?"]],"14":[[4,154,"That's my birthday, too."],[312,516,"Wait, what did you just say, Hannah?"],[554,741,"Well, maybe I got some numbers"],[741,916,"and months mixed up."],[966,1250,"But in here, you're my real Mommy."],[1337,1491,"And that's all that matters."],[1537,1641,"I need to stop hoping"],[1641,1716,"I'll find my daughter"],[1716,1854,"in every little girl I meet."],[1916,2029,"Hannah is my daughter now."],[2079,2237,"I can make a difference in her life."],[2254,2316,"Let's go."],[2316,2504,"Daddy's waiting for us."],[4354,4454,"Is everything okay?"],[4625,4800,"This place is crazy expensive."],[4841,4987,"Are you sure you meant to come here?"],[5041,5162,"It's a special day."],[5291,5429,"It deserves a special place."],[5541,5691,"Do I hear a yes, Banana?"],[5704,5779,"Yes."],[5800,5866,"Yeah!"],[6025,6254,"Mr. Cain, what a wonderful surprise."],[6337,6429,"High five, Princess."],[6579,6654,"And this is?"],[6866,6929,"My wife."],[7154,7241,"And my Mommy."]],"15":[[100,200,"Mr. Cain, in honor of"],[200,320,"your recent nuptials."],[337,437,"Thank you, Henri."],[495,658,"We'll have the chef's tasting menu."],[658,837,"No raspberries or shellfish."],[837,920,"Hannah's allergic."],[1070,1150,"What about you, Bailey?"],[1150,1350,"Any allergies I should know about?"],[1708,1750,"Excellent."],[1750,1825,"Mr. and Mrs. Cain,"],[1825,1920,"dinner will be out shortly."],[1920,1983,"Thank you."],[2633,2700,"What's wrong?"],[2787,2925,"You remember her allergies?"],[2975,3033,"Of course."],[3120,3200,"I had a lot of allergies"],[3200,3300,"growing up too,"],[3300,3475,"but no one remembered."],[3575,3670,"You're exactly"],[3670,3820,"what I dreamed a Dad would be."],[3887,3950,"Caring."],[4000,4075,"Honest."],[4195,4308,"Proof that there are really"],[4308,4425,"good men in this world."],[4470,4662,"That is the nicest thing"],[4662,4900,"anyone has ever said to me."],[5083,5145,"Wow."],[5300,5558,"Chateau Margot."],[5575,5737,"What's the occasion, Mason?"],[5862,5987,"A pity party?"],[5987,6070,"You're breaking"],[6070,6250,"the restraining order, Clarice."],[6250,6337,"Leave."],[6558,6820,"This is who you traded me for?"],[6837,6970,"A school janitor?"]],"16":[[4,250,"This is who you traded me for?"],[279,412,"A school janitor?"],[491,629,"Security is already on their way."],[962,1029,"Honey,"],[1150,1475,"this woman is not your real mother."],[1504,1591,"I am."],[1641,1762,"She doesn't even really"],[1762,1891,"care about you."],[2050,2379,"She's just using you to get to your Daddy."],[2437,2625,"And then she'll toss you aside"],[2625,2762,"like everyone else."],[2987,3100,"You touch her again,"],[3100,3275,"and I swear you will regret it."],[3462,3591,"How dare you hurt her"],[3591,3775,"with your stupid games."],[4129,4362,"You know, matching hairstyles"],[4400,4479,"doesn't make you"],[4479,4637,"Hannah's real mother."],[4704,4916,"It just makes you pathetic."],[5012,5212,"You'll always be the help,"],[5291,5479,"no matter how hard you try"],[5479,5600,"and play house."]],"17":[[83,245,"Leave my Mommy alone."],[320,454,"Back off."],[795,958,"This isn't over, Mason."],[958,1066,"It is for you."],[1345,1545,"Don't touch me."],[1633,1695,"Let's go."],[2570,2679,"Are you okay, Banana?"],[2766,2983,"Are you gonna dump me too, Mommy?"],[3008,3145,"Oh, sweetheart."],[3204,3266,"Never."],[3320,3466,"Not in a million years."],[3520,3620,"You're my daughter now."],[3654,3758,"No take backs."],[3808,3966,"Can I go home, Daddy?"],[4308,4370,"Yeah."],[4458,4533,"Let's go home."],[4579,4691,"We'll get some ice cream"],[4691,4770,"on the way, okay?"],[4770,4845,"Thank you."]],"18":[[87,245,"And the little lion looked up,"],[275,375,"and there was mommy,"],[375,495,"who had been searching for her"],[495,562,"all along."],[600,837,"And they all lived happily ever after."],[1433,1570,"She's no gold digger."],[1662,1825,"I need to tell Bailey who I am"],[1862,1975,"before I lose the best thing"],[1975,2125,"that's ever happened to Hannah and me."],[2912,3033,"Has anyone ever told you that"],[3033,3175,"you're a natural with kids?"],[3175,3283,"I love kids."],[3283,3362,"I always have."],[3783,3850,"What is it?"],[3950,4037,"Remember that creep"],[4037,4108,"that you decked?"],[4287,4375,"What he said."],[4570,4675,"She got into the part"],[4675,4825,"where she's sterile, huh?"],[4908,4962,"It's true."],[5037,5137,"I can't have children."],[5233,5287,"I'm sorry."],[5287,5345,"You probably wish"],[5345,5425,"you didn't marry me now."],[5425,5487,"Bailey."],[5620,5712,"You're my wife."],[5900,6050,"In sickness and in health."]],"19":[[275,462,"Sorry, it's too soon."],[2712,2887,"When I saw you in that purple dress,"],[2887,3020,"my heart skipped a beat."],[3145,3387,"You are so beautiful, Bailey."],[4600,4762,"I can't stop kissing you."],[4962,5137,"I've never felt this way before."],[5275,5445,"Bailey, is this your first time?"]],"20":[[0,183,"Bailey, is this your first time?"],[350,525,"If I tell you, you'll stop."],[737,900,"Not because I want to."],[937,1012,"Believe me."],[1175,1237,"We should talk."],[1237,1312,"There's something"],[1312,1437,"that I need to tell you."],[2400,2445,"It's work."],[2445,2545,"I have to get this."],[2875,3025,"Principal Davis, is something wrong?"],[3325,3400,"Wait, really?"],[3508,3670,"Yes, I'd love to."],[3712,3783,"Thank you."],[3850,3962,"Thank you so much."],[4100,4237,"I'm subbing on Monday."],[4275,4383,"I'm gonna be a teacher."],[4420,4600,"I'm so happy for you, Bailey."],[4662,4825,"Ever since I met you and Hannah,"],[4825,5020,"it's like my luck has finally changed."],[6125,6237,"Me too, Bailey."],[6312,6375,"Me too."],[6654,6829,"I gotta get ready for tomorrow."]],"21":[[550,754,"Bailey, I should have told you this"],[854,983,"when we first met, but..."],[1154,1375,"I'm the CEO of Apex Building Group."],[1516,1604,"Look, I didn't tell you"],[1604,1741,"because I've dealt with so many women"],[1741,1925,"who want the billionaire"],[1925,2029,"but not the real me,"],[2029,2250,"and I've learned to"],[2250,2366,"protect Hannah from that."],[2412,2554,"But you didn't care about any of it."],[2554,2862,"You cared about her and me"],[2862,3041,"and suddenly the lie felt even worse"],[3041,3179,"because I was terrified"],[3179,3329,"that you'd hate me"],[3329,3462,"for keeping the truth from you."],[3679,3841,"I never meant to trick you, Bailey."],[4016,4066,"I just,"],[4229,4404,"I want a real shot at this."],[4512,4579,"At us."],[4675,4962,"Mason, I forgive you."],[5079,5216,"Now shut up and kiss me."],[5216,5245,"Okay."],[5270,5300,"Just-"],[5300,5454,"Alright, get out of my truck."]],"22":[[2487,2637,"Bailey, you did all of this?"],[2675,2825,"I just want this place to feel cozy."],[2825,2937,"Especially for Hannah."],[2975,3225,"This is amazing but you're not a maid."],[3262,3345,"You're my wife."],[3383,3487,"And you look like you've been"],[3487,3675,"wrestling cement trucks all day."],[4108,4212,"Drink up before you pass out"],[4212,4312,"from dehydration."],[5237,5383,"How did I get so lucky?"],[5562,5675,"I'm gonna go get cleaned up."],[5700,5775,"I'll go make tea."]],"23":[[887,995,"So where's my new brother-in-law?"],[1333,1441,"Wow, Bailey."],[1441,1500,"You managed"],[1500,1625,"to find someone"],[1625,1845,"even more destitute than you."],[1995,2087,"What are you doing here?"],[2125,2270,"Getting what you owe us."],[2375,2537,"I paid the rent on the house."],[2562,2700,"I don't owe you anything."],[2700,2775,"Wrong."],[2820,3125,"Sis, you cost me"],[3125,3287,"a major promotion at work"],[3308,3462,"by not going out with Mr. Pitt."],[3550,3625,"There has to be"],[3625,3762,"something valuable around here"],[3762,4112,"because you owe me three grand."],[4137,4200,"Now!"],[4320,4462,"I don't have much time left."],[4516,4637,"You've been gambling again,"],[4670,4737,"haven't you?"],[4920,5037,"Someone's coming after you."],[5037