5,"with this stolen black card."],[458,683,"So this is how Chez Collette"],[683,770,"treats its customers?"],[770,904,"No, no, no, mon dieu."],[904,1045,"A thousand apologies."],[1058,1233,"Please, pick anything you want."],[1270,1358,"It's on the house."],[1608,1741,"Wait, really?"],[1833,1904,"Oui, ma chérie."],[1991,2095,"You would look ravissante"],[2095,2220,"in every dress here."],[2258,2320,"Wow."],[2370,2508,"He must owe you big time."],[2533,2745,"Yeah, something like that."],[2870,2929,"Come on."],[3133,3208,"Madame. - Madame."],[3279,3408,"Who is that guy? - Who is that guy?"],[3433,3666,"That was Mr. Mason Cain, you idiots!"],[3720,3845,"He owns the whole building."],[3891,4008,"We could be evicted."],[4058,4183,"You are fired."],[4183,4245,"Out."],[4433,4529,"The both of you."],[5358,5445,"So, what do you think?"],[5729,5829,"I still like the other one."],[6070,6158,"We'll take that one."],[6395,6466,"It's beautiful."]],"32":[[891,954,"Mason,"],[1033,1145,"what are you still doing here?"],[1245,1333,"I thought you were going to Bailey's"],[1333,1441,"high school reunion tonight."],[1458,1533,"Yeah, I am."],[1616,1770,"And afterward, I'm"],[1795,1983,"telling her that I'm a billionaire."],[2137,2187,"Okay."],[2233,2383,"Look, I know that she doesn't"],[2383,2558,"care about any of this, but..."],[2741,2841,"I want to spoil her."],[2866,2979,"Shit, man."],[3029,3170,"I've never seen you like this."],[3204,3329,"You got it bad for her, don't you?"],[3345,3541,"She's not like other women, Roger."],[3595,3695,"For the first time in my life,"],[3695,3891,"I feel like I'm loved for who I am,"],[3904,3995,"not what I own."],[4033,4104,"And the way that"],[4104,4220,"she connects with Hannah..."],[4270,4329,"It's more than"],[4329,4433,"I could have ever hoped for."],[4570,4695,"I don't know how she's going to take it,"],[4695,4837,"but I can't keep this from her anymore."],[5045,5195,"Stella, send a car for Bailey."],[5195,5308,"Nothing too flashy."],[5366,5470