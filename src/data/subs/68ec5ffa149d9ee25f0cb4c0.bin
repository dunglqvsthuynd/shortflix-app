],[1170,1270,"why I didn't want to involve you"],[1270,1391,"in my messed up family."],[1570,1729,"Why does he treat you like that?"],[1816,1891,"He took me in."],[2004,2158,"After what my foster mom did,"],[2158,2245,"he took care of me."],[2320,2629,"She was actually evil."],[2770,2908,"What did she do, Bailey?"],[3133,3258,"When I was 16,"],[3304,3458,"my foster mom had my eggs"],[3458,3554,"illegally harvested"],[3554,3683,"and sold on the black market."],[4020,4170,"The procedure left me infertile."]],"27":[[533,645,"That's awful, Bailey."],[795,883,"I couldn't go back there,"],[883,1054,"so he took me in."],[1170,1316,"He was only 18"],[1316,1445,"and didn't want his kid sister around,"],[1445,1508,"but,"],[1645,1733,"he did it anyway."],[2016,2145,"I get why you defend him."],[2145,2345,"You guys were raised by someone horrible."],[2516,2683,"But that's not an excuse."],[2870,2995,"Look how you turned out."],[3241,3366,"You're the first person"],[3366,3570,"I feel safe completely trusting."],[4170,4254,"How about you and I"],[4254,4404,"go shopping for a dress"],[4404,4508,"for this reunion tomorrow?"],[4645,4729,"I'm not going."]],"28":[[1495,1716,"Mason, I don't need a dress."],[1783,2016,"I haven't seen these people in five years."],[2129,2295,"Besides, this place"],[2295,2416,"looks pretty expensive."],[2545,2733,"Nothing is too good for my wife."],[2770,2995,"Mason, I know who I married."],[3045,3191,"I don't care that you can't afford"],[3191,3316,"expensive dresses."],[3466,3658,"I want to give Bailey the world."],[3733,3945,"How do I tell her who I really am?"],[4020,4191,"At least try something on, yeah?"],[4333,4454,"Can I help you with something?"],[4541,4729,"Yeah, we'd like to see your best dresses."],[4858,5045,"We don't donate to charities."],[5070,5241,"Goodwill is just down the street."],[5283,5358,"It's okay."],[5404,5470,"Let's just go."],[5470,5533,"No."],[5583,5708,"No, it's not okay."],[5758,5970,"And we will see some dresses today."],[5