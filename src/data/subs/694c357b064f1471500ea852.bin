{"1":[[16,166,"Mother used to say,"],[166,333,"have faith in the Gods."],[417,554,"And I believed her."],[579,650,"Please stop."],[671,775,"Until that night."],[775,863,"I know... - No!"],[909,1013,"you fucked him."],[1034,1192,"Now you will pay the price."],[1213,1322,"It was a mistake."],[1363,1501,"I didn't know he was Zeus."],[1639,1755,"Is that a Goddess?"],[1906,2052,"What is she doing to Mother?"],[2260,2552,"Did you give birth to Zeus' child?"],[2590,2644,"No."],[2660,2786,"Liar!"],[2998,3098,"Finish her off."],[3157,3303,"Then search the house."],[3495,3636,"No, please."],[4024,4074,"No."],[4112,4158,"No."],[4175,4220,"No."],[5367,5622,"I want Zeus' bastards dead."],[5684,6014,"Every last one of them."],[8274,8450,"I was Hera's blade."],[8587,8700,"Then I saw her."],[9004,9075,"I'm sorry."],[9113,9271,"And for the first time,"],[9271,9359,"I disobeyed."],[10435,10556,"No!"],[10752,10919,"Mother used to always say,"],[10948,11086,"have faith in the Gods."],[11156,11448,"I say, fuck the Gods."]],"2":[[37,183,"You have until sunset"],[237,450,"to bring in some fresh kill for dinner."],[533,613,"Otherwise,"],[738,938,"I just might have to sell her next."],[1176,1418,"The Gods bring me nothing but misery."],[1468,1634,"So the only thing that I have faith in"],[1710,1805,"is myself."],[2110,2339,"If we don't get Zeus' lamb back,"],[2339,2473,"we're all dead."],[2706,2819,"That's why you're here, champ."],[2848,3003,"No tracker or God more reliable"],[3003,3132,"than Hera's dog."],[3303,3390,"Faster than me."],[3470,3541,"Impressive."],[4104,4175,"Someone shot him."],[4375,4471,"The lamb."],[4788,4854,"Step away."],[4984,5155,"Drop your weapon and turn around."]],"3":[[246,325,"No, please."],[325,412,"Please, no."],[696,796,"There goes the lamb."],[825,930,"I'm going to bring it to Apollo,"],[930,1009,"see if he can heal it."],[1042,1151,"Kai, cool it."],[1151,1263,"You're scaring the poor girl."],[1989,2081,"I'm Kairos,"],[2118,2239,"immortal Champion of Olympus."],[2239,2289,"And you've-"],[2289,2444,"I know who you are."],[2444,2610,"I find that hard to believe."],[2673,2827,"I do not show myself to mortals."],[2827,2927,"Don't come any closer."],[2927,3078,"How did you kill the lamb?"],[3148,3257,"Mortal humans shouldn't be able"],[3257,3361,"to kill divine creatures."],[3361,3516,"I said stay away."],[3516,3682,"I'm bringing you back to Olympus."],[3737,3870,"You will face the judgment of Zeus"],[3870,3999,"for harming his sacred lamb."],[3999,4329,"You took everything from me."],[5426,5680,"I don't know who you are."],[5864,6047,"You killed my mother."]],"4":[[16,83,"Who is she?"],[145,246,"She can't be human."],[346,467,"Not even a sorry?"],[792,925,"I won't apologize for something"],[925,1021,"I don't remember doing."],[1021,1176,"You are a monster!"],[1388,1514,"Are you going to kill me?"],[1614,1751,"Kill me like you killed my mom,"],[1751,1847,"like we are nothing?"],[1847,2018,"That's what we all are."],[2072,2210,"Under the wrath of the Gods,"],[2243,2318,"we're nothing."],[2556,2882,"Aria and Kairos, you are fated."],[2882,3136,"Love will shatter your curse,"],[3136,3495,"and together, you will set each other free."],[3999,4062,"Who are you?"]],"5":[[25,91,"Who are you?"],[225,367,"No, let me go."],[492,600,"The Three Sisters of Fate"],[629,721,"showed me something,"],[742,817,"a prophecy."],[888,1017,"I'm taking you back to Olympus."],[1030,1142,"Screw your prophecy."],[1142,1280,"I won't let you kill me."],[1288,1388,"The Fates are never wrong."],[1430,1564,"This human girl is the only one"],[1564,1676,"who can set me free."],[1722,1868,"I won't kill you."],[1931,2035,"You'll be under my protection."],[2056,2147,"Protection?"],[2223,2348,"You mean imprisonment."],[2356,2527,"Would you rather die?"],[2569,2644,"If I don't come back,"],[2644,2773,"Serina is going to be all alone"],[2773,2861,"with Cletus."],[2919,3123,"If a prophecy distracts him again,"],[3161,3311,"I might be able to kill him."],[3353,3490,"This is my one chance"],[3490,3616,"to avenge my mother."],[3649,3807,"He is the reason why she's gone."],[3820,3962,"It's all his fault."],[3962,4016,"Fine."],[4141,4233,"But I need to say bye"],[4233,4358,"to my sister first."],[4508,4571,"Remember,"],[4571,4713,"hide everything from Cletus"],[4713,4871,"and just stay out of his way, okay?"],[4888,5005,"You're going to leave me alone?"],[5084,5146,"Forever?"],[5313,5476,"I need to go with that man."],[5559,5759,"But I promise you that I will be back."],[5759,5830,"I swear."],[5843,6031,"You can't leave me alone with father."],[6047,6151,"He said he'll sell me."],[6493,6552,"You're lucky,"],[6644,6781,"that I didn't toss you out of here"],[6844,7052,"when your whore of a mother died."],[7052,7286,"I'm sorry, but I have to go."],[7928,8091,"She's Eurydice's child."],[8120,8204,"The one I spared."],[8212,8308,"She's Zeus' daughter."]],"6":[[350,433,"What the fuck?"],[483,571,"Who the hell are you?"],[746,859,"You are a scum."],[888,988,"The worst of the humans."],[988,1126,"You got the wrong guy, pal, okay?"],[1142,1201,"Please."],[1276,1393,"I have two young daughters."],[1393,1518,"Whom you exploit"],[1518,1659,"and treat like objects."],[1680,1818,"You plan to live off the older one,"],[1839,1931,"sell the younger one."],[1931,2160,"What is it to you, asshole?"],[2202,2298,"If it wasn't for me,"],[2327,2448,"if I didn't kill their mother,"],[2519,2681,"they wouldn't end up with this animal."],[2719,2961,"Your daughters are under my protection."],[3011,3286,"And if you, no better than a pig,"],[3345,3574,"even lays a fucking hand on them,"],[3582,3749,"I will kill you myself."],[4037,4129,"What are you doing?"]],"7":[[0,87,"What are you doing?"],[125,191,"He hurt you."],[229,279,"Yeah."],[316,412,"Well, why do you care?"],[412,575,"Because what he did was wrong."],[613,742,"And killing my mom was right?"],[746,834,"I didn't have a choice."],[834,942,"You're a God."],[984,1121,"Gods have choices."],[1134,1213,"I'm not a God."],[1443,1547,"Your sister will be safe."],[1609,1760,"He's not at all who I thought he'd be."],[1960,2002,"What,"],[2060,2177,"what the hell is this?"],[2202,2285,"You tried to kill me."],[3474,3611,"This forest is a barrier"],[3657,3887,"for the wild beast and damned souls"],[3891,4087,"meant to keep mortals out."],[4087,4279,"And by out, I mean dead."],[4316,4521,"So keep close and do as I say."],[4587,4738,"This might be my only chance."],[4825,5013,"I'll always keep you safe."],[5271,5372,"Aria."]],"8":[[325,412,"Come on, come on!"],[521,575,"What are you-"],[871,967,"Aria, come back!"],[2573,2660,"Shit."],[2844,2894,"Shit."],[3032,3128,"Souls of the damned."]],"9":[[867,946,"Kairos!"],[2631,2727,"You saved me?"],[2815,2990,"Oh my God, you're poisoned."],[2994,3123,"Just leave him to die, Aria."],[3144,3228,"It's what you wanted."],[3228,3324,"He's a monster."],[3382,3586,"A monster who saved your life."],[3607,3841,"After you tried to kill him twice."],[3870,3941,"No, Aria."],[3945,4066,"Fuck the Gods."],[4166,4237,"Aria."],[4416,4596,"Don't leave, it's not safe."],[4621,4846,"If he really is a heartless immortal,"],[4846,5067,"then, why is he dying"],[5067,5321,"and why did he risk his life for me?"]],"10":[[975,1067,"Blood of the undead."],[1101,1197,"He's infected."],[1209,1288,"Oh Gods."],[1288,1413,"Why did I save him?"],[1493,1576,"The only way to cleanse"],[1576,1680,"a living body of the undead"],[1680,1864,"is to fill it with life."],[2673,2890,"Blood of life, into the dead"],[2890,3003,"bind my soul and flesh to his."],[4320,4446,"What are you, Kairos?"],[4462,4775,"He killed my mother, but he saved my life."],[4842,4938,"He's ice-cold."],[5025,5209,"He won't make it if I don't warm him up."],[8383,8512,"Did you try to seduce me?"]],"11":[[29,120,"Seduce you?"],[187,283,"I saved you."],[404,504,"Stop looking."],[583,688,"Why did you save me?"],[696,788,"You could have let me die."],[867,967,"It was your one chance."],[967,1146,"Yeah, well, I thought Gods can't die."],[1201,1363,"They definitely don't get infected."],[1368,1493,"I never said I was a God."],[1509,1593,"What are you then?"],[1634,1676,"Huh?"],[1697,1776,"Their servant?"],[1789,2039,"I am a Champion of Olympus."],[2052,2227,"That's not what your tattoo says."],[2281,2394,"I've seen this symbol."],[2452,2623,"It's for criminals and slaves."],[2660,2890,"Careful what you say next, Aria."],[2902,3011,"How do you know my name?"],[3178,3374,"I asked you what you are,"],[3399,3553,"and how you know my name."],[3653,3766,"Do you understand how fucked up"],[3766,3845,"all of this is?"],[3883,4024,"You killed my mom when I was ten."],[4024,4154,"And I don't even get to know why?"],[4195,4329,"And then you show up here to,"],[4371,4517,"to kill me or not to kill me."],[4521,4671,"Yet you saved me."],[4729,4813,"I saved you"],[4813,4929,"because I couldn't have you dying"],[4929,5038,"to protect me."],[5142,5292,"Because I am human,"],[5351,5509,"I have a heart,"],[5618,5868,"unlike you, you heartless murderer."],[6147,6285,"I am not heartless."],[6389,6531,"You don't know the first thing about me."],[6564,6660,"You wanted to kill me?"],[6952,7002,"Do it."]],"12":[[0,241,"Killing him should be easy."],[333,658,"But all I can think of is his beating heart."],[658,925,"The same pulse that lives in me."],[925,1334,"Human, flawed, and so terribly fragile."],[1589,1772,"I didn't save you just to kill you."],[1981,2052,"Then it's true,"],[2135,2239,"humans are foolish."],[2360,2439,"I am?"],[2590,2806,"You took everything from me"],[2823,2911,"and I'm supposed to act like"],[2911,3003,"I don't hate you?"],[3098,3190,"Why did you do it?"],[3224,3278,"Huh?"],[3328,3440,"Why did you kill her?"],[3440,3511,"That was my mom."],[3511,3628,"She was all that I had!"],[3678,3803,"I didn't have a choice."],[3908,4195,"Stop saying that and explain yourself."],[4329,4425,"I can't, Aria."],[4521,4587,"I'm sorry."],[4637,4738,"She can't know yet."],[4821,4992,"Not until I can keep her safe from Hera"],[5100,5180,"and from me."],[5651,5726,"I thought that"],[5726,5905,"you were taking me to see Zeus."],[5905,5968,"No."],[5968,6093,"I'm taking you back to my place."],[6093,6164,"You'll be safer there"],[6164,6272,"until I can figure out what to,"],[6364,6448,"what to do with you."],[6548,6656,"Welcome to Camp Mythos."],[7578,7716,"Kairos, this is,"],[7857,7999,"this is beautiful."],[8158,8216,"Humans,"],[8233,8370,"even at a time like this,"],[8370,8462,"she can still find something"],[8462,8537,"to marvel at."],[8666,8829,"Well, well, well."],[8863,8958,"Looks like the champion"],[8958,9079,"brought home another stray."]],"13":[[25,196,"Daphne, this is Aria."],[233,304,"She's mortal,"],[408,633,"and temporarily under my protection."],[633,779,"What is a mortal doing here?"],[796,905,"Your protection?"],[942,1005,"But you promised"],[1005,1130,"you'd train me all week."],[1238,1413,"Ah, I'm Daphne."],[1672,1768,"You might know my mom."],[1826,1910,"Aphrodite?"],[1939,2168,"You know, Goddess of Love, Beauty,"],[2193,2293,"all that fun stuff."],[2302,2448,"So you're a Demi-God."],[2448,2585,"Well, duh."],[2585,2777,"This is a training camp for Demi-Gods,"],[2836,2932,"although most of them"],[2932,3040,"are half-nymphs,"],[3040,3203,"sons of warriors, you know,"],[3249,3361,"lowly creatures."],[3390,3549,"I'm one of the true purebreds,"],[3578,3687,"child of an Olympian."],[3753,3924,"Where are all Zeus' other children?"],[4141,4195,"What?"],[4279,4379,"Everyone knows"],[4379,4567,"that Zeus has Demi-God kids."],[4583,4796,"There are no more of Zeus' children left."],[4896,5075,"Kairos here had them all killed,"],[5088,5205,"per Lady Hera's word."],[5276,5367,"Isn't that right?"]],"14":[[392,467,"Bad news."],[496,600,"Zeus' lamb is dead."],[650,742,"The entire Olympus"],[742,829,"will come for the girl."],[863,934,"She still with you?"],[967,1021,"Fuck!"],[1109,1188,"I have to handle this."],[1213,1338,"Stay out of trouble until I'm back."],[1397,1551,"Daphne, show her around."],[1605,1680,"No more gossip."],[1730,1906,"Oh, of course."],[1947,2106,"Anything for you, Kairos."],[2193,2248,"Well,"],[2306,2364,"come on."],[2414,2606,"It's time for your initiation ceremony."],[2677,2786,"Initiation?"],[3219,3345,"Are you sure that"],[3370,3478,"this is the right place?"],[3478,3661,"Oh yeah, for sure."],[3661,3741,"Don't worry about it."],[3741,3816,"We're just gonna go over"],[3816,3908,"some rules of the camp."],[4158,4295,"Oh, rule number one,"],[4341,4529,"don't ever go past the border."],[4587,4646,"Don't wanna get eaten"],[4646,4804,"by those wild minotaurs."],[5013,5075,"Let's see."],[5146,5230,"Yeah, this one."],[5367,5434,"Perfect."],[5451,5580,"Um, isn't this that?"],[5580,5638,"Just,"],[5714,5830,"we just do what Daphne says."],[5910,6001,"Rule number two,"],[6047,6264,"train every day and train hard."],[6318,6398,"Trust me,"],[6435,6731,"people here can be so vicious."],[6752,6848,"And rule number three,"],[6923,7244,"don't ever touch what belongs to me!"]],"15":[[688,809,"That was River Styx water!"],[834,942,"That could've burned us all."],[942,1067,"Shut up."],[1326,1518,"That was a little lesson"],[1518,1639,"for stealing my man."],[1643,1726,"That murderer?"],[1726,1843,"You can have him."],[1901,2198,"He is the Champion of Olympus,"],[2214,2344,"Hera's right-hand man."],[2360,2619,"That the Fates made us for each other."],[2656,2777,"I saw the way you looked at him"],[2836,3082,"like you two have history."],[3094,3207,"But he will never"],[3274,3528,"be with someone as weak as you."],[3536,3599,"No!"],[4391,4621,"I'm not weak."],[7023,7194,"Crawl, little mortal."],[7749,7912,"Fuck the Gods."]],"16":[[1167,1247,"Kairos!"],[1368,1655,"What was that? Was it a prophecy?"],[2056,2152,"Where am I?"],[2431,2660,"He saved me again."],[3912,4287,"These names, are they who he killed?"],[4383,4496,"Eurydice."],[4496,4604,"Mom!"],[4954,5038,"What are you doing?"],[5372,5426,"Aria."],[5472,5584,"Stay away from me."],[5684,5734,"Aria."],[5734,5897,"You're a liar and a monster."],[5914,6018,"When have I lied to you?"],[6018,6106,"You said that you wanted"],[6106,6227,"to keep me safe."],[6289,6448,"Then you leave me with that witch."],[6464,6577,"You said you don't remember"],[6577,6677,"killing my mom but"],[6727,6940,"her name is in your disgusting"],[6940,7069,"book of killings."],[7244,7382,"Are you going to kill me too?"]],"17":[[8,145,"Are you going to kill me too?"],[221,329,"I could never hurt you."],[346,479,"You're making your injuries worse."],[546,675,"Like you even care."],[684,734,"I do."],[888,1009,"If you cared,"],[1009,1213,"then you would try to explain yourself."],[1213,1301,"Tell me,"],[1326,1384,"Kairos,"],[1384,1543,"why do you kill?"],[1576,1680,"Try and convince me"],[1680,1818,"you're not this monster."],[1818,1914,"And you'll just believe me?"],[2014,2198,"I saw something, Kairos."],[2264,2389,"Your bracers,"],[2452,2673,"and Hera, something happened."],[2706,2819,"Do not ask things"],[2819,2982,"you are not ready to know, child."],[2986,3094,"I'm not a child."],[3165,3449,"I am thousands of years old."],[3465,3536,"You're a mortal."],[3541,3749,"By the time you're nothing but ashes."],[3803,3899,"I will remain."],[3949,4229,"So yes, you are a child."],[4383,4479,"Now take off your shirt."]],"18":[[25,241,"I am not taking off my shirt."],[250,337,"I wasn't asking."],[1393,1522,"You need this ointment to heal."],[1647,1730,"Kairos."],[1735,1881,"It's nothing I haven't seen, Aria."],[1976,2127,"That was different."],[2227,2323,"Don't look."],[2364,2489,"I won't disrespect you."],[3199,3269,"Does that hurt?"],[3474,3541,"No."],[3841,3949,"Don't do that, Aria."],[4433,4491,"Just,"],[4621,4796,"when you touch me."],[4813,4942,"I can't think."],[4942,5046,"I can't think"],[5046,5259,"of anything else but this."],[5259,5334,"This one's deep."],[5384,5442,"Breathe."],[5889,5947,"Good girl."],[6464,6548,"All done."]],"19":[[20,154,"You can't do this."],[183,241,"Aria."],[296,658,"You can't kill my mother in cold blood"],[658,775,"and give me no explanation."],[775,984,"You can't just be this villain"],[984,1192,"and then show me that you are not."],[1197,1368,"You can't make me hate you"],[1413,1559,"and then touch me like that."],[1559,1605,"Aria."],[1605,1856,"You can't make me feel these things,"],[1968,2043,"about you,"],[2043,2139,"because they are wrong"],[2139,2389,"and they make me hate myself, Kai."],[2431,2485,"Aria."],[2485,2598,"If you say my name"],[2623,2706,"one more time,"],[2761,2848,"I'm gonna scream."],[2990,3174,"Will you stop crying"],[3174,3257,"if I tell you?"],[3403,3570,"My hands aren't my own"],[3603,3732,"for over a century."],[3820,3933,"I've been cursed."],[4024,4124,"These are my chains."],[4158,4216,"Hera."],[4245,4379,"They call me Hera's dog."],[4408,4496,"But I'm worse than that."],[4508,4608,"I'm her weapon."],[4704,4929,"She uses me,"],[5021,5080,"so she doesn't have to"],[5080,5192,"get her hands dirty."],[5213,5392,"So all the souls that she's killed,"],[5488,5555,"haunt me."],[5572,5689,"Is that what you wanted to hear?"],[5722,5843,"No, Kairos, I..."],[6264,6348,"I'm not a God."],[6452,6535,"But I can't die."],[6581,6744,"Cursed to live for eternity"],[6752,6886,"on Hera's terms,"],[6915,7002,"serving nothing"],[7048,7152,"and no one but her."],[7152,7269,"But what if you don't obey?"],[7290,7365,"I burn."],[7565,7912,"These bracers set my flesh on fire"],[7945,8045,"until I obey."],[8095,8287,"So you see, we're the same."],[8412,8729,"We're just toys, pawns for the Gods."],[8817,8933,"I'm so"],[8988,9121,"sorry, Kairos."]],"20":[[241,325,"Thirty-two."],[371,508,"You said thirty-five yesterday."],[558,709,"You hanging on to my every word?"],[734,817,"How could I not?"],[925,1005,"You own me."],[1247,1380,"Aria, my Goddess."],[1885,1964,"The Fates, they,"],[2072,2193,"they showed me a prophecy."],[2193,2264,"Our future?"],[2318,2398,"That's not."],[2473,2756,"You're not my future."],[2823,2894,"But it is."],[2936,3073,"You asked me why I saved you."],[3090,3228,"Because it's written by The Fates"],[3253,3411,"even though you despise me,"],[3511,3574,"even,"],[3682,3824,"even though I killed your mother."]],"21":[[2118,2235,"Are you still trying to kill me?"],[2423,2481,"If so,"],[2590,2660,"I'd do it now."],[3157,3207,"No,"],[3307,3482,"I still hate you."],[3607,3712,"Is that why you're shivering?"],[3778,3903,"Is that why you're so tense?"],[3962,4137,"Is that why your body's turning hard"],[4137,4225,"to my touch?"],[4475,4562,"Kai-kai."]],"22":[[29,104,"Kairos?"],[150,291,"Hermes is looking for you."],[304,371,"It's Daphne."],[396,550,"But I don't want her to see me here."],[700,750,"Quiet."],[763,817,"What?"],[1151,1209,"Kairos,"],[1338,1434,"what are you doing?"],[1543,1655,"What does it look like I'm doing?"],[1785,1868,"Hermes is here."],[1935,1985,"Let's go."],[2039,2114,"Give me a second."],[2139,2293,"So you can finish jerking off?"],[2406,2515,"That's not what I'm doing."],[2577,2698,"Hope you're thinking of me."],[3332,3470,"What the hell was that?"],[3495,3541,"Aria."],[3553,3628,"You let her think"],[3628,3845,"that you were thinking of her while-"],[3891,3983,"You seriously think"],[3983,4158,"I could think of anything else"],[4212,4333,"while you're lying on me like that?"],[4341,4508,"Then what were you thinking of, huh?"],[4542,4729,"I would love to tell you,"],[4871,4975,"but I have to go meet Hermes."],[5096,5155,"Get dressed."]],"23":[[633,779,"Hi, is this seat-"],[779,859,"Taken."],[884,1005,"Mortal trash."],[1259,1334,"Can I?"],[1376,1626,"Sorry, no sluts here."],[1939,2122,"You know, I saw Kairos"],[2122,2331,"carrying her back to his cabin."],[2364,2444,"No way."],[2473,2556,"You think the Champion"],[2556,2740,"of Olympus is fucking a human?"],[2752,2961,"He definitely fucked her."],[3015,3228,"Do you really think she's his type?"],[3236,3361,"I think he doesn't know"],[3361,3561,"who really runs this camp."],[3866,3941,"Hey, cutie."],[3999,4083,"Do me a favor."],[4229,4358,"See that girl over there?"]],"24":[[50,133,"That's what you get"],[133,262,"when you try to take a man"],[262,417,"from Aphrodite's daughter."],[458,525,"Look at her."],[525,721,"She looks like a drowning stray dog."],[942,1088,"Probably smells like one too."],[1380,1526,"Aria, hon."],[1539,1634,"Come sit with us."],[1689,1810,"Sit with you?"],[1847,2085,"You drowned me in River Styx water."],[2085,2193,"Aw, that was just"],[2193,2314,"a little misunderstanding."],[2652,2794,"Swear on Zeus, I didn't mean it."],[2986,3115,"Be a dear and give her your food."],[3528,3636,"You know how us girls get"],[3636,3778,"when we're a little boy-crazy."],[3862,3970,"But I know better now."],[3991,4241,"Kairos likes you, then I like you."],[4250,4371,"He doesn't like me."],[4517,4600,"Kai-kai told me"],[4600,4754,"to take care of his mortal pet,"],[4783,4867,"so I will."],[4892,5088,"Here, eat, you must be starving."]],"25":[[4,191,"So you think Aria's the key"],[191,308,"to breaking your curse?"],[321,408,"And that's why you haven't turned her"],[408,496,"in to Zeus yet?"],[521,638,"I don't know if I can trust you."],[650,763,"Come on, man."],[809,925,"I've known you for centuries."],[975,1051,"Exactly."],[1359,1493,"Oh my gosh."],[1534,1772,"She's so gullible, it's hilarious."],[1960,2131,"So this is a final warning,"],[2152,2364,"for your dense mortal brain."],[2402,2519,"Touch Kairos again,"],[2552,2660,"speak to him again,"],[2715,2857,"I will kill you,"],[2882,3048,"and nothing's going happen to me."],[3949,4141,"Kairos is mine."],[4208,4300,"Understand?"],[4362,4542,"Kairos is no one's."],[6835,6923,"This is what you get"],[6923,7069,"for stealing my man!"],[7382,7453,"Enough!"],[7474,7640,"What the hell's going on here?"]],"26":[[12,171,"What the hell's going on here?"],[538,613,"Kairos,"],[663,796,"we were just teaching Aria here"],[796,900,"a little lesson."],[930,1092,"What lesson might that be?"],[1259,1322,"Well,"],[1380,1564,"I'm the daughter of Aphrodite."],[1605,1739,"I'm a goddess."],[1801,1885,"Kairos here"],[1885,2118,"is Hera's right-hand man, an immortal."],[2160,2331,"We live forever."],[2431,2681,"You are human."],[2723,2911,"No better than a bug, really."],[3036,3194,"You're meant to be squashed."],[3244,3370,"Daphne, stop this"],[3370,3436,"now. - Kairos."],[3478,3536,"Don't."],[3536,3649,"I think that you should start"],[3649,3816,"begging for your life right now."],[3849,4120,"Yeah, that sounds about right."],[4162,4341,"I'm just a powerless human."],[4529,4750,"But if the gods are built on cruelty,"],[4859,5009,"I would rather die"],[5009,5142,"than kneel before them."],[5180,5347,"I'm not begging."],[5355,5451,"Excuse me?"],[5480,5613,"I may be a mortal"],[5659,5743,"and you may be a goddess,"],[5743,5989,"but I will never, ever beg to you."],[6218,6385,"Fuck you."],[6431,6498,"Ah!"],[7269,7390,"Aria, embrace your power."],[8537,8621,"My face!"],[8641,8737,"The mortal has wounded"],[8800,8925,"the goddess?"]],"27":[[162,254,"My face!"],[296,446,"My beautiful face!"],[988,1105,"My face!"],[1180,1238,"Aria."],[1288,1476,"Fix it, fix it!"],[1868,1960,"No training today."],[1989,2093,"Go back to your cabins."],[2252,2373,"Aria, wait!"],[2585,2790,"Oh my God, I'm a monster."],[2827,2911,"No, you're not."],[2919,3028,"Yes, I am."],[3123,3253,"Did you not just see that?"],[3261,3541,"I felt strong, stronger than her."],[3541,3599,"There's this,"],[3641,3803,"this warmth, this energy in me."],[3816,3908,"Electricity."],[3912,3983,"Yes."],[4112,4208,"You're not human."]],"28":[[37,91,"Aria."],[125,254,"It was the Styx water."],[312,429,"It poisoned me, didn't it?"],[429,654,"Oh my God, it's like some dying animal"],[654,792,"with one last fight in it."],[804,863,"Aria."],[880,1034,"What's Aphrodite gonna do to me?"],[1046,1234,"Oh my Gods, and I killed Zeus' lamb"],[1234,1422,"and I destroyed Daphne's face"],[1422,1559,"and I am just this useless,"],[1580,1722,"stupid human. - Aria."],[1735,1918,"Aria, listen to me."],[2035,2122,"You're not human."],[2243,2289,"But I-"],[2289,2481,"You shot Zeus' lamb dead"],[2481,2577,"with a normal arrow."],[2577,2698,"Yes, but- - You bled me"],[2731,2819,"multiple times."],[2819,2877,"Because you were"],[2877,2998,"distracted. - You cut off"],[3028,3132,"half of Daphne's"],[3132,3207,"face. - Stop"],[3215,3374,"listing my crimes."],[3386,3670,"Aria, your face is completely healed."],[3670,3816,"No, that is not right, I..."],[3891,4079,"You're a God, Aria."],[4179,4225,"No."],[4229,4325,"You're a demigod just like"],[4325,4441,"the rest of them. - No, no, no I'm not,"],[4441,4500,"I'm not a..."],[4950,5180,"So that's the truth."],[5288,5426,"She's the last known child"],[5426,5501,"of Zeus."],[5530,5851,"The only one you didn't kill."]],"29":[[41,179,"She's the last known child"],[179,254,"of Zeus."],[266,588,"The only one you didn't kill."],[646,742,"Whatever you think this is-"],[742,880,"Oh no, I know exactly what this is."],[971,1117,"She's Zeus' bastard."],[1151,1301,"You somehow spared her."],[1317,1501,"So now she's lived a carefree"],[1501,1614,"little mortal life"],[1614,1835,"far, far away from Hera."],[1835,2010,"Well, until she got hungry"],[2010,2127,"and killed her daddy's lamb."],[2127,2227,"Hermes, if you-"],[2227,2394,"I'm the messenger of the Gods, Kairos."],[2419,2527,"You have your duties"],[2560,2631,"and I have mine."],[2781,2940,"But I do like to bend the rules."],[3048,3161,"And you are my friend."],[3190,3303,"I could buy you some time."],[3374,3457,"Thank you, Hermes."],[3474,3561,"You know, I really am rooting"],[3561,3636,"for you two."],[3712,3782,"Getting a little sick"],[3782,3941,"of all the tragic love stories"],[3941,4012,"of our time."],[4141,4208,"Love story?"],[4237,4279,"Yeah, well,"],[4279,4396,"I'm sure The Fates have shown you"],[4396,4483,"through visions."],[4621,4854,"Aria's your soulmate, Kairos."],[4854,4942,"She's the one"],[4942,5113,"you're supposed to fall in love with."],[5163,5226,"No."],[5347,5459,"If you haven't already."],[5551,5668,"She's your redemption."]],"30":[[141,300,"If I'm the daughter of Zeus, then-"],[387,542,"No, no, please."],[542,679,"Under the wrath of the Gods,"],[717,800,"you're nothing."],[867,1055,"You are human."],[1092,1267,"No better than a bug, really."],[1305,1484,"You're a God, Aria."],[1497,1589,"Just like the rest of them."],[1589,1647,"No."],[1726,1810,"That means I'm..."],[2339,2485,"You're not one of them, Aria."],[2531,2769,"They don't get to decide who we are."],[2815,2873,"Really?"],[2969,3136,"Says you, Hera's dog?"],[3465,3578,"Be a baby about it."],[3645,3812,"But I didn't spare you eight years ago"],[3812,3949,"just to watch you die now."],[4320,4475,"You disappoint me, Aria."],[4554,4621,"What?"],[4829,4971,"Why did you, huh?"],[5109,5259,"Why did you save my life?"]],"31":[[20,166,"Why did you save my life?"],[500,688,"You are the last child."],[717,859,"You shall be the first to live."],[900,971,"I'm sorry."],[1121,1217,"It was a rebellion."],[1309,1518,"A foolish act of kindness."],[1551,1735,"I didn't know that in sparing you,"],[1772,1914,"I would one day be spared."],[1951,2093,"It's funny how The Fates work."],[2143,2227,"So it's up to you."],[2339,2544,"Save us, or leave."],[2590,2690,"I will help you either way,"],[2748,2857,"but choose fast."],[2902,3015,"Hera is coming."],[3015,3148,"When she comes,"],[3148,3336,"she will try to kill us both."],[3678,3757,"My Lady Hera."],[3845,4045,"My favorite stepson."],[4421,4633,"What is this I hear of a girl"],[4633,4813,"who summons lightning?"],[4867,4929,"Lightning?"],[4996,5046,"Oh."],[5075,5188,"Oh no, lightning is,"],[5209,5288,"lightning is a strong word."],[5392,5447,"It's, uh,"],[5555,5743,"it's more, you know, static."],[5976,6056,"Static?"],[6418,6468,"Yeah."],[7465,7545,"Static."],[7782,7928,"Let's go find this girl."],[8358,8404,"Yeah."]],"32":[[1326,1397,"Made up your mind?"],[1463,1589,"I thought about what you said."],[1689,1785,"You're not a god."],[1868,1972,"You are weak."],[2043,2239,"You're foolish, sentimental."],[2381,2510,"You spared my life,"],[2515,2631,"even when you knew one day"],[2631,2802,"you could suffer the consequences."],[2827,2977,"Stop listing my crimes."],[3036,3224,"And that's why I forgive you."],[3249,3332,"Aria,"],[3420,3549,"I don't know if I deserve it."],[3549,3632,"We are nothing"],[3674,3853,"under the wrath of the Gods, Kairos."],[3937,4054,"But we can fight."],[4108,4208,"I choose to fight."],[4208,4441,"I choose you."],[4562,4733,"Will you fight with me?"],[4950,5059,"Fuck the Gods."],[5138,5271,"Fuck the Gods."]],"33":[[33,279,"I've never seen you smile before."],[350,446,"But it's beautiful."],[959,1067,"That's cheating."],[1251,1459,"Ares' spear knows no rules."],[1543,1659,"Will you teach me?"],[1789,1889,"My pleasure."],[3958,4162,"Kairos has been training Aria"],[4162,4383,"nonstop for days."],[4391,4462,"He better."],[4471,4612,"I told my mother about the rumor"],[4662,4763,"that Zeus' daughter"],[4763,4871,"walks among us."],[4900,5017,"She told Lady Hera."],[5259,5480,"Aria's days are numbered."],[5726,5843,"Come on Aria,"],[5843,6001,"you can summon your power."],[6072,6131,"Lightning."],[6464,6552,"Thunder?"],[6698,6756,"Lightning."],[6794,6877,"Oh my God."],[7048,7123,"What are you doing?"]],"34":[[45,112,"What are you doing?"],[154,429,"I'm just, um, trying to summon lightning."],[558,679,"Embracing your godhood."],[729,779,"Good."],[896,1001,"It's your only chance"],[1001,1101,"of surviving here."],[1167,1255,"Maybe even winning."],[1363,1468,"Not like this I won't."],[1547,1664,"You're thinking too much."],[1835,2047,"You're not feeling enough."],[2227,2369,"You're trying to summon power"],[2369,2544,"as if you think hard enough,"],[2577,2669,"it'll obey."],[2744,2886,"But that's not real power."],[2948,3165,"Real power is instinct."],[3687,3791,"It's need."],[4083,4195,"What do you need, Aria?"],[4412,4504,"You."]],"35":[[1326,1388,"I've-"],[1426,1551,"Never done this before."],[2018,2164,"I've done this many times."],[2239,2515,"And I'm supposed to be impressed?"],[2681,2798,"I think you will be."],[3044,3123,"Say my name,"],[3203,3294,"I'll bring the whole storm"],[3294,3403,"between your legs."],[3403,3582,"Ah, Kairos."],[3749,3816,"Aria."],[3908,4200,"You have no idea"],[4346,4517,"how much I need you, Aria."],[5071,5263,"Never thought l would tame a god"],[5309,5488,"let alone fall in love with him."],[5784,6018,"l once hated their kind, and now,"],[6085,6310,"all I want is him."]],"36":[[2344,2406,"Aria,"],[2406,2506,"are you sure?"],[2585,2660,"We can wait."],[3378,3465,"You're gonna let a human"],[3465,3599,"pin you down like this."],[3620,3745,"You don't know how hot you look"],[3745,3916,"when you look down on Gods."],[4162,4300,"Then take me."],[4475,4604,"I'll ruin you."]],"37":[[108,237,"Good morning, sunshine."],[567,729,"That's the daughter of Zeus alright."],[963,1055,"Look, I came to warn you."],[1134,1201,"Hera's here."],[1284,1343,"Here?"],[1397,1455,"Now?"],[1559,1643,"I did all I could."],[1772,1885,"But it seems she already knew..."],[1997,2077,"everything."],[2590,2765,"Kai, we have to go now."],[2765,2840,"If we don't go now, then-"],[2840,2961,"It's too late."],[3040,3115,"And with these,"],[3199,3286,"it's impossible."],[3378,3582,"But I can still break your curse."],[3661,3753,"You don't know how."],[3928,4004,"But look at me."],[4220,4400,"Nothing is gonna happen to you."],[4416,4504,"What about you?"],[4633,4688,"Trust me."],[4742,4859,"Everything's gonna be fine."],[5159,5342,"lf fate won't bring us together,"],[5417,5484,"then l'll surrender mine"],[5484,5618,"to keep you alive."]],"38":[[216,354,"Lady Hera is coming,"],[400,496,"quiet!"],[717,796,"Keep your head down."],[846,930,"Don't react."],[2473,2915,"All hail Lady Hera, Queen of Olympus."],[3103,3194,"You may rise."],[3461,3520,"Hello,"],[3607,3695,"pet."],[3991,4133,"What brings you to Camp Mythos?"],[4262,4429,"Oh, there's a funny rumor"],[4429,4596,"going around the palace."],[4683,4863,"I heard that you're harboring"],[4863,5013,"Zeus' daughter."]],"39":[[4,183,"I heard that you're harboring"],[183,329,"Zeus' daughter."],[375,613,"The last of his mutts."],[917,1063,"That is a serious accusation."],[1063,1138,"It is!"],[1201,1351,"And not plausible,"],[1451,1589,"given that I specifically"],[1589,1647,"ordered for you"],[1647,1881,"to kill them all, did I not?"],[1926,2027,"You did, My Lady."],[2185,2281,"I thought perhaps"],[2281,2506,"it's a silly girl"],[2544,2798,"pretending to be a Demi-God for fun."],[2844,3048,"A much more forgivable crime."],[3211,3349,"Do you happen to know who"],[3395,3574,"and where she might be hiding?"],[4287,4350,"Very well."]],"40":[[154,387,"Don't react, Aria, please."],[692,800,"Daphne,"],[800,1009,"you sweet girl. - My Lady."],[1693,1755,"Oh,"],[1805,1960,"you poor child."],[2039,2264,"You are ugly."],[2381,2498,"Who did this to you?"],[2585,2715,"It was her."],[3073,3190,"Is this the mortal"],[3190,3303,"that harmed a Demi-God"],[3303,3486,"with the power of lightning?"],[3561,3737,"My husband's powers."],[3807,3908,"Yes, My Lady."],[3949,4058,"And forgive me,"],[4087,4225,"but she's totally"],[4225,4333,"turned Kairos against you."],[4333,4437,"And he's like totally in love-"],[5839,5918,"Don't touch her!"],[6994,7140,"What is your name, child?"]],"41":[[175,266,"I am Aria."],[504,709,"Your bravery is outstanding."],[800,971,"I see my husband in you."],[1042,1192,"And I can also see"],[1238,1488,"why Kairos grew a soft spot for you."],[1526,1630,"Daphne is lying."],[1630,1701,"He hasn't-"],[1701,1785,"Silence!"],[1906,2056,"You shall not lie to me!"],[2114,2318,"You will face the consequences"],[2377,2627,"for being an abomination,"],[2752,2998,"and for also trying to steal my pet."],[3153,3232,"But not here."],[3536,3816,"In Olympus, where you belong."]],"42":[[62,262,"You are the last of Zeus' children,"],[262,346,"after all."],[408,771,"You shall die in his world as a reminder"],[771,1009,"of my undying love for him."],[1276,1338,"Oh,"],[1451,1609,"don't worry."],[1701,1960,"Kairos is coming with us."],[2039,2293,"Oh, who will kill you if not him?"],[2369,2598,"He shall finish what he started."],[2660,2794,"Let this be a lesson-"],[2794,2848,"No, no, no!"],[2848,2977,"in loyalty! - No!"],[3219,3286,"No, no, no!"],[3470,3545,"Where am I?"],[3653,3895,"Well done, Kairos."],[3945,4058,"You are the undefeated"],[4058,4225,"Champion of Olympus."],[4308,4425,"Name your reward."],[4600,4679,"Anything."],[4779,4850,"I'm in another one"],[4850,5021,"of Kairos' memories."]],"43":[[20,87,"My Lord,"],[166,300,"I wish to become mortal."],[517,633,"Nonsense."],[692,900,"I have something better in mind."],[1234,1405,"Why do you wish to be mortal?"],[1601,1730,"To be free, My Lady."],[1851,2127,"True freedom lies in power, dear boy."],[2218,2335,"Take Zeus."],[2381,2623,"He fucks whoever,"],[2673,2957,"wherever, whenever."],[2986,3194,"His half-breed bastards scattered"],[3194,3303,"throughout the realms."],[3399,3470,"And yet,"],[3536,3753,"when I dare to want something,"],[3853,4033,"I am told it is forbidden."],[4220,4471,"Why should he enjoy"],[4562,4833,"such pleasures,"],[4959,5084,"but I be denied?"],[5321,5434,"Lie with me,"],[5547,5793,"and I will grant you power."],[5922,6047,"All you need to do"],[6202,6439,"is give yourself"],[6648,6735,"to me."]],"44":[[738,859,"With respect, My Lady."],[942,1013,"I cannot."],[1251,1434,"Out of loyalty for Zeus?"],[1455,1514,"No."],[1593,1747,"Out of loyalty to my heart."],[1839,2018,"I do not desire you, My Lady."],[3307,3536,"My husband makes love to women"],[3536,3699,"and creatures on a whim."],[3741,3962,"And yet when I seek comfort,"],[4012,4158,"I am rejected."],[4179,4358,"I will not be humiliated"],[4358,4466,"by another man"],[4487,4729,"who claims to serve Olympus!"],[4971,5084,"What have you done?"],[5221,5663,"You are mine now, Kairos."],[5663,5855,"You must obey my every word"],[5972,6114,"for eternity."],[6206,6393,"And from this day forth,"],[6439,6552,"your duty"],[6577,6715,"is to slaughter - Kairos, no!"],[6719,6994,"every last one of Zeus' whores"],[7002,7178,"and their Demi-God children."],[7311,7394,"Kairos."]],"45":[[8,87,"Kairos."],[145,396,"Gaurds, take her to be executed!"],[458,638,"I'm pulled out of Kairos' memories,"],[638,871,"thrown back into reality."],[888,955,"No, no, no."],[963,1063,"Where are you taking me?"],[1063,1172,"Where's Kairos?"],[1255,1313,"No."],[1384,1534,"No, let me go!"],[2790,2869,"You have to go."],[2923,2973,"Now."],[2994,3144,"No, I am not leaving you."],[3157,3265,"It's too late for me."],[3315,3428,"I can never escape Hera."],[3465,3657,"The Fates, they were wrong."],[3728,3908,"No, Fates, they are never wrong."],[4158,4204,"Go,"],[4204,4258,"Aria. - No."],[4258,4358,"follow the stairs."],[4391,4487,"Hermes is waiting for you."],[4487,4554,"No, no, no, no."],[4554,4629,"I'm not leaving you,"],[4629,4704,"Kairos. - Aria."],[4821,4963,"Aria, I'll stall them."],[4992,5038,"No."],[5038,5117,"I'll kill them all."],[5134,5188,"No."],[5196,5263,"Go! - No."],[5276,5359,"Go, Aria!"],[5359,5447,"Go! - I'm sorry."],[5447,5568,"I'm so sorry."]],"46":[[754,917,"My poor pet."],[1113,1172,"Come."],[2014,2122,"Good boy."],[2302,2360,"Oh,"],[2552,2769,"not that perfect face."],[2944,3211,"Spare Aria, please."],[3382,3490,"Kairos,"],[3611,3687,"begging?"],[4054,4170,"You really are in love with her,"],[4170,4233,"aren't you?"],[4379,4446,"Yes."]],"47":[[75,166,"How lovely."],[262,467,"My immortal champion,"],[504,684,"my obedient dog"],[684,955,"in love with a filthy mutt."],[1038,1222,"I'll do anything."],[1288,1405,"Hera, please."],[1868,2106,"I am moved by your love, Kairos."],[2243,2314,"Stand."],[2840,3103,"No more of these hideous wounds."],[3653,3803,"I will spare your lover"],[3878,4133,"if you willingly become mine."],[4195,4275,"I accept."],[4562,4621,"Really?"],[4888,5034,"You will make love to me"],[5109,5180,"right here,"],[5321,5409,"right now?"]],"48":[[112,204,"Yes, My Lady."],[250,467,"I will be yours for eternity"],[529,679,"as long as you spare Aria."],[829,909,"Very well."],[1735,1789,"Aria?"],[1801,1885,"Aria. - Stay!"],[2177,2293,"I told you to go."],[2323,2435,"I couldn't leave you."],[2435,2577,"I tried to fight them."],[2577,2731,"I tried to save you."],[2806,3065,"Kairos, come here."],[3161,3349,"You want to, don't you?"],[4387,4475,"Yes, My Lady."],[4988,5092,"No, Kairos."],[5205,5309,"Kai..."],[5518,5630,"What are you doing?"]],"49":[[25,258,"Kairos has come to his senses."],[337,504,"Kairos, she is forcing you,"],[504,579,"isn't she?"],[579,709,"She's commanding you."],[750,905,"I'm not making him do anything."],[905,992,"Isn't that right?"],[1213,1301,"Yes, My Lady."],[2356,2464,"I'm thirsty."],[2523,2590,"Aren't you?"],[2711,2802,"Yes, My Lady."],[3778,3883,"No, no, no."],[3895,4062,"Kairos, why is this happening?"],[5071,5251,"No, no, no, no."],[5251,5367,"This can't be real."]],"50":[[479,575,"No, no, no, no."],[575,688,"This can't be real."],[1760,1901,"It's a simple choice."],[1989,2302,"Condemned to a life in hiding with you,"],[2356,2410,"or become"],[2410,2535,"the second-most powerful"],[2535,2723,"being in all of Olympus."],[2777,2907,"Kneeling only to Zeus?"],[2923,3086,"Kai, that's not what you want."],[3086,3303,"You don't know what I want!"],[3353,3611,"I was simply toying with you."],[3641,3712,"I just wanted to see"],[3712,3766,"what it felt like"],[3766,3908,"to fuck Zeus' daughter."],[3908,4054,"Oh, Kai, you don't mean that."],[4054,4229,"I killed your mother!"],[4458,4708,"And you still slept with me."]],"51":[[29,83,"No."],[191,529,"You are pathetic and weak,"],[633,1030,"so desperate for love and warmth,"],[1076,1201,"just like every"],[1234,1368,"useless mortal-"],[1368,1422,"No."],[1422,1505,"is."],[1534,1676,"No, please stop."],[1676,1776,"Please."],[1776,1914,"I should have killed you!"],[2339,2673,"Kairos, you're so naughty."],[3165,3319,"This can't be real."],[3357,3503,"No, this can't be real."],[3503,3682,"We're written in The Fates."],[4621,4733,"Let her watch."]],"52":[[371,437,"The Fates they-"],[696,750,"Aria."],[888,942,"Aria!"],[967,1121,"Don't you dare go to her."],[1205,1334,"Take her to the dungeons."],[1343,1614,"That is not what we agreed upon."],[1630,1826,"I told you that I would spare her life."],[1847,2027,"I never said I would let her go."],[2364,2419,"Go."],[2652,2719,"No."],[2765,2882,"No. - No, Aria."],[2919,2973,"Aria."],[3987,4058,"Hello?"]],"53":[[112,187,"Hello?"],[437,496,"Aria."],[621,696,"Don't leave."],[829,942,"You wanted to kill me?"],[1217,1284,"Do it."],[1430,1622,"I thought you were different, Kairos."],[1751,2014,"You promised that you would fight with me."],[2068,2348,"Fate brought us together, only for you"],[2348,2569,"to turn your back on me."],[2719,2840,"What do you need, Aria?"],[2923,2998,"You."],[2998,3244,"As if none of our love mattered."],[3399,3624,"You are pathetic and weak,"],[3703,4037,"so desperate for love and warmth,"],[4099,4471,"just like every useless mortal is."],[4496,4625,"I thought that you were different,"],[4625,4700,"Kairos."],[4733,4992,"You are just like the rest of the Gods,"],[5013,5259,"selfish, heartless,"],[5305,5409,"monsters."]],"54":[[12,79,"Leave,"],[100,191,"now! - Aria,"],[221,371,"I'm so sorry."],[408,525,"I don't have much time."],[525,658,"I said leave!"],[804,959,"I'm sorry. - I hate you!"],[959,1113,"I know, I know you do."],[1130,1309,"I didn't mean any of that."],[1309,1405,"No, you're lying."],[1418,1514,"Aria, please."],[1514,1643,"I, I love you."],[1768,1960,"No, how can I trust you?"],[1968,2131,"I thought I was saving you."],[2147,2331,"She told me if I gave myself to her,"],[2331,2581,"that, that she'd spare you."],[2619,2694,"Please."],[3465,3528,"Aria,"],[3611,3841,"I'd burn for you."],[3903,4020,"I'd die for you."],[4049,4116,"You can hate me,"],[4116,4425,"but please, don't deny my love."]],"55":[[54,208,"Don't deny my love."],[358,508,"You broke my heart, Kai."],[550,638,"The things that you said-"],[638,750,"I didn't mean them."],[763,867,"But they were true."],[896,975,"I am weak."],[975,1096,"I am pathetic."],[1096,1393,"And I crave your love."],[1455,1626,"The man who I watched"],[1626,1747,"murder my own mom."],[1876,1985,"We're not fated,"],[2072,2131,"Kai."],[2131,2281,"If anything, this is a curse."],[2281,2452,"I was born to hate you."],[2452,2585,"That is my fate"],[2585,2681,"and if I can't do that,"],[2681,2794,"if I can't hate the man"],[2794,2877,"who killed my mom, then,"],[3057,3232,"then what does that make me?"],[3294,3361,"Human."],[3549,3749,"It makes you human, Aria."],[3791,3945,"And that's why you're special."],[3962,4083,"You are complex."],[4108,4350,"You are full of contradictions"],[4441,4529,"and more than that,"],[4542,4746,"you love, despite it all."],[4892,5192,"And that's why I love you."],[6619,6898,"How utterly revolting."]],"56":[[0,262,"How utterly revolting."],[296,383,"Kairos,"],[392,608,"I underestimated your feelings"],[608,880,"for this disgusting mutt."],[934,1130,"I said I love her."],[1497,1564,"Yes."],[1710,1835,"You've said that."],[1864,1964,"It's a shame"],[2031,2198,"you're going to have to kill her."],[2198,2469,"Kill her, Kairos."],[2665,2731,"No, no, no, Kai."],[2827,2911,"Kai,"],[2911,2957,"it's okay."],[2957,3044,"No, Kai."],[3186,3244,"I'll fight it."],[3303,3378,"I'll fight it."],[3453,3528,"Kai?"],[3891,3999,"Go, Aria."],[4158,4441,"Obey or burn."],[4562,4637,"Go! - No, no, no."],[4637,4750,"Please, stop, Kai."],[4750,4792,"Stop!"],[4792,4979,"Kill the human bitch already."],[4979,5034,"No, Kairos."],[5034,5142,"I am not leaving you."],[5142,5242,"I'm not leaving."],[5242,5338,"I love you."],[5467,5526,"No, no, no."],[5563,5626,"Kai!"],[6231,6285,"No."],[6322,6402,"Kairos."],[6410,6481,"I'm sorry."]],"57":[[125,191,"I'm sorry."],[312,429,"Kairos needs our help, Hermes."],[437,529,"Please, we have to go back."],[529,596,"It's too late."],[633,729,"It's too late?"],[754,850,"It's too late?"],[850,942,"But I left him there."],[942,1076,"I left him burning."],[1076,1172,"It wasn't your choice."],[1180,1234,"You're a God."],[1234,1305,"You can do something."],[1305,1422,"Please, we have to go help him."],[1426,1505,"Hera is Queen."],[1622,1735,"Even Zeus fears her wrath."],[1735,1835,"And under her wrath,"],[1860,1939,"we are nothing."],[1972,2093,"But you're his friend."],[2156,2327,"That's why I stayed to guide you back."],[2389,2502,"So his sacrifice"],[2527,2635,"wouldn't be for nothing."],[2698,2806,"Okay, most of the other Olympians"],[2806,2882,"wouldn't even lift a finger"],[2882,2944,"to help him."],[3011,3069,"Why?"],[3111,3257,"Half the pantheon are Demi-Gods,"],[3282,3536,"children of both a God and a mortal."],[3591,3732,"They've hated Kairos for centuries"],[3732,3845,"for killing Zeus's kids."],[3912,4070,"Even if they know"],[4087,4229,"that he had no other choice,"],[4237,4366,"he's still Hera's dog."],[4375,4483,"And that makes him an enemy."],[4496,4571,"No, no, no, no, no."],[4571,4654,"There is a curse."],[4654,4792,"I know that there is a curse."],[4792,4863,"And we can break it."],[4863,4971,"I can break it, The Fates-"],[4979,5163,"Not if he's dead, Aria."],[5413,5484,"No."]],"58":[[0,66,"No, no, no, no."],[66,200,"I know that there's a way."],[200,275,"I know there is."],[275,346,"Look, I wish,"],[358,433,"I wish I knew."],[504,558,"Listen."],[692,846,"Kairos wanted me to give this to you."],[971,1042,"Why?"],[1305,1418,"He also said to tell you,"],[1514,1626,"think less,"],[1714,1814,"and feel more."],[2227,2456,"Live a long, happy life"],[2481,2590,"somewhere far,"],[2590,2744,"far away from us, Aria."],[3048,3140,"He burned for it."],[3937,4066,"Kairos!"]],"59":[[1505,1564,"Aria!"],[1584,1668,"Serina!"],[1881,2002,"You came back!"],[2002,2152,"I did, sweet girl."],[2152,2289,"I told you that I would."],[2348,2456,"What happened in here?"],[2510,2640,"After you left,"],[2644,2781,"all these people showed up,"],[2840,3007,"calling me Miss Serina."],[3053,3123,"And they said"],[3123,3261,"they were here to serve me."],[3303,3436,"They told Cletus to leave"],[3436,3607,"and said he was no longer my dad."],[3661,3874,"And um, who sent them?"],[3966,4087,"The guy you left with."],[4154,4241,"I have to go."],[4725,5075,"No smile, so serious, dark hair."],[5092,5217,"Did I say handsome?"],[5434,5501,"Aria."],[5559,5634,"What's wrong?"],[5705,5847,"Nothing, I'm just..."],[5910,6051,"I'm just happy to see you."]],"60":[[980,1088,"Okay, Aria."],[2281,2402,"Think less,"],[2456,2548,"and feel more."],[2777,2982,"Feel more."],[3666,3795,"A concealed message?"],[3862,4020,"My dearest Aria."],[4049,4195,"If you are reading this,"],[4241,4350,"then I'm gone."],[4416,4604,"I never wanted to keep the truth"],[4604,4850,"from you, but the world is dangerous."],[4900,5100,"You are a daughter of Zeus,"],[5121,5417,"the very last of his Demi-God children."],[5484,5734,"His blood runs in your veins."],[5764,5922,"I've known for some time now"],[5922,6097,"that my death is near."],[6197,6335,"But I'm not afraid."],[6377,6539,"Because I've seen you, Aria,"],[6556,6844,"in prophecies Zeus allowed me to see."],[6906,7107,"I've seen the path you will walk,"],[7161,7365,"the battles you will have to fight."],[7403,7624,"And though it'll be hard, you will win,"],[7674,7849,"with your soulmate at your side."],[7862,7953,"Kairos."]],"61":[[166,408,"Because I've seen you, Aria,"],[533,604,"in prophecies,"],[604,738,"Zeus allowed me to see."],[813,892,"You will win."],[938,1101,"With your soulmate by your side."],[1101,1192,"In prophecies."],[1226,1317,"I'm not a God,"],[1422,1514,"but I can't die."],[1568,1730,"Cursed to live for eternity"],[1743,1864,"on Hera's terms."],[2122,2210,"He's alive."],[2306,2389,"He's alive."],[2961,3028,"Hermes?"],[3186,3328,"Hermes, I need to speak to you."],[3328,3465,"I know that you're listening."],[3641,3691,"Okay."],[3753,3837,"Think less,"],[3958,4104,"feel more."],[4312,4400,"Hermes,"],[4479,4746,"I summon you!"],[5397,5513,"What the..."],[5601,5676,"What?"],[5693,5880,"Did you just summon me?"],[5922,6106,"He's alive, isn't he?"],[6139,6222,"Okay, listen."],[6239,6314,"Tell me!"],[6519,6715,"Alright, daughter of Zeus."],[6902,6956,"Okay."],[7015,7069,"Yes."],[7111,7236,"Your Kairos is alive."]],"62":[[12,100,"But it's not good."],[166,262,"Hera's in a bad state."],[300,412,"It's the worst it's ever been."],[446,583,"She's turned the whole camp"],[588,763,"into her personal colosseum."],[1780,1864,"She's making everyone"],[1864,1981,"fight each other to death."],[2068,2147,"And Kairos,"],[2293,2406,"he's soulless now."],[2531,2598,"She broke him."],[2790,2869,"No one can stop her."],[2961,3044,"No one will even try,"],[3123,3186,"not even us."],[3236,3345,"But she's never faced"],[3345,3503,"a child of Zeus before."],[3545,3607,"Sweetheart,"],[3691,3845,"I am the son of Zeus"],[3845,3945,"and I am full God."],[3999,4120,"And even I don't stand a chance."],[4170,4216,"I mean hell,"],[4216,4329,"even our dear old"],[4329,4437,"almighty father, Zeus,"],[4437,4558,"won't even face Hera right now."],[4637,4842,"And you are half human."],[4909,5180,"Look, I, I'm prepared to die."],[5263,5451,"I have nothing to lose."],[5505,5659,"You're willing to die for Kairos."],[5709,5830,"In the blink of an eye."],[5872,5926,"Please Hermes,"],[5926,6135,"just take me back to Olympus."],[6135,6343,"I, I will do anything."],[6393,6431,"My dear,"],[6431,6569,"you do not want to say that to a God."],[6723,6802,"I will remember."],[7036,7107,"Praise The Fates."],[7286,7399,"They are never wrong."],[7482,7599,"Alright, daughter of Zeus."],[7836,7941,"Let's go get your man."]],"63":[[392,563,"Come on, you lazy pigs!"],[583,642,"Fight's not over"],[642,759,"until one of you is dead."],[1067,1184,"I haven't had this much fun"],[1184,1347,"in centuries."],[1426,1601,"Oh, the last time was"],[1601,1772,"when you killed Aria's mother."],[1789,1864,"Remember her?"],[1926,2085,"I couldn't forget it if I tried."],[2143,2285,"And I'm sure you did."],[2389,2527,"Demi-Gods aren't worth"],[2527,2727,"the dirt beneath our feet."],[2802,2936,"I mean, look at them."],[3236,3345,"I said look."],[3803,3970,"Isn't it fun?"],[4074,4183,"Being in power?"],[4283,4379,"How lovely."],[4491,4658,"Who's our next challenger?"],[5167,5238,"Hurry!"],[5367,5522,"Right here."],[5968,6143,"I am your next challenger."]],"64":[[16,196,"I am your next challenger."],[946,1013,"No!"],[1067,1184,"Well, well, well."],[1263,1380,"I suppose we don't have to"],[1380,1543,"go hunting after all."],[1655,1730,"Grab her."],[2786,2948,"She's awakened her powers!"],[3236,3440,"What are you doing here?"],[3486,3774,"Set Kairos free."],[3832,3991,"You mortal bug."],[4112,4204,"Who do you think you are"],[4204,4408,"coming in here and making demands?"],[4433,4617,"I am the Queen of Olympus!"],[4654,5038,"And I am Aria, daughter of Zeus."]],"65":[[12,400,"And I am Aria, daughter of Zeus."],[596,896,"Very well, daughter of Zeus."],[967,1142,"What do you propose?"],[1167,1368,"You know I won't let Kairos go"],[1405,1484,"for nothing."],[1505,1751,"I challenge you, Hera."],[1805,1926,"A challenge?"],[1997,2168,"What sort of challenge?"],[2198,2460,"Put anyone here against me in a fight."],[2460,2560,"And if I beat them,"],[2594,2948,"you let everyone in this camp go."],[3174,3299,"And you free Kairos"],[3299,3465,"from your control forever."],[3532,3591,"No."],[3620,3682,"You think"],[3682,3878,"a half-blood vermin like you"],[3878,4045,"can win my trials?"],[4087,4212,"Afraid that you'll lose?"],[4396,4567,"You are just like your father."],[4629,4746,"Well, you heard her."],[4808,5096,"This girl dares to challenge me."],[5159,5259,"Very well."],[5317,5405,"Let's see it,"],[5417,5638,"bastard child of lightning."],[5772,5860,"Kairos,"],[5980,6106,"enter the arena."]],"66":[[8,66,"What?"],[125,283,"You said it yourself."],[337,487,"I can choose a fighter."],[513,638,"I choose Kairos."],[809,992,"Go, fight."],[992,1213,"If you win, you're mine forever"],[1259,1509,"and your girlfriend dies."],[1568,1843,"If she wins, then she's my prisoner."],[1893,2127,"And I can torment her whenever I like."],[2127,2273,"But, at least"],[2273,2494,"you won't be alive to see it."],[2602,2686,"I am immortal."],[2731,3015,"So is she, daughter of Zeus."],[3040,3190,"Plenty of power to kill"],[3190,3436,"an immortal warrior like yourself."],[3495,3691,"This isn't fair, Hera."],[3732,3803,"Fair?"],[3862,4004,"You should have known better."],[4024,4074,"I would have thought"],[4074,4220,"you learned a thing or two,"],[4250,4604,"you foolish, mortal scum."],[4750,4867,"As you command, My Lady."]],"67":[[1009,1134,"You're not supposed to be here."],[1176,1272,"And you're not supposed"],[1272,1347,"to love me."],[1413,1564,"Why did you return?"],[1593,1743,"I came to free you."],[1776,1881,"You don't know how."],[1897,2077,"I believe in the prophecies,"],[2077,2252,"in The Fates, in us."],[2281,2381,"I'm human."],[2423,2619,"Humans find a way to make this work."],[2669,2769,"Not this time."],[2848,2952,"There's no way out."],[3365,3516,"Are you really gonna kill me?"],[3566,3666,"Not before you kill me."],[3707,3837,"You know that I can't."],[3878,3974,"You're gonna have to try."],[4058,4124,"No."],[4187,4366,"Kairos, no!"]],"68":[[0,54,"No!"],[2131,2185,"You're gonna have to"],[2185,2260,"try harder than that, Aria."],[2302,2473,"How do I break it, Kairos?"],[2540,2610,"Tell me!"],[2882,3078,"They're both holding back."],[3153,3282,"No more games."],[3340,3470,"Kill the girl!"],[3795,3899,"Kairos, no. - Aria."],[3958,4058,"Aria, I'm sorry."],[4099,4208,"Fight it, Kairos!"],[4237,4308,"Kairos."],[4308,4371,"Aria."],[4400,4441,"Aria."],[4441,4550,"No, Kairos!"],[4817,4884,"Go!"],[4892,4984,"I can't leave you."],[4984,5113,"Run, go!"],[5134,5201,"Fight!"],[5238,5309,"No!"]],"69":[[141,225,"No!"],[279,437,"You're a God, Aria."],[533,633,"You're thinking too much."],[717,884,"Not feeling enough."],[900,1188,"Real power is instinct."],[2318,2489,"Oh my Gods."],[2519,2606,"She is-"],[2606,2731,"She is Zeus' daughter."],[3078,3136,"You did it."],[3199,3299,"You actually did it."],[4079,4191,"Enough."]],"70":[[158,283,"Enough."],[717,804,"Kairos,"],[867,984,"don't do this."],[1259,1330,"No, no, no."],[1330,1401,"What are you doing?"],[1430,1555,"You will find a way to survive."],[1580,1614,"No."],[1614,1693,"I know you will."],[1722,1793,"It's the only way."],[1793,1847,"No."],[1872,1951,"It's okay."],[1972,2114,"You're the only one who can do this."],[2181,2277,"It has to be you."],[2289,2352,"No, I..."],[2427,2615,"You're finally setting me free, Aria."],[2711,2794,"Let me die."],[2819,2982,"No, I don't wanna kill you."],[3015,3132,"I don't hate you, Kai."],[3132,3199,"I don't."],[3215,3315,"I love you, Aria."],[3315,3415,"No, no, no, no!"],[3862,3928,"Oh well."],[4016,4070,"No."],[4404,4554,"No, no, no, no, no, no, no, no."],[4713,4804,"I love you too."],[4804,4900,"I love you."],[5021,5100,"I love you."]],"71":[[1096,1184,"Aria."],[2118,2193,"Kairos."],[2252,2339,"Aria."],[2481,2569,"Impossible."],[2615,2752,"You aren't supposed to love him."],[2790,2894,"He killed your mother,"],[2894,3119,"you idiotic human."],[3207,3449,"Some of them will burn for you,"],[3449,3628,"if you choose to love them."],[3628,3732,"And that is our"],[3732,3958,"greatest strength as humans."],[3958,4133,"We choose love,"],[4133,4320,"even when it's easier to hate."],[4320,4425,"It's love."],[4450,4525,"What is?"],[4550,4725,"I chose to love you"],[4725,4871,"and you chose to love me"],[4871,5009,"even though you killed my mom,"],[5009,5201,"even though I tried to kill you,"],[5251,5347,"even though we have"],[5347,5551,"thousands of reasons"],[5551,5643,"to hate each other."],[5663,5722,"The curse."],[5747,6085,"It breaks with impossible love."]],"72":[[16,212,"But I don't deserve your love, Aria."],[237,291,"I'm a monster-"],[291,362,"No."],[425,538,"No, you're not, Kai."],[538,725,"You are so good."],[796,1009,"What if without the curse, I'm, I'm still..."],[1038,1222,"No, I have seen it, Kai."],[1222,1484,"You showed me you are good."],[1672,1881,"No!"],[3111,3169,"You did it."],[3240,3374,"You're free, Kairos."],[4054,4283,"You ungrateful wretch."],[4325,4592,"I gave you purpose, I gave you strength"],[4621,4783,"and you dare leave me?"],[4963,5017,"And you,"],[5096,5271,"you are no better"],[5271,5409,"than the other bastards."],[5447,5734,"I will obliterate you from this earth."],[5759,5951,"Let's see how useful"],[5951,6168,"your father's blood is now."]],"73":[[608,696,"Impossible."],[738,792,"Zeus."],[855,1197,"All this ruckus for one dead lamb?"],[1263,1393,"Why are you here?"],[1497,1697,"Trivial matters don't concern you."],[1705,1997,"Well, I figured he'd want to meet"],[2006,2135,"his last surviving daughter"],[2135,2210,"with a mortal."],[2235,2314,"Oh, so you brought"],[2314,2481,"the King of Olympus here to what?"],[2502,2686,"Scold me for my games?"],[2686,2815,"You've gone too far, Hera."],[2882,2986,"We're supposed to protect"],[2986,3115,"the people of this realm,"],[3165,3303,"not kill them for sport."],[3345,3474,"Well, if you hadn't stopped"],[3474,3586,"fucking around,"],[3620,3724,"I wouldn't have had to spend"],[3724,3816,"the last millennium"],[3837,3995,"eradicating every last one"],[3995,4316,"of your disgusting mortal parasites."],[4366,4542,"You left me no choice."],[4867,5021,"You think you can punish me?"],[5034,5238,"I am the Queen of Olympus."],[5267,5518,"You will face my wrath!"],[5943,6022,"There she goes."]],"74":[[321,538,"After everything you fought for,"],[538,700,"everything that we endured,"],[821,1005,"gone with the snap of his finger."],[1146,1267,"I am Zeus."],[1572,1622,"Yeah?"],[1676,1864,"Well, where were you when I needed you?"],[1893,2047,"What kind of father are you?"],[2314,2519,"You are my blood, alright."],[2585,2761,"Aria, my daughter,"],[2848,2965,"from mortal woman,"],[3069,3157,"Eurydice,"],[3182,3557,"who perished under the sword of Kairos."],[3716,3824,"It's my pleasure."],[3924,4004,"You know me?"],[4066,4166,"I am Zeus."],[4225,4408,"There is nothing I do not know."],[4600,4950,"Mythos Camp is no longer a prison."],[5017,5096,"You're all."],[5622,5784,"Except for you, Daphne."],[5860,5985,"Daughter of Aphrodite."]],"75":[[62,200,"Daughter of Aphrodite."],[233,437,"You tried to kill my daughter."],[513,909,"Well, technically everybody tried to."],[1038,1201,"Always been too chatty."],[1222,1359,"Now let your exterior"],[1359,1547,"reflect your beauty within."],[1580,1751,"I'm sure your mother would agree."],[2519,2569,"Bye."],[2806,2948,"Much to learn, my girl."],[3032,3199,"You have much to learn."],[3257,3545,"I owe you an apology."],[3803,3878,"My wife"],[4004,4124,"killed your mother."],[4312,4433,"And I did nothing."],[4579,4833,"I could say it was to protect you."],[4950,5092,"But the truth is,"],[5155,5288,"I was afraid."],[5376,5609,"You reminded me"],[5672,5926,"of everything I did wrong in my life."],[5968,6172,"You are a coward."]],"76":[[37,241,"You are a coward."],[475,533,"I am."],[646,734,"It's a mystery"],[754,967,"why immortality does not come"],[984,1263,"with courage or more integrity."],[1301,1438,"But it is written in The Fates,"],[1438,1526,"my child."],[1626,1826,"You did all you needed to do"],[1901,2010,"to endure,"],[2072,2189,"to find him."],[2494,2610,"With respect, my Lord,"],[2677,2744,"I believe The Fates"],[2744,2852,"would have led me to Aria"],[2882,3032,"even if I didn't kill her mother."],[3098,3265,"Some suffering's unnecessary."],[3307,3566,"Maybe, maybe not."],[3611,3941,"I too would prefer you didn't kill"],[3941,4124,"all my lovers and children."],[4195,4308,"My child,"],[4383,4487,"countless people,"],[4521,4725,"even heroes like Achilles,"],[4750,4938,"tried to outsmart their Fates."],[4967,5109,"There was nothing you did wrong."],[5184,5363,"Your hands were tied."],[5634,5826,"And you're here now,"],[5855,5976,"and so are you."],[6035,6101,"Yes,"],[6181,6277,"for eternity."],[6381,6448,"Aria,"],[6523,6715,"I will now grant you immortality."],[6752,6873,"No, no, I,"],[7011,7136,"I don't want that."],[7465,7524,"What?"]],"77":[[83,141,"What?"],[158,283,"If it's okay with you,"],[337,496,"I'd like to remain how I am."],[583,717,"You see, I have a little sister,"],[771,867,"a mortal, Serina,"],[867,1126,"and we have a safe and comfortable life"],[1126,1222,"back home."],[1409,1505,"And you?"],[1639,1726,"I wish for nothing more"],[1726,1951,"than to grow old and die."],[2260,2577,"My child, live the life that you want."],[2640,2756,"My palace doors"],[2836,3061,"will always be open to you"],[3115,3186,"and you,"],[3311,3436,"as long as you don't kill"],[3503,3695,"any of my precious lambs."],[4479,4600,"Goodbye,"],[4637,4742,"my daughter."],[4917,5109,"Whoa, whoa, easy, easy."],[5138,5213,"I've got you."],[5355,5438,"I feel human."],[5572,5697,"Well, welcome to my world."]],"78":[[567,775,"Serina, don't run."],[871,1038,"Come on now, be careful."],[1063,1276,"Look, a golden peacock!"],[1514,1572,"Aria,"],[1614,1726,"she's fine."],[1726,1856,"No one will bring her harm or you."],[1931,2006,"Besides,"],[2027,2152,"we haven't been alone in a while."],[2264,2339,"Oh yeah?"],[2469,2590,"What do you have in mind?"],[2623,2711,"You."],[3407,3461,"Come on."],[3524,3578,"Come on."],[3999,4108,"My goddess."],[4738,4875,"You know, you're pretty strong"],[4875,5096,"for a weak mortal."],[5167,5401,"I am just as mortal as you."],[5459,5547,"And I'm still the Champion"],[5547,5626,"of Olympus."],[5668,5743,"Oh yeah?"],[5814,6085,"Well, I am the daughter of Zeus."],[6118,6189,"We know."],[6877,6923,"You know,"],[6923,7094,"one day I will kiss all of these."],[7169,7294,"It's written in The Fates."],[7353,7469,"Yes, it is, Aria."],[7620,7728,"Say my name again."],[7807,7895,"Aria."],[7945,8024,"Aria."],[8087,8274,"Aria, my goddess."]]}