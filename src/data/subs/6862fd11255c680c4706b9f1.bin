{"1":[[762,916,"Scarlett."],[916,1025,"Okay,"],[1025,1162,"so the music is starting."],[1162,1325,"You have to go in now."],[1362,1487,"Where's your dad?"],[1487,1562,"I mean,"],[1562,1679,"even if he never cared about you,"],[1679,1837,"he can't just disappear"],[1837,1966,"in a moment like this."],[2050,2175,"Forget him."],[2175,2304,"You can walk me down the aisle."],[2304,2416,"Okay, okay."],[2416,2554,"Come on."],[2625,2737,"Okay."],[4579,4650,"Is the groom"],[4650,4762,"missing, too?"],[4816,5012,"This is the most ridiculous wedding."],[5029,5175,"I mean, the father's a no show,"],[5175,5325,"and so is the groom."],[5325,5450,"I heard Scarlett Winters"],[5450,5562,"grew up in the countryside"],[5562,5712,"and only came back in her teens."],[5712,5887,"No wonder the groom ditched her."],[5887,6041,"She's so beneath him."],[6262,6387,"Don't worry, honey."],[6387,6525,"I never wanted to marry Scarlett."],[6525,6737,"It's you I love."],[7666,7800,"Don't worry,"],[7800,7966,"I never wanna marry Scarlett."],[7966,8054,"It's you I love."],[8325,8412,"Carlton, wait, wait, wait, wait,"],[8412,8487,"what about your wedding?"],[8487,8641,"What about your wedding?"],[8912,9050,"The drug I slipped you is working,"],[9050,9125,"come on now,"],[9125,9262,"my dear sister's groom..."],[9329,9429,"Oh, God."],[9429,9637,"I hope you're seeing it Scarlett."],[10029,10187,"This wedding is over."],[11566,11637,"Mr. Forester,"],[11637,11725,"heads of state from"],[11725,11825,"three different countries"],[11825,11912,"are requesting a meeting"],[11912,12037,"with you later tonight."],[12037,12125,"Hoping to secure"],[12125,12312,"the Forester Group's support."],[12937,13054,"It's her."],[13166,13254,"Hurry!"],[13254,13300,"Hit her!"],[13300,13404,"But, sir, I don't..."],[13404,13529,"Do it."],[13529,13587,"Now!"],[15904,15962,"I promised"],[15962,16116,"I would find you again."],[16400,16550,"Excuse me, ma'am."],[16550,16675,"Can I help you up?"],[16675,16775,"Why would I want help from you?"],[16775,16937,"You just almost hit me with your car."],[18216,18375,"How about we talk compensation?"],[18466,18629,"How about..."],[18662,18825,"marry me?"],[18941,19075,"Will you forget me?"]],"2":[[58,170,"Will you forget me?"],[170,279,"Never, Scarlett."],[279,433,"Let's pinky promise."],[562,679,"I'll come back for you."],[679,800,"We'll watch the snow fall"],[800,962,"while stargazing together."],[970,1133,"You better not be lying."],[1133,1295,"The stars are watching."],[1329,1487,"I would never lie to you."],[1512,1700,"The stars are our witness."],[4079,4137,"Scarlett,"],[4137,4341,"I've been looking for you for 15 years."],[4341,4500,"Have you really forgotten me?"],[5654,5812,"You know I can walk, right?"],[5862,6020,"But you hurt your foot."],[6745,6908,"If it hurts, just let me know."],[6933,7091,"I'm here for you."],[7091,7245,"Your husband's so caring."],[7245,7412,"Oh, he's not my husband."],[7416,7575,"He will be soon."],[7720,7820,"Easy."],[7820,7916,"Hang on,"],[7916,8054,"I'll get the doctor."],[8345,8504,"Miss Winters,"],[8550,8737,"don't be so quick to reject my proposal."],[8779,8895,"You know, you went viral"],[8895,8975,"when the groom"],[8975,9120,"bailed you in the altar."],[9187,9350,"Someone even said that"],[9350,9512,"he never loved you, that..."],[9537,9670,"you just clung to him."],[9670,9795,"That's none of your business."],[9904,10116,"Now that we've crossed paths."],[10116,10270,"It is my business."],[10270,10462,"If you marry me, everyone will forget"],[10462,10662,"about how you got left at the altar."],[10662,10766,"They'll turn their attention"],[10766,10958,"to the groom."],[10958,11083,"And mock him"],[11083,11245,"for assuming that you loved him."],[11320,11433,"Marry me,"],[11433,11604,"and you can leave the Winters Family"],[11604,11745,"with no problems."],[11745,11908,"Doesn't that sound good?"],[13333,13425,"Okay!"],[13466,13525,"Great!"],[13525,13620,"Then it's decided."],[13620,13700,"I..."],[13729,13808,"Once you accept,"],[13808,13937,"you can't take it back."],[13937,14041,"I'm not taking it back."],[14041,14162,"I just want to get the marriage license"],[14162,14270,"as soon as possible."],[14270,14375,"Once you're discharged"],[14375,14429,"tomorrow,"],[14462,14545,"we'll go straight to"],[14545,14737,"the registry office."],[14883,15008,"Oh, wait."],[15079,15241,"What's your name?"],[15287,15425,"Leo."],[15425,15587,"Leo Forester."],[16475,16666,"Scarlett, why did you hang up?"],[16666,16829,"Ruby is in critical condition,"],[16829,16991,"I cannot leave her alone."],[17016,17166,"Well, then take good care of her"],[17166,17241,"because we're over."],[17400,17520,"Scarlett, don't think that"],[17520,17637,"you can marry Carlton"],[17637,17733,"just because you have"],[17733,17866,"my grandpa's will."],[17866,17954,"My hidden camera"],[17954,18062,"and the drug I slipped in"],[18062,18229,"will make your wedding a lifelong"],[18229,18370,"nightmare."]],"3":[[0,108,"Is Scarlett okay?"],[191,258,"Why is she even"],[258,387,"in the hospital?"],[450,558,"Mom, dad, you should really go"],[558,641,"check on her."],[641,825,"You just got out of the hospital."],[825,954,"Now all of a sudden,"],[954,1058,"she's hurt too."],[1058,1279,"Clearly, she's faking this."],[1279,1366,"Exactly,"],[1366,1500,"just rest up, Ruby."],[1500,1616,"Forget her."],[1616,1762,"She's still my sister."],[1762,1925,"I just want to make sure she's okay."],[2266,2337,"Don't worry."],[2337,2450,"I feel terrible for"],[2450,2579,"ruining her wedding."],[2579,2716,"Don't be silly,"],[2716,2833,"it's not your fault."],[2833,2995,"I'm terrible."],[3075,3216,"It's not your fault,"],[3216,3320,"not your fault."],[3320,3454,"It's okay."],[4291,4450,"Change into this."],[4579,4783,"Let's go get a marriage license."],[5041,5195,"How did you know my size?"],[5195,5354,"I knew from the moment I held you."],[5466,5520,"Come on,"],[5520,5566,"go try it on and"],[5566,5725,"see if it fits."],[7470,7541,"Oh my God,"],[7541,7654,"Forester Group?"],[7654,7804,"You...you're the Presi-"],[7804,7891,"Leo."],[7891,7975,"Leo Forester."],[7975,8062,"We're here to register"],[8062,8133,"our marriage."],[8987,9125,"Thank you."],[9491,9691,"I got you, don't worry."],[9783,9945,"Oh my goodness,"],[9954,10058,"that's the mysterious"],[10058,10216,"CEO of the Forester Group."],[10433,10591,"Guess what?"],[10641,10816,"The jilted bride on social media"],[10854,11091,"just married an absolute"],[11091,11245,"powerhouse."]],"4":[[383,462,"Why did the clerk"],[462,625,"look at you like that back there?"],[662,787,"Maybe she saw you limping"],[787,912,"and thought you are unhappy."],[962,1016,"Probably thought you were"],[1016,1150,"forced into this."],[1316,1412,"I'm sorry, Scarlett."],[1412,1520,"The Forester Group's name"],[1520,1600,"is too big,"],[1600,1762,"I don't want to frighten you now."],[1787,1887,"I can walk now."],[1887,1995,"My foot's fine."],[1995,2070,"Well I'm not,"],[2070,2183,"I like carrying my wife."],[2183,2250,"Hey!"],[2300,2366,"Keep struggling,"],[2366,2429,"and I won't be able to"],[2429,2562,"resist kissing you."],[3304,3441,"Let it go."],[3441,3529,"And why should I?"],[3529,3675,"She's my fiancée."],[3750,3837,"Is that so?"],[3837,4000,"Well, she's my wife and-"],[4108,4187,"at least I don't run away"],[4187,4329,"from my own wedding."],[4329,4483,"Mr. Simmons,"],[4533,4629,"don't push yourself."],[4629,4787,"Fucking hands off me."],[5587,5633,"Scarlett,"],[5633,5779,"you're not going to regret this."],[5779,5912,"Of course I'm not gonna regret it,"],[5912,6075,"it was my decision."],[6166,6283,"But I want a prenup."],[6283,6450,"Of course, it's fine."],[6450,6612,"Set whatever terms you want."],[6687,6800,"Let's go home."],[6800,6866,"Home?"],[6900,7062,"This is our wedding day."],[7091,7179,"I'm not gonna let you sleep"],[7179,7279,"anywhere else."],[7729,7770,"Scarlett,"],[7770,7829,"I know you're only"],[7829,7987,"using him to get back at me."],[8100,8250,"You'll come back to me in three days!"],[8250,8358,"You'll come crawling back."],[8358,8495,"I'm Carlton Simmons."],[8495,8654,"You don't mock me."]],"5":[[750,958,"Mom, what are you doing here?"],[1000,1112,"I wanted to meet the girl"],[1112,1270,"you chose to marry."],[1345,1458,"There's no other woman"],[1458,1620,"I would marry in this lifetime."],[1654,1783,"Aww."],[1783,1920,"In that case,"],[2162,2325,"this belongs to you."],[2483,2587,"No I couldn't."],[2587,2700,"It's..."],[2700,2858,"it's too precious."],[3191,3287,"Oh."],[3287,3466,"A Forester Family heirloom."],[3466,3625,"Starting today,"],[3645,3804,"it's yours."],[4683,4845,"Good evening."],[5250,5408,"So let's be clear,"],[5679,5870,"our marriage will last two years."],[5966,6066,"I'm sorry?"]],"6":[[0,91,"And then,"],[91,316,"if it's going well, we can continue,"],[316,483,"and, if not,"],[483,708,"we can go our separate ways."],[708,825,"Okay,"],[825,983,"two years?"],[1004,1162,"Sounds good."],[1441,1554,"Aren't you going to read it?"],[1608,1679,"No."],[1854,1941,"If after two years"],[1941,2129,"you still want to leave me, then"],[2195,2358,"that's my problem."],[3095,3216,"But,"],[3216,3354,"I have two conditions."],[3545,3708,"Okay."],[3866,4025,"First,"],[4083,4245,"if I ever cheat,"],[4283,4441,"I owe you all my assets."],[4654,4812,"But if you cheat,"],[4891,5050,"you owe me $1 billion."],[5129,5216,"Fine,"],[5216,5354,"I never cheat anyway."],[5354,5512,"And the second condition?"],[5595,5758,"We'll be a real couple."],[5766,5912,"Scarlett,"],[5912,6070,"I'm only human."],[6087,6191,"A man has needs."],[6437,6475,"I'm not going to"],[6475,6637,"fake this marriage."],[6875,6929,"At this point,"],[6929,7087,"there's nothing left to insist on."],[7195,7291,"Besides, I'm not really"],[7291,7408,"losing out."],[7437,7575,"Alright,"],[7900,8058,"let's do it."],[8058,8204,"No...okay."],[8325,8412,"If you remember,"],[8412,8512,"we have to visit your parents"],[8512,8666,"in the morning."],[8666,8825,"Right,"],[8829,8937,"my parents."],[8937,9004,"Yeah."],[9004,9087,"I'm not going to be your"],[9087,9187,"secret husband."]],"7":[[125,287,"That ungrateful brat."],[320,441,"I can't believe she got married"],[441,587,"without telling us."],[587,704,"Daddy,"],[704,783,"I'm just afraid that"],[783,858,"she's going to marry"],[858,933,"some hoodlum"],[933,1145,"and ruin the Winters Family reputation."],[1204,1304,"You wouldn't be talking about me"],[1304,1404,"now, would you?"],[1750,1879,"Scarlett Winters!"],[1879,1975,"How dare you?"],[1975,2083,"God, I can barely look at you"],[2083,2141,"right now."],[2141,2191,"You claim"],[2191,2300,"you want to be a member of"],[2300,2379,"this family,"],[2379,2562,"and this is how you treat your parents?"],[2741,2833,"Scarlett is not"],[2833,2991,"part of the Winters Family anymore."],[3000,3133,"She's a Forester."],[3279,3366,"Let's just go."],[3366,3483,"You go ahead."],[3483,3633,"I need a private moment"],[3633,3791,"with the Winters."],[3833,3900,"I'll meet up with you"],[3900,4041,"momentarily."],[5354,5425,"You know, mom and dad"],[5425,5541,"have always loved me more."],[5541,5704,"And I'm the adopted one."],[5770,5845,"It's not my fault"],[5845,6016,"that you were unidentified"],[6016,6108,"at birth and went off"],[6108,6191,"to some countryside."],[6191,6279,"We never thought that"],[6279,6483,"you would be some weird"],[6483,6641,"country bumpkin."],[6670,6820,"You know, I'm basically like,"],[6820,6983,"the heiress of this whole place."],[6983,7145,"The most popular one."],[7166,7312,"I'm basically the pride"],[7312,7470,"of the Winters Family."],[7550,7708,"Maybe you should just"],[7762,7920,"leave the family,"],[7920,8062,"and be sensible about it."],[8062,8150,"Ruby!"],[8529,8616,"Oh my God."],[8616,8775,"What is wrong with you?"],[8816,8933,"What did I do to deserve this?"],[8933,8995,"Scarlett, look,"],[8995,9137,"I get that you're mad at me,"],[9137,9229,"but Ruby has nothing"],[9229,9283,"to do with this."],[9283,9391,"You think I pushed her"],[9391,9554,"because I was jealous of you?"],[9554,9712,"I believe what I see."],[9758,9804,"Okay."],[9804,10037,"This is me pushing Ruby."]],"8":[[0,91,"This is me"],[91,254,"pushing Ruby."],[383,529,"I get that you're mad at-"],[529,675,"Let go of me!"],[733,829,"Touch my wife again,"],[829,991,"I'll break that hand!"],[1000,1129,"Don't you mock me."],[1129,1291,"You just married my sloppy"],[1291,1362,"seconds."],[1362,1454,"Go get him, baby."],[1654,1812,"Do I sense a little regret?"],[2045,2150,"What are you doing?"],[2150,2295,"I can walk by myself."],[2295,2458,"I can walk faster carrying you."],[2533,2604,"This house"],[2604,2766,"upsets my wife."],[2787,2950,"We won't be coming back."],[3345,3475,"Are you really over"],[3475,3637,"Carlton Simmons?"],[3666,3825,"Or is this just spite?"],[3850,3912,"Be honest,"],[3912,4075,"is this a ploy to get him back?"],[4075,4166,"Because it kind of"],[4166,4241,"seems like you're giving up"],[4241,4325,"on yourself."],[4454,4512,"Thank God."],[4512,4587,"That's great."],[4587,4795,"You're finally away from this scumbag."],[4795,4870,"You know what?"],[4870,5045,"Let's quit Simmons Corporations."],[5045,5137,"We can start our own place"],[5137,5220,"and get rich together."],[5220,5337,"I was thinking that, too."],[5337,5429,"Okay, amazing."],[5429,5512,"Scarlett."],[5583,5704,"Look,"],[5795,5941,"even if I can't marry you."],[5941,6087,"Hey, I promise"],[6087,6175,"that I'll take care of you"],[6175,6270,"for the rest of my life."],[6270,6429,"So you want me to be your mistress?"],[6462,6579,"Well, I'm"],[6579,6716,"sure we can figure something out,"],[6716,6766,"right?"]],"9":[[195,354,"I'm already married."],[379,554,"And if you don't stop harassing me,"],[554,679,"then I call the cops."],[679,737,"Wait, Scarlett."],[737,850,"Wait."],[1454,1570,"It's you."],[1570,1704,"I was gonna come"],[1704,1833,"pick up my wife to go home."],[1833,1925,"But"],[1925,2033,"until you scared her off."],[2033,2237,"So you two, you living together now?"],[2237,2404,"We're legally married,"],[2404,2516,"of course we live together."],[2516,2666,"Don't get too cocky."],[2666,2816,"Scarlett and I have known each other"],[2816,2870,"for eight years,"],[2870,3041,"and I know every single inch"],[3041,3129,"of her body."],[3129,3291,"She's just using you to get back at me."],[3308,3445,"You’ll never deserve"],[3445,3604,"Scarlett's love."],[3741,3879,"Keep pursuing my wife,"],[3879,4037,"and I won't take it easy on you."],[4091,4225,"Get your hands off me!"],[4237,4375,"Let's go."],[4750,4908,"Deal with somebody for me,"],[4929,5091,"I will pay you well."],[6125,6275,"Scarlett and I have known each other"],[6275,6329,"for eight years,"],[6329,6500,"and I know every single inch"],[6500,6583,"of her body."],[6887,7050,"Why are you drinking alone?"],[7550,7591,"Where were you"],[7591,7695,"this afternoon?"],[7695,7750,"Leo."],[7904,8066,"Answer me."]],"10":[[12,166,"Answer me."],[166,325,"I saw Sunny."],[354,512,"Anyone else?"],[512,675,"No point telling him about Carlton"],[675,816,"and provoking a misunderstanding"],[816,912,"right now."],[912,1116,"No, no one else."],[1929,2100,"Leo, what's gotten into you?"],[2366,2429,"Did he ever kiss"],[2429,2587,"you like that before?"],[3341,3475,"Tell me,"],[3475,3591,"has anyone kissed you like that"],[3591,3708,"before?"],[4495,4579,"Has anyone treated"],[4579,4737,"you like that before?"],[5025,5129,"What about that?"],[5162,5266,"Leo,"],[5266,5425,"what's gotten into you?"],[5441,5600,"I'm filled with jealousy."],[5633,5733,"Knowing that he's known you"],[5733,5891,"for that long."],[6304,6462,"I want you."],[6650,6808,"May I?"]],"11":[[8,166,"May I?"],[4720,4875,"No!"]],"12":[[470,675,"Boss, the email said to kidnap"],[675,741,"Miss Winters."],[741,933,"But which one is she?"],[962,1104,"These idiots."],[1104,1195,"They don't even know"],[1195,1300,"what they're doing."],[1300,1504,"She is the real Miss Winters."],[1533,1695,"I'm the adopted one."],[1700,1775,"Oh, yeah?"],[1775,1841,"Yeah."],[1841,1983,"You're pretty quick to say that."],[1983,2141,"Maybe you're the real one."],[2154,2262,"Fucking idiots."],[2262,2420,"Your boss wants her."],[2420,2495,"Trust me."],[2495,2658,"How does she know who hired them?"],[2658,2758,"Am I being set up?"],[2758,2945,"Why don't you ask whoever hired you"],[2945,3066,"which Miss Winters they want?"],[3066,3170,"Oh, no, no."],[3170,3266,"You don't need to do that."],[3283,3454,"Do you want your boss"],[3454,3600,"dock your pay and fire you?"],[3600,3750,"Both of you, shut it!"],[3750,3887,"Call the Winters Family for ransom,"],[3887,4033,"50 million each."],[4441,4558,"Damn it."],[4687,4770,"Ruby and Scarlett"],[4770,4862,"have been kidnapped."],[4862,5083,"They want $50 million apiece."],[5187,5283,"I'll bring the money."],[5283,5354,"Okay?"],[5354,5445,"If there isn't enough money,"],[5445,5637,"just get Ruby out first, okay?"],[5637,5841,"Yes, please get my poor Ruby out first."],[5883,6041,"She can't bear the torment."],[6066,6154,"Are the Winters really going to"],[6154,6229,"dump Scarlett?"],[6291,6425,"God, not a single one of the Winters"],[6425,6520,"is any good."],[6520,6770,"But if Scarlett just comes to me,"],[6770,6933,"obediently begging,"],[6933,7029,"I wouldn't mind shelling out"],[7029,7091,"the cash."]],"13":[[279,441,"Boss, this one's hotter."],[487,587,"Get away from me!"],[587,712,"Stop!"],[712,875,"Oh my god, Carlton."],[929,1075,"I knew you would come for me."],[1075,1229,"Money's all there."],[1229,1325,"Everything you asked for."],[1325,1491,"Now let her go."],[1991,2116,"Baby."],[2429,2487,"I'm so scared."],[2487,2612,"What about the other one?"],[2612,2716,"Carlton."],[3162,3325,"Here's something,"],[3325,3416,"how about you agree"],[3416,3575,"to be my mistress,"],[3600,3712,"and I'll keep you alive?"],[3712,3804,"In your dreams."],[3804,3904,"Fine."],[3941,4000,"Let these"],[4000,4162,"thugs have their way with you."],[4162,4350,"Let's see what Leo Forester to thinks"],[4350,4525,"when you turn into a shell."],[4604,4675,"Do what you want."],[4675,4787,"Carlton."],[4975,5125,"Hey, don't worry, sweetie."],[5125,5375,"He don't want you, but I do."],[5375,5575,"So this is my own parents' choice?"],[5600,5712,"And the man I loved"],[5712,5904,"for eight years?"],[6475,6612,"Feisty, huh?"],[6612,6700,"I like that."],[6725,6887,"Let's go together, pal."]],"14":[[25,187,"Oh, please."],[729,800,"Scarlett."],[800,958,"Sorry I'm late."],[2179,2291,"Scarlett."],[2450,2533,"Leo."],[2629,2787,"You always protect me."],[2875,2933,"Don't scare me"],[2933,3050,"like that again."],[3579,3775,"Don't look at those worthless people."],[4133,4250,"What I want to know"],[4250,4458,"is why it costs $50 million"],[4458,4525,"to save Ruby."],[4525,4683,"But you got away scot free."]],"15":[[0,154,"Did you plan this kidnaping?"],[183,337,"Did you?"],[337,483,"I can ask you the same thing."],[483,683,"You get the money to get Ruby out."],[708,808,"And let Scarlett"],[808,929,"at the kidnapers' mercy."],[950,1108,"Are you her father or not?"],[1162,1350,"You raised Ruby as your daughter,"],[1383,1516,"so the real one doesn't count?"],[1629,1733,"Who are you to lecture me"],[1733,1829,"about fatherhood?"],[1829,1983,"Try to hurt Scarlett again,"],[2041,2200,"you'll regret it."],[2245,2308,"Scarlett,"],[2308,2425,"don't get me wrong."],[2425,2516,"Ruby she-"],[2516,2733,"You know she was raised in luxury."],[2787,2883,"She wouldn't be able"],[2883,3041,"to handle all this torment."],[3083,3279,"We would rescue you,"],[3279,3370,"it's just that..."],[3370,3500,"So I deserve that?"],[3500,3591,"Just because I was raised"],[3591,3754,"in the countryside?"],[3779,3891,"How dare you talk to your mother"],[3891,3929,"like that?"],[3929,4100,"You ended up just fine, didn't you?"],[4116,4279,"You're disgusting."],[4362,4525,"Get out!"]],"16":[[175,270,"Dad."],[270,395,"My sister's married now, okay."],[395,554,"She will never listen to you."],[583,737,"There's no point being upset."],[737,887,"Thankfully, you're the sensible one,"],[887,933,"Ruby."],[933,1133,"So much better than that wild girl."],[1166,1241,"Don't worry."],[1241,1408,"I will personally talk to Scarlett"],[1408,1616,"when she returns to the company."],[2666,2841,"This is her first time back since"],[2841,2920,"Mr. Simmons"],[2920,3091,"bailed on the wedding."],[3283,3445,"Hey, sis."],[3691,3775,"You never came back"],[3775,3820,"after the wedding,"],[3820,3979,"so Carlton decided to give me your job."],[4054,4200,"Awkward."],[4200,4275,"It's my seat."],[4420,4504,"You know, you've been stealing"],[4504,4650,"from me since we were kids."],[4687,4858,"But let me make one thing clear."],[4858,5087,"This position is mine,"],[5087,5191,"and no one can snatch it"],[5191,5295,"from me."]],"17":[[0,104,"And no one can snatch it"],[104,266,"from me."],[379,466,"You know, on second thought,"],[466,583,"I don't want it."],[675,854,"Here's my letter of resignation."],[1433,1483,"God,"],[1483,1620,"looks like Mr. Simmons"],[1620,1808,"is still into Scarlett."],[1891,2008,"What?"],[2008,2158,"Get back to work."],[2158,2320,"Okay? Now!"],[2450,2483,"What?"],[2483,2545,"What do you want to do?"],[2545,2675,"You want to resign?"],[2675,2762,"No, I won't allow it."],[2762,2870,"I will never let you go."],[2870,2962,"Not in this lifetime."],[2962,3120,"You disgust me."],[3125,3220,"What are you putting on this"],[3220,3370,"deep love act for?"],[3370,3400,"Weren't you"],[3400,3512,"the one that told the kidnappers"],[3512,3675,"you had nothing to do with me?"],[3675,3900,"You left me there to fend for myself."],[3900,4058,"You hurt me first."],[4079,4237,"You'd rather be kidnapped"],[4237,4345,"than make up with me."],[4345,4445,"You're insane."]],"18":[[141,304,"Stormed out."],[333,462,"Nicely done,"],[462,558,"Scarlett."],[558,645,"You know, leaving that"],[645,733,"Jerk's company"],[733,845,"means that you can co-found"],[845,962,"The Young Jewelry Design studio"],[962,1045,"with me."],[1045,1154,"Oh, and this."],[1287,1337,"This is your"],[1337,1483,"welcome gift."],[1737,1900,"White Swan?"],[1900,2091,"LaVey Jewelry is big charity gala."],[2091,2179,"They want you to perform"],[2179,2262,"the opening number,"],[2262,2366,"White Swan."],[2454,2541,"Are you sure I can do that"],[2541,2604,"after what happened"],[2604,2704,"five years ago?"],[2725,2837,"Oh, that was sabotage"],[2837,2912,"and you know it."],[2912,3050,"Go prove yourself."],[3050,3216,"I mean, plus, it'll get"],[3216,3304,"The Young Jewelry Design"],[3304,3429,"noticed by LaVey."],[3441,3604,"I mean..."],[3695,3808,"cheers to that!"],[3808,3858,"Cheers!"],[4187,4254,"Miss Ruby,"],[4254,4387,"you look stunning."],[4387,4470,"You should be tonight's"],[4470,4554,"White Swan."],[4554,4691,"Why the fuck does it matter"],[4691,4850,"if I'm the White Swan or not?"],[4904,5016,"The VIP's are going to be here,"],[5016,5158,"sweetie."],[5537,5658,"Scarlett!"],[5658,5758,"Aren't you the one who got caught"],[5758,5850,"using stimulants"],[5850,6016,"at an international competition?"],[6050,6187,"How dare you show up here?"],[6387,6458,"Do you really want to"],[6458,6616,"humiliate yourself again?"],[6654,6783,"In front of all those people?"],[6783,6895,"I have a clear conscience"],[6895,6966,"about what happened"],[6966,7054,"back then."],[7079,7237,"Why are you so nervous?"]],"19":[[12,179,"I guess coffee really does"],[179,370,"stick to people with dark pasts."],[562,637,"Maybe prefers"],[637,800,"people with dark hearts,"],[812,975,"someone bitter."],[1020,1195,"You better fucking watch it."],[1195,1304,"You have witnesses"],[1304,1433,"to testify against you."],[1433,1529,"Testify that you spilled"],[1529,1645,"coffee on me?"],[1662,1820,"A country bumpkin."],[1829,2025,"We didn't see Ruby spill anything,"],[2058,2262,"but we all saw you try to pour it on her."],[2287,2362,"Go ahead."],[2362,2537,"We will all testify against you."],[2641,2766,"Then I guess I better not let"],[2766,2925,"all of you lie under oath."],[2954,3041,"Tell the organizers"],[3041,3145,"I would never share a stage"],[3145,3304,"with any of you."],[4145,4266,"Scarlett,"],[4316,4454,"I've been looking for you everywhere."],[4454,4545,"Leo."],[4545,4620,"I..."],[4795,4929,"Anyone who bullies my wife"],[4929,5050,"will pay 100 fold."],[5050,5454,"Come on, let's go get you changed."],[6691,6833,"Wow."],[6833,6995,"You look beautiful."],[8116,8245,"Those dancers don't deserve"],[8245,8366,"to be on the stage."],[8400,8591,"Ben, call the organizers."],[8591,8800,"Tell them the first dance is canceled."],[8929,9087,"Leo,"],[9212,9370,"who are you really?"]],"20":[[33,191,"Who are you really?"],[300,462,"I'm your husband."],[487,650,"Just trust me, okay?"],[1266,1383,"Miss Ruby,"],[1383,1508,"our performance got canceled."],[1508,1604,"How dare somebody"],[1604,1725,"ruin my show!"]],"21":[[700,845,"Astonishing!"],[845,1012,"Absolutely astonishing!"],[1012,1166,"President Forester,"],[1166,1412,"always an honor to have you here."],[1412,1520,"And this young lady"],[1520,1683,"is just"],[1691,1783,"dazzling."],[1783,1904,"Excuse me, Miss."],[1904,2045,"The necklace you're wearing,"],[2045,2141,"who designed it?"],[2141,2229,"I did."],[2229,2345,"I'm a jewelry designer,"],[2345,2420,"and my"],[2420,2625,"pieces feature this diamond cut design."],[2670,2925,"That's fantastic."],[2925,3087,"What company do you work for?"],[3087,3250,"The Young Jewelry Design company."],[3287,3420,"I co-founded it with renowned"],[3420,3579,"jeweler Sunny Flynn."],[3770,3929,"The Young...."],[3937,4062,"Got it."],[4108,4266,"I'll remember that."],[5066,5225,"Sunny, we did it."],[5225,5350,"LaVey Jewelry is interested in"],[5350,5433,"our designs."],[5433,5579,"It's all over social media."],[5579,5737,"Your first dance with your husband."],[5804,5962,"Scarlett, who is he?"],[6000,6158,"You said his last name is Forester..."],[6191,6329,"Is he the legendary Forester"],[6329,6491,"Empire CEO?"],[6929,6975,"Scarlett."],[6975,7020,"Carlton!"],[7020,7091,"Let go of me!"],[7091,7200,"Stop this!"],[7200,7391,"Look, I'm willing to humble myself."],[7445,7525,"If that's what you want."],[7525,7650,"I know you love me, baby."],[7650,7708,"I know you-"],[7708,7791,"You're out of your mind!"],[7791,7887,"I'm done with you."],[7887,8066,"That man is better than me?"],[8066,8112,"We've been together"],[8112,8275,"for eight fucking years."],[8316,8404,"He's better than you"],[8404,8570,"in every single way."],[8595,8687,"He's more handsome."],[8687,8762,"He's more caring."],[8762,8845,"He's more loyal."],[8845,8937,"He's more rich."],[8937,9100,"He's just more everything."],[9175,9295,"You want me to do that?"],[9337,9495,"Yes, you want me to fucking to that."],[9537,9658,"Carlton, stop!"],[9658,9845,"You're fucking blind."]],"22":[[20,162,"Let me go!"],[920,1008,"Leo?"],[1320,1437,"Do this again,"],[1437,1604,"and you'll lose your nose."],[1604,1766,"Now get the fuck out!"],[2237,2333,"You okay?"],[2420,2537,"You couldn't see,"],[2537,2691,"how did you know it was me?"],[2691,2850,"I know your scent."],[3087,3229,"Say it again."],[3308,3470,"I'm more caring,"],[3483,3595,"more handsome,"],[3595,3708,"better in every way."],[3708,3795,"Leo,"],[3891,4070,"are you the CEO of Forester?"],[4179,4441,"The one they call unstoppable."],[4441,4637,"I do work for Forester,"],[4679,4854,"and I make a lot of money, but..."],[4925,5087,"I wouldn't say I'm unstoppable."],[5237,5400,"You have nothing to worry about,"],[5400,5533,"my love."],[5533,5691,"I'm not worried."],[6875,7037,"What's this?"],[7100,7241,"It's a gift"],[7241,7400,"that I never got to give."],[7720,7879,"Who's it for?"],[7970,8108,"My first love."],[8237,8395,"When I was a child."],[8454,8616,"Will you forget me?"],[8745,8904,"Best girl in the world."],[9058,9195,"His first love had such a deep"],[9195,9291,"and profound impact"],[9291,9345,"on him."]],"23":[[4,41,"What kind of"],[41,200,"person was she?"],[233,308,"She was the most"],[308,470,"wonderful girl I've ever met."],[520,683,"Just like you."],[733,895,"Then why not fight for her?"],[925,1033,"There's no need."],[1033,1204,"She's married now, and I know her"],[1204,1333,"husband makes her happy."],[1333,1491,"How do you know that?"],[1700,1829,"Aren't you happy?"],[1829,1950,"Yes, but I mean,"],[1950,2004,"she's-"],[2075,2208,"somebody else."],[2208,2366,"What if she gets divorced?"],[2387,2545,"Are you going to"],[2545,2704,"look for her?"],[3087,3245,"She won't get divorced."],[3358,3412,"Scarlett,"],[3412,3579,"no need to rush."],[3579,3675,"I'll wait until you remember"],[3675,3770,"everything."],[4095,4166,"But..."],[4745,4820,"I've already"],[4820,5012,"worn you out enough today."],[5012,5145,"Get some rest."],[5629,5800,"You're so good to me."],[5904,5987,"Are you sure there isn't"],[5987,6170,"some secret you're holding back?"],[6170,6329,"My biggest secret,"],[6458,6637,"is that I love you deeply."],[6933,7091,"Good night."],[7566,7666,"But what if your first love"],[7666,7829,"comes back?"]],"24":[[1116,1279,"You're my first and only love."],[1433,1591,"The stars are our witness."],[2129,2195,"I'll wait for you"],[2195,2358,"to remember."],[2920,3079,"What did you say?"],[4450,4537,"Was I dreaming"],[4537,4695,"just now?"],[4945,5083,"Scarlett, honey,"],[5083,5245,"could you help me with my tie?"],[5279,5420,"Please?"],[5650,5729,"Oh, darling,"],[5729,5887,"that is entirely too tight."]],"25":[[241,400,"You did that on purpose."],[437,675,"Well, if I want to kiss my wife,"],[762,858,"I've gotta get creative."],[858,1020,"It's actually quite a chore."],[1150,1308,"But, seriously,"],[1362,1500,"if you don't like it, I can stop."],[1500,1616,"Just let me know."],[1616,1775,"No, I don't hate it."],[1820,1933,"Okay."],[2154,2304,"Oh, by the way,"],[2304,2462,"it was Ruby Winters."],[2470,2600,"She hired those thugs,"],[2600,2729,"but they must have got confused"],[2729,2929,"because, they got her too."],[2987,3150,"I emailed you all the evidence,"],[3150,3400,"so, handle them however you like."],[3400,3566,"And, Scarlett,"],[3566,3679,"I will protect you"],[3679,3841,"from any danger."],[3841,3983,"I promise."],[3983,4129,"Just trust me."],[4129,4187,"I do."],[4295,4404,"Good."],[4541,4595,"I'll see you later."],[4595,4679,"Okay?"],[5058,5170,"Am I falling for him?"],[5308,5520,"But this is a contract marriage."],[5604,5795,"Besides, he still carries that gift"],[5795,5954,"meant for his first love."],[6020,6116,"Why is he so nice"],[6116,6283,"to me?"],[6283,6408,"Am I being played?"]],"26":[[625,745,"It really was Ruby."],[1891,2033,"What do you want, Carlton?"],[2033,2154,"It's about The Young Jewelry"],[2154,2241,"Design's future."],[2241,2341,"Get over here,"],[2341,2437,"now."],[2620,2754,"Ah, Scarlett."],[2754,2937,"Just the girl I was looking for."],[3000,3137,"Take a look at this."],[3279,3550,"It's from your first design"],[3550,3783,"from our one-year anniversary."],[3854,4033,"Is this some sort of sick joke?"],[4062,4133,"Well, I told you you'd come"],[4133,4241,"crawling back to me,"],[4241,4312,"didn't I?"],[4375,4454,"What do you want?"],[4554,4637,"When did my designs"],[4637,4729,"become yours?"],[4729,4908,"Well, how did you become"],[4908,5037,"Mrs. Forester"],[5037,5175,"instead of Mrs. Simmons?"],[5254,5391,"Look, if you want to come back"],[5391,5454,"as a designer,"],[5454,5541,"you can always come back"],[5541,5679,"as my assistant."]],"27":[[0,145,"Look, if you want to come back"],[145,208,"as a designer,"],[208,304,"you can always come back"],[304,408,"as my assistant."],[579,683,"Your assistant in bed?"],[741,816,"Well, that's what you should"],[816,966,"have been from the start, right?"],[1070,1187,"Not a chance."],[1275,1404,"Oh, okay."],[1404,1466,"Fine."],[1579,1700,"You want to play like that?"],[1900,2037,"Mr. Anderson, please come in."],[2275,2350,"Mr. Anderson."],[2350,2395,"Hello."],[2487,2579,"The designer you wanted to"],[2579,2833,"sign with is actually a plagiarist."],[2891,2991,"Yeah."],[3029,3154,"She stole my work."],[3212,3295,"That's not true."],[3295,3366,"That's a lie."],[3395,3537,"Those designs are mine."],[3562,3600,"Oh, really?"],[3600,3750,"Well, I have all the designs here."],[3841,4045,"All the original drafts, the revisions."],[4045,4191,"So if it's your design,"],[4191,4320,"prove it to me."]],"28":[[0,237,"If it's your design, prove it to me."],[400,591,"You see, the LaVey Jewelry brand"],[591,770,"is a top brand."],[816,975,"They don't work with plagiarists."],[1033,1275,"Indeed, she won't."],[1412,1558,"President Forster."],[1725,1954,"This is Scarlett's design."],[2025,2145,"Every step she took,"],[2175,2391,"every revision she made"],[2458,2570,"was all sent to you."],[2658,2783,"All the records are here."],[2812,2920,"No, no, no."],[2966,3066,"This isn't possible."],[3066,3275,"I blocked her company email."],[3275,3466,"It's weird because your whole inbox"],[3466,3762,"is so easily accessible to me."],[3762,3916,"Mrs. Forester mentioned"],[3916,4129,"yesterday her design contains"],[4129,4312,"certain signature lines."],[4358,4445,"Can you tell us more?"],[4579,4662,"It's stars."],[4812,4958,"It was inspired by somebody"],[4958,5091,"I met when I was a child."],[5091,5345,"I can't remember his face, but..."],[5391,5587,"we used to stargaze together."],[5616,5837,"That's just vividly etched in my mind."],[5970,6100,"Very distinctive."],[6129,6254,"Mrs. Forester,"],[6254,6412,"LaVey would be honored to"],[6412,6537,"collaborate with you."],[6579,6800,"And I must say with president-"],[7229,7500,"With Leo supporting your career."],[7587,7762,"I'm sure you'll do brilliantly."],[8045,8200,"You can't honestly believe"],[8200,8312,"he loves you."],[8366,8591,"If he was kidnapped today,"],[8591,8695,"you think he would choose you"],[8695,8804,"or choose himself?"],[8804,8937,"I'd like to see you try."],[8975,9108,"Don't mess with me or anyone"],[9108,9179,"around me,"],[9179,9291,"or you'll regret it."],[9450,9658,"Scarlett, you've changed so much."],[9658,9783,"Yeah I'm done with being that"],[9783,9920,"plain country hick that everyone"],[9920,10050,"expects me to be."]],"29":[[8,133,"Yeah I'm done with being that"],[133,270,"plain country hick that everyone"],[270,400,"expects me to be."],[1441,1595,"Look what your precious Ruby did."],[1825,1908,"Your shamelessness"],[1908,2091,"and her viciousness are a perfect match."],[2162,2270,"Have fun being a couple together"],[2270,2358,"in jail."],[2479,2562,"No, Scarlett."],[2595,2691,"Scarlett wait."],[2712,2745,"Wait!"],[2745,2787,"I..."],[2829,2929,"I didn't have anything to do"],[2929,2970,"with this!"],[2970,3033,"Scarlett!"],[3033,3129,"Please!"],[3262,3345,"God!"],[4095,4220,"What are you doing?"],[4220,4470,"I just realized how dashing you're."],[4520,4608,"Protecting your husband with"],[4608,4745,"so much force,"],[4783,5004,"that even Carlton's face was pale."],[5170,5325,"Being with my wife,"],[5425,5495,"gives me"],[5495,5650,"unparalleled security."],[6066,6191,"I have a question for you."],[6191,6262,"Go for it."],[6291,6425,"You said that you only"],[6425,6537,"work at Forester,"],[6537,6620,"right?"],[6683,6833,"But today I heard Mr. Anderson"],[6833,7045,"call you President Forester again."]],"30":[[0,150,"But today I heard Mr. Anderson"],[150,366,"call you President Forester again."],[625,820,"It's merely business that I can."],[854,966,"Plus he wants to sign a deal"],[966,1070,"with my wife so,"],[1070,1275,"of course he'd show respect."],[2554,2662,"Scarlett,"],[2691,2858,"you're in such a hurry."],[2887,3000,"You want to do that..."],[3000,3125,"right here?"],[4512,4620,"Ruby,"],[4620,4791,"you look so sophisticated in"],[4791,4912,"a wedding dress."],[5029,5154,"You look like a perfect lady."],[5262,5404,"Unlike that unsophisticated"],[5404,5575,"country bumpkin."],[5637,5766,"You guys are the best."],[5825,5895,"Oh,"],[5895,5983,"that must be Carlton."],[5983,6054,"He said he's going to deal with"],[6054,6158,"Scarlett’s shit."],[6354,6420,"Wait."]],"31":[[270,429,"Did you arrange the kidnapping?"],[508,554,"What's going on?"],[554,658,"You fucking idiot!"],[658,750,"Were you dropping on your head"],[750,854,"as a baby?"],[1112,1166,"What?"],[1166,1337,"You will need to work this out."],[1337,1550,"This is about to be your wife."],[1612,1679,"I don't think that's going to"],[1679,1750,"happen anymore,"],[1750,1800,"actually."],[1800,1850,"What do you mean?"],[1850,1925,"Wait, wait, wait."],[1925,2029,"And how dare you"],[2029,2133,"come into my house,"],[2133,2341,"and accuse Ruby of anything"],[2341,2500,"without proof."],[2500,2583,"You think I'm too old to deal with you?"],[2583,2816,"Read the statement yourself then!"],[3166,3287,"This can't be right."],[3475,3650,"It must be Scarlett framing me."],[3650,3779,"Look at the bank statements huh?"],[3779,3879,"How the fuck did they fake"],[3879,3987,"the bank statement?"],[4004,4179,"Do you even realize what could happen?"],[4216,4412,"If Scarlett presses charges,"],[4520,4625,"then you could go to jail and you could"],[4625,4729,"drag me with you and then"],[4729,4808,"we're fucked!"],[4808,5079,"I did this all for you because I love you!"],[5166,5312,"You are a Winters."],[5350,5433,"How could you do something"],[5433,5566,"so stupid?"],[5566,5662,"Fine!"],[5662,5787,"I did it!"],[5891,5962,"I did it."],[5962,5995,"Okay?"],[5995,6120,"She walked into this house"],[6120,6325,"and she takes everything from me."],[6683,6829,"Carlton Simmons is mine!"],[6829,7133,"The Winters Family is mine!"],[7425,7604,"Let's not be so hasty okay?"],[7604,7854,"I will go beg Scarlett to spare you."],[7854,8270,"It's okay."],[8479,8595,"It's okay."]],"32":[[241,366,"Let's make a toast."],[366,466,"I'll never forget the way"],[466,587,"you protected me."],[633,741,"But next time you're in trouble,"],[741,887,"please give me a chance to help."],[925,1041,"Promise me?"],[2295,2450,"Sir, Ms. Ivy returned,"],[2450,2595,"but we lost her at the airport."],[2629,2729,"I'll be right there."],[2808,2841,"I'm sorry."],[2841,2937,"She's a childhood friend,"],[2937,3050,"and I have to go find her."],[3166,3379,"A friend he grew up with?"],[3433,3629,"Could that be his first love?"],[3966,4062,"Is that Scarlett?"],[4141,4325,"Why is she drinking by herself?"],[4400,4445,"Come on."],[4445,4633,"Come on, come on, come on."],[5225,5329,"What are you doing?"],[5329,5562,"Your sister is in a bad place right now."],[5670,5895,"The doctor said that her emotions"],[5895,6062,"are affecting her health."],[6162,6229,"Please."],[6295,6454,"Show mercy to your sister."],[6454,6641,"She didn't mean any harm."],[6683,6845,"She was wrong to hire"],[6845,6987,"those kidnappers."],[7054,7154,"If you press charges,"],[7154,7250,"you're going to ruin the entire"],[7250,7412,"Winters Family name."],[7412,7525,"You're not going to be able to escape"],[7525,7641,"that fallout."],[7691,7758,"Ruined!"],[7800,7970,"Now you remember I'm a Winters?"],[7970,8183,"Before you told me I was unworthy."],[8208,8362,"You..."]],"33":[[4,187,"Now you remember I'm a Winters?"],[187,412,"Before you told me I was unworthy."],[412,566,"You..."],[566,766,"Scarlett is not going to forgive me."],[808,912,"Please!"],[958,1058,"Scarlett,"],[1108,1287,"I am begging you."],[1320,1395,"Please,"],[1395,1629,"show, show your sister some mercy."],[1658,1854,"I'll apologize for her."],[1854,1937,"Okay?"],[1970,2225,"This is a check."],[2254,2483,"It's for a hundred million dollars."],[2483,2683,"Just sign the settlement."],[2683,2741,"Please."],[2741,2929,"And it'll take effect immediately."],[2929,3029,"Look at that!"],[3029,3175,"Mom and dad are willing to do"],[3175,3395,"all of this for me, Scarlett."],[3395,3600,"If you still refuse, you’ll look horrible."],[3675,3829,"Scarlett please, please."],[3829,3966,"I'm begging you."],[3966,4220,"Have mercy on your sister."],[4525,4641,"How touching."],[4641,4833,"You know I'm almost in tears."],[4870,4962,"One of you kneels,"],[4962,5079,"one of you pays."],[5108,5295,"Did you forget I'm your daughter too?"],[5462,5566,"Ruby had me kidnapped."],[5566,5691,"I could be dead right now."],[5691,5766,"I would be dead right now"],[5766,5929,"if it wasn't for Leo."],[5929,6154,"Was that your plan all along?"],[6183,6370,"To have me killed,"],[6370,6562,"while Ruby remains untouched."]],"34":[[16,204,"To have me killed"],[204,400,"while Ruby remains untouched."],[441,575,"Come on,"],[575,762,"I told you begging her was useless."],[762,912,"Ruby, I'll find you a good lawyer."],[912,987,"Daddy,"],[987,1200,"I don't want to go to jail."],[1200,1300,"Please!"],[1475,1616,"What do you want? Huh?"],[1616,1800,"You want me to get on my knees too?"],[1800,1862,"You want me to beg?"],[1862,1925,"Is that it?"],[1925,2075,"Give it to me!"],[3800,3925,"Even if you never loved me"],[3925,4075,"the way that you loved her,"],[4112,4291,"you're still my biological parents."],[4291,4387,"And after I signed that,"],[4387,4537,"I want nothing more to do with"],[4537,4654,"the Winters Family."],[4716,4800,"Scarlett,"],[4800,5004,"I won't let this humiliation go."],[5004,5187,"Just you wait."],[5387,5504,"You're really mean."],[5504,5675,"You are horrible."],[6087,6179,"Why won't my parents ever"],[6179,6291,"love me?"],[6291,6450,"Am I that worthless?"],[6450,6487,"Leo,"],[6487,6575,"where are you?"],[6575,6675,"I need you."],[6675,6829,"Hey, gorgeous."],[6829,6941,"Why the long face?"],[6941,7037,"Let me buy you a drink."],[7037,7150,"Show you a good time."],[7187,7300,"Get lost."],[7337,7412,"Feisty,"],[7412,7525,"I like that."],[7525,7612,"Let go of me!"],[7612,7662,"Come on!"],[8541,8625,"Are you alright?"],[9091,9212,"Her face,"],[9212,9387,"it really looks just like mine."],[9616,9750,"Check that area!"],[9750,9916,"Shhh."]],"35":[[0,187,"Shhh."],[245,412,"Aren't you going to get in trouble?"],[412,583,"Of course not."],[729,854,"I just don't want my brother to catch me"],[854,1041,"and force me back to a boring life."],[1075,1175,"How about you?"],[1175,1325,"Why are you alone?"],[1429,1583,"You and me kind of look alike."],[1754,1875,"Come on, don't be sad."],[1875,1966,"I'm Ivy."],[2070,2166,"Let's go downstairs."],[2166,2316,"There's masquerade party."],[2733,2808,"Leo?"],[2808,2891,"Leo?"],[3008,3179,"Why are you two together?"],[3258,3404,"You two know each other?"],[3741,3783,"Ms. Ivy,"],[3783,3979,"this is Mr. Forester's wife."],[4404,4475,"Why didn't you tell me"],[4475,4579,"you got married?"],[4695,4870,"She's the one you went to go find?"],[4983,5133,"Vee showed up unannounced."],[5133,5241,"We couldn't find her at the airport,"],[5241,5400,"so we got worried."],[5441,5691,"He calls her Vee so intimately."],[5820,5945,"Okay, relax."],[5945,6091,"Come on, you two look tense."],[6108,6233,"So let's go have some fun."],[6233,6391,"Come on big bro."],[7254,7341,"Wow!"],[7341,7458,"Madam and Miss Ivy really do"],[7458,7550,"resemble each other."]],"36":[[12,100,"Wow!"],[100,212,"Madam and Miss Ivy really do"],[212,304,"resemble each other."],[587,662,"What happened to your hand?"],[662,750,"Are you hurt?"],[1075,1250,"No, a creep was harassing your wife."],[1250,1425,"I mean, Mrs. Forester,"],[1425,1600,"you mind if I call you that?"],[1600,1750,"Anyway, I knocked him out though."],[1750,1987,"Just scraped myself in the process."],[1987,2137,"Do we need to get a doctor?"],[2200,2266,"Leo,"],[2266,2500,"just overprotective as always."],[2537,2762,"They really seem close."],[2812,2941,"If your last name is Southgate,"],[2941,3112,"how are you two brother and sister?"],[3112,3262,"Oh we're not actually related"],[3262,3387,"by blood at all."],[3387,3575,"We just grew up like siblings."],[3575,3829,"Leo was always so protective."],[3829,3950,"And then I finally escaped when"],[3950,4087,"I was a teenager to go study art"],[4087,4179,"in Europe,"],[4179,4300,"and now I'm back."],[4300,4504,"And finally he is married."],[4504,4662,"And to find that my new sister-in-law"],[4662,4754,"to my surprise,"],[4754,4891,"or the new Mrs. Forester"],[4891,5041,"looked so much like me."],[5237,5375,"My first love."],[5391,5475,"When I was a child."],[5641,5887,"I just didn't imagine a man of his status"],[5887,6012,"to marry so quickly."],[6012,6129,"What status?"],[6316,6425,"Never mind."],[6425,6562,"Come on, let's go dance."],[7600,7675,"Ben,"],[7687,7775,"you go find Scarlett,"],[7775,7891,"make sure she doesn't trip."],[7950,8025,"Yes, sir."],[9037,9200,"Oh, you're not her."]],"37":[[816,875,"Madam,"],[875,987,"Mr. Forester sent me to come"],[987,1050,"find you."],[1125,1250,"He sent you to come find me"],[1250,1387,"so he could dance with Ivy?"],[1700,1837,"Can you tell me the truth is?"],[1887,2037,"Is there anything between them?"],[2087,2225,"And who is he really?"],[2225,2375,"Is there something I'm missing?"],[2537,2679,"No, no, I..."],[2679,2775,"I'm not..."],[2775,2887,"I..."],[3579,3662,"I'm sorry."],[3662,3837,"I mistook you for someone else."],[4475,4625,"No one truly loves me."],[4679,4812,"Not Carlton,"],[4812,4987,"not my parents,"],[4987,5191,"not even my husband."],[5616,5804,"Maybe it's better this way."],[5804,6012,"My life has been a lie."],[6012,6141,"Let it end."],[8066,8154,"Leo?"],[8329,8466,"Leo!"],[8512,8600,"No!"],[8825,8929,"Damn it!"],[8929,9062,"She's still alive."],[9062,9175,"Ruby Winters picked a tough one"],[9175,9250,"to kill."]],"38":[[341,445,"Leo?"],[729,837,"Oh, thank God madam,"],[837,916,"you’re awake."],[916,1104,"The doctor said you fainted from shock."],[1104,1191,"Where's Leo?"],[1312,1391,"Where is he?"],[1391,1612,"He was right here next to you, but..."],[1629,1741,"What are you doing?"],[1779,1929,"No what are you doing?"],[1929,2054,"You can't take this bed."],[2054,2154,"This is Leo's bed."],[2154,2254,"You can't take this."],[2254,2308,"No..."],[2450,2550,"She can't take this!"],[2550,2683,"This is Leo's bed."],[2737,2933,"Why do you always lie to me?"],[3000,3075,"But at the same time,"],[3075,3308,"you're always there to protect me."],[3450,3525,"Ever since we met,"],[3525,3654,"it's always been this way."],[3704,3829,"And I have so many unanswered"],[3829,4008,"questions from you, Leo."],[4104,4275,"You just say something?"],[4275,4479,"Say something, Leo Forester."],[4587,4729,"You don't have to say anything at all."],[4729,4875,"If you can say whatever you want."],[4875,4970,"If you want me to go away,"],[4970,5041,"I'll go."],[5112,5254,"Just please..."],[5320,5525,"Please don't die."],[5566,5841,"I don't want you to die."]],"39":[[29,229,"I don't want you to die."],[291,387,"Who died?"],[591,912,"I was trying to say that he was busy"],[912,1075,"with work and"],[1075,1179,"outpatient treatment,"],[1179,1250,"so,"],[1250,1420,"they didn't need this bed."],[1470,1570,"You!"],[2008,2216,"Is it that much fun messing with me?"],[2300,2375,"I'm sorry."],[2375,2450,"Come here."],[2450,2475,"Come here."],[2475,2554,"I’m sorry."],[2554,2783,"Scarlett, I'm sorry I scared you."],[2975,3054,"Yes."],[3054,3150,"Okay."],[3150,3375,"I'm still a patient here, so..."],[3783,3958,"You're badly injured."],[3958,4091,"God, I'm so sorry I didn't..."],[4137,4295,"I didn't know."],[4845,4987,"Scarlett."],[4987,5079,"Not here,"],[5079,5187,"we are in the hospital."],[5608,5708,"Leo."],[5883,6066,"Who are you?"],[6066,6179,"Really."]],"40":[[29,212,"Who are you?"],[212,325,"Really."],[375,495,"I'm your husband."],[600,737,"I know we're in a contract marriage"],[737,891,"and I probably shouldn't pry,"],[891,1091,"but I can't stand this."],[1225,1395,"Why did you marry me?"],[1504,1625,"Because I like you."],[1658,1766,"Be serious."],[1766,1854,"I am."],[1991,2070,"I am."],[2141,2300,"From the moment I saw you,"],[2350,2466,"I knew you were the one I’d have been"],[2466,2650,"looking for all along."],[2895,3025,"So what is your..."],[3104,3216,"status?"],[3291,3495,"Do you work at the Forester Group?"],[3604,3829,"Yes, I work at the Forester Group."],[3829,4066,"Like I said, I'm just an employee."],[4137,4195,"As for Ivy,"],[4195,4391,"she was just exaggerating"],[4391,4604,"in front of her future sister-in-law."],[4637,4762,"You're not lying to me?"],[4829,5045,"Leo, my whole life has been"],[5045,5170,"nothing but lies."],[5170,5241,"Please."],[5341,5458,"Don't add to that."],[5500,5658,"I'm not lying."],[6012,6125,"I promise."],[6375,6500,"I got something for you."],[7295,7454,"A Kashmir sapphire?"],[7820,8037,"I overheard you and Sunny talking about"],[8037,8275,"the jewelry design competition"],[8275,8579,"next month and I thought..."],[8579,8745,"Where did you even get this?"],[8745,8887,"They're over-mined."],[8887,9050,"Where I got it doesn't matter."],[9120,9237,"I just think your collection deserves"],[9237,9429,"a gem like that."]],"41":[[183,370,"This piece is by Scarlett Forester,"],[370,462,"designer from"],[462,633,"The Young Jewelry Design."],[633,866,"Crafted with rare Kashmir sapphire."],[925,1016,"But,"],[1058,1195,"it looks somewhat similar"],[1195,1325,"to the piece entered by"],[1325,1529,"Simmons Jewelry."],[1979,2183,"Allow me to introduce my piece."],[2183,2354,"It is entitled Princess."],[2383,2595,"It is encrusted with pink diamonds and"],[2595,2770,"a floral patterns,"],[2770,3083,"much like a cradled princess."],[3083,3358,"It represents my upbringing and..."],[3466,3737,"My insane creativity."],[3758,3879,"Very nice."],[3879,3991,"The concept merges well with"],[3991,4062,"the design."],[4237,4445,"Mrs. Scarlett Forester?"],[4833,5020,"No way this country bumpkin could"],[5020,5241,"win me over this time."],[5241,5375,"Listen,"],[5375,5587,"I completely understand envying"],[5587,5695,"my life,"],[5695,5845,"like of course."],[5866,5970,"But,"],[5970,6129,"why steal?"],[6216,6370,"Not again, Ruby."],[6708,6883,"My piece may share a slight"],[6883,7029,"resemblance to hers,"],[7029,7220,"but the concepts differ."],[7283,7395,"Mine's called Starlight"],[7395,7662,"and it's based on a childhood friend."],[7666,7745,"Scarlett,"],[7745,7912,"is this necklace meant for me?"],[7912,8112,"Ms. Ruby Winters used more"],[8112,8258,"bold lines in her design."],[8258,8445,"While I focused on slim metals"],[8445,8675,"for a light and area effect."],[8716,8950,"So how is that plagiarism?"],[8979,9066,"Even so,"],[9066,9220,"the similarity is striking."],[9275,9500,"One of you must be copying."]],"42":[[0,279,"One of you must be copying."],[437,525,"Well, I designed Starlight"],[525,625,"about a year ago,"],[625,775,"and there were certain people who"],[775,925,"saw the drafts."],[1004,1137,"But out of respect for this competition,"],[1137,1341,"I actually designed two pieces,"],[1379,1462,"and coincidentally,"],[1462,1616,"they both made it to the finals."],[1779,2037,"This is a snake-like chain designed"],[2037,2162,"to protect its wearer"],[2162,2400,"and shows a regal energy."],[2400,2475,"I call it"],[2475,2612,"Fearless Guardian,"],[2737,2887,"And it's based on someone who's"],[2887,3066,"always protected me."],[3362,3575,"There's also a starlight motif"],[3575,3666,"in the design."],[3875,4162,"Mrs. Forester's two designs show"],[4162,4341,"consistent style."],[4341,4554,"I believe they're genuinely"],[4554,4804,"her originals."],[5962,6041,"Oh my gosh,"],[6041,6125,"that was amazing!"],[6125,6187,"I have to go now,"],[6187,6337,"but accept my award if I get one."],[6337,6475,"Confident much?"],[6475,6541,"Well?"],[6541,6650,"You're becoming more and more"],[6650,6737,"like your Mr. Forester"],[6737,6879,"every day."],[6987,7154,"Scarlett, wait, honey,"],[7154,7229,"I need to talk to you."],[7229,7379,"Let's have dinner or something."],[7787,7916,"What a coincidence!"],[8079,8175,"You know you should invite me too,"],[8175,8241,"Mr. Simmons."],[8241,8429,"I'm her husband after all."]],"43":[[704,837,"Are you mad at me?"],[962,1075,"I wouldn't have gone to dinner with"],[1075,1279,"Carlton even if you hadn't shown up."],[1354,1475,"I'm not mad at all."],[1529,1700,"I'm elated."],[1787,1891,"Your fashion design."],[1891,2066,"It's about me, isn't it?"],[2162,2308,"I'm your Fearless Guardian."],[2308,2379,"Yes."],[3495,3600,"Fraud!"],[3600,3720,"Scarlett Forester!"],[3720,3883,"Give us our money back!"],[4200,4316,"You plagiarized"],[4316,4495,"Ruby Winters's designs."],[4529,4733,"We are high-end clients,"],[4733,4950,"and to think that we bought jewelry"],[4950,5079,"from a fraud?"],[5158,5345,"That's humiliating!"],[5387,5504,"I didn't plagiarize."],[5541,5691,"I already proved that."],[5833,5970,"You fooled the judges,"],[5970,6083,"but not us."],[6425,6620,"You tested positive for doping"],[6620,6775,"at a dance competition."],[6833,6979,"You are a disgrace."],[7520,7645,"Get lost, liar!"],[7925,8079,"Scarlett, I'll make sure that you never"],[8079,8254,"outrun the scandal,"],[8254,8391,"ever."],[8391,8545,"Disgraced fraud!"],[8545,8637,"Get out!"],[8654,8775,"Get out of here!"]],"44":[[33,183,"Get out of here!"],[725,812,"No I didn’t..."],[812,970,"I didn’t take stimulants."],[970,1070,"Mom, dad"],[1070,1316,"you have to believe me."],[1912,2016,"That's enough!"],[2433,2500,"Get out of the way."],[2745,2887,"I didn't do it."],[2925,3058,"You have to believe me."],[3170,3245,"Scarlett,"],[3245,3341,"I believe you."],[3583,3695,"Let's go."],[4400,4537,"Sir, the one you have searched for"],[4537,4841,"your whole life is Madam, right?"],[5116,5304,"Ivy only resembles her a little bit."],[5304,5445,"It's actually Ms. Ivy"],[5445,5537,"who looks like your wife,"],[5537,5725,"not the other way around."],[5916,6083,"She's one of a kind."],[6141,6237,"No one could replace her"],[6237,6325,"in my heart."]],"45":[[929,1066,"You heard what they said."],[1170,1333,"They said I plagiarized."],[1795,1920,"I only trust you."],[2020,2279,"And what about the stimulants?"],[2279,2400,"Like I said,"],[2400,2529,"I believe you."],[2912,2987,"Tell me what happened"],[2987,3112,"so I can help you."],[3179,3320,"Thank you for trusting me."],[3475,3595,"But everything happened,"],[3595,3666,"so long ago,"],[3666,3762,"I don't think there's anything"],[3762,3908,"we can do about it now."],[4058,4237,"It was at my last dance competition."],[4237,4308,"Someone put something"],[4308,4412,"in my drink."],[4441,4629,"I think it was my teacher,"],[4629,4720,"Lillian."],[4775,4854,"And since then"],[4854,5104,"I've never danced again."],[5237,5325,"The truth may be late,"],[5325,5495,"but it will come,"],[5495,5595,"I promise."],[5875,6054,"But for now get some rest."],[6870,7004,"Let's start from the beginning."],[7066,7229,"You better tell me the truth,"],[7279,7408,"because I'm not playing games."],[7408,7562,"I am telling you the truth."],[7637,7908,"Scarlett Winters tested positive."],[7991,8291,"Didn't you give her that glass of water?"],[8358,8475,"Because you ruined"],[8475,8637,"an innocent girl's life!"],[8866,8995,"You’re trying to force a confession"],[8995,9079,"out of me?"],[9079,9191,"Possibly."],[9191,9329,"I'm not a gentleman."],[9329,9437,"You will see."]],"46":[[1491,1662,"You...what did you do?"],[1733,1845,"Nothing."],[1845,1958,"But you..."],[2029,2250,"There is a bloody hand on the door."],[2325,2504,"Are you afraid I killed someone?"],[3312,3529,"Why so tense?"],[5266,5404,"Will you forget me?"],[5404,5504,"Never, Scarlett."],[5504,5633,"Let's pinky promise."],[6095,6200,"I’ll come back for you."],[6200,6316,"We'll watch the snow fall"],[6316,6525,"while stargazing together."],[6545,6679,"You better not be lying."],[6679,6825,"The stars are watching."],[6975,7104,"I would never lie to you."],[7104,7312,"The stars are our witness."],[7662,7845,"Why am I still dreaming of him?"],[7975,8095,"Leo?"],[8195,8279,"Leo."],[9095,9237,"I drew it last night."],[9320,9400,"Do you like it?"],[9437,9604,"I never told you about any of this."],[9879,10162,"Who are you really?"]],"47":[[8,87,"Who are you?"],[566,704,"I'm your husband."],[704,791,"Unless you want me to be"],[791,875,"someone else."],[875,987,"But you clearly..."],[1737,1854,"Hi Sunny, what's up?"],[1883,1979,"Good news!"],[1979,2120,"Lillian publicly confessed."],[2120,2237,"She was the one who slipped that"],[2237,2408,"stimulant into your drink back then."],[2408,2516,"Those fake customers who"],[2516,2604,"insult you,"],[2604,2679,"they've been caught."],[2679,2854,"They admitted Ruby paid them to do it."],[2854,2983,"You cleared your name."],[4820,4891,"Oh my God."],[4891,5025,"Are you trying to poison me?"],[5025,5116,"You trying to poison me!"],[5116,5175,"Help!"],[5175,5258,"Somebody help me!"],[5258,5320,"Hey,"],[5320,5408,"don't worry,"],[5408,5520,"it's not for you."],[5775,5875,"This is your daughter though,"],[5875,5983,"correct?"],[5983,6025,"No."],[6266,6325,"I hear she has"],[6325,6495,"a competition tomorrow."],[6495,6604,"I visited her today."],[6604,6775,"She dances really well."],[6912,7020,"But don't worry,"],[7020,7170,"I'm going to give her this cup."],[7258,7379,"It's not poison."],[7504,7708,"It just has a massive dose"],[7708,7925,"of the same stimulant"],[7925,8037,"that you gave Scarlett."],[8079,8162,"No!"],[8204,8275,"No!"]],"48":[[104,162,"Damn it!"],[162,275,"Ruby!"],[587,762,"Carlton, Carlton wait!"],[762,854,"Wait, I was trying to help..."],[854,929,"Just stop!"],[929,1062,"I never ever told you"],[1062,1262,"to do anything so shameless."],[1416,1466,"You know, Ruby,"],[1466,1616,"you always look at Scarlett"],[1616,1854,"as being this country bumpkin."],[1854,1925,"Why don't you fucking look at"],[1925,2037,"yourself?"],[2037,2162,"Because you are the one acting like"],[2162,2304,"a piece of trash right now."],[2329,2416,"I'm done."],[2416,2579,"Car...Carlton, Carlton!"],[2579,2679,"Carlton please!"],[2679,2766,"No."],[3450,3575,"So Lillian's confession was"],[3575,3700,"arranged by you?"],[3766,3841,"I'm sorry."],[3841,3975,"Maybe..."],[4029,4187,"I'm sorry."],[4666,4750,"Thank you."],[5079,5312,"I don't need a formal thanks but..."],[5441,5516,"Just talk to me."],[5516,5650,"I'm here for you."]],"49":[[8,145,"Whatever you need, just tell me."],[145,262,"I'm here for you."],[262,437,"Ruby, my ex-fiance,"],[437,650,"even my parents"],[720,875,"hate me."],[945,1150,"All my life I've been unwanted."],[1254,1379,"And if I hadn't met you,"],[1379,1512,"I would've thought that I didn't deserve"],[1512,1625,"to be loved."],[1679,1833,"You don't need their approval."],[1891,1962,"Just because they don't see"],[1962,2191,"your worth doesn't mean it's not there."],[2245,2429,"You deserve the best in the world."],[3329,3516,"So you just realized"],[3516,3687,"you love Leo Forester?"],[3687,3841,"I mean we have a contract marriage."],[3841,3908,"I even put a two-year"],[3908,4000,"time limit on it."],[4000,4154,"Oh, so you regret it?"],[4154,4187,"I mean,"],[4187,4395,"then just tell him to tear up the contract."],[5237,5395,"What's up?"],[5395,5479,"It's Ruby."]],"50":[[45,162,"It's Ruby."],[225,350,"She said she wants to see me"],[350,479,"one last time."],[554,666,"You don't think she's..."],[666,800,"thinking another suicide attempt,"],[800,862,"do you?"],[862,1058,"She would never harm herself."],[1058,1154,"You cannot go."],[1400,1600,"I have to go at least check on her."],[1745,1829,"I'll be fine."],[2575,2725,"Ruby, I'm here."],[2812,2966,"Stop talking and getting into car"],[2966,3120,"before I gut you like a pig."],[3470,3570,"Don't worry,"],[3570,3783,"I'm not going to hide your body."],[3783,3875,"I'm going to leave it out there"],[3875,4033,"in the open for Carlton to find,"],[4033,4220,"and he can see a pretty little face"],[4220,4454,"all carved like the fucking pieces."],[4454,4512,"Please!"],[4545,4670,"Please!"]],"51":[[125,316,"Go ahead, cry! Beg!"],[316,504,"See if it makes a fucking difference!"],[504,579,"Please!"],[695,791,"Come on, get out."],[2145,2225,"Are you alright?"],[3279,3379,"Would you like me to go after her?"],[3429,3529,"She won't get far."],[3566,3650,"Let's go home."],[4029,4200,"Did Sunny tell you where I was?"],[4212,4283,"No."],[4312,4395,"Leo,"],[4512,4608,"are you angry?"],[5754,5837,"What are you doing?"],[5962,6066,"Ben, start the car."],[6158,6179,"No."],[6179,6400,"Leo, please! Let me explain."],[6400,6566,"I told you to stay away from"],[6566,6662,"people like this."],[6679,6800,"Why risk your life?"]],"52":[[41,91,"No."],[1554,1679,"Please don't be mad."],[1775,1879,"Of course I'm mad"],[1954,2016,"at myself,"],[2016,2158,"for thinking you'd stop putting yourself"],[2158,2220,"in danger."],[2387,2466,"Promise me,"],[2529,2625,"you won't do this again."],[2750,2829,"Alright."],[3462,3541,"Ruby."],[3608,3716,"She was just"],[3758,3891,"messing around, she was never"],[3891,3983,"gonna hurt you."],[3987,4116,"Please do not take this to"],[4116,4220,"the authorities."],[4220,4354,"Say it for the station."],[4362,4437,"Now, move aside."],[4437,4529,"No, Scarlett!"],[4654,4825,"I am begging you as your father."],[5004,5141,"Why couldn't you beg Ruby"],[5262,5362,"and spare Scarlett?"],[5433,5558,"If I would have shown up any later,"],[5558,5650,"she would have died,"],[5716,5833,"and you would have been left with a"],[5833,5958,"murder as a daughter."]],"53":[[162,250,"I wouldn't have done that."],[1033,1133,"Is this what you want?"],[1275,1354,"Look, just"],[1420,1579,"please don't do this."],[1804,1883,"Fine."],[1950,2033,"Just stand up."],[2525,2604,"Thank you."],[2658,2737,"Come on, Ruby."],[2808,2887,"Wait."],[3008,3100,"Leo, that's enough."],[3258,3508,"She's never to return to this city."],[3612,3804,"I won't let Scarlett's compassion"],[3875,3962,"to get her hurt again."],[4112,4179,"No! No!"],[4179,4362,"I have to marry Carlton Simmons."],[4362,4525,"Do you think the Simmons family is"],[4525,4562,"gone to want you"],[4562,4683,"for what you just did?"],[4795,4875,"Dad."],[5479,5537,"Hey."]],"54":[[512,650,"Are you trying to get on my good side?"],[650,737,"Yes."],[1237,1345,"What are you doing?"],[1512,1650,"Punishing you."],[1829,1958,"You admit you're wrong,"],[1958,2091,"and I decide the penalty."],[2141,2229,"Okay."],[2525,2658,"Just please don't be mad at me."],[2666,2791,"I'm not mad."],[2829,3004,"I'm just terrified of losing you."],[3575,3675,"You should get some rest."],[3675,3800,"I’m going to take a shower."],[4045,4145,"I can shower with you."],[4350,4483,"Hey, are you alright?"],[4512,4666,"Do you want me stay with you a little"],[4666,4729,"while longer?"],[4883,4962,"No."],[5079,5158,"Hey,"],[5220,5362,"don't be afraid. It's okay."],[5620,5700,"I'll be right out."],[5983,6150,"We haven't made love in a while."],[6150,6316,"Does he not want me anymore?"]],"55":[[183,387,"Control yourself. Before Scarlett falls"],[387,437,"for you,"],[437,612,"you must respect her! Hold back!"],[612,725,"Hold back!"],[1000,1100,"Do you want to end it?"],[1229,1308,"Huh?"],[1441,1566,"You promised me a real marriage,"],[1566,1745,"but you haven't touched me in days."],[2245,2362,"Do you want to call it off?"],[2558,2637,"Scarlett,"],[2725,2883,"I promise you I'd never force you."],[3037,3116,"But I want it."],[3300,3416,"I want you to force me."],[5162,5316,"Miss Ivy is missing!"]],"56":[[120,337,"Miss Ivy really looks like the madam."],[345,658,"Wrong. Madam looks like Miss Ivy."],[712,854,"She's just a stand in."],[1004,1145,"So if Miss Ivy's back,"],[1145,1287,"then the madam might have to"],[1287,1375,"step aside?"],[1387,1487,"Of course."],[1550,1800,"Mr. Forester and Ivy go way back"],[1858,2008,"childhood sweethearts."],[2129,2416,"A substitute is still a substitute."],[2487,2633,"So the reason he married me at first"],[2633,2825,"sight is because I look like Ivy."],[3241,3320,"Hello?"],[3508,3616,"Leo's been injured?"],[4083,4195,"Doctor, he's awake!"],[4479,4704,"Great. Well, I'll go ahead and change"],[4704,4800,"his medication."],[4800,4900,"And Mrs. Forester,"],[4933,5054,"you can rest easy now."],[5383,5508,"Mrs. Forester?"]],"57":[[16,141,"Mrs. Forester?"],[216,333,"Leo was"],[454,645,"hurt saving me and collapsed."],[645,845,"It was urgent, so I handled it."],[916,1066,"I hope that's okay..."],[1120,1225,"Mrs. Forester."],[1279,1333,"Well,"],[1333,1412,"it's done now."],[1533,1708,"All that matters is that he's alive."],[1812,1925,"Can you give us a minute?"],[2020,2116,"I see his mom gave you the"],[2116,2204,"heirloom ring."],[2229,2312,"Don't worry,"],[2312,2420,"It'll be mine soon."],[2820,2900,"Scarlett..."],[3750,3829,"You're mine."],[3941,4020,"What?"],[4079,4162,"You're not allowed"],[4162,4283,"to risk your life for anybody else"],[4283,4350,"but me."],[4479,4612,"I like when you're bossy."],[4712,4766,"What you think"],[4766,4887,"you're the only one who's allowed"],[4887,4979,"to be bossy?"],[5179,5375,"If I wasn't for this hospital bed,"],[5375,5458,"I don't think I'd be able to"],[5458,5562,"control myself."],[6312,6508,"Finally, I'm getting discharged!"],[6529,6704,"It's okay. Scarlett can help me."],[7245,7341,"That necklace..."],[7341,7525,"it matches the snowflake bracelet I"],[7525,7662,"saw in Leo's bedroom."],[7700,7929,"Could she really be Leo's first love?"],[8012,8250,"Exactly. She's seen that bracelet before."],[8295,8416,"Back off bitch."],[8416,8579,"No one can steal him from me."]],"58":[[1304,1383,"It's a gift"],[1462,1587,"that I never got to give..."],[1720,1816,"My first love"],[1858,1954,"when I was a child."],[2020,2229,"Ivy must really be his first love..."],[2579,2658,"Are you okay?"],[2741,2841,"Give me the first-aid kit!"],[3262,3341,"Thank you."],[4179,4358,"If he only sees me as a stand in,"],[4395,4533,"why is he so caring?"],[5191,5395,"Where does it hurt? I'll kiss it better."],[5545,5683,"Sorry, did I hurt you?"],[5875,6000,"Save your tears."],[6029,6154,"There's plenty more to come."],[6562,6775,"Come on. Stop assuming the worst."],[6816,6958,"If you don't trust him, just tell him."],[6958,7229,"But I swear, Leo only loves you."],[7854,7933,"Is that..."],[7979,8058,"Leo?"]],"59":[[1045,1195,"I'm done being naive."],[1350,1479,"Leo, you're a liar."],[2608,2687,"Here."],[3266,3350,"Here."],[3362,3445,"Have this."],[3600,3754,"Scarlett, eat this. You'll love it."],[3987,4087,"Is he pretending last night"],[4087,4179,"never happened?"],[5095,5275,"I'm sorry you had to wait for me."],[5329,5420,"But you should eat."],[5420,5525,"I didn't wait for you."],[5612,5741,"Don't flatter yourself!"],[5750,5912,"I'm sorry. Don't be mad."],[5950,6108,"I promise I won't be working late tonight."],[6316,6362,"Don't worry."],[6362,6479,"There's only a year left in this"],[6479,6608,"contract marriage."],[6766,6958,"So just try to endure it a little bit longer,"],[6958,7025,"Mr. Forester."],[7025,7150,"Then you won't have to agonize"],[7150,7200,"over it anymore."]],"60":[[108,295,"What am I even agonizing about?"],[295,433,"I don't want this to end with you!"],[495,604,"Where were you yesterday?"],[900,1000,"I had a zoom meeting."],[1041,1225,"Different time zones, so it ran late."],[1408,1516,"You weren't with Ivy"],[1583,1662,"at 3 PM?"],[1762,1862,"I swear I wasn't."],[2000,2150,"Could I have mistaken someone"],[2150,2241,"else for him?"],[3112,3187,"Tomorrow I'm holding an"],[3187,3287,"art exhibit,"],[3412,3612,"and since I credit Leo here with my"],[3612,3733,"success in art,"],[3733,3850,"I want you both to be there!"],[3920,4079,"I'm not free tomorrow."],[4179,4316,"Well. Then Mrs. Forester"],[4316,4387,"should come."],[4425,4512,"I'll see you tomorrow!"],[4700,4858,"Ivy, quick question for you."],[4895,5112,"Were we together at 3PM yesterday?"],[5483,5562,"No."],[5762,5875,"Then what about my car?"],[5916,6112,"I used it to prep for the art show."],[6166,6275,"I hope you're not mad."],[6312,6391,"No."],[6400,6479,"See you tomorrow."],[7079,7179,"I was wrong."],[7266,7400,"And what were you wrong about?"],[7683,7783,"Didn't trust you."],[8616,8737,"Don't let it happen again."]],"61":[[262,445,"Mrs. Forster! You came!"],[537,629,"And who's this?"],[662,804,"This is my best friend, Sunny."],[866,1095,"I've seen you before, right?"],[1104,1262,"Stepping out of Leo's car with"],[1262,1308,"someone who"],[1308,1475,"oddly looked a lot like him."],[1504,1604,"You did that on purpose,"],[1604,1675,"didn't you?"],[1850,1979,"So you came here to stand up for"],[1979,2041,"Scarlett?"],[2129,2291,"Just don't pin something on me I"],[2291,2362,"didn't do."],[2404,2558,"Whether it's true or not doesn't matter."],[2558,2725,"But what does matter is that"],[2725,2808,"you never"],[2808,2937,"mess with my friend again."],[2975,3054,"Got it?"],[3566,3650,"Scarlett!"],[4212,4295,"Sunny!"],[4337,4500,"Your family doesn't care about you..."],[4575,4662,"but I do."],[4700,4779,"No!"],[4816,5000,"No! Somebody help!"],[5391,5470,"Leo,"],[5562,5754,"Sunny's hurt and it's all my fault!"],[5754,5841,"No. It's okay."],[5887,6008,"I have the best surgeons around."],[6008,6087,"She'll pull through."],[6137,6258,"Mrs. Forester, thank goodness"],[6258,6341,"you’re fine..."],[6612,6754,"Bitch!"],[6825,6937,"Scarlett."],[6962,7220,"You bitch! I know you set this up!"]],"62":[[4,287,"You bitch! I know you set this up"],[287,400,"didn't you?"],[454,650,"Mrs. Forester, how dare you accuse"],[650,750,"me of something like this?"],[750,900,"The art gallery had strict security."],[900,1029,"There's nobody that got in there without"],[1029,1112,"an invitation."],[1150,1337,"That person came out of nowhere!"],[1337,1475,"How could you blame me?"],[1729,1812,"Yeah, maybe..."],[1812,1950,"Maybe this is my fault."],[2041,2175,"Maybe if I hadn't invited you and her,"],[2175,2312,"this would never have happened."],[2337,2425,"Cut the act, Ivy."],[2425,2537,"Nobody's buying it."],[2675,2829,"I will find out who hurt Sunny"],[2829,3012,"and I will make them pay!"],[3204,3337,"Very good, Scarlett."],[3341,3475,"The more impulsive you are,"],[3475,3650,"the stronger my advantage."],[4062,4150,"Scarlett."],[4262,4341,"Scarlett."],[4387,4500,"No matter how upset you are,"],[4500,4616,"you can't let it consume you."],[4625,4800,"You have to take care of yourself."],[4800,4891,"It has to be Ivy!"],[5250,5375,"She has no motive."],[5475,5604,"I mean she doesn't even know Sunny."],[5604,5737,"She is targeting me."],[5900,6100,"You really can't see that she likes you?"],[6579,6712,"We have no evidence."],[6712,6825,"You don't believe me?"],[7050,7191,"I do. I do believe you."],[7212,7362,"You always said that if anyone ever"],[7362,7412,"bullied me,"],[7412,7512,"you wouldn't spare them."],[7600,7725,"It's easy for you to punish them"],[7725,7875,"but I guess it's just as easy to let them"],[7875,7937,"get away."],[8229,8350,"If it really is her,"],[8400,8550,"I won't let her escape justice."],[8675,8762,"I promise."],[10862,10958,"What are you doing?"]],"63":[[0,100,"What are you doing?"],[237,345,"Mrs. Forester,"],[383,504,"you've had a tough day."],[504,637,"I just wanted to bring you some"],[637,666,"rose tea"],[666,779,"to help you relax."],[783,904,"I'm not really in the mood to drink"],[904,962,"anything right now."],[1104,1183,"Come on."],[1204,1345,"Just take a sip it'll make you feel so"],[1345,1420,"much better,"],[1450,1529,"trust me."],[2333,2412,"What's that?"],[2983,3229,"Take this to the lab to get tested and"],[3229,3358,"call Mr. Forester."],[3679,3758,"Vee,"],[3808,3916,"tell me the truth!"],[3933,4108,"There were just some herbs to calm"],[4108,4200,"her nerves."],[4308,4441,"Bro, do you really trust her"],[4441,4604,"so much that you would doubt me?"],[4679,4762,"Hello?"],[5050,5129,"It wasn't poison."],[5270,5475,"It just a sedative."],[5475,5608,"Bro, I've lived in your family house"],[5608,5704,"since I was little."],[5708,5854,"And you still don't trust me."],[5854,5945,"Listen, I don't know"],[5945,6062,"what you are planning,"],[6120,6220,"but it isn't over."],[6337,6512,"All I want is for you to keep"],[6512,6641,"looking paranoid."],[6666,6845,"Then no one will believe you."],[6858,7062,"That's enough! Mrs. Forester,"],[7062,7204,"you should learn to trust people."],[7204,7375,"I'd never harm anyone."],[7612,7787,"By the way... I'm pregnant."]],"64":[[75,216,"Doctor, is Sunny awake yet?"],[450,662,"Okay. Well, just please take good"],[662,791,"care of her when she wakes up."],[991,1100,"So, how's your friend?"],[1204,1350,"Have you found her attacker yet?"],[1391,1475,"Don't play dumb."],[1587,1691,"I know it was you."],[1791,1891,"You want me gone so you can"],[1891,1991,"take my place."],[2075,2187,"But you didn't expect Sunny to"],[2187,2325,"protect me, did you?"],[2525,2650,"I don't know what you're talking about."],[2725,3062,"But you better find the culprit, because"],[3091,3212,"otherwise your precious friend"],[3212,3287,"might not"],[3341,3504,"be safe for much longer."],[3575,3662,"Shut up!"],[4200,4237,"Shit."],[4275,4362,"What happened?"],[4391,4500,"My baby..."],[4650,4850,"Mrs. Forester, why?"],[5341,5475,"My child's gone now."],[5537,5650,"Are you satisfied?"],[5737,5879,"I never laid a hand on you."],[5962,6125,"Leo, if you want to believe her"],[6125,6262,"I won't argue."],[6300,6425,"But there were only two of us"],[6425,6512,"on the stairs."],[6704,6816,"Why would I harm my own baby?"],[6929,7062,"Only you can answer that."],[7425,7500,"Scarlett?"],[7662,7733,"Scarlett!"]],"65":[[187,266,"Scarlett."],[462,545,"Hey."],[625,737,"The doctor said"],[737,858,"you were coughing up blood from"],[858,987,"emotional stress,"],[1004,1225,"and... you're two months pregnant."],[1500,1579,"Pregnant?"],[2200,2237,"Scarlett,"],[2237,2341,"I know you're upset about what"],[2341,2450,"happened to Sunny,"],[2541,2637,"but the doctor said you need to"],[2637,2704,"calm down."],[2766,2937,"For the baby's sake, you gotta stop"],[2937,3029,"skipping meals."],[3237,3391,"So Ivy told you that I pushed her down"],[3391,3483,"the stairs,"],[3600,3783,"and you're taking her side in this?"],[3983,4066,"That's good to know."],[4204,4262,"It got out of hand."],[4262,4366,"Do you believe me or not?"],[4395,4475,"Of course I do."],[4516,4616,"Do you believe that Ivy"],[4616,4783,"hired the man that stabbed Sunny?"],[4812,4929,"We need more evidence."],[4979,5162,"Then why aren't you investigating?"],[5304,5391,"Where is your support"],[5391,5437,"in all of this?"],[5437,5579,"I can't do anything about it."],[5637,5762,"Sunny's in a coma,"],[5787,5954,"and the killers just out there!"],[6108,6225,"You're pregnant."],[6225,6325,"You're not well right now."],[6400,6550,"Please, you have to eat."],[6550,6600,"No."],[6600,6654,"Then I'm just not"],[6654,6695,"going to eat."],[7416,7579,"Stop! What are you doing?"],[7600,7729,"If you keep refusing to eat,"],[7729,7845,"I'm gonna feed you like that every"],[7845,7908,"single day."],[8020,8145,"Leo Forester..."],[8229,8337,"I want a divorce."]],"66":[[83,200,"I want a divorce."],[475,525,"We've"],[525,662,"rushed into this,"],[695,812,"this contract."],[879,1062,"You're taking Ivy siding in this and"],[1062,1087,"that's fine."],[1087,1200,"I mean I get it."],[1279,1370,"You’ve known her way longer than"],[1370,1466,"you know me…"],[1729,1808,"Scarlett,"],[1929,2129,"I love you. And I'm not gonna leave."],[2179,2258,"Please,"],[2333,2487,"give me time to find the truth."],[2666,2787,"Baby, don't worry..."],[2808,2995,"I'll raise you myself if I must."],[3145,3345,"Who are you? And what do you want?"],[3475,3587,"I have a proposition."],[3695,3895,"Or let's say I'm handing you a"],[3895,4016,"chance of revenge"],[4100,4204,"on Scarlett Winters."],[4395,4575,"You know you look a lot like her,"],[4600,4720,"but not really."],[4720,4937,"You can see the ambition streaming"],[4937,5045,"across your face."],[5250,5354,"Which is why I won't end up"],[5354,5425,"like you"],[5508,5608,"knocked down,"],[5679,5912,"banished here, left with nothing."],[6512,6595,"This card"],[6783,6887,"can make your life better."],[7112,7195,"What do you want me to do?"],[7295,7420,"I want you to kill Scarlett."],[7608,7691,"Do you got the nerve?"]],"67":[[225,304,"Scarlett?"],[450,650,"Scarlett, why are you here?"],[725,812,"Ever since you met me"],[812,925,"you were thinking about hurting me,"],[925,962,"weren't you?"],[1125,1329,"That day, I saved you."],[1412,1554,"I helped you deal with that drunk,"],[1554,1637,"remember?"],[1691,1775,"If it wasn't for you,"],[1775,1816,"that drunk"],[1816,1929,"would've never been in the bar in"],[1929,2016,"the first place."],[2329,2475,"Without proof, no one's gonna believe"],[2475,2575,"a word you say."],[2625,2779,"And don't you get it yet?"],[2779,2837,"Oh, I get it."],[2962,3150,"You used every single dirty trick in"],[3150,3191,"the book"],[3191,3325,"to try to push me out."],[3375,3450,"One people over,"],[3450,3612,"bit by bit, so that they would think"],[3612,3725,"that I was lying."],[3775,3875,"And then you pulled the whole"],[3891,4029,"pushed yourself down the staircase"],[4029,4262,"and you pinned it on me, didn't you?"],[4275,4462,"Exactly. Which is why everyone's"],[4462,4575,"convinced now,"],[4575,4687,"that you attacked me over"],[4687,4775,"Sunny's injury,"],[4850,5062,"and yet you pushed me,"],[5141,5300,"and you can't explain otherwise."]],"68":[[87,200,"But I can explain!"],[283,425,"She paid me to kill you."],[562,675,"Just because I'm an enemy of"],[675,716,"your enemy"],[716,816,"doesn't mean that we're automatically"],[816,908,"friends."],[1437,1566,"You made the wrong call."],[1600,1729,"I never wanted money. I wanted a"],[1729,1858,"chance into the city."],[1929,2045,"A chance to see Carlton again."],[2341,2420,"Only her and her husband"],[2420,2562,"are the ones that can give that to me."],[2758,2920,"Scarlett, don't get smug."],[3025,3200,"You still have no clue who he really"],[3200,3300,"is, do you?"],[3433,3550,"Ridiculous!"],[3758,3912,"He's been lying to you since day one,"],[3975,4120,"because he never planned to keep"],[4120,4212,"you forever."],[4283,4362,"Leo would never lie to me!"],[4479,4616,"Let me show you some facts!"],[4895,5120,"Mr. Forester, we've found the person"],[5120,5204,"who hurt Sunny."],[5516,5758,"The mastermind is Miss Ivy."],[5908,6000,"Hello Leo,"],[6066,6216,"thinking of me even at work?"]],"69":[[37,187,"Thinking of me even at work."],[425,575,"Ivy, what are you plotting this time?"],[679,887,"I just wanted Mrs. Forester to see the"],[887,954,"truth-"],[1062,1337,"that you're the almighty CEO of the"],[1337,1450,"Forester Group."],[1662,1775,"You're the CEO?"],[1900,2062,"You told me you just worked here."],[2104,2237,"You see, Mrs. Forester? He's"],[2237,2387,"been lying from the start."],[2441,2650,"This little contract marriage of yours is"],[2650,2725,"a joke."],[2725,2816,"Ivy, shut up!"],[2954,3050,"Scarlett,"],[3175,3275,"let me explain."],[3300,3462,"You promised me never lie to me."],[3600,3687,"It seems you linked the gallery"],[3687,3775,"attack to me."],[4037,4254,"You won't arrest me, will you bro?"],[4362,4512,"Because you can't understand my"],[4512,4612,"bond with Leo."],[5104,5191,"Scarlett, wait."],[5462,5612,"Did you think I would help you after"],[5612,5700,"everything you have done?"],[5725,5987,"Don't forget the bullet my father"],[5987,6100,"took for yours."],[6200,6275,"Do you recall the oath"],[6275,6362,"your father took:"],[6429,6654,"The Foresters will always protect Ivy,"],[6729,6825,"or let all fortunes"],[6825,7062,"turned to dust and my son's joy to"],[7062,7129,"ashes."],[7129,7337,"Even if I crumble to ashes,"],[7412,7537,"I will never forgive anyone"],[7575,7662,"that hurts her."],[7762,7929,"Ben, call the police."],[8462,8591,"Scarlett."],[8891,8966,"Scarlett."]],"70":[[362,441,"Drink."],[575,683,"I would but I wouldn't want to"],[683,875,"bother the CEO of Forester."],[962,1054,"Scarlett, I..."],[1637,1716,"I'm sorry."],[1745,1941,"I can stay in here all night. Let it all out."],[2116,2254,"Let's just end this."],[2362,2504,"I'll pay whatever penalty."],[3504,3608,"I can stay with you all night,"],[3675,3754,"let it out."],[3950,4033,"We should end this."],[4179,4275,"Let's end this contract I'll pay"],[4275,4379,"whatever penalty."],[4508,4600,"Scarlett,"],[4637,4779,"I wasn't trying to deceive you."],[4879,5058,"I mean if I told you I was the CEO"],[5066,5183,"from the moment we met, would you"],[5183,5225,"stay?"],[5225,5279,"No."],[5341,5433,"Then please forgive me."],[5504,5629,"I only wanted to be with you."],[5741,5845,"I'm not worthy of"],[5845,5995,"the CEO of Forester."],[6520,6600,"Scarlett..."],[6629,6737,"for the baby's sake,"],[6862,7008,"please give me another chance."],[7816,8025,"\"The Foresters will always protect Ivy,"],[8054,8179,"or let all fortunes"],[8183,8495,"turn to dust and my son's joy to ashes.\""],[8579,8700,"Leo Forester, if you"],[8704,8858,"dare break your vow and throw me"],[8858,8933,"in prison,"],[8962,9133,"know that I've already broken out-"],[9187,9333,"and I'll burn your entire world"],[9333,9416,"to ashes!"]],"71":[[579,662,"Scarlett..."],[854,950,"Please wake up."],[1108,1258,"There's so much I have to tell you."],[1395,1487,"What's this?"],[1616,1866,"It's a gift that I never got to give."],[2237,2316,"What was it for?"],[2483,2579,"My first love."],[2750,2837,"When I was a child."],[3062,3183,"I know your childhood was full"],[3183,3275,"of darkness,"],[3300,3462,"you forgot so many things."],[3462,3558,"I wanted you to remember me on"],[3558,3625,"your own."],[3645,3745,"But I can't wait any longer."],[3745,3862,"I must tell you."],[3941,4004,"We've known each other"],[4004,4079,"since we were kids,"],[4079,4237,"and I've loved you ever since then."],[4545,4641,"Scarlett..."],[4716,4812,"Scarlett, you are awake."],[4883,4979,"I need to tell you."],[5100,5179,"Leo..."],[5583,5683,"I want a divorce."],[5725,5858,"Scarlett, why? What?"]],"72":[[25,112,"Leo, you're the"],[262,404,"CEO of Forester."],[579,675,"Your life is never going to be"],[675,750,"peaceful."],[941,1075,"I mean look what Ivy did."],[1175,1237,"Tomorrow, it's gonna be"],[1237,1337,"somebody else."],[1562,1654,"I have to deal with it."],[1779,1950,"That's what I have to do."],[1987,2141,"What's best for the child."],[2279,2537,"I swear I can protect you both."],[2775,2900,"I've made up my mind..."],[3312,3404,"If only I hadn't"],[3404,3537,"run from my wedding and fall in"],[3537,3637,"front of your car..."],[4516,4600,"Sir,"],[4654,4741,"why don't you tell her about the bracelet,"],[4741,4825,"bracelet,"],[4850,4975,"and your shared past?"],[5112,5241,"She's already made her decision"],[5241,5425,"I can't change that."],[5554,5712,"But you love her so dearly..."],[5979,6108,"I respect her choice."]],"73":[[387,516,"Hi sweetie!"],[516,687,"Auntie Sunny!"],[779,916,"You're so big."],[916,1008,"Where's your mom?"],[1179,1262,"Sunny?"],[1462,1608,"What brings you here?"],[1800,1962,"I'm here to invite an acclaimed designer"],[1962,2041,"to my wedding,"],[2041,2175,"and Ollie too!"],[2258,2337,"Who's the groom?"],[2395,2479,"You'll find out."],[2712,2879,"Sunny, why am I in a wedding dress?"],[2879,3012,"You're the one getting married!"],[3012,3216,"We're best friends."],[3216,3370,"If I'm getting married, then so are"],[3370,3425,"you!"],[3425,3475,"Okay."],[3475,3604,"Don't be silly."],[3629,3762,"Who am I going to marry?"],[4229,4312,"Is it him?"],[4345,4558,"No. He's my groom."],[4587,4650,"Mine!"],[4650,4733,"Hi."],[4991,5070,"Ben..."],[5162,5262,"It's been a while."],[5454,5708,"Your groom made this for you."],[6208,6287,"Leo?"]],"74":[[12,62,"You told me about"],[62,175,"this recurring dream,"],[200,312,"you as a child,"],[312,479,"stargazing with a boy who promised"],[479,600,"to protect you, and"],[600,737,"watch the stars in the snow with you"],[737,812,"someday."],[962,1200,"That boy was Leo Forester."],[1300,1429,"He never forgot you."],[1429,1687,"He made that for you, and he painted"],[1687,1850,"this for you."],[1916,2004,"When he was young,"],[2004,2175,"the Forester Group's rivals hired"],[2175,2362,"criminals to get rid of his family."],[2462,2579,"In order to keep him safe,"],[2579,2725,"they hid him out in the countryside."],[2725,2866,"But when he came back, he searched"],[2866,3025,"everywhere for you."],[3137,3262,"And the day you fled that wedding,"],[3262,3379,"the moment he saw you,"],[3379,3475,"he recognized you."],[3700,3787,"He's always hoped that"],[3787,3875,"you would remember."],[4054,4212,"He's the one who vowed to protect me"],[4212,4325,"me since we were little."],[4475,4550,"But..."],[5254,5450,"I know you mean well, but"],[5662,5779,"I can't have Ollie dragged"],[5779,5900,"back to danger."],[5950,6062,"So I think I have to"],[6200,6316,"run from my wedding again."]],"75":[[1183,1262,"You okay?"],[2158,2237,"Excuse me,"],[2550,2629,"do you need help?"],[2995,3137,"You almost knocked us down,"],[3137,3200,"how does that help?"],[3241,3304,"I’m sorry."],[3458,3608,"Let's talk compensation."],[4095,4179,"Will you marry me?"],[4341,4475,"Scarlett... I know you fear"],[4520,4620,"for Ollie's safety."],[4729,4900,"That's why I sold all my shares."],[5012,5070,"I'm no longer"],[5070,5179,"President Forester."],[5304,5395,"I'm just Leo,"],[5533,5645,"a man who loves you,"],[5695,5900,"and a father who loves Ollie."],[7754,7858,"It was you, Leo."],[7862,7962,"It was always you."],[8087,8195,"You were the one protecting me all"],[8195,8287,"those years."],[8345,8425,"Scarlett,"],[8487,8575,"from beginning to end,"],[8575,8641,"it was always you."],[8729,8808,"And only you."]]}