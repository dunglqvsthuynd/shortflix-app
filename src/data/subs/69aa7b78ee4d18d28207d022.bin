{"1":[[50,263,"I am the heiress of the Eclipse Pack,"],[263,563,"and today is my 18th birthday."],[613,677,"Aria,"],[864,1092,"these are our pack's heirlooms."],[1151,1321,"They represent our commitment to you."],[1344,1448,"Your choice represents"],[1448,1564,"whom you're gonna marry."],[2869,3006,"This engagement was arranged for me"],[3006,3129,"since I was a child."],[3159,3309,"At the end of my 18th birthday,"],[3453,3593,"I'll choose my Alpha."],[3833,4080,"Happy birthday to you."],[4080,4227,"Oh, that must be Adrian and Julian."],[4264,4441,"I bet they have the best surprise."],[4551,4644,"Coming!"],[5648,6139,"Happy birthday to you."],[6179,6609,"Happy birthday, dear..."],[6690,6913,"Selena."],[7000,7464,"Happy birthday to you."],[7500,7694,"Happy 40th birthday, Selena."],[7941,8024,"How could I forget"],[8024,8214,"everything changed since that day?"],[8348,8435,"Aria?"],[8942,9082,"I'm sorry to tell you this,"],[9295,9516,"but Selena's our real mate."],[9936,10213,"Guys, I've just awakened my wolf."],[10213,10330,"Let's celebrate."],[10330,10457,"You have to celebrate by yourself."],[10457,10540,"Selena's sick."],[10623,10687,"I'm sorry."],[11564,11785,"Today is also Miss Greenfield's birthday."],[11808,12015,"How could I forget it's Aria's birthday?"],[12018,12145,"Well, it's..."],[12145,12362,"very thoughtful of you to remember,"],[12362,12435,"Selena."],[12712,12822,"Happy birthday."],[12876,12992,"Drop the act."],[13329,13513,"Miss, don't push me!"]],"2":[[226,367,"Help! I can't swim!"],[473,550,"Selena!"],[1061,1227,"Julian, help!"],[1781,1928,"Help, help..."],[2065,2218,"Selena is terrified of water—"],[2218,2335,"I have to save her first!"],[2665,2782,"Did they forget?"],[2872,2999,"I'm afraid of the water."],[3056,3113,"Selena."],[3256,3323,"It's okay."],[3663,3770,"Are you okay, Selena?"],[3840,3927,"Are you okay?"],[3980,4034,"Help!"],[4157,4270,"It's my fault."],[4307,4441,"When Miss pushed me,"],[4471,4601,"I reacted instinctively,"],[4601,4754,"I didn't mean to pull her in, too."],[4754,4868,"No, we wouldn't blame you."],[4874,5016,"Aria hurt you first."],[5085,5265,"We can apologize on Aria's behalf."],[5268,5352,"Help!"],[5518,5592,"Help!"],[5925,6072,"Julian, Adrian, I..."],[6072,6379,"I can't... breathe."],[7080,7310,"You've only known Selena for three months."],[7344,7590,"Three months, and it outweighed"],[7590,7847,"10 years of us growing up together..."],[8104,8194,"Aria!"],[8214,8294,"Aria!"]],"3":[[573,894,"Aria, you're finally awake."],[1494,1672,"So you guys do still care about me."],[1788,1905,"Are you okay, Aria?"],[2098,2228,"I..."],[2228,2469,"I think now is a good time to..."],[2469,2602,"apologize to Selena."],[2629,2750,"What?"],[2750,2859,"Wait."],[2859,3039,"You want me to apologize to Selena?"],[3179,3259,"But she's the one who"],[3259,3370,"pushed me in the pool."],[3460,3563,"Aria, Selena wouldn't do"],[3563,3697,"anything so childish."],[3810,4057,"Hey, hey, Aria, Aria, listen to me."],[4097,4284,"Selena is mature,"],[4310,4411,"and she's kind."],[4411,4514,"She remembered your birthday."],[4514,4714,"She wanted to celebrate with you."],[4788,4884,"She would never"],[4884,4994,"push you into the pool."],[5215,5318,"Alphas,"],[5395,5542,"please don't blame Aria."],[6383,6489,"I'm 40."],[6553,6629,"I shouldn't have even"],[6629,6773,"cared about having a birthday."],[6853,7070,"Miss Greenfield didn't push me on purpose."],[7210,7387,"Shut up, you liar!"],[7447,7570,"Aria, enough!"],[7681,7867,"She's clearly taking the blame for you."],[7894,8094,"Julian, not now."],[8248,8461,"Aria, for God's sake, please,"],[8505,8742,"just apologize to Selena."],[8748,8842,"Get this over with."],[8858,9062,"I told you I didn't do anything wrong!"],[9723,9939,"Miss, please don't be upset."],[9946,10080,"I'm really sorry."],[10186,10284,"You're unbelievable."],[10357,10500,"Selena, we'll make it up to you."],[10543,10623,"Adrian, let's go."],[10834,10980,"Aria, I think it'd be best"],[10980,11117,"if you stay here and reflect."],[11117,11244,"Think about what you've done."],[11277,11418,"Why won't you believe me?"],[12579,12832,"Soon, I'll replace you completely."],[14224,14307,"You once said that"],[14307,14467,"no matter what, you'd protect me."],[14631,14731,"Honey,"],[14731,14951,"time to choose your Alpha."],[15111,15208,"Honey!"],[15455,15565,"What happened?"],[15909,16129,"I think I decided who I'm gonna marry."],[17097,17200,"I choose..."]],"4":[[276,380,"I choose..."],[850,947,"Neither of them."],[970,1041,"What?"],[1101,1227,"But didn't you always dream of"],[1227,1394,"marrying Adrian or Julian?"],[1481,1658,"But everything's changed."],[1691,1771,"Alright."],[1808,1915,"No matter what,"],[1938,2078,"as the only female heir"],[2078,2238,"of one of the four major packs,"],[2288,2435,"your choice is yours."],[2509,2639,"Thank you, Mom."],[2776,2869,"Would you..."],[2999,3123,"would you put me in contact"],[3123,3296,"with the Blood Moon Pack's Alpha?"],[3323,3486,"The Blood Moon Pack?"],[3516,3970,"The most mysterious of all four packs?"],[3993,4114,"Are you..."],[4187,4274,"Maybe..."],[4297,4471,"there has to be a third option."],[4698,4771,"Alright,"],[4831,4991,"if that's what you want,"],[5038,5165,"I'll make contact."],[5632,5722,"Alpha,"],[5789,5905,"this is the marriage proposal"],[5905,6019,"sent by the Eclipse Pack."],[6132,6386,"The new Luna is Aria Greenfield."],[6656,6850,"After all these years,"],[6903,7047,"I finally found you."]],"5":[[670,890,"Babe, I had a top tailor design this for you."],[890,990,"You have to pick this one."],[990,1154,"Aria, I chose this one for you."],[1171,1368,"It's... super elegant,"],[1368,1481,"and... I think you'll be"],[1481,1638,"the most beautiful Luna wearing this."],[1756,1834,"Um..."],[2015,2288,"But... if I choose one of you,"],[2322,2469,"what will happen to the other one?"],[2515,2639,"No matter who you choose,"],[2639,2806,"you'll always be our little princess."],[3456,3610,"You're choosing a wedding dress?"],[3633,3740,"Who did you pick?"],[3767,3920,"That's none of your business."],[4047,4280,"I'm Julian and Adrian's mate."],[4307,4474,"No matter who you marry,"],[4517,4698,"the one they both love is me."],[4734,4811,"Oh?"],[4811,4911,"And when they find out"],[4911,5008,"who you really are,"],[5008,5128,"are they still gonna love you?"],[5145,5278,"They never will."],[5308,5578,"They will always choose me."],[5622,5679,"Just wait."],[5722,5809,"You'll see."],[6386,6486,"Miss, if you're upset,"],[6486,6593,"then just hit me."],[7250,7323,"Selena."],[7323,7397,"Selena."]],"6":[[0,83,"You hit me?"],[116,223,"Aria, I didn't."],[223,333,"I don't know why I did that."],[333,490,"Alpha Adrian, Alpha Julian,"],[587,707,"don't blame Miss..."],[707,784,"She's passing out."],[784,874,"Selena!"],[960,1081,"I'll take her to the Healer."],[1104,1201,"Julian, wait!"],[2252,2475,"Adrian, Julian,"],[2522,2689,"once again, you chose her."],[2946,3159,"Aria's already picking out wedding dresses."],[3169,3263,"It won't be long before"],[3263,3393,"she decides who to marry."],[3463,3560,"To protect Selena,"],[3560,3673,"whoever Aria picks,"],[3673,3797,"the other has to agree."],[3826,3957,"So you'd marry me"],[3977,4187,"just to protect her?"],[4204,4401,"Aria, we were just..."],[4611,4764,"We're in trouble."],[4794,4991,"She's losing too much blood!"],[4991,5188,"The supply is empty."],[5208,5305,"Take mine!"],[5485,5605,"Won't be enough."],[5625,5725,"We need more."],[5805,5832,"Okay,"],[5832,5999,"do whatever you need to keep her safe."],[6022,6152,"Take as much as you need."],[6202,6279,"Fine,"],[6329,6469,"come with me."],[6613,6816,"You love her so much"],[6816,6956,"you'd risk your lives."],[6966,7147,"So our ten years together..."],[7183,7283,"meant nothing?"],[7283,7377,"Honey,"],[7394,7624,"the housekeeper told me everything."],[7624,7794,"Oh, are you all right?"],[7861,7981,"I'm fine, Mom."],[8078,8181,"Good,"],[8181,8408,"because the Alpha of the Blood Moon Pack"],[8408,8538,"has agreed to the marriage."],[8585,8725,"But the condition is that"],[8725,8872,"the wedding will be in three days."],[9019,9115,"What wedding?"],[9262,9396,"Aria, who are you marrying?"]],"7":[[20,73,"You already know"],[73,170,"who you're gonna marry?"],[220,306,"Is it Adrian?"],[353,500,"All you care about"],[547,807,"is which one gets to stay with Selena."],[1277,1591,"Aria, I won't let you marry either of them."],[1604,1798,"Their love, their attention,"],[1798,1978,"their place in the pack..."],[2045,2228,"all of it is mine."],[2455,2562,"But you haven't secured the"],[2562,2719,"inheritance of the two packs."],[2799,2999,"I thought we had a deal, remember?"],[3129,3340,"This wolf-bane is"],[3340,3513,"only capable of confusing them"],[3513,3670,"and creating a fake mate bond."],[3770,4040,"I'll make absolutely sure they mark me."],[4284,4417,"If you say yes,"],[4417,4661,"the Blood Moon Alpha will send someone"],[4661,4818,"to bring you to him."],[5131,5235,"Mom,"],[5318,5455,"can I wait till the"],[5455,5592,"Moonrise Ritual to decide?"],[6943,7173,"She is truly the heiress of"],[7173,7367,"the entire four wolf packs."],[7370,7477,"She is incredible."],[7484,7587,"So lucky,"],[7587,7864,"she's been loved by two Alpha hotties"],[7864,7974,"since her childhood."],[7977,8081,"I know, and"],[8081,8201,"I heard that tonight she will"],[8201,8351,"be announcing her engagement."],[8808,8895,"Aria,"],[9075,9209,"why didn't you tell us"],[9209,9319,"about your engagement?"],[10340,10523,"Tonight is the Moonrise Ritual."],[10550,10740,"As heiress of the Eclipse Pack,"],[10840,11057,"tonight, I choose my Alpha."],[11354,11494,"I choose..."],[11608,11808,"Miss, no!"],[11985,12285,"Please, don't take my mates from me."]],"8":[[10,83,"Selena,"],[120,233,"put the knife down!"],[256,457,"Alpha Julian, Alpha Adrian,"],[457,563,"becoming your mate"],[563,730,"was the happiest thing in my life."],[740,824,"I remember..."],[897,1051,"how you stayed with me"],[1067,1191,"even when it meant abandoning"],[1191,1338,"Miss Greenfield's special day."],[1454,1583,"You knew I feared water,"],[1583,1858,"so you left her just to save me!"],[1881,2062,"Selena, drop it!"],[2095,2168,"You're our mate,"],[2168,2502,"so we will do anything to protect you."],[2529,2809,"That's... what you once promised me."],[2839,3046,"How dare they treat you like this?"],[3340,3476,"Always protect Selena?"],[3643,3753,"What am I?"],[3810,3953,"Who am I to you?"],[3993,4070,"Aria,"],[4070,4257,"there... there must've been some sort of"],[4257,4454,"misunderstanding, we..."],[4454,4607,"Misunderstanding?"],[4667,4891,"A misunderstanding multiple times!"],[4938,5385,"Tonight, I want an answer, me or her?"],[5492,5789,"Guys, this is your last chance."],[5925,6159,"Aria, now is not the time for threats..."],[6159,6319,"You don't need to choose me!"],[6783,6880,"As a maid,"],[6926,7213,"I was never worthy of either of you."],[7354,7415,"So..."],[8158,8311,"- No! - Selena!"],[8471,8608,"Someone call the Healer!"],[8668,8748,"Help!"],[8832,9062,"Someone as selfish as"],[9062,9224,"Selena killed herself?"],[9516,9589,"Where were we?"],[9743,10013,"I, Aria Greenfield,"],[10013,10126,"will marry the Alpha"],[10126,10283,"of the Blood Moon Pack."],[10316,10483,"The wedding will be in three days."]],"9":[[273,607,"Tell them the only way to save me"],[647,830,"is to mark me."],[1371,1538,"She needs to be marked immediately."],[1561,1721,"Only Alpha blood will save her."],[1721,1835,"What?"],[2335,2479,"Miss Luna,"],[2479,2625,"the Blood Moon Alpha"],[2625,2762,"has sent wedding gowns"],[2762,2876,"and wagons of gifts."],[2909,3036,"They will arrive soon."],[3156,3296,"Looks like I made the right choice."],[3887,3990,"Send these back."],[4027,4124,"Yes, Miss."],[4798,4878,"Selena."],[4978,5041,"Selena."],[5168,5265,"Save me."],[5295,5465,"Adrian, do we really mark her?"],[6119,6312,"Hurry, she's dying."],[6863,6936,"Alpha,"],[6936,7113,"Miss Greenfield returned the tokens."],[7357,7450,"What?"],[7517,7637,"Mark me now!"],[8171,8380,"Selena, what is this?"],[8380,9319,"Oh, hey!"],[9319,9476,"Master, we were drugged."],[9476,9636,"She wasn't our mate."],[10106,10180,"Selena,"],[10256,10377,"what've you done to us?"],[10443,10620,"What's going on?"],[10967,11047,"No."],[11131,11431,"Please, I just... I can't lose you."],[11484,11544,"What?"],[11594,11705,"Where's Aria?"],[11711,11825,"At... at the banquet."],[11831,11918,"Miss Greenfield announced"],[11918,12118,"she will marry the Blood Moon Alpha."],[12155,12268,"What?"],[12342,12539,"How could she marry someone else?"],[12669,12792,"Get out of my way."]],"10":[[807,874,"Goodbye."],[2649,2769,"Has Aria left already?"],[2769,2809,"No way."],[2809,2872,"Do you really think"],[2872,2992,"she would marry somebody else?"],[3006,3133,"She must have agreed in anger."],[3133,3189,"Damn it."],[3189,3259,"Let's go."],[3259,3390,"She might still be nearby."],[3616,3700,"Where's Aria?"],[3710,3867,"She really married the Blood Moon Alpha?"],[3883,3993,"She was upset"],[3993,4174,"and went outside to clear her head."],[4310,4377,"See?"],[4514,4701,"She's just trying to scare us."],[4911,5041,"Give this to Adrian and Julian."],[5265,5388,"If they ask about me,"],[5458,5608,"tell them I went out to get some air."],[6126,6276,"This is what she left for you."],[6379,6553,"Her final decision must be in this box."]],"11":[[113,180,"Stop!"],[193,360,"Miss Greenfield has instructed"],[360,637,"this box is to be opened in three days."],[680,820,"If you still care about her,"],[827,924,"follow her wishes."],[974,1121,"Don't disappoint her again."],[1174,1321,"So in three days,"],[1368,1544,"Aria will tell us who she wants to marry."],[3003,3273,"Julian, isn't this..."],[3273,3340,"What is that?"],[3510,3757,"Is this... the photo of us?"],[3763,3893,"It hangs on her bedroom wall."],[3893,3977,"Why is it here?"],[4367,4541,"The mate-bond backlash again!"],[4541,4631,"Alphas!"],[5598,5699,"Aria!"],[5889,6072,"Alpha, you're finally awake."],[6096,6169,"It's you."],[6409,6556,"You were both unconscious all night."],[6573,6730,"Please, have some soup."],[7404,7577,"What is that garbage?"],[7594,7731,"It tastes fucking weird."],[7747,7874,"But Aria always made soup"],[7874,7951,"when you were ill."],[8044,8204,"So, Aria's really gone?"],[9052,9168,"Aria, the kitchen staff"],[9168,9295,"could have handled it."],[9335,9483,"You boys deserve the best."],[9552,9659,"One taste and you'll know."],[9769,9893,"No, Aria would never abandon us"],[9893,9976,"when we are sick."],[10043,10166,"If we call her, she has to come back."],[10166,10213,"She will."]],"12":[[0,90,"Call her."],[507,704,"Hi, this is Aria."],[740,867,"Please leave a message."],[870,957,"She's not answering."],[1027,1134,"It's okay, I'll try."],[1471,1671,"Hi, this is Aria."],[1695,1818,"Please leave a message."],[1898,2142,"Did she... block us?"],[2152,2222,"No."],[2265,2332,"She..."],[2365,2449,"Tony, you try."],[2729,2776,"Hi."],[2779,2869,"Miss Aria,"],[2892,2999,"this is Beta Tony."],[3073,3219,"The two Alphas are very ill."],[3223,3343,"Can you come back to see them?"],[3360,3430,"If you're sick,"],[3430,3513,"call a Healer."],[3533,3630,"Why are you calling me?"],[3636,3787,"Aria, what are you talking about?"],[3803,3877,"We're sick!"],[4517,4821,"Honey, have you truly let them go?"],[5018,5288,"I think from the moment that I left,"],[5382,5593,"they stopped being any of my concern."],[5979,6116,"Is Aria really gone?"],[6156,6227,"No, no,"],[6227,6423,"she's run away before when she's angry."],[6446,6659,"She'll... she'll be back."],[6659,6760,"She'll be back."],[6836,6906,"Where?"],[7374,7587,"The box she left, what if there's a clue?"],[7697,7947,"She told us... Three days."],[7947,8061,"It's an emergency."],[8061,8201,"Finding Aria comes first."]],"13":[[200,367,"Alpha Adrian, Alpha Julian."],[613,720,"Are you alright?"],[767,997,"You dare show your face around here."],[1271,1361,"I admit it."],[1428,1624,"I used a potion to forge the mate bond,"],[1624,1785,"but... I had no choice."],[1785,1885,"I love you guys."],[1901,2082,"Only with the bond can I stay by your side."],[2128,2345,"No matter what, you still deceived us."],[2355,2699,"Alpha, I... I know I was wrong."],[2816,2936,"If you're still angry, then..."],[2936,3323,"I... I can atone with my life."],[3370,3560,"Enough, you've confessed."],[3636,3760,"Now take care of us properly."],[3917,4080,"Thank you, Alpha Julian."],[4300,4524,"Adrian, she didn't really hurt Aria."],[4567,4748,"Should she really atone with her life?"],[5165,5325,"Fine, fine."],[5412,5582,"You can stay for now."],[5715,5779,"Go."],[5859,6012,"We have things to discuss."],[6583,6786,"Aria is still furious with us, though."],[6843,7030,"If she finds out we kept Selena..."],[7053,7170,"When she comes back,"],[7210,7417,"we will plan a birthday party for her."],[7464,7634,"And maybe she'll forgive us."],[8248,8355,"Two more days..."],[8405,8501,"She'll be back."],[8725,8805,"Alpha?"],[8998,9082,"Aria?"],[9135,9219,"You're back."],[9239,9362,"I knew you wouldn't leave."],[9396,9626,"He's mistaking me for that little bitch."],[11194,11344,"I came back for you."],[11458,11775,"If you mark me, I'll be your Luna."],[11788,11851,"Aria,"],[11945,12008,"my Luna,"],[12228,12345,"I'll mark you now."],[12365,12605,"Julian, once you taste a real woman,"],[12605,12846,"you'll forget Aria, the little virgin."]],"14":[[340,580,"You're not Aria."],[1154,1421,"Alpha Julian, it's me."],[1461,1594,"I'm here to take care of you."],[1598,1858,"Selena, what are you doing here?"],[1878,2102,"Alpha, you drank too much."],[2112,2298,"Here, have some water first."],[2355,2542,"You shouldn't drink this much."],[2622,2762,"I'm afraid that your condition..."],[2836,2959,"Leave!"],[3643,3973,"Aria, two more days..."],[4234,4387,"I should meet Adrian early."],[4387,4514,"Get a gift for Aria."]],"15":[[286,500,"Welcome to the Blood Moon Pack,"],[603,707,"my future Luna."],[1294,1471,"He's Alpha Damien."],[1484,1601,"He's so handsome."],[2565,2702,"Hi."],[4634,4831,"Alpha never lets anybody touch him."],[4874,5055,"He actually..."],[5185,5268,"He's my mate."],[5268,5342,"I always thought"],[5342,5502,"it would be Julian or Adrian."],[6563,6726,"Well, this can't be,"],[6726,6916,"two Alphas from the great packs."],[6943,7013,"Tell me what you want,"],[7013,7097,"and it's yours."],[7440,7540,"Here's a deposit."],[7600,7724,"We want all your rare jewelry,"],[7744,7937,"specifically the 12-carat ruby crown."],[8338,8521,"That was sold a few days ago."],[8571,8815,"What about the... Da Vinci manuscript?"],[8848,9109,"Um... also... sold."],[9152,9302,"The blue-and-white porcelain vase?"],[9329,9452,"That's gone too."],[9472,9853,"The buyer paid 200 million, in cash."],[9879,10113,"What? Who bought them?"],[10480,10553,"In addition to"],[10553,10707,"the welcoming ceremony earlier,"],[10720,10907,"I've prepared a few small gifts."],[12065,12232,"These are antiques that I've wanted"],[12232,12345,"since I was a kid."],[12712,12786,"How'd you know?"]],"16":[[0,190,"You'll find out soon enough."],[260,393,"So mysterious."],[724,824,"Mrs. Greenfield."],[1004,1117,"My future Luna."],[1174,1391,"Lance will show you around the estate."],[2105,2238,"Who has more money than us?"],[2256,2318,"Um..."],[2422,2686,"I'm sorry, client confidentiality."],[2822,3023,"Guess we'll have to find other gifts then."],[3023,3193,"I know, but these were her favorites."],[3229,3396,"She brought us here since we were kids."],[3433,3573,"Ever since Selena showed up,"],[3610,3743,"we stopped paying attention to"],[3743,3880,"what she liked."],[4097,4217,"Gentlemen,"],[4217,4417,"I do have a new batch of"],[4417,4678,"rare luxurious jewelry, just arrived."],[4954,5058,"Great, yeah."],[5095,5155,"We'll take those."],[5205,5272,"Right away."],[5595,5658,"Call the butler."],[5699,5782,"Oh, yeah."],[5782,5945,"I'll message the butler and..."],[5975,6066,"let him know about the"],[6066,6179,"birthday banquet tomorrow."],[7681,7867,"What's all this... a party?"],[7944,8154,"That bitch Aria is gone, so..."],[8214,8324,"this must be..."],[8405,8595,"This banquet must be for me!"],[8631,8768,"Alpha, I made dinner..."],[9282,9532,"So many jewels..."],[10603,10750,"It's my size."],[10807,11021,"So this party is for me."],[12192,12415,"And what's this?"]],"17":[[16,276,"Aria, to provoke Adrian and Julian,"],[276,423,"you'd stoop to anything!"],[453,557,"You really think this will make them"],[557,684,"regret losing you?"],[1237,1311,"Never."],[2359,2542,"Damien's still a stranger to me."],[2575,2849,"Sharing a room is... way too awkward."],[2892,2956,"No."],[3003,3206,"I'll find... a guest room."],[3885,3962,"Oh!"],[4150,4300,"You aren't wearing anything."],[5011,5141,"You'll be my Luna soon."],[5275,5412,"Why are you still so shy?"],[7010,7097,"What are you doing?"],[7260,7367,"What do you think?"],[7797,7937,"Tonight, we're just sleeping."],[8121,8264,"Anything else when you're ready."],[8385,8448,"Promise?"],[8595,8675,"I promise."],[9859,10050,"Today's the day Aria comes home."],[12208,12355,"Aria will definitely"],[12355,12499,"choose me as her Alpha today."]],"18":[[1775,1915,"That old woman again?"],[1958,2112,"So what if I'm 40?"],[2112,2285,"I can still drive them wild."],[2629,2746,"You again?"],[2756,2926,"I love what you've done with the party."],[2936,3063,"Thank you, Alphas."],[3069,3163,"What are you talking about?"],[3163,3383,"This is Aria's belated birthday banquet."],[3550,3616,"What?"],[3927,4027,"Hold on a second."],[4184,4277,"What are these?"],[4285,4361,"Ow!"],[4457,4621,"Ow, you're hurting me."],[4654,4848,"These were birthday gifts for Aria."],[4908,5008,"How did you get these?"],[5118,5261,"She's gone, isn't she?"],[5278,5358,"Talk!"],[5435,5548,"Where did you get them?"],[5702,5782,"I took... took them"],[5782,5952,"from the box on the nightstand."],[6276,6356,"Box..."],[6383,6566,"Aria left that box for us."],[6596,6690,"Wait a second."],[7260,7400,"Oh my God."],[7644,7777,"These are all the birthday gifts"],[7777,8014,"we've given her over the last ten years."],[8028,8198,"She... left everything?"]],"19":[[223,373,"No, no way."],[383,473,"Aria treasured these."],[473,593,"She wouldn't just give them up."],[610,667,"This must have been"],[667,810,"what she wanted us to see today."],[844,1011,"But what do you think this means?"],[1024,1101,"Alphas!"],[1251,1408,"Aria never cared about you."],[1705,1841,"Aria returned"],[1841,2042,"everything you ever gave her."],[2118,2258,"She's not coming back."],[2262,2352,"Liar!"],[2422,2579,"Aria would never leave us."],[2919,3016,"Selena,"],[3016,3126,"you're telling me you don't know"],[3126,3229,"where Aria went."],[3229,3410,"This is all of Aria's belongings?"],[3453,3646,"The box only had these things."],[4424,4647,"I want you to return everything"],[4647,4771,"that belonged to her."],[4771,5045,"And if you don't, I'll kill you."],[5075,5138,"Got it?"],[6012,6109,"What do you want?"],[6149,6269,"Tell us where Aria is."],[6276,6426,"No comment."]],"20":[[764,920,"Adrian and Julian,"],[940,1131,"I think I've finally decided to leave."],[1244,1401,"When I was eight,"],[1404,1514,"I once accidentally"],[1514,1614,"slipped into the river stream."],[1678,1765,"But thankfully,"],[1845,2035,"you two were there to pull me out."],[2228,2399,"That was the first time that we met."],[2435,2535,"Because of you guys,"],[2545,2876,"I have this beautiful, beautiful memory."],[2952,3149,"You always saved the best for me."],[3169,3249,"I thought..."],[3249,3423,"I would happily marry one of you."],[3486,3563,"But then,"],[3650,3863,"everything began to change."],[3923,4050,"I'm sorry to tell you this,"],[4210,4377,"but Selena's our real mate."],[4544,4734,"You knew I feared the water,"],[4774,5055,"but you still chose to save Selena."],[5151,5218,"Help!"],[5985,6142,"I finally understand now."],[6142,6449,"Your love has been given to someone else."],[6459,6586,"So I'll let go,"],[6616,6873,"and return everything you ever gave me."]],"21":[[203,316,"What have we done?"],[450,527,"She doesn't mean it."],[590,677,"She was just afraid."],[694,830,"She's gonna come back, right?"],[897,994,"Since you're here,"],[1071,1234,"Miss left something for you."],[1251,1498,"She said she doesn't need these anymore."],[2185,2252,"Impossible."],[2325,2415,"Impossible."],[2482,2649,"She even left the wedding gowns."],[2672,2829,"And the engagement tokens too."],[2866,3059,"She really is marrying somebody else."],[3219,3316,"Where is Aria?"],[3353,3410,"Tell us."],[3446,3533,"Answer me!"],[3543,3687,"Her wedding hasn't begun yet."],[3703,3840,"I can't let them crash it."],[3950,4120,"She's not coming back."],[4344,4441,"What did you say?"]],"22":[[0,90,"What did you say?"],[140,313,"Miss said she's not in the mood."],[337,530,"She won't be returning for now."],[810,947,"Not... in the mood."],[1094,1214,"What are you talking about?"],[1264,1391,"She threw away everything,"],[1454,1558,"and abandoned us"],[1568,1731,"because she's not in the mood?"],[1761,1875,"We stayed up all night,"],[1875,2052,"sick and exhausted,"],[2052,2212,"to prepare this banquet for her."],[2225,2332,"Give me your phone!"],[2412,2489,"No, no."],[2489,2649,"That'll only drive her further away."],[2649,2806,"We've spoiled her for too long."],[2829,2922,"The more we chase her,"],[2922,3069,"the more defiant she becomes."],[3126,3259,"Just tell us where she went."],[3323,3573,"She ordered me not to tell."],[3860,4030,"Fine, don't tell!"],[4060,4180,"We'll find her ourselves."],[4344,4514,"Let every Shadow Pack member know."],[4557,4744,"Let the search for Aria Greenfield begin,"],[4754,4808,"now!"],[4808,4918,"If you can't find her,"],[4918,5045,"don't come back at all."]],"23":[[1898,1948,"Hello?"],[1955,2118,"Miss Greenfield, bad news!"],[2138,2322,"Alpha Adrian and Julian have mobilized"],[2322,2449,"their packs to search for you."],[2485,2542,"What?"],[2569,2612,"They planned a"],[2612,2759,"birthday banquet for you."],[2769,2886,"So they started to panic"],[2886,3033,"when they saw you're really gone."],[3079,3146,"Shame."],[3233,3306,"It's too late."],[3336,3383,"I'm afraid"],[3383,3553,"they'll try to find you and harass you."],[3646,3700,"Don't worry."],[3783,3850,"Let them."],[4681,4854,"You slept till noon?"],[4871,4971,"Must have been tired."],[5041,5095,"Yeah."],[5121,5288,"It's time for brunch, princess."],[7847,7991,"These are all my favorites."],[8151,8254,"How did you know?"]],"24":[[20,100,"How did you know?"],[310,433,"Don't worry."],[453,553,"There's no nut or milk,"],[587,844,"and it's a long story."],[937,1064,"I'll have plenty of time to tell you"],[1064,1144,"after we're married."],[3046,3179,"What's wrong?"],[3273,3390,"Why aren't you eating?"],[3403,3513,"They forget."],[3513,3770,"I have a serious nut allergy."],[3770,3947,"Come on, you could eat."],[3967,4024,"It's for Selena,"],[4024,4130,"but she didn't have an appetite."],[4150,4411,"Ah, these are Selena's favorites."],[4517,4637,"But you can't even remember mine."],[4874,5001,"What's wrong? You don't like it?"],[5105,5405,"No, no, it's great... It's great."],[5468,5598,"I just wanted to say..."],[5735,5785,"thank you."],[6029,6129,"No, Aria loves me."],[6176,6272,"Aria always loved me."],[6276,6329,"Alphas!"],[6633,6746,"Where's Julian?"],[6746,6846,"Put him on the phone!"],[7103,7160,"Dad?"],[7180,7230,"Read it."],[7237,7354,"See what mess you've made."],[7637,7867,"Eclipse Pack terminates"],[7897,8014,"all business partnerships"],[8014,8141,"with both our packs?"]],"25":[[0,166,"No, no..."],[216,373,"Aria's cutting ties with us."],[373,540,"We ignored her for a few days"],[540,704,"and she's ripping everything apart?"],[704,757,"Oh God."],[787,927,"I've already sent your Betas"],[927,1034,"the invitation to the"],[1034,1174,"Blood Moon Pack's wedding."],[1174,1374,"I demand you go and network!"],[1761,1835,"Come on."],[2198,2312,"Let's see you."],[2615,2672,"All done."],[2672,2796,"So pretty."],[2912,3026,"It's so good."],[3099,3213,"Wow."],[3216,3436,"And this one."],[3943,4067,"Oh my goodness."],[4758,4898,"You look perfect."],[5275,5502,"Just... just two more hours till the wedding."],[5635,5772,"I'm a little nervous."],[6149,6236,"Don't worry."],[6369,6436,"No matter what,"],[6436,6523,"I'll protect you."],[7303,7570,"Oh, the Eclipse guests are probably arriving."],[7570,7674,"I should go check."],[7731,7830,"Okay."],[9793,9946,"The two biggest Alphas?"],[10110,10177,"I hope they're not here"],[10177,10293,"to stop the wedding."],[10320,10403,"Let's go."],[10847,10927,"Wait."]],"26":[[357,443,"Why are there so many"],[443,543,"Eclipse Pack members here?"],[600,757,"Well, we're here."],[757,850,"So, it makes sense"],[850,987,"that the Eclipse Pack was invited."],[1034,1181,"We're all one of the Four Great Packs."],[1811,2078,"I heard that Alpha Damien"],[2078,2248,"is cold and expressionless,"],[2248,2352,"and it's crazy to think"],[2352,2522,"that he would throw a party like this"],[2522,2699,"just for his future Luna."],[2699,2849,"The Blood Moon Pack's power"],[2849,3023,"cannot be underestimated."],[3023,3186,"This wedding is incredible."],[3186,3363,"I'll throw Aria a grander one someday."],[3920,4104,"Hey, can you watch where you're..."],[4137,4230,"Aria!?"],[4330,4394,"What are you..."],[4514,4724,"Oh, don't tell me..."],[4724,4951,"Oh, you came to the wedding to find us."],[5018,5108,"Find you?"],[5108,5175,"Yeah,"],[5175,5335,"otherwise, why would you come north?"],[5335,5498,"You've never crossed over before."],[5538,5642,"Did you guys not get"],[5642,5782,"the invitations I sent?"],[5822,5905,"What invites?"],[6032,6129,"Now that you're here,"],[6393,6453,"welcome."],[6513,6646,"You can stop pretending."],[6690,6880,"You came to the wedding to find us;"],[6880,7013,"it means you still care about us."],[7060,7127,"Whatever uh..."],[7127,7177,"Look,"],[7177,7387,"we know that we were in the wrong before."],[7387,7617,"But, we're so sorry, okay?"],[7617,7737,"Come on, let's go home."],[7934,8004,"That's why—"],[8051,8148,"Don't touch our Luna."]],"27":[[0,103,"Don't touch our Luna!"],[140,203,"Lance."],[407,493,"What did you just say?"],[687,784,"Who gave you permission"],[784,910,"to access the backstage?"],[950,1054,"We're guests."],[1281,1388,"And she's with us."],[1531,1711,"Show some respect!"],[1758,1865,"She's the future Luna"],[1865,1998,"of the Blood Moon Pack."],[2018,2162,"Future Luna?"],[2175,2332,"You're kidding, right?"],[2352,2495,"She's been waiting to marry us"],[2495,2605,"since we were kids."],[2605,2786,"There's no way she's marrying your Alpha."],[2842,3046,"This is an actor, right, Aria?"],[3099,3223,"Just hired to make us jealous?"],[3236,3326,"Too bad you're shit at it."],[3326,3430,"Okay, let him go."],[3580,3630,"Fine,"],[3670,3787,"then you're coming with us."],[3800,3903,"Don't touch our Luna!"],[4217,4411,"Are you fucking kidding me?"],[4441,4674,"I am the Alpha of the Shadow Pack!"],[4794,4918,"Oh, Lance!"],[5378,5615,"Let's stop this nonsense, Aria."],[5615,5802,"Let's go home and forget all of this."],[5802,5872,"- Come on. - No."],[5872,5992,"Come on, let's go!"],[5992,6036,"Enough!"]],"28":[[6,49,"Enough!"],[323,373,"Aria,"],[403,540,"you just hit Adrian?"],[653,767,"I will say this one last time."],[807,864,"Leave,"],[884,1024,"before I have you thrown out."],[1100,1167,"Are you okay?"],[1221,1361,"Aria, he just hit me,"],[1361,1481,"and you don't give a shit!"],[1528,1708,"I don't care about you anymore."],[1725,1775,"What?"],[1828,1881,"Aria..."],[1928,2068,"so you're just gonna marry"],[2068,2182,"some random guy?"],[2188,2315,"No, go for it."],[2345,2409,"Marry him."],[2439,2605,"Let's see how long you can keep pretending."],[2612,2862,"You came to this wedding to find us,"],[2862,3003,"because you still care about us."],[3143,3213,"Pathetic."],[3370,3500,"Let's get away from these lunatics."],[3590,3710,"You'll regret it!"],[4074,4184,"And don't come crawling back"],[4184,4257,"when you do."],[4444,4534,"Regret it?"],[4821,4871,"Never."]],"29":[[340,537,"Luna, are you ready?"],[1021,1231,"Alpha has impeccable taste."],[1321,1414,"Red suits you perfectly."],[1454,1588,"Wait, he picked this?"],[1608,1661,"Picked it?"],[1751,1885,"He designed that dress."],[1951,2005,"What?"],[2025,2222,"143 diamonds,"],[2242,2352,"\"I love you\" in numbers."],[2469,2635,"He sketched the design years ago."],[2672,2726,"Your name..."],[2789,2912,"was stitched inside the dress."],[3246,3396,"Have we met before?"],[3817,3990,"Oh, honey!"],[4207,4441,"You look stunning!"],[4718,4901,"The ceremony's about to start."],[4918,5051,"Are you sure about this?"],[5101,5582,"Mom, this time, I will finally be happy."],[7013,7113,"She hates us."],[7153,7313,"No, she doesn't."],[7357,7494,"She came to this wedding to find us."],[7494,7724,"She's... too stubborn to admit it."],[7871,7941,"Damn it!"],[7941,8074,"We forgot about the business deal."],[8094,8301,"Then, let's find the Blood Moon Alpha."],[8345,8485,"The alliance comes first."],[8488,8615,"And then we'll talk to Aria"],[8615,8705,"and bring her home."]],"30":[[0,120,"And then we'll talk to Aria"],[120,210,"and bring her home."],[1211,1421,"It's him, the Blood Moon Alpha."],[1648,1778,"Alpha Damien,"],[1851,1985,"congratulations."],[2088,2172,"You two,"],[2172,2322,"very brave of both of you."],[2342,2435,"We're the two Alphas of"],[2435,2512,"the great southern packs."],[2512,2605,"Alpha Julian."],[2726,2812,"Alpha Adrian."],[2856,3006,"Wait, you know us?"],[3143,3308,"Aria's former fiancés."],[3343,3530,"Do you know whose wedding this is today?"],[3590,3720,"Aria wasn't lying?"],[3843,4130,"Alpha Damien, hey, congratulations."],[4210,4304,"Finally marrying the woman"],[4304,4394,"you love for years."],[4544,4621,"Thank you."],[4808,4915,"We're actually here to discuss"],[4915,5008,"potential partner issues."],[5008,5148,"I don't make those decisions."],[5231,5385,"After the wedding ceremony,"],[5412,5525,"speak with the Luna."],[5825,5979,"When one of us marries Aria"],[5979,6112,"and becomes the top pack,"],[6129,6292,"let's see how cocky he is."],[6733,6803,"Alpha."],[6810,6910,"Keep an eye on them."],[6983,7217,"Don't let them ruin the wedding."],[7457,7550,"When this is over,"],[7567,7764,"we're taking Aria home,"],[7797,7907,"no exceptions."],[8181,8321,"Welcome, honored guests,"],[8321,8478,"to Alpha Damien's wedding."],[8508,8728,"And now, please welcome the Luna."],[9659,9729,"Aria?"]],"31":[[70,160,"Aria?"],[477,637,"Everything Aria said was true?"],[637,704,"No, impossible."],[2962,3126,"Do you, Damien Kane,"],[3126,3266,"take Aria Greenfield,"],[3266,3346,"to be your wife,"],[3363,3563,"to love, protect her"],[3653,3810,"in sickness and in health?"],[3883,3950,"I do."],[4110,4304,"Do you, Aria Greenfield,"],[4334,4471,"take Damien to be your husband,"],[4491,4878,"and stand by him in poverty and wealth?"],[5208,5275,"I do."],[5762,5865,"No, she doesn't."],[6192,6376,"Lance, throw them out."],[6606,6876,"Aria, tell us this isn't true!"],[6886,7067,"Aria, how could you do this to us?"],[7187,7440,"Aria, say something!"]],"32":[[43,153,"Everyone,"],[210,407,"pay no mind to the interruption."],[443,557,"If anything,"],[667,738,"it only proves"],[738,904,"how certain we are of each other."],[1037,1194,"Before the Moon Goddess"],[1194,1474,"and those assembled packs,"],[1474,1731,"I declare Aria Greenfield"],[1731,1858,"and Damien Kane"],[1881,2094,"husband and wife."],[4451,4661,"Goodnight, my Luna."],[5408,5488,"Aria?"],[5532,5835,"Damien, I'm so happy today."],[5949,6182,"Me too, but it's late."],[6229,6366,"You should get some rest."],[7193,7497,"Damien, I'm ready."],[7580,7657,"What did you say?"],[7811,7971,"Nothing, I said nothing."],[8635,8769,"Did you just flirt with me"],[8769,8878,"and push me away?"],[8982,9105,"I didn't push you away."],[9212,9392,"You don't regret this?"],[9552,9649,"Mark me."]],"33":[[136,240,"Mark me."],[1761,1875,"Are you sure about this?"],[1928,2118,"We're still recovering from the backlash."],[2135,2235,"I don't care."],[2308,2469,"We're winning her back today,"],[2502,2639,"no matter what it takes."],[3773,3843,"Luna..."],[3917,4050,"You're finally awake."],[4150,4304,"You're trying to start something?"],[4864,5025,"The two bastards have come back."],[5161,5258,"Don't worry."],[5352,5435,"I'll handle it all."],[6786,6903,"Bring us to your Alpha."],[6923,6996,"Now!"],[8735,8838,"Where's Aria?"],[8928,9099,"Bring her right out now!"]],"34":[[13,113,"Where's Aria?"],[143,323,"Bring her to us, now!"],[1144,1424,"Are you ants seriously demanding me?"],[1448,1541,"What's wrong?"],[1541,1651,"You're scared if she sees us,"],[1651,1771,"she'll leave you?"],[1848,2082,"Let Aria go."],[2165,2382,"She only married you to spite us."],[2429,2555,"She doesn't love you."],[2595,2759,"Still so arrogant."],[2819,2876,"No wonder why"],[2876,3026,"Aria doesn't look at you anymore."],[3036,3183,"Shut your damn mouth!"],[3920,4024,"Enough!"],[4958,5061,"Aria,"],[5091,5271,"I know you're angry."],[5285,5452,"Please end this."],[5475,5652,"Come home with us."],[6292,6515,"Aria, you let him mark you?"]],"35":[[0,170,"You let him mark you?"],[527,630,"We came here,"],[630,750,"bloodied and broken,"],[750,854,"and you just..."],[857,1021,"You are out of my life."],[1021,1101,"Leave!"],[1177,1331,"I'm married."],[1378,1508,"Aria, why did you..."],[1544,1848,"why did you let anger ruin your life?"],[1888,2052,"Why did you risk everything"],[2052,2158,"for a stranger?"],[2165,2288,"Adrian, forget it."],[2352,2485,"She's heartless."],[2615,2809,"We ignore her for a few days, and"],[2809,3053,"then she's thrown away ten years of love."],[3136,3283,"Only a few days?"],[3386,3463,"Let's go."],[3490,3583,"She'll regret it."],[3650,3817,"Remember, you are the one"],[3817,4000,"who abandoned this love first."],[5318,5438,"Aria,"],[5685,5762,"will you blame me"],[5762,5919,"if I don't hold back next time?"]],"36":[[186,306,"Damien,"],[370,487,"I won't blame you."],[530,682,"I'm not sad because of them."],[724,834,"I'm..."],[880,1064,"sad for the version of me"],[1064,1378,"that was so desperate for their love."],[2215,2435,"Alphas, you're finally back!"],[2512,2625,"Where's Miss Aria?"],[2756,2859,"Don't mention her!"],[3003,3166,"So Aria really left them."],[3186,3269,"Perfect!"],[3269,3486,"The Luna position for both packs"],[3486,3606,"will finally be mine."],[3620,3707,"I made dinner."],[3707,3890,"You two must be starving."],[5071,5355,"Does it... taste okay?"],[5425,5675,"Definitely not anything close to"],[5675,5899,"what Aria made for us."],[6136,6332,"At least you're here for us."],[7120,7243,"Alphas,"],[7243,7597,"if the packs need a new Luna,"],[7637,7781,"I'd be more than happy"],[7781,7964,"to be that person."]],"37":[[20,113,"Enough!"],[193,513,"No one but Aria is fit to be Luna."],[637,827,"Stop daydreaming, woman!"],[1247,1368,"Alphas!"],[1461,1594,"Aria, you've already married"],[1594,1748,"and they're still taking your side."],[2686,2756,"No,"],[3036,3206,"I haven't achieved my goal yet."],[3263,3363,"I have to become Luna"],[3363,3513,"and establish my status,"],[3553,3737,"and all of the assets will be mine."],[4204,4421,"I will replace Aria for good."],[5779,6066,"Aria, you'll regret this."],[7600,7667,"Aria?"],[8401,8555,"Aria, don't leave us!"],[8972,9085,"Aria!"],[9109,9219,"Don't leave us!"],[9876,9986,"Wait!"],[10427,10587,"Come with me."],[10677,10760,"Aria?"]],"38":[[1054,1167,"Alpha, watch out!"],[2445,2532,"Selena!"],[2826,3016,"Get her to the hospital now!"],[3039,3073,"Go!"],[4344,4431,"Alpha..."],[4621,4701,"You're awake."],[4724,4911,"Why were you so reckless like that..."],[4918,5005,"shielding us?"],[5095,5428,"I only... wanted to protect you."],[5572,5658,"Selena, we..."],[5658,5819,"we've been too cold to you recently."],[5845,5929,"That's on us."],[6439,6593,"We'll make it up to you."],[6690,6866,"Alpha, I..."],[6950,7050,"Breaking news!"],[7050,7183,"The north's strongest,"],[7183,7310,"the Blood Moon Pack,"],[7310,7577,"has been attacked with heavy casualties."],[7587,7681,"What?"]],"39":[[40,193,"Alpha, I don't feel well..."],[193,223,"Later!"],[223,330,"can you..."],[1174,1308,"I did all of this for you,"],[1308,1608,"and I'm still no match for that bitch Aria!?"],[1718,1858,"Well, then, I have no choice"],[1858,2045,"but to completely eliminate her."],[2268,2389,"Jim, book me a flight to the"],[2389,2559,"Blood Moon territory, now."],[2665,2829,"Hey, Julian, where are you going?"],[2839,2962,"To the north to get Aria."],[2976,3083,"It's dangerous there."],[3113,3229,"What about Selena?"],[3286,3426,"She just took a car for us,"],[3426,3543,"and you're gonna leave her here?"],[3570,3700,"You can't do that."],[3713,3777,"I..."],[3937,4010,"Alpha,"],[4060,4167,"war's broken out."],[4184,4327,"All flights to the Blood Moon Pack"],[4327,4404,"are grounded."],[4517,4698,"Hey, hey, listen."],[4814,5001,"Aria will come back for us."],[5058,5238,"But Selena needs us"],[5238,5335,"to take care of her."],[5368,5422,"Alright?"],[5525,5622,"Come on, let's go."],[5755,5802,"Fine."],[6012,6309,"Give me the deadliest slow-acting poison."],[6413,6503,"What did she say?"]],"40":[[93,357,"Bring me the deadliest slow-acting poison."],[360,433,"Last time,"],[460,620,"you promised me to secure"],[620,924,"the Shadow's and Thunder's assets."],[924,1004,"And then what happened?"],[1007,1221,"I've already won the two Alphas' trust."],[1244,1444,"Don't worry, this time I will—"],[1554,1721,"You'll what, exactly?"],[1815,1978,"Uh... Alpha."],[1995,2082,"Poison Aria?"],[2092,2188,"What are you planning?"],[2308,2422,"That's not what you heard."],[2422,2489,"I only want..."],[2489,2545,"Let go!"],[2856,2949,"What the fuck."],[2959,3009,"Talk!"],[3053,3129,"Now!"],[3583,3646,"Don't."],[3673,3710,"Shhh..."],[3983,4060,"She's been trying to"],[4060,4227,"hurt Miss Aria several times,"],[4297,4364,"but failed."],[4467,4621,"And now she just wants to kill her."],[4918,5205,"So, it's your plan all along?"],[5225,5452,"No, he's lying!"],[5495,5582,"Li... Listen to me."],[5612,5825,"I... I was framed."],[5845,5959,"We'll listen, alright?"],[6092,6212,"In the right place."],[6696,6770,"Alpha?"],[6810,6916,"Where are you taking me?"],[6916,6986,"Come with me."],[7374,7477,"Fuck!"],[7794,7934,"Lock her in the bedroom"],[7934,8151,"and keep a close eye on her."],[8682,8765,"Promise me,"],[8908,9069,"after you watch this,"],[9085,9199,"neither of you will"],[9199,9362,"disturb Miss Aria again."],[9686,9799,"We promise."]],"41":[[353,450,"And when they find out"],[450,553,"who you really are,"],[553,674,"are they still gonna love you?"],[690,817,"They never will."],[857,1114,"They will always choose me."],[1144,1234,"Just wait."],[1267,1354,"You'll see."],[1871,2085,"Miss, if you're upset, then just hit me!"],[3340,3436,"All of it..."],[3553,3687,"was Selena's plot!"],[3730,3913,"No wonder Aria turned so cold."],[3980,4170,"And I slapped Aria because of it!"],[4304,4491,"Hey, hey... calm down."],[4541,4701,"You believe lies,"],[4701,4838,"protected Selena,"],[4864,5015,"and shattered Miss Aria."],[5095,5218,"Neither of you is"],[5218,5365,"worthy of being her Alpha."],[5742,5962,"Final pay, tenfold!"]],"42":[[1895,2272,"It seems we've misunderstood you."],[2465,2849,"Alpha, I... I told you I was framed."],[2849,3049,"Yeah, it was all Aria's fault."],[3073,3189,"Exactly!"],[3203,3329,"It's all her scheme."],[3356,3430,"On her birthday,"],[3430,3513,"she was jealous"],[3513,3650,"and pushed me on purpose."],[3660,3857,"She's a petty, vicious..."],[4421,4577,"It must be mistaken, I..."],[4604,4698,"Mistaken?"],[4821,4894,"You're right."],[4894,5015,"We failed to see you"],[5015,5141,"for who you really are."],[5245,5652,"A lying, cheating thief!"],[5962,6049,"You know?"]],"43":[[30,196,"You... you know?"],[960,1111,"Yeah, we saw the footage."],[1151,1271,"Aria never hurt you."],[1451,1621,"You drove Aria to despair."],[1675,1818,"Today you'll pay for her pain."],[2485,2619,"I did it?"],[2659,2759,"You're the fools."],[2796,2956,"You hurt her!"],[3076,3159,"Liar!"],[3243,3316,"We love Aria."],[3316,3440,"We would never hurt her."],[3456,3543,"Love?"],[3590,3817,"For three months, you put me first."],[3850,3967,"Shut up!"],[4030,4284,"You chased Aria away, no one else!"],[4294,4367,"No!"],[4511,4657,"Even if we were in the wrong,"],[4724,4921,"we still have time to make this right."],[5792,5882,"No, don't!"],[5942,6066,"I saved you once!"],[6102,6249,"You tricked us with the potion!"],[6439,6723,"You've framed Aria again and again!"],[6836,6910,"No!"],[6940,7093,"Please!"],[7223,7290,"Alphas,"],[7410,7594,"news from the Blood Moon Pack."],[7610,7764,"Alpha Damien has declared war"],[7764,7907,"on the two remaining packs."],[7967,8054,"What?"]],"44":[[56,133,"What?"],[407,530,"Just like the rumors."],[640,757,"How could Aria be"],[757,917,"happy with a man like that?"],[997,1061,"Enough."],[1101,1201,"We go beg her forgiveness"],[1201,1341,"and she comes home today."],[2005,2092,"Damien,"],[2195,2415,"If this isn't over in three days,"],[2525,2679,"I'm joining you at the front lines."],[3860,3983,"That was us."],[4127,4284,"We met back then."],[4594,4778,"Damien?"],[5258,5462,"You two?"]],"45":[[73,310,"Who let you in here? Out!"],[413,610,"Aria, one last conversation, I swear."],[610,784,"Please, Aria, just hear us out."],[814,897,"Let them go."],[1207,1287,"Aria,"],[1711,1808,"we were wrong."],[1891,2015,"We know the truth now."],[2052,2168,"Selena set us up."],[2222,2392,"Aria, we misunderstood you."],[2422,2632,"Just... punish us however you want."],[2722,2856,"So now you know the truth."],[3013,3136,"Too bad it's too late."],[3146,3276,"Don't be so heartless."],[3296,3460,"For the sake of our ten-year bond."],[3616,3767,"Look, I remembered you"],[3767,3900,"threw out the pearl necklace I got you,"],[3900,4024,"so I got you a bigger one."],[4060,4200,"And this is a diamond necklace."],[4200,4274,"I made it myself."],[4274,4377,"It's better than his."],[5719,5812,"You waited too long."],[5869,6032,"So you regretted in hindsight."],[6082,6246,"But nothing is cheaper"],[6289,6433,"than love that comes too late."],[7163,7247,"No."],[7500,7614,"Escort them out."]],"46":[[33,136,"No, Aria."],[136,330,"- Aria, Aria. - Please come on!"],[347,430,"Please!"],[447,600,"Stop all that noise."],[840,907,"Aria,"],[987,1111,"please forgive us!"],[1181,1314,"Aria, we won't give up."],[1528,1621,"Well, what now?"],[1648,1731,"Do we leave?"],[1751,1941,"No, not until she forgives us."],[1961,2105,"But she won't take the gifts."],[2128,2255,"She won't even speak to us."],[3346,3466,"Then we'll kneel here"],[3466,3713,"until she does forgive us."],[4958,5028,"Luna,"],[5105,5195,"those two..."],[5218,5395,"wedding crashers are still outside."],[5495,5578,"They're still here?"],[5792,5889,"I'll get rid of them."],[7063,7333,"Aria... you forgive us?"]],"47":[[63,186,"I'll say this one more time."],[383,603,"I want nothing to do with either of you."],[710,824,"I won't forgive you."],[950,1197,"Well then, we'll kneel here forever."],[1314,1511,"You're threatening to harm yourself"],[1511,1631,"to force my hand."],[1671,1741,"No,"],[1755,1905,"we just want your forgiveness,"],[1925,2035,"and for you to come home."],[2098,2265,"Aria, just end this."],[2282,2485,"You married a violent man..."],[2505,2746,"out of spite, you don't love him."],[2832,3006,"You think I'm doing this out of spite?"],[3263,3340,"Pathetic!"],[3576,3840,"Kneel! Fine, kneel!"],[3880,4000,"I won't do a damn thing."],[4117,4194,"Aria!"],[4274,4351,"Come on!"],[4387,4444,"God!"],[4507,4581,"Aria!"]],"48":[[700,827,"Good morning, Luna."],[827,980,"Lunch is ready."],[1311,1554,"Oh, is it not to your liking?"],[1905,2018,"Luna,"],[2018,2232,"are you sure you don't wanna talk to them?"],[2272,2495,"I mean, they're still there."],[2509,2575,"From now on,"],[2575,2742,"I don't need updates about them."],[2826,2926,"Yes, Luna."]],"49":[[397,630,"Alpha Damien has reclaimed a large"],[630,770,"stretch of border territory"],[770,980,"with the Blood Moon forces."],[1000,1211,"Aria!"],[4200,4377,"Aria..."],[4534,4627,"We are..."],[5458,5565,"Leave now."],[6009,6142,"You both are dead to me."]],"50":[[16,133,"You both are dead to me."],[440,507,"Aria."],[730,850,"You're coming home today."],[1261,1394,"Are you insane?"],[1394,1498,"Put me down!"],[3370,3506,"Don't you dare touch my Luna"],[3506,3623,"for another second!"],[4681,4754,"Damien."],[5318,5462,"I'm sorry. I'm late."],[6122,6296,"You left Aria for days!"],[6336,6426,"What gives you the right"],[6426,6519,"to be her Alpha?"],[7527,7701,"Damien, you just came from the front."],[7724,7851,"Okay, they're not worth your strength."],[7874,7937,"Relax."],[8084,8168,"They're not strong enough"],[8168,8244,"to overpower me."]],"51":[[687,870,"This is the price you pay"],[960,1124,"for laying a hand on Aria."],[1144,1221,"Just wait."],[1304,1421,"Aria will be ours."],[2966,3029,"Damien!"],[3189,3296,"Are you okay?"],[3990,4090,"Please wake up."],[4908,4992,"Damien?"],[5342,5438,"You're awake!"],[5645,5742,"Don't worry."],[5829,6006,"Your Alpha doesn't fall that easily."],[6106,6232,"I figured out,"],[6256,6396,"last week while you were gone,"],[6409,6506,"why you knew me"],[6536,6653,"even though we'd never met."],[6666,6756,"You know?"]],"52":[[547,697,"Back then..."],[774,894,"enemies hunted me."],[937,1011,"Spent of power,"],[1011,1137,"I shifted into wolf form"],[1191,1359,"and almost died in that forest."],[1444,1538,"I took you in,"],[1614,1845,"and I fed you for six months,"],[1861,1982,"and then you left."],[2095,2212,"You ditched me."],[2979,3236,"Which is why I've decided I'll repay you"],[3306,3426,"with my whole life."],[3610,3666,"Stop!"],[3843,3927,"You just woke up."],[5872,5975,"Alpha has just returned"],[5975,6057,"from the front."],[6096,6316,"No one is to disturb him or Luna."],[6389,6468,"Understood?"],[7150,7390,"I traded everything I had for this poison."],[7424,7634,"Aria, you will be a dead wolf..."],[7774,7859,"soon."]],"53":[[0,263,"Aria, today is the day you die."],[620,847,"I traded everything I had for this poison."],[1000,1271,"Aria, you'll be a dead wolf..."],[1297,1394,"soon."],[1711,1935,"Are you new here?"],[1971,2115,"Yes, Alpha."],[2155,2412,"If it's ready, take it over."],[2465,2539,"Yes."],[3416,3666,"Shit, he's watching so closely."],[3880,4024,"Can't kill you yet,"],[4024,4210,"but I can make you suffer."],[5832,6016,"Alpha, I... I didn't mean to."],[6393,6613,"Why does that voice sound so familiar?"]],"54":[[50,176,"If Luna hadn't been unhappy"],[176,290,"with the soup and wanted to toss,"],[290,397,"I wouldn't have rushed it!"],[413,520,"What are you talking about?"],[520,607,"I never said that!"],[607,810,"You're trying to harm my Luna on purpose!"],[837,1031,"Lance, take her out!"],[1067,1221,"Ten lashes, then fire her!"],[1261,1327,"Alpha!"],[1468,1521,"Believe me,"],[1521,1698,"I didn't do it on purpose."],[1791,1881,"I believe my wife."],[2535,2789,"And I've seen fake criers like you"],[2956,3153,"a thousand times."],[3590,3677,"Alpha,"],[3693,3763,"believe me."],[3763,3923,"I didn't do it on purpose."],[4140,4250,"Aria,"],[4250,4474,"I will make you pay a hundredfold!"],[4484,4561,"Alpha!"],[5495,5562,"Oh god."],[5889,6029,"Why have I been so sick?"],[6219,6319,"Could it be..."],[7087,7170,"I'm pregnant."]],"55":[[477,573,"Hi, my love."],[1630,1752,"Woo-hoo."],[2015,2389,"Finally... you're in my hands."],[2429,2499,"It's you."],[2686,2769,"What do you want?"],[3253,3396,"Alphas,"],[3486,3610,"Aria's with me."],[3720,3893,"Bring all of your assets,"],[3983,4143,"or I'll make her beg for death."],[4374,4688,"If you lay a finger on me, you'll pay."],[4761,4854,"Will I?"],[4891,5038,"Still mouthing off?"],[5101,5225,"Don't think I don't know..."],[5742,5942,"you're pregnant."],[6072,6221,"Who knew a little search"],[6221,6453,"would bring up such a surprise."],[6483,6633,"Keep threatening me,"],[6633,6866,"and I'll make it two corpses."],[7147,7263,"Let her go!"]],"56":[[236,403,"One more step and she dies."],[690,780,"You want her alive?"],[824,1007,"I want all of your assets and..."],[1007,1247,"both Luna titles for your packs."],[1708,1858,"Fine, fine, we agree."],[1998,2148,"So quick to agree?"],[2205,2332,"But it's not enough."],[2839,2939,"Don't try anything."],[3063,3223,"She's still my hostage."],[3343,3456,"I gave you the knife"],[3503,3603,"because I wanna"],[3603,3803,"watch you kill her child"],[3803,4024,"with your own hands."],[4267,4341,"What?"],[4357,4484,"Aria is pregnant?"],[4537,4604,"Selena,"],[4637,4741,"if you hurt my child..."],[4741,4824,"Shut up!"],[4881,5228,"Do as I say, or I kill her now."],[5578,5752,"Don't! Wait."]],"57":[[650,727,"Damien!"],[1214,1311,"You think you could harm"],[1311,1434,"the Blood Moon's Luna?"],[1601,1688,"Yeah."],[1715,1991,"Too bad that while she was out"],[1991,2212,"I already fed her a slow-acting poison."],[2225,2339,"You did what?"],[2382,2525,"I'm the only one with the antidote."],[2535,2696,"So, unless you want"],[2696,2866,"the mother and child dead,"],[3036,3179,"you let me go."],[3373,3496,"That's so?"],[4254,4387,"Dark Healer?"],[4504,4667,"Still wanna kill Aria?"],[4738,4814,"Dream on."],[5625,5705,"There,"],[5712,5839,"that's the last useful thing"],[5839,5932,"we can do for Aria."],[5939,6036,"Take out the trash."],[6169,6239,"Just wait."],[6316,6396,"We won't give up."],[7027,7123,"Here,"],[7187,7344,"take the antidote first."],[7634,7687,"Aria?"],[7761,7811,"Aria?"],[7954,8178,"Lance, get a car to the hospital now!"],[8308,8371,"Aria."],[8428,8488,"Aria?"]],"58":[[637,800,"Well? How's Aria?"],[970,1224,"Both mother and child are safe."],[1304,1471,"Congratulations, Alpha."],[1604,1675,"Thank you."],[1685,1745,"Thank you."],[2142,2492,"Aria, I'm going to be a dad."],[3957,4057,"Aria."],[4107,4200,"We were wrong."],[4200,4454,"Aria, we're ready to atone for everything."],[4731,4834,"Let's go."],[4961,5045,"Aria."],[5185,5315,"Aria, take one more step,"],[5315,5438,"and I'll die right here."],[5799,5895,"Aria."],[6172,6246,"Julian!"],[6256,6419,"No, no..."],[6609,6753,"Clean up this mess."],[6980,7107,"You have to celebrate by yourself."],[7107,7163,"Selena's sick."],[7190,7253,"But she's the one who"],[7253,7330,"pushed me in the pool."],[7454,7557,"Aria, Selena wouldn't do"],[7557,7691,"anything so childish."],[8585,8688,"Adrian,"],[8752,8908,"we've lost our Aria."],[8935,9142,"No, no..."]]}