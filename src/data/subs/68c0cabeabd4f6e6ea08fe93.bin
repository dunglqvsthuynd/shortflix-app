{"1":[[1555,1618,"Please."],[1643,1789,"This has to work."],[1805,1926,"This is my last chance."],[2344,2410,"Astrid!"],[2423,2519,"Put that down now!"],[3274,3386,"Haven't you caused enough damage"],[3386,3453,"for one day?"],[3482,3661,"I'm sorry, High Priestess."],[3666,3837,"I was just trying to fix things."],[3916,4041,"Same as with the heat spell."],[4041,4179,"The tower caught on fire"],[4179,4295,"because of your stupid spell."],[4346,4521,"Astrid is a threat to the whole coven."],[4537,4612,"None of the other witches"],[4612,4683,"want her here."],[4721,4821,"She needs to go."],[4967,5055,"I'm so sorry."],[5084,5188,"I didn't mean to."],[5205,5305,"Please don't make me go."],[5305,5451,"I will do anything to stay."],[5472,5580,"We can't risk the coven"],[5580,5759,"for just one student, Astrid."],[5759,5889,"I have no choice"],[5889,6035,"but to strip you of your powers"],[6072,6210,"and banish you from the coven."],[6402,6468,"Please."],[6493,6585,"I beg of you."],[6614,6777,"My powers are all I have."],[6777,6861,"Please don't make me go."],[6861,7007,"I have nowhere else to stay."],[7269,7332,"Astrid,"],[7511,7586,"you've been with us"],[7586,7691,"since you were a child."],[7749,7891,"You've always been very talented."],[7949,8045,"Through the years,"],[8045,8191,"surrounded by other witches,"],[8216,8375,"your feminine powers have grown."],[8500,8591,"But she's right."],[8625,8721,"You lack control."],[8771,9009,"Your powers require a masculine balance."],[9059,9154,"Tell me what to do."],[9192,9325,"You must leave the coven"],[9363,9488,"and live among men again."],[9559,9813,"Allow their masculine energies"],[9818,10010,"to merge with your feminine ones."],[10214,10335,"Merging energies?"],[10335,10489,"You have to sleep with them, dumbass."],[10668,10744,"Of course."],[10764,10915,"You will only have ten days"],[10915,11098,"to balance your unruly powers."],[11098,11277,"If you return before you have"],[11277,11436,"conquered your imbalance,"],[11473,11644,"I must take your powers away."],[11807,11882,"I understand."],[11924,12099,"I won't disappoint you, High Priestess."],[12166,12291,"I will find a young man"],[12291,12404,"and I will sleep with him."]],"2":[[437,617,"Fare thee well, Astrid Hall."],[658,763,"Once I've slept with boys"],[763,884,"and acquired their energies,"],[905,1063,"I'll return to my coven sisters."],[1084,1272,"Don't hurry back, dipshit."],[1463,1643,"May the gods watch over you, child."],[2439,2590,"Worthless little witch."],[2665,2844,"Hurry up and get in the car."],[3545,3674,"Blessed be, stepmother,"],[3728,3803,"stepsister."],[4020,4254,"I told you not to call us that."],[4462,4758,"So you set another building on fire?"],[4788,4879,"You better not breathe"],[4879,4954,"a word about it"],[4954,5084,"at your new boarding school."],[5150,5255,"My new boarding school?"],[5334,5463,"But I thought I was going home."],[5805,6035,"Like I'd ever let a pyromaniac like you"],[6035,6185,"under my roof again."],[6256,6398,"But it was my father's home"],[6398,6519,"long before he met you."],[6523,6731,"Well, he's dead, so it's our home now."],[6956,7102,"Do not, I repeat,"],[7102,7178,"do not tell anyone"],[7178,7278,"we're related at school."],[7303,7399,"Got it, demon girl?"],[7557,7782,"If I ever hope to return to my sisters,"],[7782,7945,"I must find masculine energies"],[7945,8062,"to balance my power."],[8124,8208,"Hello?"],[8208,8299,"Did you hear me?"],[8404,8475,"Do not worry."],[8500,8600,"I shan't inform anyone"],[8600,8750,"of our relationship, stepsister."],[8783,8929,"This I swear by the old gods."],[9021,9088,"Freak."]],"3":[[667,767,"I have to talk to the dean"],[767,884,"about your enrollment."],[1034,1172,"Don't go anywhere."],[1222,1405,"Don't do anything."],[1426,1689,"Huntington Hall is a respectable,"],[1689,1801,"normal school,"],[1830,2006,"for normal kids."],[2060,2156,"So don't pull any of that"],[2156,2260,"witchy shit here."],[2339,2410,"Understand?"],[4016,4133,"Masculine energies."],[5492,5597,"OMG, who is that"],[5597,5768,"and why is he not in any of my classes?"],[5843,5968,"You want him in class?"],[6022,6147,"I'd rather have him in my dorm room,"],[6147,6277,"up against my desk."],[6302,6402,"In the shower..."],[7148,7365,"Wait, is he blind?"],[7386,7549,"Yeah, never mind."],[7574,7665,"I only mess with guys"],[7665,7845,"who can actually see what they're doing."],[8637,8829,"So much masculine energy."],[8871,9042,"But how do I choose who to merge with?"],[9534,9759,"Greetings, sweaty mortal males."],[9926,10030,"Will one of you volunteer"],[10030,10093,"to sleep with me,"],[10093,10239,"so I may balance my powers?"],[10677,10860,"Ay yo, what the fuck?"]],"4":[[4,225,"Dude, is this emo girl being serious?"],[241,450,"Shit, I ain't usually into goth chicks,"],[450,654,"but you know what, if she's offering..."],[679,784,"Hey, sweetie,"],[804,946,"I think you're a little lost."],[946,1184,"This isn't Halloween Horror Nights."],[1355,1505,"I do not know what that is."],[1539,1705,"I simply came to seek a male."],[2435,2489,"You!"],[2531,2648,"With the mystical staff!"],[2740,2861,"Mystical staff?"],[2932,3023,"You know that emo?"],[3032,3207,"She's going straight for the rich boy."],[3207,3361,"I mean, he'll probably be into her."],[3361,3461,"Dude's blind and can't see"],[3461,3607,"how fucking weird she looks."],[3770,3841,"Wait!"],[3874,3945,"Please."],[4479,4567,"Ah!"],[4592,4633,"Fuck!"],[4667,4725,"Hey!"],[4854,5059,"You gonna say sorry, emo girl?"],[5105,5226,"Let go of me, please."],[5234,5355,"Your energy is hostile"],[5355,5497,"and incompatible with mine."],[5559,5722,"And I am not an EMO."],[5722,5809,"I am a witch."],[5843,5901,"What the fuck"],[5901,6035,"are you talking about, freak?"],[6085,6160,"Apologize."],[6181,6231,"Now."],[6456,6627,"I'm sorry you have weak muscles."],[6823,6894,"Now let me go."],[7278,7369,"Where are you going?"],[7419,7524,"Let me come with you."],[7849,7995,"Jesus, what the fuck is your deal?"],[8091,8195,"My feminine energies are"],[8195,8279,"too powerful."],[8279,8370,"And if I don't balance them"],[8370,8475,"with masculine energies,"],[8475,8541,"then they'll take away my"],[8541,8633,"powers forever."],[8800,8863,"Right."],[8975,9067,"The mental health counselor's"],[9067,9142,"on the second floor."],[9321,9438,"How fortuitous."],[9651,9776,"Can you let go of my hand?"],[9780,9959,"A sign from the old gods."],[9980,10043,"What are you talking about?"],[10043,10118,"My birthmark?"],[10139,10193,"Yes."],[10218,10314,"Um, it's nothing."],[10314,10443,"I've had it since forever."],[10443,10614,"It is no mere birthmark."],[10656,10819,"This means much more than that."],[11498,11574,"What was that?"],[11636,11824,"Did I just see her?"],[11845,11886,"Look."],[11907,11999,"I don't know you."],[12020,12099,"And you don't know me."],[12099,12274,"So, please, leave me alone."],[13500,13588,"Oh, no."],[13588,13742,"He doesn't see the car coming."],[13767,13909,"Get off the road, hurry!"]],"5":[[83,200,"Goddess Hecate,"],[225,337,"don't let me hurt him."],[1142,1209,"What the-"],[1255,1330,"Shit."],[1459,1522,"It worked."],[1785,1856,"What? What happened?"],[1856,2097,"Bro, that car almost just smoked you."],[2127,2168,"Really?"],[2168,2273,"Yes, it was coming right for you,"],[2273,2394,"but the new girl made it"],[2394,2460,"move out of the way"],[2460,2669,"with some kind of magic."],[2952,3015,"You're safe."],[3082,3165,"Thank Hecate."],[3249,3349,"You saved my life."],[3499,3591,"How can I pay you back?"],[4979,5209,"Will you sleep with me?"]],"6":[[29,66,"What?"],[158,437,"You can thank me by sleeping with me."],[496,663,"Um, I don't know where you're from,"],[663,825,"new girl, but around here"],[825,1021,"you don't just ask a complete stranger"],[1021,1084,"to sleep with you."],[1255,1338,"I feel weak."],[1755,1935,"Is she okay?"],[2565,2669,"What happened here?"],[2706,2827,"She stopped the car from hitting me"],[2827,2936,"and then just passed out."],[2965,3007,"Yeah."],[3053,3128,"After she asked you"],[3128,3211,"to have sex with her."],[3299,3365,"Dude, Luke, shut up."],[3365,3428,"It's my grandma."],[3428,3674,"My stepdaughter is very sheltered."],[3674,3858,"I'm sure she didn't mean it that way."],[3966,4062,"Nah, she was trying to hit."],[4087,4124,"Dude."],[4133,4229,"Everyone quiet."],[4262,4346,"She's waking up."],[5930,6051,"My name is Astrid Hall."],[6118,6189,"Astrid Hall?"],[6206,6293,"Will you tell me yours?"],[6468,6560,"Nathan Woodford."],[6631,6790,"Let me see you, Nathan Woodford."],[6877,6931,"What are, what are you-"],[6931,6986,"Shh."],[7369,7440,"Now I see."],[7599,7665,"There you are."]],"7":[[104,166,"Nathan."],[229,308,"Your eyes."],[316,392,"They're cursed."],[421,588,"He's blind, you idiot."],[596,734,"Stop being such a drama queen"],[734,825,"and get up."],[909,1155,"I think she's a bit shaken by the crash."],[1184,1313,"Please give us a moment."],[1622,1764,"It's only been an hour"],[1764,1843,"and you're already"],[1843,1989,"causing me problems."],[2027,2264,"No more talking about curses"],[2264,2398,"or casting spells,"],[2398,2548,"or whatever the fuck they do"],[2548,2727,"at that psycho hippie commune."],[2777,2857,"Out here,"],[2865,3003,"nobody believes in your"],[3003,3332,"satanic voodoo witchcraft bullshit,"],[3365,3474,"so you better shut up"],[3482,3570,"and stay out of sight"],[3570,3774,"before you cause an even bigger mess."],[3799,3832,"But,"],[3845,3958,"how am I supposed to go to this school"],[3958,4079,"if I can't use my magic?"],[4120,4329,"Did I ask for your opinion,"],[4329,4529,"you stupid little witch?"],[4546,4754,"I told you to shut up!"],[5096,5263,"That is quite enough, I think."],[5409,5630,"Astrid, I would be happy"],[5630,5764,"to offer you enrollment here"],[5764,5855,"at Huntington Hall."],[5901,5968,"Really? - Really?"]],"8":[[0,58,"I mean,"],[58,183,"Gram, we don't even know her."],[187,383,"Astrid saved your life, Nathan."],[404,533,"We owe her a safe place"],[533,671,"to live and to learn."],[738,971,"Although it is quite late in the semester"],[971,1101,"and the girls' dormitory"],[1101,1217,"is at capacity."],[1234,1359,"Oh, that's not a problem."],[1388,1534,"I prefer to sleep with the boys."],[1730,1922,"I require their masculine energy."],[2022,2152,"No, Astrid,"],[2168,2402,"that is not allowed under school policy."],[2402,2577,"But for now,"],[2602,2736,"you may stay with Nathan and I"],[2736,2902,"at our home just off-campus."],[2911,3040,"Wait, hold on, Gram."],[3040,3073,"I,"],[3119,3215,"I think there's something off"],[3215,3261,"with her."],[3261,3424,"This is not up for discussion."],[3545,3741,"I'm late for my board meeting."],[3753,3928,"Nate, take her to the house"],[3928,4012,"and get her settled."]],"9":[[684,825,"This is only temporary."],[875,1013,"My grandma will find another place"],[1013,1096,"for you to stay soon."],[1247,1384,"Oh, candles!"],[1401,1539,"Now I can perform a protection spell"],[1539,1597,"for your home."],[1597,1760,"No, don't light those up."],[1776,1851,"You know,"],[1851,1993,"if I accidentally knock one over?"],[2218,2281,"Of course."],[2306,2427,"I wouldn't want to start a fire,"],[2427,2535,"even though my intentions"],[2535,2669,"would be pure and honorable."],[2698,2861,"The old gods often play tricks on us."],[3003,3207,"Look, are you actually a witch?"],[3211,3265,"I am."],[3390,3511,"Are you just gonna tell me the truth"],[3511,3578,"just like that?"],[3607,3716,"I have no reason to lie."],[3782,3866,"Though it is troublesome"],[3866,3978,"that mortals of the outside"],[3978,4058,"no longer have knowledge"],[4058,4133,"of us witches."],[4166,4295,"So how'd you get here anyway?"],[4312,4483,"I, I thought you guys lived in coveys?"],[4483,4550,"A coven."],[4587,4775,"And yes, we rarely leave."],[4846,4954,"The outside world struggles"],[4954,5080,"to accept anything"],[5121,5255,"or anyone who's different."],[5655,5809,"She said my eyes were cursed."],[5897,5976,"I wonder if..."],[6047,6118,"So tell me,"],[6214,6314,"you witches have spells"],[6314,6427,"for everything?"],[6502,6614,"Not everything, no."],[6690,6744,"Sometimes,"],[6744,6906,"if my energies are out of balance,"],[6936,7052,"even the strongest spell"],[7052,7173,"can go horribly awry."],[7244,7361,"Haven't you caused enough damage"],[7361,7419,"for one day?"],[7553,7720,"Astrid is a threat to the whole coven."],[7745,7845,"She needs to go."],[8608,8679,"You okay?"],[8821,8967,"Where is your bed, Nathan Woodford?"],[8967,9088,"I wish to sleep with you now."],[9234,9313,"Astrid, wait."],[9430,9484,"Hold on."]],"10":[[66,187,"Astrid, where the hell are you?"],[558,646,"Look, I'll tell you"],[646,784,"where the pillows and blankets are,"],[788,955,"and you can stay on the couch, alright?"],[1618,1793,"Nathan, come join me!"],[2469,2552,"There you are!"],[2552,2610,"Come in!"],[2744,2827,"What do you think you're doing?"],[2890,2982,"I prefer to bathe"],[2982,3123,"in streams and waterfalls,"],[3123,3257,"but this is very nice as well."],[3299,3445,"Water has many healing properties,"],[3445,3495,"you know."],[3516,3620,"Yeah, well you need to"],[3620,3737,"heal somewhere else."],[3782,3962,"I meant for you, Nathan Woodford."],[4049,4149,"I'll get you a towel."],[4554,4667,"Won't you come any closer?"],[5030,5117,"Closer."],[5522,5580,"Whoa!"],[5697,5768,"What was that?"],[5805,5935,"Just a little spark."],[6956,7044,"What is she doing?"],[7082,7148,"Is this"],[7228,7307,"magic?"],[7882,7962,"I told you,"],[8087,8354,"your energy is drawn to mine."]],"11":[[221,408,"What is going on here?"],[408,458,"Gram!"],[667,771,"Hello, Dean Woodford."],[859,980,"I thought you had a meeting."],[1021,1142,"It was rescheduled."],[1234,1480,"Both of you, dry off and get dressed."],[1522,1576,"Now."],[1826,1881,"My God."],[2794,2915,"Was your grandmother upset?"],[3094,3374,"More like surprised and relieved."],[3436,3536,"Because I haven't dated much"],[3561,3628,"at school."],[3691,3820,"Or ever, really."],[3924,3991,"I just told her"],[3991,4237,"the shower was a misunderstanding."],[4383,4533,"Come, sit with me."],[4829,4934,"Even as a witch,"],[4934,5067,"I cannot force our energies"],[5067,5159,"to merge, Nathan."],[5213,5330,"It must happen naturally."],[6118,6302,"I sense your soul is conflicted."],[6448,6606,"First my eyes are cursed,"],[6606,6748,"now my soul is conflicted."],[6781,6865,"Does anybody ever tell you"],[6865,6948,"how weird you are?"],[7036,7102,"Frequently."],[7611,7695,"Isn't it freaky"],[7695,7862,"that we have the same birthmark"],[7862,8008,"in the same exact spot?"],[8078,8254,"Freaky is a relative term."],[8358,8500,"I prefer the word fate."],[8729,8808,"What are you doing?"]],"12":[[33,158,"You felt that too, didn't you?"],[158,246,"What the fuck was that?"],[296,404,"Don't, don't try any crazy"],[404,508,"spells on me, alright?"],[525,696,"This isn't a spell, Nathan."],[734,859,"When our energies combine,"],[859,1076,"I feel powerful."],[1155,1238,"Powerful like how?"],[1355,1488,"Like I can heal you."],[1614,1697,"Isn't that what you want?"],[1697,1839,"Don't play around with me, witch girl."],[1872,2010,"I do not wish to play around."],[2052,2202,"I can help you restore your vision."],[2231,2423,"And you can help me balance my powers."],[2477,2681,"All I require is that you sleep with me."],[2919,2961,"Okay."],[3094,3303,"If you can actually heal me,"],[3428,3499,"I'll sleep with you."],[3545,3649,"I'll do whatever you want."],[3712,3753,"Okay?"],[3828,3878,"Deal?"],[4396,4567,"I must go make the preparations."]],"13":[[291,433,"Did you find what you're looking for?"],[525,692,"Oh, not exactly."],[692,867,"These texts are very rudimentary."],[867,1076,"I seek instructions on curse reversals."],[1505,1559,"Where do you keep"],[1559,1701,"your forbidden manuscripts?"],[1968,2027,"What?"],[2156,2231,"There she is."],[2302,2394,"Astrid!"],[2444,2585,"Ah, dearest sister."],[2635,2802,"I told you to never call me that."],[3040,3132,"Would you excuse me"],[3132,3232,"and my silly sister"],[3232,3307,"for a moment?"],[3691,3757,"Let's go."],[4145,4212,"Hey bro,"],[4233,4295,"something's going down"],[4295,4400,"between the head cheer bitch"],[4400,4462,"and the new girl."]],"14":[[33,179,"What the fuck are you doing here?"],[225,371,"Well, I was trying to"],[371,504,"research curse reversals,"],[517,608,"but the resources here"],[608,750,"are surprisingly limited."],[871,1113,"I mean, what are you doing at my school?"],[1184,1305,"You and your freaky bitchcraft"],[1305,1397,"don't belong here."],[1505,1672,"You know, Mom told me that"],[1672,1814,"back in the olden days,"],[1847,1939,"they used to take people"],[1939,2089,"accused of witchcraft,"],[2127,2298,"and burn them at the stake."],[2423,2523,"Apparently, real witches"],[2523,2594,"were immune to it."],[2861,2944,"Why don't we just test out"],[2944,3057,"that little theory, huh?"],[3486,3616,"No, Georgina, please don't."],[3962,4112,"You make one fucking sound,"],[4120,4191,"and I'll burn your"],[4191,4312,"fucking face off, witch."],[4312,4404,"Burn the witch!"],[4408,4517,"Burn the witch!"]],"15":[[158,266,"Stop right there!"],[400,487,"What's going on back there?"],[487,604,"Nothing for you"],[604,779,"to worry your pretty little head about."],[809,859,"No?"],[913,988,"Then let me pass."],[1042,1222,"Can't do that, blind boy."],[1238,1397,"But I think there were a couple of mice"],[1397,1484,"looking for you."],[1689,1755,"Is something burning?"],[1785,1885,"Burn the witch!"],[1889,1960,"Burn the witch!"],[1960,2035,"Astrid!"],[2794,2840,"What?"],[2873,2977,"What the fuck was that?"],[3028,3086,"Did you just use your"],[3086,3215,"fucking magic on me?"],[3244,3378,"Just leave me be, Georgina."],[3378,3503,"I don't want to hurt you."],[3532,3620,"I'm warning you."],[3762,3928,"I swear, I'm gonna make sure you"],[3928,4058,"end up like your dead idiot daddy,"],[4058,4183,"you stupid witch!"]],"16":[[4,141,"You stupid witch!"],[141,187,"Astrid!"],[329,375,"Astrid!"],[508,600,"Astrid, where are you?"],[600,754,"What the fuck was - Astrid."],[754,817,"that, Nate?"],[825,905,"I smell fire,"],[905,988,"so I think I pretty much"],[988,1071,"just saved your life."],[1468,1547,"What did you do to Astrid?"],[1609,1710,"I was just giving her"],[1739,1931,"a proper Huntington Hall welcome."],[1931,2072,"Yeah, sure you were."],[2210,2256,"You okay?"],[2485,2652,"He can't see you, dipshit."],[2694,2827,"She's fine, Daredevil."],[2848,2965,"Why do you care?"],[3199,3269,"Because we're dating."],[3340,3403,"What? - What?"],[3511,3574,"I'm her boyfriend."],[3624,3687,"As if."],[3720,3828,"Who would want to date her?"],[3962,4029,"Astrid?"]],"17":[[784,905,"I owe my life to Astrid."],[1005,1130,"We're destined to meet each other."],[1292,1334,"Right?"],[1418,1459,"Oh!"],[1539,1634,"Yes, that's true."],[1685,1843,"Nate and I are very much dating."],[1906,2060,"We're destined to merge energies."],[2114,2252,"And you know my grandmother."],[2293,2481,"She's the dean, in case you forgot."],[2548,2644,"And she would hate to hear"],[2644,2823,"if Astrid was being mistreated."],[2907,2973,"Well, don't you two"],[2973,3082,"make the perfect couple."],[3098,3290,"The blind leading the mentally disturbed."],[3520,3678,"Sorry, my hand got burned."],[3707,3774,"What did I say"],[3774,3958,"about keeping your idiot mouth shut?"],[4154,4266,"You said you got powers?"],[4433,4491,"Show them."],[5180,5267,"What the fuck?"]],"18":[[0,79,"It's the witch!"],[104,208,"She's making me do this!"],[237,304,"Stop it!"],[329,467,"Stop it, you little fucking-"],[467,579,"G, your hair is on fire!"],[579,709,"I know it, you fuckwit!"],[709,767,"Help me!"],[767,863,"You put her hair on fire?"],[892,992,"Well, technically speaking,"],[992,1059,"she put her own hair"],[1059,1113,"on fire. - No, no."],[1255,1317,"Um, we gotta go."],[1317,1376,"This is not good."],[1393,1468,"Let's go, let's go."],[1488,1539,"Go."],[1701,1760,"Okay, stop."],[1760,1797,"Stop."],[1797,1835,"Stop!"],[1851,1901,"Stop!"],[2010,2056,"What?"],[2102,2147,"What?"],[2168,2214,"What?"],[2231,2277,"What?"],[2711,2786,"Oh my god."],[2823,2919,"No, I'm not."],[2936,3040,"No, I'm not."],[3244,3374,"I didn't mean to hurt her."],[3411,3520,"I know you didn't mean to,"],[3520,3566,"but look,"],[3591,3699,"she got what was coming to her."],[3924,3987,"Nathan?"],[4041,4087,"Yeah?"],[4200,4346,"So, since we are dating,"],[4458,4596,"does that mean you'll sleep with me now?"],[4842,4892,"Um..."]],"19":[[0,254,"Astrid, I made up that we were dating,"],[291,429,"because I thought Georgina"],[429,550,"wouldn't mess with you anymore, if"],[617,692,"you know, she thought she could"],[692,796,"get in trouble with the Dean."],[917,967,"Oh."],[1151,1338,"So, we're not dating?"],[1376,1476,"If we were,"],[1476,1605,"you wouldn't have to ask that."],[2114,2198,"Let's head back home."],[4846,4909,"Astrid?"]],"20":[[321,404,"Astrid, are you there?"],[1059,1126,"Astrid."],[1655,1714,"God."],[1793,1843,"What am I doing"],[1843,1897,"worrying about some"],[1897,2035,"weird horny witch girl?"],[2264,2435,"Maybe she really did cast a spell on me."],[2544,2811,"By magic powers both old and new,"],[2840,3015,"I hope to make your wish come true."],[3098,3215,"Find me by the pool."],[3370,3499,"This shit cannot be real."],[4696,4804,"Hey, I thought we talked about"],[4804,4900,"lighting candles."],[5176,5230,"Astrid?"],[5259,5347,"Nathan Woodford."],[5363,5480,"What excellent timing."]],"21":[[4,75,"Are you coming in?"],[150,212,"Are you kidding?"],[212,316,"Do you even know what time it is?"],[342,433,"It's witching hour,"],[458,679,"a time of great cosmic potential."],[850,1013,"You said if I would heal your eyes,"],[1013,1101,"you would sleep with me."],[1142,1263,"So, are you coming in or not?"],[1472,1539,"I don't know."],[1589,1743,"Look, I only have seven days"],[1743,1835,"to balance my powers"],[1835,1972,"before they take them away for good."],[1993,2093,"And then I'll be banished."],[2114,2289,"And I can't ever heal your eyes."],[2419,2519,"Please, Nathan."],[2594,2681,"I won't hurt you."],[2681,2777,"You can trust me."],[2923,3003,"I can't fucking believe"],[3003,3090,"I'm doing this."],[3219,3286,"Alright, fine."],[3286,3382,"You win, witch girl."],[3628,3732,"A little to the left."],[3837,3945,"A little more."],[3978,4033,"There."],[4116,4191,"Okay, you're at the edge."],[5768,5864,"I know you've got that crazy look"],[5864,5914,"on your face"],[5914,6010,"even if I can't see it."],[6031,6118,"Not yet, you can't."],[6877,7015,"Now listen to the sound of my voice"],[7015,7111,"and close your eyes."],[7248,7311,"I'm already blind."],[7311,7382,"Why does it matter?"],[7394,7449,"It matters."],[7449,7503,"Trust me."]],"22":[[16,79,"Nervous?"],[162,266,"A little, yeah."],[321,421,"Here, breathe in."],[675,721,"Breathe out."],[1005,1059,"Ready?"],[1343,1497,"From the depths of shadows,"],[1497,1618,"let light now appear,"],[1651,1805,"dispel the darkness,"],[1805,1931,"and banish all fear."],[1976,2223,"Lux Tenebris, shine bright and clear."],[2677,2740,"What's happening?"],[3078,3144,"Magic."],[4612,4700,"Now take my hand."],[5084,5176,"Now open your eyes."]],"23":[[671,734,"Wow."],[875,934,"She's..."],[1105,1180,"beautiful."],[1355,1463,"Nathan, your eyes."],[1493,1584,"They're beautiful."],[1659,1747,"I can see you."],[1814,1918,"It means the spell worked."],[2469,2615,"I don't know how I could ever thank you."],[2852,2977,"Now that my task is complete,"],[2977,3065,"you must sleep with me."],[3211,3253,"Now?"],[3294,3399,"That was your oath, wasn't it?"],[3532,3666,"Come, let us go to your room."]],"24":[[913,988,"Wow."],[1105,1247,"It's a bit smaller in here than I thought."],[1659,1735,"Thanks."],[1805,1843,"Bed."],[1864,1914,"Now."],[3315,3370,"Ready?"],[3653,3799,"Uh, yeah, just, uh,"],[3862,3916,"need a second."],[4308,4446,"Okay, but hurry,"],[4446,4542,"please, I need to recharge"],[4542,4658,"from that spell I just did."],[4884,4967,"You got this, man."],[5084,5171,"She's just a girl,"],[5276,5359,"who magically gave you"],[5359,5438,"your sight back,"],[5522,5701,"and is kind of insane."],[6894,7036,"So this is what I look like now."],[7853,7912,"Not bad."],[8354,8425,"So, uh."],[8546,8679,"Look, I'm just gonna be honest."],[8696,8812,"I've never done this before."],[9021,9088,"You're sure you want to"],[9088,9159,"sleep with me, right?"],[9242,9300,"Of course."],[11753,11799,"Um,"],[11995,12141,"are we gonna sleep together now?"],[12308,12362,"Yeah."],[12399,12441,"I mean,"],[12491,12583,"we have all night."],[12737,12825,"We can take our time."],[13038,13125,"Wait, what are you-"]],"25":[[45,229,"Is this what people normally do"],[229,354,"before sleeping together?"],[1084,1234,"Uh, what are you doing?"],[1368,1518,"Did you, uh, not like it?"],[1526,1776,"No, it's just, I, I thought that-"],[1776,1897,"I, I thought you said you wanted me"],[1897,1951,"to sleep with you."],[1972,2260,"Yes, I said sleep, not fornicate."],[2494,2602,"Oh, fuck."],[2648,2706,"Okay."],[2723,2877,"Fuck, I thought you meant..."],[2998,3065,"Jesus, Astrid,"],[3065,3211,"I thought when you said sleep with you,"],[3211,3257,"you meant-"],[3257,3336,"I know what you meant."],[3415,3557,"Sorry, I'm just confused."],[3599,3682,"What are we supposed to do?"],[3682,3716,"Just"],[3787,3903,"sleep side by side?"],[3958,4008,"Yes."],[4087,4175,"When we slumber,"],[4175,4308,"my energies will merge with yours"],[4308,4412,"and create a balance."],[4696,4783,"Yeah, I just..."],[4942,4979,"I don't know"],[4979,5109,"how I'm gonna sleep after all that."],[5109,5176,"Somnium."],[5718,5868,"Men are such strange creatures."]],"26":[[400,479,"Blessed morrow."],[513,583,"Morning."],[621,684,"You hungry?"],[759,980,"Yes, I'm absolutely famished."],[1151,1201,"Thank you."],[1242,1393,"What is going on here?"],[1472,1626,"Is that Nate's shirt?"],[1710,1755,"And..."],[2135,2327,"Are you making breakfast?"],[2385,2498,"It's a snazzy suit, Gram."],[2498,2619,"You got a big meeting today?"],[2706,2852,"Wait, I don't understand."],[3119,3215,"You can see?"],[3324,3403,"I can see."],[3457,3532,"Oh my God."],[3628,3707,"Oh my God!"],[3962,4074,"Wait, wait, wait, wait."],[4099,4175,"But how?"],[4237,4333,"It's all thanks to Astrid."],[4646,4725,"Come here, girl."],[5146,5234,"Thank you, Astrid."],[5292,5367,"Thank you."],[5413,5488,"Come here."],[5543,5701,"Oh my God."],[5776,5834,"Come here."]],"27":[[846,905,"Whoa."],[1088,1130,"You look like a"],[1130,1259,"Huntington Hall student now."],[1313,1488,"These garments are very restricting."],[1522,1618,"Yeah, sorry about that."],[1618,1785,"They're not uh, sacred cloaks"],[1785,1876,"or anything, but,"],[1939,2031,"you'll fit right in here."],[2102,2223,"Speaking of which."],[2485,2615,"But you don't need that anymore."],[2652,2756,"Thanks to you, I don't."],[2781,2873,"But um, I don't think"],[2873,2961,"I want to tell everyone"],[2961,3036,"about my vision"],[3078,3153,"just yet."],[3186,3282,"I don't want to change the way"],[3282,3340,"they treat me."],[3415,3482,"You know what I mean?"],[4275,4371,"You haven't changed."],[4404,4521,"Not the most important parts"],[4521,4587,"of you anyway."],[4746,4863,"Alright, I think we're gonna be late."],[4921,4979,"Listen."],[5063,5271,"Our union is a very powerful one,"],[5271,5338,"Nathan Woodford."],[5380,5447,"It was all you."],[5447,5526,"I didn't do much."],[5543,5618,"No, you're wrong."],[5672,5834,"Combined, our energies"],[5834,5955,"are in perfect balance,"],[5955,6072,"masculine and feminine."],[6143,6231,"I think that..."],[6356,6485,"Well, I think we should"],[6485,6577,"sleep together again."]],"28":[[37,129,"Just once more."],[129,266,"Just to ensure the balance."],[279,387,"Yeah, yeah, for sure."],[387,546,"I think we can work something out."],[633,821,"And then I can return to my coven."],[1076,1176,"Wait."],[1305,1418,"So, you mean, you're leaving?"],[1455,1522,"Of course."],[1543,1639,"I'm going to present myself"],[1639,1747,"to my High Priestess,"],[1747,1881,"show her I've balanced my powers,"],[1881,2093,"and finally reunite with my sisters."],[2293,2352,"So next week,"],[2352,2510,"you're just gonna leave,"],[2510,2581,"just like that?"],[2731,2781,"Yes."],[2852,2927,"That was always the plan."],[2927,3028,"I thought you knew this."],[3082,3140,"Right, yeah,"],[3140,3311,"it's just a part of our deal."],[3390,3470,"Help each other out"],[3470,3570,"and get the fuck out"],[3570,3657,"of each other's lives."],[3970,4041,"Works with me."],[4337,4512,"Nathan, have I said something"],[4512,4583,"to upset you?"]],"29":[[83,216,"Astrid is from a,"],[333,467,"unconventional private school."],[500,642,"I encourage all of you to help her"],[642,759,"catch up on her lab work."],[846,967,"Today, we are"],[967,1126,"finishing up experiments"],[1155,1351,"with different energetic bonds."],[1405,1514,"Feminine and masculine?"],[1805,1881,"Not quite."],[1964,2072,"Chemical bonds."],[2072,2131,"Oh."],[2143,2235,"Yes, I see."],[2252,2364,"Covalent? Ionic?"],[2402,2556,"Or did you mean Hydrogen bonds?"],[2565,2673,"They're very weak, of course,"],[2673,2823,"but very influential in nature."],[2907,2977,"Yes."],[3023,3157,"Why don't you work with Mason?"],[3228,3345,"He could use the help."],[3424,3557,"But Mason's my partner."],[3574,3699,"This is chemistry, Georgina."],[3720,3795,"Not the prom."],[3837,3995,"Go work with Nancy and Angela."],[4037,4204,"You will be spending summer school"],[4204,4308,"together anyways."],[5271,5409,"Chemistry is a fundamental part"],[5409,5543,"of my magical practices."],[5730,5847,"Screw my mom."],[5897,6047,"I'm not waiting until she turns 18."],[6101,6202,"I want her gone."],[6227,6285,"Now."]],"30":[[1618,1718,"Luke, what's going on?"],[1826,1951,"How'd you know it was me? But-"],[1968,2002,"You know what?"],[2002,2035,"Never mind."],[2035,2097,"Look, we gotta go, man."],[2097,2164,"Come on, fast."],[2164,2298,"It's something about the new girl."],[2335,2373,"Astrid!"],[3128,3194,"What is it?"],[3432,3582,"It's the sign of the devil, bro."],[3695,3799,"Burning on the grass."],[3812,3987,"It's your freak of a girlfriend."],[3987,4179,"She's trying to put a curse on all of us."],[4379,4521,"No, no, no, no, no, no, no, no..."],[4600,4683,"Oh my God!"],[4708,4867,"Who here saw what happened?"],[4888,4938,"She did."],[4971,5034,"Tell her."],[5067,5276,"It, it was the new girl!"],[5313,5547,"I saw her stealing a gas can"],[5547,5663,"from the gardener's shed."],[5772,5985,"And this is a witch thing, right?"],[6035,6185,"I heard, that Astrid"],[6185,6343,"got thrown out of her last school"],[6373,6535,"for setting it on fire."],[6664,6810,"I guess old habits die hard"],[6810,6940,"for pyro lunatics."],[6961,7194,"Astrid, come with me to my office now."],[7207,7286,"She didn't do it."]],"31":[[12,162,"What are you talking about, Nate?"],[162,287,"Georgina and her little clique"],[287,342,"set her up."],[371,446,"I know they did."],[446,629,"Are you seriously defending her"],[629,688,"right now?"],[713,900,"You haven't even seen the evidence."],[900,1151,"He can't even see anything, remember?"],[1301,1384,"I don't need to."],[1426,1514,"Okay? You've been gunning for her"],[1514,1580,"since she got here."],[1580,1718,"Oh, please."],[1739,1810,"Don't flatter her"],[1810,1939,"just because she's the first girl"],[1939,2102,"that doesn't treat you like wallpaper."],[2122,2185,"He isn't."],[2202,2277,"You're the only one"],[2277,2364,"who benefits from this."],[2402,2494,"All eyes on Astrid"],[2494,2585,"while you play the hero?"],[2669,2773,"Classic misdirection."],[2786,3023,"Guys, maybe we should just,"],[3044,3207,"I mean, I really gotta-"],[3207,3415,"Angela, shut up."],[3436,3661,"But the gas can's still in Nancy's..."]],"32":[[37,191,"What did you just say?"],[241,308,"Nothing!"],[329,458,"She said nothing!"],[558,696,"Look, I mean,"],[746,913,"I thought we were just playing a prank."],[975,1238,"Georgina said it wouldn't get serious."],[1313,1401,"No, come on."],[1447,1551,"Are you seriously"],[1551,1710,"gonna believe them over me?"],[1764,1856,"This whole school"],[1856,2056,"is crawling with weirdos, okay?"],[2056,2227,"That freak probably did it to herself"],[2227,2298,"for attention."],[2919,3107,"I don't know how that got there, I swear."],[3107,3228,"You dumbass!"],[3244,3407,"You were supposed to dump it!"],[3453,3561,"That is enough!"],[3599,3812,"I will be speaking to both of you"],[3812,4008,"in my office separately."],[4037,4170,"And as for you, Georgina,"],[4237,4325,"as punishment"],[4325,4525,"for defacing school property"],[4587,4804,"and framing another student,"],[4804,4942,"you are stripped of"],[4942,5084,"your Prom Committee duties"],[5100,5392,"and relieved as head cheerleader."]],"33":[[20,183,"You can't do that to me, okay?"],[225,371,"I've always been head cheerleader."],[371,538,"And I'm supposed to be prom queen!"],[583,784,"I guess you should have thought of that"],[784,1030,"before you decided to play with fire."],[1284,1397,"Take them to my office."],[1551,1630,"Ah!"],[1876,2252,"Astrid, I am so, so sorry."],[2285,2373,"I should have believed you."],[2594,2656,"Are you okay?"],[2765,2861,"Yes, I believe so."],[3028,3123,"Thank you, Nathan."],[3516,3599,"You did the right thing."],[3682,3799,"Stepsister is a bully."],[3853,3953,"She's always been a bully."],[4037,4183,"You just bring it out in her even more."],[4329,4504,"Georgina is a tormented soul."],[4608,4692,"If she had been born"],[4692,4804,"with the ability of magic,"],[4804,4967,"I fear what she would be capable of."],[5100,5305,"Sorry I was being a dick this morning."],[5455,5547,"What does dick mean?"],[5726,5830,"Look, that's not really important"],[5830,5880,"right now."],[5905,5993,"I'm just..."],[6051,6210,"I'm sorry that I was being a jerk earlier."],[6264,6389,"And I shouldn't have taken my anger"],[6389,6456,"out on you."],[6456,6573,"All is forgiven, Nathan."],[6856,6981,"Well, as long as you live up"],[6981,7057,"to your end of the deal"],[7057,7119,"and sleep with me."],[7211,7265,"Astrid."],[7624,7678,"Astrid!"],[7749,7870,"I, I can't see again."],[7970,8037,"What happened?"]],"34":[[12,70,"The curse."],[120,221,"I thought I had cleared it,"],[221,354,"but it's returned."],[417,546,"It's rooted deep within you."],[633,734,"I do not know the source"],[734,867,"of such terrible magic."],[938,1105,"I must consult my High Priestess."],[1380,1455,"Come, Nathan."],[2043,2206,"The High Priestess will know what to do."],[2256,2339,"Didn't your coven threaten"],[2339,2402,"to take your powers"],[2402,2469,"if you went back?"],[2523,2615,"Let them try."],[2690,2769,"But if you leave-"],[2790,2873,"I will come back,"],[2915,2994,"with my powers."],[2994,3098,"And I will heal you again."],[3128,3194,"I promise."],[3432,3557,"Look, before I leave,"],[3707,3803,"we have to bind ourselves"],[3803,3866,"to one another."],[3891,3962,"Bind ourselves?"],[3962,4024,"What is that?"],[4254,4300,"Whoa!"],[4325,4404,"What, what are you doing?"]],"35":[[287,400,"I am hand fasting us."],[433,496,"Give me your arm."],[1005,1092,"Nathan Woodford."],[1163,1292,"I promise to protect thee"],[1292,1401,"fully and wholly"],[1401,1484,"without restraint,"],[1555,1685,"in sickness and in health,"],[1751,1939,"in plenty and in poverty,"],[2006,2110,"in life and beyond."],[2289,2348,"Your turn."],[2489,2569,"Astrid Hall."],[2590,2719,"I promise to protect thee"],[2719,2802,"without restraint"],[2869,2940,"as well."],[2982,3040,"Now..."],[3090,3190,"In life and beyond."],[3240,3332,"In life and beyond."],[3499,3541,"Good."],[3603,3728,"Now we must seal the hand fast"],[3728,3787,"with a kiss."]],"36":[[392,462,"What was that?"],[483,571,"You're asking me?"],[684,771,"I feel like I could..."],[846,888,"I, I don't know,"],[888,975,"like I could light"],[975,1105,"the whole school on fire."],[1146,1230,"Don't do that."],[1230,1313,"We just convinced the dean"],[1313,1459,"that you're not a pyromaniac."],[1493,1626,"The High Priestess will guide me."],[1651,1780,"I will heal you again."],[1814,1893,"I promise."],[1943,1997,"Wait!"],[2302,2348,"I..."],[2481,2531,"Nathan?"],[2752,2840,"I'm gonna call you a driver."],[2977,3019,"Here."],[3128,3194,"What is this for?"],[3194,3349,"I'm inheriting millions, Astrid."],[3349,3386,"What do you think?"],[3386,3457,"I was gonna let you fly home"],[3457,3532,"on a broomstick?"]],"37":[[425,650,"God, this is a fucking disaster!"],[675,859,"I've been suspended from cheer,"],[859,1030,"I'm kicked off the Prom Committee,"],[1030,1226,"and it's all thanks to your shitty acting!"],[1326,1397,"This little witch thinks"],[1397,1601,"she can come to my school"],[1601,1730,"and ruin my life?"],[1743,1851,"Just because her boyfriend's"],[1851,1956,"is related to the dean?"],[2181,2389,"I still can't believe Astrid's dating Nate."],[2398,2464,"Isn't he supposed to be"],[2464,2594,"like, totally loaded?"],[2610,2769,"No, not yet."],[2831,3069,"His parents are like hella rich though."],[3128,3224,"My dad's their lawyer."],[3265,3365,"Well, one of them."],[3382,3449,"I guess that's why"],[3449,3561,"Nate lives with his grandma."],[3578,3791,"Yeah, but that's just until he turns 18."],[3803,3945,"Then he gets his trust fund"],[3945,4079,"and he's basically like"],[4079,4191,"the youngest billionaire"],[4191,4258,"in the world."],[4300,4341,"What?"],[4429,4491,"Blind boy genius"],[4491,4592,"is gonna be a billionaire"],[4592,4717,"and none of you guys told me?"],[4763,4825,"You guys are supposed to be"],[4825,4917,"my best friends."],[4934,4996,"You guys know that"],[4996,5125,"I've always wanted to marry rich."],[5125,5255,"But you're with Mason."],[5317,5518,"And that's like true love."],[5563,5613,"Right?"],[5768,5814,"Mhm."],[7653,7799,"Sisters, I have returned."]],"38":[[120,183,"Astrid!"],[237,321,"You were sent away"],[321,487,"because you were a danger to the coven."],[529,646,"And now you dare to return."],[700,838,"I have done as you've instructed."],[888,1038,"I merged with masculine energies"],[1038,1180,"and I learned to control my power."],[1276,1380,"You slept with a man?"],[1430,1505,"Nathan Woodford."],[1522,1630,"He's a schoolmate of mine."],[1668,1780,"His eyes are cursed."],[1810,1889,"I healed him, but"],[1889,2068,"but the counterspell didn't last."],[2127,2302,"I've come to beg for your guidance."],[2344,2481,"Please, High Priestess,"],[2481,2615,"show me how to fully heal him."],[2656,2740,"This young man,"],[2786,2886,"Nathan Woodford."],[2973,3123,"You say he was not born with blindness,"],[3123,3194,"but cursed."],[3286,3403,"Are you absolutely certain?"],[3674,3849,"There's a powerful dark energy"],[3849,3916,"at work here."],[3970,4120,"I'm impressed you lifted it all."],[4133,4270,"It is unusual for a witch"],[4291,4341,"to have formed"],[4341,4504,"such a strong bond with a mortal"],[4542,4662,"in such a short time."],[4700,4788,"There's something else."],[4808,4975,"He and I share the same mark."],[5105,5176,"When I'm with him,"],[5176,5301,"I feel like my body"],[5301,5467,"is on fire with pure power."],[5518,5668,"If what you say is true,"],[5718,5868,"this is no ordinary bond,"],[5922,6122,"I believe you found your soul's mate."]],"39":[[20,183,"Most go their entire lives,"],[183,321,"never knowing they are mated."],[333,508,"Your shared mark proves it."],[538,688,"Your soul is bound to his."],[771,888,"Means you're unified."],[988,1076,"You're stronger."],[1126,1184,"Whole."],[1226,1368,"But I believe at some point"],[1368,1505,"before you came to us here,"],[1543,1668,"your soul and Nathan's"],[1793,1889,"were split apart."],[2043,2097,"You were left"],[2097,2273,"with only your feminine energies,"],[2314,2473,"while Nathan was afflicted"],[2502,2602,"with dark magic."],[2602,2715,"I don't understand."],[2715,2873,"Why would someone wish to harm him?"],[2940,3036,"This I do not know."],[3057,3261,"If you wish to cure his curse,"],[3336,3453,"you must fully"],[3691,3832,"reunify your souls."],[3832,4012,"But I already slept with him."],[4074,4187,"We are hand fasted."],[4216,4362,"Even that might not be enough."],[4379,4554,"Properly merging energies"],[4650,4884,"requires a more, intimate touch."],[5730,5876,"Return to Nathan Woodford."],[5876,5976,"Have him drink this"],[6018,6168,"before you merge energies again."],[6222,6460,"This will open up his heart to yours."],[7428,7490,"Astrid?"],[7716,7795,"Astrid, is that you?"],[7920,7991,"Hi Nate."],[8099,8258,"Astrid's not home, right?"]],"40":[[95,162,"Georgina?"],[254,321,"What are you doing here?"],[350,417,"Oh..."],[471,671,"I've got a little proposal for you."],[704,792,"Mind if I come in?"],[1605,1705,"Drinking the dean's booze"],[1705,1785,"in her own house?"],[1826,1931,"A bit risky, don't you think?"],[1964,2077,"What can I say?"],[2106,2293,"I just love living dangerously."],[2819,2877,"Cheers!"],[2994,3090,"What do you want, Georgina?"],[3211,3278,"I think you've got"],[3278,3411,"the wrong impression of me."],[3424,3482,"Oh really?"],[3507,3545,"You didn't try to burn"],[3545,3649,"your stepsister alive?"],[3724,3799,"I admit that"],[3799,3916,"my feelings towards Astrid"],[3916,4104,"are complicated."],[4225,4396,"Growing up, she just always got"],[4396,4533,"so much more attention."],[4596,4750,"So I always felt less special."],[4838,4938,"And now she has something"],[4938,5180,"I've always wanted."],[5351,5434,"Aren't you with Mason?"],[5455,5626,"Oh, please."],[5672,5776,"That dumbass."],[5814,5935,"He can't keep up with me."],[6010,6239,"Now you, on the other hand,"],[6285,6348,"I think we'd make"],[6348,6477,"a pretty unstoppable duo."]],"41":[[83,166,"You need to leave."],[262,321,"Now."],[717,775,"Nathan?"],[809,867,"Astrid."],[955,1067,"Are you merging with her?"],[1121,1272,"She came onto me, I swear."],[1288,1405,"Oh, come on, pookie."],[1426,1593,"Astrid deserves to know the truth."],[1626,1747,"Nate invited me over today"],[1747,1893,"since we knew you'd be away."],[1931,2127,"We've always had a magnetic attraction"],[2127,2206,"to each other."],[2206,2385,"And I admit, I'm weak."],[2402,2502,"What are you talking about?"],[2523,2656,"Who are you going to believe, Astrid?"],[2715,2848,"Some guy you just met,"],[2932,3028,"or your own family?"],[3186,3269,"Your sister?"],[3599,3712,"Once upon a time,"],[3712,3891,"this is all I ever wanted from her."]],"42":[[692,750,"Get out."],[855,946,"Before I make you."],[1167,1259,"What are you gonna do?"],[1276,1376,"Put a curse on me?"],[1401,1534,"Set me on fire again?"],[1972,2035,"Don't do it."],[2068,2139,"She's not worth it."],[2185,2239,"You wouldn't want to"],[2239,2369,"hurt your own sister, would you?"],[2627,2769,"You told me to never call you that,"],[2769,2831,"remember?"],[2915,3086,"For years, that's all I ever wanted."],[3153,3319,"To be your real, true sister."],[3365,3411,"But now I know"],[3411,3516,"that was never gonna happen."],[3570,3712,"You have too much hatred in your heart."],[3712,3878,"How fucking dare you?"],[3916,4049,"After all me and my mother"],[4049,4137,"have done for you,"],[4170,4241,"you have no right"],[4241,4404,"to fucking speak to me like that."],[4446,4571,"Before we came around,"],[4621,4688,"you were nothing."],[4708,4846,"And you'd still be nothing"],[4846,4967,"if we didn't keep you around"],[4967,5138,"after your dumb daddy got killed."],[5584,5693,"I am more powerful"],[5693,5814,"than you could ever understand."],[5868,6018,"Don't make me prove it to you."],[6373,6519,"Listen, Astrid, she came in."],[6519,6648,"I didn't want her to even come in."],[6648,6710,"Nothing happened."],[6710,6760,"Shh."],[6827,6881,"I know."],[6965,7044,"I trust you."],[7294,7407,"You're my soul's mate."],[7661,7724,"Soul's mate?"]],"43":[[613,734,"Hey G!"],[934,1109,"What are you doing over"],[1109,1222,"at the Dean's house?"],[1234,1297,"Nothing."],[1380,1518,"Mason can never find out about it."],[1547,1597,"Got it?"],[1647,1701,"Got it."],[3261,3420,"So our matching birthmarks"],[3420,3520,"means that we're soulmates?"],[3528,3749,"I am fated to you as you are fated to me."],[4258,4350,"Does that upset you?"],[4475,4562,"No, I just..."],[4625,4675,"I don't know."],[4675,4713,"It's,"],[4771,4871,"it's a lot to take in."],[4954,5321,"I never believed in magic, fate,"],[5321,5401,"even love"],[5472,5593,"until I met you, Astrid."],[5747,5826,"I've never felt this way"],[5826,5930,"about anybody before."],[6043,6118,"I haven't, either."]],"44":[[41,129,"It's strange."],[150,271,"You're the first person"],[271,392,"to ever truly see me."],[458,529,"All of me."],[588,721,"Even before you had your sight,"],[759,842,"you still accepted me."],[896,967,"Well, you know us freaks"],[967,1080,"gotta stick together, right?"],[2227,2506,"The High Priestess, she also said,"],[2556,2665,"she said something-"],[2673,2731,"What is it?"],[2731,2802,"You can tell me."],[2852,2969,"She said, in order to"],[2969,3107,"fully merge our energies"],[3107,3207,"and to heal you,"],[3286,3482,"we may have to be a bit more..."],[3757,3816,"intimate."],[4016,4091,"So,"],[4133,4250,"more than just sleeping?"],[4633,4733,"You must drink this."],[4771,4884,"It'll make your soul more open"],[4884,4979,"to merging with mine."]],"45":[[692,746,"So..."],[855,1080,"How does one begin the intercourse?"],[1146,1213,"Geez."],[1230,1347,"Way to take the romance out of it."],[1347,1422,"Well, how am I meant to know"],[1422,1568,"what to do without proper instruction?"],[1764,1847,"Let me show you."],[4633,4708,"Is this okay?"],[4838,4929,"If you're nodding yes,"],[4929,5046,"you're gonna say it out loud, too."],[5084,5163,"I'm blind, remember?"],[5163,5238,"Oh, sorry."],[5238,5276,"Um..."],[5342,5484,"Yes, Nathan Woodford, I..."],[5534,5609,"Just call me Nate."],[5734,5805,"Yes, Nate."]],"46":[[492,638,"Good morrow, Astrid."],[663,792,"You look beautiful this morning."],[821,913,"You can see again?"],[980,1080,"I can see again."],[1209,1363,"That means the High Priestess was right."],[1388,1580,"We reunited our souls last night."],[1614,1722,"Is that why we were glowing?"],[1780,1939,"I thought I was just that good in bed."],[2227,2318,"You know, this means"],[2373,2540,"I have to return to my coven now."],[2790,2902,"We healed your eyes."],[2948,3107,"I learned to control my powers."],[3107,3211,"That was our agreement."],[3240,3311,"We're soulmates."],[3311,3349,"That's,"],[3420,3520,"that's what you said, right?"],[3536,3770,"Yes, but my place isn't here."],[3824,3924,"It's with my sisters."],[4087,4162,"You can't leave."]],"47":[[12,325,"I mean, I really don't want you to leave."],[508,658,"I don't belong here, Nate."],[800,888,"We can keep pretending"],[888,1021,"that I fit in at Huntington Hall,"],[1021,1121,"but Georgina is right."],[1159,1326,"This world is no place for a witch."],[1839,1951,"Then fuck Huntington Hall."],[2002,2097,"And fuck the whole world."],[2135,2273,"I turn eighteen tomorrow"],[2273,2385,"and I inherit my trust."],[2410,2594,"We can do anything we want with it."],[2602,2769,"Go anywhere we want."],[2932,3023,"I never considered"],[3023,3073,"what I was gonna do"],[3073,3182,"with the money before"],[3182,3269,"because I just figured"],[3349,3411,"whatever I was doing,"],[3411,3503,"I'd be doing it alone."],[3611,3728,"But now I've met my soulmate."],[3891,3978,"And I can't let you go."],[4225,4283,"I love you."],[4462,4500,"But I thought"],[4500,4612,"you didn't believe in magic"],[4646,4704,"or love."],[4729,4829,"That was before I met you."],[4850,4950,"Are you just saying this"],[4950,5071,"because I healed your eyes?"],[5188,5359,"You healed more than my eyes."],[5438,5697,"I had no plans for my life."],[5722,5855,"All I knew was darkness."],[5905,5993,"Until I met you."],[6206,6427,"I love you for you, Astrid."],[6673,6902,"Please, stay with me."]],"48":[[25,120,"99?"],[233,337,"100?"],[383,517,"Bro, you been juicing or something?"],[517,650,"Like, I've never seen you"],[650,742,"lift this much before."],[763,871,"Not steroids, man."],[921,1021,"I'm hooked on something better."],[1071,1272,"You talking about that weird witch girl?"],[1309,1359,"What?"],[1388,1501,"You got a crush on her or something?"],[1564,1639,"You know I've been blind"],[1639,1747,"since I was a kid, right?"],[1785,1860,"One day all of a sudden"],[1860,2081,"my sight was just gone."],[2156,2310,"Astrid used her magic"],[2310,2427,"and she cured me."],[2427,2531,"I can see now."],[2531,2831,"So... she's an actual witch?"],[2857,3132,"Like... real?"],[3261,3311,"Yeah."],[3403,3561,"Dude, shut the fuck up."],[3561,3712,"Hey, I'll give it to you."],[3712,3791,"You almost had me."],[3978,4099,"Never knew you wore earrings."],[4195,4254,"Suits you."],[4337,4433,"You can see?"],[4433,4521,"Shh!"],[4629,4679,"What..."],[4729,4817,"Woodford!"]],"49":[[20,108,"Don't pull that shit."],[187,300,"You know what the fuck you did."],[300,379,"What are you talking about?"],[450,504,"Look, look."],[508,638,"Georgina, she came onto me man."],[638,671,"I..."],[704,821,"You think you could get away"],[842,967,"with moving on my girl,"],[1013,1105,"because your granny's"],[1105,1213,"the fucking dean?"],[1597,1789,"Like she would ever fuck a blind guy."],[3040,3148,"Yeah, fuck him up!"],[3190,3278,"What the fuck?"],[3653,3703,"Yo."]],"50":[[575,638,"Astrid."],[796,959,"Astrid, what the fuck are you doing?"],[1205,1288,"It's that new girl."],[1334,1388,"The fuck?"],[1388,1530,"She's an actual witch."],[1931,2006,"Release your weapon"],[2006,2097,"and I'll let you walk free."],[2122,2327,"Let me go, you fucking freak."],[2398,2460,"Or don't."],[2540,2594,"We could see"],[2594,2740,"how sharp that knife really is."],[3211,3286,"What are you doing?"],[3411,3465,"Okay, fine."],[3465,3541,"I'll count to three."],[3603,3661,"One."],[3820,3874,"Two."],[4391,4433,"Three."]],"51":[[37,87,"Three."],[200,246,"There."],[433,579,"I think you owe Nathan an apology."],[633,750,"Oh, fuck that!"],[779,892,"That wasn't a question."],[1130,1192,"I'm sorry!"],[1280,1343,"I'm sorry."],[1518,1622,"A bit of sincerity."],[1664,1810,"You fucking bitch, I'm gonna-"],[1931,2052,"I'm very sorry."],[2160,2231,"It won't happen again."],[2268,2331,"I swear."],[3395,3499,"You're not worth this shit."],[3524,3699,"What, but Mason, baby, I-"],[3699,3757,"We're done."],[3778,3837,"I..."],[4466,4571,"If you're finished with your workout,"],[4571,4658,"can we go home now?"],[4859,4946,"Yeah."]],"52":[[133,254,"What's the emergency?"],[254,379,"And why'd I have to drag my ass"],[379,563,"all the way down here to deal with it?"],[654,784,"God, you look like shit."],[804,855,"Yeah?"],[880,1001,"Well, you ruined my life."],[1042,1188,"It's your fault for bringing Astrid here."],[1222,1359,"She got me kicked off the cheer team,"],[1372,1459,"prom committee, and"],[1484,1626,"and Mason just broke up with me!"],[1822,1914,"And what do you expect me"],[1914,2035,"to do about any of that?"],[2081,2285,"I expect you to fix the mistake"],[2285,2419,"you made ten years ago"],[2431,2623,"when those people you hired to kill her"],[2635,2802,"killed her dumb daddy instead."],[2861,3003,"I want Astrid gone."],[3040,3119,"For good."],[3536,3824,"A toast to Nathan and his vision"],[3824,3995,"in every sense of the word."],[4024,4116,"Happy birthday."],[4387,4571,"It's just apple cider, dear."],[4583,4700,"Oh, my favorite."],[5593,5747,"Make a wish for the years to come."],[5751,5860,"But don't say it aloud."],[5860,6006,"Let it sit in your mind and heart."],[6206,6418,"I wish that you could stay by my side,"],[6448,6514,"always."],[6614,6702,"Blow out the flame"],[6702,6877,"and let the smoke carry its intention"],[6877,6961,"into the world."],[7457,7611,"So, I know it's my birthday,"],[7611,7770,"but I got a little surprise"],[7770,7841,"for you, Astrid."],[7841,7987,"Do you mind closing your eyes?"],[8074,8216,"Our roles are finally reversed."],[8500,8537,"Alright."]],"53":[[1026,1155,"My mom told me to meet you here."],[1222,1359,"Come, Georgina."],[1539,1680,"I believe we might be able"],[1680,1805,"to help one another out."],[3174,3253,"You can look now."],[3486,3582,"What's this for?"],[3716,3870,"I thought you liked my uniform."],[3899,3966,"Hey, I do."],[3966,4037,"I just,"],[4054,4187,"you know, I think it's a little plain"],[4237,4320,"for prom."],[4462,4621,"I know it's a little late to be asking,"],[4621,4675,"but, uh..."],[4825,4984,"Astrid, will you go to the prom with me?"],[5134,5292,"I want to tell everybody about us."],[5292,5397,"About how you cured me."],[5447,5538,"You wish to tell everyone"],[5538,5609,"I am a witch."],[5638,5734,"You said there isn't a place"],[5734,5843,"for a witch in this world."],[5893,5993,"So why don't we make one?"],[6131,6177,"You in?"],[6293,6335,"I'm in."],[7440,7595,"Alright, let's get you an outfit."]],"54":[[809,1046,"God, she's such a loser."],[1046,1176,"I can't believe we used to let her"],[1176,1276,"boss us around."],[1401,1547,"I can't believe I used to date her."],[1676,1851,"May we help you, Ms. Hall?"],[1889,2110,"Oh, I just wanted to introduce myself"],[2110,2298,"to Huntington Hall's newest teacher."],[2402,2631,"May I introduce Georgina Hall?"],[2702,2819,"Ms. Knight will be joining us"],[2819,2961,"for the rest of this semester"],[2961,3148,"as your Chemistry instructor"],[3148,3399,"took ill quite suddenly, actually."],[3428,3549,"We were very fortunate"],[3549,3649,"that she was available."],[3720,3807,"I'll say."],[4587,4775,"Oh my God."],[4792,4854,"No way."],[4879,5059,"Is that Astrid?"]],"55":[[592,763,"They make a pretty perfect couple,"],[763,800,"don't they?"],[855,988,"They sure do."],[1063,1188,"Blind boy and his little freak"],[1188,1309,"of a girlfriend."],[1334,1505,"Match made in fucking heaven."],[1568,1818,"I cannot wait to see you enter tonight."],[2181,2327,"If you'll excuse me a moment."],[2585,2715,"Bro, everyone's gonna freak."],[2715,2915,"You're like a magical billionaire now."],[2923,3028,"It's not my magic."],[3028,3098,"It's Astrid's."],[3123,3319,"Well, technically, it's our magic now."],[3353,3453,"Our souls are merged."],[3499,3611,"You know, you don't have to tell everyone"],[3611,3695,"about your sight tonight"],[3695,3762,"if you're not ready."],[3778,3837,"Oh, I'm ready."],[3883,3995,"I want everyone to know exactly"],[3995,4129,"how powerful of a witch you are."],[4362,4546,"A witch, you say?"]],"56":[[0,112,"You have the gift yourself?"],[362,600,"A gift for chemistry, perhaps."],[671,750,"Everyone knows"],[750,917,"witches and magic aren't real."],[1017,1067,"Right?"],[1355,1413,"Ms. Knight."],[1605,1735,"Your new science teacher."],[1818,1960,"Isn't it a little late in the semester"],[1960,2035,"for a new teacher?"],[2052,2181,"I come when I'm called."],[2218,2318,"Your old teacher had to"],[2318,2460,"take a sudden leave of absence,"],[2460,2740,"so I always love to help."],[2936,3015,"Students!"],[3028,3065,"Students!"],[3065,3349,"Hello, Huntington Hall!"],[3390,3745,"Oh, you all look so spectacular tonight."],[3778,4033,"I just wanted to take a moment to say,"],[4058,4279,"that I know you seniors"],[4279,4479,"are racing towards graduation."],[4550,4700,"But I hope you can take..."],[4700,4775,"Nothing to worry about."],[4775,4900,"He can't see anything."],[4992,5063,"Poor kid."],[5088,5267,"... and appreciate your time here"],[5284,5380,"thus far."],[5568,5651,"What is she doing?"],[6427,6614,"Now let's turn that music back up!"],[6781,6823,"No!"],[6852,6981,"Astrid, do not drink that."]],"57":[[12,54,"I saw her"],[54,145,"put something in your drink."],[262,375,"Bro, you think the new teacher's"],[375,508,"trying to roofie your girlfriend?"],[533,642,"You need your new eyes checked?"],[658,734,"I don't know what she's doing,"],[775,896,"but I know what I saw, okay?"],[963,1142,"She denied the existence of witches,"],[1142,1309,"but I sense something"],[1309,1422,"beneath the surface."],[1472,1593,"Some type of power."],[1655,1751,"Why do you think she'd lie to you?"],[1814,2010,"I do not know, but I intend to find out."],[2398,2469,"I got an idea."],[3040,3107,"It's done."],[3148,3253,"She'll drink the elixir"],[3253,3357,"and become susceptible."],[3365,3474,"As soon as it takes effect,"],[3474,3703,"I will drain her of her powers."],[3703,3816,"And it'll kill her, right?"],[3824,4008,"No witch can survive being ripped"],[4008,4099,"from her energy."],[4187,4233,"Good."],[4270,4387,"Then we both get what we want."]],"58":[[638,759,"Can we cut the music for a second?"],[1138,1188,"Sorry for"],[1188,1267,"interrupting, everybody,"],[1309,1355,"but there's something"],[1355,1430,"I just wanted to get out"],[1430,1509,"in the open tonight."],[1534,1626,"I'm sure you've heard the rumors"],[1626,1797,"about Astrid and her abilities."],[1830,1893,"Some of you might have"],[1893,2018,"even seen her powers in action"],[2035,2135,"in the gym the other day."],[2135,2243,"But the truth is,"],[2285,2439,"Astrid Hall is not only"],[2439,2627,"brilliant and beautiful,"],[2711,2894,"but she's also a very powerful witch."],[3382,3503,"She even cured my blindness."]],"59":[[20,150,"I can see the prom banner,"],[191,291,"the flowers, the balloons,"],[291,433,"all my beautiful classmates."],[442,563,"I can even see the Prom King"],[563,663,"and Queen crowns in the back."],[704,855,"So all that witchy bullshit"],[855,975,"was real the whole time."],[975,1126,"I thought she was just a goth."],[1126,1322,"No way she's got actual magic."],[1330,1451,"Maybe he was faking being blind"],[1451,1543,"the whole time."],[1597,1739,"I promise you all it's the truth."],[1768,1851,"We're incredibly lucky"],[1851,2064,"to have Astrid Hall here at our school."],[2110,2239,"And I hope that you join me"],[2264,2364,"in embracing her here."],[3065,3148,"While we're here,"],[3182,3257,"I'd like to invite"],[3257,3407,"our new science teacher, Ms. Knight,"],[3407,3499,"to the stage."],[3566,3695,"What's this about?"],[4220,4312,"Come up here, Ms. Knight."],[4654,4750,"What's this about?"],[4779,4884,"Every coven has their time"],[4884,4975,"honored traditions."],[5013,5142,"Everybody grab a glass."],[5167,5330,"Let's have a cheers to Ms. Knight."],[5355,5484,"She came in and saved the day."]],"60":[[1071,1167,"What have you done?"],[1188,1305,"We only shared the blessing"],[1305,1463,"that you intended to bestow on me."],[1505,1584,"So the real question is,"],[1584,1664,"what have you done?"],[1847,1914,"You can't..."],[2010,2097,"Not again!"],[2364,2427,"Again?"],[2473,2565,"What are you talking about?"],[2644,2723,"Tell us what you've done."],[2765,2852,"Step aside, Nate."],[3978,4066,"Release me!"],[4200,4337,"Tell me the truth first."],[4379,4508,"Tell me what you want."],[4763,4833,"I want..."],[4850,4967,"I wanted your gift!"]],"61":[[237,337,"Why did you come here?"],[483,642,"We had an arrangement."],[658,729,"Hello!"],[729,913,"Is no one going to stop this?"],[913,1055,"Astrid just basically tortured"],[1055,1138,"that poor woman."],[1159,1330,"She's clearly delirious."],[1380,1455,"Dean Woodford!"],[1455,1605,"I, for one, would like to hear"],[1605,1726,"what she has to say."],[2081,2248,"You were an unusual child."],[2381,2548,"So much magical potential."],[2631,2765,"And your stepmother..."],[2873,3028,"she hated you for it."],[3098,3294,"Tell me something I don't know already."],[3386,3474,"She promised"],[3474,3678,"I could take your power for myself."],[3883,3945,"But then..."],[4087,4208,"something went wrong."],[4383,4646,"You were only an untrained child."],[4808,5180,"Yet somehow, you deflected my curse!"],[5472,5588,"And then your father..."],[5684,5772,"My father?"],[5809,5943,"He absorbed the brunt of it."],[6156,6285,"If we didn't keep you around"],[6285,6452,"after your dumb daddy got killed..."],[6527,6614,"You killed him?"]],"62":[[54,175,"He interfered!"],[479,579,"But your soul..."],[692,834,"it resisted the curse."],[1084,1180,"When did your father die?"],[1313,1505,"It's been ten years."],[1643,1776,"I woke up blind ten years ago."],[1843,1901,"Cursed."],[1939,2035,"My soulmate."],[2089,2252,"You took a fraction of the curse."],[2293,2423,"You and my father, together,"],[2423,2498,"you saved me."],[2731,2961,"If only he hadn't been such a fool!"],[3778,3945,"You don't have the guts to kill me,"],[3945,4033,"little witch!"],[4091,4162,"You're right."],[4275,4416,"But I can do something worse."],[4508,4579,"What are you gonna do?"],[4633,4775,"I'm gonna take away her magic."],[4813,4909,"For someone like her,"],[4909,5042,"that's a fate worse than death."],[5584,5751,"You vile little wrench!"],[5801,5864,"Besides,"],[6051,6151,"I know who's really"],[6151,6281,"responsible for this."],[6410,6585,"I had nothing to do with this!"],[6619,6727,"Poor, dear sister."],[6781,6848,"Don't you know that"],[6848,6952,"if you play with fire,"],[6952,7069,"you're bound to get burned?"]],"63":[[375,487,"Oh my God!"],[592,821,"She looks like Mr. Clean."],[900,996,"No, no!"],[1017,1192,"I quit! She's a monster!"],[1705,1851,"This isn't over, you little witch!"],[2010,2160,"Not by a long shot!"],[2377,2431,"Astrid!"],[3361,3474,"That is it!"],[3499,3728,"This prom is officially over!"],[3728,3974,"Everyone back to your dormitories!"],[4496,4579,"You two."],[4600,4692,"Are you okay?"],[4738,4825,"Are you okay?"],[4859,4917,"Yes?"]],"64":[[658,746,"I know prom is supposed"],[746,842,"to be memorable,"],[930,1038,"but that was kind of insane."],[1080,1172,"Only kind of?"],[1484,1634,"Do proms typically include"],[1634,1776,"attempted assassinations?"],[1910,2093,"Okay, it was very insane."],[2389,2510,"You must be exhausted."],[2615,2873,"Well, I did use the full extent"],[2873,2977,"of my energies today."],[3090,3332,"But I also took Ms. Knight's from her."],[3428,3528,"They run through me now."],[3670,3941,"I've never felt this kind of power before."],[4070,4225,"Didn't she use dark magic?"],[4308,4400,"You can call it that."],[4496,4642,"So does that make you a..."],[4717,4904,"Bad, bad witch now?"],[5009,5150,"How do you feel about that, Nate?"],[5251,5422,"How do I feel that my sweet girlfriend"],[5422,5584,"is now a sexy dark witch?"],[5764,5901,"I think I might kind of be into it."],[5964,6060,"Only kind of?"]],"65":[[237,362,"Fuck that, I'm very into it."],[1518,1605,"Good morning, Gram."],[1689,1751,"Is it?"],[1772,1893,"I've been fielding calls"],[1893,2085,"from belligerent parents."],[2118,2289,"The courtyard is a crime scene."],[2318,2510,"Georgina Hall, she's missing."],[2540,2690,"And now, the police want to"],[2690,2886,"take statements from everyone."],[2919,2994,"Well, here's mine."],[3028,3140,"That witch got what was coming to her."],[3228,3294,"Thank the goddess"],[3294,3440,"the universe has found its balance."],[3470,3599,"Where are you two going?"],[3820,3903,"We're dropping out."],[3987,4083,"You're what?"]],"66":[[4,183,"Nathan, you are months away"],[183,258,"from graduation."],[258,375,"No diploma is going to teach me"],[375,487,"what I want to do with my life."],[487,596,"I've got to go out and live it."],[646,809,"And my parents gave me this fortune,"],[809,930,"so why don't I spend it"],[930,1017,"on something meaningful?"],[1017,1113,"Like what?"],[1134,1251,"We're going to go back to my coven"],[1251,1368,"and convince my sisters"],[1368,1497,"to join the outside world."],[1547,1626,"With my investment,"],[1626,1755,"they can build a modern community"],[1755,1847,"anywhere they want."],[1881,1951,"They don't have to hide out"],[1951,1997,"in the woods."],[2031,2193,"We witches have much to offer,"],[2231,2344,"but also much to learn."],[2389,2619,"And we can't learn if we refuse to grow."],[2986,3053,"Don't you trust us"],[3053,3169,"to take care of one another?"],[3866,3978,"Yeah, I do."],[4546,4658,"Take care of each other."]],"67":[[671,834,"Who dare disturbs my work?"],[950,1034,"High Priestess."],[1071,1213,"I found her bleeding outside our gates."],[1251,1355,"Please help me."],[1401,1559,"My stepsister, Astrid,"],[1589,1701,"she wants me dead."],[3595,3670,"You ready?"],[3837,3916,"Of course I am."],[3999,4058,"I'm home."]]}