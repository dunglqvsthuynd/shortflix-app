{"1":[[2373,2477,"I'm sorry, baby."],[2577,2694,"I wish I could go back,"],[2773,2944,"before we lost everything."],[3065,3186,"But nothing can change"],[3186,3294,"where we are now."],[3474,3695,"I'll never be that girl again."],[4350,4437,"Christy Lane."],[4437,4562,"She's really something else."],[4596,4750,"And she's only 23."],[4792,4871,"It's a shame she had to"],[4871,4979,"drop out of music school."],[5030,5142,"Money problems."],[5405,5551,"Money problems."],[8854,9042,"I love you so much, Henry."],[9063,9200,"A few more months of working,"],[9217,9355,"and I can pay for your surgery."],[10110,10222,"And then we can build our family"],[10222,10335,"with our little girl."],[11323,11382,"Who are you?"],[11486,11574,"Brandon Shaw,"],[11636,11732,"heir to the Shaw"],[11732,11870,"entertainment empire."],[11949,12057,"I'll make this quick."],[12162,12341,"You sleep with me,"],[12445,12604,"and I'll give you all the money"],[12604,12737,"that you'll ever need."]],"2":[[33,216,"You sleep with me,"],[329,500,"and I'll give you all the money"],[500,629,"that you'll ever need."],[654,709,"What?"],[767,838,"No."],[905,1034,"I have a boyfriend,"],[1134,1259,"and I can make my own money."],[1789,1864,"What are you doing?"],[1881,1972,"I am getting"],[2085,2273,"what I want."],[2765,2840,"Help!"],[3720,3820,"Ow!"],[4187,4283,"My eye!"],[4283,4425,"My, my eyes!"],[4446,4517,"Sir."],[4633,4700,"My eyes."],[4758,4825,"Get her!"],[4825,5021,"I'm gonna fucking kill her!"],[5063,5167,"Ah!"],[5793,5868,"No, no, no, no."],[5922,6081,"The Shaws are kings."],[6122,6322,"They'll blacklist me from every venue,"],[6322,6443,"if they find out."],[6936,7098,"End your relationship with Christy,"],[7098,7315,"and I'll fund your cancer treatment."],[7444,7528,"No, Dad."],[7640,7716,"I love her."],[7795,8020,"It's not about love."],[8049,8195,"It's about your survival."],[8245,8324,"Have you forgotten"],[8324,8416,"what your mother did?"],[8445,8679,"She left you for money."],[8767,8942,"I won't stand another whore"],[8942,9096,"ruining my only son."],[9096,9438,"Christy is nothing like Mom."],[9438,9713,"Leave her and that's final."],[9738,9797,"No."],[9822,9930,"Henry has cancer,"],[9955,10064,"and I'm keeping him"],[10064,10247,"from his best chance of survival."],[10264,10418,"I don't want the next I see you"],[10418,10543,"to be in a casket."],[11649,11866,"I have to leave Henry."]],"3":[[29,91,"Henry."],[955,1042,"You and the baby"],[1042,1159,"doing all right tonight?"],[1234,1288,"Yeah."],[1614,1718,"How were your classes?"],[1751,1851,"I haven't told Henry that"],[1851,2002,"I dropped out to pay for his bills."],[2152,2223,"They were great."],[2273,2360,"I'm all ready"],[2360,2481,"for the new orchestra cycle."],[2627,2698,"Christy."],[2915,2994,"What happened?"],[3140,3382,"Just blisters from practicing."],[3495,3582,"Honey, come here."],[3678,3737,"Sit."],[3937,4104,"Alright, Christy."],[4149,4350,"I know you love your music so much."],[4375,4558,"I just wish that you would love yourself"],[4592,4704,"once in a while too."],[5201,5259,"Henry,"],[5259,5397,"with your father's connections,"],[5417,5518,"you can be cured."],[5543,5680,"I will only slow you down."],[6001,6064,"Henry,"],[6235,6322,"I'm leaving you."],[6439,6498,"What?"]],"4":[[0,95,"I'm leaving you."],[187,250,"What?"],[266,350,"How much longer"],[383,521,"were you planning on hiding it?"],[567,679,"You have cancer."],[713,825,"You're a dead man walking."],[909,967,"Hey,"],[1055,1151,"don't say that."],[1234,1309,"Come on,"],[1355,1668,"we can get through this together, okay?"],[1735,1797,"No."],[1897,2072,"Ever since I was a little girl,"],[2072,2223,"I lived for the stage."],[2281,2510,"I want money, connections,"],[2585,2740,"not a disgusting mess"],[2740,2861,"who will only drag me down."],[3044,3111,"What?"],[3265,3578,"Don't touch me, you sick, broke freak."],[3678,3745,"Christy,"],[3832,3941,"you can't leave."],[3987,4091,"What about our daughter?"],[4108,4279,"I can't let him see me cry."],[4295,4558,"I need to kill any love he has for me."],[5497,5580,"What are you doing?"],[5638,5755,"Don't come any closer,"],[5805,5985,"or this hairpin goes in my stomach."],[6131,6256,"No!"]],"5":[[8,141,"You're gonna hurt the baby, okay?"],[162,237,"That's the point."],[237,321,"No, no!"],[329,379,"No."],[667,792,"You monster."],[880,1009,"She's an innocent child!"],[1009,1109,"How could you do this?"],[1138,1326,"It's kinder to end her life"],[1326,1539,"than to have her be born in a world"],[1539,1851,"with a useless, dying dad."],[1931,2043,"You don't mean that."],[2356,2431,"No!"],[2456,2515,"No."],[2515,2677,"Without your useless baby,"],[2677,2848,"I can date all the rich men I want."],[2848,3023,"Men who'll give me money,"],[3061,3174,"instead of wasting it."],[3174,3311,"This is our baby girl!"],[3399,3465,"Too late."],[3641,3737,"She's already gone."],[4913,4967,"No."],[5025,5088,"Christy."],[5142,5388,"Tell me you didn't kill our baby girl."],[5434,5543,"Tell me you didn't kill"],[5543,5689,"our baby girl just now!"],[6156,6252,"How could you?"],[6318,6493,"How could you do this?"]],"6":[[41,129,"How could you?"],[129,166,"Wait."],[166,266,"How could you?"],[304,471,"How could you do this to us?"],[504,563,"Henry?"],[629,688,"Henry!"],[1130,1330,"It's raining so hard outside."],[1409,1559,"Why don't you stay at my place?"],[1655,1751,"Ms. West."],[1881,2006,"The only reason I'm dating you"],[2006,2168,"is because my father insisted."],[2273,2414,"I have no interest in you,"],[2502,2598,"and I never will."],[3107,3199,"What the hell?"],[3399,3520,"Some hobo is playing music"],[3520,3620,"outside my house."],[3824,3887,"Wait."],[4020,4099,"The violin."],[4304,4437,"I know her sound anywhere."],[4466,4529,"Her?"],[4583,4650,"Who's her?"],[4688,4850,"Henry, what are you talking about?"],[4867,4992,"Seven years."],[5109,5317,"I never forgot the sound of her violin."],[5422,5543,"Okay, change of plans."],[5543,5718,"We're not going to my house anymore."],[5718,5968,"I am not going to lose her again."],[6089,6168,"Stop it."],[6272,6385,"Stop driving."],[6731,6790,"Hey."],[7144,7207,"Watch out!"],[7207,7315,"No, Anna."],[7799,7920,"Mommy!"],[7945,8091,"No!"]],"7":[[750,900,"Good, no one got hurt."],[1463,1568,"It's not Christy,"],[1584,1685,"but I could have sworn"],[1685,1901,"it was the sound of the Rose Violin."],[2915,3032,"You stupid brat."],[3032,3115,"What do you think you're doing"],[3115,3240,"in front of my house?"],[3240,3353,"I'm sorry, ma'am."],[3353,3407,"I was doing-"],[3407,3495,"Just scamming people"],[3495,3649,"out of their hard-earned cash?"],[3737,4024,"You, all of you, get off my property,"],[4024,4154,"or I'm calling the cops."],[4487,4587,"How rude."],[4604,4725,"She was just trying to help"],[4725,4825,"her sick mother."],[4838,4909,"Sick?"],[4921,4988,"Get away from me,"],[4988,5138,"you dirty, infected scum."],[5234,5380,"Ow!"],[5380,5555,"Stop crying,"],[5605,5705,"or I'll give you something"],[5705,5818,"to cry about."],[5872,5947,"No, please."],[5985,6122,"Somebody save me."],[6327,6410,"Enough!"],[6485,6610,"Don't hurt her."],[6698,6819,"We don't need a lawsuit."],[7570,7770,"No, my violin!"],[7791,7870,"What's wrong?"],[7870,8049,"Can't scam people without this?"],[8070,8174,"Give it back."],[8195,8312,"I need the violin."],[8312,8508,"It's the only way I can get money."],[8546,8621,"Henry honey,"],[8646,8758,"I can break a twenty dollar"],[8758,8904,"junk instrument, right?"],[8929,9096,"It won't cost us anything."],[9142,9346,"And it'll teach that brat a lesson."],[9346,9588,"Please, mister, tell her to stop."],[9588,9697,"I'm going to smash your"],[9697,9880,"stupid violin into pieces."],[9889,10022,"No, the violin is special."],[10022,10243,"It's the only way Daddy can find me."],[10268,10318,"Please, sir."],[10318,10410,"It's expensive."],[10431,10623,"It has a Rose-carving on it."],[10706,10852,"Could it be Christy's violin?"]],"8":[[75,216,"Could it be Christy's violin?"],[279,492,"Really, Henry, how naive are you?"],[521,671,"Look at how dirty she is."],[700,863,"She can't even afford proper clothes."],[917,1126,"There's no way the violin is real."],[1138,1217,"Let me see it."],[1217,1363,"Please, this piece of junk?"],[1463,1634,"It's worth more as wood chips."],[2135,2248,"No!"],[2277,2548,"No, my violin!"],[2635,2756,"It can't be."],[2982,3115,"The Rose Violin."],[3570,3661,"Daddy?"]],"9":[[0,287,"No, my violin!"],[504,600,"This little girl,"],[650,804,"why does seeing her in pain"],[804,938,"hurt me so much?"],[992,1080,"Let's go, Henry."],[1113,1242,"There's no way a beggar girl"],[1242,1422,"has one of the most illustrious violins"],[1422,1497,"in the world."],[1551,1780,"It was fake and you know it."],[1860,2068,"Did anyone see a woman"],[2118,2260,"playing the violin earlier?"],[2293,2494,"No, sir, it was just a little girl."],[2565,2711,"Guess it's another wild goose chase."],[2948,2998,"Here."],[3073,3144,"Take this."],[3257,3370,"Money for damages."],[3566,3678,"Don't think about suing."],[3870,4004,"Of course it wasn't Christy."],[4054,4195,"Fate would never be so kind"],[4195,4312,"as to bring her back."],[5388,5467,"Mommy."],[5497,5680,"Could her mother be?"]],"10":[[300,412,"Mommy."],[713,892,"Henry, why don't you stay the night?"],[909,1034,"Your car is totaled."],[1409,1509,"Whose fault is that?"],[1614,1818,"Leave me alone."],[1931,2072,"No, it's all over."],[2131,2260,"The Cole heir hates me."],[2982,3207,"It's all that stupid brat's fault."],[3482,3591,"I know what I heard."],[3624,3837,"It was the sound of the Rose Violin."],[3878,3983,"The question is,"],[4049,4187,"where is Christy hiding?"],[4500,4562,"Logan,"],[4612,4767,"host a violin contest"],[4767,4896,"at the villa this weekend."],[5013,5125,"Open invitation."],[5209,5342,"Make the grand prize,"],[5547,5839,"fifteen million dollars."],[5860,6110,"Fifteen million, sir?"],[6151,6306,"Christy loved money more than life."],[6364,6473,"If she's in town,"],[6585,6669,"she'll come."],[7207,7403,"Doctor, is Mommy going to be okay?"],[7449,7590,"She's stable for now,"],[7632,7807,"but she's going to need surgery."],[7853,7912,"It will cost"],[7912,8049,"a hundred thousand dollars."],[8070,8199,"A hundred thousand?"],[8258,8433,"That's a lot of money."],[8458,8629,"Is my Mommy going to die?"]],"11":[[37,208,"Is my Mommy going to die?"],[262,425,"We think that the repeated stress,"],[425,625,"over the course of many years,"],[625,734,"triggered a flare-up"],[734,900,"of her neurological condition."],[1001,1163,"She likely ignored the pain,"],[1297,1443,"which caused permanent damage"],[1443,1597,"to the nerves in her hands,"],[1597,1760,"and her arms and her legs."],[2268,2410,"That's the third time this week."],[2439,2515,"You're done!"],[3044,3240,"She worked herself to the bone."],[3365,3532,"Coupled with the stress of childbirth,"],[3561,3666,"she never recovered."],[4550,4646,"Spread out."],[4658,4746,"Boss said he saw his"],[4746,4863,"attacker around here."],[4917,4971,"Come on."]],"12":[[367,479,"I will follow you"],[479,721,"to the ends of the earth, Christy."],[721,959,"I'll pay you back for what you did tenfold."],[2060,2231,"Coupled with the stress of childbirth,"],[2260,2360,"she never recovered."],[2448,2531,"So it was my fault"],[2531,2669,"that Mommy's like this?"],[2669,2790,"Oh, no, honey."],[2802,2886,"It's my fault"],[2886,2990,"that Mommy can't play"],[2990,3128,"the violin anymore."],[3440,3553,"Just please save Mommy."],[3553,3753,"I'll get the money, I promise."],[3770,3832,"Anna."],[4070,4229,"I'll save you, Mommy,"],[4229,4412,"no matter what it takes."]],"13":[[150,346,"Doctor said Mommy got sicker"],[346,442,"when I was born,"],[442,575,"so it's my fault."],[575,734,"I have to help Mommy."],[838,1059,"Oh boy, leftovers."],[1317,1426,"Garlic bread?"],[1426,1522,"Yum."],[2252,2323,"Daddy,"],[2323,2402,"why doesn't she have"],[2402,2523,"a Mom or Dad?"],[2569,2752,"Some kids don't have family, sweetie."],[2827,2936,"Come on, let's go."],[3123,3207,"You're wrong."],[3207,3411,"I have a Mommy and a Daddy."],[3428,3591,"He's just not back yet."],[3616,3703,"Dear God,"],[3703,3933,"please let Daddy come back to us."],[3933,4108,"Please, please."],[4396,4458,"Mommy,"],[4529,4688,"this is how much I made tonight."],[4892,5075,"Ten, five."],[5176,5359,"A hundred and twenty dollars."],[5492,5605,"That's a lot less"],[5605,5722,"than a hundred thousand."],[5851,5914,"Anna,"],[6001,6147,"there's someone very special"],[6147,6243,"here to see you."],[6314,6410,"Is it Daddy?"]],"14":[[4,100,"Is it Daddy?"],[754,817,"Anna."],[1146,1351,"There's a thousand dollars in here."],[1393,1493,"Keep it safe."],[1972,2118,"And here's all my savings."],[2118,2239,"Three thousand dollars."],[2239,2344,"It's yours."],[2740,3061,"I don't have any money,"],[3061,3445,"but this is my late wife's wedding ring."],[3516,3620,"And she wanted it"],[3620,3812,"to go to a good cause."],[3845,3983,"Use it for your Mom."],[4033,4225,"Thank you, thank you so much."],[4704,4859,"And look what we have here."],[4984,5167,"Henry Cole, the richest"],[5167,5317,"businessman in town, is holding"],[5317,5472,"a violin competition tomorrow."]],"15":[[29,212,"Henry Cole, the richest"],[212,362,"businessman in town, is holding"],[362,517,"a violin competition tomorrow."],[563,809,"You can get fifteen million dollars."],[867,959,"That's more than enough"],[959,1113,"to pay for Mommy's surgery."],[1151,1334,"But I don't have a violin anymore."],[1693,1760,"You do now."],[1822,1918,"Mom's violin."],[2006,2110,"You fixed it?"],[2143,2289,"My father's a talented luthier."],[2323,2423,"The body was cracked,"],[2423,2548,"but totally repairable."],[2565,2752,"Your Dad might not be here,"],[2781,2915,"but you're not alone."],[2973,3132,"We're all here for you, Anna."],[3174,3407,"Tomorrow, you play your heart out,"],[3445,3574,"for your Mom and Dad,"],[3624,3807,"for all of us."],[4650,4817,"I have to do this for Mommy."],[4854,5042,"Mr. Cole's money will save her."]],"16":[[892,1067,"Everything's so pretty."],[1101,1288,"There's so much food."],[2068,2248,"Ew, who is that?"],[2273,2381,"This was supposed to be"],[2394,2535,"a child-free event."],[2535,2640,"I bet she's a thief"],[2640,2869,"like every other homeless person."],[2907,3128,"No, I'm not a thief!"],[3148,3411,"I came here to play violin for Mr. Cole."],[3636,4066,"Thief."],[4204,4362,"It's that homeless girl again."],[4792,4917,"Oh no, it's the mean lady"],[4917,5063,"who broke my violin."],[5096,5226,"It's you, little beggar."],[5234,5405,"What are you doing here?"],[5455,5655,"Do you even know where you are?"],[5739,6060,"You have no right to be here."],[6268,6364,"No, I need to win"],[6364,6498,"the violin competition"],[6498,6694,"to pay for Mommy's surgery."],[6823,6894,"You?"],[6956,7207,"With your broken, useless violin?"],[7240,7315,"Look,"],[7315,7478,"you've already dirtied the floor."],[7515,7699,"Get out, now!"]],"17":[[20,179,"I will clean the floor."],[1438,1639,"I didn't mean to make it dirty."],[1676,1818,"Please don't make me leave."],[1818,1972,"I have to save Mommy."],[2452,2523,"Enough."],[2540,2623,"Security,"],[2660,2831,"make her disappear."],[3036,3161,"Please, I need the money"],[3161,3299,"to help Mommy."],[3299,3415,"Help, Mr. Cole."],[3415,3482,"Help."],[4362,4462,"Let me in, please."],[4462,4583,"I need to save Mommy."],[4583,4733,"I need to play violin."],[5042,5176,"I'm sorry, Mommy."],[5205,5392,"They won't even let me play."],[5505,5718,"How am I supposed to save you now?"]],"18":[[1092,1247,"Mommy, will this really work?"],[1280,1363,"It's okay, baby."],[1401,1476,"We had to leave Daddy"],[1476,1630,"when you were still in Mommy's belly."],[1676,1847,"He loves you so much."],[1918,2102,"He didn't even know me."],[2531,2631,"You play the violin"],[2631,2786,"exactly how I showed you,"],[2806,2890,"he'll know it's you."],[2957,3036,"I promise."],[3111,3303,"And then we'll all be together, right?"],[3303,3415,"All three of us."],[3478,3536,"Yeah."],[3641,3749,"We'll all be together."],[4112,4300,"Even if they won't let me in,"],[4341,4504,"I still have my violin."],[5613,5730,"Please, Daddy."],[5759,5922,"Please come back."]],"19":[[1463,1559,"My violin competition"],[1559,1647,"is going great."],[1672,1810,"Henry has to propose to me"],[1810,1897,"after this."],[1931,2002,"She's good,"],[2039,2152,"but not what I wanted."],[2198,2314,"Not who I wanted."],[3144,3228,"That song."],[3457,3524,"Henry."],[3774,3928,"Hiss, Henry, sit down!"],[4596,4683,"That piece."],[4863,4946,"That's exactly"],[4946,5105,"how Christy would play it."],[5447,5580,"Could it actually be her?"],[5684,5918,"Ugh, is that brat trying to one-up me"],[5918,6110,"by playing the violin outside?"],[6710,6819,"Please, Daddy."],[6844,6952,"Mommy is sick."],[6977,7107,"I need you to come back"],[7107,7194,"to help Mommy."],[7194,7290,"Please."]],"20":[[725,934,"I told you to leave."],[950,1076,"I'm sorry."],[1242,1322,"Too late."],[1334,1522,"I'm confiscating your instrument."],[1526,1672,"No, you can't do that."],[1676,1768,"It's mine."],[1776,1843,"Ms. West,"],[1843,1914,"Shut up. - please."],[2002,2235,"I think this dirty, stupid beggar"],[2281,2527,"needs to be taught a music lesson."],[2656,2715,"Stop!"],[2715,2940,"You're gonna snap the violin in half!"],[2973,3032,"Hmm."],[3115,3182,"Will I?"],[3319,3440,"Ms. West, please."],[3482,3582,"Mr. Cole will not condone"],[3582,3682,"destruction of property."],[3703,3824,"Only if he sees me."],[3937,4112,"Breathe a word of this and you're fired."],[4204,4245,"Yeah."],[4325,4425,"Thought so."],[4604,4758,"Please, stop."],[4758,4846,"Me and my mommy"],[4846,4984,"need that violin to live."],[4984,5142,"You're gonna break it."],[5167,5259,"That's the plan."],[5326,5438,"Now, let's see."],[5492,5651,"How many twists does it take"],[5651,5734,"to get to the center"],[5734,5918,"of a broken violin?"],[6760,6831,"Stop!"]],"21":[[41,104,"Stop,"],[187,262,"right there."],[771,925,"What's with the violin?"],[980,1042,"She stole it"],[1042,1217,"from one of the musicians inside."],[1426,1497,"Is that true?"],[1672,1747,"I don't know, sir."],[1789,1885,"I suppose it could be."],[2131,2202,"I didn't."],[2202,2310,"I brought it with me."],[2310,2402,"It's mine."],[2873,2982,"That Rose-carving."],[3111,3169,"It's"],[3203,3307,"the Rose Violin."],[3403,3507,"This is"],[3603,3728,"Christy's violin."],[3920,4041,"No, it can't be."],[4104,4195,"It just can't be."],[4662,4742,"Sweetheart."],[4938,5030,"What's your name?"],[5117,5184,"I'm Anna."],[5184,5397,"I came here to play violin for you."],[5467,5605,"Is this your violin?"],[5768,5897,"No, it's not."],[6418,6535,"It's my Mommy's."],[7057,7123,"Anna."],[7290,7424,"What's your Mommy's name?"],[7540,7603,"Christy."],[7603,7695,"Christy Lane."]],"22":[[20,162,"Her mother is Christy Lane."],[246,358,"My Christy."],[446,625,"Could this be my daughter?"],[1639,1801,"DNA test, now."],[1801,1864,"Yes, sir."],[1981,2035,"Oh."],[2152,2210,"Good."],[2252,2356,"Henry, you have to do something"],[2356,2498,"about this little thief."],[2548,2610,"She's nothing"],[2610,2840,"but a stupid, fatherless brat."],[3107,3219,"Fatherless brat?"],[3261,3465,"Yeah, she's a street beggar, Henry."],[3503,3737,"She's the lowest of the low."],[3778,4024,"Regardless of her situation,"],[4087,4404,"she is a poor, innocent child."],[4429,4671,"And this is the Cole estate."],[4700,4829,"She doesn't belong."],[4917,5075,"Henry, I'm just doing you a favor."],[5138,5242,"You don't want to be associated"],[5242,5397,"with the likes of her, do you?"],[5543,5701,"I told you to leave."],[5734,5922,"Why are you still here?"],[5955,6026,"Out."],[6043,6114,"Now."],[6310,6694,"You do not give orders in my house."]],"23":[[8,187,"Henry, what's wrong with you?"],[187,333,"She's just a stupid beggar girl."],[354,521,"No one touches Anna."],[692,817,"Not while I'm around."],[1217,1401,"Henry, why are you siding with her?"],[1443,1664,"I'm supposed to be your fiancée."],[1701,1956,"Security, escort her out."],[1993,2085,"Do you hear that?"],[2114,2248,"Mr. Arthur Cole just said"],[2248,2444,"they're gonna kick you out."],[2711,2748,"What?"],[2748,2831,"Hey, no!"],[3044,3165,"On the contrary,"],[3165,3382,"you're the one being kicked out."],[3382,3440,"No."],[3465,3532,"Let me go."],[3532,3611,"Stop."],[4245,4308,"Anna?"],[4404,4458,"Anna?"],[4521,4575,"Anna?"],[4592,4642,"Honey?"],[4662,4792,"Hey, Anna?"],[4854,4925,"Are you okay?"],[4971,5021,"Anna?"],[5096,5176,"Call an ambulance."],[5217,5276,"Anna?"],[5342,5413,"Wake up."]],"24":[[596,646,"Sir,"],[759,850,"the DNA test."],[2202,2385,"She's your biological daughter."],[2548,2698,"I have a granddaughter."],[2761,2932,"A dear, precious,"],[2932,3065,"beautiful granddaughter."],[3236,3299,"Christy,"],[3324,3449,"not only did you leave me,"],[3474,3586,"you took our daughter"],[3586,3691,"away from me."],[3691,3820,"You hid her from me."],[3937,4070,"You're the cruelest woman"],[4070,4204,"I've ever met."]],"25":[[4,112,"Is she gonna be okay?"],[254,362,"I'm sorry, sir."],[392,638,"She is severely malnourished."],[675,800,"Poor kid hasn't had anything"],[800,917,"to eat in days."],[1076,1146,"Days?"],[1255,1355,"On top of that,"],[1443,1634,"she's suffered multiple injuries."],[1705,1760,"Christy,"],[1760,1918,"you said you were leaving me"],[1918,2110,"to live the high life."],[2243,2344,"What were you doing"],[2344,2452,"all these years?"],[2598,2811,"What did you do to our daughter?"],[2948,3111,"Her dress has holes."],[3199,3415,"Her shoes barely fit her feet."],[3474,3687,"Christy, how could you let this happen"],[3687,3933,"to our perfect little girl?"],[4045,4204,"Do you hate me so much,"],[4204,4412,"you'd take it out on an innocent child?"],[4867,4988,"Where am I?"],[5084,5184,"Where's Mommy?"],[5634,5726,"Mr. Cole?"],[5830,5880,"Hey."],[6010,6114,"No, sweetheart."],[6360,6439,"I'm your Dad."]],"26":[[4,83,"I'm your Dad."],[246,396,"Daddy! Daddy!"],[996,1101,"You came back."],[1101,1247,"Just like Mommy said."],[1284,1463,"I missed you so much."],[1488,1634,"Everybody was mean to me,"],[1634,1810,"because I didn't have a Dad."],[1839,1989,"Please don't leave again."],[2010,2097,"Please."],[2181,2239,"No."],[2302,2360,"No."],[2402,2665,"Honey, I, I am so sorry."],[2727,2932,"I didn't know that you were out there."],[2973,3240,"I'm never gonna let you go, okay?"],[3265,3349,"I promise."],[3478,3753,"I love you so much."],[3903,4033,"And you're my precious"],[4033,4124,"granddaughter."],[4149,4350,"We'll give you the world from now on."],[4558,4617,"Come on."],[4679,4808,"Grandpa has something special"],[4808,4875,"for you."],[4917,4971,"Hmm."],[5271,5476,"How about me first?"],[6715,6956,"Welcome home, Ms. Anna Cole."]],"27":[[25,70,"Anna,"],[120,300,"meet your nutritionist,"],[300,429,"your personal tutor,"],[429,696,"and your etiquette coach."],[779,863,"What do you mean?"],[1034,1096,"Anna,"],[1126,1372,"you are our little princess now."],[1405,1522,"All these people here,"],[1572,1672,"they're here to protect you."],[1743,1818,"They'll help you."],[1881,1951,"That's okay."],[1985,2160,"I don't want anyone else besides you,"],[2160,2218,"Daddy."],[2631,2894,"Oh, my sweet, sweet girl."],[2998,3174,"Let's get you some food, yeah?"],[3199,3315,"Yay! - Yeah."],[3336,3395,"Come on."],[3953,4004,"Whoa."],[4012,4175,"Is that a real turkey?"],[4204,4412,"I've never seen one before."],[4458,4521,"Well?"],[4600,4675,"What would you like?"],[5292,5597,"I have so much food and a new dress,"],[5626,5830,"but Mommy's still at the hospital."],[5847,6031,"I have to help Mommy first."],[6089,6189,"What is it, Anna?"],[6252,6423,"Would you like something else?"],[6573,6765,"Daddy, can I ask you for something?"],[6936,7069,"Yeah, sweetheart."],[7136,7228,"Anything you want."],[7248,7303,"Can I have"],[7303,7474,"a hundred thousand dollars?"]],"28":[[208,262,"Anna,"],[433,483,"wha