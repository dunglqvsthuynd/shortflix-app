],[6427,6506,"The hospital?"]],"35":[[45,145,"Why, why would Christy"],[145,237,"be at the hospital?"],[329,408,"Let's go."],[408,546,"We're bringing my granddaughter"],[546,613,"back home."],[763,821,"Go, go."],[1172,1297,"I'm sorry, Mommy."],[1343,1451,"I found Daddy."],[1484,1630,"But he hates us."],[1630,1760,"He wouldn't even let us"],[1760,1897,"use Grandpa's credit card"],[1897,2010,"to save you."],[2348,2452,"But it's okay."],[2477,2598,"I will play the violin"],[2598,2731,"until we have enough money"],[2756,2919,"to pay for your surgery."],[3620,3666,"Ugh."],[3666,3832,"I can't believe I twisted my ankle."],[3858,4062,"If it weren't for that stupid violin brat,"],[4062,4129,"Henry and Arthur"],[4129,4270,"would have never kicked me out."],[4542,4604,"Wait."],[4633,4700,"That's her."],[4729,4846,"What is she doing here?"]],"36":[[33,95,"You!"],[191,342,"What are you doing here?"],[400,521,"My Mommy is sick."],[521,729,"I was just taking her outside."],[775,921,"She's still in her rags."],[967,1109,"That means Henry and Arthur"],[1109,1222,"didn't give her anything."],[1309,1372,"I knew it."],[1401,1526,"She was a fraud."],[1526,1668,"Um, can I go now, ma'am?"],[1893,1956,"Wait."],[2143,2364,"That's the Cole's exclusive credit card."],[2456,2577,"You little thief."],[2652,2781,"This is payback."],[3303,3361,"No."],[3386,3478,"My credit card!"],[3490,3641,"What happened to my credit card?"]],"37":[[0,100,"My credit card."],[100,241,"What happened to my credit card?"],[279,379,"What happened?"],[417,592,"Someone stole my credit card."],[608,821,"I had millions on that account."],[1017,1076,"You."],[1092,1234,"I bet you took it."],[1343,1409,"What?"],[1409,1543,"No, I didn't."],[1593,1643,"Wait."],[1643,1722,"That's Anna,"],[1722,1801,"the kid who was taking care"],[1801,1881,"of her Mom."],[1939,2077,"Ma'am, I think you should check"],[2077,2147,"your purse again."],[2173,2256,"Anna's a good kid."],[2256,2335,"She's not a thief."],[2373,2489,"We'll see about that."],[2519,2631,"I'm searching you."],[2761,2861,"Stop it!"],[2927,3044,"Let me go!"],[3211,3265,"Aha."],[3303,3428,"Then what's this?"],[3478,3645,"Caught red-handed."]],"38":[[16,91,"No!"],[91,200,"That's my credit card."],[200,354,"Grandpa gave it to me."],[392,546,"What is going on?"],[567,729,"You expect me to believe that?"],[754,975,"You don't have a grandpa."],[1030,1121,"Little beggar."],[1167,1280,"Little thief."],[1309,1388,"No."],[1418,1555,"I'm not a thief!"],[1580,1672,"I'm good!"],[1685,1872,"Mommy taught me never to steal."],[1872,1997,"Shut up, brat."],[2018,2102,"This credit card"],[2102,2231,"belongs to the Coles,"],[2256,2481,"and I'm Henry Cole's fiancée."],[2535,2686,"I'm turning you in to the cops."],[2736,2811,"Stop it!"],[2811,2977,"Hey, get your hands off the kid!"],[3007,3140,"Let me go!"],[3695,3828,"Mommy!"],[4137,4279,"Mommy, are you okay?"],[4333,4504,"You bit me, you mutt!"],[4842,4917,"That's it."],[4938,4996,"I'll show you"],[4996,5125,"what happens to brats like you."],[5163,5251,"Watch out!"],[5430,5497,"No!"],[5501,5568,"Don't!"],[5672,5747,"Mr. Cole."],[6039,6110,"Stop!"]],"39":[[33,104,"Stop."],[771,825,"Hey."],[892,955,"Henry."],[1063,1126,"It's okay."],[1213,1267,"I'm here."],[1313,1422,"You came back."],[2560,2665,"I should have never left."],[3382,3482,"Mr. Cole."],[3520,3649,"I was just looking out for you."],[3649,3812,"She took your credit card."],[3812,3912,"My granddaughter"],[3912,4083,"can take whatever she wants."],[4166,4229,"Wait."],[4362,4437,"Granddaughter?"],[4725,4884,"Anna's my biological daughter."],[5067,5230,"The new Cole heiress."],[5359,5413,"No."],[5467,5613,"No, no, no, no!"],[5689,5843,"No one is allowed"],[5843,6060,"to hurt my granddaughter."]],"40":[[196,296,"No, let me go!"],[342,417,"Stop!"],[546,671,"Henry, please."],[742,779,"I get it."],[779,863,"She's your daughter, fine."],[863,1001,"Let's just drop this, okay?"],[1176,1292,"You want me to forgive you,"],[1338,1480,"for accusing the Cole heiress"],[1480,1609,"of being a thief?"],[1685,1839,"She's seven years old!"],[1851,1960,"Congratulations."],[1972,2089,"You framed a child."],[2139,2235,"How cruel are you?"],[2235,2323,"No, Henry, I..."],[2373,2481,"Okay, I might have done that,"],[2481,2702,"but that's not actually my fault."],[2702,2877,"This bitch is on my last nerve."],[2877,2965,"Get her out of here."],[2986,3140,"No, Mr. Cole, please, I..."],[3236,3336,"You can't do this to me."],[3361,3453,"I'm the West heiress."],[3453,3591,"You can't destroy me like this."],[3591,3645,"I can."],[3766,3845,"And I will."],[5067,5117,"Hey."],[5201,5259,"What is it?"],[5301,5476,"Dad, could you help Mommy now?"],[5601,5672,"Christy?"]],"41":[[95,187,"Where is she?"],[1301,1368,"Christy."],[1451,1505,"Hey."],[2189,2344,"You said you were gonna leave me,"],[2344,2481,"so you could marry rich."],[2761,2836,"What happened?"],[2940,3115,"How did you end up like this?"],[3432,3566,"Mommy was sick."]],"42":[[367,529,"A sandwich, yum."],[1313,1463,"Mommy, you have some."],[1697,1768,"No, thank you."],[1835,1960,"Mommy's not hungry right now."],[2410,2469,"Is it good?"],[2619,2673,"Good."],[3249,3324,"Mommy,"],[3324,3566,"I wish I could hear you play the violin."],[4129,4250,"I wish I could, baby,"],[4270,4425,"but some things are"],[4425,4542,"meant to stay in the past."],[4604,4683,"Like Daddy?"],[4846,4900,"No,"],[4988,5100,"Daddy's gonna come back."],[5330,5509,"Mommy was always sad,"],[5543,5701,"but I wasn't sad."],[5739,5868,"I was happy,"],[5868,6089,"because I know Mommy loved me."]],"43":[[367,425,"Christy,"],[496,663,"I've imagined seeing you again,"],[713,859,"a thousand different ways,"],[971,1121,"but it wasn't ever like this."],[1501,1584,"Mr. Cole,"],[1643,1785,"her condition is serious."],[1810,1972,"She needs surgery now."],[2164,2335,"Daddy, please save Mommy."],[2335,2402,"The surgery's"],[2402,2569,"a hundred thousand dollars."],[2690,2957,"That's why you asked us for money."],[3566,3724,"Give me every specialist in the city."],[3778,3945,"I don't care how much it costs."],[4054,4175,"I'm not losing her again."],[4412,4479,"Please,"],[4575,4671,"just this once,"],[4713,4813,"come back to me."],[5718,5876,"Mommy, please wake up."]],"44":[[225,354,"Mommy, you're awake."],[621,746,"I thought you were gonna-"],[804,913,"Shh, Anna."],[1267,1347,"I'm okay."],[1710,1755,"Anna,"],[1818,1868,"were you the one"],[1868,1997,"who took Mommy to the hospital?"],[2198,2364,"I'm so proud of you."],[2485,2623,"The doctor said soon you'll be"],[2623,2756,"able to move normally."],[3365,3561,"I can feel my fingers."],[3720,3807,"Oh, Anna,"],[3883,4079,"you're Mommy's biggest miracle."],[4629,4683,"Come on."],[4758,4838,"Let's go back."],[4884,4938,"Mommy,"],[4959,5046,"we don't need to live"],[5046,5171,"on the streets anymore."],[5209,5359,"We can live with Daddy."]],"45":[[563,617,"Come on."],[696,767,"Let's go back."],[817,875,"Mommy,"],[892,980,"we don't need to live"],[980,1096,"on the streets anymore."],[1142,1272,"We can live with Daddy."],[1889,2072,"That's impossible."],[2168,2243,"Oh, Anna,"],[2323,2435,"are you sure it's Daddy?"],[2464,2577,"Yeah, he's outside."]],"46":[[1463,1755,"Henry, it's really you."],[2273,2335,"Anna,"],[2439,2602,"will you go outside with Grandpa?"],[2660,2781,"Just for a minute, okay?"],[3174,3286,"Come on, sweetheart."]],"47":[[312,500,"You paid for my hospital bills?"],[558,684,"I wasn't gonna let the kid"],[684,813,"watch her mom die,"],[871,1121,"but I came here for something else."],[1322,1430,"Read the document."],[2623,2690,"You want me to give up"],[2690,2823,"the rights of my daughter?"],[2823,2944,"She's my daughter too."],[3094,3336,"And I would never let her starve,"],[3378,3566,"or beg on the streets."],[3624,3691,"Henry,"],[3753,3787,"that's not-"],[3787,4058,"You said you wanted money and fame."],[4166,4283,"So I'll make you a deal."],[4458,4696,"How much do you want for Anna?"]],"48":[[37,254,"You think I would sell my own daughter"],[283,346,"for money?"],[467,538,"Wouldn't you?"],[617,984,"You left me dying in a hospital bed."],[1046,1192,"You hid our daughter away"],[1192,1297,"for seven years"],[1297,1434,"only to send her back to me"],[1434,1559,"dressed in rags,"],[1605,1805,"expecting me to pick up the pieces."],[1889,2002,"Of course you'd sell her."],[2035,2260,"You would do worse."],[2369,2469,"No, Henry."],[2535,2631,"I went into hiding"],[2631,2756,"so Anna would be safe."],[2781,2902,"But I can't tell you that."],[2948,3019,"Am I wrong?"],[3228,3507,"You really think so lowly of me?"],[3557,3674,"Of course I do."],[3770,3966,"You took my love,"],[4066,4170,"my child,"],[4216,4471,"left me at my lowest."],[4537,4704,"I would be a fool"],[4704,4854,"to ever want you after that."],[4892,4950,"Right."],[4984,5184,"Why would he ever trust me again?"],[5230,5367,"I've been a monster to him."],[5434,5655,"And Brandon Shaw, the mafia heir,"],[5697,5872,"is still hunting me down."],[5972,6076,"I have to let them go"],[6177,6297,"to keep them safe."]],"49":[[825,875,"Wait."],[1234,1397,"I have another document that"],[1459,1547,"you could sign."],[1597,1722,"A marriage certificate."],[1910,2035,"No matter our past,"],[2118,2227,"Anna adores her."],[2356,2540,"I can forgive her for everything else."],[2644,2802,"I have to keep Henry safe."],[2802,2952,"I can't marry him."],[2952,3048,"I'll give up custody."],[3632,3737,"Goodbye, Henry."],[3782,3916,"Brandon Shaw will never"],[3916,4149,"find you or Anna."],[4149,4316,"Farewell, my love."],[4316,4441,"Take care of our daughter."],[4575,4783,"I agree to give up custody."]],"50":[[45,145,"She signed it."],[246,371,"She gave up our daughter,"],[425,513,"just like that."],[654,834,"And I was about to marry this woman."],[3240,3349,"Get it notarized."],[4041,4170,"How much money did you want?"],[4421,4475,"None."],[4767,4867,"Drop the act."],[4954,5167,"Take your grand prize."],[5451,5613,"This should set you up for retirement."],[6101,6389,"Henry, you still believe"],[6389,6623,"I'm nothing but a gold digger."],[6652,6827,"I wish I could tell you the truth."]],"51":[[254,421,"Grandpa, I'm so happy"],[421,638,"Mommy is getting out of the hospital."],[671,846,"We can finally be together."],[1172,1284,"Ah, the car."],[1889,2064,"Daddy, are you happy too?"],[2164,2289,"Daddy, where's Mommy?"],[2485,2627,"Daddy, we can't leave yet."],[2627,2773,"We forgot Mommy."],[3136,3253,"Sorry, Anna."],[3253,3390,"Mommy is,"],[3424,3503,"she's going to be"],[3503,3720,"a famous violinist now."],[3753,3912,"But we'll take care of you."],[3978,4079,"No!"],[4308,4379,"Mommy!"],[4562,4813,"Mommy, no!"],[4879,5067,"I'm so sorry, Anna."],[5084,5230,"Mommy!"],[5230,5480,"I'm so sorry, baby."]],"52":[[1338,1568,"As if I would ever use the money I got"],[1568,1693,"from giving up my daughter."],[4095,4158,"No."],[4341,4429,"It's him."]],"53":[[613,692,"What do you want?"],[692,779,"What do I want?"],[804,896,"The same thing"],[896,1109,"that I wanted seven years ago."],[1188,1355,"Look at you."],[1405,1597,"All skin and bones."],[1630,1739,"Once the world's greatest"],[1739,1830,"concert violinist,"],[1868,1981,"now you're looking for"],[1981,2114,"odd jobs at a bar?"],[2143,2323,"Don't you want to be back on stage?"],[2373,2485,"I can make it happen."],[2552,2769,"I can put you back in the spotlight."],[2823,2998,"The only thing I ask"],[3094,3232,"is that you are mine."]],"54":[[166,279,"I've lost my love."],[358,479,"I've lost my daughter."],[525,654,"Do I have another choice?"],[950,1276,"Don't disappoint me, Christy."],[2581,2756,"Sir, the investor's on his way."],[2919,3061,"Big investor today, huh?"],[3090,3161,"You don't say."],[3207,3357,"He's the richest guy in the state."],[3457,3549,"Here's to making a great"],[3549,3678,"first impression, Brandon."],[4283,4354,"Christy?"],[4429,4496,"Henry?"]],"55":[[592,855,"What is Christy doing here?"],[909,1101,"You must be one of Mr. Cole's people."],[1142,1284,"He doesn't know who I am."],[1372,1459,"You could say that."],[1488,1597,"Seems like you're taking"],[1597,1722,"a fancy to my girl."],[1976,2031,"No,"],[2060,2248,"I prefer my women more faithful."],[2306,2381,"Faithful?"],[3803,4087,"And I prefer mine obedient."],[4304,4404,"Sit down on Daddy's lap."],[4483,4692,"I was hired as a violinist."],[4692,4829,"I said sit!"],[5155,5276,"You're a beautiful girl."],[5380,5492,"You're so beautiful."],[5814,5905,"What the fuck?"],[6039,6197,"Back off."]],"56":[[108,233,"What the fuck?"],[358,429,"Back off."],[454,592,"You take your hand off of me right now"],[592,717,"before I have it cut off."],[1092,1159,"This was a"],[1401,1580,"consensual transaction."],[1655,1730,"You hear that?"],[1976,2210,"Far be it from me to criticize"],[2327,2431,"your new hobbies."],[2473,2535,"New?"],[2535,2635,"Oh, oh no."],[2648,2731,"What we've got going on"],[2731,2911,"is been five, six, seven years."],[3019,3111,"What did he just say?"],[3144,3315,"Oh, she was a feisty one."],[3336,3390,"But don't worry,"],[3390,3524,"it didn't take much to get her"],[3578,3687,"put into shape."],[4066,4254,"Tell me he's lying."],[4254,4404,"It's not what you think."],[4629,4708,"You're lying!"],[4729,4800,"Stop."],[4833,4942,"You cannot afford"],[4942,5055,"to mess with Brandon."],[5230,5292,"Henry."],[5363,5442,"Stop."]],"57":[[141,204,"Henry."],[271,371,"Stop."],[604,671,"Henry?"],[925,1255,"Henry, you're that cancer boyfriend."],[1384,1580,"Oh, poor you."],[1626,1722,"While you were half-dead"],[1722,1814,"in the hospital,"],[1830,2002,"I had this one on her back,"],[2018,2268,"begging and screaming for more."],[2531,2836,"No one touches my woman!"],[2848,2990,"Oh, you mother-"],[3007,3086,"Mr. Shaw."],[3098,3174,"Sir, sir!"],[3194,3249,"Sir."],[3653,3803,"Your woman?"],[3903,4241,"She was never your woman."],[4658,4954,"Tell your boss that the deal's off,"],[4954,5271,"because I'm gonna fucking kill you!"],[6468,6531,"You'd be dead"],[6531,6677,"before the bullet left the gun."],[6856,6919,"Damn!"],[6948,7007,"Fuck!"]],"58":[[1209,1272,"Where are we?"],[1468,1564,"You don't remember?"],[2469,2540,"It's beautiful."],[2715,2756,"Yeah."],[3807,4020,"Imagine a big, beautiful house"],[4020,4166,"with a grand staircase."],[4295,4408,"And a stage,"],[4500,4612,"for you to play the violin."],[6197,6414,"I spent the past seven years,"],[6414,6573,"building your dream house."],[6619,6681,"Henry."],[7253,7394,"You said you wanted to be rich,"],[7469,7757,"so I took over the Cole Group."],[7811,8033,"You said you wanted glamour,"],[8058,8179,"so I built this house,"],[8229,8575,"designed every room for you."],[8658,8725,"And now,"],[8796,8896,"you're telling me,"],[8929,9075,"you were cheating on me"],[9121,9284,"with Brandon Shaw?"],[9355,9522,"Henry, stop."],[9567,9772,"It wasn't like that, we weren't-"],[9772,9909,"That's why you were always away"],[9909,10001,"when I was sick."],[10035,10143,"You were out"],[10143,10352,"fucking Brandon Shaw!"],[10593,10748,"Is Anna even my daughter?"]],"59":[[16,141,"Is Anna even my daughter?"],[208,454,"What's the point of asking questions"],[454,554,"if you're not even going to-"],[554,658,"I did listen!"],[742,829,"And you said"],[867,1009,"you were gonna kill our baby."],[1063,1134,"That's right."],[1180,1372,"I don't deserve to be around anymore."],[1438,1559,"You're a beautiful girl."],[1701,1956,"I agree to give up custody."],[2189,2323,"A single word from her,"],[2323,2481,"and I would give her"],[2481,2648,"anything she wanted."],[2965,3203,"But even now, she's choosing to leave."],[3261,3328,"Mommy?"],[3395,3470,"Mommy!"]],"60":[[33,95,"Mommy?"],[112,183,"Mommy?"],[450,517,"Hey, honey."],[633,692,"Daddy,"],[692,859,"why did Mommy leave again?"],[859,1001,"Why can't she stay?"],[1368,1484,"This is some adult stuff"],[1484,1576,"going on right now,"],[1576,1655,"so well,"],[1676,1735,"why don't you go back"],[1735,1822,"to your room, okay?"],[1851,1914,"No."],[1914,1960,"Hey,"],[2035,2156,"stop it, all right?"],[2156,2327,"No, Mommy would never leave me."],[2327,2398,"Something bad"],[2398,2494,"must have happened."],[2515,2673,"Daddy, make her come back."],[2756,2811,"Come on."],[2969,3023,"Come on."],[3103,3199,"Go to your room."],[3232,3461,"No, I just want Mommy back."],[3953,4087,"Why can't Mommy and Daddy"],[4087,4220,"just be together?"],[4325,4379,"Come here."],[4550,4600,"No."],[4642,4750,"No, if you don't make"],[4750,4846,"Mommy come back,"],[4846,5034,"then you're not my Daddy anymore!"],[5050,5105,"What?"],[5280,5409,"Bye-bye, tiara."],[5630,5684,"Honey."],[5739,5797,"Come here."],[5985,6160,"I don't want pretty things, Daddy."],[6193,6293,"I just want Mommy"],[6293,6460,"because Mommy loves me."]],"61":[[1017,1080,"Anna,"],[1146,1288,"Daddy is so sorry."],[1372,1555,"I promise I'm gonna get Mommy back,"],[1568,1626,"okay?"],[1847,1935,"Come on, sweetheart."],[2027,2156,"Daddy will go out there."],[2185,2310,"It's past your bedtime."],[3228,3303,"Christy."],[3478,3741,"You've been nothing but cruel"],[3820,3912,"to me and Anna."],[3912,4062,"Yet our daughter loves you"],[4245,4329,"so much."],[5221,5296,"Is that..."],[5780,5897,"To Henry."],[5930,6126,"Our beautiful baby girl."],[6322,6527,"So she didn't want to kill our baby?"]],"62":[[834,888,"Oh."],[930,1042,"When Mommy was pregnant,"],[1063,1201,"some bad things happened."],[1222,1334,"I didn't want to leave Daddy,"],[1359,1551,"but I had to keep you safe."],[1584,1714,"She wasn't two-timing me."],[1847,1951,"She was trying to protect me"],[1951,2043,"from Brandon Shaw."],[2377,2469,"Mommy got sick,"],[2489,2660,"and couldn't play the violin anymore."],[2698,2882,"But she always loved you."],[2998,3098,"No, Christy."],[3465,3661,"She watched her future slip away"],[3661,3782,"right before her eyes,"],[3837,4016,"and she still never gave up on Anna."],[4967,5146,"I've hurt Henry too many times."],[5284,5422,"I have to move on."],[5501,5818,"I don't deserve any kindness."]],"63":[[1021,1184,"I need to protect Anna"],[1184,1393,"by any means necessary."],[1547,1755,"Well, well, look who it is."],[1772,1939,"You promise not to hurt them,"],[1939,2031,"if I come to you."],[2122,2314,"You promise to be my wife,"],[2314,2506,"and we got a deal baby."],[3399,3478,"Christy."],[3728,3812,"Christy!"]],"64":[[971,1063,"Christy,"],[1151,1351,"my musical genius."],[1438,1622,"Why are you out here getting so wet?"],[1680,1872,"Why don't you come in with me"],[1872,2035,"and get dry, huh?"],[3048,3203,"Christy!"],[3470,3516,"No!"],[3532,3595,"No!"]],"65":[[291,358,"This is it."],[383,467,"Today is the day"],[467,725,"I sign my life over to the tyrant,"],[725,829,"Brandon Shaw."],[1518,1630,"No sign of Christy, sir."],[1822,1914,"And we are live"],[1926,2002,"from the beautiful wedding"],[2002,2118,"of Mr. Brandon Shaw,"],[2135,2239,"and his fiancée,"],[2256,2481,"rumored to be a violin prodigy."],[2519,2623,"The wedding takes place"],[2623,2840,"at the historic Shaw family chapel,"],[2865,3044,"with big names in attendance."],[3290,3399,"Cars, now!"],[3561,3766,"I'm never losing you again, Christy."],[4742,4967,"I'm sorry, Henry, Anna."],[5180,5338,"This is the only way"],[5338,5459,"I can keep you safe."]],"66":[[538,617,"Wait for me."],[729,796,"Please."],[4813,5025,"Do you, Brandon Shaw,"],[5071,5213,"take Christy Lane"],[5267,5501,"to be your lawfully wedded wife?"],[5563,5634,"Oh, father."],[5793,5855,"I do."],[5980,6177,"And do you, Christy Lane,"],[6247,6393,"take Brandon Shaw"],[6393,6673,"to be your lawful, wedded husband?"],[6861,6952,"I..."],[7090,7161,"No!"]],"67":[[425,500,"No!"],[1530,1843,"Henry Cole, cancer boyfriend!"],[1872,1951,"You come to stick"],[1951,2077,"on my gig again, huh?"],[2139,2360,"None of her is yours."],[2389,2448,"Well,"],[2489,2615,"funny thing about that is"],[2727,2936,"Christy here, like a good girl,"],[2977,3261,"signed a contract with me, yes."],[4074,4362,"No one touches the mother of my child."]],"68":[[855,913,"Hey, wait!"],[913,988,"Wait, hold on!"],[1034,1163,"God damn it!"],[1384,1459,"Christy."],[1672,1764,"My Christy."],[1864,1939,"I'm sorry."],[2031,2122,"You have to go."],[2164,2385,"You have no idea the things he did,"],[2540,2752,"and the things I did."],[3532,3624,"I know everything."],[3958,4070,"Seven years ago,"],[4191,4383,"when I was lying in that hospital bed,"],[4475,4550,"dying,"],[4596,4804,"it was you who paid for my treatment."],[5055,5230,"You dragged your pregnant body"],[5230,5376,"from concert to concert,"],[5417,5518,"day after day,"],[5643,5818,"just trying to scrape together"],[5818,5922,"whatever money you could"],[5939,6089,"to pay for my medical fees."],[6156,6297,"And I wasn't even there for you."],[6398,6493,"I wasn't there"],[6569,6635,"when Brandon"],[6635,6777,"forced himself on you."],[6844,6915,"And I wasn't there"],[6915,7065,"when my own father blamed you"],[7065,7161,"for my illness."]],"69":[[8,120,"And then you left me."],[212,304,"You ran away"],[417,492,"from Brandon."],[538,621,"You got sick,"],[750,884,"yet you still worked."],[975,1167,"You still took care of Anna."],[1242,1330,"And through it all,"],[1393,1472,"you loved her."],[1593,1676,"You loved me."],[1872,1947,"And you did it,"],[2072,2177,"so I would live."],[2752,2844,"So please."],[2994,3103,"Just this once."],[3174,3411,"Let me protect you,"],[3474,3607,"for the rest of your life."]],"70":[[1405,1476,"Christy,"],[1780,1876,"will you marry me?"],[2252,2318,"Yes."],[2385,2506,"A hundred times."],[2581,2744,"A thousand times."],[2815,2886,"Yes."]],"71":[[191,325,"Today marks the triumphant debut"],[350,500,"for violinist Christy Cole,"],[546,654,"returning to the stage"],[667,809,"after a seven year absence."],[829,900,"She performs"],[921,1055,"in the beautifully renovated"],[1080,1184,"Cole concert hall,"],[1238,1443,"purchased from Brandon Shaw."],[4808,4909,"Encore."],[4929,5025,"Encore."],[5080,5184,"Encore."],[5221,5334,"Encore."],[5397,5459,"Ready?"]],"72":[[2122,2260,"This piece is dedicated"],[2260,2344,"to my children,"],[2406,2460,"Anna,"],[2523,2602,"and our new baby,"],[2781,2844,"Henry."],[4466,4750,"Finally, we're all together as a family."]]}