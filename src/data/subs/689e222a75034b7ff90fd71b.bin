{"1":[[58,175,"My sister and I were born"],[175,329,"just ten minutes apart."],[383,554,"Identical in every way."],[566,750,"We'd often switch places,"],[750,937,"secretly fooling our parents,"],[937,1070,"and teachers for fun."],[1125,1237,"Ever since we shared"],[1237,1333,"our mother's womb,"],[1333,1558,"we've never been apart."],[1660,1820,"Now to the final asset."],[1820,2004,"In the 400 billion dollar,"],[2020,2220,"Fitzroy and Belmont divorce."],[2266,2466,"The heirs, Erin and Elise,"],[2475,2575,"will be divided"],[2575,2710,"between the parents."],[2729,2908,"James Belmont will take sole custody"],[2908,2991,"of Elise."],[3016,3187,"Laura Fitzroy will take Erin."],[3275,3404,"Divorce can break you."],[3487,3679,"It broke my sister and I."],[3762,4062,"3500 miles now lay between us."],[4116,4329,"We were told to forget each other,"],[4341,4433,"and over time,"],[4504,4612,"we did."],[4925,5091,"I hope you don't mind."],[5091,5312,"I hope you don't mind,"],[5358,5645,"that put down in words."],[5766,6075,"How wonderful life is,"],[6179,6479,"when you're in the world."],[6550,6675,"Where are you taking me, Damien?"],[6675,6800,"Aw, patience, darling."],[6800,6912,"It's a surprise."],[6954,7137,"I have a surprise for you as well."],[7154,7354,"Our babies growing inside me"],[7395,7687,"and naming you the new Belmont CEO."]],"2":[[245,408,"No peeking now, Elise."],[454,562,"So mysterious."],[875,1054,"You brought me to Lovers Point?"],[1125,1287,"Happy fifth anniversary, darling."],[1370,1470,"It's beautiful."],[1604,1812,"You know, some say that after death,"],[1833,1958,"people turn into stars."],[2058,2145,"Do you think my dad is"],[2145,2212,"one of those stars"],[2212,2337,"looking down on us right now?"],[2479,2645,"Why don't you ask him yourself?"],[2783,2829,"What?"],[2983,3229,"It's time for you to die, Elise."],[3279,3429,"And as your grieving widower,"],[3520,3691,"I'll be taking over the Belmont Group."],[3816,3962,"What? So..."],[3987,4104,"So your surprise is that"],[4104,4237,"you're going to kill me?"],[4341,4450,"Damien, I was going to share it"],[4450,4537,"all with you."],[4658,4716,"I"],[4729,4795,"don't"],[4808,4883,"share."],[5045,5179,"Damien, please no!"],[5220,5387,"I'm pregnant with your baby."],[5433,5529,"So am I."],[5716,5791,"Selene?"],[6395,6641,"I'm also pregnant with Damien's child."],[6683,6820,"So the one in your belly,"],[6820,7075,"can go ahead and die with you."],[7129,7262,"You're supposed to be my best friend,"],[7262,7412,"and you're sleeping with my husband?"],[7429,7591,"We've been doing it right under"],[7591,7733,"your nose, you stupid bitch."],[7775,7854,"Enough talk!"],[8012,8120,"Get on with it, Selene."],[8216,8320,"You know what I hate most"],[8320,8416,"about you?"],[8529,8829,"Is that beautiful face of yours."],[10029,10116,"Oh my God!"],[10370,10508,"Something's wrong with Elise."]],"3":[[195,341,"Is CEO Elise Belmont,"],[341,445,"really dead?"],[604,741,"I don't want to believe it either."],[1104,1225,"Since my father in law"],[1225,1433,"passed, three months ago."],[1545,1666,"Elise had been emotionally"],[1666,1733,"unstable."],[1929,2087,"If I had only been with my wife,"],[2093,2139,"that night."],[2279,2404,"Instead of at work."],[2591,2725,"I might have been able to prevent her"],[2725,2808,"from jumping."],[2895,2979,"A suicide!"],[3050,3241,"Elise Belmont was one of the richest"],[3241,3350,"women in the world."],[3458,3633,"Elise, my twin sister."],[3675,3795,"It's been 20 years"],[3795,3958,"since we were separated."],[3970,4075,"But I know"],[4075,4208,"you would never kill yourself."],[4220,4337,"Such a loving husband."],[4395,4495,"What a tragedy."],[4533,4641,"Who will lead the Belmont Group"],[4641,4695,"now?"],[4750,4879,"Already the jackals"],[4879,4970,"circle Elise."],[5041,5170,"And your husband,"],[5170,5345,"may be the worst of them."],[5500,5666,"Give me all the intel you can gather"],[5666,5808,"on Damien Maxwell."],[6204,6275,"What?"],[6320,6416,"Elise?"],[6483,6583,"It can't be."],[6816,7004,"Because I fucking killed her."],[7054,7133,"Please."],[7208,7304,"Just let me die."],[7333,7475,"What are you doing, Selene?"],[7487,7633,"Don't come any closer."],[7645,7812,"Elise was my best friend."],[7845,8062,"And I just can't live without her."],[8129,8183,"Mhm,"],[8195,8437,"Elise, I'm going to suck Damien off"],[8437,8537,"in your bed tonight."],[8579,8766,"Rest in peace."],[9429,9570,"This press conference is over."],[9666,9858,"Please respect our privacy,"],[9858,9945,"while Ms. Dixon, and I"],[9945,10066,"grieve for Elise."],[10650,10745,"Is this is yours?"]],"4":[[287,458,"Damien!"],[483,616,"I can't take it anymore."],[616,783,"I miss Elise so much."],[1438,1664,"Poor Elise Belmont."],[1775,2020,"So very rich."],[2045,2233,"So very beautiful."],[2337,2595,"So very dead, and ugly!"],[2769,2945,"That was quite the show you put on."],[3041,3216,"You weren't half bad yourself."],[3312,3541,"Now the Belmont group is all yours."],[3562,3816,"And you're all mine."],[3875,4104,"I only get full control,"],[4116,4320,"by cracking Elise's damn safe."],[4420,4554,"I can't believe you didn't get the code"],[4554,4675,"before you threw her off the cliff."],[4783,4891,"I assumed,"],[4904,5029,"you had the code."],[5030,5183,"Since you're her best friend."],[5284,5429,"What, she didn't give it to you?"],[5445,5605,"Well, she didn't give it to you either."],[5745,5920,"Maybe she didn't trust her,"],[5975,6087,"sexy,"],[6162,6312,"ambitious,"],[6312,6412,"husband."],[7061,7233,"You're not missing that stupid twat,"],[7233,7294,"are you?"],[7424,7524,"Of course not."],[7670,7779,"It's just..."],[8162,8241,"I think I saw her"],[8241,8366,"at the press conference."],[8441,8500,"That's..."],[8529,8650,"Impossible."],[8837,9016,"Nobody could've survived that fall."],[9062,9179,"Relax."],[9208,9358,"I'll worry about finding"],[9358,9412,"the passcode"],[9412,9537,"to the safe."],[9584,9712,"All you have to worry about,"],[9712,9918,"is satisfy me in bed."],[10058,10262,"I'm not worried."],[11116,11150,"Tell me."]],"5":[[125,270,"What the fuck?"],[387,483,"Elise."],[616,716,"Elise."],[837,941,"I saw Elise."],[983,1116,"Oh, my God, you're losing it."],[1125,1187,"It was her,"],[1200,1283,"she was there."],[1395,1541,"Stop imagining things, okay?"],[1629,1712,"Am I?"],[1745,1904,"The cops never found her body."],[1904,2062,"They never found her body, Damien."],[2091,2279,"Because it was washed down"],[2279,2391,"the river."],[2416,2537,"Jesus Christ, Selene, please."],[2537,2587,"Come on, just..."],[2587,2704,"You said it yourself."],[2729,2945,"She couldn't have survived that fall."],[3037,3070,"Right."],[3175,3312,"- Right? - Right."],[3354,3437,"Get a grip."],[3679,3820,"I was just afraid."],[3837,3925,"That's all."],[3975,4116,"I need you to stay strong."],[4150,4237,"Okay?"],[4258,4354,"Play your part,"],[4354,4466,"at the funeral tomorrow."],[4654,4791,"Poetic, isn't it?"],[4858,4987,"How she had to die."],[4987,5229,"In order, for our dream to live."],[5304,5475,"I don't believe in ghosts,"],[5591,5750,"but if Elise has one,"],[5841,6033,"I dare her to come find me."],[6895,7025,"Little sister,"],[7095,7275,"you've barely taken your last breath,"],[7275,7391,"and already your husband, and"],[7391,7608,"best friend are sharing your bed."],[7658,7775,"Your memory deserves"],[7783,7958,"so much better than these two."],[8020,8241,"Who are now my prime suspects."],[8370,8500,"Elise,"],[8520,8654,"when life isn't fair,"],[8716,8941,"justice must be served after death."],[9050,9208,"I'll see you at the funeral tomorrow."]],"6":[[554,854,"Elise, my wife, my angel, my love."],[895,1004,"Your heart made this world"],[1004,1095,"a better place."],[1150,1375,"Every day of your 26 short years."],[1583,1733,"Rest in peace, sweet darling."],[2016,2241,"Now shed a tear for the board members"],[2241,2370,"and keep the show moving."],[2404,2537,"The sooner it's over,"],[2537,2654,"the sooner the Belmont Group"],[2654,2750,"is mine."],[3000,3162,"My deareast friend,"],[3379,3537,"I'll spend every waking moment"],[3537,3687,"wishing you were here with me."],[3858,4004,"And if your ghost tries to come"],[4004,4162,"between Damien and me again,"],[4212,4470,"I'll go to hell and kill you all over again."],[4625,4704,"Ms. Elise,"],[4737,4983,"you'll always be in my heart."],[5000,5095,"Who's that old woman?"],[5208,5400,"Martha, Ms. Belmont's"],[5400,5491,"nursemaid."],[5541,5745,"She knew Elise better than anyone."],[6525,6745,"Oh, Martha."],[6783,6900,"Sorry."],[7279,7383,"It's time we all accept"],[7383,7466,"that she's gone."],[7562,7725,"Time we get on with our lives."],[7795,7966,"And I'll never believe"],[7966,8095,"that you killed yourself."],[8120,8295,"In honor of my late wife,"],[8387,8558,"I will be stepping in as the CEO"],[8562,8658,"of Belmont Group."],[8745,8862,"I object!"]],"7":[[387,500,"- Ghost! - Ghost!"],[541,662,"Don't come any closer."],[675,812,"Don't come any closer."],[845,979,"The cheating couple."],[1129,1183,"It's her."],[1216,1312,"It's really her."],[1412,1545,"That's impossible."],[1566,1741,"So, my sister never told you"],[1741,1866,"she had an identical twin."],[1908,2004,"Works for me."],[2037,2245,"Let's see which one of you breaks first."],[2383,2529,"Long time no see, hubby."],[2670,2804,"That delicate face."],[2850,2937,"It can't be."],[3000,3191,"Selene splashed acid on her."],[3237,3400,"Is this some kind of sick joke?"],[3508,3758,"Ms. Elise, is it really you?"],[3891,4037,"Take a closer look hubby."],[4062,4145,"It's me."],[4183,4383,"Elise Belmont, your wife."],[4620,4704,"Selene,"],[4750,4920,"my husband doesn't recognize me."],[4995,5162,"How about you? My best friend."],[5216,5287,"Get away!"],[5350,5487,"Go away, go away!"],[5512,5625,"Strange,"],[5691,5870,"moments ago, you were all crying"],[5870,5991,"over my grave."],[6116,6258,"And yet now that I'm back,"],[6258,6454,"you don't seem sad at all."],[7183,7441,"Elise Belmont, is dead."],[7591,7687,"I don't know who the fuck"],[7687,7754,"you are,"],[7787,7887,"but you're not her."]],"8":[[75,229,"I don't know who the fuck you are,"],[287,375,"but you're not her."],[437,654,"Only Elise's killer could be so certain"],[654,741,"that she's dead."],[804,875,"Damien,"],[925,1087,"don't you want me to be alive?"],[1158,1283,"I would give up anything"],[1283,1433,"for my Elise to be with me."],[1475,1533,"But the only thing"],[1533,1633,"you share with my wife,"],[1633,1729,"is a face."],[1737,1950,"She looks just like Ms. Elise."],[1950,2104,"But there's something stronger"],[2104,2187,"in her eyes."],[2208,2420,"So, Elise Belmont isn't dead after all."],[2445,2575,"But even her husband"],[2575,2708,"doesn't acknowledge her."],[2708,2850,"She must be an imposter."],[2850,3008,"What kind of cruel hoax is this?"],[3062,3250,"April 15th, 2019."],[3333,3445,"The first time we met,"],[3445,3595,"you pretended to ask for directions"],[3595,3658,"to an exhibit,"],[3666,3791,"and I ended up joining you."],[3962,4116,"February 1st, 2020."],[4116,4270,"You proposed to me in Times Square,"],[4270,4420,"and all the billboards"],[4420,4570,"lit up with images of our love."],[4670,4787,"Two weeks ago on our anniversa..."],[4787,4912,"Enough!"],[4967,5050,"Hubby,"],[5095,5179,"between the two of us,"],[5179,5334,"I know it all too well."],[5383,5612,"So this funeral is one big farce."],[5641,5791,"There's no need to transfer power"],[5791,5916,"to Damien Maxwell."],[5958,6070,"Transfer of power?"],[6083,6195,"That's ridiculous."],[6200,6404,"I'm the CEO. I'm not dead."],[6425,6483,"Listen lady,"],[6483,6625,"you may resemble my wife"],[6625,6825,"and know a little bit about my past,"],[6825,6912,"but you can't just..."],[6954,7116,"Just swagger in here,"],[7116,7233,"and cheat your way into"],[7233,7312,"the Belmont Group."],[7345,7391,"Hubby..."],[7391,7487,"You said you remember"],[7487,7541,"everything."],[7575,7675,"What about your attempted"],[7675,7837,"suicide at Lovers Point?"]],"9":[[4,83,"Lies."],[116,191,"My sister would"],[191,416,"never take her own life."],[666,758,"It's so painful."],[854,925,"It hurts so bad."],[1004,1141,"I woke up on a riverbank,"],[1141,1316,"and I don't know how I got there."],[1316,1400,"And..."],[1400,1562,"My memory, it's just..."],[1562,1695,"bits and pieces."],[1950,2016,"Damien,"],[2016,2179,"did someone try to push me off?"],[2291,2383,"Is she a phony,"],[2383,2508,"or did she really survive?"],[2600,2733,"Either way,"],[2733,2933,"game fucking on!"],[2962,3020,"Darling,"],[3020,3050,"There's no way"],[3050,3170,"you could have been pushed."],[3191,3245,"You were the only one"],[3245,3354,"at Lovers Point that night."],[3366,3454,"Selene, and I didn't arrive"],[3454,3633,"until after we heard the news."],[3712,3758,"So,"],[3758,3916,"there were three people that night."],[3954,4070,"My little sister."],[4070,4191,"Her cheating husband."],[4212,4387,"And a snake of a best friend."],[4550,4716,"I'm so relieved you're back."],[4754,4900,"I'll take good care of you from now on,"],[4900,5058,"and make sure that you, I mean..."],[5066,5200,"Never attempt suicide again."],[5300,5416,"So that's your angle."],[5445,5637,"You slick bastard."],[5679,5958,"Game fucking on!"]],"10":[[54,112,"Hubby."],[158,275,"Shall we go home now?"],[437,583,"Of course, darling."],[791,866,"The Belmont Group"],[866,975,"must be in turmoil,"],[975,1104,"over my two week absence."],[1212,1291,"As CEO,"],[1291,1412,"I'm calling an emergency"],[1412,1529,"board meeting tomorrow."],[1550,1712,"I look forward to seeing you all there."],[1816,1912,"See you tomorrow, Ms. Belmont."],[1912,2033,"Take care Mrs. Belmont."],[2033,2116,"Take care."],[2150,2229,"Whoever you are,"],[2279,2366,"you're not going to rob me"],[2366,2500,"of what's rightfully mine."],[2579,2683,"There's no way that's"],[2683,2770,"Elise Belmont."],[2804,2970,"she's not all bossy like that."],[3054,3162,"I have a sure fire way"],[3162,3262,"to expose her."],[3933,4045,"Have Striker guard the entrance"],[4045,4137,"to the estate."],[4237,4375,"I'm bringing a special guest."]],"11":[[54,191,"Little sister."],[191,491,"So this is where you grew up without me."],[1491,1679,"Miss Elise,"],[1679,1866,"you were always sweet and kind"],[1866,2045,"and protected by your late father."],[2116,2391,"Then Mr. Damien came along,"],[2391,2575,"and your father was impressed by him."],[2600,2725,"Everyone is."],[2725,2845,"Where is she going with this?"],[2845,3004,"Is she testing me?"],[3029,3120,"Martha, I..."],[3120,3245,"I don't know what you mean."],[3412,3591,"You're not Ms. Elise, are you?"],[3816,3945,"I don't understand."],[3983,4095,"I watched Elise grow,"],[4104,4270,"from a scared six year old girl"],[4270,4425,"to the woman that she is today."],[4616,4825,"She was like a daughter to me."],[4825,4920,"Martha!"],[4920,5087,"And I remember in the early days,"],[5087,5291,"she would cry for her big sister,"],[5291,5387,"Erin."],[5541,5662,"That's you, isn't it?"],[5766,5837,"What have you done with"],[5837,5937,"Ms. Elise?"],[5950,6129,"Tell me, where did you hide her?"],[6129,6262,"What are you two talking about?"],[6387,6545,"It's not me. It's them."],[6562,6654,"If you want to help Elise,"],[6654,6816,"help me expose them."],[7054,7154,"What's wrong, Martha?"],[7187,7225,"I..."],[7254,7400,"I, I..."],[7433,7595,"I can't be exposed this soon."],[7620,7725,"What is it, Martha?"],[7725,7837,"You recognize this woman"],[7837,7954,"as an imposter?"],[7995,8104,"Miss Dixon,"],[8133,8354,"miss Elise and I were just talking"],[8354,8533,"about her late father."],[8566,8683,"That's why I can't"],[8683,8820,"stop crying."],[8904,9079,"Oh, that's it?"],[9145,9279,"What else do you think"],[9279,9350,"we were talking about, hubby?"],[9387,9545,"How I killed myself?"],[9987,10133,"You remember striker?"],[10262,10420,"My mean-ass dog."],[10495,10645,"Whenever some stranger"],[10645,10766,"steps onto the property."],[10783,10883,"We trained him"],[10883,11070,"to tear them to fucking pieces."]],"12":[[8,204,"To tear them to fucking pieces."],[845,991,"That's a good boy!"],[1008,1204,"You missed me, huh?"],[1445,1575,"It can't be."],[1820,1916,"Strange,"],[1929,2079,"you're both acting like you wanted"],[2079,2200,"striker to maul me."],[2216,2379,"A pooch always knows its owner."],[2425,2550,"Is she really,"],[2550,2720,"Elise Belmont?"],[2831,2991,"I invited Striker to greet you."],[2991,3132,"He missed you so much."],[3178,3432,"Aw, you're so sweet, hubby."],[3616,3770,"Where the hell is she?"],[3770,3979,"Why didn't you just stay dead?"],[4004,4229,"You made a fool of my poor brother."],[4291,4475,"So this is the wicked family,"],[4475,4654,"my sister married me into."]],"13":[[100,225,"Vicious mother in law,"],[237,420,"cold blooded sister in law,"],[420,533,"plotting mistress,"],[533,670,"and a dangerous husband."],[683,933,"Little sister, what were you thinking?"],[945,1137,"As you can see, I didn't die."],[1154,1300,"Sorry, not sorry."],[1379,1537,"You dare come back here"],[1537,1679,"with an attitude."],[1762,1987,"You need to be put in your place."],[2337,2437,"You crazy bitch!"],[2575,2745,"Damien, do something."],[2795,3012,"Portia, I'm the lady of the house."],[3029,3191,"You do well to remember that."],[3208,3354,"You're not Elise Belmont."],[3354,3525,"She never fought back."],[3591,3725,"You know what they say, don't you?"],[3766,3845,"What doesn't kill you"],[3845,3937,"makes you stronger."],[3949,3991,"Enough!"],[4087,4291,"Mother, Portia,"],[4325,4437,"Elise just got back."],[4508,4650,"Why don't you go in, darling."],[4650,4741,"Get some rest."],[4875,4979,"Great idea, hubby."],[5016,5091,"Gotta be fresh"],[5091,5216,"for tomorrow's board meeting."],[5654,5750,"Son, did you hear"],[5750,5891,"what that bitch just said?"],[5929,6041,"She still wants to keep"],[6041,6183,"the company from you."],[6220,6341,"Be quiet, mother."],[6462,6712,"Selene, take this to the lab."],[6733,6870,"Have it DNA tested."],[6958,7112,"We'll find out the truth soon enough."],[7150,7233,"And at the shareholder"],[7233,7333,"meeting tomorrow,"],[7362,7575,"I'll expose that fake bitch myself."]],"14":[[2433,2600,"I'd like to start by thanking the board,"],[2600,2708,"for minding the company"],[2708,2800,"during my absence."],[2854,3000,"Your loyalty would make my father"],[3000,3133,"very proud."],[3233,3366,"I especially want to thank"],[3366,3570,"my dear husband, Damien."],[3587,3720,"For keeping a brave face,"],[3720,3862,"while his heart was breaking."],[4441,4525,"All right."],[4525,4637,"Enough with the pleasantries."],[4645,4816,"Let's get down to business, shall we?"],[4816,4950,"First item in my agenda..."],[4950,5116,"Proving you're Elise Belmont!"],[5212,5416,"And why would you even doubt me?"],[5437,5583,"Elise Belmont's suicide"],[5583,5708,"was all over the news."],[5733,5895,"And then out of the blue,"],[5941,6091,"a look-a-like shows up,"],[6091,6245,"claiming to be her."],[6295,6641,"Claiming to be our CEO."],[6662,6862,"I, for one, refuse to put"],[6862,6983,"this company at risk,"],[6983,7183,"and my millions in stock options,"],[7183,7350,"until we have solid proof"],[7370,7545,"you are Elise Belmont."],[7624,7711,"Well."],[7741,7891,"Your tone has certainly changed"],[7891,7987,"since the funeral."],[7987,8083,"I wonder why."],[8300,8433,"Mr. Ruskin,"],[8433,8562,"we're counting on you at the board"],[8562,8704,"meeting tomorrow."],[8704,8841,"Damien is going to expose"],[8841,8958,"that con artist,"],[8958,9079,"and force her to reveal"],[9079,9250,"who she truly is."],[9358,9500,"Just out of curiosity,"],[9500,9708,"what type of proof are you looking for,"],[9708,9754,"exactly?"],[9805,9964,"Funny you should ask."]],"15":[[133,304,"Recognize this?"],[337,604,"I recognize a trap when I see one."],[654,791,"It's a safe."],[883,958,"That's right."],[1050,1204,"From the CEO's office."],[1275,1404,"It contains the bylaws,"],[1404,1508,"governing documents,"],[1508,1641,"and account codes to all"],[1641,1741,"of Belmont Group's"],[1741,1879,"holdings across the globe."],[1937,2100,"And there's only one person"],[2141,2279,"in the entire world"],[2291,2483,"who knows the passcode."],[2570,2779,"Elise fucking Belmont."],[2941,3004,"Please,"],[3004,3216,"if you would indulge the board"],[3229,3366,"Elise,"],[3412,3533,"and open it."],[3541,3720,"That should prove who you really are."],[3783,3829,"Do it!"],[3829,3887,"Show us!"],[3887,4016,"Now, god dammit!"],[4033,4241,"You're not scared, are you?"],[4350,4604,"That's no way to speak to your CEO,"],[4612,4912,"but I'll let it slide just this once."],[5062,5308,"This is my first step to avenge my sister."],[5329,5529,"I must think like Elise Belmont."],[5558,5712,"Let's do this."],[6389,6631,"I have the DNA test results."],[6687,6795,"Perfect timing."],[6845,6920,"Bring it up."],[7070,7158,"Selene,"],[7175,7325,"in the future, when you're in a meeting"],[7325,7425,"with your CEO,"],[7466,7583,"your calls can wait."],[7766,7858,"My bad."],[7908,8129,"Please, continue."],[8175,8320,"Enjoy your little charade"],[8320,8429,"while it lasts,"],[8441,8591,"you arrogant bitch."],[9195,9383,"We're waiting."],[9404,9516,"Let's see how well I know you"],[9516,9720,"after all these years, little sister."]],"16":[[1350,1525,"Surprise, surprise."],[1595,1691,"Guess who isn't"],[1691,1854,"Elise Belmont, after all."],[1875,1987,"Call security to haul"],[1987,2145,"her sorry ass out of here."],[2254,2387,"My memory's still a little fuzzy"],[2387,2475,"from the fall."],[2533,2700,"Nice try, you psycho."],[2758,3058,"I assure you, I am anything but."],[3083,3279,"Okay, okay, okay."],[3441,3591,"I'll give you another try."],[3683,3808,"Guide me, Elise."],[3829,3962,"So that I can avenge you,"],[3962,4129,"and catch your killer."],[4750,4916,"As much as I'd love to see you"],[4916,5104,"make a fool of yourself all day,"],[5166,5220,"that safe"],[5220,5341,"will permanently lock"],[5341,5520,"with one more incorrect entry."],[5587,5691,"Three strikes,"],[5795,5937,"and you're out baby."],[6154,6329,"That's a chance I'm willing to take."],[6416,6504,"But do any of you"],[6504,6658,"have the guts to do the same?"],[6700,6858,"What is she talking about?"],[6908,6991,"A bet."],[7041,7133,"You all have millions"],[7133,7225,"in stock options."],[7250,7350,"If you're so sure that I'm not,"],[7350,7437,"Elise Belmont,"],[7437,7537,"why don't you put your money"],[7537,7641,"where your mouth is?"]],"17":[[358,479,"You can't be serious."],[500,600,"Gambling on shares"],[600,779,"on whether you can open that safe."],[812,895,"That's right."],[895,1070,"This is ridiculous."],[1095,1308,"What's ridiculous is any doubt that I'm"],[1308,1479,"not the CEO of the Belmont Group."],[1537,1720,"Now, this meeting is over."],[1741,1950,"Talking tough proves nothing."],[2025,2204,"The odds of me getting this right"],[2204,2333,"if I'm not Elise Belmont,"],[2333,2495,"are one in a million."],[2562,2720,"By you cowardly refusing the bet,"],[2720,2816,"you're clearly admitting"],[2816,3062,"that I am Elise Belmont, as I say."],[3095,3312,"Don't talk down to me, little girl."],[3333,3466,"I was working at Belmont"],[3466,3600,"when you were in diapers."],[3625,3825,"This is all so fucking pointless."],[3850,3970,"Miss Dixon."],[3991,4145,"She's just trying to stall"],[4145,4266,"before the truth comes out"],[4266,4387,"that she's a fraud."],[4658,4829,"Fine, I'll take the bet."],[4862,5095,"But if I go in, we all go."],[5112,5220,"Agreed, all in!"],[5225,5295,"You're on!"],[5537,5679,"All right."],[5729,5820,"These are the share"],[5820,5937,"transfer agreements."],[5979,6216,"They make our wager official."],[6250,6337,"The balls are you."],[6337,6437,"Why do we need to sign?"],[6495,6700,"Because I don't trust you to pay up."],[7175,7337,"That agreement means nothing,"],[7337,7529,"because you're not Elise Belmont."],[7608,7716,"Selene,"],[7729,7895,"I'd ask you to join the bet as well,"],[7895,8020,"but we both know you don't have any"],[8020,8145,"shares to put up."],[8229,8379,"If only you had something else"],[8379,8512,"of value."],[8533,8754,"Just spit it out! What do you want?"],[8983,9095,"Your dignity."]],"18":[[0,212,"When I proved to be Elise Belmont,"],[212,370,"you'll hang a sign around your neck"],[370,525,"that says I'm a worthless,"],[525,700,"two timing whore."],[716,762,"And parade"],[762,929,"through my Belmont building."],[1050,1162,"I'm not a whore, bitch."],[1162,1258,"You are!"],[1354,1491,"Elise never suspected"],[1491,1670,"I was fucking Selene before."],[1766,1933,"How much does she know?"],[1970,2133,"All right, let's get on with it."],[2133,2241,"I have a company to run,"],[2241,2383,"and time is money."],[2650,2745,"All right,"],[2745,2850,"I'll sign."],[3125,3316,"By some miracle, she figures out"],[3316,3425,"the code."],[3445,3604,"Nothing will save her"],[3604,3745,"from a DNA test."],[3854,4054,"Selene has placed her bet."],[4112,4304,"The shareholders have signed."],[4454,4754,"Now it's your turn."],[4812,4908,"Hubby,"],[4954,5125,"you're a shareholder as well."],[5125,5304,"I'd hate to discriminate."],[5333,5429,"Why don't you put your shares"],[5429,5583,"on the table as well?"],[6879,6987,"Thank you, hubby."],[7033,7245,"I promise you, that's the last time"],[7245,7404,"you ever call me that."],[7475,7670,"What if she really cracks the safe?"],[7720,7941,"Please, she failed twice already."],[7941,8041,"What makes you think she'll get it"],[8041,8095,"now?"],[8220,8345,"Go ahead."],[8466,8625,"They want you to fail."],[8625,8791,"Which is why you can't."],[8958,9229,"Justice for Elise is why you won't."],[9258,9558,"one last chance."],[9887,10145,"Could this really be the passcode?"]],"19":[[487,787,"Twin girls born ten minutes apart."],[987,1112,"The elder on May 1st,"],[1112,1266,"just before midnight."],[1266,1541,"The younger on May 2nd, just after."],[1579,1733,"The code for the safe."],[1733,1854,"My birthday."],[1904,2016,"After all this time,"],[2016,2204,"you never forgot me, little sister."],[2291,2425,"It's not possible."],[2550,2670,"How did you do that?"],[2670,2770,"She is indeed,"],[2770,2908,"Elise Belmont."],[2916,3058,"She gets all of our shares."],[3058,3370,"No, no, this can't be happening."],[3375,3487,"You assured me"],[3487,3616,"she was an imposter,"],[3616,3804,"and yet she opened that safe."],[3804,4004,"What the hell is going on?"],[4066,4220,"It's a lucky guess."],[4220,4358,"It was a fluke."],[4366,4462,"Hardly, Selene."],[4462,4616,"Let’s do the math, shall we?"],[4633,4741,"If you have a 10 number"],[4741,4941,"keypad, how many 6 digit codes"],[4941,4995,"are possible?"],[5150,5245,"Anybody?"],[5354,5437,"One million."],[5491,5633,"Do you honestly believe"],[5633,5829,"I could just nail that in just three times?"],[5858,5937,"Do the shareholders"],[5937,6041,"believe that?"],[6070,6275,"If so, you belong in the mailroom"],[6275,6404,"not the board room."],[6429,6616,"I don't like the smell of this."],[6625,6804,"Are you hustling us, Miss Dixon?"],[6804,6925,"This was all a trick!"],[6970,7095,"Give us back a shares."],[7116,7254,"We want back our shares."],[7266,7358,"All bets are off!"],[7358,7545,"Stop! Proof is on the way."],[7570,7658,"We'll be fine."],[7679,7791,"Only Elise Belmont could"],[7791,7891,"open up the safe."],[7891,8045,"Your words, not mine."],[8191,8266,"Hubby,"],[8320,8450,"What more do I have to do,"],[8450,8570,"to prove to you that I am Elise Belmont?"],[8575,8716,"Take a DNA test?"],[8795,8891,"You already have!"]],"20":[[33,179,"What more do I have to do to prove"],[179,275,"to you that I am Elise Belmont?"],[275,375,"Take a DNA test?"],[483,612,"You already have."],[841,1000,"I ran a DNA test"],[1000,1166,"on a strand of your hair."],[1216,1383,"The lab compared the results,"],[1383,1516,"with a strand found"],[1537,1758,"In Elise's favorite hairbrush."],[1808,2041,"The safe was just for show."],[2100,2195,"What's in that envelope,"],[2208,2408,"is the stake through your fucking heart."],[2595,2683,"We're not ruined."],[2695,2883,"I was about to shit myself."],[2966,3075,"Plastic surgery"],[3075,3266,"can forge someone's face,"],[3275,3470,"and dumb luck can crack"],[3500,3629,"their secret passcode."],[3645,3741,"But there's no getting around"],[3741,3945,"the truth of a DNA test."],[3962,4133,"Science never lies,"],[4191,4341,"but opportunists always do."],[4379,4550,"Time's up. Bitch!"],[4550,4658,"Open it already!"],[4658,4750,"Open it!"]],"21":[[283,433,"Is this,"],[441,533,"possible?"],[533,683,"She's a phony and a fake."],[683,795,"That report proves that she's not"],[795,962,"Elise Belmont, right?"],[995,1125,"Right?"],[1125,1308,"Well, what does it say?"],[1341,1508,"Can we or can't we get our shares back,"],[1508,1650,"and kick this imposter out?"],[1704,1812,"Like I said,"],[1812,1979,"I am and always will be"],[1979,2150,"Elise Belmont."],[2308,2500,"Read it and weep."],[2533,2662,"It must be a mistake,"],[2662,2833,"a glitch with the test."],[2883,3016,"A tainted sample."],[3054,3187,"Idiots,"],[3187,3395,"Elise and I are identical twins."],[3395,3575,"We share the same DNA."],[3600,3837,"Didn't you just say, and I quote,"],[3837,3995,"there's no getting around"],[3995,4175,"the results of a DNA test?"],[4245,4395,"So it was really her."],[4654,4775,"Damien, what do we do?"],[4775,4891,"It's really her."],[4904,5066,"She's come back to get even."],[5066,5258,"Shut up."],[5587,5679,"Ms. Belmont,"],[5679,5829,"please, I beg of you,"],[5829,5979,"accept the board's apologies."],[6012,6133,"Forgive our stupidity"],[6133,6212,"and insolence."],[6325,6366,"We've been"],[6366,6504,"deceived and manipulated"],[6504,6704,"by Selene's false promises."],[6745,6958,"Return our shares, I beg of you."],[6991,7112,"I have elderly parents,"],[7112,7262,"children to care for."],[7262,7445,"Please have mercy on us."],[7462,7616,"Business is a minefield,"],[7616,7816,"all it takes is one wrong step,"],[7816,7954,"and you're dead."],[7962,8079,"You all went behind my back"],[8079,8229,"and tried to get at me."],[8254,8341,"KABOOM!"],[8462,8566,"Now you're done."],[8587,8708,"Get out of my building!"],[8745,8833,"All of you."],[9054,9254,"This is all your fault, Maxwell."],[9254,9391,"You and Selene Dixon"],[9391,9491,"promised she was a fraud."],[9491,9650,"Promise we'll prove it."],[9650,9750,"You owe us."],[9750,9950,"We demand payback."],[9970,10083,"Give us back our shares,"],[10083,10150,"goddammit!"],[10162,10291,"Get your hands off me!"],[10333,10512,"I lost shares too, dumb ass!"],[10550,10829,"I lost everything, just like all of you."],[10854,10929,"Hubby."],[11245,11425,"I'll never let my husband be broke."],[11504,11641,"This grants you all the shares"],[11641,11729,"to the Belmont Group."],[11937,12133,"A gift for my one true love."]],"22":[[33,141,"What do you mean?"],[162,333,"Forgive me for having a bit of fun."],[345,466,"I always intended to give you"],[466,545,"all the shares."],[566,783,"That's why I staged this little joke."],[800,929,"Sorry if I scared you."],[929,1125,"What game is she playing?"],[1141,1216,"Damien!"],[1370,1541,"You fucking played me!"],[1666,1779,"Son of a bitch!"],[1791,1987,"So you two are in on this together,"],[1987,2125,"jerking us around like a bunch"],[2125,2200,"of monkeys?"],[2241,2325,"Get him!"],[2375,2441,"No!"],[2495,2625,"One more step,"],[2625,2745,"and I'll send you to jail."],[2754,2850,"You don't want to go to jail,"],[2850,2975,"and be broke all on the same day."],[2975,3029,"Do you?"],[3162,3312,"Get out! Now!"],[3333,3429,"You're good!"],[3595,3725,"Let's go."],[4187,4233,"Damien,"],[4233,4383,"what the hell is going on?"],[4470,4554,"You are,"],[4579,4741,"Elise Belmont?"],[4837,4975,"I love you, hubby."],[5000,5216,"But your doubts are breaking my heart."],[5275,5575,"I'm your Elise, Elise Belmont."],[5608,5858,"Take the bait, scumbag."],[5858,5925,"Take it!"],[6029,6145,"Whoever you are,"],[6145,6283,"there's more to gain with you"],[6283,6400,"than against you,"],[6454,6554,"for now."],[6658,6733,"Darling,"],[6733,6850,"welcome back!"],[6900,6954,"But,"],[7045,7187,"what about me?"],[7216,7362,"Why are you grabbing on my"],[7362,7454,"husband?"],[7583,7708,"Damien is mine now."],[7937,7987,"Beat it!"]],"23":[[70,154,"But..."],[241,370,"Damien, please."],[379,508,"Show some goddamn"],[508,620,"self-respect."],[671,737,"But,"],[830,954,"we're a couple now."],[975,1129,"She's supposed to be dead."],[1254,1379,"There you go, Selene."],[1387,1537,"Keep talking."],[1608,1745,"Ever since Lovers Point, we..."],[1887,2087,"You shut your mouth."],[2241,2425,"Hubby, what are you talking about,"],[2425,2470,"death for?"],[2470,2591,"You are scaring me."],[2766,2845,"Nothing."],[2966,3166,"Selene mentioned Lovers Point."],[3166,3266,"That's where I fell."],[3266,3404,"Does she know something I don't?"],[3491,3595,"No, she's crazy."],[3595,3770,"Just ignore her nonsense."],[3845,3958,"If I'm crazy,"],[3958,4104,"it's because you drove me there,"],[4104,4245,"you heartless bastard."],[4275,4541,"There's nothing between us."],[4616,4712,"Nothing?"],[4766,4916,"You call a baby, nothing?"],[5108,5216,"Hers might be dead,"],[5304,5412,"but mine is still alive,"],[5412,5529,"inside of me."],[5562,5658,"Oh, God."],[5708,5858,"Was my sister pregnant"],[5858,5995,"when they killed her?"],[6454,6583,"For a big shot CEO,"],[6583,6745,"you sure are clueless, Elise."],[6904,6983,"Hubby,"],[7020,7191,"is she pregnant with your baby?"],[7266,7566,"Only in her sick, twisted mind."],[7616,7679,"Watch it!"],[7683,7841,"A paternity test would prove"],[7841,8029,"otherwise, Damien Maxwell."],[8070,8279,"What a despicable couple."],[8316,8466,"You deserve everything coming"],[8466,8529,"to you."],[8616,8945,"I don't take accusations lightly."],[8975,9129,"Because you're her best friend,"],[9129,9275,"I won't treat that as a threat."],[9291,9441,"But you better watch yourself,"],[9441,9537,"Miss Dixon."],[9775,9862,"Anyone who comes"],[9862,10041,"for my husband is no longer a friend"],[10041,10125,"of mine."],[10250,10437,"Speaking of humiliation,"],[10470,10658,"I think it's time we hang that sign"],[10658,10770,"around your neck."],[10820,10941,"And what if I refuse?"]],"24":[[166,337,"This conversation has been recorded,"],[337,487,"and I'll post it online"],[487,608,"and you'll lose credibility"],[608,825,"across every social media platform,"],[866,1000,"or the Belmont Group."],[1041,1162,"Choice is yours."],[1216,1362,"You think you got me beat?"],[1420,1541,"But as long as my child"],[1541,1787,"remains alive, I'm still in the game."],[1891,1983,"Elise Belmont,"],[2054,2170,"you just wait."],[2962,3141,"I said no pictures."],[3275,3437,"No photos."],[3641,3779,"Finally!"],[3779,4000,"This is over and I can go home."],[4216,4416,"You called reporters?"],[4450,4612,"Oops. Forgot to mention it."],[4795,4991,"Miss Dixon, don't leave."],[4991,5133,"Why are you wearing that sign?"],[5146,5280,"Come back!"],[5383,5537,"Smile for the Camera, hubby."]],"25":[[225,320,"What's wrong?"],[395,512,"Is the wound on your face"],[512,625,"causing you pain?"],[908,1087,"Oh, them."],[1100,1225,"Well, she's the CEO"],[1225,1316,"of the Belmont Group."],[1320,1433,"And that's her husband,"],[1433,1558,"Damien Maxwell."],[1683,1825,"Must be nice having all that"],[1870,2095,"fame, and power and money."],[2158,2341,"Not that we'll never find out."],[2450,2558,"Well, stop watching"],[2558,2654,"if it bothers you."],[2987,3087,"She's not..."],[3150,3270,"I am..."],[3512,3620,"Just rest."],[3650,3750,"I'll take your stitches out"],[3750,3812,"tomorrow."],[4787,4891,"Ms. Fitzroy, I..."],[4900,5037,"I don't understand why you gave all"],[5037,5145,"the Belmont shares"],[5150,5270,"to Damien Maxwell."],[5408,5520,"Pigs need to be fattened,"],[5520,5675,"before they're slaughtered."],[5775,5937,"Did you get Elise's medical records?"],[6041,6100,"Yes."],[6191,6341,"Your sister was indeed pregnant"],[6341,6583,"with twin girls."],[6695,6837,"So that evil couple didn't"],[6837,6995,"just kill my sister?"],[7050,7241,"They murdered my nieces."],[7279,7366,"And there's more."],[7420,7575,"They found acid sulfuric solution"],[7575,7712,"at the crime scene."],[7779,7904,"So they tortured Elise,"],[7904,8012,"before killing her."],[8441,8620,"Damien Maxwell,"],[8620,8754,"Selene Dixon."],[8787,8995,"You will suffer so much more"],[8995,9087,"than death."],[9325,9487,"Make the call."],[9487,9579,"See how many crimes"],[9579,9704,"we can add to the list."]],"26":[[579,987,"That was the CFO of Fitzroy Holdings."],[1054,1229,"And they're offering, wait for it..."],[1275,1641,"$10 billion to buy the Lakewood"],[1641,1770,"parcel of land."],[1787,1925,"I thought you said that land"],[1925,2062,"wasn't worth anything."],[2062,2233,"Oh, well, not to us."],[2270,2437,"Fitzroy Holdings builds resorts all"],[2437,2512,"over the world."],[2512,2666,"If they're willing to buy it"],[2666,2783,"for 10 billion."],[2783,2912,"It must be worth ten times that."],[2912,3070,"And so is the adjacent land."],[3079,3241,"We'll use the dummy corporation"],[3241,3383,"we set up, to buy it."],[3574,3679,"How much of your own money"],[3679,3820,"are you going to invest?"],[4020,4183,"All of it."],[4370,4516,"It's the deal of a life time."],[4658,4937,"And maybe, I'll give you a taste."],[5254,5333,"So, what?"],[5412,5545,"Am I forgiven now?"],[5662,5866,"As long as that bitch suffers,"],[5895,6004,"I'm in."],[6600,6683,"Hubby."],[6725,6833,"I was thinking,"],[6858,6941,"we should announce you"],[6941,7066,"as the new Belmont CEO"],[7066,7204,"at the Chamber Commerce banquet"],[7204,7291,"next week."],[7454,7558,"Don't toy with me."],[7579,7716,"I'm serious."],[7729,7883,"You work so hard,"],[7883,8095,"you deserve everything you get."],[8175,8354,"Okay, so I made dinner."],[8387,8491,"Let's go eat."],[8558,8704,"- Okay. - I know!"]],"27":[[504,608,"It's about time"],[608,729,"you came to your senses,"],[729,895,"and handed the shares over"],[895,991,"to my son."],[1116,1229,"And you make dinner."],[1250,1391,"It seems like things are finally"],[1391,1487,"getting back to normal"],[1487,1550,"around here."],[1633,1800,"Darling, what did you cook?"],[2012,2166,"Your son eats first."],[2166,2337,"I made this meal especially"],[2337,2445,"for him today."],[2466,2629,"And what about tomorrow?"],[2629,2750,"And the next day?"],[2770,2866,"You should resume"],[2866,3125,"all of your wifely duties from now on."],[3137,3379,"Oh, hell no, you meddling witch!"],[3412,3516,"We'll see."],[3516,3691,"Since I returned, every day"],[3691,3816,"is a new discovery."],[3954,4125,"I’m sure I’ll love whatever surprises"],[4125,4366,"my darling wife has in store for me."]],"28":[[366,483,"Elise!"],[529,787,"You gave me a heart attack."],[908,1070,"What is the meaning of this?"],[1108,1325,"Damien, we never mourned"],[1325,1408,"our babies."],[1408,1645,"And all Selene talks about having one."],[1645,1812,"I'm so sad."],[1866,1941,"Tell me,"],[2004,2166,"who killed our baby girls?"],[2229,2479,"Don't believe Selene's nonsense."],[2533,2812,"You had a miscarriage."],[2870,3004,"We can try again."],[3033,3175,"Really?"],[3233,3333,"Yes."],[3583,3691,"Martha,"],[3737,3854,"please take these dolls,"],[3854,3962,"and dispose of them."],[3962,4120,"Yes, Mr. Maxwell."],[4120,4254,"Thank you."],[4337,4441,"It's fine."],[4479,4608,"We'll have Martha whip something up"],[4608,4704,"for dinner."],[4895,5058,"I'm not feeling very well."],[5117,5195,"Why don't you all go ahead"],[5195,5276,"without me."],[5812,6033,"Is it just me, or does she seem"],[6033,6162,"like a different person?"],[6187,6416,"There's definitely something off"],[6416,6500,"with her."],[6550,6641,"No matter how much she's"],[6641,6708,"changed,"],[6750,6891,"she's still Elise Belmont."],[6920,7079,"She still loves me."],[7162,7316,"And I still need her."],[7337,7466,"I'm worried that..."],[7466,7629,"Don't worry, mother."],[7666,7750,"After the banquet,"],[7750,7866,"I will become the CEO,"],[7866,7983,"and Elise,"],[8054,8225,"will have no value."],[8262,8437,"And then you can divorce"],[8437,8587,"that toxic bitch."],[8620,8866,"And her fortune will be ours."],[8891,9037,"And if she keeps acting crazy,"],[9037,9195,"I'll have her institutionalized"],[9195,9245,"as well."],[9316,9475,"Even better!"],[10008,10120,"Little sister, it makes me sick"],[10120,10258,"thinking of you living with these"],[10258,10400,"monsters all these years."],[10408,10637,"They will pay. They will all pay."]],"29":[[262,491,"I haven't settled the score with you."],[491,691,"And you reached out to me first."],[691,958,"What are you up to?"],[1208,1341,"Why'd you invite me here?"],[1362,1512,"I said everything I needed to"],[1512,1695,"with that sign around your neck."],[1887,2070,"Elise, I..."],[2070,2275,"I needed to apologize,"],[2275,2408,"face to face."],[2433,2629,"Oh, really?"],[2783,2895,"I was lonely,"],[2945,3075,"but I was wrong to get in bed"],[3075,3208,"with Damien."],[3208,3375,"I feel so ashamed."],[3395,3550,"I mean, I want to die."],[3550,3645,"I know a good cliff"],[3645,3783,"you could throw yourself off of."],[4008,4095,"Just kidding."],[4300,4395,"I forgive you."],[4537,4645,"That easily?"],[4737,4820,"Sure."],[4866,5004,"On one condition,"],[5191,5329,"you tell me everything that"],[5329,5487,"happened that night at Lovers Point."]],"30":[[145,400,"You don't remember anything?"],[479,612,"Nothing."],[612,729,"My memory is blank."],[966,1079,"Don't worry."],[1079,1183,"I got you covered."],[1304,1466,"But first, a drink."],[1525,1704,"A toast to old friends."],[1875,2025,"You didn't poison it, did you?"],[2795,2862,"There."],[2929,3029,"Feel better?"],[4425,4516,"You want to know what happened"],[4516,4579,"that night?"],[4629,4737,"I want the truth."],[4845,5070,"The truth is that you shouldn't be alive."],[5083,5191,"So hurry up and die."],[5191,5337,"So me and my baby can live"],[5337,5516,"happily ever after with Damien."],[5575,5729,"you drugged my drink?"],[6229,6370,"I already killed you once."],[6379,6504,"You'd think you'd learn."],[6575,6770,"I knew you'd suspect your drink,"],[6862,7112,"so I drugged mine instead."],[7562,7737,"I need muscle."],[7737,7929,"Get me some of the nastiest"],[7929,8091,"motherfuckers you got."],[8370,8579,"Your obituary will read,"],[8579,8708,"Elise Belmont,"],[8708,8854,"was a dirty slut,"],[8958,9183,"who died in the dirtiest place."]],"31":[[270,487,"Elise Belmont,"],[620,841,"so beautiful,"],[841,979,"and rich."],[1045,1187,"Yet, you choose someone like me"],[1187,1345,"to be your best friend."],[1379,1550,"Am I supposed to be grateful?"],[1583,1741,"Well, fuck your pity."],[1775,1975,"Look who's pitiful now."],[2012,2308,"Begging for your life at Lovers Point."],[2412,2629,"Pathetic, and weak."],[2650,2879,"Pleading for your unborn child."],[2883,3029,"As if we'd regret killing it"],[3029,3125,"along with you."],[3325,3450,"The only thing I regret,"],[3570,3729,"is not climbing down that cliff"],[3729,3870,"to make sure you were dead."],[3983,4062,"But this time,"],[4062,4266,"oh, I'm going to enjoy"],[4337,4600,"watching you take your last breath."],[4800,4920,"I wouldn't count on that."],[4950,5100,"No, no. How?"],[5129,5275,"you're you're you're conscious."],[5275,5420,"I've been faking a drug induced coma"],[5420,5520,"this whole time."],[5591,5733,"But the wine."],[5837,5941,"Before you switched it,"],[5941,6075,"I had already beaten you to it."],[6341,6445,"Damien?"],[7308,7454,"And you had a few sips, so..."],[7500,7612,"It should be kicking in,"],[7612,7908,"right about now."],[8291,8400,"What do you want?"],[8441,8558,"What do you think?"]],"32":[[775,900,"What are you afraid of?"],[970,1137,"This is your plan, all along?"],[1258,1400,"Are you suggesting that,"],[1420,1570,"I'm behind an evil plot"],[1570,1700,"against my BFF?"],[1850,1962,"It was you"],[1962,2150,"who invited me for drinks,"],[2183,2379,"and it was you who brought me here."],[2433,2612,"I had nothing to do with any of that."],[2683,2883,"Or what happens next."],[2962,3087,"I need muscle."],[3137,3316,"Get me some of the nastiest"],[3316,3462,"motherfuckers you got."],[3595,3679,"You know what?"],[3679,3812,"You're going to regret this."],[3812,4016,"Damien is going to destroy you."],[4104,4229,"Damien?"],[4279,4475,"Damien doesn't care about you."],[4475,4650,"He only cares about himself."],[4666,4904,"But you'll find that out soon enough."],[5141,5420,"No, no, please, please,"],[5420,5483,"I'm begging you."],[5483,5591,"I'm begging you."],[5645,5804,"Not so weak and pathetic, now,"],[5804,5887,"are we?"],[5887,5987,"That you're the one begging?"],[6112,6250,"I bet you wish you could go back,"],[6250,6516,"and spare me and my unborn babies."],[6616,6716,"I'm sorry, Elise."],[6716,6825,"I'm sorry."],[6825,6883,"No, you're not,"],[6975,7054,"but you will be."],[7087,7200,"We were told there's only going"],[7200,7387,"to be one woman to work over."],[7454,7533,"I was just leaving."],[7575,7708,"Don't go, I was, I was wrong."],[7708,7850,"Did it to yourself, Selene."],[7879,7979,"Elise!"],[8079,8162,"Back off."],[8162,8241,"Back off."],[8291,8495,"I hired you, she's the target."],[8537,8608,"Nice try."],[8621,8720,"Your ass is in the chair."],[8720,8775,"Stop!"],[8783,8879,"You're supposed to hurt her!"],[8879,9020,"She's the one you're supposed to"],[9020,9095,"hurt!"],[9095,9204,"Nice try."],[9262,9400,"Your ass is in the chair."],[9625,9741,"Little sister,"],[9762,9925,"for the pain and anguish"],[9925,10029,"you've suffered."],[10054,10225,"She's now paying double."]],"33":[[529,775,"Our baby is gone."],[1020,1133,"What happened?"],[1195,1337,"They were supposed to torture"],[1337,1383,"Elise,"],[1383,1525,"but she tricked me,"],[1595,1779,"and switched places."],[2337,2475,"Fucking kill her."],[2533,2637,"Kill her!"],[2745,2883,"I won't."],[2912,3062,"You're talking nonsense."],[3300,3420,"The Chamber of Commerce"],[3420,3545,"banquet is tomorrow night."],[3608,3700,"Where, the Belmont Group,"],[3700,3875,"will sign a $10 billion"],[3875,4091,"land deal with Fitzroy Holdings."],[4150,4279,"Immediately afterwards,"],[4279,4558,"Elise will declare me as the CEO."],[4620,4912,"At that moment, the entire company"],[4912,5112,"will belong to me."],[5262,5433,"I need Elise."],[5637,5800,"I can't have her die yet."],[5800,6012,"You fucking asshole."],[6295,6500,"Like I've never heard that before."],[6550,6658,"Don't forget,"],[6720,7054,"you killed Elise's babies."],[7170,7320,"Now you're even."],[7458,7612,"It's your child too!"],[7612,7716,"It's your child."],[7716,7941,"It's so fucking disgusting."],[8016,8108,"Listen, Selene,"],[8108,8250,"if you need another baby,"],[8250,8450,"get some loser to knock you up."],[8483,8725,"I like the useful you."],[8737,8866,"Not this weak"],[8866,8929,"version."],[8945,9183,"You'll only drag me down, okay?"],[9183,9308,"Hey, look at me."],[9337,9629,"Get your shit together!"],[9725,9795,"Or,"],[9900,10041,"don't call me anymore."],[10050,10229,"Damien, Damien!"],[10312,10366,"No."]],"34":[[187,262,"Are you ready?"],[2066,2220,"It's not me."],[2429,2541,"Miss,"],[2608,2762,"your face was burned beyond"],[2762,2875,"recognition."],[2875,2995,"Even if God himself were"],[2995,3095,"in the operating room,"],[3095,3320,"there's simply no way to restore it."],[3387,3512,"What happened to me?"],[3570,3725,"You really don't remember?"],[3929,4070,"I know who I am."],[4070,4208,"but I don't know why"],[4208,4295,"I fell off that cliff,"],[4295,4470,"or how I got disfigured."],[4529,4654,"Well, that could be your brain's"],[4654,4875,"protective mechanism at work."],[4933,5120,"You're selectively forgetting painful"],[5120,5233,"memories."],[5316,5429,"Thank you, doctor."],[5554,5662,"So what are your plans?"],[5720,5866,"I'm going back to my life."],[5966,6112,"You'll be discharged in the morning."],[6441,6554,"Damien,"],[6579,6762,"I'm the real Elise Belmont."],[6829,6983,"She's an imposter."],[7100,7270,"I will find you."],[7558,7683,"Little sister,"],[7845,7966,"he took your kindness,"],[7966,8120,"and paid it with betrayal."],[8820,8970,"If only I would have been here"],[8970,9066,"to protect you."],[9204,9412,"That is a burden I'll take to the grave."],[9666,9787,"What the fuck are you doing?"]],"35":[[70,175,"What the fuck are you doing?"],[595,833,"Elise, darling."],[895,1070,"Is this about what Selene tried to do."],[1145,1220,"Or do you remember"],[1220,1270,"something?"],[1375,1445,"Why?"],[1587,1712,"Are you scared?"],[1754,1970,"I don't like this photo very much."],[2004,2116,"The look in your eyes says"],[2116,2245,"you don't love me."],[2425,2783,"Stop imagining things."],[3416,3600,"If you don't like the photo,"],[3716,3850,"we can take another one."],[3891,4008,"Okay, hubby."],[4137,4212,"Now,"],[4420,4637,"at this banquet tomorrow night."],[4745,4929,"Are you really going to declare me"],[4929,5145,"the Belmont Group's new CEO?"],[5196,5272,"Why?"],[5408,5579,"You don't want it anymore?"],[5708,5950,"Are you feeling guilty?"],[6650,6779,"Guilty?"],[6975,7237,"It's from my gorgeous wife."],[7383,7525,"Why would I feel guilty?"],[8079,8133,"What's wrong?"],[8283,8375,"I'm going to bed."],[8454,8554,"Sounds good to me."],[8766,8845,"Alone."],[9000,9108,"Gotta get some beauty sleep"],[9108,9312,"so I can shine on your arm tomorrow."]],"36":[[370,562,"Damien, I've come back to you."],[650,700,"Hey lady,"],[700,833,"you can't come in without a pass."],[891,1041,"The CEO doesn't need a pass."],[1062,1220,"Dennis it's me, Elise Belmont."],[1387,1525,"I've guarded this door for ten years."],[1562,1650,"You think I don't know what"],[1650,1770,"Ms. Belmont looks like?"],[1783,1929,"I had a terrible accident."],[1954,2162,"Plastic surgery changed my face."],[2191,2254,"Lady, you have quite"],[2254,2366,"an imagination."],[2404,2483,"If you're her,"],[2516,2583,"who is the Ms. Belmont"],[2583,2658,"I see every morning?"],[2658,2804,"I don't know, that's why you need to"],[2804,2954,"get into my office and figure it out."],[2954,3083,"You're crazy. Beat it!"],[3120,3200,"You have to believe!"],[3200,3225,"Hey!"],[3275,3316,"Leave!"],[3316,3462,"Or I'll remove you by my self."],[3712,3879,"I am Elise Belmont."],[3920,4029,"Who's the nutjob?"],[4041,4166,"She looks nothing like her."],[4166,4279,"Are they on drugs?"],[4295,4475,"The Elise Belmont you see everyday"],[4475,4625,"is a fake, a charlatan."],[4658,4829,"Dennis, get rid of this crazy wacko"],[4829,5000,"before the real Ms. Belmont arrives."],[5108,5183,"Go!"],[5266,5379,"Don't make me tell you again."],[5647,5716,"You're wrong."],[5716,5822,"I am the real"],[5825,5912,"Elise Belmont."],[7258,7362,"Damien!"]],"37":[[108,204,"Sorry, Mr. Maxwell,"],[254,291,"Ms. Belmont."],[366,433,"She’s just some lunatic"],[433,491,"who showed up."],[533,625,"I'll get out of here."],[845,937,"Come on, let's go."],[1029,1116,"Damien,"],[1116,1175,"wait."],[1787,1941,"I am, Elise Belmont,"],[1941,2108,"but no one recognizes me."],[2208,2308,"What do I do?"],[2312,2425,"You say you're Elise?"],[2608,2683,"Selene?"],[2779,2987,"Selene, it's me! It's Elise."],[2995,3083,"Yeah, right."],[3137,3233,"I don't think so."],[3287,3416,"We went to college together."],[3441,3575,"You asked me to have lunch with you"],[3575,3641,"after class."],[3670,3812,"You were the first person I told,"],[3812,3962,"when I fell in love with Damien."],[4050,4208,"My face is different because it was"],[4208,4370,"burnt, but it's still me."],[4458,4562,"The acid."],[4608,4775,"She couldn't know about the burn."],[4791,4887,"Unless..."],[5050,5216,"It really is you, Elise."]],"38":[[154,266,"Selene!"],[754,954,"I'm so happy to have you back."],[1000,1170,"I was so confused."],[1187,1320,"I woke up in the hospital,"],[1320,1487,"and had no idea how I got there."],[1550,1720,"And then Damien's out there"],[1720,1858,"with someone who looks like me."],[1895,2016,"Amnesia."],[2016,2212,"Oh, hell yes."],[2270,2450,"That woman is pure evil."],[2450,2608,"She's the enemy within."],[2608,2712,"What?"],[2762,2895,"Is Damien in danger?"],[2895,3145,"Not yet, but it's only a matter of time."],[3287,3400,"I have to do something,"],[3400,3641,"but he doesn't know my face."],[3641,3808,"No one recognizes me."],[4025,4133,"I have no idea."],[4208,4341,"The Chamber of Commerce is"],[4341,4445,"having a banquet tonight"],[4445,4529,"at the Marquis Hotel."],[4604,4825,"All of the city's elites will be there."],[4904,5000,"I can get you in,"],[5000,5133,"and then you can expose"],[5133,5508,"that conniving bitch once and for all."],[5608,5750,"In front of everybody?"],[5916,6125,"Elise, I'm your best friend."],[6125,6254,"Do you trust me?"],[6254,6383,"Of course I do."],[6529,6687,"Like a lamb to slaughter."],[6737,6837,"You definitely are"],[6837,7008,"the real Elise Belmont."],[7050,7266,"First, we'll get rid of your look-a-like."],[7304,7500,"Then I'll get rid of you."],[7570,7808,"Come, let's get ready for tonight!"]],"39":[[291,400,"Belmont’s royal couple"],[400,550,"has arrived."],[875,1070,"I can't wait to see the look on Elise’s face"],[1070,1220,"when she loses everything!"],[1237,1291,"On behalf of the"],[1291,1429,"Chamber of Commerce,"],[1429,1562,"I'm very, very pleased"],[1562,1658,"to host this banquet,"],[1741,1958,"welcoming Fitzroy Holdings"],[1958,2112,"the British conglomerate"],[2112,2258,"to our shores."],[2270,2337,"And"],[2408,2491,"I'd like to add"],[2570,2666,"that I've heard"],[2704,2779,"that today"],[2779,2925,"they will be signing"],[2925,3233,"a $10 billion agreement."],[3283,3479,"between Fitzroy Holdings,"],[3479,3620,"and the Belmont Group."],[4108,4204,"Mr. Brady,"],[4220,4520,"Ms. Belmont, please take the stage."],[4600,4795,"I have something to announce first."],[4866,5004,"Here we go, you greedy bastard,"],[5054,5258,"show your fucking hand!"]],"40":[[41,158,"For some time,"],[158,458,"my wife Elise, has been unwell."],[458,583,"She's never fully recovered,"],[583,854,"from her attempted suicide."],[854,1012,"One of her first destructive"],[1012,1170,"acts was the firing"],[1170,1337,"of the entire board of directors,"],[1337,1533,"after stealing their shares."],[1533,1741,"Elise Belmont is unfit"],[1741,1900,"to be CEO of Belmont!"],[1900,2041,"She'll destroy the company"],[2041,2154,"if she's not stopped."],[2291,2412,"God."],[2412,2558,"You're all whiny little bitches,"],[2558,2670,"who don't deserve to play"],[2670,2825,"in the big leagues."],[2845,2933,"Your actions didn't"],[2933,3175,"stop in the boardroom, Elise."],[3175,3270,"You've been terrorizing"],[3270,3429,"my mother, and sister"],[3429,3562,"with your crazy behavior."],[3583,3875,"She's been dabbling in the dark arts"],[3875,4083,"with voodoo baby dolls."],[4137,4379,"I'm scared to close my eyes at night."],[4412,4579,"Where is he going with this?"],[4579,4816,"I don't know, but I'm hooked."],[4845,5091,"It is with a heavy heart that I announce,"],[5091,5258,"Elise Belmont is no longer"],[5258,5483,"the CEO of Belmont Group."],[5500,5650,"I have used my shares"],[5650,5829,"to initiate a vote of no confidence."],[5829,6029,"And now I am the acting CEO."],[6158,6350,"As for our marriage,"],[6408,6491,"and for the physical"],[6491,6791,"and mental stability of my family,"],[6908,7041,"I want a divorce."]],"41":[[154,337,"I want a divorce."],[1204,1379,"Damien Maxwell,"],[1379,1541,"such a great man."],[1587,1795,"So selfless."],[1795,2095,"Always looking at the bigger picture."],[2095,2212,"Believe me, Elise,"],[2212,2425,"I take no pleasure in this."],[2425,2645,"Mother, the divorce papers."],[2800,2925,"Elise,"],[2925,3066,"we both know in our hearts"],[3066,3345,"this marriage was over a long time ago."],[3345,3575,"This will make it legal."],[3616,3737,"Well then,"],[3737,3883,"I'll sign it right away."],[3883,4095,"I hope you don't regret it, hubby."],[4258,4387,"You all bear witness,"],[4387,4558,"Elise Belmont and I,"],[4558,4858,"are legally ending our marriage."],[5329,5575,"This stupid girl signed."],[5575,5629,"Finally,"],[5629,5870,"my brother's free of that wretched woman."],[5941,6133,"He walked all right into the trap."],[6133,6362,"Now it's time to spring it."]],"42":[[0,145,"You all bear witness,"],[145,237,"Elise Belmont,"],[237,537,"and I have legally ended our marriage."],[750,1050,"Now that the Belmont Group belongs to me,"],[1104,1375,"effective immediately,"],[1375,1512,"I will be renaming it,"],[1550,1675,"the Maxwell Group."],[1720,1945,"Aren't we in a hurry?"],[2050,2170,"Open your mouth again,"],[2170,2275,"and I'll have security"],[2275,2412,"escort you out that door."],[2412,2554,"You think you've won?"],[2554,2745,"I know I have."],[2987,3145,"Pardon me for the delay."],[3145,3379,"Can we sign the Fitzroy contract now?"],[3379,3500,"Of course, Mr. Brady."],[3500,3616,"Mr. Maxwell."],[4670,4791,"After today,"],[4791,4970,"the business world,"],[4970,5137,"will have a new power player."],[5158,5466,"Damien Maxwell is going to soar."],[5466,5658,"There will be no stopping him."],[5754,5954,"Before I have you booted out of here,"],[5954,6154,"I would like you to witness exactly,"],[6154,6262,"what the Maxwell Group"],[6262,6395,"can achieve under my"],[6395,6591,"brilliant leadership."],[6645,6841,"Goodie, can’t wait."],[7754,7837,"Not so fast."],[7987,8162,"You can’t sign that contract."],[8200,8350,"The hell did you just say?"],[8350,8500,"We have a deal."],[8529,8683,"I will sue Fitzroy Holdings"],[8683,8762,"for breach of contract"],[8762,8870,"if you back out now."],[8870,8954,"Oh, you misunderstand,"],[8954,9079,"Maxwell."],[9095,9175,"It’s not that Fitzroy"],[9175,9329,"won't sign the contract."],[9345,9562,"It's that you can't sign."],[9562,9708,"The contract is between"],[9708,9862,"Fitzroy Holdings,"],[9870,10050,"and Ms. Elise Belmont."],[10079,10308,"And since you've just divorced her."],[10308,10445,"This is ridiculous."],[10445,10583,"We can amend the paperwork right now."],[10583,10691,"I'll do it myself."],[10691,10808,"Well, I'm afraid that"],[10808,10970,"with this change of leadership,"],[10970,11095,"we're no longer interested"],[11095,11258,"in doing business."],[11258,11358,"Looks like the divorce"],[11358,11475,"cost you 10 billion."]],"43":[[12,150,"You set me up."],[150,300,"Now, now, Damien,"],[300,533,"you were the one who asked for a divorce."],[533,741,"I had nothing to do with that."],[858,983,"Not so suave,"],[983,1270,"and in control now, are we, Damien?"],[1270,1458,"What do you want, Elise?"],[1458,1662,"Spell it the fuck out."],[1662,2004,"You on your knees in front of everyone"],[2066,2287,"begging for me to take you back."],[2362,2500,"Never."],[2525,2704,"I want to speak to your fucking boss."],[2704,2837,"Get me the president of Fitzroy Holdings"],[2837,2945,"here right now."],[2975,3066,"The terms in the contract"],[3066,3262,"couldn't be more clear."],[3300,3508,"This is a $10 billion deal,"],[3508,3775,"not some chicken shit project."],[3775,3862,"Well,"],[3862,3962,"the terms of the contract"],[3962,4175,"were drafted by the president,"],[4175,4291,"and Fitzroy Holdings"],[4291,4391,"Group is a global"],[4391,4691,"conglomerate worth $500 billion."],[4770,4945,"So I won't bother the president"],[4945,5087,"with something so"],[5162,5270,"trivial."],[5341,5570,"You're humiliating yourself, Damien."],[5570,5662,"Just give it up."],[5662,5883,"Admit it, you've lost."]],"44":[[283,358,"I get it."],[358,537,"You two are working together,"],[570,762,"corroborating against me."],[762,850,"You know what?"],[850,962,"I bet you two are fucking,"],[962,1041,"aren't you."],[1070,1245,"Adulterers!"],[1375,1533,"I knew Elise Belmont was a slut,"],[1533,1675,"as well as a thief."],[1700,1858,"When the president of Fitzroy Holdings"],[1858,2004,"finds out about this,"],[2004,2191,"they're both dead."],[2220,2412,"He has a fierce reputation,"],[2412,2558,"for no bullshit."],[2591,2695,"It's true."],[2695,2829,"Brady and I have known each other"],[2829,2950,"for some time now."],[2950,3133,"But it's not the relationship"],[3133,3254,"that you claim."],[3291,3479,"Of course you’d deny it, you skank!"],[3516,3691,"If you have nothing to hide,"],[3691,3783,"then call the president of"],[3783,4008,"Fitzroy Holdings here right now."],[4037,4216,"Are you sure you want that?"],[4241,4379,"Absolutely."],[4379,4562,"He'll see through both of your lies,"],[4562,4862,"and know that I'm the rightful CEO."],[4866,5025,"All right, then,"],[5066,5358,"president Fitzroy,"],[5358,5487,"please take a seat."]],"45":[[520,704,"Is this some kind of sick joke?"],[787,883,"You said you wanted to meet"],[883,1091,"the president of Fitzroy Holdings."],[1091,1212,"Now you have."],[1279,1454,"She's the president of a 500"],[1454,1675,"billion conglomerate?"],[1675,1812,"Looks like, Damien Maxwell"],[1812,1941,"dug his own grave."],[1941,2070,"That’s impossible!"],[2070,2287,"Get a hold of yourself, Maxwell."],[2287,2412,"She can't be president!"],[2412,2541,"You're both lying."],[2566,2770,"Stop this trickery, and"],[2770,2991,"get off the stage already!"],[2991,3095,"The Chamber of Commerce"],[3095,3229,"can vouch for me."],[3283,3429,"And I've personally done business"],[3429,3550,"with many of the companies"],[3550,3675,"in this room."],[3700,4000,"Now, since my identity is real"],[4029,4116,"then her identity"],[4116,4308,"as the president cannot be fake."],[4333,4612,"I’ve lived with Elise for 5 years."],[4625,4825,"How did she hide this from me?"],[4825,5125,"It can't be true, Damien."],[5137,5183,"Shut up, mother!"],[5183,5354,"Both of you."],[5437,5616,"You want to see me on my knees?"],[5616,5708,"I'll do it."],[5708,5841,"I would love that."]],"46":[[95,270,"Elise, your love was"],[270,383,"the one thing in this world"],[383,554,"that I could count on."],[554,833,"Please take me back"],[833,895,"and together,"],[895,1100,"we'll join forces and become a worldwide"],[1100,1204,"power couple."],[1333,1516,"I already have power."],[1658,1837,"The power to make you pay for murdering"],[1837,2029,"my twin sister."],[2433,2608,"I know what you did, Damien."],[2608,2791,"I know everything."],[2791,2991,"Down to the land and the stock options,"],[2991,3104,"you've been snatching up"],[3104,3250,"with privileged information"],[3250,3370,"from the Fitzroy Holding deal"],[3370,3666,"to line your pockets."],[3687,3987,"And now that the deal is gone,"],[4012,4066,"you're broke,"],[4066,4200,"Damien Maxwell."],[5191,5366,"Oh, what the fuck have you done?"],[5366,5487,"Me?"],[5487,5725,"You committed insider trading, hubby."],[5725,5895,"You're going to jail."],[5895,6041,"And we both know, it should be"],[6041,6279,"for attempted murder, as well."],[6279,6479,"Security!"],[6550,6712,"No, no."],[6712,7012,"No, you are not Elise Belmont!"],[7012,7195,"Elise Belmont is pure,"],[7195,7279,"and kind."],[7308,7479,"Yeah, and you used her kindness"],[7479,7645,"and took advantage of her."],[7645,7729,"You sicken me."],[7729,7858,"Security, take him away."],[7858,7950,"No."],[7995,8070,"Get off me!"],[8070,8200,"Let my husband go!"]],"47":[[312,420,"I am the real,"],[420,616,"Elise Belmont."],[800,966,"Little sister,"],[966,1133,"you're alive?"],[1762,1875,"It's been 20 years"],[1875,2054,"since I last saw you,"],[2054,2208,"and your face has changed,"],[2208,2462,"but I'd recognize you anywhere."],[2462,2579,"My twin."],[2579,2775,"Born from the same egg."],[2775,2962,"Do you take us for fools?"],[2962,3100,"You look nothing like her."],[3100,3400,"Elise Belmont is right there!"],[3429,3758,"That woman on stage is not Elise Belmont."],[3854,4054,"She's a fraud."],[4054,4329,"You said you're Elise Belmont."],[4329,4475,"Do you have any evidence?"],[4537,4641,"On our wedding day,"],[4641,4825,"my father, James Belmont,"],[4825,4975,"presented us with matching"],[4975,5125,"wedding bands."],[5133,5287,"They are priceless"],[5287,5533,"and worn by medieval royals in the past."],[5533,5654,"There are no other rings"],[5654,5795,"like them in the world."],[5795,5908,"The male wedding ring,"],[5908,6070,"is on Damien's finger,"],[6070,6216,"and the female wedding ring."]],"48":[[79,379,"Get off me!"],[637,833,"Could the ring be stolen?"],[875,979,"This is the first time"],[979,1279,"I've taken my ring off, in five years."],[1400,1591,"This ring has a special texture,"],[1591,1687,"and from the sun"],[1687,1787,"mark on my finger,"],[1787,1866,"you can tell it's"],[1866,2079,"been on my finger this whole time."],[2079,2258,"No matter how I look at you,"],[2258,2429,"you don't have Elise Belmont's face."],[2429,2708,"This Elise does, compared to a ring,"],[2708,2850,"we trust the face more."],[2850,3150,"I hope you have more conclusive evidence."],[3175,3350,"Of course."],[3350,3500,"I've prepared this."],[3583,3883,"This as a parent child DNA report,"],[3941,4075,"with a hairbrush provided"],[4075,4375,"to us by Elise’s former nursemaid, Martha."],[4395,4612,"We're able to prove without a doubt,"],[4612,4716,"that the woman standing"],[4716,4829,"next to me is indeed"],[4829,5054,"James Belmont's daughter."],[5054,5216,"It's really you,"],[5216,5516,"little sister."],[5566,5808,"You really are Elise Belmont."],[5808,5937,"Damien, my love."],[6154,6337,"How much do you remember?"],[6370,6462,"What?"],[6641,6791,"But if you are Elise,"],[6791,7016,"what happened to your face?"],[7054,7250,"You need to ask this woman."]],"49":[[662,812,"You need to ask this woman."],[812,900,"Me?"],[950,1029,"This is all"],[1029,1179,"because of you."],[1529,1712,"I don't understand."],[1712,1891,"You ruined her face."],[1891,2033,"And then you tried to kill her,"],[2033,2212,"by throwing her off a cliff."],[2883,3025,"And then got a plastic surgeon"],[3025,3262,"to copy my face, to pretend to be me?"],[3262,3358,"Excellent,"],[3358,3612,"Elise’s amnesia buys me time."],[3612,3779,"If she starts to remember,"],[3779,3941,"I'll just kill her again."],[4016,4175,"Elise, you can’t listen to anything,"],[4175,4358,"Damien, or Selene say to you."],[4395,4562,"I'm so sorry, darling."],[4562,4770,"I didn't protect you well."],[4770,4979,"Let her go!"],[5066,5279,"You, have no place here."],[5279,5450,"It's you who are the criminal now."]],"50":[[58,266,"Let her go."],[354,566,"You, have no place here."],[566,791,"It's you who are the criminal now."],[816,933,"You pretended to be me,"],[933,1162,"to get close to Damien, for what?"],[1212,1525,"Oh, so you're my sweet daughter in law."],[1575,1850,"You have no idea how miserably"],[1850,2216,"I've been treated by that lying witch."],[2266,2466,"How dare you hurt my family?"],[2466,2708,"They're not your family, I am."],[2754,2925,"Let me explain."],[2991,3183,"Explain what?"],[3183,3295,"That you set a trap"],[3295,3566,"to try to ruin her husband's reputation,"],[3566,3795,"and send him to jail?"],[3883,4058,"Damien, did she hurt you?"],[4091,4229,"I'm all right."],[4229,4500,"It's a shame I was deceived by her face."],[4500,4695,"I didn't want to divorce you, but"],[4887,5012,"you weren't the woman I married"],[5012,5116,"anymore."],[5137,5258,"Divorce?"]],"51":[[20,266,"Divorce?"],[266,504,"You divorced my husband in my place."],[504,604,"How could you do that?"],[637,800,"It was for your own good."],[800,1004,"Does the divorce even count,"],[1004,1162,"if Elise didn't sign it?"],[1162,1375,"My mother's right. In the eyes of the law,"],[1375,1575,"we're still married."],[1575,1758,"You've won nothing, bitch."],[1758,1958,"Since the divorce is invalid,"],[1958,2091,"the share transfer agreement"],[2091,2391,"I signed as Elise, is also invalid."],[2425,2550,"What do you mean?"],[2550,2708,"The Belmont Group is no longer"],[2708,2858,"the Maxwell Group."],[2858,3091,"You're not the CEO."],[3091,3379,"Maxwell Group?"],[3379,3491,"Elise, don't blame me."],[3491,3554,"I-"],[3604,3775,"I wanted to give the company a new face."],[3775,3958,"lift it bigger, and better."],[3958,4033,"I understand,"],[4033,4204,"but you promised my father"],[4204,4408,"you'd keep the Belmont Group going."],[4408,4537,"You're right."],[4537,4637,"I lost sight of that"],[4637,4808,"with you gone, and this impostor"],[4808,4895,"in your place."],[4970,5108,"Oh you're good."],[5108,5237,"How dare you!"],[5237,5341,"It's okay,"],[5341,5491,"as the heiress to the Belmont Group,"],[5491,5608,"I'll re-sign the shares and"],[5608,5729,"hand the company over to you."],[5850,5979,"Really?"],[5979,6220,"What's mine is yours."],[6220,6379,"Thank you, darling."],[6437,6591,"I won't allow it."],[6654,6891,"There's nothing you can do to stop it."],[6891,7041,"Yes, I can,"],[7041,7145,"because I'm also the"],[7145,7279,"heiress to the Belmont Group."]],"52":[[0,116,"What did you say?"],[208,316,"I'm also,"],[316,579,"the heiress to the Belmont Group."],[579,716,"So any share transfer"],[716,950,"agreements have to go through me first."],[950,1220,"What the fuck is happening?"],[1233,1387,"Lies!"],[1387,1675,"What more chaos do you plan to cause?"],[1675,1825,"Who the hell do you think you are?"],[1825,1958,"Why are you doing this?"],[1958,2079,"What do you want?"],[2100,2316,"Nothing Elise,"],[2316,2616,"I'm doing this for you."],[2616,2754,"Elise it's me,"],[2754,3116,"it's Erin."],[3383,3533,"Big sister?"],[3675,3895,"Little sister."],[4629,4791,"This face, it makes sense."],[4791,4945,"But I thought you moved to London,"],[4945,5112,"and were never coming back."],[5112,5250,"Dad said that."],[5250,5487,"But mom passed away this year,"],[5487,5541,"like dad."],[5541,5704,"She said her biggest regret"],[5704,5866,"was not seeing you again."],[5866,6133,"Dad regretted not seeing you again, too."],[6133,6345,"But why didn't you come earlier?"],[6420,6620,"I'm so sorry I tried,"],[6620,6750,"but when I came back,"],[6750,6908,"you were already missing."],[6954,7208,"I'm so sorry Elise."],[7208,7400,"I'm so sorry."]],"53":[[712,937,"Elise, so this is?"],[937,1150,"Erin, my twin sister."],[1320,1466,"Twins."],[1575,1675,"Of course."],[1675,1862,"We haven't seen each other in 20 years."],[1862,2016,"But you're back now."],[2016,2095,"Elise,"],[2095,2375,"even if this is your real sister,"],[2375,2650,"she made a real mess of things."],[2650,2770,"What about the shares"],[2770,2929,"of the Belmont Group?"],[2929,3195,"What will happen to my son?"],[3195,3391,"Before my father passed away, he'd"],[3391,3466,"written in his will"],[3466,3600,"that my sister got shares in the company."],[3600,3720,"company."],[3745,3866,"I didn't think she was coming back."],[3866,4016,"So I didn't tell you?"],[4016,4200,"Stupid girl."],[4200,4366,"You should never have kept"],[4366,4537,"that from Damien and me."],[4537,4737,"That's enough Karen."],[4737,4833,"Your bully tactics"],[4833,5037,"will no longer work in this family."],[5037,5279,"Erin, that is my mother-in-law."],[5416,5608,"Has she ever treated you like a"],[5608,5725,"daughter-in-law?"],[5729,5800,"Big sister."],[5800,5916,"You must have misunderstood"],[5916,6037,"something."],[6054,6216,"So you really are."],[6216,6333,"Erin Fitzroy,"],[6333,6529,"President of Fitzroy Holdings."],[6587,6741,"Right."],[6741,6916,"Well, I'll call you Erin,"],[6916,7216,"since we are relatives after all."],[7245,7520,"But if you do anything to harm Elise."],[7520,7612,"Like, throw her off a"],[7612,7750,"cliff after you burned her."]],"54":[[58,212,"Right."],[212,291,"Well, I'll"],[291,387,"Well, I'll call you Erin,"],[387,687,"since we are relatives after all."],[716,991,"But if you do anything to harm Elise."],[991,1120,"Like, throw her off a cliff"],[1120,1420,"after you burned her."],[1445,1704,"Erin, what are you talking about?"],[1716,1879,"Think about it, Elise?"],[1879,2083,"Who benefits from your death?"],[2200,2362,"Damien would never hurt me."],[2462,2583,"Oh little sister,"],[2583,2725,"open up your eyes."],[2725,2850,"These two basically told me,"],[2850,2991,"that they plotted your death."],[3045,3337,"Elise is my best friend."],[3337,3483,"Why would I hurt her?"],[3625,3733,"You're the violent one."],[3733,3908,"You caused me to miscarry."],[3937,4062,"You were pregnant?"],[4062,4145,"Who's the father?"],[4604,4816,"You don't know him."],[4816,4950,"But wait a couple days,"],[4950,5229,"and I'll present him to you."],[5287,5395,"Elise,"],[5395,5525,"these two are consummate liars."],[5525,5633,"You can't trust a word that"],[5633,5787,"comes out of their mouth."]],"55":[[45,316,"Sis, I'm really happy to see you again."],[316,525,"But I'm sorry."],[554,700,"Elise, no."],[812,1016,"Erin, I haven't seen you in 20 years."],[1016,1112,"And the minute you arrive,"],[1112,1283,"you want me to turn my back on my family"],[1283,1425,"and friends?"],[1425,1600,"I can't do it."],[1600,1758,"And as for my murderer, well,"],[1758,1991,"I'll look into it with Damien."],[1991,2070,"I believe that"],[2070,2133,"whatever happened"],[2133,2237,"will come to light."],[2237,2383,"Right."],[2383,2595,"We'll find the murderer together."],[2608,2687,"I'm tired."],[2687,2883,"Can we go home, hubby?"],[2945,3141,"Absolutely."],[3433,3600,"The insider trading charges."],[3704,3966,"You could send Maxwell to jail."],[3966,4204,"That would only alienate her more."],[4204,4329,"I just got my sister back."],[4329,4583,"I can't lose her again."],[4583,4725,"You might anyway."]],"56":[[354,520,"For five years, I've worn"],[520,729,"the mask of a loving husband."],[820,1062,"And I sucked up to Elise’s arrogant dad,"],[1062,1270,"until I poisoned him."],[1270,1570,"Erin Fitzroy, will meet a similar fate."],[1629,1854,"Nothing will stand in my way."],[2237,2450,"What way is that, hubby?"],[2900,3033,"I love you Elise."],[3062,3266,"Nothing will ever keep us apart."],[3283,3462,"Do you really mean that Damien?"],[3504,3683,"I know my face isn't the same."],[3683,3929,"I'm not the Elise Belmont I used to be."],[3929,4125,"Oh, I don't mind."],[4125,4370,"I never loved you for your face."],[4370,4579,"I loved your status and money."],[4579,4750,"You stupid bitch."],[5166,5466,"Did my sister cut the portrait?"],[5516,5716,"She wants to tear us apart."],[5795,5950,"I promise,"],[5950,6075,"I won't let her."],[6750,6925,"Who's calling you so late?"]],"57":[[4,195,"Who's calling you so late?"],[195,400,"It's just work."],[400,700,"Don't wait up for me, okay?"],[833,941,"Then why do I feel as"],[941,1087,"though something's wrong?"],[1691,1825,"What were you thinking?"],[1825,1937,"Calling me when you knew"],[1937,2066,"I was with Elise?"],[2066,2200,"I want to be your deadliest"],[2200,2354,"weapon, Damien."],[2354,2583,"Use me however you want."],[2583,2708,"Just don't leave me."],[2708,3008,"Stop acting so damn needy."],[3008,3062,"I brought"],[3062,3233,"Elise to the banquet tonight."],[3233,3350,"I helped you."],[3350,3545,"You also knew she was alive,"],[3545,3695,"and said nothing."],[3695,3825,"You let me walk into that room"],[3825,4116,"blind, humiliated in front of everyone."],[4116,4408,"I'm sorry, Damien, but I didn't think"],[4408,4708,"that Erin Fitzroy was that vicious."],[4720,4929,"We can fight her together,"],[4929,5066,"and have another baby."],[5320,5558,"You think I'd touch you again?"],[5558,5850,"You're fucking dirty now."],[5850,5987,"What did you say?"],[6204,6366,"Two men."],[6366,6495,"Two."],[6495,6716,"You set the trap for Erin,"],[6716,6895,"but you fell in it."],[6895,7029,"Not only are you fucking dirty,"],[7029,7287,"you're dumb as wood."],[7608,7908,"I did everything for you, Damien."],[7966,8145,"I don't need you anymore."],[8145,8291,"You can't get rid of me."],[8291,8354,"I promised"],[8354,8525,"Elise I would introduce her to my man."],[8525,8629,"Should I maybe."],[8629,8900,"Should I do that right now?"],[8900,9025,"I dare you to try."]],"58":[[162,379,"Why do you have that bitches number?"],[379,629,"I never trusted you."],[629,904,"I needed a way out."],[904,1041,"Imagine,"],[1041,1204,"what if Erin had proof"],[1204,1395,"of all your crimes."],[1395,1537,"How quickly she would tell her"],[1537,1766,"little sister."],[1795,1979,"You said you loved me."],[1979,2208,"I'm no Elise."],[2208,2508,"I love myself more."],[2754,2966,"Sorry, Selene."],[2966,3225,"I also love myself more."],[3541,3750,"Why isn't Selene Dixion answering?"],[3750,3870,"She knows better than anyone."],[3870,4020,"Damien is too dangerous to double cross."],[4212,4241,"And she"],[4241,4470,"still reached out to me for a deal."],[4620,4791,"What if she's bluffing?"]],"59":[[775,975,"Finally someone stays dead,"],[975,1095,"like they're supposed to."],[1133,1275,"Selene."],[1416,1612,"Elise."],[1612,1666,"What's gone,"],[1666,1762,"is gone."],[1862,2033,"Selene! Get up!"],[2033,2170,"Aren't you going to introduce me"],[2170,2254,"to your man?"],[2320,2516,"You can't break your promise."],[2816,3008,"Elise,"],[3008,3166,"you must soldier on."],[3166,3316,"She's my best friend."],[3316,3525,"We just saw each other last night."],[3545,3654,"Selene definitely"],[3654,3900,"would not want to see you like this."],[4079,4216,"Okay."],[4245,4350,"Okay."],[4383,4450,"Okay."],[4450,4537,"If you need to cry"],[4537,4700,"just let it out."],[4866,4979,"Hey."],[5350,5420,"The police will get"],[5420,5650,"to the bottom of this. Okay."],[5650,5837,"Let them do their job."],[6029,6158,"Officer,"],[6158,6279,"what exactly happened"],[6279,6420,"to my friend?"],[6487,6650,"The body was found at the bottom"],[6650,6933,"of Lovers Point this morning."],[6933,7012,"The autopsy showed"],[7012,7262,"significant signs of struggle."],[7395,7504,"We suspect that she was"],[7504,7804,"pushed off the cliff to her death."],[7866,8154,"Lovers point... Fell to her death?"],[8245,8525,"That son of a bitch is so cocky."],[8525,8779,"He returned to the scene of his crime."],[8779,8916,"It's all my fault."],[8916,9145,"This unknown killer was trying to get me."],[9145,9291,"Selene was caught in the crossfire."],[9291,9450,"She was an innocent victim."],[9475,9529,"Elise,"],[9558,9750,"how many times do I have to tell you?"],[9750,9966,"There is no unknown killer?"],[9966,10104,"Everything that happened to you"],[10104,10320,"was orchestrated by Damien Maxwell,"],[10320,10445,"and Selene Dixon."],[10445,10529,"Selene dying,"],[10529,10725,"is Damien just-"],[10725,10950,"Erin stop, just stop."]],"60":[[29,225,"Elise, please listen to me."],[283,441,"Selene was my best friend,"],[441,566,"and now she's dead."],[566,729,"How can you be so cruel?"],[754,891,"Hey, your sister's"],[891,1033,"just trying to cover her tracks."],[1033,1208,"Elise, as your best friend"],[1208,1404,"Selene was a threat to her."],[1404,1579,"Now Erin can just swoop in"],[1579,1775,"with the big sister routine."],[1775,1895,"Okay, Damien,"],[1895,2091,"that's pathetic, even for you."],[2091,2258,"Erin, I don't expect you to blend"],[2258,2408,"into my world overnight,"],[2408,2595,"but I do hope you'll treat my husband,"],[2595,2900,"and friends with respect."],[2987,3079,"Elise,"],[3079,3287,"you are blinded by love,"],[3287,3545,"and you're going to regret it one day."],[3741,3816,"I have an update"],[3816,3987,"about the suspect."],[4158,4441,"Did I leave any evidence behind?"],[4441,4662,"Please go ahead officer."],[4700,4837,"We retrieved the victim's"],[4837,5041,"last phone call, and this is the number."],[7083,7141,"Erin?"],[7141,7283,"It wasn't me."],[7283,7445,"Elise, you have to believe me."],[7445,7562,"Please."],[7587,7750,"First you pretend to be me,"],[7750,8050,"and bully Selene."],[8062,8270,"Then you call her a murderer,"],[8270,8479,"and even say she deserves to be dead."],[8479,8679,"Every lead points to you."],[8679,8829,"How can I trust you?"],[8829,9050,"Wait a minute. It was just a phone call."],[9050,9312,"Let's not jump to conclusions."],[9312,9566,"In fact, there is other evidence."],[9595,9791,"Well, whatever it is, show us now."],[9791,10058,"So the murderer has nowhere to hide."],[10412,10662,"This."],[11058,11270,"You recognize this ring?"],[11270,11454,"Damian, that's your wedding ring."],[11454,11629,"Elise, listen to me."],[11629,11775,"Mr. Maxwell."],[11775,11925,"Why was your wedding ring,"],[11925,12141,"found on the victim?"],[12479,12629,"Damien Maxwell,"],[12629,12791,"you're finished."]],"61":[[200,408,"The night the banquet ended, Selene"],[408,500,"took the ring."],[583,662,"Why?"],[662,783,"Because she and her fiancé"],[783,954,"were getting married soon."],[954,1083,"So she wanted to borrow it"],[1083,1295,"in order to design a similar style."],[1295,1554,"Hey, it's tragic."],[1554,1737,"The wedding was just around the corner."],[1737,1820,"Elise,"],[1820,2104,"the man that she was fucking was him."],[2104,2275,"Damien?"],[2275,2445,"I'm sorry, Elise."],[2445,2579,"Before I let her borrow the ring,"],[2579,2833,"I should have got your opinion first."],[2833,3025,"It's okay. I don't mind."],[3025,3295,"Elise, this story is ridiculous."],[3295,3425,"You can't believe him."],[3425,3529,"I love him,"],[3529,3654,"Erin."],[3654,3779,"Maybe"],[3779,4041,"when you fall in love, you'll understand."],[4116,4212,"Okay, folks,"],[4212,4437,"save your family drama for home."],[4437,4570,"The cell phone and the ring"],[4570,4700,"are now evidence."],[4700,4791,"You'll get them back,"],[4791,4941,"when the case is closed."],[4941,5162,"Thank you officer."],[5233,5354,"Let's go, darling."],[5608,5787,"I need to open up Elise's eyes to the"],[5787,5958,"two timing rat that he is."]],"62":[[229,404,"Elise Belmont"],[404,616,"does whatever she's told."],[616,704,"The real issue"],[704,945,"is how to get rid of Erin Fitzroy."],[1166,1295,"I'm so sorry Mr. Maxwell."],[1312,1470,"I couldn't stop her."],[1533,1729,"Not many can, Maureen."],[1729,1825,"You can go."],[2204,2416,"To what do I owe the displeasure?"],[2695,2812,"How long do you think"],[2812,2962,"you can keep up this act?"],[3158,3404,"Well, let's see, it's been about what?"],[3404,3529,"Five years?"],[3529,3787,"So I'm thinking,"],[3787,4012,"however long I fucking want."],[4075,4300,"How much will it take to get rid of you?"],[4300,4429,"1 billion?"],[4429,4575,"2?"],[4575,4683,"10?"],[4891,4954,"You don't have that"],[4954,5125,"kind of disposable income."],[5262,5395,"Try me."],[5500,5604,"I wonder what would’ve happened if"],[5604,5833,"I’d met the older twin first?"],[5979,6250,"I would have cut your"],[6250,6362,"dick off."],[6608,6779,"So do we have a deal?"],[6808,6962,"10 billion dollars and you’ll leave"],[6962,7195,"Elise’s life for good?"],[7391,7754,"Such sisterly devotion."],[7783,7933,"Take the deal, Damien."],[7933,8175,"Get out while you still can."],[8262,8466,"You can't make your mark on this world"],[8466,8583,"by playing it safe."],[8904,9062,"No deal."]],"63":[[62,250,"You're not going to sign a 10 Billion dollar"],[250,383,"contract?"],[662,1004,"You see, I take calculated risks."],[1204,1466,"And you Erin Fitzroy,"],[1466,1733,"you're a fucking black hole."],[1733,1862,"I'd rather take my chances"],[1862,2129,"with your sweet and malleable sister."],[2258,2458,"Careful, Damien."],[2458,2754,"Or you'll end up like your gambler daddy."],[2754,2850,"Isn't it true?"],[2850,3050,"you saw him jump from the 40th floor"],[3050,3262,"and go splat all over the pavement"],[3262,3516,"in front of you?"],[3695,3887,"What the fuck did you just say?"],[3966,4166,"You heard me,"],[4166,4433,"and he risked all your family's money"],[4433,4600,"and left you with nothing."],[5045,5133,"One more body"],[5133,5308,"won't make a damn difference to me."],[5370,5525,"Loser!"],[5525,5762,"Go to hell, you fucking bitch!"],[5762,5962,"Damien?!"],[5962,6020,"Elise?!!"],[6020,6166,"What? What are you doing?"]],"64":[[16,108,"Elise?!"],[108,325,"What are you doing?"],[458,604,"Damien what are you doing?"],[604,687,"No! Elise!"],[687,945,"Are you out of your god damn mind?"],[945,1050,"Damien."],[1112,1308,"Isn't it true"],[1308,1441,"that you promised me"],[1441,1562,"once I made you the president of"],[1562,1633,"of Fitzroy Holdings"],[1633,1833,"that you'd leave Elise for good."],[1862,2004,"Is that true?"],[2004,2187,"No that's a lie."],[2187,2354,"Erin, you set me up."],[2354,2450,"Really?"],[2450,2758,"How exactly does a grown-ass man"],[2758,2937,"put his hands around my neck?"],[2937,3079,"Oh, you conniving"],[3079,3200,"fucking little Cun-"],[3200,3325,"Little sister."],[3325,3420,"Look at this."],[3420,3587,"You have to pay attention to the signs"],[3587,3675,"of what's going on?"],[3675,3854,"Damien is a man who will sell his soul"],[3854,4050,"for money and power."],[4050,4179,"Elise, let me explain."],[4179,4416,"Don't touch me! She's my sister."],[4416,4583,"What are you doing?"],[4583,4716,"It's not what it looks like."],[4716,4812,"Then tell me why"],[4812,5016,"my sister is trying to steal my husband."],[5016,5162,"I'm not stealing him."],[5162,5320,"I am exposing him."],[5320,5487,"Shut the fuck up!"],[5741,5929,"Elise, please"],[6000,6095,"don't go."],[6141,6245,"Elise."],[6245,6345,"It's not what you think."],[6345,6575,"Elise!"],[6575,6766,"Oh, fuck."],[6954,7166,"You fucking played me."],[7216,7487,"I protected my sister."],[7508,7808,"I came all this way."],[7912,8100,"I won't give up now."]],"65":[[320,529,"Oh, little sister,"],[529,641,"how can I save you?"],[641,941,"when you won't save yourself?"],[1045,1245,"Ms. Fitzroy."],[1695,1887,"Is this from Elise?"],[1962,2075,"Yes."],[2125,2283,"She and Maxwell are hosting a party"],[2283,2483,"tomorrow evening."],[2520,2658,"To renew their vows."],[2891,3070,"We should head back to London."],[3100,3229,"Your sister has made it perfectly"],[3229,3387,"clear that she won't leave him."],[3441,3620,"I can't abandon her."],[3645,3875,"I won't abandon her again."],[3929,4108,"When I was little, I had no choice."],[4225,4450,"Don't leave me Erin."],[5012,5266,"But I'm not a helpless kid anymore."],[5312,5458,"We're going to that party."]],"66":[[179,462,"Dad, thank you for the wedding ring,"],[462,641,"but a lot of terrible"],[641,795,"things have happened recently."],[795,937,"And,"],[937,1233,"I need a fresh start with Damien."],[1233,1400,"Tonight, he's going to present me"],[1400,1633,"with the new ring he designed for me."],[1745,2000,"Everything's going to be okay."],[2062,2158,"Miss,"],[2233,2375,"do you remember on the day"],[2375,2591,"you got married, five years ago?"],[2616,2804,"It's also me that brushed your hair."],[2804,2983,"Of course I remember."],[2983,3116,"You're the best."],[3216,3433,"And back then, your father was on board"],[3433,3637,"with you marrying Mr. Maxwell."],[3637,3729,"But,"],[3779,3983,"I had my doubts."],[4079,4325,"I heard rumors that Mr. Damien"],[4325,4479,"was mean to the help,"],[4479,4779,"and I didn't speak up."],[4812,5087,"Martha, what are you trying to say?"],[5087,5262,"Ms. Erin opened my eyes to"],[5262,5429,"Mr. Damien's ways,"],[5462,5612,"and I can't unsee them."],[5612,5783,"She's just trying to protect me,"],[5783,5966,"but, she's wrong about him."],[5966,6120,"He lied Ms. Elise,"],[6266,6400,"Mr. Damien was wearing his"],[6400,6483,"wedding ring"],[6483,6641,"when he came home from the banquet."]],"67":[[58,212,"Mr. Damien was wearing his"],[212,275,"wedding ring,"],[275,495,"when he came home from the banquet."],[645,833,"Do you really mean it, Damien?"],[900,1116,"I know my face isn't the same."],[1116,1245,"I'm not the Elise Belmont"],[1245,1400,"I used to be."],[1400,1558,"Why would I mind?"],[1625,1850,"I never married you for your face."],[2545,2733,"Oh, my God, Martha,"],[2733,2883,"he didn't give the ring to Selene"],[2883,2987,"at the banquet?"],[3075,3241,"No, Ms. Elise."],[3295,3425,"Oh, my God."],[3479,3625,"He was wearing the ring"],[3625,3758,"when he left that night,"],[3758,3900,"after the call."],[3979,4279,"The night, Selene was murdered, and,"],[4304,4458,"and when he came back it was gone."],[4458,4595,"I'm gonna be sick."],[6295,6504,"Twins."],[6504,6600,"I can't wait to tell your"],[6600,6745,"daddy about it."],[6937,7233,"Then I'm going to call aunt Erin."],[7233,7533,"I need my big sister right now."],[7625,7779,"It's time for you to die,"],[7779,7854,"Elise."],[8195,8308,"Elise!"],[8383,8504,"What happened?"]],"68":[[125,287,"What happened?"],[495,600,"What's wrong?"],[850,1008,"I'm so silly."],[1008,1216,"I tripped on the hem of my dress."],[1216,1400,"It must be wedding nerves."],[1433,1529,"Darling, you do know"],[1529,1658,"we're already married?"],[1658,1870,"Yes, I'm very aware of that."],[1937,2183,"I need to finish my makeup."],[2183,2283,"Now shoo!"],[2408,2691,"Okay, okay, but don't take too long."],[2691,2875,"Everyone has arrived."],[4162,4320,"I wasn't sure you'd come."],[4483,4604,"Just because I'm here doesn't mean"],[4604,4808,"I support your marriage to my sister."],[4925,4987,"It doesn't matter"],[4987,5154,"what you believe, matters"],[5154,5308,"what Elise believes."],[5308,5608,"And she believes in me."],[5629,5900,"Where is my sister?"],[5900,6054,"Mr. Damien?"]],"69":[[33,75,"What now?"],[75,170,"Martha,"],[170,400,"the caterer needs you in the kitchen."],[591,720,"What happened to servants being seen"],[720,845,"and not heard?"],[845,975,"That's supposed to be about children,"],[975,1191,"but it's still an asshole thing to say."],[1191,1325,"Whatever."],[1325,1483,"Mr. Damien!"],[1895,2025,"Don't drink that."],[2025,2233,"I saw Damien put something in it."],[2233,2287,"Oh, my God,"],[2287,2370,"he was going to poison me"],[2370,2616,"in the middle of the party."],[2616,2741,"Not that you believe me."],[2741,3000,"I do believe you."],[3091,3270,"I remember Erin."],[3270,3412,"You were right,"],[3458,3683,"about everything."],[3683,3920,"I'm so sorry, Elise."],[3920,4125,"I should have been here to protect you."],[4175,4395,"You're here now, big sister."],[4508,4637,"I'm hopeless."],[4637,4895,"But you never gave up on me."],[4895,5050,"And I never will."],[5187,5262,"If you're afraid, I have a"],[5262,5362,"getaway car outside."],[5362,5533,"We can go right now."],[5533,5683,"No."],[5683,5775,"I'm going to finish this"],[5775,5933,"farce of a marriage ceremony."],[6029,6162,"Elise."],[6162,6329,"Erin, please"],[6375,6558,"just be there for me."],[6558,6612,"You got it."]],"70":[[383,562,"Thank you all for coming."],[654,804,"Excuse me."],[966,1170,"Now, I'm sure you all know my wife,"],[1170,1445,"Elise, has"],[1445,1745,"had a terrible accident sometime ago."],[1800,1958,"However, she's now here with me now."],[1958,2166,"And is beautiful as ever."],[2225,2379,"I'd like to take this opportunity"],[2379,2604,"to propose to my wife again."],[2995,3087,"Darling."],[3087,3212,"The second time around,"],[3212,3533,"I promise to love and cherish you."],[3591,3808,"Honor, and protect you."],[3808,4008,"Forsaking all others"],[4079,4275,"till death do us part."],[4425,4550,"A toast."],[4550,4729,"As I say, my vows."],[4908,5208,"To a marriage like no other."],[5237,5341,"Drink to that."],[5741,5808,"Oh, yeah."]],"71":[[200,300,"Oh yeah."],[466,629,"This second time around,"],[629,916,"I promise to face the past,"],[916,1079,"no matter how painful."],[1079,1262,"To stand for the truth"],[1304,1400,"and believe in myself,"],[1400,1612,"as forces rally against me."],[1712,1920,"What kind of wedding vows are those?"],[2033,2300,"The only kind you deserve."],[2383,2545,"I hope you enjoyed the wine."],[2545,2625,"That was the glass"],[2625,2779,"you gave my big sister."],[3083,3183,"For the first time"],[3183,3375,"in five years of marriage."],[3375,3545,"I guessed correctly your thoughts,"],[3545,3770,"hubby."],[3770,3929,"What kind of poison did you put in it?"],[3929,4125,"Fast or slow acting?"],[4341,4462,"Slow,"],[4512,4683,"fuck."],[4766,4929,"Painful, I assume."],[4929,5050,"Very."],[5050,5362,"You fucking cunt!"],[5562,5712,"Shit!"],[5858,5966,"Damien!"]],"72":[[16,250,"Shit!"],[395,545,"Damien!"],[637,837,"What have you done to my son?"],[837,1062,"He did this to himself."],[1387,1504,"I remember the night"],[1504,1720,"you killed me and our babies."],[1720,1933,"I hope you burn in hell."],[2041,2204,"Damn, Elise."],[2204,2395,"I was just going to get him arrested."],[2395,2550,"I'm impressed."],[2550,2720,"He doesn't deserve to breathe."],[2720,2929,"Not when our babies never will."],[2929,3033,"Ambulance!"],[3033,3216,"Call an ambulance!"],[3525,3654,"I have the getaway car."],[3654,3770,"Let's go together."],[3962,4291,"Let's stay together, little sister."],[5654,5741,"Excuse us."],[5741,5875,"Thank you."],[5875,6075,"Sorry about the mess."],[6075,6170,"Good luck with the blood."],[6170,6333,"Bye."]]}