{"1":[[796,871,"Emilia!"],[934,1088,"Wait!"],[2106,2298,"You have to mask your scent."],[2298,2494,"No one-witch or werewolf-"],[2494,2686,"can ever know what you truly are."],[2748,2823,"Mom,"],[2823,2973,"you already know I have a mate."],[2973,3098,"You think that's"],[3098,3328,"something to be proud of?"],[3328,3578,"A half-witch, half-wolf abomination,"],[3578,3766,"neither side will ever claim you."],[3970,4166,"Do you think I'm going to sit here"],[4166,4408,"and watch while you throw yourself away?"],[4408,4612,"Do as I say!"],[5380,5555,"The school is divided-"],[5555,5693,"witches and wizards."],[5693,5839,"A normal human being?"],[5839,6014,"What, did she just wander in?"],[6368,6564,"Oh no, don't tell me."],[6564,6735,"We are doing charity admissions now?"],[6735,6827,"What's next,"],[6827,6952,"diversity for strays?"],[6952,7107,"She's lucky she's just a human."],[7107,7319,"If the school ever stoops so low"],[7319,7578,"as to admit a filthy half-blood,"],[7578,7720,"we'd all tear her apart."],[8370,8475,"And then,"],[8475,8608,"there's them,"],[8608,8696,"werewolves."],[9417,9676,"A human try to pass as us."],[9676,9780,"How adorable."],[9955,10055,"What's wrong?"],[10055,10181,"I heard humans cry easy."],[10181,10281,"Let's see."],[10343,10506,"Please, let me go!"],[10506,10635,"Oh, she begs."],[10635,10731,"Cute."],[10731,10923,"I bet you can't even shift, huh?"],[10944,11119,"Maybe we should check."],[11119,11240,"Rip her clothes off."],[11240,11415,"See if she's hiding a tail somewhere."],[11953,12087,"That's enough!"],[13947,14097,"The scent..."],[14097,14264,"It's him."],[14264,14389,"He's my mate!"]],"2":[[179,229,"Wesley,"],[229,308,"we were just..."],[308,448,"welcoming the new girl."],[821,934,"You okay?"],[1213,1276,"Thank you."],[1572,1843,"Wesley, you can just let the human go."],[1843,1943,"She's not worth your time."],[1943,2085,"Since when is it funny"],[2085,2206,"to gang up on someone?"],[2590,2794,"Wesley, it was just a silly mistake."],[2794,2977,"I mean, I'm sure she would agree."],[2977,3090,"Right?"],[3090,3228,"Sweetheart?"],[3257,3378,"I'm Wesley."],[3449,3620,"Welcome to Willowbrook."],[3620,3941,"I'm sure you need a guide to"],[3941,4066,"show you around this place,"],[4066,4140,"right?"],[4938,5155,"Wesley, we have plans."],[5321,5530,"As long as I drink that potion,"],[5530,5693,"he will never know I'm his mate."],[7557,7645,"Are you alright?"],[7882,7945,"I should've known"],[7945,8119,"these wolves were causing trouble."],[8162,8245,"No maturity."]],"3":[[379,546,"Watch yourself, wizard."],[546,638,"You're in my territory."],[925,1030,"Wait."],[1030,1167,"He's a Dawson?"],[1167,1305,"The most powerful wizard family?"],[1438,1547,"Are you seriously suggesting"],[1547,1655,"I just stand by"],[1655,1760,"and let you bully the new girl?"],[1872,1964,"Don't act like you've ever been"],[1964,2093,"on the side of justice,"],[2093,2202,"wizard boy."],[2202,2377,"How ridiculous."],[2473,2656,"It's... it's my problem."],[2702,2773,"No."],[2773,2890,"It's not true."],[2890,2969,"These wolves must have"],[2969,3073,"scared the crap out of you."],[3190,3224,"Come on."],[3224,3349,"Let me show you around the school."],[4562,4725,"Guess it's time to say goodbye."],[4813,4909,"Thank you, Liam."],[4984,5050,"Really nice."],[5142,5255,"The newbie already found herself"],[5255,5326,"a new guy."],[5401,5472,"I'm not as rude"],[5472,5618,"as some of the werewolves,"],[5618,5718,"but if you ever need me,"],[5718,5843,"you know where to find me."],[6602,6719,"Wesley is sitting behind me."],[6781,6840,"What the hell!"]],"4":[[166,271,"Ms. Hale?"],[325,454,"Are you even listening?"],[496,583,"Yes!"],[621,759,"We're discussing Shakespeare."],[825,1067,"Name one of his plays-"],[1067,1205,"besides Romeo and Juliet."],[1313,1384,"Oh no,"],[1384,1539,"do we have to loan the new girl a book?"],[2006,2285,"Taming of the Shrew, Macbeth,"],[2318,2394,"Hamlet."],[2452,2556,"I didn't take you for the type"],[2556,2806,"to forget your own history, Chloe."],[3144,3194,"Good one."],[3303,3357,"Thanks."],[4662,4875,"So the teacher is pairing us up"],[4875,5013,"for a scene performance."],[5188,5267,"You got a partner?"]],"5":[[12,250,"I... I... um..."],[250,337,"Oh, she does."],[454,613,"Her partner is me, Wesley."],[613,779,"Come on, don't be jealous."],[842,1013,"Emilia actually knows Shakespeare,"],[1013,1055,"right?"],[1138,1226,"And besides, it's not like"],[1226,1322,"we'll be glued together."],[1484,1630,"I don't know... I mean..."],[1639,1793,"Come on. She can barely breathe around you."],[1793,1893,"Yeah, Wesley,"],[1893,2035,"you're being way too nice"],[2035,2139,"to the lost lamb."],[2139,2231,"She barely even"],[2231,2377,"deserves a seat in this class."],[2427,2569,"Wesley, since when did you start"],[2569,2727,"collecting strays?"],[2727,2902,"An alpha deserves someone worthy."],[2902,3061,"Someone who can stand beside him,"],[3061,3186,"like his future Luna."],[3186,3240,"Not a"],[3240,3403,"shabby little human."],[3403,3453,"It's enough!"],[3503,3657,"I'll decide who I'm with."],[3741,3862,"No one else, you got it?"],[4033,4120,"Yes, Wesley."],[4625,4729,"Did I..."],[4729,4788,"scare you?"],[4988,5042,"A little."],[5138,5292,"Is it because of how I yelled at them?"],[5330,5459,"Look, they're my pack."],[5459,5647,"And I'm their future alpha."],[5647,5789,"That's why they look at me like, um..."],[5789,5914,"something untouchable."],[5985,6147,"But you are..."],[6147,6214,"special."],[6377,6423,"You mean that?"],[6639,6690,"Look,"],[6810,6927,"if..."],[6927,7207,"I don't find a Luna before my birthday,"],[7207,7311,"I can't become alpha."],[7374,7499,"And the law is clear."],[7553,7728,"No alpha, no claim."],[7957,8053,"Only execution for"],[8053,8133,"the next in line."],[8466,8575,"Have we met before?"],[8812,9067,"I read a new poetry book today."],[9138,9296,"Huh, says here..."],[9334,9509,"you're mine forever."],[9951,10147,"The moment my mother found out..."],[10147,10310,"we vanished from the town overnight."],[10356,10514,"Before we even knew each other's names."],[10698,10844,"I don't think so."],[11665,11774,"Why can't I smell you?"]],"6":[[54,221,"I'm sorry, I don't feel well."],[813,934,"Stupid. Stupid Emilia."],[1026,1192,"What the hell are you doing?"],[1192,1355,"Wesley was like right there,"],[1355,1609,"and you're acting like a fucking idiot!"],[1743,1847,"The pull."],[1847,2039,"The bond between you and Wesley."],[2102,2227,"You know what this is-"],[2289,2456,"Denial won't save you."],[2623,2698,"Emilia?"],[2798,2957,"Is your wolf spirit out again?"],[3123,3240,"I told you."],[3240,3470,"Stay away from werewolves."],[3536,3611,"Mom..."],[3966,4129,"Your father was a wolf,"],[4233,4454,"a lying, selfish bastard."],[4454,4733,"They take, and then they ruin,"],[4733,4904,"and then they leave."],[4904,5142,"Always hungry for attention."],[5142,5426,"Emilia, this is the way it's always been."],[5497,5651,"Not everyone is like Dad."],[5697,5805,"Drink this."],[5805,5914,"It's stronger,"],[5914,6147,"and it'll erase your scent completely."],[6172,6368,"Mom, please, not again-"],[6368,6644,"I am doing this for you, Emilia."],[6644,6798,"I won't let them hurt you."],[7102,7215,"Alright,"],[7244,7303,"let me announce"],[7303,7469,"the partners for the Shakespeare project."],[7499,7607,"Emilia Hale"],[7607,7732,"and..."],[7732,7807,"Wesley Blackwood."],[8041,8220,"Guess you're stuck with me again, Emilia."],[8437,8550,"This can't be happening."]],"7":[[321,529,"Are you always this nervous"],[529,654,"or is it because of me?"],[654,759,"What?"],[759,804,"No."],[1889,1985,"You smell different."],[2168,2298,"I need some air."],[3111,3299,"Got partnered up with Wesley."],[3299,3374,"Lucky you."],[3486,3586,"I don't want trouble."],[3586,3695,"Oh, but you are trouble."],[3749,3916,"Taking things that don't belong to you."],[3987,4062,"Listen,"],[4099,4275,"maybe we don't need to be so aggressive."],[4371,4433,"Let's make a deal."],[4512,4617,"What deal?"],[4658,4871,"You give up your spot with Wesley,"],[4942,5230,"and I make sure that nobody bothers you."],[5292,5452,"Maybe I'll even be your friend."],[5601,5714,"A friend?"],[5714,5901,"Or another leash around my neck?"],[5901,5989,"Think it over."],[6035,6235,"But not for too long."],[6314,6431,"I don't have very much patience."],[6544,6660,"It's the easy choice."],[6698,6881,"I can walk away from all this madness."],[6944,7102,"But can I really let go of Wesley?"],[7161,7211,"Okay."],[7273,7419,"I'll give up the partnership."],[7540,7728,"I can't control Wesley if he decides-"],[7728,7786,"Excuse me?"],[7874,8041,"Wesley is my mate."],[8041,8120,"Why do you think he would"],[8120,8204,"choose you over me?"],[8333,8420,"Liar."],[8420,8579,"He's ours."],[8579,8808,"Say it. Say it!"]],"8":[[62,367,"You have nothing to worry about then, right?"],[396,504,"You'll regret this."],[1864,1951,"So..."],[2085,2273,"Are we gonna do this assignment? Or..."],[2273,2336,"are you just gonna pretend"],[2336,2431,"like I don't exist?"],[2556,2819,"I just think we should get started."],[2819,2936,"We have to pick a scene."],[3011,3182,"Yeah, whatever you like."],[3282,3361,"These plays are"],[3361,3482,"boring as hell to me anyway."],[3757,3958,"How about Romeo and Juliet?"],[4233,4262,"Really?"],[4350,4466,"The tragic love story?"],[4521,4621,"It's... one of"],[4621,4788,"Shakespeare's most famous plays."],[4884,5121,"And the language is so..."],[5192,5246,"Romantic?"]],"9":[[1180,1251,"Look at this line-"],[1480,1626,"\"With love's light wings,"],[1626,1797,"did I o'erperch these walls.\""],[1956,2210,"Romeo isn't just sneaking into"],[2210,2331,"Juliet's garden."],[2331,2494,"He's flying to her."],[2494,2744,"Love makes him feel weightless."],[2744,2977,"It's reckless. It's..."],[3065,3157,"You really like this stuff."],[3257,3294,"Huh?"],[3561,3661,"I told you."],[3832,4066,"Stay away from werewolves."],[4366,4554,"Oh my God, I'm sorry."],[4554,4696,"I didn't mean to ramble. I..."],[4696,4906,"You probably don't care about... um..."],[4950,5001,"Hey!"],[5188,5388,"Relax, Shakespeare. I don't bite."],[5693,5830,"Shoot, I forgot to"],[5830,5964,"drink the potion today."],[5993,6110,"Mom's going to kill me."],[6202,6318,"Looking for something?"],[6464,6577,"Give it back, Chloe!"],[6852,6952,"So desperate."],[6952,7148,"What's in here that's so important anyway?"],[7148,7315,"You think you're good enough for Wesley?"],[7361,7449,"You're nothing."],[7507,7711,"Just some pathetic little human,"],[7711,7862,"no place in his world."],[7937,7974,"No!"],[9242,9309,"Uh oh."],[9426,9567,"Looks like somebody is out of luck."],[10151,10393,"I... I..."],[10556,10710,"Look, I didn't mean to scare you before."],[10710,10777,"I just..."],[10865,10919,"Sorry."],[11056,11286,"Told you. One look and she bolts."],[11332,11419,"Like clockwork."],[11611,11665,"Hey, what's wrong?"],[12670,12779,"Why do you smell different?"],[13000,13058,"I have to go."],[13196,13321,"I'm not gonna let you go."],[13463,13688,"You're my mate, aren't you?"]],"10":[[83,154,"Wesley."],[154,246,"Emilia."],[329,421,"You know, I'm just..."],[479,608,"a normal human being."],[700,788,"I can't be your mate."],[1059,1272,"You're right, I don't know why I ask that."],[1272,1409,"I don't know what came over me."],[1609,1864,"Well, can you still hang out this weekend?"],[1972,2147,"Wesley is asking you out, you fool."],[2198,2439,"Say yes! Say yes!"],[2640,2727,"I..."],[2727,2806,"I can't."],[2927,3044,"I have to stay home."],[3161,3336,"Are you stupid?"],[3336,3428,"Shut up."],[3428,3536,"Mom will kill me."],[3570,3645,"Right, well..."],[3741,3903,"well, I'll see you next time then."],[4879,5038,"So, ready to"],[5038,5184,"do something fun this weekend?"],[5380,5467,"Yeah, sure."],[5513,5559,"Let's go."],[6631,6710,"Look at them, Emilia."],[6790,6877,"Is this what you wanted?"],[7002,7098,"You don't know what you missed."],[7257,7328,"Of course I know."],[7432,7461,"Emilia?"],[7695,7774,"Need a ride home?"]],"11":[[20,87,"How's school going?"],[191,283,"Is Chloe messing with you again?"],[446,498,"It's fine."],[738,817,"I'll see you tomorrow."],[2957,3082,"Having a fun time?"],[3203,3424,"Mom, I can explain."],[3490,3557,"Get in the car."],[3724,3799,"Bye, Emilia."],[4396,4562,"You leave me no choice."],[4562,4717,"Mom, please. No!"],[4717,4925,"You keep defying me."],[5117,5380,"Every rule that I set to keep you safe."],[5380,5513,"And for what?"],[5513,5626,"A filthy wolf?"],[5693,5818,"Where are they now?"],[5818,5850,"Huh?"],[5910,6093,"Only I stayed."],[6093,6339,"No one loves you like I do."]],"12":[[571,642,"Well,"],[700,838,"if it isn't our little daydreamer."],[930,1013,"Wesley and I had"],[1013,1197,"the best time last weekend."],[1197,1309,"By the way,"],[1309,1526,"you know I really should thank you... for"],[1622,1729,"bringing us closer."],[1764,1931,"Just leave me alone, Chloe."],[2218,2348,"Wesley and I are mates."],[2348,2540,"So stop the daydreaming, clown."],[2585,2667,"You're nothing."],[3645,3687,"Hey."],[3762,3853,"So, look, I know"],[3853,3999,"you left with your mom last week."],[3999,4124,"But, what about"],[4124,4212,"hanging this week?"],[4296,4400,"Um..."],[4400,4629,"I don't think it's a good idea."],[4700,4792,"Why not?"],[4921,5176,"Isn't Chloe your girlfriend?"]],"13":[[100,179,"What?"],[246,375,"No. Where'd you hear that?"],[504,571,"I..."],[571,759,"I heard you two are mates."],[842,955,"Is that true?"],[1105,1217,"It's complicated."],[1297,1438,"I knew my mate once"],[1438,1605,"who I saw her once when I was younger."],[1676,1789,"But it was like a dream."],[1918,2147,"Didn't even feel like she was real."],[2410,2790,"Maybe... maybe there's some reason why"],[2848,2944,"she can't meet you."],[3115,3224,"But if I don't get a mate"],[3224,3303,"by the time I'm 20,"],[3303,3461,"I'm gonna have to be with Chloe."],[3553,3749,"God, our parents would love it."],[3824,4049,"They get their perfect little union,"],[4062,4187,"and I get my mate."],[4308,4387,"Simple."],[4396,4521,"But you don't want her,"],[4617,4696,"do you?"],[4763,4842,"Doesn't matter."],[4909,5063,"My job is to find my mate,"],[5121,5259,"become Alpha, and..."],[5321,5426,"protect my pack."],[5467,5551,"That doesn't mean you have to"],[5551,5718,"settle for someone you don't love."],[5868,5947,"Oh really?"]],"14":[[83,266,"That's funny coming from you because"],[266,417,"there actually is someone I like,"],[417,600,"and she won't even go out with me."],[750,988,"Wow, so you won't even look at me."],[1121,1251,"I don't know what you mean."],[1438,1647,"You know exactly what I mean."],[1747,1843,"I'm sorry, Wesley."],[1951,2018,"Where are you going?"],[2018,2097,"Ah!"],[2181,2364,"I'm sorry I didn't mean to hurt you."],[2598,2706,"It's... it's fine."],[3311,3457,"What happened to your arm?"],[3557,3687,"I'll go get help. I'll get medicine."],[3691,3812,"No, it's... it's fine."],[3812,3912,"It's nothing."],[3958,4074,"You don't have to do anything."],[4112,4266,"Why do you keep pushing me away?"],[4295,4350,"You know I'm not gonna"],[4350,4517,"touch you without your permission."],[4637,4754,"Emilia, I just..."],[4821,5005,"I don't want you to hate me."],[5005,5067,"Okay?"],[5392,5526,"I don't hate you."],[5726,5860,"I can't be with you."],[5901,5980,"But why?"]],"15":[[66,171,"I'm sorry, Wesley."],[905,1055,"I saw my mate once"],[1055,1188,"when I was a kid."],[1215,1338,"Just once."],[1885,2010,"Catch me if you can!"],[2043,2264,"I'm the fastest in the world!"],[2731,2815,"The bond,"],[2882,3048,"the one you've been running from,"],[3090,3215,"hiding from,"],[3294,3411,"denying."],[4141,4225,"What is this?"],[4275,4371,"Is this my bond?"]],"16":[[525,604,"Who are you?"],[625,704,"Uh..."],[759,1001,"Hi, I'm Wesley, a friend of Emilia's."],[1030,1109,"A friend?"],[1167,1322,"Well, she was hurt."],[1322,1447,"I just wanted to check up on her."],[1447,1559,"Make sure she's okay."],[1630,1730,"She's not here."],[2002,2081,"Okay."],[2198,2277,"Well,"],[2306,2435,"can you give this to her for me?"],[2556,2635,"And look,"],[2706,2940,"if you happen to know who did this..."],[2961,3244,"Tell me. I'll make sure they regret it."],[3269,3407,"I'll beat their ass!"],[3420,3499,"Hmm..."],[3511,3645,"I'd love to see that."]],"17":[[229,508,"I told you not to act like a whore."],[554,675,"I like Wesley!"],[696,800,"He's different!"],[850,1026,"He's a werewolf."],[1026,1188,"They're all the same."],[1188,1338,"He's not my father!"],[1368,1480,"He would never treat me"],[1480,1601,"the way father treated you!"],[1613,1768,"What did you just say?"],[1890,2035,"How dare you?"],[2047,2198,"You were right about one thing."],[2264,2398,"Father never cared,"],[2448,2565,"not about you,"],[2581,2698,"not about me."],[2786,3019,"But Wesley does. He cares about me."],[3057,3219,"You're just like him..."],[3219,3495,"You ungrateful little monster!"],[3507,3691,"Doesn't matter whatever you say."],[3724,3866,"I'm not coming back!"],[4721,4817,"Got lost?"],[4921,5080,"I can make you feel so much better."],[5138,5301,"How about a little gratitude, sweetheart?"],[5522,5572,"I've got something"],[5572,5730,"you could put those lips to use for."],[5922,6051,"She's a rare little beauty."],[6197,6348,"No, please no!"],[6723,6827,"Back off!"]],"18":[[16,125,"Back off!"],[880,1076,"Leave! Now!"],[2406,2485,"Are you okay?"],[2669,2761,"You're safe now."],[2811,2907,"Let's get out of here."],[3390,3545,"So do you want to tell me what happened?"],[3824,3908,"You know,"],[4070,4329,"opening up to someone can be intimidating."],[4458,4575,"Why don't we start with this?"],[5096,5221,"Just pretend like..."],[5288,5401,"you're talking to the cup."],[6031,6206,"My mother thinks I'm a monster."],[6377,6531,"I'm not witch enough,"],[6627,6756,"not wolf enough."],[6890,7027,"Neither side wants me."],[7407,7520,"It can be lonely,"],[7561,7716,"not having a place to call home."],[8208,8274,"It..."],[8274,8541,"feels like I don't belong anywhere."],[8742,8821,"No,"],[8900,9046,"you don't have to go through that alone."],[9142,9309,"You don't have to face anything alone."],[9388,9517,"I can offer you something."],[9617,9701,"A mindlink."],[9826,10101,"It's a bond, a direct connection."],[10130,10406,"No words, no distance."],[10414,10531,"Whenever you need me,"],[10585,10798,"whenever you're in pain, I'll know."],[11061,11148,"So, what do you say?"]],"19":[[83,162,"I don't know."],[421,650,"It feels... too close,"],[779,867,"too personal."],[988,1108,"It doesn't have to be anything"],[1108,1247,"that you're not willing to share."],[1284,1484,"Think of it like a safe space,"],[1526,1755,"a place where you can speak without walls."],[1868,2081,"You ungrateful little monster!"],[2097,2239,"Wesley and I are mates."],[2239,2419,"So stop with the daydreams,"],[2431,2510,"clown."],[2540,2598,"Right now,"],[2598,2781,"there's someone I actually like,"],[2865,3040,"and she won't even go out with me."],[3144,3290,"I'm sorry, Wesley."],[3578,3657,"I..."],[3699,3945,"I really need a friend."],[4058,4166,"Then let's give it a try."],[4320,4400,"Thank you."],[5188,5276,"What are you doing?"]],"20":[[120,225,"Get the hell off!"],[408,513,"You should direct that anger"],[513,625,"towards your rogues."],[625,763,"What the hell are you talking about?"],[784,888,"Wesley, stop!"],[971,1130,"Liam saved me from the rogues!"],[1201,1343,"You met the rogues? Are you hurt?"],[1434,1589,"No, I'm... I'm fine."],[1668,1801,"Liam showed up just in time."],[2231,2406,"Thanks, wizard."],[2414,2581,"That wasn't for you, wolf."],[2615,2731,"Yeah right, I get it."],[2731,2894,"Why the hell were you hugging her then?"],[2948,3028,"What?"],[3086,3165,"What?"],[3224,3290,"We're supposed to"],[3290,3415,"have a tighter connection."],[3495,3636,"You haven't hugged me once."]],"21":[[871,984,"Wesley, don't you think"],[984,1180,"we're a bit too close?"],[1309,1566,"Okay, that skinny wizard might be"],[1566,1668,"able to weave spells for you,"],[1668,1835,"but I can do so much more."],[1922,1985,"I mean how come you"],[1985,2147,"keep chasing him and not me?"],[2210,2381,"Are you competing with him?"],[2427,2560,"I'm just saying..."],[2660,2744,"I'm right here for you."],[2790,2944,"Okay, I'm right here."],[3165,3440,"Thank you. It's very sweet."],[3561,3649,"Honestly,"],[3649,3741,"you don't have to"],[3741,3891,"follow me around everywhere."],[3970,4079,"I'm safe now."],[4166,4245,"Okay."],[4350,4429,"See you in..."],[4462,4562,"English."],[4863,5055,"I think I've made myself clear."]],"22":[[20,175,"Wesley is my alpha."],[175,404,"How many times do I need to remind you?"],[479,638,"Stay the hell away from him,"],[667,825,"or I'll be forced to remind you again."],[880,1084,"And trust me, you won't like"],[1084,1284,"when I lose my patience."],[1317,1539,"You can't claim Wesley as your mate."],[1630,1760,"Not now, anyway."],[1864,1981,"I know you two don't have a bond."],[1981,2164,"I don't need a bond to know what's mine."],[2323,2406,"So prove it."],[2619,2769,"Until then, you have no right"],[2769,2927,"to call yourself his mate."],[3136,3215,"So,"],[3286,3424,"what's gonna be?"],[3620,3724,"Show me the bond,"],[3807,3987,"or tell everyone that you've been lying"],[3987,4108,"this entire time."],[4220,4391,"You fucking bitch!"],[4554,4696,"You should have known your place."]],"23":[[41,125,"Emilia!"],[2181,2423,"Hey, I'm okay, really."],[2477,2556,"You're not."],[2690,2827,"I shouldn't have left you alone."],[2923,3119,"Hey, it's not your fault."],[3336,3507,"I... I just want you to be happy."],[3787,3920,"I like it when you laugh."],[4546,4660,"I'll bring you some water."],[5488,5568,"Oh my god,"],[5634,5755,"is Emilia okay? I've..."],[5764,5885,"I've been so worried."],[6022,6218,"She told me everything, Chloe."],[6268,6348,"You pushed her."],[6385,6431,"What? That's..."],[6431,6531,"that's not what happened."],[6531,6644,"She just fell."],[6677,6815,"You know how clumsy she can be."],[6815,7002,"Stop lying, Chloe."],[7027,7248,"Wesley, we've known each other for forever."],[7273,7428,"You're really gonna pick some human girl"],[7428,7611,"that you met three months over me?"],[7699,7895,"Over someone who stood by you"],[7945,8062,"since we were born?"],[8345,8504,"We're childhood friends."],[8546,8662,"Why don't you trust me?"]],"24":[[425,621,"It's destiny, Wesley."],[738,905,"We've always been meant to be together."],[930,1030,"I have had..."],[1071,1155,"enough..."],[1180,1263,"of your lies."],[1263,1309,"What?"],[1309,1459,"What? Do you think I'm deaf?"],[1497,1643,"I heard the rumors about"],[1643,1826,"you saying that you're my mate."],[1826,1906,"That isn't a lie."],[1906,1981,"We will be mates."],[1981,2164,"I already have a mate!"],[2214,2398,"I had one and then I lost her."],[2439,2686,"You and I both know that she doesn't exist."],[2731,2890,"We are the perfect couple."],[2890,3028,"Everybody thinks so."],[3036,3228,"The only reason I let it slide"],[3261,3357,"is because our families are"],[3357,3482,"tied together by blood."],[3482,3757,"Out of respect, out of loyalty for your family,"],[3757,3874,"I kept quiet."],[3874,4091,"But that's over now, Chloe."],[4108,4320,"I will never be your mate,"],[4341,4562,"not now, not ever."],[4608,4708,"You're really gonna pick some"],[4708,4867,"plain human over me?"],[4888,5046,"She's not even your mate!"]],"25":[[116,225,"Believe whatever you want."],[308,387,"I don't care."],[600,763,"You will regret this, Wesley."],[1601,1664,"Here."],[1760,1818,"Let me do that."],[1876,1972,"It's fine Wesley,"],[1972,2056,"I can do it myself."],[2110,2223,"You humans..."],[2285,2464,"not stronger than a wolf."],[2540,2606,"You humans are..."],[2677,2765,"vulnerable..."],[2844,2923,"weak."],[3153,3286,"But you have a strong heart, Emilia."],[3390,3516,"You're the second most stubborn person"],[3516,3586,"I've ever met."],[3724,3816,"Who's the first?"],[3920,3970,"Me."],[4079,4204,"And that's why..."],[4204,4341,"I'm not gonna listen to you anymore."],[4416,4487,"From now on,"],[4546,4642,"you're staying with me..."],[4683,4763,"at school."],[4859,5013,"No one's ever hurting you again."],[5209,5347,"I want to let him protect me."],[5438,5547,"I want to believe in us..."],[5601,5659,"in him."],[5747,5864,"But I can never escape her..."],[5968,6051,"My mother."],[6164,6343,"I really appreciate it, Wesley."],[6381,6443,"But..."],[6443,6481,"I..."],[6535,6598,"What?"],[6809,6919,"I felt the mindlink."],[6919,6977,"Are you okay?"]],"26":[[16,150,"Why are you here?"],[271,371,"It's fine, Wesley."],[417,558,"Liam just felt that I was in danger."],[600,667,"Yeah,"],[667,721,"of course."],[1059,1126,"Come on, Emilia."],[1155,1242,"I can take you home."],[1330,1434,"You really want to go with him?"],[2535,2652,"But I can never escape her..."],[2827,2886,"My mother."],[3282,3403,"It's for the best, Wesley."],[4579,4675,"It's not best"],[4675,4804,"for either of us, Emilia."]],"27":[[617,713,"You're in a good mood."],[917,1026,"Um..."],[1026,1146,"It's just a normal day."],[1539,1789,"What are you hiding from me?"],[3390,3528,"You defied me!"],[3528,3616,"You had no right..."],[3641,3870,"Of course I have the right!"],[3870,3953,"I'm your mother!"],[3953,4074,"You don't control me!"]],"28":[[1046,1163,"I just need to forget..."],[1297,1397,"just for a moment."],[1785,1885,"Forget school."],[2010,2143,"I just need to be free."],[3086,3186,"Wait... is that my Luna?"]],"29":[[41,187,"My Luna... it's really her."],[575,654,"But wait..."],[742,821,"her leg...?"],[1138,1347,"Wait, let me see your face."],[1409,1576,"No, no... This can't happen."],[1630,1735,"Wait, come back!"],[1839,2002,"What the hell are you waiting for?"],[2072,2193,"Why are you not with Wesley?"],[2339,2423,"Mom will kill me."],[2481,2581,"I can't let him see."],[2644,2698,"I just can't."],[3253,3357,"Why would she run from me?"],[4120,4166,"Emilia?"]],"30":[[508,621,"Whoa, let me help you."],[621,709,"Yeah, I'm there."],[809,938,"She's my partner,"],[971,1071,"wizard boy."],[1614,1755,"Wesley, you don't have to..."],[2419,2502,"Did you see that?"],[2502,2629,"He's totally into her."],[2631,2695,"Yeah."],[2715,2972,"It was kind of sweet and possessive way."],[3044,3111,"It's better this way,"],[3240,3299,"isn't it?"],[3361,3415,"Partner?"],[3908,4045,"You're making it so obvious."],[4083,4186,"Who cares."],[4200,4266,"Let them see."],[4810,4926,"You look nice."],[5067,5229,"Is there something on my face?"],[5309,5405,"No, it's..."],[5405,5504,"not that…"],[5555,5622,"I just..."],[5747,5845,"I feel like I've missed you"],[5845,5990,"for longer than I realize."]],"31":[[688,888,"\"With love's light wings,"],[888,1117,"do I o'erperch these walls;"],[1117,1230,"For stony limits"],[1276,1372,"cannot hold love out...\""],[1476,1639,"For stony limits cannot hold love out..."],[1768,1872,"Romeo's not just"],[1872,2002,"sneaking into Juliet's garden."],[2156,2243,"He's flying to her."],[2327,2394,"Love makes him..."],[2502,2552,"weightless."],[2644,2715,"You remember it?"],[2802,2940,"I remember everything you said."],[3336,3440,"For stony... limits cannot hold"],[3440,3778,"love out...\""],[3778,4055,"Nor can love's promises"],[4104,4258,"be stopped by walls of stone.\""],[4291,4416,"\"My ears have not yet drunk"],[4416,4554,"a hundred words..."],[4604,4750,"Of that tongue's uttering,"],[4771,4984,"...that tongue's uttering..."],[5034,5080,"yet..."],[5125,5234,"I know the sound...\""],[5797,5868,"Can I kiss you?"]],"32":[[66,196,"I'm sorry I just..."],[296,454,"Every part of me wants to be near you."],[454,629,"I know you don't want to..."],[1443,1543,"From now on,"],[1576,1789,"you're staying with me at school."],[1822,1997,"No one's ever hurting you again."],[2068,2164,"You remember it."],[2231,2398,"I remember everything you said."],[3428,3516,"I have to go."]],"33":[[41,125,"Emilia!"],[588,679,"Are you running away again?"],[938,1009,"Look..."],[1096,1213,"I know you feel the pull."],[1401,1501,"That fire."],[1597,1739,"So don't pretend that you don't."],[2077,2185,"Why can't you just accept it?"],[3470,3728,"Stay away from werewolves!"],[3803,3941,"Wesley, I can't..."],[4020,4149,"Then tell me to stop."],[4521,4650,"I saw my mate in the woods."],[4829,4917,"Her legs were hurt,"],[5042,5138,"just like yours."]],"34":[[70,191,"It doesn't mean anything."],[437,596,"Then why can't you even look at me?"],[825,942,"We met when we were kids,"],[1038,1080,"didn't we?"],[1351,1497,"I think I've loved you ever since then."],[1743,1826,"Wesley, stop..."],[1868,1926,"please."],[2085,2185,"If we keep doing this..."],[2185,2302,"we'll just end up getting hurt."],[2302,2369,"I don't care."],[2565,2702,"Look, I don't know what you're afraid of, but..."],[2886,2994,"I want to face it with you."],[3190,3269,"This isn't your fault..."],[3395,3490,"It's the curse."],[3528,3603,"We can't escape."],[3695,3820,"Emilia, I'll stand by you."],[4024,4129,"Whatever comes,"],[4225,4354,"I'm just a greedy and..."],[4412,4487,"selfish wolf"],[4487,4621,"who wants to bond with this Luna..."],[4804,4888,"which is you."],[5088,5184,"And I want to do that now."],[5309,5397,"Look, I'll wait for you,"],[5501,5588,"whenever you're ready."],[5701,5772,"We can be like..."],[5868,5972,"Romeo and Juliet."],[6239,6314,"Just for us."],[6498,6560,"What do you say?"]],"35":[[204,329,"How dare you steal him from me."],[1017,1109,"I have an offer for you."],[1184,1234,"Oh?"],[1368,1547,"And why would I waste..."],[1547,1655,"my time..."],[1655,1910,"with a spoiled little beta like you?"],[1989,2118,"Because I know what you crave..."],[2189,2282,"How badly you want to"],[2282,2423,"tear Wesley's pack apart."],[2686,2736,"Take her."],[2827,2948,"Do whatever you want to her."],[3040,3111,"And in return,"],[3182,3349,"I will ensure you have everything you need."],[3411,3516,"My pack's resources,"],[3516,3632,"their borders... everything."],[3741,4062,"You really must hate her."],[4112,4208,"I want what's mine."],[4291,4446,"And nobody is gonna stand in my way."],[4596,4742,"Then we have a deal."]],"36":[[162,354,"I... I wanted to tell you in person."],[529,663,"Wesley and I are together now."],[771,817,"I..."],[817,967,"guess congratulations are in order."],[1101,1238,"You're not angry at me?"],[1334,1384,"Well,"],[1447,1584,"I don't think he deserves you."],[1672,1814,"Wesley isn't as bad as you think."],[1885,1972,"In fact,"],[1972,2060,"some people think"],[2060,2214,"it's me who doesn't deserve him."],[2273,2431,"That's nonsense. He's an..."],[2489,2669,"overgrown, immature pack leader"],[2669,2786,"who spends way too much time"],[2786,2923,"acting like a spoiled prince."],[2923,2982,"Liam."],[3215,3357,"I always thought we would end up together."],[3666,3745,"I... I..."],[3745,3841,"I was kidding."],[3920,4041,"Hey buddy,"],[4041,4216,"you don't mind keeping your distance"],[4216,4375,"from the overgrown,"],[4375,4587,"immature pack leader's girlfriend,"],[4637,4717,"do you?"]],"37":[[41,141,"Well... Look who's decided to"],[141,258,"grace us with his"],[258,417,"royal presence."],[579,658,"Wow..."],[700,809,"Not even gonna hide it, huh?"],[809,992,"Just gonna claim her like that?"],[1138,1230,"Why would I pretend?"],[1238,1351,"Wesley, really?"],[1505,1693,"I can't even talk to her anymore?"],[1693,1776,"I'm just trying to make sure"],[1776,1968,"my Luna is properly protected."],[1968,2131,"So what? So I gotta"],[2131,2223,"put all my messages"],[2223,2385,"through your royal messenger?"],[2385,2519,"I'm glad you understand."],[2569,2673,"What would you like to say?"],[2719,2844,"Why don't you tell Emilia that"],[2844,2902,"I think she's making"],[2902,3023,"the worst mistake of her life"],[3023,3123,"in dating you."],[3257,3349,"You got it."],[3465,3570,"Emilia,"],[3570,3716,"Liam just told me"],[3716,3787,"that you're making"],[3787,3958,"the smartest decision of your life"],[3958,4037,"by dating me."],[4112,4204,"Unbelievable."],[4316,4471,"Come on, no more interruptions."],[4508,4612,"Just you and me,"],[4654,4717,"all day,"],[4783,4863,"all day long."]],"38":[[367,458,"I didn't know you'd come to"],[458,579,"places like this."],[642,884,"I usually stay at home..."],[884,1076,"and get lost in a book."],[1288,1313,"Okay..."],[1313,1576,"Well, today we're doing"],[1576,1701,"something different."],[1785,1901,"Come on, let's go."],[4087,4166,"No."],[4220,4333,"Absolutely not."],[4387,4483,"Why not?"],[4667,4796,"Wesley, what are you doing?"],[4796,4871,"You really expect me"],[4871,4967,"to let you walk out of here"],[4967,5071,"wearing that... while all those"],[5071,5201,"guys looking at you?"],[5392,5480,"Jealous much?"],[5522,5609,"I just wanna make sure you know"],[5609,5730,"who you belong to."]],"39":[[804,992,"Careful now, little miss."],[992,1230,"It's dangerous to roam these parts alone."],[1534,1614,"Chloe?"],[1668,1864,"You should've just stayed away from him."],[1864,1985,"But now?"],[1985,2068,"It's too late."],[2777,2877,"Feisty."],[2877,2982,"I like that."],[3724,3895,"Wesley can't save you this time."]],"40":[[171,250,"Emilia."],[287,450,"Emilia is in danger!"],[538,667,"What the hell happened?"],[675,775,"The mindlink..."],[809,905,"I can feel it, Wesley."],[905,1046,"She's in pain right now."],[1634,1739,"It must be Chloe."],[1751,1830,"Chloe?"],[1868,2135,"I mean, she's a pain in the ass, but this?"],[2135,2214,"Kidnapping?"],[2248,2323,"That's not like her."],[2323,2419,"There's got to be someone else"],[2419,2506,"pulling the strings."],[2506,2652,"Then we find them both."],[2652,2702,"Help!"],[2836,2886,"Help!"],[2998,3057,"Wait!"],[3057,3107,"It's not safe."],[3107,3186,"Don't go alone!"],[3186,3236,"Help!"],[3428,3520,"Help!"],[3624,3691,"Please!"],[3770,3962,"Took you long enough, Wesley."],[3962,4095,"Thought you'd never show."]],"41":[[387,513,"Wesley, Liam?"],[513,629,"Emilia! You're here."],[775,885,"You should be more concerned"],[885,1046,"for yourself, Wesley."],[1046,1217,"Once I take over your pack..."],[1217,1388,"I'm going to end you."],[1676,1755,"You two..."],[1805,1901,"Are you okay?"],[1901,1989,"I'm fine."],[1989,2118,"Liam is fine."],[2118,2281,"Well, thanks for answering for me,"],[2281,2348,"Wesley."],[2927,3007,"Really?"],[3007,3094,"Here?"],[3094,3178,"Now?"],[3178,3269,"What?"],[3269,3374,"I'm just making sure you know"],[3374,3457,"where the line is."],[5230,5263,"Okay."],[5263,5455,"Look, I was joking."],[5455,5492,"All right?"],[5492,5663,"I just want her to feel comfortable."],[5709,5797,"I know."],[5993,6143,"Well, she's asleep now..."],[6239,6339,"So what's your plan?"]],"42":[[50,233,"Well, I can teleport out of here."],[333,417,"Great."],[462,538,"Let's go."],[538,642,"There's a catch."],[642,817,"I can only teleport myself."],[1013,1088,"Alright, that's fine."],[1088,1180,"I'll take care of her."],[1393,1426,"What?"],[1426,1559,"She's fine with me."],[1701,1826,"I'll go get help."],[1826,1947,"Just be safe."],[2068,2185,"Yeah, you know I will."]],"43":[[187,312,"Where's the other one?"],[312,433,"He's gone."],[433,675,"He's probably gathering an army as we speak."],[675,980,"Then I'll make sure I finish you both,"],[980,1234,"before your little hero can come back."],[1234,1280,"No!"],[1280,1393,"Don't touch him!"],[1722,1843,"Let him go!"]],"44":[[166,400,"I said don't touch my boyfriend!"],[1384,1468,"Who're they?"],[1468,1572,"It's Alpha Jack."],[1693,1843,"Oh God, Wesley, you're bleeding."],[1914,2064,"Shh, it's okay."],[2064,2106,"Focus."],[2106,2206,"Don't let him hear you."],[2231,2310,"Wesley, there's something"],[2310,2410,"I need to tell you."],[2748,2948,"I can smell you."],[3682,3745,"Run! Now!"],[3745,3849,"Wesley!"],[3849,3920,"Enough!"]],"45":[[66,120,"Mom,"],[171,204,"you..."],[258,404,"What are you doing here?"],[404,759,"I told you that this wolf would ruin your life."],[980,1051,"Wesley!"],[1051,1405,"Wesley..."],[1405,1488,"You're... safe."],[1551,1672,"That's all that matters."],[2027,2281,"Wesley, I'm your mate."],[2281,2331,"Please..."],[2331,2469,"You can't just..."],[2469,2548,"No!"],[3103,3236,"Give him this."],[3236,3332,"It will heal him."],[3382,3503,"You're helping him?"],[3557,3666,"I see now..."],[3762,3937,"He's not just a beast,"],[3937,4062,"not just a wolf."],[4145,4346,"He risked everything to save you."],[4466,4587,"And I nearly fainted"],[4587,4692,"when I thought you were gone"],[4692,4833,"from your room."],[4833,4959,"That place..."],[4959,5130,"It was a cage for you, wasn't it?"],[5880,6131,"I know you were trying to protect me..."],[6331,6443,"but yes,"],[6544,6648,"it was a cage."],[7182,7340,"You're free now, Emilia."],[7419,7503,"To live"],[7707,7782,"and to love,"],[7782,7912,"as you choose."],[8470,8575,"Thank you, Mom."],[10940,11023,"Emilia?"]],"46":[[62,117,"Wesley."],[2756,2907,"Wesley... really?"],[2907,3115,"Is this your idea of a subtle entrance?"],[3115,3336,"Subtlety is weak."],[3336,3520,"I want everyone"],[3520,3682,"to know you're mine."],[3682,3782,"My Luna."],[4909,5159,"So, how's it feel to be back at school,"],[5159,5296,"now that you're King of the Hill?"],[5296,5388,"Better."],[5388,5484,"Now that I can finally"],[5484,5601,"show off my Luna."],[5680,5778,"What about your pack?"],[5778,5876,"Aren't they curious"],[5876,5947,"what happened to her?"],[6010,6139,"Why would they care?"],[6139,6256,"They're too busy celebrating"],[6256,6468,"the fact that I took care of a few..."],[6468,6539,"rebels."],[6589,6681,"You mean Chloe?"],[6727,6856,"What happened to her?"],[6856,7027,"She was cast out."],[7027,7286,"I couldn't give a damn about her, though."],[7732,7791,"You know..."],[7949,8053,"I've dreamt of this moment,"],[8053,8279,"ever since we first became partners."],[8279,8375,"Dreamt of what?"],[8641,8758,"You."],[8758,8913,"In my arms."],[8913,9095,"Reading Shakespeare‘s love poems"],[9184,9309,"to only me."],[9309,9398,"I knew you were my mate"],[9398,9548,"from the moment I met you."],[9672,9834,"And yet, you still made me waiting."],[10460,10615,"No more waiting, Wesley."],[10714,10806,"We're home."]]}