{"1":[[283,470,"One, two, three."],[470,663,"I got one more."],[1023,1160,"Dylan,"],[1160,1450,"is there anything else you're hiding from me?"],[1680,1810,"Why don't you believe me?"],[2053,2220,"What did you think of me when you were..."],[2370,2463,"Derek Norton?"],[2890,3063,"Go to hell, you liar!"],[5070,5453,"What is the combination?"],[5460,5640,"If I tell you,"],[5640,5843,"the Norton family will kill me."],[6020,6130,"Hurry up."],[6130,6300,"I've got a date to get to."],[6300,6540,"Don't kill me. Don't kill me."],[6610,6793,"I'll give you the combination."],[7040,7160,"Good."],[7500,7609,"Bite."],[7963,8084,"Don't make a sound"],[8084,8233,"until I leave this building."]],"2":[[860,1190,"Mr. Norton, please spare me."],[1200,1333,"It was that venomous woman"],[1333,1450,"from the DeVille family"],[1450,1540,"who took the goods."],[1540,1710,"That \"Bloody Rose\" again?"],[1710,1860,"Andy,"],[1890,2070,"I already gave you a chance."],[2093,2200,"Get him out of here."],[2323,2463,"Wait."],[2690,2890,"Did you get a good look at her?"],[2890,3210,"Not clearly, but if I see her,"],[3233,3390,"I might recognize her."],[3390,3583,"Useless."],[3593,3670,"No, no."],[3670,3720,"Mr. Norton,"],[3720,3890,"you can't do this to me..."],[4359,4458,"It reveals they're really"],[4458,4558,"pushing their luck."],[4570,4655,"This is the third time"],[4655,4773,"they've stolen our goods."],[4850,4973,"What do you think of this outfit?"],[4973,5053,"You're going on another date"],[5053,5153,"with Alyssa?"],[5153,5269,"Today"],[5269,5510,"marks our 100th day since we've met."],[5520,5690,"If Alyssa finds out that you're not Dylan,"],[5690,5770,"the restaurant owner,"],[5770,5936,"but Derek Norton, the true heir"],[5936,6190,"-of the Norton family. -She's not ever"],[6190,6340,"gonna find out."],[6350,6570,"She's too good-hearted for that kind of life."],[7870,8040,"No, I'm not Aria,"],[8040,8233,"the \"Bloody Rose\" of the Devil family"],[8233,8333,"right now."],[8340,8650,"I'm Alyssa, the gentle flower shop owner."]],"3":[[880,1093,"To 100 days since we met."],[1250,1363,"Thank you."],[1660,1750,"Nobody move."],[1980,2103,"Go get me the money."],[2430,2533,"Well, well, well,"],[2533,2680,"nice seeing you again."],[2760,2950,"No, I can't scare her."],[3780,3820,"What..."],[3820,3940,"What should we do?"],[4000,4160,"I hit him."],[4220,4333,"Should we call the police?"],[4333,4480,"I'll call the police."],[5330,5523,"I was so terrified."],[6573,6750,"You were so brave today."],[6750,6815,"I can't imagine"],[6815,6986,"what would've happened if you hadn't been there."],[7133,7260,"Didn't know what I was doing."],[7383,7540,"Just scared that he was gonna hurt you."],[10050,10260,"If I ever lied to you, would you be mad at me?"]],"4":[[210,393,"What could you possibly lie to me about?"],[543,713,"You've already had my heart."],[2580,2660,"Don't kill me."],[2660,2753,"I'll do anything you want."],[2780,2916,"I need you to do something"],[2916,3083,"very important for me."],[4250,4348,"These really are the best"],[4348,4500,"pancakes in Atlanta."],[4653,4793,"I might need to bother you more often"],[4793,4890,"from now on."],[7570,7723,"You made this for me."],[8123,8263,"These are the best pancakes"],[8263,8353,"I've ever had."],[8363,8483,"Almost,"],[8483,8750,"almost as good as the Reale restaurant's"],[8750,8813,"head chef."],[8920,8983,"Really?"],[9020,9183,"Don't all pancakes taste the same?"],[9250,9427,"How did he immediately recognize"],[9427,9580,"they're from Reale's head chef?"],[9590,9715,"I do have one more question"],[9715,9810,"to ask you."],[9810,9910,"Close your eyes."],[9923,10086,"Why is he looking at me like that?"],[10086,10241,"Did he figure something out?"],[10241,10376,"Close your eyes."]],"5":[[450,600,"Will you marry me?"],[720,873,"Let's spend every day"],[873,1006,"and every night together,"],[1083,1210,"side by side."],[1400,1643,"Cooper from the Francis family."],[1643,1800,"Strong, brave,"],[1800,1940,"and a good match for you."],[1940,2073,"What are you doing?"],[2120,2306,"I told you I wanna live a normal life."],[2323,2450,"The Francis family's support"],[2450,2560,"is crucial for us."],[2610,2740,"Yeah, but you promised"],[2740,2950,"that once I finished what you asked,"],[2953,3070,"I could leave the family."],[3070,3173,"Aria!"],[3173,3270,"You're my daughter."],[3270,3447,"Now is not the time."],[3523,3692,"If you can't respect my choices,"],[3692,3758,"then consider me"],[3758,3873,"no longer your daughter."],[3960,4063,"Fine."],[4120,4188,"Then finish these"],[4188,4350,"last few jobs for me."],[4350,4447,"Don't think I don't know"],[4447,4570,"about that poor restaurant boy"],[4570,4740,"you've taken a liking to."],[4750,4967,"He thinks your name is Alyssa, no?"],[4986,5150,"Stay away from Dylan."],[5250,5363,"It's up to you then."],[5410,5583,"Finish these tasks."],[5583,5713,"We'll talk."],[6093,6185,"Alyssa?"]],"6":[[103,210,"I..."],[330,436,"This is so sudden."],[490,640,"I need time to prepare."],[700,853,"Maybe we could live together"],[853,933,"for a while first"],[933,1055,"and see if we can adjust each other"],[1055,1203,"and then decide about marriage."],[1260,1640,"So, starting today,"],[1650,1850,"we're living together?"],[2840,2910,"I'm so sorry."],[2910,3093,"I promised Susan I'd get to the shop early."],[3093,3300,"She's taking her son to the dentist."],[3300,3456,"Oh. I'll drive you."],[4140,4380,"Come. Saga Restaurant."],[4736,4797,"Boss."],[4797,4903,"Just got word John Deville"],[4903,4970,"set up a reservation"],[4970,5056,"at your restaurant."],[5123,5203,"I'll be right there."],[5860,6076,"Of all the places Father chooses,"],[6076,6256,"it had to be Dylan's Restaurant."],[6880,7200,"Cooper, the youngest son of the Francis family."],[7206,7280,"The two of you"],[7280,7440,"have a lot to talk about."],[7710,7796,"A pleasure."],[8156,8261,"Bring that table a bottle"],[8261,8426,"of your finest champagne."],[8426,8516,"Very good, sir."],[9356,9426,"I'm so sorry."],[9426,9536,"Is everything okay?"],[9540,9636,"Buzz off."],[9816,9910,"Goodness,"],[9910,10146,"a woman as beautiful as you."],[10146,10280,"It's wonderful to meet you"],[10280,10371,"in the flesh."],[10700,10741,"Justin,"],[10741,10816,"I don't see him."]],"7":[[440,650,"Boss, you're not going to believe this."],[650,790,"I need you back here now."],[1100,1164,"Fuck!"],[1380,1549,"I don't know what my father told you,"],[1549,1698,"but I already have a boyfriend."],[1826,1903,"You know..."],[1910,2160,"Your father told me everything."],[2200,2334,"See, he's not too keen"],[2334,2483,"on your boyfriend."],[2496,2649,"It's just temporary."],[2670,2773,"Dylan is a good man."],[2773,2882,"He'll win my father's approval"],[2882,2976,"eventually."],[3030,3190,"I heard he owns a restaurant."],[3270,3348,"Tell me,"],[3440,3583,"can he handle a gun?"],[3600,3859,"I don't care whether he can use a gun or not."],[3860,4076,"Does he know that your family"],[4076,4280,"is one of the biggest Mafia families"],[4280,4370,"in the whole city?"],[4376,4553,"He doesn't need to know that."],[4565,4737,"Let me make this very clear."],[4737,4896,"I won't obey my father's orders"],[4896,5130,"and marry into any mafia family."],[5150,5319,"I just wanna live a normal life."],[5740,5883,"Sooner or later,"],[5883,6108,"you'll beg to be with me."],[6570,6640,"Why did you make me"],[6640,6745,"have dinner with that idiot"],[6745,6866,"from the Francis family?"],[6903,6980,"We need their business"],[6980,7200,"and connections in the West District."],[7200,7480,"And you need a husband who can protect you."],[7480,7541,"How many times"],[7541,7683,"do I have to tell you this?"],[7730,7843,"I wanna live a normal life,"],[7843,7962,"and I don't want to be involved"],[7962,8090,"in any more gang business."],[8090,8175,"What kind of spell"],[8175,8380,"is that restaurant boy cast on you?"],[8380,8610,"It's not about him, Father."],[8770,8920,"Please, just..."],[8920,9063,"just tell me what I have to do"],[9063,9210,"for you to let me leave the family?"],[9420,9560,"There is a crucial document"],[9560,9690,"in the hands of this man."],[9820,9960,"Go and get it for me."]],"8":[[310,610,"Mike Evans, a former Mossad agent."],[620,736,"He's currently in possession"],[736,910,"of the classified military documents"],[910,1140,"related to the operation in the Middle East."],[1210,1325,"He's currently staying"],[1325,1480,"at the Queens Hotel tonight."],[1480,1650,"I'll take a team to retrieve it."],[1690,1830,"He's not that easy to handle."],[1890,2070,"I'll take care of it myself."],[2940,3090,"Baby."],[3270,3400,"You're finally here."],[3490,3660,"Such a hot and steamy day."],[3660,3800,"How about I take a shower first?"],[3910,4020,"Of course."],[6040,6180,"Good evening, sir."],[6230,6360,"Here's your dinner."],[6360,6478,"You're not the same guy"],[6478,6650,"who delivered lunch earlier."],[6650,6800,"Danny's taking the night off,"],[6800,7010,"so I will be serving you tonight."],[7390,7610,"It looks good."],[7610,7720,"Honey."],[7720,7793,"Are you gonna join me"],[7793,7960,"for some Lobster Thermidor?"],[7960,8100,"No, thank you."],[8100,8250,"I already ate before I came."]],"9":[[580,727,"Are you sure you don't want any?"],[800,930,"It's really good."],[930,1093,"Really, I'm fine."],[1640,1773,"Are you two working together?"],[1853,1910,"What?"],[2210,2283,"Who is that?"],[2293,2443,"I've never seen her before."],[3060,3193,"What's going on in there?"],[3360,3500,"She jumped out the window."],[3533,3630,"Imbecile!"],[3720,3823,"She dropped this, though."],[4240,4460,"You dare try to steal from me?"],[4460,4496,"Wait a minute."],[4496,4643,"I really don't know her."],[4753,4890,"Sir, there's been a fire."],[4900,4987,"Please evacuate to the lobby"],[4987,5050,"immediately."],[5350,5430,"You're lucky."],[5520,5573,"Come on."],[6370,6490,"I had it under control."]],"10":[[280,373,"Did you see who that woman"],[373,460,"in the room was?"],[510,599,"I was stationed in the lobby"],[599,660,"the whole time."],[680,793,"Didn't see her go up."],[813,897,"Do you think that could've been"],[897,1063,"the DeVille family's Bloody Rose?"],[3020,3180,"Hey, Dylan, what's up?"],[3180,3233,"Sweetheart, are you"],[3233,3320,"at the flower shop?"],[3410,3520,"Yeah, I am."],[3630,3700,"Do you want me to pick you up"],[3700,3780,"after work?"],[3840,4060,"No. No need. I already called a taxi."],[4060,4173,"It'll be here soon."],[4173,4277,"Have you been at the flower shop"],[4277,4340,"all day?"],[4473,4540,"Yeah."],[4580,4693,"Susan took the day off."],[4793,4853,"Alright."],[4930,5010,"I'll head home then."],[5113,5210,"I'll see you later."],[5403,5530,"You're not going back to the office?"],[5583,5633,"No."],[5730,5830,"I need to see Alyssa."],[5830,5964,"Just gather all the intel"],[5964,6011,"that you can"],[6011,6130,"and send it over to me."],[6200,6310,"Don't you two live together?"],[6310,6423,"What's the rush to see her?"],[6423,6520,"She lied."],[6540,6620,"What?"]],"11":[[0,210,"Let's see how she explains this."],[1033,1143,"How did you get hurt?"],[1170,1270,"Oh."],[1310,1523,"I got hit by a bike messenger"],[1523,1653,"while making a delivery today."],[1670,1723,"Wait a minute."],[1723,1778,"I thought you said"],[1778,1930,"that you were at the flower shop all day."],[1930,2026,"How did you get hit"],[2026,2173,"by a bike messenger?"],[2186,2416,"Why is he suddenly questioning me like this?"],[2563,2673,"Is something wrong?"],[2706,2826,"In my restaurant,"],[2876,3146,"some other guy,"],[3243,3316,"and"],[3433,3603,"kissing your hand."],[3643,3803,"Oh, he saw Cooper."],[3833,3966,"Thank goodness."],[4023,4173,"That was just a client."],[4200,4276,"He promised me a big,"],[4276,4373,"long-term contract."],[4456,4656,"So, kissing hands for contracts?"],[4756,4966,"It was just a polite hand kiss."],[5066,5196,"That seemed like it wasn't anything,"],[5196,5260,"but..."],[5320,5456,"polite."],[5540,5670,"Are you jealous?"],[5710,6000,"No, of course not."],[6023,6113,"Alright, Dylan."],[6220,6440,"I've had a long day at work, so..."],[6563,6660,"I'm gonna take a shower"],[6660,6863,"and head to bed."],[7070,7173,"That silhouette..."],[7300,7510,"No, it can't be..."],[7520,7700,"I need you to look into something for me."]],"12":[[470,570,"Hi, I want to buy these."],[570,680,"Oh, yes."],[800,900,"Thank you."],[900,1000,"Have a good day."],[1053,1150,"Hello."],[1233,1393,"Do you want this wrapped or not?"],[1423,1560,"Whatever you think it's best."],[1780,1983,"Why has business gotten so good lately?"],[2410,2460,"Hello."],[2460,2583,"This is Alyssa's Flower Shop."],[2583,2680,"How can I help you?"],[2700,2857,"Please just make sure to deliver it"],[2880,2980,"as soon as possible."],[2980,3090,"Yes, of course."],[3720,3810,"How is it going?"],[3810,3930,"How many orders are done?"],[4000,4130,"We almost finished here."],[4420,4583,"Why did you use the boss's address?"],[4663,4780,"I told you..."],[4830,4910,"I don't care who."],[4910,5030,"Just fix it."],[5350,5473,"It should be around here."],[5793,5903,"The houses in this rich neighborhood"],[5903,6040,"are so hard to find."],[6390,6457,"Dylan!"],[6900,7060,"What are you doing here?"],[7120,7250,"I..."],[7270,7360,"Great question."],[7380,7580,"Why would a small-time restaurant owner"],[7580,7803,"be in a top-tier, wealthy neighborhood?"],[7840,8010,"I'm delivering food."],[8263,8370,"You're going there, too?"],[8383,8633,"Oh, you're delivering this here too?"],[8633,8756,"The person that ordered these flowers"],[8756,8860,"is at the same address."],[8860,8960,"We should go together."],[9280,9542,"Those idiots used my home address."]],"13":[[23,153,"What took you so long?"],[180,300,"Watch it!"],[360,500,"Or I'll have to file a complaint"],[500,581,"next time."],[650,750,"He's only a little late."],[750,880,"You're being way too harsh."],[890,1080,"Miss, your flowers are so beautiful."],[1080,1273,"And the delivery was so fast."],[1300,1520,"I'm definitely ordering from your shop again."],[1540,1640,"Here's a tip."],[1680,1773,"This much?"],[1773,1933,"We only charge a 10% delivery fee."],[1990,2150,"What about him? Where's his tip?"],[2184,2490,"Uhm... Right..."],[2513,2590,"His tip."],[2610,2790,"I... I don't need any."],[2940,3080,"Okay. Never mind then."],[3090,3190,"Why not?"],[3190,3293,"You earned it."],[3293,3453,"It's fine, really."],[3530,3715,"You can't run a business at a loss."],[4910,4963,"You know,"],[5020,5210,"the flower shop is too exhausting."],[5260,5363,"Why don't you sell it?"],[5413,5570,"I make enough money for the both of us."],[5610,5760,"By selling pizzas every day?"],[5780,5930,"Well, also, I have..."],[5930,6070,"you know, some..."],[6233,6300,"It's the shop."],[6450,6620,"Come back immediately."],[6635,6748,"The intel has been confirmed"],[6748,6945,"to be in the Norton family's hands."],[7620,7800,"That waiter and the fire alarm"],[7800,7970,"were definitely suspicious."]],"14":[[433,490,"What?"],[646,770,"Stunned by my good looks?"],[863,1070,"Yeah, I'm totally speechless."],[1170,1333,"Why am I overthinking?"],[1350,1480,"Something came up with the shop."],[1560,1670,"I have to head out."],[1880,1960,"See you tonight."],[3490,3571,"It looks humble,"],[3571,3715,"but it was Mom's pride and joy."],[3740,3790,"No, it's..."],[3790,3880,"It's beautiful,"],[3933,4073,"but also very fragile."],[4100,4230,"Just like your mother."],[4280,4440,"Don't talk about Mom like that."],[4513,4653,"I'm not belittling her."],[4670,4760,"I just blame myself"],[4760,4883,"for not being able to protect her."],[4940,5013,"Father."],[5047,5153,"I just don't want you to be"],[5153,5290,"as naive as she was,"],[5330,5436,"thinking that running away"],[5436,5530,"could solve everything."],[5560,5683,"I'll get you the intel back"],[5683,5807,"from the Norton family."],[5830,6020,"I hope you can keep your promise too."],[7703,7816,"Derek Norton's mansion"],[7816,7943,"is in the West District,"],[7943,8066,"heavily guarded"],[8066,8213,"with a tight security system."],[8240,8443,"A direct breach is too risky."],[8453,8611,"The best approach is to find"],[8611,8760,"the right opportunity."],[8820,8957,"So."],[8957,9206,"this is the home of Father's nemesis,"],[9206,9300,"Derek Norton."],[9418,9610,"I delivered flowers to this place."],[9643,9760,"What are the odds?"],[10083,10153,"-You? -You?"]],"15":[[520,650,"What are you doing here?"],[650,788,"I'm here to pitch business."],[788,897,"They bought a lot of flowers"],[897,969,"from me last time,"],[969,1120,"so, I thought I'd try my luck"],[1120,1223,"and see if I could get more orders."],[1223,1300,"What about you?"],[1393,1490,"I..."],[1490,1693,"I'm here catering the events."],[1730,1856,"Looks like they were really happy"],[1856,1960,"with our service last time."],[1960,2063,"Yeah,"],[2110,2250,"hard work pays off!"],[2700,2900,"You look stunning in this gown."],[2980,3123,"You look handsome, too."],[3373,3473,"Oh, no,"],[3473,3620,"my gun's in my pocket."],[3920,4020,"My decoder!"],[4063,4143,"What do I do?"],[4183,4340,"I need to focus on the mission."],[4420,4488,"Boss."],[4830,4890,"Yeah."],[4910,5090,"The catering boss."],[5180,5260,"What is it?"],[5310,5540,"Are we running low on desserts?"],[5548,5656,"Huh?"],[5670,5774,"Uh..."],[5850,5900,"Boss,"],[5930,6050,"we're running low on drinks."],[6090,6180,"Can you go restock?"],[6240,6460,"Sure, I can handle it."],[6540,6623,"I'm gonna be in the kitchen"],[6623,6723,"for a bit."],[6750,6933,"Go ahead. Yeah, I'll be fine."],[7790,7882,"Boss,"],[7882,8010,"what is Alyssa doing here?"],[8050,8160,"She said she's here to"],[8160,8340,"drum up business for her flower shop."],[8530,8670,"Is the bait set up yet?"],[8680,8760,"Don't worry."],[8760,8900,"Once they step in here tonight,"],[8930,9003,"they won't be leaving."],[9083,9300,"Boss. Bad news."],[9300,9380,"It's been stolen."]],"16":[[210,320,"How is this possible?"],[323,387,"No one showed up"],[387,490,"in the surveillance footage."],[510,590,"We've been played."],[700,890,"They must've altered the surveillance feed."],[930,1020,"What we saw"],[1083,1160,"wasn't real."],[1803,1940,"Everything you wanted is here."],[1960,2033,"Excellent."],[2043,2127,"I've already contacted"],[2127,2260,"the military representative."],[2300,2438,"Once we hand this over,"],[2463,2593,"they'll give all business operations"],[2593,2713,"in Atlanta to us."],[2713,2826,"And they'll help us take down"],[2826,2920,"the North family, right?"],[2920,3090,"-Of course. -That's great."],[3123,3203,"You won't have to worry about"],[3203,3383,"your business being sabotaged anymore."],[3470,3763,"Then can I go live a normal life"],[3763,3830,"with Dylan?"],[4040,4220,"If you truly love him, then go."],[4293,4350,"Really?"],[4393,4560,"Just remember, if he treats you poorly,"],[4673,4783,"I will break his neck."],[5073,5220,"Then I'll go tell Dylan"],[5220,5350,"the good news right away."],[5910,5980,"Dylan."],[6070,6251,"Now I can give you my answer."],[6303,6463,"I can marry you."],[6780,6946,"This is the partially restored"],[6946,7023,"surveillance footage."],[7080,7300,"Whoever she is, she's very careful."],[7360,7493,"No clear facial features."],[7493,7593,"Just this glimpse."],[7920,8240,"She must be celebrating her success right now."],[8250,8513,"She probably has no idea that we let her win."],[8620,8753,"Initiate Plan B."],[8963,9173,"I can't wait to see the look on her face"],[9233,9475,"when she realizes she's been caught."]],"17":[[1110,1180,"Hey."],[1323,1443,"Why did you leave early?"],[1573,1753,"I looked for you after the event."],[1813,1921,"Figured that we would"],[1921,2033,"go home together."],[2073,2236,"I walked around and look for clients"],[2236,2324,"but I couldn't find any,"],[2324,2523,"so I came back first."],[2793,2896,"So,"],[2993,3153,"what do you want first?"],[3163,3236,"Dinner?"],[3323,3393,"Or me?"],[3413,3657,"You really didn't go anywhere else?"],[3663,3793,"What's wrong?"],[3793,3866,"Nothing."],[4036,4316,"Maybe, I'm just tired from work."],[4363,4570,"No, it can't be Alyssa."],[4653,4903,"So, you mentioned"],[4903,5093,"you wanted to get married last time."],[5223,5356,"Does that offer still stand?"],[5356,5466,"Of course."],[5470,5613,"Then we better start preparing."],[5806,5930,"I don't wanna wear a wedding dress"],[5930,5986,"in the winter."],[6100,6226,"Are you saying what I think"],[6226,6310,"you're saying?"],[10683,10750,"Boss,"],[10770,10910,"the fish has taken the bait."],[10910,11000,"Emergency."],[11000,11110,"Come back immediately."]],"18":[[90,175,"I totally forgot"],[177,278,"I scheduled an electrician"],[278,379,"to fix the wiring at the shop."],[379,466,"I need to get there fast."],[466,510,"You know what,"],[510,585,"the flour and butter"],[585,670,"are being delivered today."],[670,800,"I gotta sign for it, so..."],[2400,2530,"What's the problem?"],[2610,2673,"This."],[2790,2976,"The other party has specifically"],[2976,3180,"requested to deal with the \"Bloody Rose\"."],[3248,3340,"With me?"],[3350,3420,"Why?"],[3490,3583,"They've heard a lot about you."],[3700,3760,"They're curious"],[3760,3880,"after learning all that you took"],[3880,3953,"from the Nortons."],[3990,4067,"Dad, you said that"],[4067,4203,"this was the last job."],[4203,4290,"I know, Aria,"],[4343,4560,"but technically, the job's not finished."],[4660,4829,"Complete this and you can have"],[4829,4930,"what you want."],[5103,5200,"Fine."],[5373,5496,"I've arranged for the contact"],[5496,5620,"to specifically request"],[5620,5750,"the \"Bloody Rose\" for delivery."],[5793,5963,"There's no way she'll escape this time."],[6253,6320,"Come in."]],"19":[[950,1030,"-You? -You?"],[1085,1171,"Boss,"],[1171,1270,"what is Alyssa doing here?"],[1333,1480,"What are you doing here?"],[1790,1940,"How foolish was that."],[1990,2133,"You're the \"Bloody Rose\"."],[2180,2330,"Dylan, what are you doing here?"],[2370,2653,"Were you expecting the military contact?"],[2710,2900,"That was supposed to be a trap"],[2943,3070,"for the \"Bloody Rose\"."],[3070,3240,"Dylan, what are you talking about?"],[3240,3373,"Alright, stop"],[3470,3603,"calling me Dylan."],[3690,3980,"My name is Derek"],[4043,4220,"Norton."],[4220,4403,"Derek Norton?"],[4493,4643,"The heir to the Norton family?"],[4703,4800,"And you?"],[5230,5370,"You"],[5370,5843,"are the DeVille family's \"Bloody Rose\"."],[5870,5977,"Why?"],[6005,6130,"How did this happen?"],[6173,6473,"You altered the surveillance footage."],[6500,6662,"She said she's here to drum up business"],[6662,6780,"for her flower shop."],[6840,7043,"I thought you were admiring"],[7043,7263,"the flowers in the basement bar,"],[7263,7320,"but instead,"],[7320,7707,"you were in my office stealing the intel!"]],"20":[[420,723,"You're lying to me all along."],[723,950,"The gentle flower shop owner?"],[1020,1169,"While you're arranging flowers,"],[1169,1250,"you seem to be really"],[1250,1413,"skilled with a blade, too."],[1580,1740,"Can't handle a gun, huh?"],[1740,1915,"Specializes in Chinese cuisine?"],[1915,2096,"I actually believed your nonsense!"],[2096,2223,"When were you gonna tell me"],[2223,2320,"the truth?"],[2320,2460,"After the wedding?"],[2460,2553,"Or were you never planning on"],[2553,2630,"marrying me."],[2660,2800,"I was being played like a fool!"],[3133,3323,"As if I'd marry a liar like you!"],[3506,3626,"So all that marriage talk, huh?"],[3636,3748,"It was just a lie."],[3748,3856,"You tell me."],[4926,4986,"Really?"],[5046,5153,"I don't wanna wear a wedding dress"],[5153,5225,"in the winter."],[5225,5376,"It'll ruin the outdoor photos."],[5456,5563,"And it'll help us take down"],[5563,5686,"the Norton family, right?"],[5686,5766,"Of course."],[6246,6346,"God."],[6346,6426,"Dammit!"],[6646,6886,"I can't believe I fought with my father for you."],[6936,7066,"For you of all people."],[7066,7180,"What are you talking about?"],[7226,7319,"What did you say about me?"],[7319,7450,"It's all in the past now."],[7520,7620,"All of it."],[7666,7806,"Go to hell, you liar!"],[7960,8070,"Will you marry me?"],[8080,8205,"Spend every day"],[8205,8385,"and every night together,"],[8385,8486,"side by side."],[8866,8976,"What is this?"],[9360,9430,"Justin,"],[9470,9620,"I'm bringing you"],[9646,9796,"the Bloody Rose."],[10346,10520,"Boss, Alyssa..."],[10520,10646,"What did she do now?"],[10706,10876,"She broken the window and tried to escape."],[10876,11046,"She hurt herself in the process."],[11446,11676,"I told you to keep an eye on her!"]],"21":[[450,613,"I don't think you can provoke me"],[613,696,"into killing you."],[696,816,"Don't think you can use me"],[816,1000,"as leverage against my father."],[1046,1250,"The Deville family doesn't bow to threats."],[1296,1416,"Threats?"],[1516,1736,"Oh, he's in no condition to be threatened."],[1776,1926,"He's already done for."],[1926,2071,"And I didn't have to lift a finger."],[2071,2193,"What do you mean?"],[2193,2370,"You want me to tell you?"],[2386,2556,"Then keep quiet."],[2560,2706,"Stop causing trouble"],[2706,2803,"and stop making everything"],[2803,2940,"so difficult for me."],[2940,3236,"And maybe, just... maybe,"],[3356,3434,"I can tell you when I'm"],[3434,3506,"in a better mood."],[3926,4046,"Get a doctor here now!"],[4446,4510,"Boss,"],[4510,4639,"what are you planning on doing with her?"],[4716,4826,"She can't die."],[4846,4920,"I won't allow it."],[4920,5060,"So, go watch her"],[5060,5230,"and make sure she doesn't escape."],[5606,5810,"Are you able to move your right arm?"],[5836,5883,"I don't think"],[5883,5986,"there's anything fractured."],[7520,7876,"Hey, the DeVille girl escaped alone."],[7886,7970,"Good."],[7970,8140,"I've been waiting for this day"],[8140,8246,"for a long time."]],"22":[[480,840,"What do we have here?"],[1510,1693,"I'm not like that idiot Derek,"],[1693,1913,"keeping a threat like you alive."],[1913,2250,"However, I won't let you die too quickly."],[2310,2490,"How should I make you suffer?"],[2580,2722,"Let her go."],[2739,2845,"Father?"],[2850,2923,"Do you know what I do"],[2923,3043,"to disgusting scum like you"],[3043,3170,"that try to hurt my daughter?"],[3220,3353,"The little life you have left"],[3353,3483,"will be begging me to end it."],[3553,3820,"On the contrary, Mr. Deville..."],[3900,4110,"I believe it is you who will be begging."],[4600,4653,"No!"],[5230,5319,"That's what you get"],[5319,5470,"for making a fool of me."],[6550,6719,"Be strong..."]],"23":[[110,233,"Alyssa!"],[370,460,"Alyssa!"],[503,543,"Quick!"],[543,693,"Get the anesthesiologist ready."],[693,860,"We need to operate immediately!"],[1143,1240,"Boss,"],[1240,1351,"you really should rest."],[1360,1483,"You haven't slept in over a day."],[1510,1720,"Do we have any word on that bastard Andy?"],[1740,1870,"Latest intel says he was spotted"],[1870,1980,"near the Mexican border."],[2013,2180,"Contact the local gangs."],[2283,2543,"Ten million to whoever catches him."],[2560,2650,"Got it."],[2683,2820,"She's awake."],[3423,3540,"Who are you?"],[3540,3690,"She has a minor issue here."],[3780,4056,"To be precise, she's..."],[4056,4170,"lost her memory."],[4510,4783,"You... don't know who I am?"],[4840,4980,"Do we know each other?"],[5450,5560,"I'm..."],[5820,5913,"I'm your fiancé,"],[6043,6140,"Dylan."],[6140,6240,"Fiancé?"],[6240,6307,"Yeah."],[6440,6530,"We've been living together"],[6530,6623,"for a few months."],[6730,6856,"And we were gonna get married"],[6856,6940,"at the end of June."],[7020,7133,"Living together?"]],"24":[[510,610,"This place"],[670,813,"feels so familiar."],[1743,1853,"I've been here before."],[2220,2316,"My head hurts."],[2403,2520,"I can't remember now."],[2770,2843,"Don't..."],[2913,3030,"force yourself."],[3093,3200,"Just get some rest."],[3240,3353,"Maybe your memory will come back"],[3353,3433,"in a few days."],[4483,4580,"Dylan?"],[5060,5210,"I heard a noise."],[5210,5280,"I... I thought"],[5280,5443,"there was a burglar."],[5443,5523,"A burglar?"],[5680,5760,"Did you see anyone?"],[5780,5830,"No."],[5910,5973,"There's nothing."],[6093,6213,"Then get some rest."]],"25":[[1380,1530,"Are you feeling any better today?"],[1693,1993,"I still can't remember."],[2010,2096,"You said we were supposed"],[2096,2233,"to get married in June."],[2290,2463,"Why don't I have any memory of that?"],[2533,2780,"Because we..."],[2810,3016,"we were planning on getting married"],[3016,3114,"in Florida,"],[3170,3304,"and living there afterwards."],[3304,3400,"That's probably why"],[3400,3580,"it doesn't seem familiar."],[3603,3700,"Florida?"],[3733,3943,"You loved the scenery there,"],[4033,4200,"so we bought an estate."],[4303,4450,"All the wedding plans were made there."],[4530,4653,"I see."],[4940,4980,"How about this?"],[4980,5300,"Why don't we go to Florida tomorrow?"],[5310,5450,"Maybe the familiar environment"],[5450,5580,"will help you with the memories."],[7143,7293,"Are we going to live here?"],[7323,7483,"I still have some work to do in Atlanta,"],[7526,7636,"so I have to head out soon."],[7696,7770,"Oh..."],[7823,7890,"okay."],[7973,8036,"Sweetheart."],[8153,8333,"Relax and rest up."],[8433,8623,"I can join you once I'm done with work."],[8666,8813,"Please, follow me."]],"26":[[103,253,"This is a detailed report"],[253,340,"on Alyssa's activities"],[340,470,"over the past few days."],[474,555,"It really does seem like"],[555,700,"she has no memory of anything."],[733,823,"It doesn't look like an act."],[1290,1400,"Good."],[1400,1753,"What's the situation with the DeVille family?"],[1753,1880,"John DeVille is still in a coma."],[1880,2020,"And Cooper from the Francis family"],[2020,2130,"has been taking care of him."],[2193,2270,"Cooper."],[2290,2387,"Should we leak the information"],[2387,2473,"that Alyssa is in our hands?"],[2473,2540,"No."],[2590,2690,"Let's wait."],[2700,2800,"As long as she's with me,"],[2800,2946,"then we have an opportunity"],[2946,3000,"to exploit"],[3000,3173,"the DeVille family's weaknesses."],[3380,3433,"Mm-hmm."],[3516,3600,"Okay,"],[3663,3780,"I'll report it to him."],[3823,3910,"Boss,"],[3950,4150,"Alyssa has insisted on going out shopping."],[4253,4490,"Tina couldn't stop her. She had to follow her."],[4490,4593,"Maybe it's time to head back"],[4593,4693,"to the estate."],[5063,5210,"Sir, you won't believe it."],[5210,5372,"Today, I saw Alyssa beat up a thug"],[5372,5427,"on the street."],[5427,5493,"She was like..."],[5650,5906,"Has she regained her memory?"],[5933,6063,"Where is she now?"]],"27":[[1493,1570,"Dylan!"],[2260,2400,"What's wrong?"],[2400,2480,"Uh, sorry."],[2480,2780,"I just didn't wanna get my work clothes wet."],[2800,2964,"Oh, okay."],[2964,3057,"Well, let me go dry off"],[3057,3220,"so I can give you a proper greeting."],[3220,3520,"She doesn't seem like she's having a memory."],[3543,3643,"So why does she..."],[3643,3783,"Are you coming?"],[5893,5970,"No."],[6050,6223,"She's the DeVille family's"],[6223,6310,"\"Bloody Rose\"."],[6373,6613,"Don't be fooled by her temporary facade."],[7273,7380,"What's wrong?"],[7440,7590,"Why are you going out this late?"],[7603,7686,"I just remembered"],[7686,7760,"that there's something urgent"],[7760,7890,"at the office, so..."],[7943,8110,"I had to take the next flight back."],[8120,8260,"When will you be back?"],[8280,8340,"A few days."],[8450,8530,"Okay."]],"28":[[33,133,"I'm not eating."],[190,279,"He lied to me."],[279,430,"He said he'd come back, but he didn't."],[430,613,"And I'm not eating until he does."],[2686,2826,"Dylan? You're really back!"],[2990,3136,"Why are you crying?"],[3170,3356,"I feel so lonely."],[3356,3546,"I have no memory and no one I can trust"],[3546,3766,"except for you, and you're never here."],[3766,4046,"Is this all just a ruse from the \"Bloody Rose\""],[4046,4246,"or can we truly forget our entire past"],[4246,4426,"and start our future together?"],[4526,4630,"I won't leave you again."],[4776,4876,"Really?"],[4910,5010,"Of course."],[8746,8846,"Your phone."],[8886,8980,"It's Emma."],[9140,9306,"I need to take this call."],[9846,10020,"You're coming to the estate?"],[10020,10126,"Did you forget?"],[10126,10242,"I spent my birthday"],[10242,10406,"at the estate every year."],[10406,10666,"Oh, no, I really forgot."]],"29":[[750,793,"I'm sorry."],[793,986,"I think the heat was too high."],[1043,1143,"It's fine."],[1260,1370,"It's delicious."],[1393,1473,"Really?"],[1476,1583,"Um-hum."],[1643,1779,"Emma hosts her birthday party"],[1779,1890,"at the estate every year."],[1970,2140,"With so many guests at the event,"],[2140,2277,"what if someone recognizes Alyssa?"],[2277,2353,"Alyssa,"],[2460,2560,"if you're bored,"],[2560,2723,"we can go to the seaside for a change."],[2783,2933,"That sounds great."],[2970,3116,"How about we leave tomorrow?"],[3133,3223,"Tomorrow?"],[3540,3643,"I'm sorry."],[3660,3856,"I didn't expect work to get so crazy."],[3933,4063,"You don't have to apologize."],[4063,4153,"I understand."],[4210,4273,"Have fun."],[4950,5030,"Boss,"],[5030,5156,"your mother's plane has landed."],[5273,5393,"Here's the list and the schedule"],[5393,5463,"for the party."],[5880,6050,"Why is Olivia on this list?"],[6910,7050,"Oh, my dear son,"],[7050,7230,"I've missed you so much."],[7440,7606,"I've missed you, too."],[7640,7753,"Long time no see, Derek."],[8763,8920,"Let me take those to your room."],[8950,9093,"I can get them by myself."],[9140,9280,"Why don't you talk to Olivia?"],[9280,9380,"I'm sure you two"],[9380,9540,"have a lot of catching up to do."],[9593,9738,"I've told you my feelings for her"],[9738,9881,"are in the past."]],"30":[[1800,1936,"Why are you here?"],[1980,2140,"Shouldn't you be at the party?"],[2160,2260,"Emma sent me to come"],[2260,2363,"and fetch you, but..."],[2433,2550,"I wanted to let you know"],[2550,2750,"that I'm here for you."],[2903,3130,"I shouldn't go on some fun relaxing trip"],[3130,3226,"while he has to stay"],[3226,3356,"and work so hard."],[3420,3540,"I should go back and help him."],[3540,3603,"Driver,"],[3686,3763,"please turn around."],[3933,4050,"Ever since we broke up,"],[4050,4171,"I haven't been able"],[4171,4340,"to stop thinking"],[4340,4460,"about you even for a moment."],[4483,4616,"Let's start over, darling."],[5353,5440,"Olivia."],[5513,5683,"Whatever happened between us,"],[5730,5880,"it's in the past."],[5976,6050,"Oh, no."],[6103,6159,"Are you sure"],[6159,6320,"you don't feel anything for me anymore?"],[6333,6460,"You're overthinking it."],[7880,8038,"Emma said Dylan hasn't been"],[8038,8180,"feeling that well lately."],[8223,8290,"Here."],[8333,8430,"This is his favorite."]],"31":[[1253,1410,"Why"],[1413,1690,"does it feel suddenly so hot?"],[2040,2173,"May I join you?"],[3010,3110,"I'll make you fall in love"],[3110,3223,"with me again."],[3370,3560,"Get... get out."],[4213,4383,"Are you sure you want me to leave?"],[4820,4893,"Wait."],[4990,5100,"Maybe I can be romantic"],[5100,5216,"and surprise him."],[5273,5413,"I'll sneak in through the back."],[5850,5940,"Alyssa?"],[6020,6150,"What are you doing back so soon?"],[6210,6300,"Where is Dylan?"],[6363,6433,"He's resting."],[6463,6583,"Maybe I can call you when he wakes up."],[6590,6670,"That's okay."],[6670,6750,"I need to see him now."],[6750,6814,"Wait."]],"32":[[510,630,"Get... get out."],[680,833,"Are you sure you want me to leave?"],[1100,1196,"I said get out!"],[1423,1490,"Alyssa?!"],[1710,1813,"Did I hurt you?"],[1836,1956,"Who did you think I was?"],[1970,2062,"Ugh..."],[2070,2166,"No one."],[2180,2320,"I was having a nightmare."],[2370,2498,"How come you came back so early?"],[2560,2743,"What? Are you not excited to see me?"],[2790,2940,"No... of course I am."],[3030,3127,"I just thought you would've been"],[3127,3243,"enjoying yourself."],[3300,3354,"I knew I couldn't"],[3354,3521,"enjoy myself without you by my side,"],[3521,3633,"so I came back."],[3923,4043,"I feel the same way."],[4373,4513,"What's this?"],[4660,4763,"I dropped by the store"],[4763,4873,"and got you a little present."],[6776,6906,"Let go of me!"],[6946,7066,"Do you know who..."],[7630,7699,"Does Dylan have"],[7699,7778,"something going on"],[7778,7840,"with that woman?"]],"33":[[1770,1866,"We've confirmed it."],[1930,2067,"Alyssa is indeed John DeVille's"],[2067,2130,"only daughter"],[2130,2287,"and the heir to the DeVille family."],[2330,2519,"Also, he has arranged the marriage"],[2519,2686,"for the youngest son of the Francis family."],[2783,2846,"Cooper?"],[2863,2910,"Yes."],[2990,3155,"John DeVille wants to join forces"],[3155,3253,"with the Francis family"],[3253,3410,"to control West District's business."],[3576,3766,"Son of a bitch!"],[4043,4150,"Alyssa,"],[4180,4327,"is this your true heart"],[4420,4601,"or is this all one big lie?"],[4850,4979,"Olivia's been sent back."],[5003,5137,"Make sure I never see her again."],[5210,5293,"I can't believe"],[5293,5413,"that she drugged me."],[5453,5573,"I know you don't wanna hear this,"],[5630,5730,"but everybody believes"],[5730,5858,"that John Deville was taken down"],[5858,5913,"by your order."],[5993,6063,"And Alyssa…"],[6063,6113,"Enough."],[6180,6230,"I know."],[6300,6345,"And that's why"],[6345,6553,"we've got to catch that traitor, Andy."],[7170,7288,"Whose earrings are these?"]],"34":[[240,320,"There has to be"],[320,440,"an answer in here."],[1260,1368,"Today at noon,"],[1368,1523,"I ran into Alyssa on the street."],[1593,1667,"She came with me"],[1667,1783,"to deliver an order."],[1823,1930,"And then we ate sandwiches"],[1930,2050,"she bought by the roadside."],[2150,2530,"It was the best sandwich I've ever had."],[2673,2793,"When was this memory?"],[2883,3100,"Today, I proposed to Alyssa!"],[3190,3310,"Will you marry me?"],[3450,3570,"Let's spend every day"],[3610,3730,"and every night together."],[3810,3930,"I'm such a fool."],[3993,4140,"We clearly are deeply in love."],[4260,4384,"Quick, call the doctor!"],[4500,4593,"How did this happen?"],[4593,4690,"It was retaliation..."],[4690,4770,"Justin!"],[4810,4965,"Retaliation for what?"],[4973,5093,"Uh... ah... nothing."],[5093,5213,"Nothing, it was..."],[5240,5330,"Don't worry."],[5330,5510,"This is just a flesh wound."],[6010,6130,"Just a flesh wound?"],[6240,6329,"This is what happens"],[6329,6443,"when you leave me."],[6474,6576,"Just stay here and let me"],[6576,6640,"take care of you."],[8175,8246,"Ah!"]],"35":[[0,63,"Ugh!"],[183,280,"Let me help you."],[3406,3603,"I'm so sorry I ever doubted you."],[3723,3833,"What for?"],[5213,5343,"Why do you have my mother's earring?"],[5433,5553,"Your mother's?"],[5553,5643,"Yeah."],[5643,5739,"She visited here"],[5739,5853,"not too long ago."],[5886,5983,"I was so jealous."],[5983,6156,"I thought you were with another woman."],[6293,6413,"There's no need to worry."],[6443,6513,"I'm so scared"],[6513,6676,"I'm not gonna get my memories back."],[6716,6833,"It's only when I'm at your side"],[6833,6926,"do I feel at ease."],[6926,7042,"Hey, hey, hey."],[7233,7396,"There is no need to be afraid."],[7483,7603,"I'll always be here for you."],[7703,7871,"Forget Cooper."],[7963,8126,"Forget being the DeVille heir."],[8223,8353,"That's all in the past now."],[8463,8663,"Alyssa is my fiancée."],[8793,8913,"I'll love you"],[9083,9160,"forever."]],"36":[[510,633,"I lost my phone in the store."],[640,692,"Sorry, miss,"],[692,770,"I'll be right back."],[1273,1420,"So, long story short."],[1520,1630,"I'm getting married."],[1630,1750,"You're getting married?"],[1823,1943,"Yeah."],[1950,2107,"And we have got to start"],[2107,2240,"with the preparations right away."],[2263,2460,"We gotta be married before this summer ends."],[2460,2580,"Are you sure this is a good idea?"],[2653,2773,"She's the DeVille family's…"],[2890,3010,"From now on,"],[3040,3163,"she's just Alyssa."],[3253,3390,"She has no connection"],[3393,3513,"to the DeVille family."],[3620,3720,"Also,"],[3720,3960,"make sure no one talks about the past"],[3990,4110,"in front of her."],[4490,4590,"What the hell?"],[4590,4723,"Aria. Stop. It's me."],[4730,4810,"Cooper."],[4810,4930,"Cooper?"],[4970,5090,"Why did you call me Aria?"],[5120,5240,"Because it's your name."],[5273,5430,"You're part of the DeVille family."],[5460,5630,"I'm Cooper, your fiancé."],[5630,5740,"Fiancé?"],[5850,5980,"My fiancé is Dylan."],[5980,6113,"That bastard tricked you."],[6250,6370,"Someone's coming."],[6423,6550,"I have to leave you."],[6600,6690,"Here."],[6890,7030,"Why does this rose emblem"],[7030,7160,"feel so familiar?"]],"37":[[580,700,"Wear this"],[773,840,"and the honor of"],[840,960,"the DeVille family"],[1030,1169,"will be yours to inherit."],[1513,1633,"Father?"],[1820,1940,"Father!"],[2933,3147,"Sir, John Deville has woken up."],[3233,3353,"He actually survived."],[3430,3602,"That's one tough son of a bitch."],[3670,3870,"He has Cooper take over the DeVille family affairs"],[3870,4050,"in Alyssa's name as her fiancé."],[4100,4180,"But the DeVille family"],[4180,4300,"isn't happy with Cooper,"],[4303,4410,"so he's searching everywhere"],[4410,4530,"for Alyssa."],[4690,4818,"We cannot let her"],[4818,4933,"be found by him."],[5126,5166,"Who's there?"]],"38":[[503,746,"Oops, I dropped the glass."],[843,980,"Justin, what are you doing here so late?"],[1023,1143,"I was just leaving."],[1160,1280,"Have a good night."],[1600,1720,"Time to bed."],[1750,1880,"You're always working too hard."],[1960,2080,"Yeah, you're right."],[4903,5090,"Was Cooper telling the truth?"],[5850,5970,"Aria,"],[6050,6180,"you finally remember."],[6180,6286,"No."],[6323,6450,"My memories haven't come back."],[6560,6680,"I have to deal with that later."],[6690,6810,"You need to see your father."],[6833,6953,"My father?"],[6990,7180,"He's unwell, and I'm afraid"],[7180,7296,"if you don't see him now,"],[7296,7430,"you won't have the chance."]],"39":[[443,563,"Aria."],[930,1050,"Avenge me."],[1163,1300,"Protect the DeVille family."],[2330,2450,"I'm sorry."],[2490,2574,"He's gone."],[2903,3023,"Aria."],[3033,3100,"You're my daughter."],[3100,3270,"Now is not the time."],[3420,3483,"Just remember,"],[3483,3603,"if he treats you poorly,"],[3693,3813,"I will break his neck."],[3990,4110,"Let her go!"],[4160,4220,"Father?"],[4303,4373,"No!"],[5070,5133,"Doctor, please"],[5133,5253,"have his body preserved."],[5960,6080,"Where are you going?"],[6240,6370,"To avenge my father."]],"40":[[63,180,"Aria, wait."],[180,350,"You can't take down the whole Norton family"],[350,470,"all on your own."],[470,643,"Do I have to report to you?"],[643,690,"No."],[693,891,"Your father wanted us to work together"],[891,952,"as a team."],[980,1200,"And how do you propose we do that?"],[1210,1376,"If we unite our forces,"],[1376,1560,"we can destroy Derek Norton"],[1560,1640,"once and for all."],[1663,1770,"No, thanks."],[1883,2038,"I can handle this on my own."],[2183,2273,"Aria!"],[2413,2610,"How foolish was I."],[2650,2770,"You're \"Bloody Rose\"."],[2833,3021,"He's in no condition to be threatened."],[3073,3300,"Stop calling me Dylan."],[3350,3480,"Do we know each other?"],[3480,3596,"I'm..."],[3730,3850,"your fiancé,"],[3870,3990,"Dylan."],[4923,5013,"Alyssa."],[5013,5110,"Long time no see."],[5110,5178,"I'm off work now."],[5178,5263,"I gotta go."],[5490,5600,"I need you to do something"],[5600,5660,"for me."],[6383,6503,"Anything?"],[6603,6703,"Well, if you can't find her,"],[6703,6860,"then just pack your bags and leave."],[6860,6920,"Boss,"],[6953,7156,"could Alyssa have regained her memory?"],[7160,7281,"Impossible."],[7370,7428,"I made sure"],[7428,7530,"that nothing around her"],[7530,7659,"reminds her of the past."],[7710,7990,"No, I wouldn't allow it."],[8030,8112,"And how do you explain"],[8112,8243,"her sudden disappearance?"],[8293,8384,"Since losing her memories,"],[8384,8450,"she has been in contact"],[8450,8604,"with no one, except you"],[8623,8710,"and the people around you."]],"41":[[80,253,"Boss, someone named Anthony"],[253,395,"is on the phone for you."],[570,600,"Hello."],[600,720,"Are you Alyssa's friend?"],[853,970,"I am."],[970,1150,"I need you to pick her up."],[1513,1620,"Once you see him,"],[1620,1757,"you better not say a word."],[1770,1890,"I understand."],[2600,2730,"I know you don't love me."],[2820,2987,"You don't have to pretend anymore."],[3040,3200,"You know how I've been the last few days?"],[3200,3320,"I thought you were kidnapped."],[3470,3590,"You liar!"],[3983,4103,"Where did you get these?"],[4200,4360,"So, you're not denying it."],[4373,4590,"No, but I can explain this."],[4773,4980,"I don't wanna hear your excuses."],[5110,5220,"If you don't believe me,"],[5220,5338,"then come back"],[5338,5483,"and check the surveillance footage."],[5483,5593,"Fine."],[5593,5815,"But once I see your ugly truth,"],[5815,5945,"we are through."],[6300,6340,"Hopefully,"],[6340,6471,"this little act will cover up"],[6471,6640,"where I've been these past few days."]],"42":[[513,660,"Sorry, it took so long."],[813,947,"They're handmade."],[967,1107,"Shipped from Italy."],[1280,1403,"Are these dresses for me?"],[1550,1808,"Yes. My beautiful bride."],[1970,2090,"I can't wait to see you in them."],[2320,2440,"I love you"],[2480,2600,"so much."],[2730,2850,"And what about Olivia?"],[4130,4279,"Olivia and I are in the past."],[4490,4610,"All I want..."],[4753,4873,"is you."],[5016,5150,"But she's so beautiful."],[5203,5323,"Don't you regret it?"],[5753,5873,"Not for one second."],[6950,7080,"Who is this poor woman?"],[7173,7358,"Almost marrying her father's killer."]],"43":[[303,423,"As you instructed,"],[433,553,"Olivia has been warned."],[620,691,"Good."],[880,1000,"Where are you going?"],[1043,1163,"Just a last minute trip."],[1250,1370,"Do you need a driver?"],[1370,1563,"No. I'll drive myself, and..."],[1740,1833,"tell the bodyguards"],[1833,1953,"not to follow me."],[3256,3386,"The dress is so beautiful."],[3433,3553,"I couldn't wait to wear it."],[3663,3783,"Let's start our life together now."],[4703,4883,"One. Two. Three."],[4883,4990,"I got one more."],[5540,5673,"I swear."],[5673,5760,"I'll love you"],[5820,5873,"forever."],[5903,6003,"The bastard tricked you."],[6103,6190,"Avenge me."],[6240,6373,"Protect the DeVille family."],[6390,6530,"We cannot let her"],[6530,6650,"be found by him."],[6803,6923,"Dylan."],[7056,7176,"Do you really love me?"],[7223,7352,"Who's been spreading rumors again?"],[7493,7854,"Is there anything else"],[7854,7976,"that you're hiding from me?"],[8133,8253,"I already told you everything."],[8513,8616,"Why don't you believe me?"],[8616,8736,"Then tell me. Dylan."],[8813,8953,"What did you think of me when you were..."],[9103,9213,"Derek Norton?"]],"44":[[30,190,"What did you think of me when you were"],[190,310,"Derek Norton?"],[500,600,"Go to hell, you murderer!"],[1980,2213,"So, I hear you"],[2213,2363,"finished off Derek."],[2380,2500,"A toast is in order."],[3320,3540,"So, have you thought about my proposal?"],[3610,3730,"I told you"],[3800,3950,"I could handle this on my own."],[4060,4210,"I don't need an alliance."],[4360,4480,"You should leave."],[4860,4960,"What are you doing?"],[4960,5080,"What am I doing?"],[5130,5250,"I told you"],[5310,5503,"I'm your fiancé."],[5503,5650,"In your dreams!"],[6113,6203,"You drugged me?"]],"45":[[523,643,"What do you want from me?"],[763,883,"Marry me."],[920,1040,"Never."],[1270,1390,"It's a shame."],[1450,1593,"It seems as though you've forgotten"],[1593,1801,"what business I'm in."],[1880,2040,"Oh, no, no, no."],[2060,2183,"Best behave."],[2280,2370,"We'd hate to end up"],[2370,2565,"like dear old daddy."],[3020,3140,"What do you mean?"],[3178,3291,"What did you-"],[3291,3427,"What did you do?"],[3593,3713,"What I did to him?"],[3773,3825,"Oh, nothing."],[3825,3943,"Really."],[3950,4123,"Just sent him to an early grave."],[4303,4387,"Bang!"],[4520,4610,"Just like that."],[4740,4834,"And you thought it was"],[4837,4953,"one of the Nortons?"],[5110,5243,"Spectacular."],[5443,5590,"And by this time tomorrow,"],[5660,5785,"I will be one of the heirs"],[5785,5910,"to the DeVille fortune."],[6040,6202,"Doesn't that sounds perfect?"],[6560,6672,"Can you hear that?"],[6771,6936,"Sounds like wedding bells."]],"46":[[150,280,"Aria DeVille."],[333,480,"Do you take Cooper Francis"],[480,673,"to be your lawfully wedded husband,"],[730,893,"to have and to hold,"],[893,1080,"for better or worse,"],[1103,1273,"till death do you part?"],[1273,1380,"I..."],[1620,1670,"I..."],[1670,1740,"No!"],[1840,1903,"She doesn't."],[2070,2210,"You're supposed to be dead!"],[2233,2353,"I was sorry to disappoint you."],[2400,2520,"No matter."],[2773,2893,"Where is everybody?"],[2910,3030,"It's over, Cooper."],[3060,3163,"You're surrounded."],[3270,3380,"Don't get cocky!"],[3530,3650,"My gun."],[3660,3780,"Looking for this?"],[4073,4193,"When did you sober up?"],[4233,4437,"I do know what business you're in."],[4570,4723,"I've had the antidote in me"],[4723,4843,"this whole time."],[4923,5043,"You two were in it together?"],[5190,5310,"But how?"],[5790,5960,"Why can't you trust me?"],[5960,6080,"Trust you?"],[6100,6170,"Not long ago,"],[6170,6330,"my father died in my arms,"],[6333,6440,"shot by your men."],[6440,6553,"How can I trust you?"],[6553,6680,"I didn't kill him!"],[6813,6910,"It was Andy."],[7010,7130,"It's a trap."],[7170,7336,"And I had to brought him back from Mexico."],[7400,7530,"If you can..."],[7576,7674,"If you can trust me..."],[7674,7803,"just trust me one more time."],[7803,7930,"I could explain everything."],[7933,8090,"You're still trying to lie to me!"]],"47":[[20,97,"Yes."],[140,266,"Yea, okay?"],[350,480,"I wanted to lie to you."],[563,722,"I wanted you to forget everything"],[722,900,"and just be by my side."],[1013,1133,"I was afraid"],[1133,1290,"if someone was gonna say something to you,"],[1300,1413,"you were going to remember everything,"],[1413,1533,"and then you were gonna leave me."],[1740,1860,"So, please."],[2023,2150,"Just kill me."],[2150,2250,"Because..."],[2350,2470,"I can't watch you leave."],[2603,2723,"You're insane."],[2933,3170,"Yes, I'm crazy."],[3580,3740,"I'm so crazy in love with you,"],[3943,4153,"and you still refuse to trust me."],[5223,5343,"Mr. Norton,"],[5360,5450,"Ms. DeVille."],[5450,5649,"I beg you. Spare me."],[5649,5794,"It was all Cooper's idea."],[5794,5910,"He made me do it."],[5929,6023,"Cooper?"],[6050,6170,"He came to me."],[6203,6338,"He said that we should take out"],[6338,6506,"your father together."],[6600,6727,"And once he had his hands"],[6783,6970,"on the DeVille family's assets,"],[6970,7141,"he promised to help me"],[7141,7309,"take down the Norton family."],[7350,7470,"Quite a plan."],[7470,7681,"The moment Alyssa escaped,"],[7740,7850,"I tipped him off."],[7850,7980,"He called your father,"],[8013,8110,"John DeVille,"],[8110,8250,"and we ambushed you."],[8310,8430,"Unfortunately,"],[8460,8610,"when John didn't die,"],[8693,8836,"Cooper bribed the doctor"],[8836,8917,"to delay treatment."],[9010,9106,"If you don't believe me,"],[9106,9220,"go ask the doctor."],[9283,9438,"Sir, the doctor's dead."]],"48":[[240,306,"I need to get to"],[306,420,"the bottom of this."],[480,630,"If what Andy says is right,"],[683,765,"I won't let Cooper"],[765,880,"get away with it."],[930,1043,"I'll look into it."],[1048,1126,"No!"],[1233,1318,"My father's death"],[1320,1440,"is mine to avenge."],[1590,1710,"But it's too dangerous."],[1720,1840,"Dangerous?"],[1910,2010,"I'm the DeVille family's"],[2010,2130,"\"Bloody Rose\"."],[2250,2370,"Right."],[2450,2637,"I forgot you're the definition"],[2637,2723,"of danger."],[2760,3001,"Just promise me"],[3050,3170,"you'll be careful."],[3820,4036,"You were lying to me this whole time."],[4075,4145,"No."],[4260,4399,"You were lying to me."],[4530,4677,"You used the guise to work"],[4677,4830,"with my father to murder him."],[4850,4998,"And you'll get what you deserve."],[5040,5320,"I said don't get cocky."],[5410,5530,"If I die,"],[5553,5804,"Emma Norton won't see the light of day."],[5830,5950,"What did you say?"],[6110,6386,"I said Emma Norton's life"],[6386,6570,"is in my hands."],[6643,6763,"Don't believe me?"],[6833,6953,"Give her a call."],[7603,7723,"Put her on the phone."],[7723,7830,"Let me go!"],[7830,8031,"You filthy, despicable cowards!"],[8160,8199,"Hey hey hey!"],[8200,8295,"Aha!"],[8330,8450,"One more move"],[8570,8762,"and I'll blow her brains out."],[8810,8973,"Just do as he says."],[9010,9100,"That's right."],[9503,9600,"Fine."]],"49":[[650,699,"Do you have"],[699,830,"the money and the goods?"],[903,1023,"It's in the other room."],[1033,1153,"Perfect."],[1173,1307,"I'll check the inventory."],[1373,1508,"You keep your eye on these two."],[2410,2540,"It seems as though"],[2540,2690,"I've underestimated you"],[2690,2843,"for the last time."],[2940,3060,"I see why they call you"],[3080,3243,"\"Bloody Rose\"."],[3390,3520,"Any last words?"],[3543,3643,"Yeah."],[3673,3793,"Fuck you!"],[4570,4613,"Darling."],[4613,4753,"Thank you for saving me."],[5130,5243,"Perfect."],[5243,5394,"Just in time to clean up the trash."],[5490,5610,"How did you know we were here?"],[5860,5933,"Fine."],[5990,6163,"We let Cooper capture me on purpose,"],[6163,6290,"so he'd lead us to you."],[6450,6554,"So, now that you two"],[6554,6750,"have everything figured out,"],[6780,6900,"what's next?"],[7410,7661,"Mr. Norton, do you take Ms. DeVille"],[7661,7820,"to be your lawfully wedded wife?"],[7900,8070,"To enter into the covenant"],[8070,8190,"of marriage?"],[8193,8337,"To have and cherish her"],[8337,8543,"in sickness and in health"],[8560,8682,"till death do you part?"],[8830,8920,"I do."],[9013,9251,"Ms. DeVille, do you take Mr. Norton"],[9251,9463,"to be your lawfully wedded husband?"],[9495,9625,"To enter into the covenant"],[9625,9732,"of marriage,"],[9733,9886,"to love and cherish him"],[9886,10080,"in sickness and in health,"],[10100,10220,"till death do you part?"],[10300,10390,"I do."],[10483,10560,"The groom may now"],[10560,10680,"kiss the bride."],[10810,10869,"Wait."]],"50":[[3,190,"Mr. Norton, do you object?"],[210,330,"No!"],[360,480,"No, I don't."],[663,783,"Alyssa,"],[910,1030,"I want you to have"],[1120,1240,"everything"],[1300,1410,"that I have."],[1913,2114,"This gun"],[2220,2340,"represents protection"],[2440,2590,"in honor of my family."],[2873,2998,"And from this day forward,"],[3193,3322,"it will protect you too."],[3920,4039,"Likewise."],[4310,4481,"Let the DeVille family token"],[4490,4619,"protects you."],[4880,4969,"Now the groom"],[4969,5103,"may kiss the bride."],[7510,7550,"Heads up."],[7590,7664,"We've got company."]]}