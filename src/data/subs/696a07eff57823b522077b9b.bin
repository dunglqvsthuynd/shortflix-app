{"1":[[30,83,"Miss,"],[116,236,"the doctor said your husband, Marlon,"],[236,377,"has only ten months left."],[413,460,"When that happens,"],[460,647,"the Stantons will use your lack of children"],[650,710,"to let your step-sister"],[710,837,"marry him with her bastard."],[854,987,"Why aren't you worried at all?"],[1014,1084,"Why should I?"],[1124,1301,"I'll have a child,"],[1341,1538,"so she won't have the chance to marry him."],[2809,2889,"Mr. Stanton."],[3113,3163,"I'm next."],[3256,3336,"I don't fight women."],[3490,3623,"Beat a woman first,"],[3717,3773,"then we'll talk."],[3890,4014,"You don't get to see Mr. Stanton"],[4027,4107,"being challenged by a woman."],[4768,4914,"I won't go hard."],[4951,5068,"When you lose,"],[5115,5195,"don't cry."],[5238,5348,"If I lose,"],[5402,5508,"my chips,"],[5602,5709,"and myself,"],[5762,5885,"are yours to choose from."],[5942,6089,"What if I win?"],[7384,7781,"I want you to sleep with me."],[8128,8541,"Whoever matches with you"],[8678,8885,"can name any bet, right?"],[9009,9139,"But I don't think"],[9175,9305,"you're anything special."],[9315,9366,"Wait."],[9783,9909,"If you lose,"],[10326,10443,"I want your tongue."],[10577,10627,"Deal."],[15291,15358,"Mr. Stanton."],[15418,15545,"A bet is a bet."],[15772,15852,"Tonight,"],[15985,16062,"you're mine."],[17987,18058,"Tell me."],[18181,18344,"Why did you approach me?"],[18695,18818,"It's because"],[19092,19406,"you're hot, Jared."],[19499,19589,"Jared,"],[19601,19766,"I'm borrowing your sperm"],[19766,20020,"to pass the Stantons' paternity test."],[21421,21464,"No."],[21811,21905,"I like this way."]],"2":[[1051,1224,"Pretending to be the cougar?"],[1801,2088,"Find the woman from the pool hall."],[2732,2829,"Emergency delivery!"],[2829,2942,"Make way, everyone!"],[3391,3526,"I told you to find a woman,"],[3526,3653,"but you haven't found her in nine months."],[3653,3737,"What am I paying you for?"],[3837,3903,"From now on,"],[3903,3983,"stop eating rice."],[3993,4067,"Go eat chaff instead."],[4124,4207,"Mr. Jared,"],[4230,4317,"that night at the hotel,"],[4317,4507,"all surveillance footage was wiped clean."],[4581,4784,"She wanted to sleep with you, sir."],[4811,4984,"Why would she refuse to see you?"],[5118,5188,"Why is that?"],[5231,5392,"If I knew why,"],[5442,5545,"would I need you to find her?"],[5602,5879,"Could it be that that night,"],[5909,6019,"you didn't satisfy her?"],[6289,6423,"Your prowess"],[6436,6506,"is unquestionable."],[6569,6793,"She was satisfied that night, right?"],[6976,7070,"Emergency delivery!"],[7070,7220,"Coming through!"],[8181,8251,"Miss Carson,"],[8261,8375,"push harder!"],[8418,8498,"Deep breaths!"],[8594,8664,"Deep breath."],[8825,8898,"Inhale!"],[9239,9309,"Miss Carson,"],[9319,9422,"push harder!"],[9442,9542,"- The baby's crawling! - Ahh!"],[9809,10066,"It hurts like hell!"],[11064,11354,"A big fat boy, seven catties and eight taels!"],[11725,11851,"It's not my child."],[11898,11978,"Why so happy?"],[12028,12202,"It looks like you want to be a father."],[12242,12385,"It's about time you found a wife."],[12402,12589,"Mr. Marlon's illegitimate son is already five."],[12634,12742,"Since you can't find that woman,"],[12743,12820,"who am I supposed to marry?"],[12949,13103,"I'm not as casual as he is."],[13707,13797,"Look, Miss."],[13830,13997,"This child looks so much like you."]],"3":[[1101,1174,"Sir,"],[1201,1324,"no smoking in the hospital."],[1878,1981,"News from the main house."],[2015,2168,"Marlon is fading fast."],[2225,2385,"I'm going back to Switan."],[2489,2649,"I'll give you one more month."],[2712,3009,"If you still can't find her, you're fired."],[3266,3333,"Miss,"],[3390,3516,"the Stantons called."],[3540,3763,"Marlon can't eat anything anymore."],[3800,3943,"He's living on IV fluids."],[3980,4147,"When should we take the baby back?"],[4300,4441,"After Marlon is cremated,"],[4511,4621,"we'll take Bennett"],[4647,4754,"to meet the Stantons."],[4838,4908,"Miss,"],[4978,5171,"what if Marlon made a will in advance?"],[5188,5261,"What do we do?"],[5532,5805,"That guy only loves himself."],[5889,6016,"Making a will early"],[6050,6246,"is like handing his life over to Irene."],[6306,6413,"He wouldn't do that."],[6593,6680,"Marlon,"],[6760,6916,"you've schemed against me for years."],[6960,7137,"It's time I returned."],[8651,8775,"This is Mr. Marlon Stanton's funeral."],[8805,8912,"No outsiders allowed."],[8945,9142,"I am Marlon's wife."],[9172,9396,"How dare you impersonate his wife?!"],[9456,9656,"She just went inside with a child."],[9729,10026,"She went inside with a child?"],[10063,10130,"Sister."],[10336,10400,"Mrs. Stanton."],[10450,10530,"You're back."],[10593,10684,"Irene."],[10744,11041,"You're Marlon's wife?"],[11111,11137,"Yes."]],"4":[[13,420,"You're Marlon's wife?"],[800,870,"Regina,"],[937,1037,"why are you back?"],[1124,1211,"If I hadn't come back,"],[1271,1408,"how would I know Irene"],[1434,1678,"was out here using my identity as Mrs. Stanton?"],[1741,1835,"Throwing her weight around?"],[1945,2005,"Sister,"],[2055,2325,"Andy is Marlon's only child."],[2349,2569,"He'll represent Marlon."],[2589,2749,"That is beyond doubt."],[2891,3203,"The Stantons have already accepted us."],[3266,3520,"I even organized this funeral"],[3540,3843,"in his lawful wife's name."],[3953,4060,"Later,"],[4074,4210,"I'll move into the Stanton family."],[4307,4414,"I advise you"],[4427,4624,"to move out now."],[4674,4814,"Don't make me give you the boot."],[4878,4988,"Throughout history,"],[5018,5185,"I've never seen a mistress"],[5218,5382,"kick the lawful wife out."],[5502,5565,"Alma,"],[5637,5792,"don't you agree?"],[5845,5905,"Regina,"],[5939,6122,"you were married to Marlon for years"],[6122,6232,"without a single child."],[6279,6489,"Luckily, Irene gave Marlon an heir,"],[6506,6700,"which saves our relationship with the Carsons."],[6746,6910,"What right do you have"],[6913,7033,"to call yourself the lawful wife?"],[7060,7103,"You two"],[7103,7307,"feel superior as homewreckers?"],[7420,7550,"You really have no shame."],[7550,7754,"Stop calling her a homewrecker at every turn!"],[7807,7887,"Don't forget,"],[7914,8148,"the one holding the cards now is Irene."],[8194,8288,"Alma is right."],[8331,8568,"You can't produce an heir for the family."],[8605,8832,"We have already recognized Irene and Andy."],[8902,9052,"Get away from them!"],[9105,9159,"Richard,"],[9182,9315,"I've told you more than once,"],[9396,9566,"bastards don't deserve to exist."],[9586,9636,"You!"]],"5":[[533,660,"Regina!"],[704,827,"How dare you hit me?"],[1398,1464,"Regina,"],[1538,1678,"I'm not afraid of death."],[1745,1971,"But I'm afraid that after I'm gone,"],[2012,2178,"no one will protect you."],[2239,2392,"The... the last thing"],[2552,2692,"I can do for you"],[2842,2916,"is to"],[2946,3653,"help you keep the m-marriage alliance."],[3803,3883,"Mom."],[4020,4100,"Mom!"],[4220,4327,"Mom, wake up."],[4404,4461,"Mom!"],[4524,4698,"Mom, wake up!"],[4698,4781,"Mom!"],[4794,5005,"Mom, wake up!"],[5018,5065,"Irene,"],[5168,5245,"listen to me."],[5261,5375,"As long as I'm breathing,"],[5428,5779,"you son will always be a bast*rd!"],[5845,5972,"And your mom stays as a mistress."],[6076,6129,"Regina!"],[6740,6850,"You ungrateful!"],[6946,7017,"Richard,"],[7103,7323,"Sir Stanton is so fond of Regina."],[7364,7467,"He even stated"],[7474,7637,"that she is his only daughter-in-law."],[7670,8001,"Regina wouldn't go to Sir Stanton,"],[8007,8138,"and keep Irene out of the family, would she?"],[8204,8271,"Mom,"],[8321,8435,"she doesn't have a child."],[8475,8605,"No mattter"],[8605,8832,"how much Sir Stanton likes her, it won't work."],[8895,9079,"Marlon's mom won't agree,"],[9079,9225,"and the Stanton Group board"],[9235,9342,"won't approve either."],[9392,9486,"Irene is right."],[9536,9649,"Our Irene entering the Stantons"],[9656,9863,"is a done deal!"],[9966,10023,"Dad,"],[10036,10316,"you can finally bring Mom home."],[10367,10457,"Today,"],[10477,10563,"I'll welcome your mom"],[10603,10730,"into Carsons' Manor!"],[11227,11344,"Regina,"],[11394,11581,"you're no match for me."],[11878,11958,"Miss."],[11985,12125,"Marlon has been buried."],[12175,12308,"Let's take the baby back."]],"6":[[6,270,"How could a woman just vanish into thin air?"],[310,463,"Why haven't you found her yet?"],[2709,2796,"Regina,"],[2819,2932,"you're back."],[2972,3013,"Dad."],[3086,3153,"Dad?"],[3672,3915,"This is Regina, your sister-in-law!"],[3940,4080,"You're Marlon's wife."],[4652,4705,"It's not her."],[4894,5141,"Why were you getting handsy with with her?"],[5368,5439,"Regina,"],[5474,5665,"who is this child?"],[5863,5907,"Dad,"],[6027,6207,"when Marlon was diagnosed,"],[6264,6367,"I got pregnant."],[6411,6454,"He was just born."],[6458,6548,"What did you say?"],[6599,6969,"This is Marlon's child?"],[7197,7320,"That's wonderful!"],[7457,7928,"Marlon has left a legitimate heir."],[8373,8473,"Impossible!"],[8788,8968,"You disappeared for months."],[9048,9245,"Now that Marlon is dead,"],[9345,9556,"you bring back some bast*rd"],[9584,9721,"and claim he's Marlon's!"],[9751,9951,"Are you here for the inheritance?"],[10223,10297,"Mom."],[10564,10628,"Mom,"],[10663,10720,"it's not like that."],[10747,10897,"This really is Marlon's child."],[11074,11151,"Regina,"],[11172,11249,"I'm warning you,"],[11285,11435,"don't play games with me!"],[11474,11597,"Everything Marlon owned"],[11692,11796,"belongs to me."],[11797,12037,"It belongs to my only grandson, Andy!"],[12083,12239,"I'll bring his mother back"],[12305,12509,"with a grand welcome."],[12561,12641,"When that happens,"],[12674,12834,"you can get the hell back to the Carsons!"],[13041,13095,"Mom,"],[13130,13237,"if you don't believe me,"],[13261,13354,"we can get a DNA test."],[13395,13519,"Although Marlon is gone,"],[13585,13759,"my child is Dad's biological grandson."],[13811,14058,"Why not let him have a DNA test with my child?"]],"7":[[24,161,"Although Marlon is gone,"],[173,353,"my child is Dad's biological grandson."],[390,640,"Why not let him have a DNA test with my child?"],[700,760,"Right."],[804,890,"If you don't believe it,"],[934,1224,"I'll take the child for a DNA test."],[1307,1391,"Go get the car."],[1538,1558,"Oh."],[1634,1711,"Regina,"],[1795,2075,"if that child isn't Marlon's,"],[2138,2359,"I'll make you disappear from Switan!"],[3109,3255,"Miss Regina, bad news."],[3266,3360,"Your father has moved Alma Harper"],[3360,3486,"into Carsons' Manor."],[3666,3723,"I got it."],[3910,3963,"Dad,"],[3987,4070,"you and Uncle Jared"],[4080,4184,"take the baby to the hospital."],[4200,4287,"Something came up at home,"],[4287,4361,"I have to go back first."],[4367,4407,"Okay."],[4434,4521,"You can go."],[4657,4691,"Mom,"],[4741,4958,"Alma has given birth to a boy and a girl."],[4998,5245,"And Irene gave the Stantons their first grandson,"],[5265,5475,"solidifying the bond between our families."],[5498,5638,"Those two"],[5665,5929,"are the Carsons' great heroes."],[5969,6042,"That's right."],[6189,6419,"You should move in with us long ago."],[6509,6649,"It's been so unfair to you."],[6666,6743,"If anyone is to blame,"],[6816,6990,"it's that damn girl, Regina,"],[7047,7130,"who stood in the way."],[7217,7277,"Grandma."],[7313,7564,"She won't be able to push us around anymore."],[7711,7917,"Irene, you really are capable."],[8279,8342,"Mom,"],[8405,8518,"please have some tea."],[8641,8762,"Good, good."],[8798,8872,"From now on,"],[8888,9199,"you are officially my daughter-in-law."],[9309,9669,"Who dares to move homewrecks into my house?"]],"8":[[173,253,"You ungrateful!"],[316,423,"What do you want?"],[493,533,"Dad,"],[607,710,"is it true that"],[734,1084,"you're moving Irene and Alma Harper into my house?"],[1117,1284,"Alma is your mother."],[1331,1428,"Who gave you the right"],[1474,1541,"to call her by her name?"],[1558,1644,"My mother is dead."],[1791,1921,"If she wants to replace her,"],[1971,2082,"she has to die first."],[2145,2248,"Regina!"],[2295,2432,"You're cursing my mom?"],[2482,2545,"Grandma,"],[2589,2826,"every single brick of this house"],[2849,2986,"come from my mother's blood and sweat."],[3046,3153,"If you and Dad"],[3173,3410,"move these homewreckers into my house,"],[3423,3556,"I'll burn it to the ground!"],[3683,3730,"You!"],[3777,3967,"You unfilial wretch!"],[3983,4234,"How dare you threaten to burn down the house?"],[4277,4407,"That is outrageous!"],[4421,4477,"Sis,"],[4534,4764,"you used to be the lady of the Stanton family,"],[4774,4924,"everyone respected you."],[4964,5278,"But now they gave you the boot."],[5305,5468,"How could you still disrespect your elders?"],[5502,5615,"How come I didn't know"],[5665,5829,"the Stantons gave me the boot?"],[5892,5959,"Sis,"],[5985,6282,"Andy has already moved into the Stanton family."],[6312,6419,"His grandma"],[6419,6613,"will send someone to pick me up soon."],[6613,6736,"What's more,"],[6746,6840,"she promised"],[6840,7007,"to make me her daughter-in-law"],[7020,7253,"with a grand entrance."],[7323,7487,"You've already been kicked out."],[7504,7701,"Irene is the capable one."],[7724,7891,"She knew to give the Stantons"],[7891,7991,"a grandson early on."],[8021,8191,"She rises with her son."],[8214,8348,"In wealthy families,"],[8348,8535,"it's always been that way."],[8578,8772,"You only have yourself to blame, Sister."],[8812,8992,"You couldn't keep a man's heart,"],[9026,9195,"or bear a child."],[9305,9399,"How do you know"],[9456,9629,"I didn't give the Stantons a child?"]],"9":[[23,126,"How do you know"],[166,313,"I didn't give the Stantons a child?"],[590,670,"Sis,"],[690,810,"you wouldn't go so far as to"],[810,1021,"claim you had Marlon's child"],[1047,1384,"just to keep us out of the family, right?"],[1474,1741,"But Marlon told me explicitly"],[1798,1971,"he never shagged you."],[1995,2108,"He despised you."],[2118,2288,"You're dull in bed."],[2328,2459,"Even so, you and your mother"],[2495,2709,"will always be beneath the legitimate wife,"],[2739,2892,"and you'll never be able to hold your heads up."],[3066,3380,"All you can do now is talk big."],[3430,3683,"Once the Stantons arrive and pick me up,"],[3730,3893,"we'll see if you have the last laugh."],[3967,4034,"Dad,"],[4047,4307,"hurry up and move Mom's things inside."],[4347,4561,"If the Stantons are here"],[4597,4848,"and Mom still has no official status,"],[4874,5021,"it's bad for Andy and me."],[5215,5281,"Alma,"],[5315,5438,"ignore that brat."],[5478,5632,"I'm in charge of this family."],[5692,5809,"You guys, move her stuff inside."],[5972,6062,"Don't you dare!"],[6102,6196,"Regina!"],[6413,6553,"The Stantons are done with you!"],[6569,6713,"They're picking up Irene any minute."],[6723,6936,"If you delay her entry into the family,"],[6963,7077,"I'll make you pay!"],[7143,7213,"Richard,"],[7250,7364,"are you so sure"],[7384,7470,"that the Stantons"],[7470,7634,"are taking Irene home with such honor?"],[7731,7861,"Why bother asking?"],[7897,8194,"Our Irene bore the Stantons' only grandson."],[8221,8401,"They value her."],[8438,8521,"Just ignore her."],[8555,8641,"Keep moving stuff in!"],[9652,9826,"Why aren't the results out yet?"],[9909,9973,"Jared,"],[10010,10140,"hurry the doctor along."],[10226,10316,"What's the rush?"],[10340,10497,"The baby isn't going anywhere."],[10613,10694,"Chairman,"],[10787,10867,"the results are out."],[11378,11611,"It is our family's child."],[11725,11795,"Jared,"],[11831,11978,"it's your older brother's child."],[12399,12649,"Marlon treated Regina so poorly,"],[12649,12769,"yet she held no grudge."],[12839,12976,"She even went away all alone"],[12976,13166,"to give birth to his child."],[13402,13510,"Get the car ready."],[13580,13890,"I'm going to the Carsons' to bring Regina"],[13897,14117,"back to the family with full honors."]],"10":[[193,276,"Richard,"],[333,407,"what about the things"],[407,573,"inside Regina's mother's room?"],[607,677,"What should we do?"],[714,787,"Just throw them out."],[824,914,"Throw it all out."],[954,1047,"It's bad luck."],[1103,1281,"Don't you touch my mom's things!"],[1297,1482,"Let me go! Get off me!"],[1628,1795,"You can't touch my mom's things!"],[3843,4017,"Drink some water and rest a bit."],[4344,4401,"Regina,"],[4484,4674,"I have to finish this proposal today,"],[4724,4898,"so your dad can close the deal tomorrow."],[5251,5405,"Take this and go play for a while."],[5452,5565,"I will come join you soon."],[5635,5668,"Be a good girl."],[5795,5849,"Mom,"],[5915,6036,"is this the man you worked yourself"],[6046,6259,"to death to support?"],[7023,7173,"Don't touch my mom's things!"],[7213,7357,"What 'your mom's things'?"],[7364,7444,"Now,"],[7454,7590,"everything belongs to my mom!"],[8114,8211,"Drive faster!"],[8728,8815,"Irene,"],[8822,8982,"I'll make you and your mother"],[8988,9152,"kneel before my mom's spirit tablet and apologize!"],[9192,9312,"Don't you realize"],[9312,9452,"what your status is right now?"],[9542,9612,"Sir!"],[9619,9743,"Sir Stanton and Mr. Jared are here."],[9766,9849,"They brought a lot of people."],[11264,11388,"What are you doing?"],[11564,11661,"Sir Stanton!"],[11775,11831,"Sir Stanton!"],[11861,11973,"Why did you and Mr. Jared"],[12018,12138,"come here personally?"],[12162,12298,"For my grandson's biological mother,"],[12322,12415,"of course I have to"],[12422,12549,"come in person."],[12632,12751,"The Stantons"],[12756,12896,"value Irene so much."],[13093,13209,"Regina,"],[13226,13336,"do you see that?"],[13396,13603,"Andy's Uncle Jared and Grandpa"],[13620,13777,"came to pick me up personally."],[13830,13917,"You're done for."],[14587,14657,"Sir Stanton,"],[14677,14771,"Mrs. Stanton said"],[14771,14921,"she'd send the butler for me."],[14948,15181,"Why did you come personally?"],[15308,15475,"I'm not here for you!"]],"11":[[33,273,"I'm here for my eldest daughter-in-law,"],[310,390,"Regina."],[573,653,"Regina,"],[686,793,"you've been through a lot."],[840,884,"Dad."],[1041,1127,"Sir Stanton,"],[1141,1344,"are you mistaken?"],[1394,1584,"I'm Andy's biological mother."],[1668,1775,"Yeah."],[1861,2258,"Andy is just Marlon's illegitimate son."],[2339,2449,"Only Regina's child"],[2505,2739,"is the rightful heir of our family."],[2832,3096,"But didn't Regina never have a child?"],[3119,3193,"Says who?"],[4200,4287,"He's hungry."],[5031,5091,"Regina,"],[5135,5331,"who is this child?"],[5385,5542,"He's Marlon's child."],[5578,5665,"That's impossible."],[5692,5955,"Marlon never slept with you!"],[5979,6159,"That's not his child!"],[6516,6619,"I see."],[6680,6800,"You had this child"],[6816,6996,"with someone else, right?"],[7047,7243,"No wonder you disappeared for months."],[7290,7550,"You were pregnant with a bast*rd!"],[7941,8104,"Marlon told you he never touched me,"],[8148,8254,"and you believed him?"],[8288,8545,"He also told me he was just toying with you."],[8601,8665,"Do you believe that?"],[8822,8928,"Impossible!"],[9049,9122,"Sir Stanton,"],[9135,9279,"believe me."],[9285,9492,"This child isn't Marlon's."],[9529,9666,"I've already taken the child"],[9713,9906,"to the hospital for a DNA test."],[9936,10013,"The child"],[10036,10146,"belongs to the Stantons."]],"12":[[13,146,"I've already taken the child"],[196,387,"to the hospital for a DNA test."],[423,493,"This child"],[517,640,"belongs to the Stantons!"],[797,937,"How could this be?"],[980,1191,"Marlon, that b*stard,"],[1201,1351,"dared to lie to me!"],[1391,1464,"Irene,"],[1508,1644,"didn't you believe Marlon"],[1644,1768,"truly loved you?"],[1805,1945,"Then I'll make sure his love for you"],[1945,2068,"dies without proof."],[2302,2442,"This is wonderful."],[2485,2595,"Irene and Regina"],[2595,2769,"both gave birth to Marlon's children."],[2796,2912,"Congratulations, in-law."],[2949,3046,"You have another"],[3046,3169,"fine grandson!"],[3283,3466,"Regina is the hero of our family."],[3516,3606,"I plan"],[3643,3753,"to have her join Stanton Group"],[3797,3867,"and serve as"],[3897,4024,"the Vice President."],[4114,4217,"In-law,"],[4287,4397,"you really do think highly"],[4397,4547,"of our Regina."],[4671,4748,"Now,"],[4818,4914,"can you make Alma Harper"],[4914,5071,"get the hell out of my mom's house?"],[5235,5295,"Alma,"],[5331,5418,"you'd better"],[5472,5612,"move to the apartment."],[5648,5742,"Richard,"],[5779,5947,"you said you'd give me a status today."],[6192,6259,"Regina,"],[6291,6539,"how... how could you hit an elder"],[6556,6693,"in front of your father-in-law?"],[6783,6916,"Regina,"],[6930,7067,"what gives you the right to hit my mom?"]],"13":[[286,440,"In front of me and my dad,"],[460,580,"you hit a Stanton?"],[650,747,"Do you have a death wish?"],[840,947,"Jared is right."],[1011,1094,"Regina"],[1104,1194,"is our family's"],[1204,1394,"lawfully wedded daughter-in-law,"],[1434,1611,"and the Stantons' eldest daughter-in-law."],[1631,1731,"Hitting her"],[1761,1985,"is a slap in the Stantons' face!"],[1995,2075,"Mr. Stanton,"],[2092,2162,"but"],[2172,2318,"didn't I give the Stantons"],[2328,2495,"a grandson as well?"],[2532,2676,"Andy is my grandson."],[2716,2809,"The Stantons"],[2826,2946,"will definitely claim him."],[2999,3129,"Other than entering the family,"],[3166,3276,"whatever condition you have,"],[3306,3380,"just name it."],[3453,3523,"Regina,"],[3556,3620,"let's go."],[3827,3933,"Whatever you took from my mom,"],[3957,4047,"put it back"],[4070,4170,"exactly where it came from,"],[4204,4341,"and get out of my mom's house!"],[5362,5412,"Regina"],[5412,5598,"how did she suddenly return with a child?"],[5685,5879,"Now the Stantons won't let Irene in."],[5925,5985,"Does this mean"],[6022,6096,"we're going to be"],[6096,6279,"under Regina's thumb forever?"],[6299,6443,"Irene couldn't marry into the Stantons,"],[6466,6586,"and I couldn't help it either."],[6633,6853,"George has always valued Regina."],[6880,6980,"And now she is"],[6980,7107,"even more powerful thanks to her son,"],[7127,7380,"becoming the Vice President of Stanton Group."],[7514,7667,"Our families' partnership"],[7687,7844,"depends on Regina."],[7937,7981,"So,"],[8007,8104,"we can't offend her."],[8178,8321,"You'd better just"],[8361,8428,"move back."],[8442,8655,"I gave you two children."],[8728,9062,"Our son will be getting married soon,"],[9075,9305,"yet I still don't have a title."],[9349,9559,"Stop crying. We haven't lost yet!"],[9619,9749,"We still have Andy."],[9823,9903,"Regina."],[9929,10070,"Andy was raised"],[10070,10163,"by Grandma herself."],[10163,10296,"She won't give up on Andy."],[10310,10423,"The Stanton family"],[10437,10597,"will definitely be my son's."]],"14":[[100,330,"Is this really Marlon's child?"],[357,517,"Am I dreaming?"],[563,647,"Look,"],[661,787,"those features"],[824,1151,"loos exactly like Marlon when he was little."],[1321,1478,"Jared, take a look."],[1518,1695,"Doesn't he look like your big brother?"],[1891,2001,"This child"],[2035,2402,"actually looks so much like Jared."],[2472,2565,"Really?"],[2625,2686,"Mom,"],[2719,2819,"it's getting late."],[2869,2892,"I…"],[3139,3426,"Grandma, I miss Dad."],[3480,3580,"Oh,"],[3670,3953,"your dad left us both."],[4020,4180,"He's never coming back."],[4200,4364,"Dad doesn't want me anymore."],[4364,4601,"Grandma doesn't want me either."],[4637,4728,"Nonsense."],[4811,4931,"Get up, sweetie."],[5228,5438,"You're my precious darling."],[5468,5729,"How could I ever not want you?"],[5759,5975,"They said there's another boy"],[5975,6219,"and you're going to kick me out!"],[6282,6416,"Who told you that?"],[6559,6753,"Irene said it, of course."],[7030,7230,"Andy is my eldest grandson."],[7260,7374,"He is my life."],[7420,7794,"If anyone gossips around Andy again,"],[7824,7974,"I'll cut out their tongue!"],[8014,8211,"I don't want you to hold the baby."],[8231,8448,"You're mine and mine alone!"],[8832,8912,"Andy,"],[8978,9132,"Bennett is your younger brother."],[9132,9339,"You need to take care of each other."],[9462,9492,"You!"],[9576,9666,"All right."],[9723,9973,"With a new child suddenly in the house,"],[10003,10310,"Andy's entitled to feel insecure."],[10323,10440,"Why are you scolding him?"],[10670,10730,"Jared,"],[10794,11131,"take Regina and Ben upstairs."],[11184,11231,"Okay."]],"15":[[543,767,"Marlon didn't know he had this child, did he?"],[910,1041,"Why did he ask?"],[1364,1488,"It seems I guessed right."],[1592,1768,"If he and Irene"],[1808,1951,"knew about this child,"],[2028,2188,"would they have let me give birth?"],[2336,2480,"You might have had"],[2535,2625,"a different sister-in-law."],[2742,3139,"Two sisters fighting to be a widow."],[3455,3554,"How amusing."],[3660,3787,"My mom loves her"],[3787,3927,"eldest son and grandson."],[3963,4174,"On the surface, Dad runs the family,"],[4234,4361,"but he fears his wife."],[4454,4601,"Having this child"],[4678,4841,"doesn't guarantee an advantage."],[5423,5503,"Jared,"],[5535,5612,"you've never known"],[5612,5759,"the feeling of sinking in deep mud."],[5802,5932,"If you don't fight to climb up,"],[5955,6129,"you'll be trampled down."],[6159,6229,"Richard,"],[6353,6459,"look at her condition,"],[6566,6726,"she's going to die in the house."],[6751,6853,"It's such bad luck."],[6920,6990,"Hurry up,"],[7013,7213,"send her to the countryside."],[7707,7767,"All right."],[8108,8208,"Don't touch my mom!"],[8294,8458,"How dare you!"],[8495,8651,"I've agreed to marry Marlon."],[8692,8838,"I'll be the Stantons' eldest daughter-in-law."],[8848,8968,"Let's see who dares to touch my mom!"],[9444,9579,"Only by climbing up"],[9719,9948,"can I protect what I care about."],[11204,11354,"Sis, you're back."],[11648,11881,"Bad Auntie, this is me and Mommy's home!"],[11898,12058,"Get out of my house!"],[12607,12691,"Sis,"],[12699,12812,"Andy is just a child,"],[12812,12946,"why are you being so mean to him?"],[13143,13243,"All right."],[13299,13376,"Look,"],[13390,13533,"you've scared him to tears."],[13592,13747,"W-What's wrong?"],[13904,13984,"Grandma,"],[13990,14167,"Auntie hit me!"]],"16":[[16,90,"Grandma,"],[90,290,"Auntie hit me!"],[400,607,"Maybe my being here"],[617,794,"is why Regina is upset."],[854,1007,"I was the one who invited Irene."],[1054,1247,"This year's Stanton Charity Gala"],[1291,1494,"will be organized by you and Irene together."],[1533,1668,"I don't have the energy for it."],[1748,1845,"You two work it out."],[1871,1918,"Mom,"],[1937,2138,"the Charity Gala"],[2148,2245,"has traditionally been organized"],[2268,2455,"by the women in the Stanton family."],[2500,2623,"The guests are all high society."],[2746,2876,"Given Irene's status,"],[2922,3059,"I'm afraid it's not appropriate."],[3173,3253,"Regina,"],[3313,3513,"Marlon is already gone."],[3543,3690,"Can't you be the bigger person"],[3710,3970,"and stop bickering with Irene and Andy?"],[4020,4170,"She is your sister, after all."],[4207,4297,"Isn't that better than"],[4320,4674,"some homewrecker outside?"],[4834,5015,"It's easy to preach"],[5068,5241,"when you're not the one suffering."],[5338,5648,"I still need to discuss it with Dad."],[5685,5849,"Don't use him to pressure me."],[5982,6296,"Andy was Marlon's favorite son."],[6376,6576,"This year, I'm making sure Irene"],[6586,6800,"steps into the spotlight"],[6823,6996,"to pave the way for Andy's future!"],[7333,7387,"Sis,"],[7439,7580,"it seems Marlon"],[7592,7792,"never took you to any events back then."],[7871,8098,"But in these last few years,"],[8121,8231,"while I was with Marlon,"],[8248,8415,"I met quite a few big names."],[8445,8601,"So, I'll be the one"],[8651,8818,"hosting this event."],[8835,8922,"Nominally,"],[8958,9152,"we'll say it's a joint effort."],[9319,9396,"Is that so?"],[9472,9599,"Then I'd like to see"],[9632,9793,"what big shots you can invite."],[10100,10183,"Irene,"],[10313,10507,"I won't give you a chance to shine."]],"17":[[607,674,"Miss,"],[704,860,"Mr. Whitman is a renowned director"],[887,954,"and is highly respected."],[1007,1121,"If we can invite him,"],[1133,1197,"we'll crush"],[1197,1341,"the celebrities Irene invited."],[1439,1715,"But Mr. Whitman has been retired for years."],[1795,1928,"Can we really get him to come?"],[1977,2075,"We just have to try."],[2479,2632,"Miss Carson, it's been a while."],[2692,2886,"Mr. Whitman's guest set up a challenge today."],[2939,3019,"He has been working on it"],[3019,3113,"but hasn't cracked it."],[3129,3229,"You should go help him."],[3329,3413,"Right this way."],[3713,3770,"Mr. Whitman."],[3788,3872,"Regina."],[3903,3967,"Simply perfect timing."],[4044,4167,"Take a look. How would you solve this?"],[5689,5792,"Brilliant!"],[5849,5975,"Why didn't I think of that?"],[8141,8204,"Good."],[8405,8451,"Mr. Whitman,"],[8501,8655,"who set up this puzzle for you?"],[8678,8828,"They're bullying an old man."],[8865,9062,"That kid went to take a call."],[9146,9222,"Jared,"],[9279,9352,"come look."],[9389,9547,"Someone solved your puzzle."],[9572,9693,"Why is Jared here?"]],"18":[[13,140,"Why is Jared here?"],[236,360,"Why are you just standing there?"],[860,917,"Sister-in-law."],[977,1087,"I didn't know you played pool."],[1197,1254,"Just a little."],[1327,1404,"Oh no."],[1478,1648,"Did Jared recognize me?"],[1738,1838,"Sister-in-law."],[1888,1978,"You know each other?"],[2092,2155,"Mr. Whitman,"],[2218,2355,"there's something I haven't told you."],[2409,2549,"I'm Jared's sister-in-law."],[2645,2756,"You sly girl."],[2782,2906,"You hid that well."],[2962,3046,"If I had known"],[3046,3206,"you were in-laws,"],[3236,3410,"I would've invited you together often."],[3486,3563,"So,"],[3656,3810,"my sister-in-law is good at pool?"],[4024,4214,"She's better than you."],[4244,4274,"Come on."],[4294,4414,"Why don't you two play a round?"],[4461,4514,"Mr. Whitman,"],[4547,4634,"actually, I came for…"],[4634,4704,"Play a game."],[4938,4981,"Right."],[5015,5128,"Hurry up, play a game."],[5181,5278,"Let me see"],[5278,5445,"which of you is better."],[5855,5899,"Sister-in-law."],[6236,6332,"What are you so nervous about?"],[6446,6519,"I can't panic."],[6566,6730,"I'll give myself away."],[6823,7010,"Since Mr. Whitman wants us to play,"],[7047,7153,"we should make a wager."],[7220,7287,"Don't you agree?"],[7333,7427,"You sly girl."],[7474,7577,"I knew it."],[7587,7721,"You haven't visited in months."],[7737,7854,"You're up to something."],[7894,8001,"Tell me what you want."],[8034,8088,"Mr. Whitman,"],[8151,8244,"if I win,"],[8278,8381,"you have to do me a favor."],[8438,8581,"You have to tell me what it is first."],[8688,8768,"If it involves murder or arson,"],[8782,8858,"count me out."],[8885,8948,"I promise it's not."],[9000,9135,"You seem so confident."],[9245,9366,"Are you sure you'll win?"],[10964,11017,"Sister-in-law."],[11147,11217,"Make your move."],[11368,11468,"Just like ten months ago"],[11504,11648,"the puzzle he used again me"],[11668,11841,"when I bet against him."],[12058,12138,"He's testing me."]],"19":[[420,477,"Sister-in-law,"],[573,694,"have you seen this puzzle before?"],[737,877,"Jared is suspicious."],[924,1067,"I can't let him confirm it."],[1124,1214,"Otherwise, all of my efforts"],[1214,1294,"will have been for nothing."],[1504,1581,"No, never."],[1618,1728,"I was thinking about"],[1728,1838,"how to take this shot."],[1921,2032,"The only way to make it"],[2032,2235,"is with the technique he taught me that day."],[2282,2379,"What do I do?"],[2766,2846,"Watch closely."],[2929,3053,"Here's how to play this shot."],[3923,4080,"I designed this puzzle myself."],[4157,4280,"I only taught it to that woman."],[4551,4651,"Regina,"],[4714,4784,"what's the matter?"],[4841,5008,"Has this kid stumped you?"],[5178,5228,"Regina,"],[5308,5428,"if you can't make the shot,"],[5522,5662,"you can always forfeit."],[5799,5875,"Regina,"],[5889,6019,"getting a favor from me"],[6039,6152,"isn't that easy."],[6199,6262,"No way."],[6316,6436,"I have to get Mr. Whitman."],[6473,6556,"I can't give up."],[6673,6730,"Let me try."],[10213,10310,"It's in."],[10470,10543,"It's not her."],[10667,10860,"Or maybe she realized I was testing her,"],[10904,11054,"she risked using a different technique."],[11518,11594,"Check something for me."],[11608,11758,"On that day eleven months ago,"],[11775,11951,"did Regina go to Harbress?"],[12322,12392,"Mr. Whitman,"],[12409,12492,"I won."],[12515,12652,"I'd like to invite you to"],[12652,12779,"the Stantons' charity gala."],[12849,12912,"Regina,"],[12962,13203,"I've been retired for so many years,"],[13276,13416,"and hardly anyone recognizes me anymore."],[13446,13626,"You should find someone else."],[13660,13727,"Mr. Whitman,"],[13807,13967,"at your age,"],[14010,14134,"you can't break your promise."],[14187,14277,"You sly girl."],[14304,14457,"Youset a trap"],[14471,14594,"just for me to walk into."],[14611,14677,"Mr. Whitman,"],[14734,14821,"you know me."],[14934,15135,"If I had any other choice,"],[15185,15291,"I wouldn't be bothering you."],[15418,15528,"Let me think about it."],[15618,15739,"I'll have someone pick you up then."],[15892,15952,"Jared,"],[15972,16069,"I'm heading home first."]],"20":[[794,867,"Drive!"],[964,1084,"Miss, what's wrong?"],[1097,1203,"Why are you so nervous?"],[1254,1341,"I ran into Jared."],[1371,1464,"He suspects me."],[1631,1735,"What do we do?"],[1805,1931,"He's a monster."],[1968,2042,"If he finds out,"],[2042,2155,"forget about telling the Stantons,"],[2195,2295,"he would just"],[2442,2579,"kill us himself."],[2602,2722,"He probably isn't sure yet."],[2806,2912,"My trips to Harbress"],[2919,2999,"you wiped the records, right?"],[3036,3153,"Yes, they're gone."],[3493,3683,"Let's focus on the charity gala first."],[3730,3833,"We can't let Irene"],[3833,3953,"stand out at the gala."],[4010,4057,"Otherwise,"],[4067,4167,"Joanna Warren's next move"],[4167,4287,"will be to get her on the Board."],[4844,4938,"Is that you?"],[5045,5128,"My sister-in-law?"],[9385,9542,"Marlon, you unfilial son."],[9586,9903,"How could you make me bury my own child?"],[9966,10156,"Mrs. Stanton, please stay strong."],[10163,10517,"Your son wouldn't want to see you in tears."],[11041,11237,"Mrs. Stanton, who is this?"],[11408,11518,"This is Irene,"],[11554,11688,"Andy's mother."],[11708,12122,"She organized tonight's charity gala alone."],[12188,12308,"That's incredible."],[12352,12552,"She looks so young."],[12595,12675,"Yes."],[12675,12819,"She is very capable."],[12859,12996,"Is she your daughter-in-law?"],[13086,13126,"Yes."],[13133,13183,"Mom,"],[13233,13306,"there you are."]],"21":[[166,280,"Where have you been?"],[296,423,"The guests are all here,"],[457,563,"and you just got back."],[620,787,"This must be the eldest daughter-in-law."],[790,920,"We've seen her at"],[920,1014,"past charity galas."],[1194,1361,"Uh, yes, this is my eldest daughter-in-law."],[1394,1554,"She hasn't really done much."],[1591,1654,"So,"],[1675,1835,"for this charity gala,"],[1835,1921,"we had to leave the planning"],[1935,2168,"entirely to Irene."],[2195,2305,"It shows how important it is for a wealthy family"],[2305,2485,"to have a capable daughter-in-law."],[2525,2689,"Miss Irene is beautiful"],[2689,2779,"and capable."],[2849,3013,"She's a blessing Marlon left behind."],[3128,3209,"Indeed."],[3521,3664,"Madam, Miss Irene,"],[3680,3757,"Evelyn is here."],[3770,3843,"Oh my god!"],[3843,4070,"Miss Irene actually invited Evelyn!"],[4100,4210,"She's the most successful star"],[4210,4401,"discovered by the famous director,"],[4401,4527,"David."],[4551,4654,"She's busy with her movie career,"],[4654,4781,"so she rarely attends events."],[4831,4911,"Really?"],[4944,5205,"That's exactly why I say Irene is capable."],[5568,5635,"Irene."],[5702,5792,"Evelyn."],[5825,5932,"Welcome."],[6072,6189,"You look so beautiful."],[6202,6393,"Even prettier than on TV."],[6413,6533,"As a public figure,"],[6533,6696,"it's my honor to contribute"],[6716,6836,"to charity."],[6953,6990,"Oh,"],[7290,7354,"Sister,"],[7394,7544,"go help Miss Monroe."],[7544,7640,"Take the coat and bag"],[7640,7771,"to the lounge."]],"22":[[96,176,"I'm busy."],[223,296,"Do it yourself."],[477,617,"What could you possibly be busy with?"],[677,874,"You're making a fuss just to deliver a coat."],[914,1044,"What contribution have you"],[1044,1197,"actually made to this event?"],[1244,1374,"Don't get upset over this."],[1424,1558,"My assistant will be here any minute."],[1564,1654,"Just give me the coat."],[1731,1918,"Oh, Miss Monroe,"],[1975,2118,"she's got nothing better to do."],[2122,2205,"Let her take it."],[3166,3223,"Mom,"],[3266,3396,"the guest I invited is here."],[3410,3513,"I need to go outside and greet them."],[3787,3860,"Sister,"],[4080,4394,"I invited so many guests tonight,"],[4431,4654,"and everyone who matters is already here."],[4691,4861,"If it's some nobody,"],[4894,5028,"just don't let them in."],[5068,5171,"We don't have enough"],[5208,5352,"seats as it is."],[5538,5645,"Irene is right."],[5679,5772,"Who is this guest?"],[5802,5919,"Are they really important enough"],[5919,6089,"for you to greet them personally?"],[6129,6246,"If you have time for that,"],[6259,6436,"why don't you take Miss Monroe's coat"],[6436,6519,"upstairs?"],[6830,6896,"Evelyn,"],[6926,7150,"they say the Master has come out of seclusion."],[7243,7317,"Mr. Whitman?"],[7364,7460,"Is that the"],[7460,7584,"director who retired years ago,"],[7584,7731,"David?"],[7827,7924,"Are you kidding me?"],[7964,8104,"My mentor has been retired for years."],[8111,8224,"No one has been able to bring him out."],[8284,8375,"It's true."],[8391,8485,"Look at the news."],[8511,8615,"Someone spotted Mr. Whitman"],[8615,8788,"registering at the hotel entrance."],[8918,9052,"What kind of event"],[9052,9175,"could actually bring Mr. Whitman here?"],[9292,9409,"Isn't this"],[9452,9622,"the registration desk for this event?"],[9893,10100,"I sent Mr. Whitman an invitation."],[10140,10316,"I didn't expect him to actually come."],[10330,10543,"What, Irene?"],[10580,10780,"You managed to invite Mr. Whitman?"],[10974,11131,"Mr. Whitman definitely came"],[11131,11277,"because of my invitation."],[11314,11404,"Mrs. Stanton,"],[11434,11544,"I think only Miss Irene"],[11554,11721,"is fit to be your eldest daughter-in-law."],[11865,12052,"I certainly chose the right person."],[12115,12168,"Mom,"],[12202,12302,"I'll go welcome Mr. Whitman."],[12435,12502,"Sis,"],[12575,12672,"Mr. Whitman"],[12686,12852,"wasn't invited by you."],[12912,13029,"Why are you going to greet him?"],[13149,13216,"Yeah."],[13266,13390,"You want to take the credit,"],[13393,13610,"so why don't you put in more effort usually?"],[13690,13760,"Mr. Whitman!"],[13763,13857,"Mr. Whitman is here!"],[13940,14024,"Sir!"],[14148,14250,"Mr. Whitman."],[14361,14434,"You little girl,"],[14471,14561,"you left this old man"],[14561,14681,"hanging out there all alone."],[14711,14781,"Is this how you show"],[14781,14951,"your sincerity in inviting me?"]],"23":[[0,80,"Mr. Whitman,"],[93,246,"I was just about to go out to welcome you."],[370,600,"How did she manage to get Mr. Whitman to come?"],[653,737,"Mrs. Stanton,"],[737,870,"I think your eldest daughter-in-law"],[870,957,"is really something."],[960,1051,"David has been"],[1051,1167,"retired for years."],[1194,1331,"The last time the state held an event"],[1331,1414,"and invited him,"],[1434,1538,"he turned them down."],[1581,1654,"Yeah,"],[1678,1835,"so many big stars here today"],[1835,2012,"are his proteges."],[2022,2082,"Sir,"],[2108,2248,"you've finally come out of retirement."],[2292,2412,"No matter how we tried to invite you before,"],[2412,2485,"you wouldn't come."],[2605,2682,"Well, Regina"],[2712,2799,"she insisted on dragging"],[2799,2929,"my old bones out here."],[2956,3103,"I couldn't say no to her."],[3189,3390,"How did that bi*ch Regina"],[3413,3553,"know Mr. Whitman?"],[3583,3723,"Mr. Whitman,"],[3943,4114,"this is my mother-in-law."],[4124,4290,"She's the wife of the Stanton Chairman,"],[4300,4461,"and also the President of the"],[4461,4514,"Stanton Charity Association."],[4594,4637,"Mom,"],[4694,4771,"this is Mr. Whitman."],[4964,5215,"Mr. Whitman, your reputation precedes you."],[5215,5331,"It's an honor to meet you!"],[5345,5472,"Oh, you flatter me."],[5508,5675,"It's my honor to promote"],[5675,5899,"charitable causes."],[6006,6212,"Please, have a seat, Mr. Whitman."],[6276,6393,"This way, please."],[6846,7013,"Hurry up and take Miss Monroe's dress"],[7057,7123,"upstairs."],[7577,7647,"Mrs. Stanton,"],[7647,7724,"you and Mrs. Carson,"],[7724,7821,"along with Mr. Whitman and Evelyn,"],[7821,7907,"everyone squeeze in a bit closer."],[7914,8018,"I'll take a group photo"],[8018,8161,"for the charity gala's cover."],[8284,8334,"Irene,"],[8334,8489,"the news that Regina invited David"],[8501,8611,"is the number one trending topic."],[8858,9002,"Originally, Ms. Warren planned"],[9002,9182,"to use the credit from this charity gala"],[9195,9366,"to get me onto the Stanton Group board."],[9419,9512,"I never expected"],[9539,9713,"that b*tch Regina"],[9713,9869,"to steal the spotlight again!"]],"24":[[787,864,"Mrs. Stanton,"],[864,947,"your pomegranate juice."],[1598,1651,"Miss Regina,"],[1701,1828,"there's something wrong with that drink."],[3013,3126,"Are the men ready?"],[3166,3249,"All set."],[4017,4167,"Regina,"],[4174,4300,"I'll make sure you never"],[4318,4528,"have the chance to fight me again."],[6466,6549,"What's wrong?"],[8948,9049,"Where is that woman?"],[9135,9269,"She was just here. Find her!"],[10253,10367,"Find Lena for me."],[10520,10633,"You've been drugged."],[11097,11184,"Jared,"],[11494,11708,"call the family doctor for Regina."],[11985,12108,"Get Mom and Dad, too."],[12275,12385,"Keep it quiet."],[13206,13303,"Hurry."],[16413,16510,"Lena,"],[16629,16716,"I'm on the second floor."],[16805,16950,"Get Richard."],[17360,17497,"Have Dr. Miller come to the lounge."],[17567,17627,"Also,"],[17687,17804,"get Mr. Stanton"],[17847,17971,"and Mrs. Stanton."]],"25":[[153,230,"Irene."],[276,357,"How did it go?"],[393,500,"Did those two men"],[500,670,"take Regina to the room?"],[687,717,"No."],[727,914,"Regina is in Mr. Jared's lounge."],[914,1091,"Mr. and Mrs. Stanton both went there."],[1204,1301,"What did you say?"],[2022,2095,"Regina."],[2132,2212,"Mr. Stanton,"],[2215,2382,"Regina was drugged with an aphrodisiac."],[2412,2532,"The audacity!"],[2575,2776,"To do such a filthy thing"],[2776,3039,"at a Stanton charity gala!"],[3239,3303,"Dad,"],[3380,3476,"keep it down."],[3533,3693,"There are still many guests here."],[3767,3993,"Regina, nothing happened to you, right?"],[4000,4154,"This charity gala was going so well"],[4154,4280,"and was such a success."],[4330,4517,"To have such a scene at the very end"],[4571,4704,"is really distressing."],[4801,4998,"Dad, Mom,"],[5061,5285,"luckily I ran into Jared today."],[5352,5542,"He called a doctor for me in time."],[5608,5769,"If it had been anyone else,"],[5825,5985,"the consequences would be unimaginable."],[6146,6322,"Marlon just passed away."],[6373,6623,"If anything happened with another man,"],[6730,6831,"to the Stantons"],[6883,7070,"and to the late Marlon,"],[7113,7253,"it would be a humiliation."],[7313,7597,"We must investigate this thoroughly!"],[7647,7791,"I want to see"],[7791,7937,"who would dare"],[7962,8158,"humiliate my poor son like this!"],[8188,8294,"Regina, don't worry."],[8341,8498,"We definitely won't spare anyone"],[8498,8651,"who tries to harm you or the Stantons."],[8785,8895,"Bring everyone who handled"],[8895,9085,"Round up everyone who handled the drink"],[9155,9302,"Regina had and question them."],[9389,9456,"Crap."],[9763,9983,"The Stantons are investigating the drugging."],[9986,10113,"Destroy all the surveillance footage."],[10687,10950,"Mom, Dad, why are you here?"],[10950,11067,"Lena just called us."],[11067,11277,"She said something happened to you at the gala!"],[11331,11408,"Regina."],[11454,11715,"Dad, someone drugged me."],[11771,11888,"It almost ruined the reputation"],[11888,12078,"of the Stanton and Cheng families."],[12128,12238,"Who has the audacity"],[12252,12472,"to target the Stantons' Young Mistress?"],[12512,12709,"Please, don't worry."],[12726,12816,"I've already sent people"],[12826,12949,"to investigate the matter."],[12969,13086,"We'll have results soon."],[13129,13276,"The surveillance footage is destroyed."],[13306,13520,"I should be safe. They can't trace it to me."],[13920,13990,"Young Mistress,"],[14037,14144,"all the surveillance cameras here"],[14144,14250,"have been destroyed."],[14357,14547,"But someone witnessed the drugging"],[14577,14664,"and filmed it."]],"26":[[186,263,"The one who drugged her"],[316,453,"was Miss Irene's assistant."],[460,553,"I didn't know anything!"],[586,700,"This has nothing to do with me."],[737,910,"The video is crystal clear."],[937,1023,"It was your person."],[1074,1180,"And you still claim you didn't know!"],[1220,1280,"Irene,"],[1290,1444,"Marlon has only just left."],[1471,1537,"How could you do this?"],[1551,1621,"Irene,"],[1647,1768,"do you think if I'm ruined,"],[1794,1964,"it only humiliates me?"],[2111,2295,"People will criticize Dad behind his back,"],[2328,2445,"mocking his failure as a father."],[2525,2638,"In-law,"],[2699,2899,"look at the good daughter you raised!"],[3146,3206,"You disgrace!"],[3216,3312,"The stupid thing you did"],[3319,3443,"almost caused a disaster."],[3466,3603,"Kneel down and apologize to your sister!"],[3609,3659,"Dad,"],[3689,3853,"I really didn't do it."],[3873,3966,"It was my assistant."],[3983,4026,"She"],[4026,4150,"She acted on her own!"],[4420,4474,"Mom!"],[4490,4624,"You still dare to deny it!"],[4650,4724,"Richard,"],[4767,4914,"you already slapped Irene."],[4937,4987,"Regina"],[5001,5114,"is fine, isn't she?"],[5144,5194,"How dare you!"],[5248,5365,"If the Stantons' eldest daughter-in-law"],[5375,5511,"has her reputation ruined,"],[5525,5648,"it brings shame to my grandson,"],[5658,5848,"and he'll be cursed for life!"],[5975,6039,"Ah!"],[6119,6155,"Ah!"],[6172,6199,"Irene!"],[6199,6309,"Apologize to your sister!"],[6332,6365,"Mom!"],[6365,6406,"Irene!"],[6499,6546,"Richard!"],[6582,6749,"Only when your core interests are at stake,"],[6786,6949,"do you turn on this mother and daughter."],[6953,7043,"Stop hitting her!"],[7060,7106,"Stop!"],[7106,7182,"Are you trying to beat her to death?"],[7226,7286,"Stay out of this!"],[7333,7417,"Grandpa!"],[7430,7571,"Stop hitting Mommy!"],[7580,7740,"Please stop hitting Mommy!"],[7757,7917,"I"]],"27":[[26,99,"Stop hitting her!"],[146,265,"Don't hit Andy!"],[280,406,"Come here to Grandma."],[473,630,"Don't look. Don't be scared."],[636,790,"With a mother like you, Andy"],[803,940,"is bound to be led astray!"],[967,1084,"From now on, without my permission,"],[1160,1294,"you are not allowed in the Stanton house!"],[1310,1374,"No"],[1404,1467,"Mr. Stanton"],[1531,1690,"I was wrong."],[1698,1758,"Let's go!"],[1858,2028,"Let Regina get some rest."],[2161,2201,"Move!"],[2255,2321,"I don't want to!"],[2345,2475,"Andy"],[2498,2538,"Mr. Stanton,"],[2552,2772,"I'll discipline her strictly when we get home."],[2805,2892,"Irene."],[3986,4026,"Regina,"],[4133,4303,"you knew something was wrong with that drink,"],[4370,4450,"yet you drank it on purpose."],[4507,4587,"Jared,"],[4660,4797,"how can you say that?"],[4917,5124,"Why would I harm myself?"],[5368,5418,"\"Miss Regina,"],[5451,5578,"there is something wrong with your drink.\""],[6959,7063,"You felt that"],[7093,7190,"only when their dignity"],[7190,7350,"was truly threatened,"],[7377,7487,"would they take this seriously."],[7517,7573,"Otherwise,"],[7617,7897,"they would have just brushed it aside."],[7959,8097,"Am I right?"],[8151,8204,"Jared,"],[8331,8431,"you think I am"],[8464,8611,"far more calculating than I really am."],[9038,9082,"Jared"],[9255,9332,"It's okay, Regina."],[9399,9465,"Keep it on."],[10977,11107,"Jared is meticulous,"],[11157,11220,"so I have to be on guard."],[11350,11417,"Miss Regina."],[11417,11587,"Did Jared check my itinerary?"],[11598,11654,"He did."],[11681,11811,"Luckily, we tampered with it beforehand."]],"28":[[239,306,"Let's have some milk."],[366,410,"Drink up, Bennett."],[416,569,"Don't cry."],[663,727,"Such a good boy."],[803,982,"Mr. Jared."],[990,1140,"Look how much Bennett likes you."],[1164,1227,"As soon as he saw you,"],[1227,1304,"he stopped crying."],[1330,1531,"Blood ties really are magical."],[1594,1721,"Blood ties"],[1758,1851,"I actually think,"],[1851,2091,"this kid looks just like the young Jared."],[2482,2568,"You little thing."],[2578,2682,"You were crying so hard just now."],[2699,2805,"Why did you stop?"],[2909,2962,"Jared,"],[3072,3159,"why did you come back?"],[3226,3302,"Father"],[3326,3453,"called and ordered me to return."],[3489,3599,"Just now, Mr. Jared"],[3623,3830,"heard Bennett crying and came over."],[3886,3976,"He just touched him once,"],[4026,4143,"and the crying stopped instantly."],[4147,4220,"He's so young,"],[4233,4333,"yet he already recognizes his uncle."],[4384,4474,"Smart little guy."],[4964,5041,"I'm heading out."],[5098,5141,"Mhm."],[6309,6496,"Jared has been back for days,"],[6516,6676,"but he's barely been home."],[6699,6883,"Why did he suddenly come into my room?"],[7637,7693,"Mr. Jared,"],[7710,7834,"do you have any instructions?"],[7860,7954,"Run a DNA test on this."],[8004,8174,"Mr. Jared, is this"],[8217,8364,"I suspect the woman from that night"],[8434,8531,"was Regina."],[8541,8608,"Mr. Jared,"],[8614,8751,"Mrs. Regina is known for her virtue."],[8765,8821,"She wouldn't do that."],[8829,8974,"Hurry. Make it quick."],[9402,9462,"Regina"],[9572,9719,"I want to see"],[9819,9896,"if you're truly virtuous,"],[10016,10113,"or just putting on an act."]],"29":[[393,486,"What were you thinking,"],[526,727,"drugging her at an event like that?"],[767,883,"Ms. Warren intended to use"],[910,1080,"the success of my charity gala"],[1080,1190,"as leverage to get me"],[1207,1354,"on the Stanton Group board."],[1367,1481,"We were about to make a comeback!"],[1564,1781,"But I didn't expect that b*tch Regina"],[1808,1968,"to actually invite David."],[2068,2208,"All the effort I put in"],[2235,2330,"was completely wasted!"],[2351,2452,"What do we do now?"],[2488,2732,"I earned my MBA from Yestar University,"],[2775,2882,"and I have inside info on"],[2925,3172,"the land the Stantons want."],[3196,3356,"Once this all blows over,"],[3376,3549,"I'll go beg Ms. Warren again."],[3596,3669,"She's sure to"],[3716,3866,"agree to help me again."],[3930,4143,"Won't Regina interfere again?"],[4363,4470,"Why are you scared of her?"],[4504,4660,"Since she's so clueless,"],[4727,4884,"we'll have to teach her a lesson."],[4895,5017,"We'll teach her how to"],[5017,5181,"keep her head down and behave."],[5261,5354,"What are you planning?"],[5438,5655,"Your dad already has a rift with your sister."],[5655,5782,"Don't do anything rash."],[5788,5958,"Don't worry, Mom."],[6012,6149,"Dad loves me too much to hit me."],[7964,8037,"Miss Regina,"],[8074,8224,"Madam's tombstone was smashed!"],[8624,8698,"The old caretaker at the cemetery"],[8698,8808,"didn't dare say who was there."],[9008,9180,"Ryan Cheng"],[9419,9595,"splashed dog's blood on the headstone."],[9619,9806,"It's a curse to damn her soul for eternity."],[9836,9962,"He's an absolute animal!"],[10012,10066,"Lena,"],[10133,10256,"find someone to repair Mom's headstone."],[10299,10376,"Leave Ryan"],[10476,10550,"to me."],[10603,10717,"But Miss Regina,"],[10750,10930,"Ryan is your father's favorite,"],[10963,11057,"and the Carson Group"],[11057,11194,"is still in his hands."],[11220,11340,"If you touch Ryan,"],[11347,11404,"I'm afraid"],[11474,11564,"I know what I'm doing."],[12185,12261,"Mom,"],[12331,12535,"I failed to protect you in life,"],[12685,12779,"and in death,"],[12965,13226,"I couldn't even protect your tombstone."]],"30":[[323,413,"Hahaha!"],[503,700,"I smashed her mom's tombstone!"],[730,923,"And splashed it with black dog's blood!"],[960,1194,"I want her soul to never find peace,"],[1217,1327,"to remain a ghost forever,"],[1327,1447,"watching you and Dad"],[1447,1581,"live happily ever after."],[1604,1788,"Mom, don't worry."],[1808,1924,"That bi*ch Regina"],[1924,2065,"if she dares to stand in our way,"],[2088,2145,"then I'll"],[2278,2341,"kill her."],[3306,3389,"She's so hot."],[3423,3503,"So beautiful."],[4003,4067,"Mom,"],[4083,4197,"I'll talk to you later."],[5728,5808,"She made that shot?!"],[5808,5898,"Impressive."],[6345,6452,"She's got skills."],[6489,6569,"Hey, gorgeous."],[6639,6739,"Are you planning"],[6773,6949,"to win the entire Midnight Jackpot"],[6959,7066,"tonight all by yourself?"],[7066,7150,"I win on skill alone."],[7240,7356,"What? Can't Midnight afford to pay?"],[7370,7503,"Of course we can."],[7523,7760,"I'm just particularly interested"],[7790,7950,"in a beauty with such a great figure"],[7960,8071,"and such amazing pool skills."],[8257,8431,"Interested in me?"],[8731,8835,"Then we'll have to see"],[8835,8998,"if you have what it takes."],[9285,9358,"Alright."],[9374,9612,"You really are a unique kind of beauty."],[9625,9742,"Bring me my cue."],[9972,10103,"If you lose,"],[10236,10423,"you're coming home with me tonight."],[10423,10540,"If I win,"],[10673,10817,"I want one of your fingers."],[10890,11055,"What? Scared?"],[11134,11284,"If you're scared, stay away."],[11404,11721,"I'm not interested in weaklings."],[11744,11801,"Woman,"],[11848,12018,"since you have a death wish,"],[12024,12178,"don't blame me for not holding back."],[12598,12648,"Mr. Jared,"],[12668,12772,"the DNA results are in."]],"31":[[176,303,"Quite the devoted wife and mother."],[546,650,"Where is the Young Madam?"],[650,757,"The Young Madam's mother's grave"],[757,853,"was smashed by Ryan."],[867,940,"Right now,"],[997,1160,"the Young Madam is at Zero Billiards,"],[1187,1254,"wearing a mask,"],[1277,1397,"and playing pool with Ryan."],[1434,1491,"What's the bet?"],[1521,1604,"If she loses,"],[1624,1694,"she leaves with Ryan."],[1701,1834,"If she wins, she gets one of his fingers."],[1982,2158,"For smashing my mother-in-law's grave,"],[2308,2468,"one finger isn't enough."],[3593,3643,"Argh!"],[3730,3786,"It hurts!"],[3836,3880,"Punk,"],[3920,4060,"who the hell are you?"],[4137,4280,"I hate it when people point at me."],[4457,4550,"Argh! It hurts!"],[4564,4637,"It hurts!"],[4637,4704,"It's broken!"],[4881,4967,"Jared."],[5001,5098,"Why is he here?"],[5828,5892,"Sister,"],[5922,6039,"you really made me work to find you."],[6125,6195,"Thank goodness,"],[6229,6382,"he doesn't seem to know who I am."],[6592,6729,"Who are you to this woman?"],[6786,6843,"Her husband."],[6859,6929,"Husband?"]],"32":[[19,209,"No wonder she's so alluring."],[279,400,"Turns out she's a married woman."],[496,560,"But,"],[603,700,"I like that even better."],[973,1020,"Kid."],[1381,1424,"Sister,"],[1504,1591,"stay focused."],[1614,1748,"They won't be like me,"],[1791,1864,"going easy on you."],[3496,3553,"Mr. Carson,"],[3589,3643,"I win."],[3686,3873,"You didn't sink that shot."],[3903,4053,"You distracted me first."],[4090,4153,"My"],[4303,4524,"It's only fair that my brother helps me."],[4620,4781,"Did you actually see"],[4781,4964,"me get someone to interfere with your shot?"],[5174,5254,"Did you guys see that?"],[5278,5338,"No!"],[5885,5978,"Here's the proof."],[6018,6119,"The great owner of Zero Billiards"],[6135,6225,"is a sore loser"],[6242,6392,"who plots against a woman."],[6406,6462,"Smart."],[6492,6682,"Truly the Regina who dares to cheat with me."],[6709,6816,"The evidence is right here."],[6879,7060,"Mr. Carson, still want to ignore the rules?"],[7093,7183,"So what?"],[7193,7260,"This is my turf."],[7260,7367,"I am the rules!"],[7990,8047,"Brother,"],[8257,8327,"want to pick me up?"],[8508,8588,"I want to sleep with you."],[8751,8911,"Then let's see if you have what it takes"],[9008,9105,"to handle him."],[9389,9582,"This woman really has two faces."],[10363,10573,"I'll see just who makes the rules."]],"33":[[23,70,"Punk,"],[116,273,"that I want your wife"],[296,383,"is a blessing for you."],[406,533,"Don't be ungrateful!"],[666,740,"You have a death wish."],[777,927,"Do you have any idea who I am?"],[953,1124,"You dare call yourself my father?"],[1164,1284,"I'll not only be your father,"],[1344,1460,"I'll f*ck your mom."],[1561,1607,"Argh!"],[1851,1958,"Let me tell you,"],[2035,2248,"I'm the eldest son of the Carsons in Switan!"],[2311,2438,"The Chairman of Stanton Group"],[2438,2532,"is my brother-in-law!"],[2568,2655,"If you dare touch me,"],[2696,2794,"you're dead meat!"],[2825,2895,"You're saying"],[3346,3539,"the late President of Stanton Group"],[3583,3669,"is your brother-in-law?"],[3870,4047,"Scared now, kid?"],[4080,4223,"My own sister"],[4223,4467,"gave the family a grandson."],[4520,4741,"She's about to join the Stanton Board."],[4774,4907,"If you know what's good for you,"],[4907,5081,"kneel and kowtow to me three times."],[5108,5324,"Your sister joining the Stanton Board"],[5431,5551,"really went to your head."],[5591,5792,"Chop off his pinky fingers."],[5872,6032,"That's the price for welching."],[6102,6229,"You wouldn't dare!"],[6312,6365,"Argh!"],[6652,6726,"Ryan,"],[6803,7033,"this is just a small lesson."],[7276,7363,"Where are you taking me?"],[7407,7537,"I got revenge for you."],[7597,7727,"Shouldn't you give me a reward?"]],"34":[[373,583,"Do you know I've been looking for you?"],[613,686,"Was that night"],[853,970,"so unforgettable for you, Mr. Jared?"],[1137,1260,"It was my first time."],[1374,1437,"What do you think?"],[1621,1684,"What?"],[1721,1938,"That was actually Jared's first time?"],[2008,2175,"With his reputation, how is that possible?"],[2518,2588,"Sleep with me again."],[2662,2735,"Let's get married."],[3376,3446,"Mr. Jared,"],[3483,3636,"you haven't even seen my face,"],[3723,3880,"yet you'd pledge your life to me?"],[3950,4023,"I'm not afraid."],[4063,4177,"What if I'm too ugly to be seen?"],[4350,4517,"I have plenty of money for plastic surgery."],[5368,5465,"Then sleep with me again."],[7306,7383,"It's getting late."],[7470,7557,"I should go home."],[8281,8334,"Don't take it off."],[8458,8514,"Sweetie,"],[8658,8791,"our relationship"],[8918,9035,"is only meant for the night."],[9082,9172,"Once the sun rises,"],[9282,9338,"I must go back"],[9355,9472,"to be a good wife and mother."],[9909,10006,"How can I find you again?"],[10046,10126,"Give me your phone."],[10209,10286,"I'll leave my number."],[11330,11474,"What if this number is fake?"]],"35":[[293,370,"Believe me now?"],[486,580,"I'll have someone drive you back."],[593,643,"No need."],[2004,2105,"Young Master, are you going back?"],[2111,2161,"Yes."],[2228,2295,"To the old mansion."],[2331,2405,"I'll be living there from now on."],[3186,3252,"The doctor said"],[3252,3342,"if we'd been a little later,"],[3363,3519,"the two fingers couldn't be reattached."],[3549,3656,"Who's bold enough"],[3673,3843,"to chop off Ryan's fingers in public?"],[3880,4063,"No one on the scene took a video,"],[4100,4290,"and the surveillance footage was wiped."],[4323,4514,"Who on earth did you offend?"],[4600,4687,"Was it"],[4690,4784,"Regina?"],[4884,4964,"What did you do?"],[5017,5121,"Impossible!"],[5168,5338,"Even if Regina had the guts,"],[5348,5415,"she wouldn't dare."],[5531,5631,"That guy from last night"],[5658,5768,"seemed pretty powerful."],[5782,5925,"There's no way Regina"],[5932,6075,"could simply buy him off."],[6089,6295,"Then what big shot did you offend?"],[6332,6489,"Are you still in danger?"],[6516,6639,"What are you scared of?"],[6696,6863,"Once my sister joins the Stanton Group board"],[6873,7033,"and takes over my brother-in-law's shares,"],[7056,7150,"in Switan,"],[7150,7216,"aside from the Stantons,"],[7216,7363,"who's more powerful than us?"],[7490,7530,"Irene,"],[7617,7650,"can you really"],[7663,7817,"join the Stanton Group board?"],[7850,7920,"Don't worry."],[7944,8181,"Ms. Warren has already promised me"],[8227,8474,"that she'll transfer half of Marlon's shares"],[8488,8614,"to Andy."],[8678,8778,"I'll hold the shares,"],[8805,8911,"and join the Board."],[8938,9132,"But Regina is Stanton Group's VP now."],[9162,9268,"She definitely won't agree."],[9365,9555,"Over half of the Board members"],[9555,9749,"are Ms. Warren's relatives."],[9782,9989,"What does it matter if Regina disagrees?"],[10006,10069,"Hey, Sis,"],[10116,10209,"you gotta help me find"],[10209,10299,"that punk from last night."],[10363,10553,"I want to chop off his hand myself."],[10573,10770,"Before I join the Board,"],[10810,10933,"don't cause trouble for me!"]],"36":[[393,440,"Mr. Warren."],[483,563,"Hello, Mr. Warren."],[606,666,"Have a seat, everyone."],[1104,1197,"I have an announcement to make."],[1284,1504,"As you all know,"],[1567,1808,"Irene is Andy's mother."],[1858,1928,"I,"],[1974,2115,"in accordance with the law,"],[2151,2245,"am transferring Marlon's"],[2258,2498,"fifty percent of the shares to Andy,"],[2509,2676,"to be held in trust by Irene."],[2702,2795,"Starting today,"],[2825,2932,"Irene officially"],[2962,3129,"joins the Stanton Group Board!"],[3202,3319,"For such a major decision,"],[3369,3429,"how could you"],[3459,3720,"decide so rashly?"],[3796,3886,"You were rash"],[3886,4153,"to give Marlon's position to Regina."],[4153,4267,"So why can't I give some shares"],[4290,4427,"to the child my eldest son"],[4427,4564,"loved the most?"],[4564,4694,"Is there a problem with that?"],[4694,4914,"It was only with my mother's tech support"],[4971,5154,"that Marlon could join the Board."],[5204,5311,"We signed an agreement."],[5358,5521,"The shares are held jointly."],[5561,5611,"Mr. Warren,"],[5641,5718,"you have no right"],[5718,5848,"to distribute mine and Marlon's shares."],[5995,6055,"Is there?"],[6089,6155,"I didn't see it."],[6179,6275,"And I wasn't present."],[6352,6442,"Does anyone here"],[6476,6616,"know about this?"],[6943,7019,"I was there!"],[7103,7176,"George,"],[7206,7413,"my eldest son is dead."],[7540,7633,"Before he passed,"],[7643,7797,"he asked me to care for them."],[7800,7960,"If I can't even do this much,"],[7960,8121,"what kind of mother am I?"],[8257,8321,"Mr. Stanton,"],[8361,8431,"Irene"],[8431,8581,"is also the mother of your biological grandson."],[8591,8741,"You shouldn't play favorites."],[9198,9288,"Regina,"],[9345,9519,"don't be too greedy."],[9549,9726,"You've already had a child."],[9756,9982,"Just take what you deserve."],[10012,10136,"Don't push things too far,"],[10153,10326,"or it'll backfire on you!"],[10883,10960,"Sis,"],[10983,11067,"from now on,"],[11067,11190,"I'll be sitting right next to you."],[11507,11681,"So what if you brought Mr. Whitman"],[11741,11851,"to expose the drugging?"],[11851,11954,"What does it matter?"],[11998,12105,"I can still"],[12131,12355,"sit as your equal."],[12448,12628,"I object to Irene joining the Board."]],"37":[[29,86,"Jared."],[146,243,"What are you doing here?"],[393,433,"Mom,"],[463,586,"now that my big brother is gone,"],[603,747,"can't I join the Board?"],[893,980,"Jared,"],[1034,1207,"that's not what I meant."],[1227,1427,"Andy is your own nephew."],[1467,1647,"I'm letting Irene join the Board"],[1661,1811,"simply to protect"],[1811,1974,"your brother's son."],[2125,2205,"Oh, right."],[2261,2462,"I just overheard from outside"],[2488,2605,"that Regina"],[2622,2749,"mentioned the marital agreement"],[2749,2945,"she signed with my brother."],[3082,3169,"I believe I was there."],[3599,3679,"Uncles,"],[3783,3946,"weren't you two"],[4040,4120,"present back then?"],[4180,4240,"Jared!"],[4240,4434,"This is a Stanton Group board meeting."],[4447,4480,"You"],[4490,4580,"what are you doing?"],[4596,4711,"Put that away, quickly!"],[4781,4904,"I was there."],[4927,5004,"I was there, too."],[5264,5471,"Why is Jared suddenly stepping in"],[5485,5595,"to help Regina?"],[5601,5668,"Jared,"],[5728,5815,"have I"],[5835,6018,"done something to offend you?"],[6045,6212,"You've offended me plenty!"],[6282,6399,"That brother of yours,"],[6416,6512,"Ryan,"],[6576,6869,"has been posing as a Stanton in-law"],[6886,7086,"to bully people everywhere."],[7103,7236,"He even tried to steal my woman."]],"38":[[26,143,"Your woman?"],[226,386,"When did you get a woman?"],[440,483,"Dad,"],[573,656,"that's not the point."],[690,847,"Tell us what happened."],[860,1054,"So the person who cut off Ryan's finger"],[1090,1257,"was actually Jared?"],[1337,1404,"Jared,"],[1421,1597,"my brother has never met you."],[1617,1838,"There must be some misunderstanding."],[1904,1948,"A misunderstanding?"],[2011,2055,"Hah."],[2278,2341,"'Hey kid,'"],[2412,2558,"'I've got my eyes on your wife,'"],[2558,2672,"'you should consider yourself lucky!'"],[2692,2759,"'Scared?'"],[2772,2892,"'My sister'"],[2919,3126,"'gave the Stantons a grandson.'"],[3132,3366,"'She's about to join the board of Stanton Group.'"],[3366,3496,"'If you know what's good for you,'"],[3496,3679,"'get on your knees and kowtow three times.'"],[3689,3880,"'You dare call yourself 'Daddy' in front of me?'"],[3883,4016,"'I'm not only gonna be your Daddy,'"],[4023,4130,"'I'm gonna f*ck your mom!'"],[4170,4230,"Outrageous!"],[4273,4397,"Who gave him the audacity"],[4397,4524,"to be so arrogant?"],[4627,4781,"Jared really came through."],[4797,4927,"Mr. and Mrs. Stanton,"],[4934,5091,"my brother didn't know who Jared was."],[5101,5198,"That's why he offended him."],[5201,5264,"When I get back,"],[5294,5411,"I'll be sure to discipline him."],[5425,5645,"Can he just rob people if he doesn't know them?"],[5718,5945,"He's using the Stanton Group's name,"],[5978,6072,"it's absolutely disgraceful!"],[6142,6215,"This is simply"],[6215,6342,"ruining the Stantons' reputation."],[6359,6486,"I firmly oppose"],[6486,6642,"Irene joining the board!"],[6649,6743,"I disagree as well."],[6783,6956,"Why did she win again?"],[7326,7513,"Uncle Jared, I thought I heard you say"],[7530,7690,"that Stanton Group's upper management"],[7697,7870,"needs some fresh blood."],[8071,8184,"Well said!"],[8254,8341,"So,"],[8548,8694,"I plan to join Stanton Group."]],"39":[[22,86,"Jared,"],[113,279,"you've never run a company."],[339,466,"If you join,"],[493,700,"what position would be suitable for you?"],[753,863,"Regina can step in"],[863,1060,"and take over Marlon's role as President,"],[1134,1237,"and I'll settle for Vice President."],[1571,1801,"Why push me to be Stanton Group's President?"],[1858,1914,"Mr. Warren,"],[1961,2038,"this way,"],[2065,2235,"you won't have to worry"],[2318,2508,"that I'm trying to steal Marlon's legacy."],[2525,2638,"So he's worried"],[2638,2775,"that his biased mother might overthink things."],[2789,2879,"Mr. Warren,"],[2899,3092,"it's time we handed over management"],[3109,3252,"to the younger generation."],[3259,3396,"Let's do as Jared proposes."],[3429,3496,"Jared,"],[3573,3800,"you must do your best to assist Regina"],[3813,3983,"and help her build authority at the company."],[4040,4133,"Rest assured, Chairman."],[4280,4620,"I will support Regina fully."],[4704,4764,"Good."],[5311,5378,"Mrs. Stanton,"],[5401,5621,"you'd better control your arrogant brother!"],[5668,5712,"I"],[5772,5885,"How did this happen?"],[5945,6119,"Not only did I miss the Stanton Group board,"],[6119,6269,"but that b*tch Regina"],[6309,6456,"actually became Stanton Group's President!"],[6539,6786,"This is the executive floor of Stanton Group."],[6806,6916,"Do I need to call security"],[6926,7016,"to drag you out?"],[7033,7303,"Regina, you just wait!"],[8030,8097,"Jared,"],[8134,8227,"thank you for today."],[8401,8458,"Regina,"],[8641,8808,"I look forward to working with you."],[9068,9102,"Mn."],[9372,9445,"Regina,"],[9515,9595,"this position,"],[9619,9819,"if you want to hold onto it,"],[10019,10176,"you'll have to remain a widow for life."],[10236,10370,"You're only twenty-six."],[10486,10606,"Have you thought it through?"],[10679,10830,"Is he suspecting me,"],[10903,11144,"or testing if I'd betray his brother?"],[11274,11481,"Don't worry, Jared."],[11522,11661,"Until the child grows up,"],[11738,11831,"I won't look for anyone else."],[11944,12001,"Regina,"],[12071,12155,"you misunderstand."],[12215,12345,"What I mean is,"],[12852,13082,"if you ever want another man,"],[13209,13296,"I'm available."]],"40":[[393,440,"Miss Regina."],[810,890,"Mr. Carson."],[927,990,"I'll let you get back to work."],[1354,1401,"Miss Regina."],[1410,1467,"Mr. Jared."],[1467,1551,"What's gotten into him?"],[1614,1768,"Does he already know my identity?"],[1824,1918,"No way."],[1948,2068,"If he knew,"],[2078,2235,"would he let me off so easily?"],[2495,2618,"This is from Jared."],[2779,2832,"Sister,"],[2879,3005,"I kicked Ryan's sister"],[3005,3149,"out of the Stanton Group board."],[3182,3219,"Praise me."],[3249,3406,"Is this really the same"],[3406,3553,"domineering Jared from just now?"],[4407,4480,"Jared"],[4514,4660,"Whether you know who I am or not,"],[4701,4904,"you didn't expose me, so you won't, right?"],[5515,5568,"Good job."],[5585,5772,"Then do you dare pause the Stanton Group's"],[5772,5875,"upcoming cooperation with the Carsons?"],[6106,6175,"Of course."],[6482,6546,"To the hospital."],[6596,6679,"To see Ryan."],[7383,7614,"Regina's office chair is pretty comfortable."],[7890,7954,"Mr. Jared,"],[7997,8191,"Madam went to the hospital to visit her brother."],[8241,8304,"Visit"],[8821,9035,"Cancel all cooperation with the Carson Group."],[9242,9385,"Hand over these projects I prepared"],[9462,9545,"to the Project Department."]],"41":[[109,149,"Miss Regina,"],[223,319,"Jared really did stop"],[319,443,"all cooperation with the Carsons."],[460,543,"And he even brought out"],[543,660,"better projects to replace them,"],[686,800,"silencing the Project Department."],[817,1020,"He really played the villain for me."],[1751,1828,"Sis,"],[1868,2011,"did you find the bast*rd"],[2011,2151,"who cut off my finger"],[2151,2238,"at the pool hall last night?"],[2468,2498,"Irene!"],[2512,2585,"Why did you hit him?"],[2598,2865,"It was Jared who cut off his finger."],[2895,3076,"He offended Jared!"],[3082,3152,"What?"],[3172,3266,"You idiot!"],[3302,3383,"Jared"],[3393,3559,"He's known as the Devil himself!"],[3619,3860,"I didn't know it was Jared."],[3896,4006,"I've never even met him."],[4167,4233,"It's all your fault."],[4277,4487,"You cost me my seat on the Stanton board,"],[4501,4667,"and let that bi*ch, Regina,"],[4701,4817,"become the President of Stanton Group!"],[5058,5108,"Irene,"],[5161,5264,"you said your sister"],[5308,5481,"became the President of Stanton Group?"],[5485,5645,"If not for this idiot"],[5645,5785,"offending Jared,"],[5795,6002,"I would be on equal footing with Regina!"],[6179,6282,"With so many women out there,"],[6295,6492,"why did you have to touch his wife?!"],[6669,6749,"I didn't know"],[6756,6903,"she was Jared's wife."],[6919,6949,"You"],[6963,7026,"Hey, Irene,"],[7029,7113,"when did Jared"],[7123,7256,"get married?"],[7296,7340,"Well,"],[7417,7580,"What a lively scene."]],"42":[[46,109,"Regina,"],[153,233,"are you here to see your brother?"],[239,313,"Regina,"],[349,513,"you're visiting a patient."],[546,700,"What's with the chrysanthemums?"],[720,860,"Are you trying to curse Ryan?"],[860,993,"I brought them for Ryan"],[993,1137,"to take to my mother's grave as an apology."],[1200,1280,"What happened?"],[1297,1371,"Three days ago,"],[1394,1574,"Ryan smashed my mother's tombstone"],[1627,1784,"and splashed dog blood on it."],[2028,2161,"Is what she said true?"],[2175,2318,"You shouldn't have bullied my sister!"],[2345,2522,"She deserved a lesson."],[2522,2608,"Let's see if she dares"],[2625,2722,"stand in my sister's way again."],[2755,2869,"You ungrateful brat!"],[2892,2985,"How could you do"],[2992,3142,"something so disgraceful?"],[3259,3326,"Regina,"],[3389,3523,"I'll go fix your mother's grave."],[3539,3656,"Ryan is just a kid,"],[3693,3790,"and he's injured."],[3836,3943,"When he gets home,"],[3953,4083,"I'll make sure to discipline him."],[4143,4217,"Richard,"],[4217,4360,"it's because you spoil him"],[4360,4574,"that Ryan is so out of control."],[4610,4724,"I've already fixed the grave."],[4774,4847,"But,"],[4911,5108,"I want him and Alma"],[5118,5274,"to kneel and apologize at my mother's grave."],[5301,5425,"You want my mom"],[5458,5655,"to kneel and apologize to yours?"],[5695,5805,"You've got some nerve!"],[5855,5952,"Regina,"],[5982,6045,"I swear,"],[6045,6139,"I'll dig up your mom's ashes"],[6139,6242,"and scatter them!"],[6322,6409,"Shut your mouth!"],[6462,6516,"Uh,"],[6542,6616,"please don't take"],[6643,6739,"what the kid said seriously."],[6863,6986,"Still not leaving?"],[7093,7183,"I'm counting to three."],[7213,7256,"Regina,"],[7286,7417,"just because you're President of Stanton Group,"],[7440,7523,"doesn't mean you can turn on your family."],[7567,7700,"Our partnership with the Stanton Group"],[7704,7907,"has been solid for years."],[7997,8047,"It's not like"],[8047,8194,"you maintained it all by yourself."],[8207,8261,"Three."],[8584,8664,"Chairman, bad news!"],[8688,8805,"Jared claims the Young Master"],[8805,8948,"ruined Stanton Group's reputation,"],[8964,9095,"so he ended all cooperation."]],"43":[[11,61,"Dad!"],[163,243,"What happened?"],[266,390,"Jared has stopped"],[390,560,"all of Stanton Group's cooperation with us."],[576,646,"What do we do?"],[650,803,"Go ask Mr. Stanton about this immediately."],[837,1037,"How can he just end the cooperation?"],[1154,1237,"Hey, Regina,"],[1267,1417,"you're the President of Stanton Group."],[1417,1644,"Jared should listen to you, right?"],[1687,1728,"Dad."],[1764,1921,"The Carsons and the Stantons"],[1974,2221,"rely on years of solid ties,"],[2308,2372,"not on me."],[2465,2642,"The Carsons are your family, too."],[2672,2815,"We rise together,"],[2869,2959,"and we fall together."],[3019,3259,"My mom's new headstone hasn't even dried,"],[3316,3486,"and a bastard smashed the First Wife's grave."],[3529,3669,"And you're talking to me about rising together"],[3669,3760,"and falling together!"],[4067,4150,"Regina!"],[4187,4384,"Don't you threaten Dad with that here!"],[4400,4517,"You better hurry up"],[4517,4654,"and restore the partnership with Carson Group."],[4677,4781,"Otherwise,"],[4781,4974,"I'll go dig up your mom's ashes right now"],[4974,5084,"and scatter them to the wind!"],[5104,5168,"Try me!"],[5551,5635,"You scoundrel!"],[5680,5792,"But Dad,"],[5842,5925,"she's your daughter."],[5925,6022,"She should listen to you."],[6022,6139,"What are you afraid of?"],[6202,6245,"Dad,"],[6285,6402,"weigh your options."],[6416,6472,"(Sighs)"],[6679,6723,"Get up."],[6759,6843,"Go apologize to your First Mother!"],[6863,6903,"Dad!"],[6933,6996,"You've ruined the Carsons."],[6996,7103,"You're no son of mine."],[7186,7300,"Talk nicely to him."],[7327,7457,"His hand is still hurt!"],[7954,8017,"First Mother,"],[8057,8144,"I'm sorry."],[8264,8334,"Louder."],[8381,8454,"Regina!"],[8461,8534,"Do you have a death wish?"],[8631,8728,"Kowtow!"],[8748,8851,"Apologize sincerely."],[8868,8935,"Regina,"],[8965,9052,"Ryan made a mistake."],[9078,9148,"I'll apologize for him!"],[9238,9285,"Mom,"],[9298,9369,"you see?"],[9409,9505,"True love might not"],[9505,9662,"make a man bow to you,"],[9726,9819,"but power can."],[9982,10046,"Regina,"],[10117,10333,"just keep moving forward with your head held high,"],[10356,10470,"and the thorns in your path,"],[10506,10607,"I'll cut them down for you."]],"44":[[133,189,"Hey, Regina."],[263,336,"About the partnership"],[362,506,"You need to restore it ASAP!"],[543,743,"Give me back my mom's shares,"],[783,980,"and I'll resume the partnership with Carson Group."],[1000,1110,"You b*tch!"],[1110,1237,"You're going back on your word, aren't you?!"],[1531,1634,"Given the Carson Group's current state,"],[1653,1778,"it probably won't last more than three days."],[1848,1898,"Lena,"],[1898,1951,"let's go."],[2311,2355,"Dad,"],[2435,2688,"are you really giving Regina the shares?"],[2722,2869,"I'm your only son!"],[2895,3096,"Everything the Carsons own is mine!"],[3096,3186,"It's mine!"],[3216,3366,"If you hadn't offended Jared,"],[3396,3549,"Irene would've joined Stanton Group by now."],[3603,3720,"We wouldn't have to beg her!"],[3830,3976,"If it weren't for Regina,"],[3976,4117,"I'd have joined the Stantons long ago!"],[4147,4243,"You're right."],[4390,4547,"Then we'll just have to make her disappear."],[9682,9779,"Water"],[11441,11561,"It's bitter."],[11728,11788,"Silly girl,"],[11938,12048,"medicine is always bitter."],[12285,12331,"Here."],[13319,13399,"Mom"],[13689,13806,"Alma Harper,"],[13956,14193,"she knelt down and apologized to you."]],"45":[[103,183,"Mom,"],[293,543,"I did exactly as you said."],[666,967,"I became the perfect Stanton wife."],[1681,1811,"I didn't expect you to be so fragile."],[4397,4530,"Did anyone come by last night?"],[5218,5278,"What is it?"],[5304,5378,"Mr. Jared,"],[5408,5545,"Bennett has been crying all day,"],[5558,5655,"and I couldn't soothe him at all."],[5678,5798,"I came to check on Mrs. Stanton"],[5798,5898,"to see if she was awake."],[5932,5982,"Give him to me."],[6179,6235,"I'm up."],[6252,6332,"Give me the child."],[6589,6632,"Regina."],[6672,6819,"Why are you so guarded around me?"],[6873,6980,"Just like my mom,"],[6999,7126,"afraid I'll hurt the child?"],[7146,7326,"Did his mother's bias against him growing up"],[7367,7573,"leave a shadow over him?"],[7603,7840,"Jared, you've misunderstood Regina."],[7860,8064,"Regina's just worried that if Bennett cries,"],[8094,8164,"he'll annoy you."],[8201,8277,"He stopped."],[8304,8421,"Earlier, when Bennett"],[8421,8511,"was making a fuss,"],[8511,8761,"he stopped the moment he saw Mr. Jared."],[8788,8861,"Is that so?"],[8891,8991,"Uncle Jared"],[8991,9228,"has been called a little devil growing up,"],[9265,9465,"but our Bennett isn't afraid of him at all."],[9532,9612,"Maybe,"],[9649,9799,"he thinks I'm his dad."]],"46":[[7,131,"Jared's right."],[139,276,"He looks just like his big brother."],[337,451,"Our Bennett is smart."],[469,546,"He knows his own kin."],[674,861,"Mr. Jared is so handsome,"],[875,975,"when he has kids of his own,"],[985,1175,"they'll surely be as cute as Bennett here."],[1215,1278,"Oh, by the way,"],[1325,1472,"aren't you seeing someone?"],[1485,1605,"What's her background?"],[1605,1665,"How old is she?"],[1699,1856,"When will you bring her home?"],[1856,2002,"Let your mom and me meet her."],[2022,2149,"I'll ask her today."],[2276,2380,"Better hurry."],[2403,2476,"I want to see"],[2520,2680,"exactly what kind of woman"],[2680,2810,"is worth our Jared"],[2810,3037,"cutting off two fingers for."],[3124,3187,"Jared."],[3220,3310,"Ben is asleep."],[3344,3461,"I'll take him back to his room."],[3467,3524,"Regina,"],[3594,3657,"you have a cold."],[3714,3801,"I'll take him in."],[4004,4148,"Jared, that boy,"],[4171,4295,"has really grown up."],[4315,4592,"He used to hate kids."],[4592,4745,"He even threw his Second Aunt's granddaughter"],[4765,4922,"right into the snow."],[4979,5029,"What was it that"],[5029,5222,"made such a cynical playboy"],[5252,5386,"change so drastically?"],[7565,7678,"It was Jared last night."],[7752,7895,"He knows who I really am."]],"47":[[156,220,"Regina,"],[246,370,"you've been staring at me."],[396,480,"Do you want to"],[503,583,"You're handsome,"],[624,774,"but I'm not that desperate."],[816,900,"Ben is asleep."],[928,998,"Put him down."],[2106,2153,"Regina,"],[2230,2293,"do you also think"],[2320,2443,"he looks a lot like me?"],[4866,4913,"Regina,"],[4913,5040,"I'll transfer the shares to you."],[5040,5153,"Are you satisfied?"],[5160,5313,"Come to the office today to sign."],[5326,5493,"Okay, I'll be there later."],[5843,5983,"My dad wants to give my mom's shares"],[6013,6070,"back to me."],[6096,6206,"The condition is"],[6400,6503,"that Stanton Group continues cooperating"],[6503,6566,"with Carson Group."],[6650,6780,"You're the President."],[6850,7013,"If you want to work with the Carsons,"],[7040,7110,"I have no objections."],[7320,7460,"I'm going to Carson Group today."],[7526,7606,"Okay."],[8430,8510,"I'm here."],[8590,8670,"Where are you?"],[9523,9610,"Why are you here?"],[9703,9863,"This is my company!"],[9903,10036,"Now that my sister is here,"],[10113,10236,"of course I need to find someone"],[10236,10363,"to take good care of her."],[10396,10518,"It's a trap."],[10673,10743,"Sister,"],[10780,10923,"where are you going?"],[10936,11000,"Get out of my way."],[11270,11356,"Regina,"],[11443,11590,"you can't escape today."],[11593,11673,"What do you want?"],[11693,11813,"Take good care of her."],[11840,11973,"When she's exhausted,"],[11990,12110,"throw her down"],[12110,12213,"from right here."],[12233,12290,"Heh heh heh."],[12306,12470,"Don't worry, Mr. Carson."],[12470,12526,"The two of us"],[12526,12600,"will make sure Regina"],[12610,12840,"has a really good time."]],"48":[[22,93,"Ryan!"],[126,223,"This is the Carson Group."],[229,323,"You dare touch me here?"],[329,400,"Exactly."],[416,637,"Doing it right here is the best part!"],[807,970,"Young Mrs. Stanton,"],[1007,1134,"unwilling to be a widow,"],[1134,1284,"returns to her maiden home for a fling,"],[1304,1561,"and falls to her death after getting caught."],[1591,1728,"I've even written the headline for you."],[1781,1908,"Not bad, huh?"],[2055,2241,"What are you waiting for? Do it!"],[2268,2465,"I wonder just how good"],[2482,2588,"Young Mrs. Stanton feels."],[2678,2755,"Let go of me."],[2819,2912,"Let me go!"],[3196,3299,"This little b*tch is feisty."],[3369,3516,"You like to scream, don't you?"],[3526,3686,"I'll f*cking let you scream all you want!"],[3726,3763,"Yeah."],[3780,3900,"Make sure she gets her fill!"],[3920,4123,"I'll take some videos to post online,"],[4123,4267,"so everyone can see"],[4280,4387,"just how much of a sl*t"],[4387,4547,"Young Mrs. Stanton is"],[4547,4771,"when she's with a man."],[4791,4874,"Ryan!"],[4904,5007,"You animal!"],[5258,5311,"Irene,"],[5391,5518,"are you sure we'll be okay?"],[5558,5712,"George values Regina."],[5712,5838,"If something happens to her,"],[5882,5945,"won't the Stantons"],[6015,6172,"come after us?"],[6172,6212,"Pfft."],[6299,6479,"For a powerful family like the Stantons,"],[6512,6699,"if Regina dies here today"],[6726,6886,"in such a disgraceful way,"],[6903,7060,"they'll be dying to"],[7060,7146,"cut ties with Regina."],[7273,7361,"Let go of me!"],[7383,7447,"Richard!"],[7457,7547,"You sick old b*stard!"],[7567,7693,"You're gonna pay for this!"],[7717,7774,"Dad,"],[7794,7910,"don't worry."],[7930,8010,"At the Stantons',"],[8020,8197,"as long as we don't touch Jared's property,"],[8223,8304,"we're safe."],[8347,8388,"Let's go."],[8578,8648,"Jared"],[8775,8841,"Let go of me!"],[9048,9158,"Didn't you love"],[9158,9392,"making me kneel at your mom's grave?"],[9399,9532,"I knelt for a while,"],[9555,9672,"so I'll send a video of you"],[9759,9892,"to your mom's grave."],[9892,10032,"I'll let her enjoy the show too."],[10043,10096,"How about that?"],[10096,10136,"Go to h*ll!"],[10199,10296,"Ryan!"],[10486,10566,"Hurry up!"],[10580,10737,"Rip her clothes off!"],[10767,10847,"Let go of me!"],[11124,11190,"Let her go!"],[11297,11360,"Jared!"]],"49":[[53,89,"You"],[89,136,"what are you doing?"],[738,848,"Security!"],[850,940,"Who let him in?"],[1277,1364,"Where the h*ll did you come from?"],[1364,1447,"Do you have a death wish?"],[2348,2448,"It's okay, Regina."],[3209,3249,"Mr. Jared."],[3286,3486,"Get rid of this man for good."],[3743,3876,"Mr. Stanton?"],[3893,4010,"Listen to me!"],[4030,4167,"It was that bi*ch Regina!"],[4167,4277,"She seduced me herself!"],[4991,5174,"How did Regina survive again?"],[5274,5338,"Son!"],[5488,5668,"M-Mr. Stanton"],[5728,5798,"Richard."],[5845,5955,"You don't have a son anymore."],[6025,6099,"Ah!"],[7226,7296,"Let go of me!"],[7323,7383,"Get away!"],[7530,7590,"Regina."],[7680,7744,"It's me."],[8254,8351,"Jared."],[8514,8621,"Where am I?"],[8765,8851,"This is my villa."],[8951,9045,"Just rest easy."],[9092,9242,"How did you know to come find me?"],[9412,9665,"You told me you were going to Carson Group."],[9709,9832,"Isn't it obvious"],[9866,10029,"that you knew your father's motives"],[10056,10206,"and wanted to secure a way out?"],[10256,10503,"I didn't expect him to actually guess my thoughts."],[10750,10867,"Regina,"],[10907,11114,"do you find your brother-in-law"],[11150,11224,"to be a useful pawn?"],[11297,11421,"I don't know what you're talking about."],[11567,11627,"Then what about this?"]],"50":[[150,230,"Then what about this?"],[417,497,"Don't."],[840,920,"Regina."],[1011,1184,"I can be your pawn,"],[1368,1564,"but you can't treat me like a castoff"],[1611,1691,"to simply discard."],[1825,1985,"After Mom died, he was"],[2038,2208,"the first person willing to protect me."],[3913,3987,"Jared."],[4080,4204,"I'm your sister-in-law."],[4277,4377,"We can't do this."],[4414,4511,"\"We can't do this\"?"],[4657,4821,"You bore my child, yet we \"can't do this\"?"],[4888,5001,"Is that right?"],[5131,5275,"Then what are we doing in the car?"],[6586,6666,"Irene."],[6826,6910,"It's Irene."],[6970,7123,"They saw you take me away."],[7167,7250,"I have to go home,"],[7300,7410,"or they'll get suspicious."],[8214,8371,"You're afraid of their suspicion,"],[8445,8508,"but aren't you afraid of me"],[8511,8634,"exposing the truth?"],[9072,9152,"Jared."],[9299,9496,"It hasn't been easy for me to get here."],[10380,10520,"Have you ever begged"],[10600,10747,"Marlon like this?"],[10964,11027,"No."],[12038,12145,"I'll let you go back for now."],[12318,12412,"Ian will drive you."],[15135,15198,"Mr. Jared."],[15211,15355,"Mrs. Marlon won't let me drive her."],[15385,15535,"Mrs. Jared."],[15658,15769,"Who is Mrs. Marlon?"],[15829,15922,"She said"],[15922,16026,"Lena is coming to pick her up."],[16479,16619,"The evidence against Ryan,"],[16636,16736,"have you gathered it all?"],[16750,16810,"Yes."],[16846,17030,"Regina has also been collecting it secretly."],[17030,17163,"The evidence of Ryan's crimes"],[17193,17360,"is enough to put him away for life."],[17497,17674,"She doesn't fight battles she can't win."]],"51":[[226,296,"Miss Regina,"],[320,480,"your father is a real piece of work."],[500,630,"You're his own flesh and blood."],[674,744,"Hand over"],[744,874,"all the evidence against Ryan"],[904,1011,"to the police."],[1081,1127,"Understood."],[1187,1254,"He won't be coming out."],[1348,1414,"Richard,"],[1494,1638,"let your precious son"],[1638,1715,"continue the Carson family line"],[1715,1891,"from inside the prison."],[1955,2018,"Today,"],[2018,2175,"it's a good thing Mr. Jared arrived in time."],[2245,2345,"Otherwise, the consequences"],[2372,2459,"would have been unimaginable."],[2689,2809,"Why did Mr. Jared"],[2809,2896,"suddenly decide to go to"],[2896,2986,"Carson Group to save you today?"],[2986,3053,"Miss Regina,"],[3136,3216,"He knows"],[3336,3476,"I'm the one who slept with him."],[3656,3777,"What?"],[3847,3967,"Then what do we do?"],[4187,4267,"Regina,"],[4344,4541,"I can be a pawn for you,"],[4594,4791,"but you can't treat me like I'm disposable"],[4938,5018,"and throw me away."],[6486,6639,"If Ryan goes to jail,"],[6639,6823,"what will we do in the future?"],[7267,7404,"Why hasn't the lawyer called yet?"],[7460,7567,"Mom, Dad,"],[7574,7744,"don't worry too much."],[7757,7844,"Regina"],[7844,8021,"didn't suffer any substantial harm."],[8034,8118,"Ms. Warren"],[8118,8258,"has also agreed to help."],[8388,8558,"My brother won't get a heavy sentence."],[9072,9129,"Chairman,"],[9129,9319,"Uncle received proof of the Young Master's crimes."],[9349,9492,"Including charges for rape and running"],[9492,9649,"an illegal underground casino."],[9649,9816,"He's facing at least twenty years."],[9916,10003,"What did he say?"],[10353,10457,"The lawyer said,"],[10509,10597,"Ryan"],[10647,10834,"will be sentenced to at least twenty years."],[10917,11074,"My poor boy!"],[11174,11307,"Mom."]],"52":[[80,170,"Madam,"],[206,373,"Bennett hasn't had any milk all afternoon."],[400,520,"He's throwing up and has diarrhea."],[550,590,"We need to go to the hospital."],[590,674,"I'll get the car!"],[1294,1371,"I'll take his temperature."],[1651,1778,"The baby won't hold the thermometer still."],[1788,1851,"You have to hold it."],[1905,2032,"Check it in five minutes."],[2095,2172,"Dad,"],[2235,2302,"He's not."],[2909,3053,"This kid's health is nothing like mine."],[3099,3253,"I was never hospitalized as a kid."],[3363,3460,"You were so little,"],[3503,3603,"you remember that?"],[3626,3680,"My mom told me."],[4137,4330,"Grow up fast, Ben."],[4371,4454,"When you grow up,"],[4471,4637,"Daddy will teach you how to play basketball."],[4797,4914,"Jared!"],[4973,5127,"Stop talking nonsense."],[5218,5345,"Which part is nonsense?"],[5488,5672,"That I'm not the father,"],[5725,5875,"or that I can't teach him to play ball?"],[6259,6359,"Five minutes should be up."],[6720,6790,"Be careful."],[6926,7057,"Don't drop the baby."],[7137,7197,"Regina."],[7500,7644,"What are they doing here?"]],"53":[[136,246,"Five minutes are up."],[273,413,"Let me see the thermometer."],[940,1014,"Hand it over."],[1247,1584,"Why are Regina and Jared"],[1601,1761,"at the hospital with a child?"],[1958,2102,"And holding each other?"],[2455,2612,"The little one has a slight fever."],[2669,2772,"Probably just a cold."],[2799,2866,"I'll prescribe some medicine."],[2922,3029,"Take it home,"],[3056,3133,"and keep an eye on him."],[3166,3209,"Okay."],[3219,3289,"Thank you, Doctor."],[3636,3763,"This dad is really hands-on."],[3767,3897,"Much better than most fathers."],[3903,3973,"He's not"],[4024,4144,"Let's go get the medicine."],[4207,4324,"If only he could openly"],[4324,4504,"love Bennett"],[4657,4754,"What am I thinking?"],[4778,4901,"He can only be Bennett's uncle."],[4944,5028,"Why are you zoning out?"],[5064,5141,"Let's go get the medicine."],[5799,5982,"Look at that kid's dad."],[6002,6172,"Handsome and caring."],[6216,6339,"Dad"],[6445,6653,"Could Regina's child"],[6713,6866,"be Jared's?"],[7000,7153,"I need to confirm this."],[7747,7844,"Andy,"],[7891,8034,"Mommy has a job for you."]],"54":[[206,280,"Regina,"],[290,403,"how is Ben?"],[450,593,"The doctor said he caught a cold,"],[593,680,"so it's nothing serious."],[694,820,"Don't worry, Dad."],[940,1014,"Ma'am,"],[1044,1174,"I see Bennett is asleep."],[1191,1341,"Let me take him."],[1775,1865,"For the next few days,"],[1911,2028,"just stay at home"],[2048,2142,"and keep Bennett company."],[2192,2258,"It's also a good time"],[2258,2389,"to prepare for"],[2389,2535,"Ben's hundred-day banquet."],[2552,2702,"As for company matters,"],[2722,2889,"leave them to Jared."],[2889,2942,"Okay."],[3206,3286,"Jared,"],[3303,3390,"I've noticed"],[3390,3533,"you've become much more responsible."],[3540,3623,"You even knew"],[3623,3820,"to accompany Regina to the hospital"],[3820,4017,"to get Bennett treated."],[4154,4214,"Mhm."],[4240,4371,"If he were truly responsible,"],[4371,4497,"he would find a partner"],[4527,4711,"and settle down soon,"],[4734,4861,"instead of fooling around all day."],[4898,5098,"Jared, listen to me."],[5128,5241,"You need to hurry up"],[5248,5328,"with your personal life."],[5362,5442,"Regina,"],[5485,5665,"if you know anyone suitable,"],[5719,5842,"someone right for Jared,"],[5842,5962,"please introduce them."],[6062,6186,"I don't think Regina wants"],[6186,6316,"me to settle down so early."],[6466,6596,"Is he trying to get me killed?"],[6873,6946,"Jared,"],[7013,7110,"Mom and Dad are right."],[7190,7283,"It's time you started a family."],[7447,7504,"Okay."],[7580,7681,"I'll listen to you, Regina."],[10170,10250,"Jared?"],[10326,10450,"What are you doing in my room?"],[10900,10994,"Jared!"],[11061,11171,"We're at home."],[11181,11317,"Do you realize what you're doing?"],[11705,11768,"Regina,"],[11875,12038,"since you want me to start a family,"],[12092,12218,"then marry me."],[12292,12445,"I'll go tell the old man right now."]],"55":[[77,220,"I don't want to call you Regina anymore."],[353,500,"I want our son"],[573,723,"to openly call me Dad."],[1978,2075,"We're at home."],[2130,2260,"People will get suspicious if they see us."],[2706,2809,"Don't cry, Ben."],[2839,2899,"Be a good boy."],[3226,3306,"Regina,"],[3386,3563,"are you that afraid of being found out?"],[3680,3853,"The Stantons' eldest daughter-in-law position"],[3853,3970,"and whatever it offers you,"],[4003,4100,"I can give you too."],[4491,4607,"I won't take that risk."],[4901,4968,"Mr. Jared,"],[4977,5191,"why are you in your sister-in-law's room?"],[6703,6913,"Joanna Warren favors Marlon so much."],[6943,7037,"If she finds out this child"],[7037,7130,"isn't Marlon's,"],[7193,7357,"she'll go completely crazy."],[7887,7994,"Uncle Jared,"],[8084,8178,"what are you doing?"],[8218,8341,"I came to use the bathroom."],[9035,9092,"Mom,"],[9092,9396,"I got Uncle Jared and Ben's hair."],[10507,10583,"Miss Carson,"],[10607,10704,"the test results are out."],[11221,11444,"It's a ninety-nine percent match."],[11464,11591,"It's a biological match."],[11644,11745,"No wonder."],[11778,11955,"I knew Marlon wouldn't lie to me."],[12098,12215,"Regina,"],[12252,12472,"cheating with your brother-in-law,"],[12489,12726,"and passing off Jared's child"],[12726,12889,"as Marlon's."],[12912,13159,"You're finished this time!"],[13873,14010,"Go get things ready."],[14047,14237,"At Regina's son's"],[14237,14347,"hundred-day banquet,"],[14421,14594,"I want to give her a surprise."]],"56":[[1855,1921,"Jared,"],[1995,2092,"what is the meaning of this?"],[2132,2252,"This is Uncle Jared's"],[2268,2419,"gift of assets to the child."],[3600,3666,"Jared,"],[3720,3910,"you're giving Bennett three buildings"],[3950,4154,"and all your shares in the Stanton Group?"],[4544,4691,"Is he losing his patience?"],[4701,4764,"Jared,"],[4764,4898,"that is incredibly generous."],[5001,5068,"Why,"],[5121,5231,"is Uncle Jared so bad that"],[5258,5378,"even giving the child a gift"],[5378,5488,"is met with suspicion?"],[5585,5668,"No,"],[5735,5805,"Jared,"],[5855,5985,"I just didn't expect"],[6029,6169,"you to care so much about"],[6169,6319,"your older brother's child."],[6319,6383,"He isn't my"],[6383,6436,"Jared."],[6680,6813,"These gifts are too expensive."],[6863,6963,"Bennett can't accept them."],[7017,7170,"Exactly, Jared."],[7183,7283,"In the future, you"],[7283,7474,"will have your own family and children."],[7474,7574,"Since you've given everything to Bennett,"],[7600,7660,"then later,"],[7660,7827,"what about your own children?"],[7854,7994,"Even for a biological son,"],[7994,8174,"it's rare to give so much."],[8221,8328,"Don't worry."],[8528,8641,"For my own son,"],[8705,8872,"even if he wanted the stars in the sky,"],[9025,9129,"I would pluck them for him."],[9746,9789,"Then,"],[9823,9999,"then you should hurry up and get married"],[9999,10093,"and have a child."],[10377,10627,"Jared doesn't need to marry or have kids."],[10653,10840,"Regina's son"],[10840,11004,"It is his child."]],"57":[[16,203,"Regina's son"],[203,367,"is his child."],[557,774,"Irene, what are you saying?"],[777,970,"Regina's child"],[970,1104,"isn't Marlon's,"],[1121,1271,"it's Jared's."],[1401,1461,"Oh my God."],[1461,1594,"That's absolutely shocking."],[1601,1795,"A child between Regina and Uncle Jared."],[1870,2015,"What nonsense are you talking about?"],[2035,2138,"I'm not talking nonsense."],[2155,2335,"I already took Jared's"],[2335,2475,"and the child's hair"],[2475,2639,"for a DNA test."],[3430,3513,"Is this child"],[3553,3707,"really Jared's?"],[3883,3943,"Mom,"],[3980,4214,"Irene got samples from who knows where,"],[4214,4334,"and with just one test report,"],[4334,4474,"she thinks she can slander my reputation?"],[4521,4634,"Regina,"],[4681,4954,"you won't admit it until you're cornered, right?"],[4998,5088,"If you don't believe me,"],[5088,5155,"you can take"],[5155,5275,"samples from both of them"],[5281,5392,"and test them again."],[5392,5475,"Then you'll know."],[5622,5762,"Jared gave this child"],[5762,5882,"so many things."],[5915,6059,"It is indeed suspicious."],[6876,7093,"Simon, take them for a test."],[7093,7227,"Do it as fast as possible."],[7240,7377,"Oversee it personally."],[7721,7807,"Regina,"],[7827,8044,"you cheated on Marlon."],[8064,8281,"Just wait to be kicked out of the Stantons."],[8294,8438,"The results aren't even out yet."],[8471,8581,"What makes you so sure"],[8591,8722,"that I cheated on Marlon?"],[8815,8968,"She fits still so calm."],[9102,9209,"Then we'll just"],[9242,9366,"wait for the results."],[9469,9679,"If what Irene said is true,"],[9783,9876,"the two of you"],[9933,10113,"get the h*ll out of the Stantons!"],[11137,11197,"Don't be scared."],[11224,11351,"Being kicked out of the Stantons is perfect."],[11361,11451,"We'll be together."],[11484,11621,"My assets outside the family"],[11634,11798,"will keep our son rich for generations."],[11935,12022,"The results are out."]],"58":[[0,76,"The results are out."],[153,216,"Hurry, hurry."],[518,674,"Isn't this... isn't this the same result"],[674,757,"as the test I did"],[757,904,"with Bennett?"],[980,1054,"Irene,"],[1061,1231,"what on earth is going on?"],[1611,1721,"That's impossible."],[1738,1855,"I already ran a test,"],[1865,2018,"and they were a father-son match."],[2098,2202,"This report"],[2202,2369,"was it tampered with?"],[2419,2555,"I handled the whole process alone."],[2575,2712,"No one else touched it."],[2729,2792,"That's right."],[2809,3009,"Simon wouldn't lie to me."],[3063,3119,"No"],[3153,3279,"It must be that you"],[3299,3416,"contacted the doctor in advance"],[3416,3523,"and bribed him!"],[3556,3630,"Irene,"],[3646,3760,"get a grip."],[3777,3833,"Did I know"],[3833,3970,"you were coming to frame me today?"],[3980,4147,"How could I have contacted the doctor?"],[4170,4247,"Irene,"],[4310,4597,"you've tried to harm Regina time and again."],[4654,4808,"What exactly do you want?"],[4871,4958,"Mr. Stanton,"],[4958,5171,"I had Andy collect hair from Jared"],[5171,5258,"and Bennett,"],[5258,5412,"and we did a paternity test."],[5472,5542,"Mrs. Stanton,"],[5542,5679,"you must believe me."],[5822,5992,"But these results show"],[6009,6149,"that Bennett and Jared"],[6149,6296,"are only relatives."],[6296,6353,"This"],[6519,6643,"this can't be right."],[6700,6896,"Mrs. Stanton, let's do it again."],[6896,7060,"We'll go to the hospital and supervise it."],[7070,7157,"Enough."],[7190,7297,"What do you take me for?"],[7370,7557,"What do you take the Stantons for?"],[7627,7754,"I didn't lay a hand on you earlier"],[7764,7971,"because today is a special occasion."],[8004,8131,"Don't push your luck."],[8154,8274,"Jared is right."],[8398,8465,"Security!"],[8465,8591,"Drag her out."],[8611,8718,"From now on,"],[8725,8895,"Andy and this mother of his"],[8895,9032,"have nothing to do with each other!"],[9032,9175,"If he dares to acknowledge her as his mother,"],[9225,9362,"kick him out of the Stantons too!"],[9456,9622,"You're stealing my son!"],[9676,9739,"No!"],[9739,9906,"Andy is my son!"],[9913,10006,"Drag her out!"],[10063,10173,"Regina!"],[10190,10340,"What kind of tricks did you pull?"],[10350,10430,"Bennett is clearly"],[10440,10647,"Jared's son!"]],"59":[[0,80,"Spreading such lies,"],[80,266,"aren't you afraid of karma?"],[363,437,"No!"],[697,870,"I bribed Simon long ago."],[907,1004,"How could I possibly let you"],[1004,1167,"get dirt on me so easily?"],[1214,1277,"Regina,"],[1331,1434,"you've suffered enough."],[1551,1698,"Mom, Dad,"],[1735,1838,"the guests have all arrived."],[1851,1935,"Let's sit down."],[1951,2062,"- Oh, okay. - Sure."],[2062,2128,"Come on,"],[2128,2212,"let's sit."],[2832,2906,"Mr. Jared,"],[2919,3036,"three days ago, Lena"],[3036,3176,"already bribed Simon."],[3530,3610,"Nice."],[3690,3867,"Taking money from three people."],[4010,4100,"Top tier."],[4354,4517,"I want to earn three salaries, too."],[5191,5395,"Why doesn't this guy know to keep his distance?"],[5779,5859,"Jared,"],[5922,6052,"go sit on the opposite side."],[6072,6236,"I invited Ruth from Northmark,"],[6262,6459,"the youngest daughter of the Blakes."],[6476,6706,"Make sure to have a good chat with her today."],[6940,7010,"Regina,"],[7037,7170,"Ruth's older sister"],[7200,7347,"was your classmate, right?"],[7414,7527,"That works out perfectly."],[7527,7704,"You can play matchmaker for Jared."],[7867,7947,"Okay."],[8608,8702,"We're here."]],"60":[[73,253,"Ashley, you're here."],[337,493,"This is my little sister, Ruth."],[543,710,"Last time I saw her, she was a little girl."],[724,807,"She's all grown up."],[867,934,"Come, sit down."],[1364,1421,"Jared."],[1444,1554,"I brought you a gift."],[1728,1788,"Thanks."],[2065,2172,"Ruth,"],[2252,2442,"you brought a gift for Jared,"],[2445,2649,"but did you bring anything for us?"],[2665,2752,"I did."],[2769,2836,"It's just"],[2836,3043,"I was in a rush and forgot to bring them."],[3123,3329,"Oh, listen to her."],[3329,3570,"She only has eyes for Jared."],[3570,3763,"Oh, we get it."],[3777,3893,"Exactly."],[3917,4050,"Since we got back,"],[4050,4234,"we haven't seen a gift from her either."],[4234,4318,"Sis!"],[5098,5168,"- Mom. - Hm?"],[5168,5261,"Bennett is hungry."],[5268,5375,"I'm going to go feed him."],[5382,5495,"Okay, go ahead."],[7620,7747,"Let's hide out here."],[8101,8204,"What are you doing here?"],[8355,8441,"Looking for you."],[9149,9239,"Go ahead, scream."],[9315,9409,"Why aren't you screaming?"],[9806,9939,"I told you,"],[9959,10076,"I won't be a castoff."],[10130,10256,"How dare you even think"],[10256,10383,"about discarding me?"],[10491,10571,"Jared,"],[10620,10740,"considering the risk I took"],[10754,10860,"to have a child by you,"],[10897,11007,"you should know"],[11061,11247,"how important it is to be"],[11254,11394,"the Lady of the house!"],[11408,11481,"What about me?"],[11634,11811,"You barged into my world."],[11858,12001,"Did you ever think I'd fall for you?"],[12395,12462,"I'm sorry, Jared."],[12555,12662,"Ruth is better for you."],[12879,12986,"Better for me?"],[13363,13530,"I think I'm better for you."]],"61":[[90,250,"Jared, Jared, not here!"],[306,380,"No."],[580,734,"I just want you to know,"],[820,944,"that if I want something,"],[1014,1157,"no one can stop me."],[1661,1741,"Jared."],[1808,1975,"What will it take for you to let me go?"],[2028,2118,"Let you go?"],[3493,3683,"This is the last time I let you go."],[4104,4264,"Stay away from me from now on."],[5672,5745,"Regina."],[5795,6022,"What took you so long to feed Ben?"],[6079,6196,"Ben fell asleep."],[6219,6349,"I was afraid it was too crowded inside,"],[6349,6433,"and it would wake him."],[6499,6559,"Oh."],[6790,6940,"Did you see Jared?"],[7017,7097,"No."],[7210,7400,"Then let's go eat."],[7517,7594,"Let's go."],[8018,8084,"Just now, the lady entering"],[8084,8274,"Mr. Jared Stanton's office,"],[8284,8505,"they say she's Mr. Jared Stanton's fiancée."],[8528,8631,"She's beautiful,"],[8648,8788,"and comes from a good family."],[8795,8875,"She and Mr. Jared Stanton"],[8875,8978,"are a match made in heaven."],[8978,9029,"Exactly."],[9285,9416,"It's lunch time. Why aren't you eating"],[9436,9546,"instead of gossiping here?"],[9639,9726,"Mr. Carson."],[10253,10353,"Regina."],[10410,10550,"Ruth, you're here."],[10563,10694,"I'm here to have lunch with Jared."],[10754,10900,"Do you want to join us?"]],"62":[[13,150,"I'm here to have lunch with Jared."],[186,337,"Do you want to join us?"],[383,433,"Didn't you say"],[433,543,"you wanted to have lunch with me alone?"],[930,1051,"Lena already bought me lunch."],[1074,1154,"You guys go ahead."],[1277,1358,"Okay,"],[1358,1481,"then we're off to eat."],[2906,2999,"I'm not going down to the cafeteria."],[3049,3199,"Could you bring some food up for me?"],[6700,6770,"Miss Regina,"],[6790,6973,"I discovered a big secret."],[6986,7063,"What is it?"],[7097,7197,"Ian also went to see"],[7197,7333,"Simon on the very same day"],[7340,7450,"that we went to find him."],[7524,7624,"How do you know?"],[7677,7814,"I just went to pay off"],[7814,7891,"Simon's gambling debt,"],[7914,8061,"but the creditors said"],[8061,8148,"that Simon's debt"],[8148,8238,"had already been paid,"],[8274,8385,"and Ian was the one who did it."],[8591,8668,"It seems"],[8668,8775,"Mr. Jared Stanton is also afraid we'll"],[8775,8898,"reveal the secret about the child."],[8912,8972,"Now,"],[8982,9069,"we can rest easy."],[9235,9322,"But what about me?"],[9486,9629,"You barged into my world."],[9693,9863,"Did you ever think I'd fall for you?"],[9946,10033,"Jared."],[10166,10253,"I'm sorry."],[10537,10610,"Ruth,"],[10633,10734,"go have lunch on your own."],[10770,10857,"What's wrong?"],[10890,11000,"I don't want to date,"],[11057,11174,"and I definitely don't want to marry you."],[11271,11404,"Did I do something wrong?"],[11428,11554,"You didn't do anything wrong."],[11628,11708,"It's my fault."],[12062,12245,"I won't give up on you!"]],"63":[[420,520,"Mrs. Stanton."],[660,770,"What are you moving?"],[787,940,"Mr. Jared is moving out."],[990,1144,"He's moving out?"],[2629,2699,"Regina."],[2802,2919,"You just get back?"],[2969,3019,"Yeah."],[3089,3223,"I just saw the housekeeper"],[3223,3373,"moving Jared's things."],[3386,3493,"That boy,"],[3493,3727,"moving out as soon as he starts dating."],[3733,3893,"It shows they're getting along well."],[3917,4090,"It just feels a bit strange to me."],[4154,4260,"Since when has Jared"],[4260,4491,"ever been this well-behaved?"],[4494,4678,"Maybe since his brother is gone,"],[4691,4784,"he's matured."],[4954,5088,"I hope so."],[5171,5288,"If he settles down,"],[5318,5495,"maybe his relationship with his mom"],[5505,5602,"will finally improve."],[5658,5715,"Dad,"],[5805,5949,"why does Mom"],[6026,6232,"dislike Jared so much?"],[6466,6599,"If you can't tell me,"],[6599,6713,"that's okay."],[6763,6886,"When he was six,"],[6910,7017,"his mom was pregnant."],[7110,7213,"One morning,"],[7213,7340,"when she got out of bed,"],[7374,7490,"somehow, there were"],[7490,7610,"lots of red beans on the floor."],[7644,7777,"She accidentally slipped"],[7777,7877,"and took a bad fall."],[7877,7957,"She lost the baby."],[7957,8111,"There was blood everywhere."],[8278,8461,"Ten-year-old Marlon dragged his mom"],[8478,8591,"out of the room."],[8591,8828,"He got help in time,"],[8828,8978,"and that saved her life."],[9059,9162,"But she"],[9162,9322,"can never get pregnant again."],[9366,9519,"The baby she lost"],[9556,9779,"was the daughter she wanted most."],[10016,10206,"Did Jared scatter the beans?"],[10236,10373,"Jared said he didn't,"],[10387,10550,"but the maids and Marlon"],[10563,10770,"all claimed they saw him do it."],[10797,11037,"And it fit his mischievous nature."],[11074,11164,"Ever since then,"],[11194,11364,"a rift grew between mother and son."],[11431,11554,"No wonder Joanna Warren"],[11554,11695,"favors Marlon so much."],[11848,11955,"Maybe the beans"],[11955,12098,"weren't scattered by Jared."],[12369,12519,"Aside from me,"],[12519,12719,"you're the second person to believe Jared."],[12892,13023,"You should get some rest."],[13149,13209,"Okay."]],"64":[[150,260,"From now on, Ruth"],[260,473,"will be Mr. Jared Stanton's wife."],[543,730,"Mr. Jared Stanton's wife is so beautiful."],[857,1027,"I look forward to working with you all."],[1044,1211,"Here's a little something for everyone."],[1678,1875,"They brought her into the company so fast."],[2185,2282,"Regina,"],[2359,2479,"Ruth is joining the company"],[2505,2682,"as Jared's secretary."],[2722,2879,"Regina, make sure"],[2906,3049,"you look out for her."],[3086,3136,"I will."],[3219,3386,"Welcome, Ruth."],[3440,3510,"Regina,"],[3510,3623,"this is for you."],[3743,3817,"Thanks."],[3883,4010,"I have a meeting soon,"],[4010,4134,"so I'll go get ready."],[4164,4227,"By the way,"],[4244,4444,"Jared is attending this morning's meeting too."],[4444,4557,"I need to go prepare as well."],[6066,6146,"Mr. Carson, why are you"],[6146,6292,"getting water in the pantry yourself?"],[6319,6426,"The office is out of water."],[8284,8445,"Jared, what's wrong?"],[8762,8885,"Did you skip breakfast?"],[9089,9185,"I told you not to"],[9185,9252,"Jared."],[9266,9391,"I got you something to eat."],[9406,9469,"Let me feed you."]],"65":[[453,517,"Ruth,"],[550,647,"take care of Jared."],[663,760,"I'm heading to the meeting."],[794,944,"We'll head over once Jared finishes eating."],[1598,1664,"Jared,"],[1688,1771,"what's wrong?"],[1888,2062,"I told you I don't like you."],[2148,2278,"Why do you keep coming to Stanton Group?"],[2412,2522,"I bought movie tickets."],[2532,2682,"Let's go watch a movie this weekend."],[2696,2779,"Miss Blake,"],[2862,3013,"if you don't understand Mandarin,"],[3013,3136,"go learn it again."],[3450,3590,"I won't give up on you easily."],[4017,4184,"Mr. Jared Stanton hasn't arrived yet."],[4274,4411,"Mr. Jared Stanton isn't feeling well."],[4444,4527,"Let's not wait for him."],[4808,4914,"Mr. Jared Stanton."],[5298,5398,"Since Mr. Jared Stanton is here,"],[5428,5505,"let's continue."],[5692,5822,"Regarding the land for the resort project,"],[5822,5942,"it still hasn't been secured."],[5962,6092,"Where is the hold-up?"],[6189,6343,"It's stuck at the final approval step."],[6353,6476,"It's been dragging on for over a year."],[6653,6843,"There's a city cultural tour this weekend."],[6843,6963,"All the leaders will be there."],[6996,7147,"They sent an invitation to Stanton Group."],[7173,7293,"Mr. Carson, either you or Mr. Stanton"],[7293,7417,"should attend."],[7534,7594,"Regina,"],[7614,7747,"Jared and I are going"],[7747,7851,"to the movies this weekend."],[8071,8164,"You two go on your date."],[8198,8324,"I'll attend the event."],[8348,8435,"Thanks, Regina."]],"66":[[213,286,"Make the arrangements"],[320,523,"for the cultural tour in the city this weekend."],[540,613,"But,"],[613,750,"events like that"],[750,857,"are mostly attended by older"],[857,907,"male leaders."],[1081,1154,"Mr. Jared,"],[1204,1398,"those tours are usually pretty messy."],[1458,1591,"Are you sure you don't want to go with Regina?"],[1838,2018,"Sir Stanton's checkup results aren't good."],[2035,2118,"He's preparing to step down."],[2138,2275,"He wants to make me Chairman."],[2328,2465,"Only if I succeed with the Resort Project,"],[2482,2612,"will Sir Stanton have a valid reason"],[2625,2746,"to promote me."],[2786,2839,"Later,"],[2862,2932,"send me the profiles of the leaders"],[2932,3059,"attending this cultural tour."],[3059,3129,"I want to see them all."],[3450,3570,"She wants power,"],[3603,3700,"and status."],[3737,3893,"She wants to fight for it."],[3933,4003,"So let her."],[4354,4517,"Hello, Mr. Jones."],[4667,4841,"Mr. Warren, Mr. Collins."],[4964,5011,"Mr. Harper."],[5061,5178,"Please, have a seat."],[5578,5729,"It seems Mr. Stanton of the Stanton Group"],[5729,5825,"is really planning to"],[5825,5932,"retire from the spotlight."],[5965,6126,"Sending his young daughter-in-law"],[6126,6212,"out here to handle business."],[6226,6312,"Mr. Stanton said"],[6312,6493,"he wants to give us young people a chance."],[6546,6770,"Mr. Carson, when you're out socializing,"],[6803,6953,"no one cares about your youth"],[6990,7147,"or gives you special treatment."],[7177,7243,"Mr. Warren,"],[7290,7427,"I wouldn't ask for special treatment,"],[7450,7560,"I just hope for some guidance."],[7560,7657,"It's only right."],[7711,7767,"Mr. Carson."],[7834,8094,"You gotta drink if you want a favor."],[8488,8595,"Drinking is part of the job."],[8628,8775,"I'll toast Mr. Jones first."],[9743,9859,"- Mr. Warren. - Cheers."],[11511,11578,"Mr. Harper."],[14237,14340,"You rascal,"],[14451,14634,"moving on to the next one so fast."],[15251,15311,"Cheers."],[15472,15742,"Mr. Carson, stop looking at your phone."],[15859,15949,"Come on, have a drink."],[16623,16703,"I'll drink."],[16820,16883,"I'll take a penalty drink."],[17844,18031,"You know, Mr. Carson,"],[18071,18331,"you're even more charming when you drink."],[18421,18475,"Mr. Warren,"],[18578,18712,"this is a proper business dinner,"],[18742,18978,"so keep your hands to yourself."],[19008,19105,"Is that so?"],[19215,19449,"Let me see just how proper."],[19459,19512,"Mr. Warren!"],[19528,19796,"If you do that again, I'm done being polite."],[19937,20033,"Fine."],[20166,20270,"Stop being polite."],[20316,20633,"The Stanton Group sent you to entertain us,"],[20633,20860,"so it seems that's all you're worth to them."],[20934,21191,"Just be a good boy and serve us well,"],[21191,21297,"secure the land,"],[21344,21591,"and you'll be a hero back home."]],"67":[[96,183,"Get away!"],[377,437,"Regina,"],[507,600,"where do you think"],[640,740,"you're going?"],[884,961,"Let me go!"],[1044,1084,"Come on,"],[1161,1274,"we're out in the suburbs,"],[1328,1494,"and we've booked the entire hotel."],[1528,1618,"Tonight,"],[1655,1718,"you're just"],[1728,1862,"our plaything."],[1955,2128,"You're a widow anyway,"],[2165,2312,"so let us help you"],[2375,2525,"relieve your loneliness."],[4864,4991,"I thought you were smarter than this."],[5078,5215,"You drank this much with them?"],[5272,5342,"Who the h*ll are you?"],[5362,5448,"Who let you in!"],[5495,5585,"Jared."],[5892,5982,"It's Jared."],[6403,6456,"Mr. Jared,"],[6476,6516,"Mrs. Stanton."],[6543,6690,"Get rid of everyone inside."],[6813,6880,"Wait, don't!"],[6933,7047,"Don't touch them yet."],[7354,7561,"I haven't secured the land yet."],[7821,7921,"In your eyes,"],[7993,8131,"do you only care about money and status?"],[8341,8471,"Shh."],[8588,8702,"Keep it down."],[8862,8945,"Regina"],[9009,9209,"is playing a chess game."],[9606,9653,"Mr. Jared Stanton,"],[9779,9873,"Regina had me film those men"],[9873,9950,"forcing her to drink"],[9966,10096,"and trying to assault her."],[10260,10360,"Mrs. Stanton"],[10360,10493,"really isn't that foolish."],[10547,10637,"So, you mean"],[10707,10797,"I came for nothing."],[11468,11534,"Jared,"],[11865,11978,"was the movie good?"]],"68":[[461,662,"You've never taken me to the movies,"],[817,1001,"or bought me popcorn."],[1141,1234,"You"],[1693,1982,"With such nice pecs,"],[2095,2315,"are you going to let others touch them?"],[2589,2642,"Regina,"],[2806,2869,"I told you"],[2981,3119,"to stay away from me."],[3236,3353,"Otherwise,"],[3413,3547,"I won't hold back."],[4007,4060,"Jared."],[4137,4264,"Regina is drunk."],[4630,4708,"Too late."],[5549,5595,"Jared."],[5770,5893,"You have a girlfriend."],[6089,6199,"I'm not dating her."],[6409,6499,"And I didn't go to the movies."],[9963,10026,"Jared,"],[10166,10333,"it's time to end our"],[10413,10574,"secret, forbidden affair."],[11131,11184,"Jared,"],[11411,11458,"I love you."],[11965,11988,"Regina"],[13133,13199,"Miss Blake,"],[13463,13687,"The reason Jared keeps rejecting you"],[13753,13850,"is because"],[13887,13964,"Regina"],[13987,14087,"has been seducing him."],[14214,14280,"Regina."],[14494,14564,"Miss Blake,"],[14631,14764,"do you want to join me"],[14801,14918,"and get rid of Regina?"]],"69":[[1461,1541,"Regina,"],[1628,1708,"today,"],[1708,1905,"all of Stanton Group's shareholders are here."],[1965,2072,"I'm going to watch"],[2115,2168,"exactly how you get"],[2219,2325,"kicked out of Stanton Group."],[2656,2722,"Thank you, everyone."],[2766,2822,"That concludes"],[2846,2963,"my speech."],[2999,3096,"Thank you all."],[3647,3690,"Dad."],[3723,3770,"Regina,"],[3823,3980,"you make me so proud."],[4411,4507,"Moving on,"],[4519,4673,"I will officially step down from"],[4694,4834,"the Stanton Group board."],[4911,5038,"My daughter-in-law,"],[5048,5135,"Regina,"],[5228,5282,"will take over as"],[5292,5425,"the next Chairman."],[5462,5557,"Please cast your votes."],[5609,5672,"I agree."],[5715,5782,"Yes."],[5829,5896,"Yes."],[5912,5962,"Yes."],[5968,6050,"Yes."],[6136,6229,"- Regina... - I vo"],[6229,6366,"She's unfit to be Chairman!"],[6726,6830,"Regina"],[6843,7003,"and her brother-in-law, Jared,"],[7030,7270,"have been having an illicit affair!"],[7477,7581,"What is going on?"],[7864,8038,"These aren't the photos I prepared."],[8171,8318,"I didn't expect Ruth"],[8328,8451,"to be capable enough"],[8555,8658,"to get photos like these."],[8889,8942,"That's right."],[9079,9212,"Mr. Jared Stanton and I"],[9236,9359,"are in love,"],[9442,9546,"and we have a child together."]],"70":[[410,570,"She actually admitted it!"],[887,961,"She has no morals!"],[997,1121,"It's absolutely scandalous!"],[1218,1291,"Regina,"],[1361,1581,"you shameless bi*ch!"],[1601,1645,"I"],[2078,2132,"You"],[2232,2315,"You two"],[2422,2479,"Regina,"],[2549,2672,"Jared"],[2686,2792,"is your brother-in-law!"],[2846,3146,"Sleeping with your brother-in-law?"],[3270,3406,"Have you no shame?"],[3613,3670,"Irene,"],[3773,3910,"when you seduced your brother-in-law,"],[4037,4160,"had an illicit affair,"],[4224,4361,"and gave birth to a bast*rd,"],[4454,4541,"where was your shame then?"],[4561,4608,"You"],[4771,4871,"When you and Marlon"],[4888,4961,"had a child,"],[4961,5068,"and flaunted him in front of me,"],[5185,5305,"why didn't you mention that your child"],[5325,5395,"was a bast*rd?"],[5539,5672,"I'm just giving you a taste"],[5722,5829,"of your own medicine."],[5939,6079,"Why is it 'true love' for you two,"],[6159,6293,"but 'immoral' for me?"],[6439,6516,"Does society"],[6623,6776,"allow men to have illegitimate children,"],[6873,6967,"and grant those children"],[6993,7117,"equal inheritance rights,"],[7200,7310,"but when a woman does it,"],[7360,7507,"she gets kicked out of the family?"],[7584,7674,"Besides,"],[7781,7924,"since my husband is sick"],[7954,8061,"and impotent,"],[8101,8235,"to ensure he has an heir,"],[8351,8455,"I turned to Jared"],[8485,8555,"just to borrow his seed."],[8899,9072,"That's absolutely right. Well said."]],"71":[[136,210,"Regina,"],[253,307,"I'm sorry."],[330,490,"I was too harsh on you earlier."],[570,690,"You're a role model for all women."],[720,850,"From now on, you're my idol!"],[927,977,"I think"],[997,1084,"Regina is right."],[1124,1211,"It was Mr. Marlon"],[1228,1384,"who wronged her first."],[1434,1555,"Regina still went to great lengths"],[1565,1701,"to ensure his family line continues."],[1751,1811,"Exactly."],[1825,2005,"We're not living in the dark ages anymore."],[2038,2155,"Stop pandering to men."],[2272,2375,"How can this be?"],[2702,2793,"Mrs. Stanton,"],[2873,2993,"don't you care about Marlon?"],[3036,3119,"Andy"],[3119,3276,"is Marlon's only son."],[3370,3547,"They betrayed Marlon!"],[3703,3773,"Jared,"],[3897,4044,"you killed"],[4160,4454,"your own unborn sister,"],[4551,4681,"and then you and Regina"],[4754,4861,"had a bastard together,"],[4861,4928,"passing him off as"],[4928,5031,"your older brother's child."],[5068,5198,"Are you trying to seize"],[5228,5402,"everything the Stantons own?!"],[5595,5679,"Let me tell you,"],[5756,5822,"it's not happening."],[5925,6078,"Unless I'm dead,"],[6102,6152,"everything your brother owns"],[6223,6473,"belongs to Andy!"],[6516,6671,"Your unborn child"],[6716,6873,"was killed by Marlon."],[7070,7204,"How does she know that?"],[7357,7494,"You two did"],[7500,7657,"such a shameful thing,"],[7731,7881,"and you still dare to show your faces here"],[7901,8091,"You're slandering my Marlon!"],[8161,8211,"Lena,"],[8315,8395,"bring her in."],[8802,8855,"Mabel."],[8949,8999,"Madam,"],[9079,9236,"this is Marlon's wet nurse."],[9306,9436,"Let's have her explain exactly"],[9486,9573,"how Marlon"],[9613,9709,"got rid of"],[9709,9799,"your unborn third child,"],[9870,10036,"and how he turned you against Jared."],[10046,10103,"I"],[10143,10193,"Speak."],[10337,10477,"Madam, back then, all you cared about"],[10500,10687,"was the daughter in your womb."],[10724,10807,"Mr. Marlon"],[10814,10927,"was afraid that one more person"],[10954,11027,"would compete for favor"],[11044,11121,"and the inheritance."],[11154,11371,"So he scattered beans all over the floor."],[11472,11582,"After you miscarried,"],[11589,11718,"he was terrified."],[11795,11942,"He made me lie for him,"],[11962,12134,"saying Mr. Jared did it."],[12190,12366,"I was wrong."],[12380,12472,"Sir, Madam,"],[12495,12609,"- Please forgive me. - You"],[12619,12722,"Spare me!"],[12752,12856,"You caused Jared"],[12856,13063,"to be hated by his mother for so many years."],[13230,13293,"No."],[13400,13483,"Impossible."],[13613,13707,"My Marlon"],[13708,13912,"isn't that kind of child."],[14010,14087,"Regina,"],[14137,14307,"you think bribing an old servant"],[14317,14387,"to give false testimony"],[14404,14504,"is enough to slander Marlon?"]],"72":[[86,223,"Of course I have evidence."],[490,696,"One... two"],[1711,1768,"Mom,"],[2015,2125,"actually, Jared got hold of"],[2125,2219,"this video a long time ago."],[2279,2429,"You had already lost a daughter,"],[2456,2539,"and he was afraid"],[2539,2683,"you'd be disappointed in your trusted eldest son,"],[2719,2814,"so he never exposed the truth,"],[2816,2909,"allowing you to keep your faith,"],[2966,3089,"and let you misunderstand him."],[3506,3733,"How could this be?"],[4097,4150,"Speak!"],[4491,4662,"Still won't admit it, huh?"],[4701,4921,"So young yet so scheming,"],[4941,5128,"harming your own siblings!"],[5352,5432,"Speak!"],[5495,5745,"I didn't scatter the red beans!"],[5815,5946,"You still deny it?"],[6092,6379,"I'll beat you!"],[6399,6460,"Talk!"],[6600,6623,"Take that!"],[6812,7150,"I was wrong about you."],[7314,7701,"Why didn't you tell me?"],[7744,7854,"It's okay, Mom."],[7871,8091,"Our family only needs one heir."],[8141,8278,"As long as Stanton Group"],[8291,8398,"remains with the Stantons,"],[8798,8929,"Jared,"],[8929,9139,"my son!"],[9326,9599,"I've failed you."],[9766,10110,"I wrongly accused you."],[10143,10317,"It's all my fault."],[10473,10540,"Mrs. Stanton,"],[10560,10716,"don't listen to her one-sided story."],[11057,11221,"I warned you last time"],[11258,11381,"not to show your face"],[11394,11605,"at any Stanton events again!"],[11655,11825,"You never learn, do you?"]],"73":[[26,272,"Mr. and Mrs. Stanton,"],[283,453,"Andy is your grandson,"],[510,637,"and I am his mother."],[677,744,"Besides me,"],[757,847,"no one treats Andy"],[847,967,"better than I do!"],[1228,1388,"Andy is Marlon's child."],[1448,1535,"Whether it's the Stantons"],[1571,1645,"or me,"],[1668,1768,"we won't treat him poorly."],[1845,1945,"But since you and Marlon acts"],[1945,2015,"harmed the Stanton family's interests,"],[2035,2185,"I'm going to settle the score"],[2262,2439,"with both of you."],[2455,2495,"Lena."],[2819,2869,"Dad,"],[2929,3076,"this proves Marlon embezzled funds"],[3103,3216,"to gamble at the casino run by"],[3216,3306,"Irene and her brother."],[3370,3480,"He couldn't cover his losses,"],[3537,3613,"so he sold off several"],[3613,3690,"company projects."],[3780,3905,"That unfilial son!"],[3927,4037,"So those projects"],[4037,4147,"were lost to gambling?"],[4157,4268,"That is despicable!"],[4357,4384,"No"],[4461,4601,"Mr. and Mrs. Stanton,"],[4634,4731,"don't listen to her nonsense."],[4761,4854,"It's not like that!"],[4864,4935,"Whether it is or not,"],[5025,5205,"you can explain it to the police."],[5382,5438,"Irene,"],[5465,5602,"you are suspected of running an illegal casino,"],[5619,5679,"rigging games,"],[5695,5799,"and defrauding others."],[5837,5910,"Come with us."],[5911,5950,"No,"],[5998,6046,"I didn't"],[6089,6157,"I didn't do it!"],[6426,6543,"Sis,"],[6583,6643,"I'm begging you,"],[6676,6723,"please save me."],[6723,6793,"I was wrong."],[6793,6937,"I really know I was wrong!"],[6987,7057,"I told you,"],[7140,7399,"the power and status my mom and I have"],[7447,7541,"are things you and your mom"],[7597,7757,"could never dream of reaching."],[7827,7874,"Take her away."],[7994,8121,"Sis!"],[8485,8528,"Regina,"],[8578,8648,"Bennett is hungry."],[9152,9239,"You have big things to do,"],[9289,9389,"so I'll take care of the child."],[9900,9950,"Regina,"],[10213,10377,"say hi to Grandma."],[10664,10777,"Let Grandma hold you."],[10934,11017,"From now on,"],[11037,11191,"your dad and I will look after the child."],[11281,11408,"You and Regina,"],[11811,12007,"you and Regina,"],[12095,12155,"from now on,"],[12175,12409,"must manage the company well together."]]}