{"1":[[412,600,"All eyes on young Lily Pearson"],[613,746,"as she plays for the match point"],[746,867,"against reigning champion,"],[867,971,"Anna Petrikova."],[1038,1238,"Emotions are high with Lily's mother"],[1238,1363,"recently hospitalized."],[1430,1539,"Can she take the win?"],[1651,1805,"Or will she crack under the pressure?"],[3199,3299,"Fuck!"],[3591,3661,"You did it."],[3707,3778,"I knew you could do it."],[4120,4212,"Thank you."],[4696,4792,"Lily Pearson,"],[4804,4984,"you just broke the world record"],[4984,5201,"as the youngest Grand Slam winner."],[5242,5330,"What's next for you?"],[5330,5388,"Wimbledon?"],[5651,5801,"This win marks my retirement."],[6022,6177,"I'll be coaching my fiancé full time."],[6327,6368,"What?"],[6377,6418,"But-"],[6452,6514,"No! - Wait!"],[6627,6677,"Wait!"],[7044,7198,"You're throwing away your career"],[7207,7298,"for some guy?"],[7374,7545,"Lily, you're on track to be the next"],[7545,7640,"Serena Williams."],[7661,7766,"Hell, even better!"],[7770,7878,"Adam isn't some guy."],[8053,8229,"He's the only reason I'm here today."],[8475,8633,"She's going to need a heart transplant."],[8846,8958,"Heart transplant?"],[9217,9259,"Doctor,"],[9259,9392,"we don't have that kind of money."],[9392,9446,"Yes, we do."],[9622,9688,"Yes, we do."],[10539,10689,"Adam, Adam, those are your winnings."],[10689,10806,"I can't have you wasting those."],[10806,10894,"It's not a waste."],[10935,11027,"You and your mom are literally"],[11027,11144,"the two most important things"],[11144,11261,"to me in the whole world."],[11473,11515,"Lily."],[12007,12087,"Will you marry me?"],[12379,12449,"Yeah."],[12458,12495,"Yes?"],[12495,12554,"Yeah."],[13188,13321,"He's the only thing that matters."],[13367,13409,"Kid."],[13480,13626,"You're making a terrible mistake."]],"2":[[308,404,"Oh, I'm sorry."],[450,563,"He only drinks kale smoothies"],[563,646,"after matches."],[663,709,"Oh."],[829,992,"I don't know if Adam Parker is luckier"],[992,1113,"to have won the Grand Slam"],[1113,1263,"or to have such a loving girlfriend"],[1263,1338,"be his coach."],[1380,1501,"The world once knew me"],[1501,1584,"for my serve."],[1705,1864,"Now I serve Adam Parker."],[1901,1976,"Coach Lily,"],[2010,2168,"how does it feel to help Adam Parker"],[2168,2327,"win his third Grand Slam?"],[2352,2498,"And Lily, you've been engaged to Adam"],[2498,2627,"for ten years now."],[2660,2802,"Is he ever going to seal the deal?"],[3036,3111,"There he is!"],[3424,3620,"With Mia Sparks?"],[3628,3778,"The current world number one"],[3778,3899,"in women's singles?"],[4029,4099,"What's going on?"],[4120,4241,"He brought his secret lover"],[4241,4320,"out in public?"],[4341,4396,"Secret?"],[4425,4508,"Everyone knows"],[4508,4646,"he's been cheating on Lily Pearson."],[4679,4813,"Let's just address the elephant"],[4813,4871,"in the room."],[4938,5038,"You all know Mia."],[5163,5267,"She's my date tonight."],[5730,5801,"The press conference"],[5801,5947,"is only for athletes and their coaches."],[5947,5993,"Okay."],[5993,6131,"Well, I think you can make"],[6131,6239,"an exception for Mia"],[6239,6335,"because she's the best"],[6335,6464,"and we all know you'd do anything"],[6464,6564,"for the best player."],[6639,6710,"Excuse me?"],[6823,6940,"Just take my seat, babe."],[6998,7065,"Take my seat."]],"3":[[575,692,"Stupid."],[950,1101,"Stupid, you should have known."],[1146,1222,"Mr. Parker,"],[1263,1380,"does this signal"],[1380,1509,"the end of your relationship"],[1509,1593,"with Coach Lily?"],[1614,1801,"No, no, no."],[1830,1926,"Lily is loyal."],[1960,2072,"She's like a little dog."],[2110,2344,"I mean, she doesn't mind me going out"],[2344,2431,"and having a little fun"],[2431,2565,"every once in a while, right?"],[2569,2790,"He's a player on and off the court."],[2852,2923,"Guilty!"],[3495,3557,"I should have known"],[3557,3695,"that promises expire."],[3737,3824,"Maybe even sooner"],[3824,3953,"than a career in sports."],[4108,4149,"Ah."],[4158,4237,"Babe, I'm bleeding."],[4287,4341,"What?"],[4341,4408,"I'm busy!"],[4491,4617,"You stopped giving me anything"],[4617,4754,"a long time ago, Adam."],[4838,4917,"But I stayed."],[5080,5146,"I loved you"],[5159,5330,"because you once gave me everything."],[5501,5705,"I don't owe you anything anymore."],[5793,5968,"I'm done repaying that debt."],[6018,6151,"I'm done letting you trample"],[6151,6264,"over my feelings."],[6293,6514,"I'm done being the tolerant woman"],[6514,6723,"standing behind a mediocre man."],[6765,6848,"Adam Parker,"],[7182,7315,"I don't want to love you anymore."]],"4":[[8,162,"Give us a kiss, Mr. Parker!"],[196,262,"You got it."],[1009,1059,"Lily,"],[1176,1301,"let me make this public."],[1522,1630,"I'm breaking up with you."],[2127,2181,"Okay."],[2494,2548,"Okay?"],[2681,2790,"We can still be friends."],[2836,2890,"I mean,"],[2973,3103,"you can coach Mia now."],[3140,3378,"Yeah, I would really love to learn"],[3378,3687,"from an older female player."],[3958,4079,"We are not friends."],[4154,4316,"And I am not coaching"],[4316,4396,"your girlfriend."],[5543,5609,"What are you doing?"],[5618,5755,"My name is Lily Pearson."],[5789,5905,"You may know me as a coach"],[5905,5976,"or as the great mind"],[5976,6072,"behind Adam Parker's"],[6072,6139,"game strategy."],[6139,6218,"What are you doing?"],[6218,6285,"You may know me - Stop it."],[6285,6410,"as his devoted girlfriend,"],[6410,6519,"who smiles and nods"],[6519,6631,"while he cheats."],[6886,7011,"But that's not who I really am."],[7144,7282,"I am the world record holder"],[7282,7419,"for the youngest tennis player"],[7419,7582,"to ever win a Grand Slam."],[7686,7770,"They used to call me"],[7770,7857,"Queen of the Court."],[7866,7957,"The Queen of the Court."],[7974,8041,"Wow. - Yeah."],[8041,8133,"Yeah. - That's right."],[8320,8450,"And I'm coming out of retirement."],[8575,8633,"Yes!"],[8829,8900,"Hell yeah!"]],"5":[[0,112,"Okay, okay."],[112,171,"Alright!"],[262,362,"Let's just let menopause"],[362,462,"walk out of the room."],[467,625,"Let's not forget this is mine!"],[638,763,"We are here for me!"],[775,825,"Okay?"],[946,1080,"It looks like Lily Pearson"],[1080,1226,"is officially abandoning"],[1226,1305,"Team Adam."],[1401,1426,"Dude."],[1568,1814,"She'll be back in like five seconds."],[1939,2060,"Five."],[2060,2177,"Four."],[2189,2277,"Three."],[2306,2460,"You're throwing away your career"],[2464,2556,"for some guy?"],[2581,2706,"You've been engaged to Adam"],[2706,2798,"for ten years."],[2798,2927,"Is he ever going to seal the deal?"],[2948,3048,"Lily is loyal."],[3069,3190,"She's like a little dog."],[3244,3328,"Two."],[3345,3449,"One!"],[3845,4004,"See you on the court, asshole."],[5059,5100,"Babe,"],[5130,5213,"you said she was gonna coach me-"],[5213,5284,"Get the fuck off me."],[5309,5451,"Coach Lily was the brains"],[5451,5559,"behind your game."],[5609,5726,"Aren't you worried about your game"],[5726,5830,"now that she's walked?"],[5847,5893,"I wouldn't say that-"],[5897,6081,"Would you say that your reign is over"],[6106,6243,"now that your secret weapon"],[6243,6339,"has dumped you?"],[6364,6452,"Okay, I dumped her!"]],"6":[[8,204,"I pay her two million dollars"],[204,296,"to be my coach."],[358,412,"Okay?"],[467,542,"She can't live"],[542,663,"without that kind of money."],[725,867,"And you can put that on the record."],[1059,1105,"Lily,"],[1151,1247,"I don't know what the hell"],[1247,1363,"is going on with you, okay?"],[1413,1547,"But if I were you,"],[1605,1689,"I would think twice"],[1689,1789,"about what you just did."],[1826,1926,"You're not winning anything."],[1926,2006,"And you're certainly"],[2014,2189,"not beating Mia here in anything"],[2189,2318,"but your fucking waist size."],[2339,2527,"So, why don't you just come back,"],[2565,2656,"accept your two million"],[2656,2761,"dollar contract?"],[4295,4429,"I'm done dimming my light,"],[4429,4546,"so you can shine."],[4788,5025,"It took me ten years to see through you."],[5117,5334,"Ten years of giving up my dreams"],[5334,5451,"to fulfill yours."],[5976,6101,"I'm taking it all back."],[6189,6293,"Our trophies,"],[6327,6431,"our winnings."],[6606,6673,"And now,"],[6823,6898,"my career."],[7903,7953,"Oops."]],"7":[[271,367,"Wendy, where's my"],[367,521,"goddamn breakfast?"],[742,888,"It's gonna take me all day"],[888,1017,"to clean up this mess."],[1017,1105,"I don't care."],[1105,1226,"I want my juice."],[1322,1505,"My hangover juice, the Korean one?"],[1526,1689,"That was Miss Lily's recipe."],[1764,1881,"She made it for you."],[1926,1985,"What?"],[2006,2093,"Whenever you'd stay out"],[2093,2173,"all night drinking,"],[2173,2339,"she'd get up at six in the morning"],[2339,2460,"to make that for you."],[2665,2761,"You had a long night."],[2857,2911,"Look."],[3007,3174,"I figured you'd feel like crap,"],[3211,3315,"so I made you that juice"],[3315,3420,"that you wanted in Asia?"],[3853,3966,"Just shut up."],[3983,4124,"You're being too goddamn loud."],[4600,4788,"Okay, so where the fuck's Lily?"],[5017,5134,"What the fuck?"],[5134,5326,"Did a burglar break in or something?"],[5355,5459,"She left."],[5484,5634,"She took all your trophies"],[5668,5739,"and the money."],[5776,5939,"I think that she's the one"],[5939,6010,"who broke everything."],[6010,6106,"She did what?"]],"8":[[0,154,"What the fuck?"],[717,763,"God!"],[821,1067,"Oh, no, no, no, no, no!"],[1088,1142,"Thanks for letting me"],[1142,1238,"crash last night, man."],[1272,1405,"I was fucking wasted."],[1405,1543,"Can you fucking see, dude?"],[1543,1651,"She took everything."],[1701,1839,"Oh, shit."],[1876,2014,"You really pissed Lily off, man."],[2052,2152,"Just call her and apologize."],[2152,2239,"Apologize?"],[2285,2377,"What the fuck do I have"],[2377,2485,"to apologize for?"],[2502,2615,"She should apologize."],[2690,2848,"I'll make her apologize to me."],[2927,2977,"Fair."],[3028,3257,"Hey, but remember, not too much."],[3261,3303,"Right."],[3345,3490,"Hey, Lily."],[3516,3611,"I know you love me."],[3678,3766,"Call me back."],[3766,3878,"The person you have dialed"],[3878,4016,"is not able to receive calls"],[4016,4091,"at this time."],[4099,4187,"Shit!"],[4208,4283,"Shit."],[4291,4404,"She blocked you."],[4471,4546,"What are you gonna do?"],[4546,4608,"I don't know."],[4633,4817,"You need her tennis strategy, man."],[4867,4954,"She might not play anymore,"],[4954,5034,"but she's still-"],[5034,5121,"Shut the fuck up, dude."],[5121,5234,"Shut the fuck up!"]],"9":[[500,575,"Fuck!"],[604,717,"Hey, it's okay."],[729,779,"I mean,"],[867,955,"you haven't played like this"],[955,1055,"in like a decade."],[1055,1167,"No, it's not okay."],[1222,1326,"I'm supposed to be good."],[1334,1505,"I'm supposed to be the best, actually."],[1559,1614,"I know,"],[1647,1868,"but do you really think"],[1868,2027,"you're ready to take on Adam?"],[2060,2156,"Even Mia?"],[2185,2281,"I mean, he's ranked number two"],[2281,2369,"in the world."],[2394,2640,"And him and that brainless rat,"],[2640,2781,"Mia is number one"],[2781,2907,"in female players."],[3123,3232,"I need Coach Art back."],[3282,3370,"If I could get him,"],[3536,3595,"I could win."],[3749,3799,"But?"],[3858,4008,"He doesn't speak to me anymore, Diana."],[4245,4371,"I broke his heart when I quit."],[4758,4863,"He's not gonna take me back."],[5075,5142,"Oh, he will."],[5205,5296,"He just needs"],[5363,5492,"someone to convince him."],[5518,5576,"Oh, yeah?"],[5734,5784,"Who?"],[6460,6602,"Finn Reid,"],[6710,6798,"Art's crown jewel."],[6894,7094,"Well, after you left anyways."],[7399,7649,"They call him the Falcon now."],[7670,7870,"Reining in at number one in the world"],[7887,8162,"with ten Slams and counting."],[8587,8687,"Finn hated me."],[8808,8917,"Coach Art liked me better."],[8950,9100,"Please."],[9134,9217,"He was practically"],[9217,9351,"your personal ball boy"],[9351,9451,"at the academy."],[9572,9630,"Watch."],[11036,11090,"Hello?"],[11194,11344,"Wait, the Lily Pearson,"],[11453,11532,"needs my help?"],[11720,11770,"Yeah."],[12387,12454,"Oh, shit!"],[12708,12900,"Finn has agreed to meet."],[12954,13167,"We are gonna get your coach back!"],[13234,13338,"Then I better look ready."]],"10":[[108,216,"Do you want to change it?"],[379,496,"But you look like a doll."],[575,642,"You know, I feel like"],[642,746,"if you got more weight"],[746,821,"into your back foot,"],[821,909,"you'd get more power"],[909,1021,"on your groundstrokes."],[1046,1101,"You're also not going"],[1101,1155,"back to center"],[1155,1292,"before your returns,"],[1292,1397,"and you're hitting the ball"],[1397,1455,"instead of brushing it-"],[1455,1526,"Uhh, hey."],[1710,1772,"Why don't you ever wear"],[1772,1826,"your hair down?"],[1885,1968,"Like those girls."],[2114,2147,"I mean,"],[2147,2327,"I can't play with my hair down."],[2327,2377,"Play?"],[2548,2677,"You're not a tennis player anymore."],[3461,3570,"You can still wear your hair up"],[3570,3645,"in the bedroom,"],[3787,3853,"princess."],[4166,4245,"That's the point."],[4308,4375,"I'm not a doll."],[5880,6068,"Two days. And she still hasn't"],[6068,6143,"unblocked me."],[6202,6331,"Why is it taking her so long?"],[6731,6961,"Her form is as perfect as her body."],[6977,7015,"I know,"],[7015,7207,"I wish I was that hot while I play."],[7344,7557,"I'm the prettiest athlete in the world."],[7574,7703,"No wonder Adam picked me."],[7703,7795,"Welcome to"],[7799,8091,"the Rochester Invitational!"],[8133,8295,"Featuring top-ranking"],[8308,8425,"power couple,"],[8458,8771,"Adam Parker and Mia Sparks!"],[9059,9121,"You're too close."],[9138,9200,"You're too close."],[9250,9334,"And now,"],[9363,9592,"in a shocking last-minute entry,"],[9793,10026,"playing for the opposing team!"],[10289,10335,"Babe."],[10364,10410,"What?"],[10414,10485,"Babe, is that-"],[10485,10535,"What?"]],"11":[[4,145,"Making her debut"],[145,291,"after she's been off the court"],[291,417,"for a decade,"],[450,642,"it's Lily Pearson!"],[863,992,"Let’s go!"],[1038,1167,"Yeah!"],[1251,1380,"Whoo!"],[1730,1772,"Lily."],[1914,1964,"Lily."],[2060,2152,"You didn't have to do all this"],[2152,2256,"just to impress me."],[2306,2427,"Trying to get Adam's attention"],[2427,2510,"with your new look?"],[2590,2677,"That's just pathetic."],[2677,2852,"Well, you know what they say"],[2852,2977,"about one woman's trash."],[3086,3190,"Adam's all yours, babe."],[3207,3328,"You bitter old hag."],[3328,3461,"You can't talk down to Adam"],[3461,3586,"just because no man here"],[3586,3657,"will look your way."],[3657,3741,"And now,"],[3741,3899,"to complete the pairing,"],[3920,4187,"it's the reigning number one player"],[4187,4325,"in the world!"],[4596,4742,"Finn Reid!"],[4867,4925,"Finn!"],[4954,4979,"Finn!"],[4984,5013,"Finn!"],[5013,5055,"Over here!"],[5055,5113,"The Falcon!"],[5113,5276,"Oh my god, he's so sexy!"],[5276,5430,"Finn, sign my purse!"],[5484,5613,"I love you!"],[5672,5776,"Oh, what the fuck?"],[5955,6031,"Lily Pearson."],[6206,6293,"It's been a while."]],"12":[[4,162,"Oh my God, I'm gonna faint."],[175,392,"Did the Finn Reid just talk to Lily?"],[392,467,"Not just that,"],[467,588,"but they're playing together."],[588,692,"What an embarrassment"],[692,754,"for Mia."],[809,1001,"I'd pick Finn over Adam any day."],[1001,1163,"We'll give each pair a moment"],[1163,1443,"to warm up and strategize."],[1451,1593,"What the fuck are you doing here?"],[1618,1722,"I'm helping an old friend."],[1751,1801,"Friends?"],[1801,1881,"You're not frie-"],[2052,2097,"Oh."],[2177,2243,"I get it."],[2356,2444,"When did you start fucking"],[2444,2540,"the world number one?"],[2656,2748,"Hey, hey we are not!"],[2748,2865,"I left because I'm a better"],[2865,2982,"tennis player than you."],[3003,3078,"Always have been."],[3090,3236,"That's just shameless, Pearson."],[3236,3328,"You're unranked."],[3328,3478,"Adam was never a worthy opponent."],[3545,3716,"At my prime, I beat Finn a few times."],[3787,3878,"Your prime was like"],[3878,3983,"a hundred years ago!"],[4033,4124,"Well, I wouldn't say that."],[4137,4245,"Are you serious?"],[4245,4458,"This washed-up, old, bitter-"],[4458,4529,"Stop it."],[4679,4863,"Lily Pearson beat you?"],[4946,5125,"The world's number one champion?"],[5234,5355,"Let's just show them, Pearson."],[5743,5814,"Adam Parker,"],[5843,6085,"number two in the world."],[6085,6139,"And..."],[6306,6473,"I am so sorry, I forgot your name."],[6473,6581,"How many Slams have you won?"],[6631,6664,"Yeah."],[6685,6919,"Versus ten-time world champion,"],[6923,7007,"best player in the world,"],[7061,7236,"paired with a nobody."],[7344,7461,"She used to be known as..."],[7632,7716,"Queen of the Court."]],"13":[[0,654,"Match! Match! Match! Match!"],[654,729,"Let's go!"],[1067,1222,"Who knew he'd be on my side?"],[1643,1718,"Fuck this!"],[1860,1926,"We're not playing."],[1956,2035,"Babe, we have to."],[2089,2189,"Stop calling me babe."],[2260,2331,"We're not playing."],[2348,2506,"Adam Parker just backed"],[2506,2602,"out of the game!"],[2619,2719,"What's he afraid of?"],[2756,2848,"What the hell?"],[2852,3057,"I never took Adam Parker for a coward."],[3057,3190,"And why is Mia Sparks"],[3190,3311,"scared of Lily Pearson?"],[3349,3432,"No, we need to train."],[3486,3532,"We're gonna get"],[3532,3624,"crushed by her."],[3641,3682,"Train?"],[3682,3762,"She's old."],[3816,3895,"Okay? She sucks."],[3895,3970,"What are you talking about?"],[3970,4108,"If you could play half as good as her,"],[4154,4216,"then we wouldn't have to"],[4216,4308,"walk away at all."],[4496,4567,"God."],[4863,4934,"Hey!"],[5159,5213,"Let's talk."],[5276,5321,"Wait."],[5321,5392,"Let her go, Parker."],[5392,5467,"Shut the fuck up, dude!"],[5476,5576,"No one's talking to you!"]],"14":[[16,104,"Lily, listen."],[129,183,"Okay, I get it."],[183,283,"You're upset about Mia."],[283,379,"I understand that."],[417,529,"But I'm just trying to play"],[529,596,"a game of tennis."],[608,638,"Okay?"],[638,704,"I don't need you guys"],[704,838,"eye-fucking each other on the court."],[838,938,"You're overreacting!"],[959,1046,"Overreacting?"],[1126,1238,"Overreacting, Adam?"],[1238,1372,"There were a hundred times"],[1372,1455,"that I should have left you,"],[1455,1509,"but I didn't,"],[1509,1584,"because you happened"],[1584,1647,"to be there when"],[1647,1714,"nobody else was."],[1810,1993,"You loved me when I needed you most."],[2081,2131,"So I thought that"],[2131,2214,"I couldn't live without you,"],[2214,2281,"but I can."],[2423,2527,"I don't need you to love me."],[2594,2711,"I don't need anyone to love me,"],[2711,2861,"because I've got my own back."],[2882,2952,"I've got me."],[2977,3090,"I don't need you anymore."],[3090,3140,"Got it?"],[3603,3666,"See you around,"],[3749,3799,"number two."],[4049,4112,"Or not."]],"15":[[45,125,"Sorry about that."],[208,325,"Not a great first impression,"],[325,383,"I'm sure."],[433,479,"No."],[538,679,"Not a first impression at all."],[1618,1647,"Hey!"],[1647,1739,"Give that back!"],[1739,1860,"What are you working so hard for,"],[1860,1926,"Pearson?"],[1935,2068,"It's just girls' tennis."],[2093,2285,"You love to act like a hot shot."],[2327,2369,"But you know"],[2369,2510,"you didn’t ever beat a guy."],[2606,2673,"You know what?"],[2752,2823,"I could beat you."],[2890,2982,"I could beat both of you"],[2982,3082,"without breaking a sweat."],[3140,3219,"Oh, really?"],[3253,3315,"How about this?"],[3315,3411,"How about we bet on it?"],[3465,3570,"And if we win,"],[3616,3712,"you have to wash our underwear"],[3712,3820,"for the rest of the season."],[3841,3912,"And when I win,"],[4066,4141,"you'll be fetching my balls"],[4141,4237,"for me like dogs."],[4354,4437,"Yeah, right."],[4504,4575,"Good luck with that."],[4575,4629,"Mhm."],[5647,5705,"Here, boy."],[5834,5897,"Go fetch."],[6310,6389,"From that day on,"],[6389,6564,"I became your biggest fan, Lily."],[6644,6785,"Until you threw your career away"],[6827,6915,"for young love"],[6915,7052,"and shattered Coach Art's"],[7052,7144,"hopes and dreams."],[7144,7236,"I was just a kid."],[7265,7340,"We were all just kids"],[7340,7440,"when we started tennis."],[7524,7636,"You know, some of us didn't use that"],[7645,7741,"as an excuse to quit."],[7753,7849,"I thought you were here to help me."],[7849,7903,"I am."],[8145,8212,"You want me to share"],[8212,8291,"Coach Art with you?"],[8400,8450,"Then show me"],[8450,8566,"you're still the Queen of the Court."],[8646,8925,"The best female tennis player."]],"16":[[212,262,"Alright."],[408,471,"Let's see it."],[1509,1622,"Some things don't change."],[1647,1697,"Sorry."],[3557,3645,"Going easy on me?"],[3703,3774,"Wouldn't want to bruise"],[3774,3891,"the world champion's ego."],[4550,4633,"Dang it!"],[5317,5409,"It was a noble effort."],[5522,5622,"You always this cocky?"],[5668,5751,"Only when I'm winning."],[6927,6973,"Come on."],[7069,7186,"I'm going to take you to Coach Art."],[7273,7461,"He’s going to lose his mind."],[7632,7703,"Yes!"]],"17":[[250,308,"Damn it."],[396,467,"Patience."],[508,600,"Aces aren't easy to hit."],[600,658,"You're the one who"],[658,729,"told me it was doable."],[729,800,"It is."],[905,971,"I had a student."],[1051,1201,"She could hit 50 aces in a row."],[1217,1288,"You're just saying that to"],[1326,1430,"play mind games with me."],[1430,1480,"I..."],[1497,1547,"No, kid."],[1580,1651,"Her name was Lily."],[1710,1776,"Lily Pearson."],[1885,2085,"She was the best I ever trained."],[2181,2298,"She was also the youngest"],[2298,2439,"Grand Slam winner in the world."],[2506,2627,"She was on her way to becoming"],[2686,2811,"the greatest player of all time."],[2894,3028,"So what happened to her?"],[3044,3132,"She got distracted."],[3153,3382,"Gave up her potential for a man."],[3611,3720,"Yeah, that's right."],[3762,3853,"No, Coach."],[3887,3999,"It's, it's the Falcon."],[4116,4254,"Finn, what are you doing here?"],[4308,4383,"I thought you were playing."],[4400,4496,"Coach, I uh,"],[4654,4758,"I have someone here for you."],[5993,6060,"Hey, Coach."],[6089,6156,"Lily Pearson."],[6277,6318,"It's been..."],[6339,6377,"You know what?"],[6423,6564,"Don't call me Coach, okay?"],[6573,6731,"Because I don't coach quitters."],[6777,6844,"You can leave."]],"18":[[41,116,"Coach, wait."],[216,312,"I know I let you down."],[312,404,"You can yell at me all you want,"],[404,521,"but I will never quit again."],[521,588,"Ten years."],[638,779,"I waited ten years for you."],[779,880,"I know, I know."],[1005,1142,"I thought about returning to tennis"],[1142,1238,"countless times,"],[1238,1405,"but I just didn't know"],[1405,1501,"if you would take me back."],[1609,1714,"Please, it was my dream."],[1735,1843,"It still is my dream."],[1851,1926,"Please, Coach."],[2077,2168,"Please take me back."],[2314,2381,"I'm sorry."],[2473,2548,"Crazy kid."],[2748,2794,"When do you learn"],[2794,2911,"to control your emotions?"],[3036,3128,"It's bad for your game."],[3219,3319,"Not when she's determined"],[3319,3395,"to win a Slam."],[3536,3595,"A Slam?"],[3753,3874,"You want to win a Slam"],[3874,3995,"after a ten-year break?"],[4116,4166,"Yes."],[4220,4287,"And I know I can."],[4341,4441,"But only if you're my coach."],[5234,5284,"Karina."],[5497,5568,"This is Karina."],[5593,5705,"She's one of my new students."],[5768,5839,"I'm prepping her"],[5839,5980,"for her first junior tourney."],[6031,6097,"It looks like"],[6268,6373,"she's going to have to find herself"],[6373,6443,"a new coach."],[6519,6577,"Wait, what?"],[6948,7140,"We start tomorrow morning."],[7761,7828,"Thank you."]],"19":[[296,367,"Can't keep up?"],[1051,1205,"We just ran ten miles."],[1347,1518,"Need to work on your stamina, Queen."],[1614,1797,"I can think of a few ways to do that."],[1889,1956,"Like what?"],[2806,2957,"You're playing dirty, huh?"],[2957,3073,"Gotta keep up."],[3115,3186,"Come on, Mr. Number One,"],[3186,3311,"you gotta keep your head in the game."],[3983,4066,"Right back at ya."],[4362,4425,"Wendy,"],[4604,4713,"where are my pills?"],[5138,5238,"You didn't organize them?"],[5238,5321,"What the fuck?"],[5376,5522,"I think I need a sign that says,"],[5522,5680,"Miss Lily did that for you."],[5689,5860,"Jesus, you're fucking useless."],[6135,6268,"I'll just do it myself."]],"20":[[179,287,"Is this Lily's journal?"],[1743,1822,"You're up early."],[1885,1960,"What's all this?"],[1997,2077,"Set it up for you."],[2143,2202,"Did some reading"],[2202,2348,"on fast-switch muscle fibers,"],[2348,2444,"and allegedly,"],[2444,2560,"this is going to make you twice"],[2560,2677,"as explosive on the court."],[2681,2815,"You are the best coach"],[2823,2936,"in the whole world."],[3228,3278,"Thank you."],[4033,4166,"Ripped out?"]],"21":[[938,1030,"God! -That was close."],[1109,1197,"You're getting faster."],[1280,1330,"High five."],[1668,1810,"Dude, imagine letting your girl"],[1810,1901,"beat you like that."],[1922,2014,"Hey, Parker!"],[2056,2147,"You getting sponsored"],[2147,2281,"by Lululemon next?"],[2460,2552,"Adam, Adam, hey."],[2560,2619,"It's not worth it."],[2619,2690,"First, you're going to make me"],[2690,2781,"look like a little bitch,"],[2781,2848,"and then you're going to tell me"],[2848,2944,"not to get mad about it?"],[3240,3278,"What the hell?"],[3278,3386,"My mom bought me that."],[3386,3490,"If you're going to play like a girl,"],[3490,3620,"then play with a girl's racket."],[3653,3803,"Stop showing off like a slut."],[4875,4996,"You weren't like this before."],[5392,5442,"Come on."],[6339,6398,"Yes!"],[6452,6510,"Yes!"]],"22":[[212,308,"Oh, fuck."],[329,479,"Do we need to go to the hospital?"],[479,538,"No!"],[617,838,"Wait, Lily didn't block Wendy."],[838,905,"Give me your phone."],[1614,1735,"Wendy, is everything okay?"],[1835,2027,"Um, I was just..."],[2072,2231,"Uh, do you have my pills?"],[2231,2364,"Because I really have"],[2364,2427,"a stomach ache"],[2431,2606,"and it's pretty bad, so..."],[2615,2719,"This isn't 911."],[2765,2831,"Wrong number. - No!"],[2857,2898,"Lily!"],[