d."],[646,742,"I am scared,"],[967,1042,"but not of him."],[1242,1317,"Scared I'm..."],[1413,1514,"not a good player anymore."],[1697,1805,"You're not doing this alone."],[2439,2556,"We need to take Komatsu"],[2556,2619,"off her game"],[2619,2773,"by making her run around the court."],[3015,3082,"She's strong,"],[3119,3332,"but she's got no stamina."],[3541,3636,"If you keep her running"],[3636,3724,"around the court,"],[3837,3958,"then you'll win in two sets."]],"36":[[817,971,"Nobody's gonna be hitting that fast."],[1059,1146,"Are you playing to win?"],[1180,1230,"Yes."],[1280,1322,"No."],[1343,1455,"I saw the press conference."],[1480,1551,"You're playing"],[1551,1739,"to humiliate them back."],[1776,1981,"Now, I need you to be a killer"],[2014,2077,"on the court."],[2139,2189,"Got it?"],[2252,2356,"Make them eat your dust."],[2460,2523,"Let's go again."],[2602,2669,"Thanks, Coach."],[2994,3182,"Oh, Coach Art,"],[3182,3445,"we are about to get you."],[3461,3716,"Coach to all the top world champions."],[3883,4099,"Lily Pearson doesn't stand a chance"],[4099,4187,"against you"],[4195,4383,"once you've trained with him."]],"37":[[33,104,"Are you sure?"],[154,342,"I heard he doesn't take new students"],[342,467,"no matter how much money you pay."],[538,804,"We are holding two hundred grand's"],[804,942,"worth of gifts in our hands."],[971,1192,"No coach would ever pass that up."],[1363,1589,"Oh, well would you look at that."],[1609,1789,"Here to beg for Adam back,"],[1789,1868,"are we?"],[1868,1951,"She really doesn't have"],[1951,2085,"anything better to do in her life"],[2085,2185,"than stalk Adam."],[2231,2306,"It's sad."],[2352,2485,"I'm actually coming from practice."],[2494,2565,"Excuse me."],[2577,2673,"Wait, you're going to miss me"],[2673,2794,"training with Coach Art?"],[2886,3082,"Oh, so sad."],[3082,3303,"If you're jealous you can't afford him."],[3336,3520,"After all, he is going to make Mia"],[3520,3707,"the best player in the world."],[3749,3832,"I'm a