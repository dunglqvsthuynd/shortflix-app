es"],[6840,7015,"who enter our salsa competition."],[7044,7161,"See you lovebirds there."],[7161,7240,"I'm sorry, we're not-"],[7240,7303,"We are in."],[7303,7449,"Oh, uh..."]],"57":[[50,196,"I'm sorry about that back there,"],[196,367,"but we can drop the salsa crap."],[367,446,"No, we're not dropping"],[450,513,"the salsa crap."],[513,596,"I happen to enjoy"],[596,684,"playing your boyfriend."],[684,792,"Stop it."],[829,875,"Lily."],[1121,1209,"I'm in love with you."],[1263,1401,"And I don't mean to pressure you."],[1426,1626,"I just want you to know that I'm yours,"],[1747,1835,"if you'll have me."],[2494,2698,"Welcome to the 42nd annual"],[2698,2919,"Palm Springs Salsa showcase."],[2957,2998,"Woo!"],[3457,3624,"Each of you will have a chance"],[3624,3782,"to showcase your skills."],[3816,3962,"And one lucky couple"],[3962,4041,"will be crowned"],[4041,4195,"king and queen of the floor."],[4195,4270,"Vamos!"],[4270,4346,"Woo!"],[4725,4833,"I can't dance."],[4884,5005,"Everybody can dance."],[5205,5259,"You're the world's"],[5259,5380,"greatest tennis player."],[5430,5534,"Just follow my lead."]],"58":[[104,283,"You know it's not bingo night,"],[283,350,"right Grandma?"],[396,487,"You don't actually think"],[487,550,"you're gonna win"],[550,692,"the salsa competition, right?"],[754,796,"You know,"],[842,971,"you think about winning a lot"],[971,1130,"for someone who doesn't really do it."],[1251,1309,"Bitch."]],"59":[[137,258,"Who is that?"],[258,421,"They look so good together."],[454,563,"And she's beautiful."],[846,1009,"Get your fucking hands off of her."],[1217,1347,"Whoo! Whoo!"],[1418,1547,"That was amazing."],[1622,1693,"Bravo!"],[1997,2122,"I now welcome everyone"],[2122,2231,"to cast your votes."],[2256,2352,"Please give a rose"],[2352,2469,"to your favorite couple."],[3007,3123,"Congratulations,"],[3123,3261,"couple number three!"],[4037,4133,"You're never going to win"],[4133,4304,"anything ever again, bitch."]],"60":[[325,479,"Why would you risk your 