67,667,"I didn't leave you for anyone."],[784,884,"What you don't get"],[925,1051,"is that I would rather be alone"],[1051,1134,"than be with you."],[1409,1463,"Luckily,"],[1818,1881,"not every man"],[1881,2018,"is as revolting as you are."],[2656,2798,"God, I'm so sorry."],[2877,3023,"I keep throwing our fake relationship"],[3023,3094,"in his face."],[3244,3349,"He just won't leave me alone."],[3599,3695,"Then let's make it real."]],"63":[[1601,1697,"Only if you want to."],[2139,2185,"Lily?"],[2310,2364,"Lily?"],[2510,2627,"Lily, I was just joking."],[2627,2677,"Please."],[2811,2944,"Just please open the door."],[3799,3845,"Fuck!"],[3883,3924,"Fuck!"],[3924,3958,"Fuck!"],[3958,4004,"Fuck!"],[4058,4166,"Open the door!"],[4671,4746,"Shit!"]],"64":[[909,959,"Wait."],[1455,1526,"I won't be ready,"],[1805,1951,"until after I win this tournament."],[2473,2569,"What are you doing?"],[2573,2623,"Put me down!"],[2623,2719,"I'm taking you to bed."],[2719,2790,"I need this tournament"],[2790,2915,"to happen immediately."],[3712,3762,"Good luck at the"],[3762,3849,"Indian Wells Challenger,"],[3849,3912,"Miss Pearson."],[3912,3983,"Thank you."],[4229,4291,"Okay."],[4346,4416,"Looks like you're seeded"],[4416,4496,"for your first round"],[4496,4713,"against Komatsu at 2 p.m."],[4713,4954,"So that gives us plenty of time"],[4954,5105,"to warm up and go over strategies."],[5146,5176,"You know,"],[5176,5280,"I've been meaning to thank you."],[5326,5409,"Not just for this trip,"],[5409,5488,"but for everything."],[5563,5618,"You really helped me"],[5618,5701,"get out of my head."],[6289,6427,"Good luck on your games today, Lily."],[6427,6564,"Though, since you clearly"],[6564,6677,"don't know what's good for you,"],[6727,6794,"I don't think you're going to"],[6794,6936,"win any of them without me."]],"65":[[321,421,"What's so fucking funny?"],[504,658,"Just that you think I still need you."],[775,867,"Fuck off, Adam."],[1255,1405,"Now here's a little surprise for you."],[1468,1576,"Just in case you're wondering"],[1576,1676,"why you're going to get kicked"],[1676,1847,"out of my resort."],[2310,2398,"Babe, what's going on?"],[3253,3345,"You're permanently banned"],[3345,3453,"from Reid's Resorts."],[3516,3557,"What?"],[3682,3766,"What the fuck?"],[3820,3941,"Guys, you need to get your stuff"],[3949,3995,"and get out of here. - Give me"],[3995,4087,"a second, okay?"],[4162,4212,"I didn't know"],[4212,4350,"that you were dangerous,"],[4391,4433,"Mia."],[4450,4579,"Babe, just let me explain."],[4592,4637,"No."],[4688,4804,"You fucking hurt me."],[4938,5075,"I just love you so much"],[5075,5184,"and Lily didn't even get hurt."],[5184,5251,"She's fine."],[5280,5317,"Well,"],[5317,5442,"you listen to me very carefully,"],[5442,5492,"okay?"],[5522,5684,"If you ever come near Lily again,"],[5697,5834,"I will fucking ruin you."],[5889,5964,"Do you understand?"]],"66":[[16,183,"If you ever come near Lily again,"],[196,329,"I will fucking ruin you."],[387,458,"Do you understand?"],[629,679,"Adam,"],[742,871,"you left me for Lily."],[871,1005,"I know you love me more than her."],[1005,1121,"Don't flatter yourself."],[1222,1409,"Every single time I was fucking you,"],[1426,1526,"I was thinking of Lily."],[2965,3065,"I love you, Adam."],[3123,3232,"You're only acting like this"],[3232,3303,"because of Lily."],[3365,3445,"Once I show you"],[3445,3561,"she's nothing compared to me,"],[3561,3695,"we can be in love again."],[3845,3958,"Lady, you need to get out of here."],[3958,4066,"Okay, fuck off!"],[4066,4133,"I'm leaving!"],[4212,4270,"God!"]],"67":[[37,83,"Thank you."],[125,208,"I think you're going to win."],[266,358,"We just need to make sure"],[358,475,"this is secure. - What is the point?"],[475,571,"How could you leave me"],[571,667,"for someone else?"],[1584,1672,"I hate you."],[2018,2156,"You're really cooked, Spencer."],[2198,2298,"You're cooked, dude."],[2423,2519,"Dude, Spencer,"],[2519,2673,"you're so ass, bro."],[2702,2790,"Babe, I'm bleeding."],[2827,2902,"Okay."],[2944,3136,"Dude, you're fucking cooked."],[3140,3194,"Adam."],[3228,3282,"What?"],[3282,3349,"I'm busy!"],[3395,3495,"Oh my God."],[3628,3712,"Get fucked, dude."],[3716,3791,"I got you."],[3962,4016,"No way."],[4024,4112,"No shot."]],"68":[[400,492,"I don't love you."],[563,692,"I don't hate you either."],[775,1021,"You make me feel nothing."],[2223,2494,"Miss Lily, where is your umbrella?"],[2731,2781,"Oh."],[3082,3219,"Today was your mother's funeral."],[3474,3557,"Where's Adam?"],[3778,3953,"I need some water, Wendy."],[4024,4079,"Now."],[4166,4375,"Oh, Spencer got us a table"],[4375,4500,"last night at Chloe's."],[4542,4696,"We were popping bottles and"],[4696,4867,"it was so fun."],[5084,5330,"Do you have any idea what day it is?"],[5376,5518,"What, is it your birthday?"],[5960,6093,"You're wearing black."],[6193,6281,"I like that."],[6502,6648,"How could I be so wrong?"],[6898,6944,"Lily,"],[7032,7161,"I lost your love."],[7282,7361,"It's the only thing"],[7361,7469,"that ever mattered to me."]],"69":[[829,963,"Offer my opponent two million dollars"],[963,1101,"to throw the match tomorrow."],[2210,2352,"Pearson's first official"],[2352,2585,"Tennis Association match in ten years"],[2585,2665,"and she's going up"],[2665,2844,"against fifth seed, Komatsu."],[3094,3182,"Are you playing to win?"],[3261,3303,"No."],[3349,3420,"You're playing"],[3428,3611,"to humiliate them back."],[3795,3928,"And she's taking it."],[3987,4262,"I need you to be a killer on the court."],[4471,4621,"Lily Pearson has just"],[4621,4808,"come out of retirement to defeat"],[4808,5038,"the third ranked player in the world."],[5063,5259,"But can she do it again?"]],"70":[[150,325,"This is who you are."],[483,638,"Not just someone's wife."],[734,800,"Not a girl"],[800,955,"who abandons her dream."],[1368,1476,"You're the tennis player"],[1484,1576,"who's going to win"],[1584,1735,"this entire tournament."],[1910,2006,"Oh yeah!"],[2035,2168,"Pearson's a killer."],[2314,2469,"We need a new nickname for her."],[2498,2569,"Fans have started"],[2569,2711,"calling her the Boomerang."],[2752,2857,"She's back."],[2857,3057,"The Boomerang is back!"],[3103,3190,"Oh yeah!"],[3399,3474,"Great game."],[3490,3586,"Old bitch."]],"71":[[8,175,"Oh my God! - Lily, can I please"],[175,221,"that was - have your"],[221,287,"incredible. - autograph?"],[287,521,"when you hit that ace. -Sign this for me?"],[608,692,"Thank you guys."],[692,813,"You're amazing. - Thank you so much"],[813,875,"Thanks, guys."],[875,992,"That ace at the end?"],[1046,1101,"Whoo!"],[1238,1305,"Just one second guys,"],[1305,1363,"I'll be right back."],[1363,1430,"Okay? - Okay."],[1964,2043,"I feel amazing."],[2122,2252,"Like myself again for the first time"],[2252,2323,"in a long time."],[2377,2456,"Just one more match"],[2456,2544,"till you win this thing."],[2573,2802,"After that, Australian Open."],[3028,3086,"Oh wait."],[3203,3299,"Looks like your opponents"],[3307,3382,"are going to be..."],[3440,3511,"Miss Sparks,"],[3511,3607,"do you have anything to say"],[3607,3787,"to Miss Pearson before the match?"],[3841,3945,"Do you have your hearing aids in,"],[3945,3991,"Lily?"],[4012,4108,"You better listen up."],[4162,4233,"I took your man"],[4233,4404,"and I'm gonna take this tournament too."],[4704,4934,"God. Mia’s a goddamn disgrace to tennis."],[4967,5009,"No."],[5050,5146,"You know what? I don't mind."],[5213,5313,"It's gonna feel that much better"],[5313,5380,"when I beat her."]],"72":[[283,350,"After that..."],[375,513,"Oh my God, apology flowers?"],[513,563,"Babe!"],[563,633,"They're not for you."],[688,829,"And stop calling me babe."],[925,1026,"You're still angry at me?"],[1084,1155,"I won my match."],[1155,1284,"You said you love winners."],[1305,1443,"Two million dollars, Mia."],[1480,1547,"You really don't think"],[1547,1614,"I would have noticed"],[1614,1751,"that being taken out of my account?"],[1830,2060,"I know you paid to throw your match."],[2147,2314,"It's disgusting how low you can get."],[2335,2452,"I did it for us."],[2494,2544,"Babe."],[2590,2740,"Once you help me beat Lily,"],[2761,2923,"you can finally see what a loser she is"],[2923,3015,"and we can be together again."],[3015,3157,"You are delusional,"],[3157,3211,"if you think"],[3211,3307,"that I'm ever gonna help you"],[3307,3386,"on the court again."],[3578,3691,"Do you want some real advice?"],[3774,3841,"Anything, babe."],[3949,4004,"Quit."]],"73":[[33,83,"Lily."],[208,325,"Trouble in paradise, Adam?"],[325,396,"God."],[446,525,"You saw that?"],[754,867,"Well, I broke up with Mia."],[905,1013,"I'm completely over her."],[1176,1267,"I got you these."],[1484,1534,"Please."],[1559,1630,"Wait. - Let go of me."],[1639,1718,"No, you were there for me"],[1718,1814,"when everyone else thought"],[1814,1889,"I was nothing."],[1939,2102,"And I was selfish and I was arrogant"],[2102,2218,"and I treated you like shit."],[2273,2352,"And I'm the reason"],[2352,2444,"that your light went out."],[2502,2656,"And I just want to spend"],[2656,2740,"the rest of my life"],[2740,2836,"making you shine."],[3032,3153,"I have nothing without you."],[3215,3307,"You're too late, Adam."],[3307,3386,"Please, please."],[3386,3436,"I don't care."],[3436,3536,"You can be with Finn."],[3624,3728,"Just please don't cut me"],[3728,3837,"out of your life forever."],[3837,3953,"You can never give me back"],[3953,4029,"the years of my life"],[4029,4149,"that you stole from me."],[4208,4279,"But you can make sure"],[4279,4379,"you don't ruin the rest."],[4379,4521,"So let me go, Adam."],[4625,4763,"If you really loved me, you would."]],"74":[[16,120,"I mean, what does she have"],[120,221,"that I can't give you?"],[2064,2135,"Oh, Lily."],[2168,2348,"You're gonna lose so bad."],[3065,3190,"Hey!"],[3319,3407,"Hi, everyone."],[4929,5100,"If Pearson pulls this off,"],[5100,5276,"she's gonna go to her first final"],[5276,5392,"in half a decade."],[5430,5643,"This is really important to her."],[6197,6423,"It may be her first loss, too."],[6464,6635,"I didn't even have to lace your drink"],[6635,6735,"to beat you, huh?"],[7132,7215,"Stop shaking."]],"75":[[2631,2756,"You can do this."],[4404,4596,"And the first set goes to Pearson."],[4654,4804,"I might just eat my words."],[5922,5993,"That's right, Lily."],[6043,6114,"Drink up."],[6310,6556,"What's wrong with me?"],[7157,7340,"Wait, the water!"]],"76":[[884,955,"Violation."],[955,1080,"He can't be on the court."],[1113,1272,"Mr. Reid, get off the court!"],[1313,1384,"What are you doing?"],[1476,1576,"You need your boyfriend"],[1576,1689,"to coach you, Lily?"],[1776,1910,"There is something in that water."],[1964,2039,"It's spiked."],[2369,2477,"How would you even know that?"],[2548,2665,"Lily, just forfeit."],[2665,2752,"You're causing a scene."],[3194,3353,"Why is the lid left open?"],[3503,3620,"Anything given to Lily,"],[3620,3737,"I check out myself"],[3737,3866,"because I care about her."],[3924,4024,"And I know you're desperate"],[4024,4099,"and stupid enough"],[4099,4225,"to pull something like this."],[4350,4483,"You stand for nothing, Mia."],[4575,4683,"You don't respect women."],[4704,4788,"You don't respect the game."],[4788,4959,"And you don't respect yourself."],[5155,5246,"I'm calling security."],[5246,5288,"No."]],"77":[[25,150,"I want to finish what I started."],[383,500,"I want the world to see me win."],[608,713,"The world already knows"],[713,784,"you're a quitter."],[850,959,"And you have no proof."],[988,1042,"Who do you think"],[1042,1113,"they're going to believe?"],[1176,1234,"Your serve."],[1622,1672,"Ready?"],[1793,1885,"Play, please."],[1914,2035,"Yeah, Lily!"],[2035,2122,"Go, Lily, go!"],[2168,2277,"Yeah, Lily!"],[2289,2398,"Yeah, Lily!"],[3445,3611,"Who is this Lily Pearson?"],[3636,3787,"Pearson seems angry."],[3787,3962,"We have never seen her like this."],[4037,4237,"I'm done being walked over."],[4270,4479,"I'm done looking the other way."],[5042,5113,"Boomerang,"],[5130,5255,"more like a bayonet."],[5292,5526,"Lily Pearson, where have you been?"]],"78":[[137,250,"Wait, I'm, I’m not ready."],[412,500,"Time violation."],[500,579,"She's stalling."],[604,771,"Warning, Miss Sparks."],[3174,3315,"Game, set, match."],[3319,3395,"Pearson."],[3478,3532,"Fuck!"],[3603,3712,"And she's done it."],[3745,3912,"Lily Pearson is back."],[3933,4154,"She's going to the Australian Open."],[4617,4683,"There she is."],[4725,4859,"She's the one who poisoned the water."],[5038,5100,"What are you doing?"],[5242,5288,"Adam?"],[5351,5417,"What are you doing?"],[5417,5455,"No!"]],"79":[[8,183,"You are under arrest, Mia Sparks."],[196,291,"Following a very thorough"],[291,383,"investigation,"],[400,542,"if you are found guilty-"],[542,625,"Which she will be."],[638,700,"You will be banned"],[700,788,"from all future competition"],[788,896,"and stripped of your titles."],[896,1030,"Adam, I did this for us."],[1059,1101,"Okay?"],[1101,1146,"I love you."],[1146,1230,"Why are you doing this to me?"],[1230,1313,"Take her away, boys."],[1326,1380,"Adam!"],[3207,3274,"Impressive."],[3345,3428,"You’re amazing."],[3657,3728,"Miss Pearson."],[3749,3812,"Miss Pearson."],[3853,3937,"Who do you have to thank"],[3937,4016,"for your success?"],[4287,4346,"My team."],[4446,4550,"Coach Art and Finn Reid."],[5025,5088,"And myself."],[6373,6510,"Hi, listen, I know you're really tired,"],[6510,6614,"but could you sign this autograph"],[6614,6664,"for me?"]],"80":[[4,45,"Of course."],[45,108,"My name's Lily."],[129,183,"It is?"],[204,254,"Yeah."],[254,350,"Nice to meet you, Lily."],[358,442,"I'm such a big fan."],[454,492,"Could you give me"],[492,588,"any words of advice?"],[596,725,"I want to be just like you one day."],[746,905,"Hey, you should play just like you,"],[905,1001,"and then you're going to play better."],[1096,1255,"Also, don't ever let anyone"],[1255,1338,"make you feel small."],[1430,1493,"Your dreams are never"],[1493,1555,"going to be too big"],[1555,1672,"for someone that really loves you,"],[1685,1730,"okay?"],[2106,2193,"Thank you so much."],[2193,2285,"Yeah, of course."],[2302,2360,"You're welcome."],[3069,3228,"Can I have an autograph next?"],[3265,3319,"Yeah, you deserve"],[3319,3449,"way more than an autograph."],[3499,3603,"You just got drugged for me."],[3628,3703,"And I'd do it again."],[3762,3853,"A punching bag,"],[3874,3945,"a stress ball,"],[4008,4083,"anything for you."],[4108,4166,"That's all?"],[4270,4358,"Maybe student."],[4400,4554,"If you're up for teaching ever again."],[4567,4696,"You know, I've got a rule."],[4788,4917,"I don't date my students."],[4917,5050,"So I don't think I can take you on."],[5134,5176,"Hmm."],[5296,5359,"Wait a minute."],[5417,5476,"So that means-"]]}