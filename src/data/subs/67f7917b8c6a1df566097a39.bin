y thing is a lie."],[2623,2715,"You've been conspiring on this"],[2715,2790,"from the beginning."],[2836,2977,"You instructed her to steal my sperm,"],[2977,3032,"didn't you?"],[3073,3140,"Too bad."],[3165,3244,"Your plan was doomed"],[3244,3311,"from the start."],[3411,3561,"What she gave you wasn't mine."],[3699,3816,"It was her husband's."],[3987,4054,"What?"],[4054,4225,"This is impossible!"],[4237,4291,"Wait."],[4316,4425,"Is this true?"],[4458,4521,"Mom,"],[4525,4612,"get her out of here now."],[4667,4800,"Emily and I will not be coming back"],[4800,4863,"to live here."]],"63":[[16,150,"Emily and I will not be coming back"],[150,216,"to live here."],[216,283,"Lucas!"],[321,517,"Everything I did, I did for you!"],[608,750,"You've worked so hard"],[750,871,"to get where you're at."],[896,1105,"I just want you to have a wife"],[1105,1217,"who will help you."],[1259,1418,"But is she really the right choice?"],[1906,1997,"I..."],[2022,2102,"I... ah..."],[2102,2223,"I think I'm delivering."],[2318,2385,"Ah!"],[2844,2957,"You can stay here from now on."],[2994,3136,"Just think of it as a place"],[3136,3232,"to clear your mind, okay?"],[3345,3516,"What's gonna happen to Lucas?"],[3582,3699,"Is he going to have another fight"],[3699,3778,"with his mother?"],[3824,3941,"You're still worried about him?"],[4120,4258,"You really love him that much?"]],"64":[[25,154,"You really love him that much?"],[241,358,"I think I do."],[2798,2873,"Whatever you want."],[3920,4037,"I'm on my way, Emily."]],"65":[[717,855,"Why do you care so much?"],[875,946,"You're already going to have"],[946,1017,"another baby."],[1017,1155,"You don't need me anymore."],[1526,1630,"Can you feel my heartbeat?"],[1776,1906,"I don't need a child."],[1976,2056,"I need you."],[2752,2815,"Emily,"],[2815,2977,"have my actions not made my feelings"],[2977,3032,"clear to you?"],[4358,4491,"You're the only one I love."]],"66":[[112,183,"So..."],[237,333,"you weren't actually"],[333,496,"looking for a surrogate that day?"],[575,709,"Emily, I only want a kid"],[709,804,"because I met you."],[1005,1184,"So you'd still marry someone else"],[1184,1322,"if it wasn't for that incident?"],[1355,1484,"And that woman at the mall?"],[1651,1689,"Oh my God,"],[1689,1768,"it all makes sense now."],[1768,1851,"No wonder she thought"],[1851,1964,"that I took her place."],[1989,2064,"No, it's just everything"],[2064,2202,"with you felt right."],[2344,2435,"I never forgot about you"],[2435,2552,"ever since I first saw you."],[4500,4692,"How is this not Lucas's child?"],[5005,5226,"You will pay for this."]],"68":[[304,396,"It's you."],[492,575,"What are you doing here?"],[575,700,"Don't you dare hurt my mother!"],[800,892,"And what about me?"],[921,1092,"A woman of my family background"],[1092,1255,"forced to raise some child"],[1255,1409,"from some low-class nobody."],[1564,1668,"I would already be married"],[1668,1776,"to a jewelry tycoon"],[1776,1926,"if it wasn't for you, bitch!"],[3094,3203,"The kid you have"],[3224,3328,"will never be Lucas's,"],[3328,3415,"even without me!"],[3415,3495,"Shut up!"],[3687,3828,"You ruined everything."],[3908,4029,"Everything that you've been doing"],[4029,4149,"is against the law!"],[4149,4258,"Yeah, maybe."],[4258,4375,"But the thing is,"],[4375,4496,"I'm not afraid of anything."],[4562,4825,"Especially if I end up being his wife."],[4892,5063,"I've loved him for so long."],[5063,5125,"And what?"],[5125,5238,"You think I would just sit around"],[5238,5313,"and watch him get married"],[5313,5463,"to a bitch like you?"],[5518,5605,"I don't think so."],[5659,5809,"Do you even realize"],[5809,5960,"how much effort I put in?"]],"69":[[16,162,"Do you even realize"],[162,312,"how much effort I put in?"],[1947,2006,"Emily?"],[2640,2806,"Boss, your wife is in danger."],[3174,3407,"Do you think Lucas will still want you?"],[3407,3511,"After he sees you"],[3511,3699,"humiliated by another man?"],[3732,3837,"How can you be so evil?"],[3837,3991,"I have nothing to do with your failures!"],[3991,4070,"Save it!"],[4124,4241,"I'm not gonna let you go."],[4279,4450,"You can go to hell, bitch."],[4450,4562,"And your mother, too."],[4646,4742,"And now..."],[4825,5138,"now I get to watch you beg for your life."],[5201,5317,"You done talking?"],[5317,5422,"It's my turn now."],[5951,6101,"You really are gorgeous."],[6126,6189,"No!"],[6193,6239,"No!"],[6243,6302,"No!"],[6710,6810,"Wait for me, Emily."],[6886,6973,"I'm coming for you."]],"70":[[29,79,"No!"],[100,150,"No!"],[642,784,"Private party, asshole!"],[1184,1242,"Emily."],[1505,1584,"Lucas."],[1618,1701,"My mom..."],[1726,1797,"Don't worry."],[1839,1985,"Someone's already protecting her, okay?"],[2256,2318,"Emily?"],[2448,2702,"You got here so fast."],[2723,2819,"Too bad you missed a chance"],[2819,3007,"to see Emily under someone else."],[3023,3115,"What do you want?"],[3148,3411,"I did everything to be close to you!"],[3486,3603,"I bribed servants,"],[3603,3824,"and she ruined everything!"],[3858,4020,"I even had to have a lowborn child"],[4020,4108,"because of her!"],[4195,4337,"You're out of your mind."],[4917,5055,"If I can't have you..."],[5150,5255,"no one can!"]],"71":[[0,120,"If I can't have you..."],[221,325,"no one can!"],[3420,3474,"Hey."],[3578,3636,"Hey."],[3928,3987,"I've been wanting"],[3987,4154,"to apologize to you, Emily."]],"72":[[33,100,"I've been wanting"],[100,275,"to apologize to you, Emily."],[362,517,"It's my fault you got hurt."],[592,671,"But now,"],[692,813,"Sophie's in jail,"],[942,1026,"and me..."],[2264,2314,"Emily?"],[2385,2444,"Are you okay?"],[2444,2535,"Do I need to call a doctor?"],[2686,2761,"It's okay."],[2811,2882,"I just..."],[2923,3086,"I forgot to tell you that I'm pregnant."],[3153,3282,"Okay, you're pregnant, that's..."],[3874,3920,"Wait."],[4045,4108,"You're pregnant?"],[4241,4325,"I'm gonna be a dad."],[4529,4688,"Emily, I love you so much!"],[5159,5226,"This..."],[5413,5601,"is the ring I wanted to give you before."],[6056,6122,"Emily."],[6468,6539,"My love."],[6802,6890,"Will you marry me?"],[7924,8058,"I will always be your knight..."],[8229,8324,"to protect..."],[8416,8533,"and love you forever,"],[8600,8692,"my princess."]]}