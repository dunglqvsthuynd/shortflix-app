 contract-"],[688,750,"Damn it."],[855,909,"One sec."],[2731,2873,"Sorry, I didn't mean to interrupt."],[2873,3011,"I told you."],[3011,3140,"It's getting late."],[3315,3378,"My boy."],[3524,3741,"These are why I have so many kids."],[3966,4033,"Looks like I'm going to"],[4033,4220,"have a great grandkid soon."],[4537,4617,"Come on."],[4617,4679,"Let's go."],[7328,7390,"Damn it!"],[7390,7453,"No!"],[7453,7574,"They really are together!"]],"30":[[563,638,"Thanks for..."],[679,738,"standing up"],[738,800,"for me today."],[1026,1067,"Here."],[1151,1213,"No, no, no."],[1488,1568,"It's yours now."],[1743,1805,"But..."],[1856,1972,"I'm only your surrogate."],[2139,2206,"Right, right, right."],[2344,2431,"Um..."],[2481,2615,"You know, we should get some rest."],[2615,2711,"I have work"],[2711,2790,"with Grandpa in the morning"],[2790,2873,"and my mom's coming back"],[2873,2952,"from a vacation."],[2969,3040,"But I'm..."],[3053,3128,"sure she'll love you."],[4554,4696,"Lucas actually married some"],[4696,4783,"country girl."],[4854,4988,"No, that's not happening!"]],"31":[[1964,2089,"Yeah, I'm going to the office right now."],[2602,2681,"Wow!"],[2790,2977,"This place is huge!"],[3028,3082,"Don't worry,"],[3090,3215,"I won't let you down, ma'am."],[3240,3524,"She's just a nobody country bumpkin."],[3524,3628,"I'll make sure she gets"],[3628,3812,"exactly what she deserves."],[5017,5188,"Wasn't that my breakfast?"],[5201,5280,"That's the breakfast"],[5280,5426,"specially made for Mr. Andersen."],[5559,5776,"Ugh, how are you so clueless?"],[5814,5918,"Okay, so..."],[5989,6122,"where's mine?"],[7357,7457,"Here's your food,"],[7457,7720,"you worthless parasite."]],"32":[[0,283,"You worthless parasite."],[458,508,"But..."],[600,767,"That's... that's trash!"],[917,1159,"Trash only deserves to eat trash."],[1251,1343,"Why are you insulting me"],[1343,1438,"like this?"],[1493,1655,"Well, you asked for breakfast,"],[1655,1768,"and here it is."],[1839,1876,"What?"],[1876,2002,"You don