{"1":[[241,291,"Wow!"],[291,429,"So this is where Kevin works?"],[462,575,"There's nothing like this"],[575,658,"back at home."],[738,909,"I know he'll be excited to see me."],[909,1005,"Safe travels, boss."],[2248,2306,"Oh! - Oh!"],[2402,2473,"So sorry. I'm so, so sorry"],[2473,2502,"about that."],[2552,2606,"All good!"],[2635,2715,"I'm so, so sorry."],[2715,2777,"Yeah, yeah."],[3695,3774,"Hey, you!"],[4012,4120,"Oh, excuse me!"],[5447,5505,"Oh!"],[5518,5572,"Ah!"],[5593,5647,"Ah!"],[5922,6006,"Ugh."],[6006,6081,"Ah!"],[6206,6281,"Oh!"],[6314,6389,"Hey, hey boss,"],[6389,6468,"isn't that your wallet?"],[6710,6769,"Here."],[6844,6969,"Be more careful next time."],[6990,7040,"Thank you."],[7161,7240,"How can I..."],[7253,7344,"repay you for this?"],[7432,7553,"And can I ask why you have..."],[7590,7711,"corn on the cob in your bag?"],[7732,7924,"Oh, it's from my family's farm."],[7924,8099,"I was bringing it to my boyfriend."],[8133,8199,"Right."],[8304,8445,"Anyways, bye!"],[8491,8575,"Bye."],[8762,8833,"Hey, boss."],[8833,9009,"I, I really think you should get yourself"],[9009,9109,"a security guard."],[9109,9221,"Let's uh, head back to the mansion."],[9409,9530,"Grandpa's probably gonna start"],[9530,9680,"pushing me to get married again."],[9813,9980,"Why hasn't Kevin texted back yet?"],[10076,10176,"Should I call him?"],[10977,11111,"Why is this Emily calling you?"],[11311,11428,"He does want to see me,"],[11515,11590,"doesn't he?"]],"2":[[158,283,"Your cousin again?"],[308,392,"Cousin?"],[446,596,"She's just a desperate bitch"],[596,688,"who paid for my college"],[688,788,"back in the day,"],[788,950,"and won't stop bothering me for it."],[1138,1263,"Why isn't he answering?"],[3290,3374,"What are you doing here?"],[3453,3545,"What am I doing here?"],[3545,3641,"I'm your girlfriend!"],[3737,3820,"Girlfriend?"],[3853,3978,"Are you out of your mind?"],[3978,4099,"Only someone as beautiful"],[4099,4216,"and as smart as Rose"],[4216,4325,"is worthy of that title."],[4333,4521,"Get out of here, you poor country girl."],[4554,4738,"Kevin, I worked my ass off"],[4738,4821,"for your college."],[4821,4942,"Five years we've been together"],[4942,5075,"and this is how you treat me?"],[5088,5255,"You're lucky you even know me."],[5288,5426,"Without me, you'd still be stuck"],[5426,5568,"in that miserable little town."],[5751,5889,"So this is what our relationship"],[5889,5951,"means to you."],[5993,6056,"Nothing."],[6202,6260,"Fine!"],[6260,6460,"I want you to pay me back every penny"],[6460,6606,"that I spent for your tuition."],[6606,6664,"Money?"],[6815,6902,"What money?"],[6936,7069,"Is this how you beg for money?"],[7461,7603,"You're an asshole, Kevin!"],[7636,7811,"I want you to pay me back every penny"],[7811,7974,"that I spent on your tuition!"],[7974,8062,"You want money?"],[8358,8487,"Here's your cash."],[8558,8696,"A little farewell gift."]],"3":[[41,154,"Now get lost."],[1017,1071,"No!"],[1126,1222,"You can't leave!"],[1555,1668,"My mom's sick!"],[1668,1843,"Her hospital bills are in hundreds"],[1843,2018,"of thousands of dollars in debt!"],[2018,2235,"Don't you care at all about what we had?"],[2531,2665,"How is your mom's death"],[2706,2802,"any of my business?"],[2965,3078,"Let's go, babe."],[3916,4074,"No, you can't leave!"],[4283,4325,"Wait!"],[4375,4496,"Wait, don't leave!"],[7015,7194,"How did he become like this?"],[7261,7432,"What am I supposed to do now?"]],"4":[[1146,1217,"Hey, hey, hey."],[2256,2306,"You okay?"],[2431,2540,"It's you."],[2640,2694,"Come on, come on."],[4091,4158,"Ma'am,"],[4158,4337,"my boss booked you a room here."],[4371,4458,"Feel free to rest."],[4458,4596,"And if you need anything,"],[4596,4750,"the front desk is at your service."],[5288,5338,"Shit."],[5338,5426,"His jacket!"],[5501,5609,"We'll probably never see"],[5609,5709,"each other again."],[5709,5976,"But, I did also help him today. So..."],[6010,6122,"I guess we're even."],[6806,7036,"You're 28, for God's sake!"],[7036,7203,"If you don't settle down soon,"],[7203,7311,"I'll have no choice"],[7311,7499,"but to hand the family business"],[7499,7649,"to your brother Noah!"],[7878,7982,"Adam, I need you to find me"],[7982,8108,"a contract wife."],[8162,8291,"Any requirements, sir?"],[9897,9972,"Ms. Davis,"],[9972,10051,"your mom's medical bills"],[10051,10114,"are overdue."],[11357,11565,"$500,000 to be a surrogate?"]],"5":[[58,133,"Boss,"],[133,212,"the candidate for your"],[212,375,"contract wife is waiting inside."],[475,688,"The hospital's final notice came today."],[713,859,"I don't have a choice anymore."],[859,1021,"This is my only way out."],[1584,1639,"Hey."],[2477,2560,"It's you. - It's you."],[2598,2794,"He's the one who needs a surrogate?"],[2819,3032,"She's the candidate for my contract wife?"],[3123,3190,"Well, my..."],[3190,3257,"assistant should have"],[3257,3403,"explained all the requirements."],[3403,3599,"I'll need you to take this job seriously."],[3599,3707,"And as for the price..."],[3787,3837,"name it."],[4066,4266,"But we both need to contribute."],[4266,4562,"Should we go to the hospital now, or...?"],[4608,4671,"Hospital?"],[4763,4909,"We're gonna go to my house."],[5017,5142,"Your house?"],[5163,5330,"Is your wife okay with that?"],[5467,5580,"You are my wife."],[5618,5730,"It's part of the job."],[5772,5847,"Wife?"],[5901,6085,"I have to marry him to be a surrogate?"],[6151,6247,"No surgery?"],[6306,6464,"Does he expect us to..."],[6531,6710,"have a child the natural way?"],[6927,6944,"Oh!"],[6969,7090,"Uh, hi, uh..."],[7098,7344,"I thought you were already in there."],[7432,7549,"My boss is inside."],[7607,7665,"Follow me."],[7711,7882,"He won't be able to resist me."],[7882,8012,"Once he sees my face,"],[8012,8199,"I'll have him wrapped around my finger."],[8508,8554,"Come on."],[8854,9079,"Adam, take us to the registry office."],[9296,9363,"Oh, uh."],[9363,9413,"What?"],[9434,9501,"What?"]],"6":[[412,467,"You okay?"],[550,675,"Oh, yeah."],[800,1001,"Well, I have some errands to run,"],[1001,1142,"but take your time."],[1163,1263,"Buy yourself some clothes."],[1317,1372,"But there is something I"],[1372,1463,"need you to be at tonight at..."],[1676,1739,"One second."],[1976,2177,"Did I really just marry a stranger?"],[2189,2298,"Does that mean I have to"],[2377,2489,"do that with him tonight?"],[2623,2711,"He's hot, though,"],[2711,2761,"and..."],[2790,2873,"mom can finally"],[2873,2994,"get the treatment she needs."],[3157,3278,"Grandpa, I'm gonna be bringing my wife"],[3278,3370,"to the banquet tonight."],[3478,3553,"What?"],[3687,3820,"You're married?"],[3866,3916,"Yeah!"],[3928,4008,"You're gonna love her."],[5213,5284,"Wow!"],[5397,5538,"I'd never find anything"],[5538,5638,"like this at home."],[5764,5834,"You."],[5893,5993,"You're the country girl"],[5993,6131,"who stole my spot"],[6131,6297,"as wife of the CEO."],[6368,6464,"CEO's wife?"],[6464,6535,"What are you"],[6535,6694,"talking about? - Don't play dumb."],[6760,7015,"You got there before I did,"],[7015,7119,"and you took"],[7119,7273,"my spot."],[7319,7486,"You don't even deserve him."],[7574,7640,"I didn't know"],[7640,7849,"surrogacy was such a hot job."],[8024,8262,"So what if I'm from the countryside?"],[8262,8379,"At least I'm healthy."],[8420,8512,"You, on the other hand,"],[8512,8646,"look like you'd snap in half"],[8646,8767,"if you tried to have a baby."],[8917,9100,"And what's that supposed to mean,"],[9100,9205,"you bitch?"]],"7":[[0,116,"You bitch!"],[500,588,"Touch me again,"],[588,713,"and I'll call the police."],[713,834,"Call the police?"],[834,1051,"Who do you think you are?"],[2364,2452,"Oh my god."],[2523,2669,"What are you doing here?"],[2706,2815,"I'm with my wife."],[2869,2986,"Care to explain what the hell you're doing?"],[2986,3082,"You see, I was supposed"],[3082,3186,"to be here earlier today,"],[3186,3324,"and she stole my spot."],[3374,3503,"She's not good enough for you."],[3553,3674,"Okay, so you were late,"],[3674,3770,"and that's on you."],[3816,3916,"And for the record..."],[3941,4070,"I decide what's best for me."],[4091,4191,"Mr. Andersen,"],[4195,4250,"please."],[4250,4416,"She's just some country girl"],[4416,4529,"wearing trash."],[4629,4750,"She's not good enough for you,"],[4750,4829,"Mr. Andersen."],[9430,9547,"Mr. Andersen,"],[9567,9726,"you shouldn't be doing this!"],[9788,9847,"You're a..."],[9897,9984,"billionaire..."],[9984,10122,"jewelry tycoon."],[10189,10251,"I'm..."],[10251,10381,"just Emily's husband."],[10493,10568,"Security!"],[10610,10860,"Ban this woman for life from Maple malls"],[10860,11052,"for insulting the CEO's wife."],[11052,11119,"No!"],[11140,11202,"You can't!"],[11211,11315,"You can't!"],[11911,12074,"Wow, I didn't know that"],[12074,12195,"you had so much power."],[12295,12374,"It's no big deal."],[12458,12554,"You're my wife now."],[12654,12783,"Let's go home and get ready for tonight."]],"8":[[692,859,"All these are for me?"],[884,984,"Of course they're for you."],[2152,2252,"VIVAIA..."],[2369,2523,"These are so soft."],[3299,3428,"These are so comfortable."],[3641,3837,"How can he be so generous?"],[3933,4154,"There's so many beautiful things."]],"9":[[1159,1272,"Catch a good look, wifey?"],[1747,1797,"Um..."],[1818,1868,"I..."],[1868,1918,"think I..."],[1947,2052,"need to go, like..."],[2110,2177,"right..."],[2214,2281,"now."],[2727,2936,"No, these reports are a disaster."],[2944,3078,"Boss, would it be alright"],[3078,3211,"if we get the revised"],[3211,3365,"version to you by tomorrow morning?"],[3611,3687,"Yeah, keep, keep..."],[3695,3774,"keep up the good work."],[4062,4120,"So..."],[4162,4250,"what do you think?"],[4783,4867,"You look beautiful."],[5296,5397,"Uh..."],[5397,5497,"should we start"],[5497,5630,"the surrogacy stuff now?"],[5768,5851,"What surrogacy?"]],"10":[[33,108,"What surrogacy?"],[225,325,"Oh, boss, it's..."],[412,538,"It's almost time for the banquet."],[596,688,"The banquet?"],[713,792,"Of course,"],[792,925,"so that's what he meant earlier."],[975,1130,"Ugh, what was I even thinking?"],[1785,1968,"My uptight brother got married."],[2093,2235,"Let me guess, it's a contract wife"],[2235,2423,"to keep his CEO title safe from me."],[2498,2577,"I guess I'll just have to"],[2577,2698,"expose his little charade"],[2698,2823,"in front of everyone tonight."],[4371,4446,"Wow, it's..."],[4508,4646,"beautiful here!"],[4654,4704,"Go on."],[4746,4842,"Take a look around."],[4909,4992,"I'll find you in a bit."],[5321,5392,"Ms. Rose,"],[5392,5568,"you're still as beautiful as ever!"],[5618,5722,"Absolutely."],[5730,5855,"And as Mr. Andersen's"],[5855,5939,"chosen partner"],[5939,6118,"for the largest jewelry empire,"],[6147,6214,"well..."],[6214,6281,"you're basically"],[6281,6439,"a top tier tycoon yourself."],[6439,6594,"Congratulations."],[7077,7298,"She's gorgeous!"],[7298,7453,"Isn't that that country girl"],[7453,7578,"we ran into earlier?"],[7599,7699,"Is that her?"],[7795,7853,"Really?"]],"11":[[667,813,"Are you out of your mind?"],[813,892,"Emily,"],[934,1059,"still haven't given up?"],[1121,1197,"Following me here"],[1197,1343,"and dressing like that?"],[1401,1539,"Who you trying to impress, huh?"],[1539,1634,"You probably rented"],[1634,1751,"that outfit, didn't you?"],[1830,1997,"Trying to snag a rich guy?"],[1997,2173,"It doesn't matter what you wear."],[2173,2406,"You won't lose that small town vibe."],[2544,2706,"Wait, she's just a gold digger?"],[2706,2857,"I thought she was a big shot."],[2857,2944,"How dare you talk about"],[2944,3094,"Ms. Jones like that?"],[3132,3299,"Do you know who you're talking to?"],[3570,3657,"I wonder what kind of woman"],[3657,3791,"Lucas picked to be his wife."],[3858,3958,"This should be interesting."],[4037,4129,"What did you think?"],[4129,4183,"You were gonna"],[4183,4366,"transform into a princess?"],[4391,4491,"Overnight?"],[4617,4688,"Please."],[4713,4954,"Even if you were standing here naked,"],[4954,5130,"I wouldn't give you a second glance."],[6018,6139,"What the hell?"],[6181,6272,"Feeling refreshed?"],[6272,6393,"Maybe this will help you"],[6393,6556,"pull your head out of your ass!"],[6664,6773,"You're an interesting woman."],[6827,6923,"Thanks for the glass."],[7119,7278,"I think I just found the one."]],"12":[[37,141,"Thanks for the glass."],[738,834,"What's with that look?"],[855,905,"Do you really think"],[905,1055,"I was just going to pay for your college"],[1055,1134,"while you run off"],[1134,1259,"with some sugar mommy?"],[1259,1397,"I should have thrown all your money"],[1397,1505,"into the pond."],[1526,1597,"Do you have any idea"],[1597,1718,"who you're messing with?"],[1718,1785,"I'm going to make sure"],[1785,1989,"you crawl back to that dirty little town."],[2022,2156,"She's just a town girl?"],[2156,2289,"No wonder she's so..."],[2310,2385,"rude!"],[2394,2510,"Mr. Andersen"],[2510,2631,"is announcing his wife"],[2660,2748,"to the public."],[2794,2923,"You don't belong here."],[2940,3003,"Bye!"],[3073,3182,"Mr. Andersen?"],[3224,3274,"Yeah!"],[3290,3357,"That's right."],[3357,3511,"So you better get your ass out of here"],[3511,3691,"and stop making a fool of yourself."],[3691,3807,"Maybe you should leave."],[3845,4041,"If you don't leave now,"],[4079,4158,"I can't promise"],[4158,4275,"what's going to happen to you."],[4275,4379,"Why should I leave"],[4379,4542,"when Mr. Andersen invited me?"],[4608,4771,"Is this some kind of joke?"],[4792,5030,"Mr. Andersen's a jewelry tycoon."],[5046,5180,"Who the hell do you think you are?"],[5188,5376,"Get your filthy hands off of me!"],[5826,5980,"You think you can take me on?"],[5980,6047,"Try me."],[6335,6385,"Hey!"],[6468,6535,"Let go of her!"],[6535,6627,"Let go of my wife!"]],"13":[[0,45,"Hey!"],[45,112,"Let go of her!"],[112,204,"Let go of my wife!"],[291,392,"She's your wife?"],[392,462,"What are you doing here?"],[1222,1372,"How did someone this interesting"],[1372,1522,"end up being married to Lucas?"],[1522,1605,"Knowing him,"],[1605,1764,"she's probably just a contract wife there"],[1764,1926,"to secure his CEO position."],[2002,2164,"Who the hell do you think you are"],[2164,2293,"talking to my wife like that?"],[2331,2439,"Mr. Andersen!"],[2439,2552,"This has got to be a joke!"],[2585,2702,"How could a small-town girl"],[2702,2844,"like this be your wife?"],[2844,2932,"You think I'd joke around"],[2932,3011,"with someone like you?"],[3040,3244,"So Mr. Andersen did invite her?"],[3307,3478,"Rose was the one insulting your wife."],[3499,3616,"This has nothing to do with us."],[3624,3703,"Sorry."],[3812,3970,"He carries himself with more power"],[3970,4099,"than the mayor back home."],[4195,4262,"She's pathetic!"],[4262,4354,"She was practically"],[4354,4462,"trying to steal my boyfriend"],[4462,4600,"and begging for money!"],[4713,4771,"What?"]],"14":[[0,87,"Seriously?"],[171,321,"You've been chasing me all these years"],[321,454,"and begging me for money"],[454,546,"just yesterday,"],[546,675,"and you've already found a new guy"],[675,763,"to latch onto?"],[892,980,"She has history"],[980,1105,"with Rose's boyfriend."],[1105,1163,"Enough!"],[1201,1338,"You two have a lot of nerve"],[1338,1451,"talking to my wife like that"],[1451,1514,"in front of me."],[1580,1685,"Say one more word,"],[1735,1801,"and you'll regret it"],[1801,1910,"for the rest of your life."],[2414,2531,"The most important"],[2531,2673,"announcement tonight"],[2673,2869,"is the marriage of Lucas,"],[2894,3157,"heir to the Andersen family."],[3157,3219,"Damn it!"],[3253,3386,"Why does she get all the luck?"],[3386,3457,"She couldn't even"],[3457,3603,"pay her mom's medical bills."],[3603,3703,"It is my honor"],[3732,3820,"to introduce"],[3820,4029,"my grandson's new wife, Emily."],[4225,4433,"And as part of the Andersen family,"],[4433,4729,"she will receive 5% of our holdings."],[5130,5196,"What?"],[5201,5330,"She's got to be using Mr. Andersen"],[5330,5388,"for money."],[6060,6222,"Their marriage is fake!"]],"15":[[29,187,"What did you say?"],[308,362,"Sir,"],[400,525,"I said..."],[525,638,"their marriage"],[638,746,"is fake!"],[800,975,"She just got here yesterday!"],[975,1017,"They couldn't have"],[1017,1134,"gotten married overnight."],[1197,1380,"It doesn't make any sense!"],[1397,1476,"And..."],[1493,1659,"her mom is in the hospital."],[1710,1951,"She's clearly desperate for money."],[2018,2131,"Emily's mom is sick?"],[2160,2243,"Is that why she agreed"],[2243,2360,"to this contract marriage?"],[2594,2694,"Lucas..."],[2740,2836,"is that true?"],[2952,3057,"You didn't fake a wedding"],[3057,3236,"just because of what I said..."],[3282,3390,"Did you?"],[3390,3553,"That woman would do anything"],[3553,3703,"to get what she wants."],[3741,3916,"Grandpa can't find out about this."],[3970,4049,"Plus,"],[4066,4183,"I'm starting to have a thing for her."],[4266,4433,"If they find out I'm a surrogate,"],[4433,4608,"I'll never get the money for mom."],[4708,4871,"Grandpa, I know Emily"],[4871,4971,"and I haven't known each other"],[4971,5050,"for very long."],[5238,5376,"But it was love at first sight."],[6602,6673,"She's brave."],[6852,6986,"You're a born actor, Lucas."]],"16":[[175,262,"Yes, Grandpa."],[262,421,"Lucas and I, our marriage is real."],[421,533,"We're having a kid together."],[779,867,"Uh..."],[917,1121,"Grandpa, Emily is very, very blunt."],[1134,1247,"It's, it's not like we're-"],[1247,1418,"All right, all right!"],[1443,1626,"I believe you two!"],[1676,1780,"My dear,"],[1822,1943,"I don't know what you like,"],[1943,2039,"but..."],[2039,2139,"Grandpa's gonna find"],[2139,2260,"a suitable gift for you..."],[2310,2381,"later!"],[2498,2681,"Let's start the banquet."],[2740,2840,"Go on."],[2840,3044,"Enjoy yourselves!"],[3653,3849,"You'll never be a Cinderella."],[3870,4041,"I'll make you pay for this!"],[4225,4379,"Since you two are getting married,"],[4379,4512,"why don't you move back to the mansion?"],[4596,4704,"Just try not to get caught."],[5105,5238,"I need to keep an eye on Noah."]],"17":[[437,513,"Noah's right."],[513,592,"You should move back"],[592,725,"to the mansion with Emily."],[759,825,"But Grandpa..."],[825,950,"But what?"],[975,1088,"It's decided!"],[1088,1205,"End of discussion!"],[1351,1555,"I want to hear some good news"],[1555,1659,"from both of you..."],[1743,1801,"soon."],[2135,2314,"Leaving your new wife here all alone?"],[2369,2439,"Perfect."],[2439,2602,"Let's see what you two really are up to."],[2802,2911,"May I have this dance?"],[3007,3098,"You are?"],[3199,3290,"Plus, plus I,"],[3307,3420,"don't know how to dance."],[3465,3536,"I'm Noah."],[3586,3670,"Lucas's brother."],[3803,3874,"And I'll teach you."],[4099,4216,"After all, he never bothered"],[4216,4358,"to introduce you to his family,"],[4371,4471,"did he?"],[5192,5321,"What the hell is he doing?"],[5563,5647,"I'll take it from here."],[5726,5822,"I believe I was here first,"],[5851,5947,"Lucas."]],"18":[[8,100,"I believe I was here first,"],[120,196,"Lucas."],[216,287,"So what?"],[475,554,"Alright, big bro."],[554,738,"Good luck with this contract marriage."],[792,925,"Let's hope it doesn't get exposed."],[971,1101,"Otherwise I'm going to have to step up,"],[1101,1251,"and take care of the family business."],[1426,1547,"How's everybody doing tonight?"],[1705,1839,"And can we please welcome..."],[1839,1972,"Mr. and Mrs. Andersen"],[1972,2110,"for their first dance."],[3482,3549,"Oh my God!"],[3549,3703,"I'm so sorry, uh,"],[3720,3866,"this is my first time,"],[3866,4004,"in heels, no less..."],[4049,4104,"It's okay."],[4204,4366,"I can assure you that the VIVAIA shoes"],[4366,4525,"are very soft and comfortable."],[4600,4667,"Seriously,"],[4688,4792,"you won't feel any discomfort."],[4821,4904,"You can count on me."],[6147,6210,"You ready?"],[6890,7032,"They look so in love."],[7574,7699,"Oh my God, no!"],[7732,7862,"The shoes!"],[8149,8204,"It's okay."],[9793,9889,"Did you have fun today?"],[10026,10097,"It was perfect."],[10097,10285,"It was like stepping into a dream."],[10314,10381,"You know, you're actually"],[10381,10472,"not Cinderella."],[10852,10956,"You're my princess."],[11106,11182,"And the best part is"],[11182,11294,"all your stuff will still be there"],[11294,11415,"when the clock strikes midnight."],[11966,12162,"If only this weren't just a contract."],[12228,12395,"If only this could be for real."]],"19":[[1021,1071,"Sir."],[1146,1242,"Here's what we found."],[1338,1397,"If these get out,"],[1397,1568,"it will ruin Lucas's reputation."],[1839,1897,"Sir?"],[2039,2072,"You want me"],[2072,2181,"to release these photos?"],[2235,2398,"You can take over the Anderson family"],[2398,2602,"if these get leaked."],[2894,2952,"Sir?"],[3244,3340,"I won't to achieve my goals"],[3340,3445,"by destroying a woman."],[3541,3620,"Get rid of them."],[3670,3737,"All of them."],[3803,3928,"I never want to see them again."],[4162,4304,"I've never seen him like this before."],[4375,4583,"What's so different about this woman?"],[4746,4909,"Who does she think she is?"],[5130,5259,"We'll stay at the mansion today."],[5296,5505,"But I do have to stop by one of the rooms"],[5505,5659,"and grab an extra blanket for you."],[5734,5872,"Don't want the servants to notice."],[6018,6076,"Wanna come?"],[6498,6556,"Maybe you should"],[6556,6673,"hit that dessert table first."],[7015,7132,"Wow, this looks so good."],[7152,7240,"I gotta get a picture."],[7540,7624,"Oh shoot!"]],"20":[[120,325,"You're Lucas's surrogate?"],[554,667,"I knew it! - Wow!"],[925,1059,"How else could"],[1059,1201,"a pathetic nobody"],[1209,1301,"like you"],[1301,1368,"end up being"],[1368,1589,"the wife of a jewelry CEO?"],[1589,1710,"But let's be real."],[1710,1789,"Your kids?"],[1789,1981,"Probably won't amount to much."],[1981,2227,"It was all just a game that we were playing."],[2227,2335,"A game?"],[2335,2460,"You're nothing more than..."],[2494,2644,"a baby-making machine."],[2723,2852,"A woman that"],[2852,3107,"can apparently be bought."],[3161,3228,"They're ri