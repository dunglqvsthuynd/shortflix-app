{"1":[[450,550,"May I have a word?"],[809,900,"Yeah, outside."],[1622,1793,"Without a bone marrow transplant,"],[1860,2173,"your daughter has maybe a year..."],[2173,2306,"If we're lucky"],[2306,2373,"No."],[2373,2510,"You can't give up on her. She's all I have."],[2510,2635,"I'm sorry, Emily."],[2635,2752,"Without payment, we..."],[2752,2927,"we can't keep her on the transplant list..."],[2927,3128,"No, this can't be happening."],[3128,3174,"Please!"],[3174,3265,"Maybe try your"],[3265,3395,"employer's insurance again,"],[3395,3532,"and see if there's a way."],[4658,4817,"Hey, sweetie, How're you doing?"],[4817,4917,"It's always the same."],[5067,5150,"Pain"],[5150,5246,"and misery."],[5321,5359,"Oh!"],[5501,5609,"I was born unlucky."],[5655,5780,"No father"],[5780,5930,"and endless sickness-"],[6147,6256,"Selena, please."],[6443,6669,"I'm nothing but a mistake"],[6669,6790,"and... and a curse."],[6790,6961,"I don‘t deserve to be here. Selena, stop! No!"],[6961,7006,"Selena!"],[7203,7244,"Selena!"],[7403,7449,"Selena!"],[7836,7882,"Selena!"],[8070,8128,"Are you okay?"],[8179,8287,"Watch where you're going!"],[8408,8541,"Mom, you're bleeding."],[8541,8675,"I couldn't watch another car"],[8675,8767,"take someone I love."],[8767,8867,"Not like before..."],[8938,8996,"Before,"],[8996,9088,"what do you mean?"]],"2":[[62,162,"Before?"],[162,283,"What... what do you mean?"],[1601,1705,"Mark, babe,"],[1705,1751,"hurry!"],[1751,1914,"I have the most exciting news."],[1914,2052,"Oh, perfect timing-"],[2077,2206,"I'm right around the corner."],[2248,2444,"Yeah, you're gonna love what I got you."],[2615,2648,"Mark?"],[2948,2998,"Mark?!"],[3549,3611,"Please, my boyfriend-"],[3611,3712,"I was just on the phone with him."],[3712,3858,"White shirt? Good-looking guy?"],[3858,3924,"Yea."],[3924,4170,"They just rushed him to the hospital."],[4170,4291,"It didn't look good."],[5392,5543,"What happened to him?"],[5543,5739,"He, um..."],[5739,5864,"He vanished."],[5864,6014,"No body,"],[6014,6151,"no goodbye,"],[6151,6277,"just..."],[6277,6356,"gone."],[6448,6631,"Get the Bayread Plaza deal done by four."],[6631,6731,"No delays."],[6781,6865,"I'll take care of it."]],"3":[[95,196,"No delays."],[250,350,"I'll take care of it."],[713,813,"Are you blind?"],[813,892,"You almost just"],[892,1105,"ran straight into the CEO."],[1105,1297,"Toilets need some TLC!"],[1472,1526,"Chop, chop."],[2385,2615,"Can you believe that bitch Emily"],[2615,2873,"almost ran into the CEO?"],[2873,2965,"Oh,"],[2965,3078,"it gets better."],[3078,3265,"I just got her request"],[3265,3420,"for company insurance."],[3420,3632,"Huge medical bill."],[3632,3766,"I think it's time we remind her"],[3766,3903,"how things work around here."],[4329,4391,"Who's there?"],[4950,5088,"Well, well."],[5543,5655,"Speak of the devil."],[6247,6389,"What the hell is wrong with you?"],[6552,6844,"Watch your mouth, you sneaky bitch-"],[6844,7082,"spying on private conversations."],[7082,7211,"And yet you think you can just"],[7211,7440,"sneak onto the company insurance"],[7440,7565,"behaving like this?"],[7565,7707,"My daughter, she's sick."],[7707,7816,"Oh,"],[7816,7916,"how tragic."],[7995,8191,"Give us a moment, will you?"],[8416,8633,"You see, Emily..."],[8633,8796,"if I take a risk,"],[8796,8925,"helping out your daughter,"],[8946,9017,"Ahh!"],[9100,9250,"I need something"],[9250,9380,"in return."],[9380,9538,"And since you had the nerve to"],[9538,9818,"eavesdrop on our private conversation..."],[9818,9972,"I need..."],[9972,10105,"insurance"],[10105,10347,"that you'll keep your mouth shut."],[10347,10460,"The money barely covers"],[10460,10564,"her treatment as it is."],[10735,10915,"To make sure there's no"],[10915,11106,"\"misunderstanding\" later."],[11248,11302,"Strip."],[11419,11528,"You're insane..."],[11528,11636,"Darling,"],[11636,11778,"you'll catch a cold"],[11778,11970,"staying wet like this."],[11970,12078,"So,"],[12078,12241,"what will it be?"],[12241,12408,"Your daughter's insurance..."],[12408,12620,"or your dignity?"]],"4":[[379,508,"No, I won't do it."],[508,642,"Then kiss your daughter's"],[642,759,"future goodbye."],[779,925,"One phone call"],[925,1021,"and I will have you"],[1021,1230,"scrubbing toilets in Jersey."],[1334,1409,"How long do you"],[1409,1539,"think your daughter has left?"],[2268,2373,"Keep going."],[2640,2786,"Keep going-"],[3165,3311,"What the hell is going on here?"],[3311,3415,"Oh!"],[3415,3528,"Um..."],[3528,3611,"Mr. Cardmon!"],[3611,3753,"Thank God you're here."],[3753,3878,"I..."],[3878,4003,"Mr. Cardmon?"],[4003,4141,"Mark Cardmon,"],[4141,4279,"our CEO."],[4279,4350,"Mark Cardmon?"],[4433,4571,"He shares the same name"],[4571,4713,"with my ex-boyfriend,"],[4713,4950,"but he looks nothing like him."],[4988,5125,"Have we met before?"],[5125,5330,"No, sir, I don't think so."],[5330,5455,"Strange,"],[5455,5563,"something about you..."],[5563,5801,"Sir, this janitor was just caught"],[5801,6056,"prostituting herself on company grounds..."],[6056,6185,"She was sending nudes"],[6185,6310,"to the security guards."],[6327,6443,"No, that's a lie!"],[6443,6531,"She was threatening me"],[6531,6606,"and recording me-"]],"5":[[0,171,"Tyler, take Ms. Jones to HR"],[171,337,"for a full investigation now."],[383,571,"You'll be lucky if all you lose is your job."],[600,692,"God."],[855,1076,"I swear I know you from somewhere."],[1167,1322,"I don't think so, sir-"],[1322,1430,"Please,"],[1430,1518,"call me Mark."],[3732,3853,"Let me help."],[3870,3937,"I can manage."],[3937,3974,"No,"],[3974,4074,"please."],[4074,4145,"Let me."],[4587,4642,"That..."],[4683,4738,"That's..."],[4738,4850,"Championship trophy."],[4904,4988,"Class of '05."],[5059,5192,"Only time the college team won."],[5251,5347,"Someone I used to know"],[5347,5509,"had the exact same one."],[5509,5576,"Better?"],[5772,5897,"This person with a trophy...."],[5943,6018,"What was his name?"],[6126,6177,"Mark."]],"6":[[95,145,"He, um..."],[145,237,"Sir,"],[237,325,"the board's waiting."],[371,437,"Thanks, Tyler."],[525,642,"I'll have HR"],[642,771,"fast-track hearing insurance."],[771,846,"Thank you."],[846,980,"That really means a lot."],[1013,1096,"Consider it done."],[1401,1634,"Tyler, find me everything on Emily Adams."],[1634,1735,"Employment history,"],[1735,1864,"background,"],[1864,1968,"everything."],[1968,2081,"You got it, boss!"],[2515,2673,"$20,000 for the"],[2673,2873,"pre-transplant meds..."],[2873,2965,"I can..."],[2965,3069,"I can handle it."],[3069,3224,"I have to."],[4216,4358,"Application denied,"],[4358,4542,"Ms. Adams."],[4542,4600,"Please-"],[4600,4692,"No assets."],[4692,4750,"My daughter-"],[4750,4904,"No collateral."],[4904,5071,"Income..."],[5071,5305,"barely above minimum wage..."],[5305,5530,"The math just..."],[5530,5693,"doesn't work."],[5693,5730,"Please."],[5730,5947,"I'll take any interest rate. I'll..."],[5947,6076,"I'll work three jobs."],[6076,6143,"I'll do..."],[6143,6189,"I'll do anything."],[6189,6239,"Well..."],[6239,6468,"There's always the old-fashioned way."],[6514,6731,"Find yourself a rich old man"],[6731,6944,"with one foot in the grave."],[7119,7269,"Works like a charm!"]],"7":[[892,1009,"Jesus, Emily!"],[1076,1176,"What are you thinking?"],[1176,1259,"I'm fine."],[1317,1359,"Ouch!"],[1359,1534,"You're not fine."],[1534,1659,"Let me drive you home."],[1659,1776,"No, that's not necessary."],[1776,1939,"It's what any decent employer would do."],[1939,2018,"I have to get to the hospital."],[2018,2064,"My daughter-"],[2064,2173,"Then I'll drive you there."],[3211,3274,"Hey,"],[3274,3382,"either I help you walk"],[3382,3461,"or I carry you."],[3461,3566,"You don't have to-"],[3566,3720,"Walking a distance."],[4496,4658,"Are you my dad?"],[4942,5171,"You're Mark, aren't you?"],[5171,5338,"The one that mom lost..."],[5434,5555,"I thought maybe..."],[5555,5776,"Yes, I'm Mark."]],"8":[[0,108,"How did you know my name?"],[183,371,"Sweetheart,"],[371,521,"this is Mr. Cardmon."],[521,588,"My boss."],[671,779,"It's a different Mark."],[1201,1288,"Stand back, please."],[1409,1459,"Just calm down."],[1459,1543,"Just calm down."],[1543,1626,"She's crashing."],[1626,1772,"Get her to the OR. Now!"],[1835,1914,"What's happening?"],[2298,2427,"I need to ask..."],[2427,2640,"Where are we stand on the pre-transplant?"],[2640,2802,"She hasn't signed off on it yet."],[2961,3128,"She's stable for now."],[3128,3228,"We have to hurry."],[3265,3403,"Doesn't have much time."],[3403,3461,"Okay."],[3691,3787,"Why do you need a loan?"],[3908,4079,"Company insurance should cover this."],[4079,4245,"I'm just a janitor, Mr. CEO."],[4300,4433,"Basic coverage only pays"],[4433,4608,"for hospital stays, and..."],[4608,4804,"the prep meds alone are $20,000."],[4863,4959,"And the transplant..."],[4959,5059,"Well..."],[5059,5217,"No bank will touch me."],[5217,5326,"Just a single mum,"],[5326,5513,"and I earn minimum wage, and..."],[5513,5609,"I have no collateral."],[5609,5714,"This is on me."],[5714,5776,"My company."],[5893,5989,"Let me make it right."],[6026,6060,"How?"],[6297,6348,"Marry me."]],"9":[[0,75,"No..."],[75,212,"You've already done too much."],[266,392,"Look at your daughter."],[392,546,"Let me help, please."],[546,734,"She already thinks I'm her dad."],[734,938,"And why we play along, you know,"],[938,1038,"for her sake."],[1038,1201,"A little fiction to give her hope."],[1814,1901,"Selena..."],[1901,2093,"I need to tell you something."],[2093,2252,"I am your father."],[2252,2314,"I knew it."],[2348,2502,"I knew I was right!"],[2502,2640,"Your mum and I..."],[2640,2857,"we lost each other years ago."],[2857,3019,"But I'm here now."],[3019,3078,"And I want to make up for"],[3078,3215,"every second I missed."],[3449,3511,"Thank you."],[4542,4637,"Congratulations."],[4704,4821,"Finally, married a Mark..."],[4992,5071,"\"Married a Mark?\""],[5071,5171,"What am I, someone double?"],[5171,5351,"No, sorry..."],[5351,5480,"My boyfriend from college"],[5480,5605,"had the exact same name,"],[5605,5689,"but he disappeared"],[5689,5818,"after a car accident."],[5818,5897,"Car accident?"],[5897,6060,"Yea, we never found him."],[6060,6164,"Strange."],[6164,6368,"I had a serious accident in college, too."],[6368,6535,"The accident took everything."],[6560,6685,"My memories,"],[6685,6769,"even my face."]],"10":[[0,166,"The accident took everything."],[191,354,"My memories, even my face."],[354,462,"Oh my God!"],[462,563,"I'm so sorry!"],[563,621,"It's fine."],[621,725,"I'm just gonna go clean up"],[725,821,"in the restroom."],[2610,2781,"Still watching over you..."],[3370,3528,"Once the insurance kicks in..."],[3528,3670,"we can end this."],[3670,3916,"No strings, no demands."],[3970,4074,"Right."],[4325,4437,"Oh, it's Anna."],[4437,4579,"I gotta get back to work."],[4621,4754,"Can you just drop me around the corner?"],[4754,4829,"I don't want anyone"],[4829,4967,"to get the moment, either."],[5221,5292,"Thanks."]],"11":[[663,742,"Looks like there should be"],[742,892,"a photo in here..."],[1655,1876,"Didn't expect to see me here, huh?"],[1876,2106,"What the hell were you doing in Mark's car?"],[2106,2277,"You fucking whore!"],[2277,2423,"Mark's got a fiancée."],[2423,2573,"If you want to spread your legs,"],[2573,2681,"during your lunch break,"],[2681,2802,"do it somewhere else!"],[2802,2957,"He's just driving me to the hospital."],[2957,3073,"What fiancée?"],[3073,3224,"Don't act stupid."],[3224,3324,"It's annoying."],[3324,3407,"Now come with me."],[3407,3603,"What are you doing? Let me go!"],[4295,4441,"Relax, sweetheart."],[4441,4604,"We're just gonna teach you a lesson."]],"12":[[41,196,"Stay away from me..."],[196,329,"Where are you trying to go?"],[329,408,"Relax."],[408,525,"We're just gonna have some fun."],[1514,1614,"Help!"],[1614,1710,"Somebody, help!"],[1710,1830,"You think that you can just"],[1830,2022,"walk into our world?"],[2022,2223,"Getting rides from the CEO?"],[2248,2423,"Well, where is he now?"],[2423,2606,"Hmm, I wonder..."],[2606,2765,"Will he still look at you"],[2765,3036,"when you're not so pretty anymore?"],[3036,3123,"Anna,"],[3123,3199,"please don't do this."],[3199,3303,"Begging now?"],[3303,3470,"Not so feisty anymore."]],"13":[[713,880,"Turn this shit off!"],[880,971,"Who the fuck..."],[1530,1634,"Boss,"],[1634,1755,"I... I didn't see you there."],[1755,1814,"Touch her again,"],[1814,1960,"and I will cut your head off."],[1960,2031,"It was Emily..."],[2031,2164,"She wanted money."],[2164,2206,"I..."],[2268,2364,"My wife doesn't need a"],[2364,2477,"damn thing from you."],[2535,2652,"Emily's your wife?"],[2723,2765,"How?"],[2765,2819,"Fire her."],[2819,2902,"And press charges."],[3015,3165,"I didn't do anything!"],[3165,3282,"I swear!"],[3282,3457,"Emily, say something!"],[3457,3645,"No one touches my wife."]],"14":[[1626,1689,"Where are we?"],[1722,1793,"My place..."],[1830,1985,"Why didn't you ask me for help?"],[1985,2077,"We're gonna end this"],[2077,2239,"sooner or later, Mark."],[2239,2356,"No reason to tell the whole world"],[2356,2502,"about our marriage."],[2573,2648,"Couldn't agree more."],[2752,2815,"Drink?"],[2886,2965,"No, thanks."],[3061,3186,"Mark's photo?"],[3345,3474,"Which one is you?"],[3474,3570,"Oh."],[3991,4029,"Sorry."],[4642,4829,"What the hell is going on here?!"],[4829,4984,"Are you trying to shame me"],[4984,5146,"by bringing another woman into our house?"]],"15":[[0,108,"Oh, I can explain it."],[108,166,"You!"],[166,229,"Shut up!"],[229,404,"What the hell is your problem, Eve?"],[404,504,"You know what our relationship"],[504,600,"really is."],[638,771,"And is this your way of what,"],[771,925,"getting back at me?"],[925,1084,"I am still your fiancée!"],[1176,1263,"Your fiancée?"],[1263,1388,"What is she talking about?"],[1388,1526,"You're wrong, Eve."],[1526,1634,"She's just my employee."],[1634,1701,"She was injured."],[1701,1876,"I was helping her with her wounds."],[1876,2043,"How could he say that?"],[2043,2223,"Was everything..."],[2223,2306,"a lie?"],[2448,2527,"Yeah, I got into"],[2527,2606,"some kind of trouble"],[2606,2694,"and Mr. Carmen was"],[2694,2806,"just helping me out."],[2844,2877,"No."],[2973,3090,"I knew you wouldn't choose someone"],[3090,3211,"like her over me."],[3382,3478,"I'll do whatever you want."],[3478,3657,"Just don't be mad at me, Mark."],[3657,3878,"Enough, Eve. We're not alone."],[4037,4154,"What are you still doing here?"],[4154,4200,"Get out!"],[4200,4320,"Yes, sir."],[4320,4471,"Let my assistant drive you home."],[4471,4512,"Uh..."],[4512,4567,"I'm fine."],[4567,4604,"Thank you."],[4988,5130,"Marry me, Mark."]],"16":[[171,312,"Did you not hear what I said?"],[312,458,"I said I want you to marry me-"],[458,613,"We've always just been business."],[671,800,"When the deal's done,"],[800,905,"I'm calling off the wedding."],[1192,1334,"Oh, that bitch!"],[1334,1609,"She is not stealing my fiancé."],[2552,2777,"Oh... Did I lose the locket?"],[2806,2869,"Shit."],[2869,3028,"The one thing that I"],[3028,3157,"that reminded me of you, Mark."],[3319,3453,"I can't believe I lost it."],[3916,4045,"I screwed up, I'm sorry."],[4112,4245,"Please, let me explain."]],"17":[[41,196,"The thing with Eve..."],[196,383,"It's complicated."],[383,538,"That's why I can't go public with..."],[538,633,"our marriage."],[688,804,"Got it. We're..."],[804,942,"just a contract."],[942,1017,"Nothing more"],[1017,1213,"and I won't make it a thing."],[1343,1514,"You left this in my car."],[1626,1814,"Oh my God. Thank you."],[1814,2031,"Should be a photo inside..."],[2031,2173,"You and someone else?"],[2173,2289,"Yeah,"],[2289,2456,"someone long gone."],[2515,2635,"Selena’s getting worse."],[2635,2756,"We need to act fast."],[3144,3315,"She needs a transplant,"],[3315,3457,"but there's no match."],[3528,3716,"Emily's marrow doesn't work."],[3753,3891,"I can donate."],[3974,4079,"Odds are slim-"],[4079,4187,"even with family."],[4187,4295,"Not to mention you are..."],[4295,4446,"I'm her father."],[4446,4