,[1851,2031,"or I'm gonna make you wish you"],[2031,2147,"were dead."],[2264,2444,"Dad, hurry up and tell her."],[2444,2473,"Okay."],[2473,2560,"I don't want to die."],[2560,2623,"I'll tell you."],[2652,2723,"But you have to promise"],[2723,2844,"not to hurt Hailey or I."],[2911,2994,"Isaac Beaumont,"],[3028,3161,"do you really think that you're"],[3161,3370,"in a position to negotiate?"],[3774,3862,"Ms. Beaumont,"],[3870,3970,"your mother's taken a turn"],[3970,4041,"for the worse."],[4041,4175,"You need to come in now."]],"58":[[212,275,"Fine."],[358,442,"I agree."],[487,654,"But you better be telling me the truth"],[654,834,"or I will have your head."],[871,967,"I will, I will."],[967,1126,"Just don't hurt us."],[1138,1247,"And let us stay in the house."],[1338,1413,"Deal."],[1526,1584,"Adrian,"],[1614,1747,"come with me to the hospital."],[1755,1818,"Find someone"],[1818,1964,"to keep and eye on Isaac."],[2252,2356,"Do you want to take them down?"],[2385,2556,"Uh, of course I do, Dad."],[2577,2623,"But how?"],[2656,2852,"She's got us under lock and key."],[2907,2990,"I have a plan."],[3086,3161,"They're watching me,"],[3161,3307,"but they're not watching you."],[3345,3528,"First, follow them."],[3549,3628,"And then..."],[3945,4087,"Good plan, dad."],[4200,4308,"She's going down."]],"59":[[930,1009,"Mom!"],[1034,1117,"Mom, what's wrong?"],[1117,1172,"What's wrong?"],[1409,1551,"Did you take my babies?"],[1605,1701,"I deserved it."],[1701,1856,"I shouldn't have been so jealous."],[1897,2002,"I'll do anything."],[2002,2093,"I'll kneel down."],[2173,2285,"Please don't do this."],[3044,3123,"It's okay."],[4329,4425,"Ms. Beaumont."],[4479,4646,"Your mother's experiencing acute"],[4646,4842,"stress from prolonged trauma."],[4904,5021,"The only way to help her"],[5030,5213,"is to find her children."],[5309,5363,"Hey,"],[5409,5505,"don't worry, Blair."],[5555,5672,"I sent some people to the address"],[5672,5759,"Isaac gave us."],[5780,5889,"We'll hear good news soon."],[