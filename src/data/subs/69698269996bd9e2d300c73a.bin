"I'll go turn myself in."],[3044,3161,"I'll go right now!"],[3657,3824,"What are you still doing here?"],[3937,4112,"Blair, please, I can't go to jail."]],"44":[[37,133,"Are you trying to bargain?"],[183,367,"Do I look like I'm in the mood?"],[467,571,"I have something you might be"],[571,646,"interested in."],[742,892,"I know where your real brothers are."],[1088,1167,"What?"],[1484,1576,"When your mother and Jessica"],[1576,1693,"gave birth to the triplets,"],[1755,1893,"I sent them to the orphanage"],[1893,1972,"and kept tabs"],[1972,2077,"on them the whole time."],[2110,2214,"I'm the only person"],[2214,2381,"on earth that knows where they are."],[2406,2489,"Isaac Beaumont,"],[2489,2665,"don't you dare threaten me!"],[2694,2752,"Go ahead."],[2802,2857,"Kill me."],[2907,3048,"But you'll never find your brothers,"],[3078,3228,"and your mother will stay in the asylum."],[3240,3378,"Is that really what you want?"],[3636,3695,"Fine."],[3737,3787,"Speak."],[3787,3845,"Tell me."],[3862,3974,"Tell me what you want."],[4124,4266,"Let me stay at the Beaumont mansion."],[4746,4833,"Fine."],[4892,4975,"You can stay."],[5180,5271,"You'll find them here."]],"45":[[387,533,"Now get out of my sight!"],[1263,1376,"Why'd you let him off so easy?"],[1459,1664,"I know his words are full of lies,"],[1664,1843,"but for my mother's sake,"],[1843,1989,"I gotta let him stay."],[2373,2477,"Hey, Adrian."],[2569,2673,"I just want to thank you"],[2681,2831,"for helping me manage Sandrix"],[2831,3011,"Industries for the past three years."],[3053,3161,"You've been a huge help."],[3203,3311,"Anything for you, Ms. Blair."],[3528,3741,"You don't have to call me Ms. Blair,"],[3778,3816,"okay?"],[3816,3962,"You don't have to be so formal."],[3962,4049,"When it's just us,"],[4049,4191,"you can drop the Ms."],[4312,4341,"You know,"],[4341,4446,"ever since the day you saved me,"],[4521,4679,"I swore I'd protect you,"],[4733,4859,"follow you to the ends of the earth."],[6001,6106,"Are you hungry?"]],"46":[[233,387,"Back then, when I asked for your name,"],[496,604,"you told me to call you Ms. Blair."],[834,955,"Force of habit, I guess."],[959,1042,"Oh my god,"],[1042,1176,"I can't believe you still remember that."],[1213,1288,"Even I don't."],[1376,1463,"Adrian."],[1463,1564,"You seem to remember"],[1564,1701,"all my words so clearly."],[1860,2039,"Do you like me or something?"],[2402,2452,"Well,"],[2556,2610,"actually..."],[2702,2790,"I'm just messing with you."],[2790,3003,"I know that the only reason"],[3003,3094,"you've stayed by my side"],[3094,3232,"this long helping me manage"],[3232,3453,"Sandrix Enterprises,"],[3520,3699,"is because you're really"],[3699,3803,"into my secretary."],[4033,4083,"Huh?"],[4083,4137,"Yeah."],[4162,4283,"If you like her that much,"],[4283,4425,"let me be your wingwoman."],[4429,4612,"I can save you the trouble of stumbling"],[4612,4825,"over yourself too afraid to confess."],[5280,5543,"Wait, you got it all wrong, Blair, it's..."],[5543,5597,"Anyways,"],[5609,5755,"here is the address"],[5755,5860,"I want you to look into."],[5968,6035,"Report back to me"],[6035,6114,"when you have a lead."],[6402,6456,"Okay."],[7094,7165,"Wait."],[7215,7298,"Isn't this the orphanage"],[7298,7382,"I grew up in?"]],"47":[[392,500,"My babies."],[558,654,"My babies."],[738,913,"Where did my babies go?"],[913,1096,"I can't find my babies."],[1217,1384,"Give them back to me."],[1451,1639,"Dr. Monica, what is wrong with my mom?"],[1701,1780,"Your mom went through"],[1780,1931,"an extreme shock."],[1939,2122,"She's very unstable right now."],[2122,2252,"If you want her to recover,"],[2285,2456,"you need to find her sons."],[2527,2573,"I see."],[2686,2731,"Thank you."],[3332,3432,"No!"],[3545,3670,"Get away from me."],[3716,3870,"You stole my babies."],[3903,3991,"Give them back."],[4024,4120,"Give them back."],[4120,4229,"-Give them back. -No, mom."],[4229,4300,"Mom, okay?"],[4300,4362,"It's me."],[4391,4421,"It's me."],[4421,4517,"It's Blair. Okay?"],[4517,4617,"It's your daughter, Blair."],[4617,4713,"You can look at me, mom."],[4713,4771,"It's okay."],[4808,4913,"No! No!"],[4913,5013,"You're not my daughter."],[5013,5209,"You're an evil woman. Leave!"],[5242,5296,"Leave."],[5326,5430,"I said, Leave!"],[5476,5576,"Leave! Leave!"],[5768,5834,"Mom."],[6343,6406,"Mom."],[6493,6539,"Mom, I..."],[6619,6719,"Mom, I promise you."],[6806,6944,"I will find my brothers and"],[6986,7140,"and we'll all be reunited again."],[7494,7636,"I have to find my babies."],[7728,7895,"I have to find my babies."],[7924,8078,"I have to find my babies."]],"48":[[1509,1572,"Ms. Blair,"],[1772,1847,"how's your mom?"],[2035,2223,"Um, well,"],[2223,2414,"before she was a little confused,"],[2419,2435,"but"],[2585,2665,"after the huge shock,"],[2665,2798,"she got a lot worse."],[2923,2961,"Don't worry."],[3019,3090,"I've already contacted"],[3090,3228,"the world's best psychiatrists."],[3345,3461,"They're gonna help her recover."],[3628,3753,"That's not gonna do anything."],[3828,3999,"There isn't a doctor that can fill"],[4024,4070,"this void."],[4070,4220,"She needs to get her sons back."],[4258,4346,"That is the only way"],[4375,4500,"that we are gonna get her back."],[4888,4954,"What happened?"],[4988,5146,"Um, Mom."],[5251,5313,"Mom..."],[5313,5447,"Mom just got a little frustrated."],[5501,5588,"I'm fine."],[5647,5705,"I'm fine."],[5776,5826,"You're bleeding."],[5930,6001,"It's not fine."]],"49":[[187,237,"Ow."],[342,387,"Sorry."],[513,617,"I thought you said it was fine."],[713,788,"It was fine."],[821,963,"And then you started touching it,"],[963,1096,"so it started to hurt."],[1234,1351,"Still as stubborn as ever."],[1985,2093,"Adrian...Um..."],[2202,2356,"You're pretty handsome"],[2385,2523,"when you're serious like this."],[2786,2886,"Stop teasing me."],[2927,2973,"What?"],[3007,3157,"I'm just calling it how it is."],[3282,3370,"You look pretty good."],[3470,3578,"Exactly my type."],[3636,3695,"But..."],[3837,3920,"You like someone,"],[3920,4245,"so I'm not gonna push you."],[4391,4512,"I wouldn't mind if you did."],[4708,4808,"What was that?"],[4875,4942,"Nothing."],[5125,5180,"I'm done."],[5305,5372,"I..."],[5530,5697,"I have some business to do,"],[5697,5855,"so could you stay back"],[5855,5951,"and watch mom?"],[5951,6010,"Yeah."],[6881,6948,"Ms. Blair,"],[7073,7265,"I'm gonna tell you how I really feel."]],"50":[[116,166,"Yeah."],[212,271,"Okay."],[342,412,"Understood."],[809,975,"You missed a spot, Hailey."],[1030,1105,"Have you never cleaned"],[1105,1188,"a floor before?"],[1359,1488,"I'm sorry, Ms. Blair."],[1564,1685,"I've never done this before,"],[1685,1810,"so I don't know how to do it."],[1843,1989,"Never done it before?"],[2056,2114,"Then learn."],[2202,2268,"If you don't"],[2281,2344,"figure it out,"],[2344,2464,"then it's straight to the slammer"],[2464,2519,"for you."],[2598,2673,"You'd have plenty of time"],[2673,2773,"to figure it out in there."],[2844,2890,"Hmm."],[2969,3078,"Yes, Ms. Blair."],[3182,3261,"I'll learn well."],[3382,3415,"Cool."],[4054,4183,"Being a maid clearly"],[4187,4316,"isn't punishment enough."],[4396,4471,"You still have energy"],[4471,4604,"for these petty games."],[4646,4758,"No, Ms. Blair."],[4796,4846,"I'd never."],[4917,4984,"I just"],[5146,5217,"slipped."],[5376,5509,"Don't think that I don't know"],[5509,5680,"exactly what you're doing."],[5747,5843,"If there is a next time,"],[5893,6039,"you can reunite with your mom."],[6122,6181,"In prison."],[6581,6673,"Blair Beaumont,"],[6815,6981,"how dare you humiliate me?"],[7194,7286,"I'm gonna make sure you"],[7286,7469,"suffer 100 times over."]],"51":[[2077,2252,"Once the world finds out about the"],[2252,2469,"Beaumonts' dirty little secret,"],[2581,2761,"Dad and I will rise to the top again!"],[3274,3370,"Let's see you try and"],[3370,3524,"get out of this one, bitch!"],[3991,4045,"Ms. Blair,"],[4154,4233,"Ms. Blair,"],[4362,4416,"I'm here."],[4533,4617,"I got your message."],[4729,4813,"Why'd y