n't try to flatter yourself."],[4346,4579,"Aw, your secret lover's upset."],[4592,4725,"Don't you want to chase after her?"],[4875,4954,"Who needs a secret"],[4954,5059,"lover when I have you?"]],"62":[[70,204,"Blair, we found them."],[650,717,"What happened?"],[729,792,"We had a private"],[792,905,"investigator look into it."],[975,1021,"And guess what?"],[1059,1155,"Turns out they've been working"],[1155,1297,"for us this entire time."],[1297,1384,"We just didn't know it."],[1434,1522,"Oh my god."],[1584,1634,"Wait,"],[1634,1793,"so you're saying that..."],[1830,2014,"that my brothers are working"],[2014,2143,"for Beaumont Enterprises"],[2143,2214,"right now?"],[2239,2298,"Yes."],[2377,2448,"And they were adopted"],[2448,2544,"by a loving family."],[2615,2660,"We're just waiting"],[2660,2811,"on the DNA test results to confirm."],[2932,3032,"Isn't this wonderful?"],[3128,3169,"I mean,"],[3169,3257,"you're finally going to get"],[3257,3386,"to grant your mother's wish."],[3386,3474,"Yes."],[3570,3641,"Wait, uh,"],[3682,3949,"DNA testing takes about a week, right?"],[3983,4129,"The board meeting is next week."],[4166,4237,"Board meeting?"],[4366,4479,"Wait, you mean?"],[4479,4562,"Precisely."],[4650,4713,"At the board meeting,"],[4729,4808,"I'm going to announce"],[4808,4954,"that I found my brothers."],[4954,5067,"And I'm going to make them heirs."],[5196,5338,"I want to split the family"],[5338,5434,"assets equally."],[5472,5668,"Splitting the assets with them?"],[5709,5793,"I should be the head"],[5793,5918,"of the Beaumont family!"],[5947,6085,"All that money and power"],[6085,6210,"should be mine!"],[6231,6464,"I've been humiliated more than 20 years."],[6564,6702,"I'm not going away that easy."],[6835,7015,"I'm going to take back what's mine."],[7494,7561,"It's me."]],"63":[[221,304,"Blair?"],[325,400,"Blair!"],[400,546,"I...I mean, Ms. Beaumont,"],[546,688,"please have some mercy on me."],[688,813,"I know we're not technically"],[813,867,"siblings,"],[867,955,"whatever that means,"],[955,1067,"but we grew up together."],[1067,1247,"Can you please have some mercy on me?"],[1267,1343,"Derek?"],[1351,1484,"I thought you turned yourself in."],[1514,1559,"I did,"],[1559,1689,"but they let me go because of"],[1743,1847,"such good behavior."],[1851,1956,"But now I have nothing,"],[1956,2143,"nothing to my name, no trust to fall on."],[2177,2302,"I was in a weird place then."],[2302,2481,"Please, please help."],[2927,2998,"Help you?"],[3023,3169,"When you were humiliating my mom,"],[3169,3236,"did you ever think"],[3236,3357,"about helping her out?"],[3382,3411,"You know,"],[3411,3524,"we went way too easy"],[3524,3595,"on you by just kicking"],[3595,3691,"you out of the house."],[3757,3795,"And now,"],[3841,3920,"you have the nerve to come"],[3920,4041,"back here and try to just..."],[4091,4191,"push Ms. Blair?"],[4308,4375,"Blair!"],[4579,4629,"Actually,"],[4654,4783,"instead of begging me for mercy,"],[4783,4863,"why don't you ask"],[4863,4963,"your precious father?"],[5000,5130,"Dad, please help me!"],[5150,5313,"Get off me, you disgusting rat!"],[5330,5426,"I'm not helping you."],[5509,5643,"I'm trying to save my own ass."],[6018,6302,"Isaac, you'll reap what you sow."]],"64":[[175,241,"Mom,"],[342,517,"I already found my brothers."],[575,638,"We're just waiting"],[638,775,"to confirm the DNA test,"],[775,988,"but then I'll introduce you."],[1142,1272,"Just wait for me, Mom."],[1334,1564,"Okay, we'll all be reunited again soon."],[1634,1722,"I don't know when."],[2373,2456,"Hey."],[2506,2594,"Don't sigh, Blair."],[2640,2781,"Test results are gonna be back soon."],[2890,2936,"Then you can"],[2936,3011,"introduce your brothers"],[3011,3082,"to your mom and..."],[3215,3340,"you guys can all start over."],[3782,3941,"According to the DNA report,"],[3945,4062,"I can confirm that"],[4062,4300,"I've found my three biological brothers."]],"65":[[0,241,"I've found my three biological brothers."],[404,521,"Well, congratulations,"],[