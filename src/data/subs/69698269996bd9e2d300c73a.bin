y think that you're men?"],[1743,1797,"Mr. Beaumont."],[2035,2068,"Here."],[2102,2218,"The real family crest."],[2314,2531,"Now everyone can see that I,"],[2585,2681,"Isaac Beaumont,"],[2681,2748,"am the true"],[2748,2890,"Beaumont's successor."],[2890,2948,"And you."],[3023,3224,"You were so full of yourself."],[3712,3837,"You even tried to hit me."],[4054,4145,"No!"],[4145,4245,"Don't touch her!"],[4325,4400,"You can get it too."],[4525,4587,"Isaac!"],[4658,4746,"How dare you hit my mom?"],[4746,4838,"I'll kill you!"],[4838,4967,"Stop struggling."],[4988,5109,"You could cry when you're"],[5109,5192,"in the loony bin."],[5226,5492,"Isaac, sweetie, you're the best."],[5555,5613,"Thanks to you,"],[5684,5872,"everything's all cleared up now."],[5872,6076,"You old hag!"],[6076,6268,"I told you not to mess with us."],[6335,6431,"And now you know who you're"],[6431,6539,"really dealing with."],[6589,6756,"You won't get away with this!"],[6936,7073,"Have fun in the asylum!"]],"23":[[4,75,"Mom."],[104,183,"Mom!"],[567,646,"Mom."],[646,688,"No, no."],[688,729,"Mom!"],[754,846,"Don't be scared."],[917,1059,"At St. Paul's Mental Asylum,"],[1059,1188,"you and your mother will be in..."],[1247,1347,"excellent hands."],[2798,2973,"Mom, wake up."],[3107,3265,"I'm so sorry, Blair."],[3311,3503,"I should have made you apologize."],[3545,3737,"Then we wouldn't be in this mess."],[3737,3770,"No, no, no."],[3770,3807,"I should have"],[3807,3924,"protected you better."],[3924,4037,"As soon as I get back"],[4037,4137,"control of the Beaumonts,"],[4137,4275,"I'm going to make them pay for this."],[4350,4379,"Ha!"],[4454,4521,"Once you're locked up,"],[4521,4608,"you'll never leave."],[4696,4859,"Mr. Beaumont says that you'll feel"],[4859,5030,"the electric shocks down to your bones."],[5159,5305,"You'll be begging on your knees."],[5430,5601,"Don't get your hopes up."],[7791,7878,"Let's get you out of here."],[8717,8792,"Mr. Beaumont..."],[8925,8971,"they..."],[9104,9192,"they got away."]],"24":[[41,262,"Oh...No, no, no, I was wrong."],[371,408,"Please,"],[567,675,"please let Blair go."],[1021,1126,"Ms. Beaumont,"],[1230,1309,"your mother is"],[1334,1522,"exhibiting signs of PTSD,"],[1601,1797,"which could be due to prolonged stress"],[1818,1881,"and trauma."],[2022,2189,"She may act confused"],[2189,2339,"and disoriented for a while."],[2560,2644,"Those bastards."],[2798,2890,"I'll make them pay."],[3082,3161,"Okay."],[3224,3261,"Thank you."],[3862,3983,"Grandpa's still in surgery."],[3983,4095,"He can't help yet."],[4229,4337,"I need to move the Beaumont"],[4337,4466,"assets before they get their hands"],[4466,4496,"on them."],[5130,5213,"Oh, those snakes?"],[5313,5384,"Well, they must have planned"],[5384,5451,"this from the start."],[5451,5576,"Everything is gone."],[5822,5910,"Oh, they even emptied"],[5910,6022,"the trust fund."],[6139,6218,"Unbelievable."],[6327,6468,"But this isn't over yet."],[6869,6911,"Ms. Blair."],[7002,7073,"Adrian,"],[7144,7265,"I need you to do something for me."],[7298,7332,"Name it."]],"25":[[62,108,"Blair."],[120,179,"Blair, what?"],[237,400,"Why did you bring me here?"],[400,550,"We need to get away from here."],[617,696,"It was hard enough"],[729,867,"to crawl out of the lines."],[867,1046,"Then why won't we run straight back in?"],[1071,1130,"No, Mom."],[1130,1234,"This is our house."],[1234,1376,"We belong here."],[1376,1488,"Blair, I'm begging you."],[1488,1634,"Let's leave fast."],[1730,1755,"Look,"],[1755,1910,"if they want the Beaumont fortune,"],[1910,1981,"they can have it."],[2052,2189,"We can't go against them."],[2252,2298,"Don't worry-"],[2298,2394,"Blair, we'll die."],[2494,2585,"We'll be fine."],[2677,2723,"Trust me."],[2848,2898,"I got this."],[3311,3386,"Oh, wow..."],[3403,3482,"Cheers."],[3482,3649,"Cheers."],[3737,3816,"Cheers."],[4350,4391,"Well,"],[4521,4671,"after planning for years,"],[4721,4838,"the Beaumont empire"],[4838,4946,"is finally mine."],[5000,5142,"Congratulations, honey."],[5142,5221,"Now,"],[5267,5363,"does this mean I can"],[5363,5497,"buy anything I want now?"],[5497,5626,"Oh, of course."],[5709,5764,"The Beaumonts"],[5764,5955,"will not bow down to anyone."],[5955,6122,"We hold our heads up high."],[6177,6214,"Daddy,"],[6377,6639,"there's a purse I really want,"],[6639,6852,"but it's a million dollars."],[7032,7107,"You really want it?"],[7323,7374,"Buy it."],[7407,7545,"Oh, and Dad,"],[7545,7803,"there's a car I really wanted."],[7803,7962,"Well, hey, I want a penthouse."],[7982,8158,"Dad, I'm not asking for a lot."],[8158,8316,"Just a million dollars every month"],[8316,8379,"for my allowance?"],[8500,8558,"Of course."],[8558,8662,"Yes!"],[8783,8871,"Buy anything you want."],[8942,9067,"Money is no option."],[9129,9271,"You're the best, sweetie."],[9355,9455,"Thank you, Daddy."],[9522,9617,"Thanks, Dad."]],"26":[[0,100,"Thanks, Dad."],[179,221,"Oh, wow."],[266,350,"Young."],[433,496,"Yes, sir."],[496,625,"I'm a man of my word."],[692,800,"I'll introduce you to the board"],[800,930,"of directors very soon."],[930,1034,"You'll be vice president."],[1242,1297,"Thank you."],[1297,1388,"Thank you, Mr. Beaumont."],[1522,1559,"Laney,"],[1693,1772,"you've been the Beaumont"],[1772,1910,"butler for decades."],[1910,1976,"Smart man."],[1997,2131,"You know how to choose sides."],[2156,2206,"This check"],[2335,2398,"is yours."],[2460,2573,"Thank you, Mr. Beaumont,"],[2573,2740,"but I must refuse."],[2786,2831,"Instead,"],[2852,3090,"all I ask is for a quiet retirement."],[3182,3374,"I'm getting older and don't know"],[3374,3453,"how much longer"],[3453,3599,"I can serve the Beaumonts."],[3724,3807,"Retirement."],[3941,3995,"I can do that."],[4074,4245,"But as for the Beaumont affairs..."],[4245,4371,"Don't worry, Mr. Beaumont."],[4408,4550,"I won't tell anyone"],[4550,4667,"about the Beaumont affairs."],[4842,4929,"Mrs. Beaumont has"],[4950,5113,"always been just a good Beaumont."],[5113,5355,"Anyone else is just an impostor."],[5422,5492,"A fake."],[5580,5651,"Good."],[6110,6222,"Very good."],[6231,6289,"Wait."],[6339,6389,"Dad,"],[6389,6523,"didn't that driver say that"],[6523,6719,"Blair and her mom escaped?"],[6719,6794,"I mean, come on."],[6794,6940,"Given Blair's personality,"],[6940,7077,"she and her mom are scheming right now."],[7077,7119,"They're on their way-"],[7119,7194,"What are you afraid of?"],[7328,7469,"The Beaumont assets belong"],[7490,7570,"to us."],[7670,7774,"They can't do anything."],[7774,7932,"And if she comes here, even better."],[8012,8120,"We'll get rid of her for good."],[8120,8204,"Yeah."],[8329,8387,"Dad's right."],[8596,8829,"Isaac Beaumont, come out!"]],"27":[[20,225,"Isaac, did you not hear me?"],[258,446,"I said come out!"],[671,754,"Oh, Blair!"],[859,992,"Wouldn't expect you to show up"],[992,1126,"after you escaped the asylum,"],[1155,1317,"but then you come waltzing up in here?"],[1384,1505,"Don't waste your breath, Dad."],[1593,1710,"Now that she's back,"],[1760,1914,"we'll send her out in a coffin."],[1914,1993,"Come on, Dad."],[1993,2131,"She's clearly begging to die,"],[2131,2335,"so why not oblige her?"],[2335,2414,"I came back."],[2414,2577,"to get payback for my mom."],[2669,2769,"You've got two choices."],[2869,3015,"One, kneel,"],[3073,3148,"apologize,"],[3148,3294,"and return what you stole."],[3390,3445,"Or two,"],[3553,3645,"I take it by force."],[4116,4208,"Oh, please."],[4295,4408,"You think you're hot shit?"],[4517,4767,"Your mom is terrified of me."],[4829,5055,"One look, and she'll pee her pants."],[5255,5338,"I'm sorry."],[5338,5397,"I'm sorry."],[5397,5472,"It's my fault."],[5505,5593,"It's my fault."],[5593,5751,"Please, please don't hurt my daughter."],[5801,5851,"You should"],[5851,6097,"really learn from your pathetic mom."],[6210,6481,"Maybe if you get on your knees too,"],[6573,6740,"I'll ask dad to go easy on you."],[6881,6990,"Mom, please."],[6990,7077,"You don't need to listen"],[7077,7173,"to these animals."],[7248,7319,"Please, Blair."],[7319,7449,"You should kneel down, too."],[7449,7545,"If you kneel, they will..."],[7570,7670,"They will let us go."],[7670,7741,"Please."],[7766,7928,"Mom, don't do this to yourself."],[7928,8112,"They are no better than animals."],[8137,8208,"Blair, please."],[8208,8395,"You don't know what I've been through."],[8395,8546,"I beg you. Please."],[8546,8675,"They will let us go."]],"28":[[8,150,"Mom, please."],[150,216,"I shouldn't kneel,"],[216,316,"and neither should you."],[358,483,"What are you doing?"],[521,742,"I'm doing this for your sake."],[742,859,"Please."],[1013,1159,"I should have raised her better."],[1159,1234,"I, I..."],[1234,1322,"Mom, enough!"],[1484,1622,"You raised me to be tough."],[1680,1722,"Okay?"],[1722,1830,"Stand up for what's right."],[1910,2060,"If you believe me, your daughter,"],[2193,2264,"will stand up."],[2310,2460,"But I raised you better than that"],[2460,2577,"I just kneeled."],[2652,2840,"I don't want them to hurt you."],[2840,2936,"I'll be your slave."],[3123,3249,"But don't hurt her."],[3249,3374,"Hey, hey, let's just stand up."],[3887,4037,"My people will be here soon."],[4170,4237,"And when they do,"],[4295,4412,"we'll make these monsters"],[4412,4637,"kneel down and apologize to us."],[5000,5180,"You're such a joke."],[5271,5447,"Still acting all high and mighty,"],[5488,5630,"even now."],[5630,5726,"Your people, Blair?"],[5764,5880,"Uh, uh, where?"],[5880,5910,"Oh,"],[5910,6010,"let me remind you"],[6010,6106,"because I think you forgot."],[6135,6272,"So the Beaumont family crest"],[6297,6423,"and all the assets are"],[6423,6498,"in Dad's hands."],[6523,6727,"So you literally have nothing."],[6831,6911,"You really think that's"],[6911,6977,"going to stop me?"]],"29":[[62,200,"Blair Beaumont."],[250,346,"What are you saying?"],[375,663,"What I'm saying, Isaac Beaumont,"],[713,900,"is that this isn't over yet."],[1042,1213,"Oh, sweetheart."],[1242,1463,"Don't listen to this brat's threats."],[1559,1718,"She's only acting tough because"],[1743,1789,"she thinks"],[1789,1943,"the Beaumont name can save her."],[1972,2281,"But we both know she's got nothing."],[2281,2323,"It's true."],[2348,2494,"When Blair was studying abroad,"],[2494,2577,"the Beaumonts paid"],[2577,2681,"for all her expenses."],[2736,2844,"Without the Beaumont name,"],[2844,2948,"she's got nothing."],[3061,3178,"Wow, Young."],[3236,3432,"You really think you know me, huh?"],[3474,3536,"Do I not?"],[3628,3762,"Don't kid yourself, Blair."],[3762,3866,"You were just lucky being"],[3866,4024,"born the Beaumont heiress."],[4024,4141,"If anyone else was in your place,"],[4141,4220,"they'd be the same."],[4333,4475,"You sound pretty sure of yourself."],[4612,4871,"But you made a big mistake, Young."],[4913,5092,"I got here by myself."],[5092,5163,"I didn't get here"],[5196,5263,"by using the"],[5263,5372,"Beaumont heiress status."],[5372,5588,"I worked hard to get where I am."],[5839,6018,"I got to where..."],[6164,6222,"Please."],[6222,6297,"All right, all right."],[6327,6385,"That's enough."],[6427,6602,"Think a lucky break is gonna save you?"],[6669,6886,"This isn't some soap opera."],[7036,7248,"Daddy, can we get it going?"],[7282,7369,"I wanna see them beat"],[7369,7482,"into a bloody pulp."],[7565,7807,"Security, drag them out and beat them."]],"30":[[0,75,"Security,"],[75,300,"take them out of here and beat them."],[300,454,"Why don't you listen?"],[454,629,"Just hurry up and kneel."],[629,742,"It's too late for me."],[742,875,"I don't want them to hurt you."],[905,971,"Miss Blair,"],[971,1042,"you should just"],[1042,1117,"listen to your mother."],[1155,1205,"Otherwise,"],[1205,1292,"the two of you"],[1292,1480,"will be leaving here as corpses."],[1572,1668,"Mom, mom,"],[1714,1881,"would you believe me if I told you that"],[1881,1997,"in 10 seconds,"],[1997,2156,"my people will be here?"],[2202,2356,"Oh, oh, no, I'm..."],[2423,2498,"I'm so scared."],[2598,2698,"Give it up already."],[2756,2798,"Oh, Blair,"],[2798,2907,"are you going to do a nice little"],[2907,3007,"countdown for us?"],[3007,3094,"Because we're all so"],[3094,3174,"scared of who's going"],[3174,3257,"to come through that door"],[3274,3365,"when you count to three."],[3365,3436,"Enough!"],[3557,3699,"Guards, get them out of here."],[3845,3878,"Three."],[4016,4079,"Two."],[4200,4233,"One."],[4362,4416,"Bye-bye."],[4504,4583,"Get your hands off her!"]],"31":[[91,154,"Hey!"],[154,250,"It's Walker."],[638,679,"You alright?"],[738,813,"I'm fine."],[1280,1380,"Who the fuck are you?"],[1413,1555,"You know this is Beaumont property."],[1555,1726,"You threaten my family?"],[1726,1893,"You're not leaving here alive."],[1893,1964,"Who is he?"],[2093,2231,"You don't recognize him?"],[2556,2669,"You're Adrian Lance,"],[2669,2861,"the founder of Sandrix Industries?"],[2944,3015,"Almost."],[3140,3249,"Adrian Lance, yes."],[3319,3386,"Founder of Sandrix?"],[3532,3591,"No."],[3695,3770,"That'd be Ms. Blair."],[3995,4083,"Oh, wow."],[4287,4362,"It's impossible."],[4387,4529,"Sandrix worth trillions."],[4554,4671,"Much more than the Beaumonts."],[4746,4825,"You're the founder."],[4988,5084,"Yeah, Mr. Beaumont."],[5084,5184,"I've been by her side"],[5184,5280,"for three years,"],[5280,5326,"and she's"],[5326,5438,"never stepped foot anywhere"],[5438,5588,"close to the Sandrix offices."],[5630,5693,"Yeah."],[5739,5989,"This must just be part of her act."],[5989,6047,"Yeah,"],[6047,6164,"and I bet those are all actors,"],[6164,6239,"and honestly,"],[6268,6343,"pretty shitty ones."]],"32":[[91,266,"When I was at Maple Elite Academy,"],[266,396,"I didn't just study hard."],[450,533,"I worked hard, too."],[613,763,"I founded my own company to prove"],[763,959,"that I should be the successor."],[1084,1213,"And I knew one of you"],[1213,1301,"would pull something like"],[1301,1468,"this as soon as I left for school."],[1468,1497,"So,"],[1539,1743,"I secretly founded Sandrix Industries,"],[1797,1960,"all for a moment like this."],[2135,2273,"No way, that can't be!"],[2273,2439,"Yeah, I'll bet you cut the shit, Blair,"],[2439,2615,"because we're not falling for it."],[2652,2694,"Dad!"],[2756,2857,"Don't just stand there,"],[2857,2919,"deal with her."],[2952,3098,"Show her we're not playing around."],[3199,3336,"Guards, get them out."],[4233,4379,"Blair, what are you doing?"],[4483,4642,"You really think that this is an act?"],[4779,4867,"Let's find out then."]],"33":[[37,91,"It's time."],[980,1234,"Sandrix acquired all the Beaumont"],[1234,1338,"subsidiaries,"],[1343,1476,"and everything it's all gone."],[1522,1609,"This can't be."],[1651,1685,"Isaac,"],[1714,1876,"do you remember the choices I gave you?"],[1931,2085,"One, apologize"],[2085,2268,"to mom and return everything,"],[2352,2686,"or two, I take it by force."],[2831,3007,"Uh, I..."],[3103,3224,"Make your choice."],[3432,3632,"Dad, she's faking."],[3712,3858,"Hurry up and say something."],[3887,3937,"Isaac,"],[3937,4087,"hurry up and check your bank account."],[4087,4175,"What if she's lying?"],[4212,4237,"Yeah,"],[4237,4329,"don't let that fucking"],[4329,4429,"snake get you, Dad."],[4479,4567,"Right, right, right."],[4646,4754,"It must be fake."],[5025,5105,"It's all gone."],[5121,5213,"Even the savings."],[5313,5417,"It's a zero."],[5588,5714,"Isaac Beaumont,"],[5747,5834,"you used dirty"],[5834,5955,"tricks to grab the Beaumont"],[5955,6085,"assets and my trust fund."],[6268,6348,"Did you really think"],[6373,6493,"I couldn't do the same?"],[6577,6660,"We are screwed."],[6777,6898,"Completely screwed."],[6956,7182,"Now then, Isaac, tell me."],[7298,7478,"What is your choice?"],[7912,7991,"I'm so sorry."],[8078,8141,"Please,"],[8208,8354,"please forgive me, please."],[8391,8437,"I was wrong."],[8462,8529,"I was wrong."],[8575,8721,"Please, just forgive me."]],"34":[[308,483,"Mom, it's all over now."],[513,588,"You can stand up."],[675,817,"Blair, Blair, what's going on?"],[867,1017,"They're not going to hurt us any more or"],[1121,1251,"force us to apologize?"],[1288,1443,"Mom, you don't need to apologize."],[1468,1564,"They're the ones who"],[1564,1676,"should be apologizing."],[1797,1868,"Here, come on."],[2102,2189,"Sit tight, mom."],[2260,2448,"We'll make them kneel and apologize"],[2448,2565,"for what they've done to us."],[2615,2748,"No, no, I’m-"],[2748,2806,"Isaac,"],[2852,2940,"none of this would have"],[2940,3015,"happened if it wasn't"],[3015,3061,"for you."],[3061,3161,"You did this to mom."],[3224,3382,"You and all your backsabbing,"],[3382,3582,"so crawl over and apologize"],[3582,3724,"for what you did."],[3924,4062,"Honey, I'm sorry."],[4095,4295,"I was selfish and blinded by greed."],[4316,4421,"If you just forgive me,"],[4446,4550,"your family made me feel so"],[4550,4721,"inferior when I married in."],[4721,4754,"I mean,"],[4754,4929,"what kind of guy rely on his wife?"],[5267,5409,"You're a piece of work, Isaac."],[5488,5634,"Are you really blaming mom"],[5634,5693,"for all this?"],[5755,5818,"No, I'm not."],[5843,6089,"It's not, it's not your fault at all."],[6210,6339,"It's Jessica's fault."],[6339,6460,"She's the one that trapped me,"],[6460,6519,"seduced me, and"],[6519,6656,"came up with this plan."],[6723,6848,"Honey, it's all that bitch"],[6848,6952,"Jessica's fault."],[6986,7057,"She's the one that"],[7057,7144,"stole me away from you."],[7273,7524,"You're a disgusting little man, Isaac."],[7590,7753,"You don't deserve my mom."],[7753,7791,"Oh!"],[7824,7866,"Oh!"],[8087,8254,"There, honey, daddy was wrong."],[8287,8429,"If you forgive me, I'll promise."],[8479,8704,"Fix my mistakes and be a good person."],[8717,8938,"Just give me another chance."],[9000,9075,"Forgive you?"],[9104,9142,"Yeah."],[9200,9355,"Not a chance."]],"35":[[241,296,"Mom,"],[354,454,"What are you doing?"],[492,604,"You stole my mother's"],[604,692,"identity and even"],[692,855,"forced her to lick your shoes."],[930,1021,"I was forced to."],[1101,1197,"He made me do it."],[1317,1430,"You fucking liar."],[1451,1589,"Blair, don't listen to her."],[1614,1693,"She's the one that"],[1693,1780,"started this whole shit."],[1868,2081,"Man, talk about doggy dog."],[2147,2281,"This is a shit show."],[2402,2527,"I am so sorry."],[2627,2773,"I... I shouldn't have done it."],[2773,2894,"I'll never do it again."],[2973,3207,"Since you forced her to lick your shoes,"],[3244,3403,"I think you should lick hers."],[4016,4200,"I can kneel and apologize, but..."],[4366,4416,"What?"],[4462,4608,"This isn't a request,"],[4646,4788,"this is an order."],[6418,6510,"What's wrong?"],[6556,6664,"Not to your taste?"],[6861,7019,"Oh, scary."],[7048,7107,"Relax."],[7132,7261,"I'm only just getting started."],[7378,7595,"Haley, it's your turn."]],"36":[[4,150,"Are you going to come here yourself"],[150,291,"or am I going to have to drag you?"],[429,504,"Kneel."],[596,667,"I don't want to."],[796,1038,"I said kneel."],[1647,1689,"Shut up."],[2072,2189,"Now, apologize."],[2394,2485,"What's with the face?"],[2510,2569,"Don't want to?"],[2619,2681,"Yeah."],[2786,2923,"I don't wanna."],[2961,3023,"Why should I?"],[3057,3174,"Why did you get everything?"],[3232,3382,"While I grew up being laughed at"],[3382,3503,"for being the illegitimate one?"],[3595,3657,"Why?"],[3849,3891,"Yes,"],[3891,4012,"you're the illegitimate"],[4012,4066,"daughter."],[4099,4179,"But you still had"],[4179,4404,"all the resources and privilege"],[4404,4533,"to make something of yourself."],[4579,4646,"And you chose"],[4646,4804,"shortcuts and dirty tricks,"],[4829,4917,"you freeloader."],[5363,5505,"You sound so sure."],[5618,5847,"Even if I was the good girl,"],[5893,6006,"do you think I'd ever"],[6043,6126,"reach your level?"],[6156,6310,"Unlimited cash?"],[6398,6589,"The whole world at my feet?"],[6598,6664,"No!"],[6690,6931,"That's why I have to get rid of you"],[6931,7040,"and your mom."],[7073,7278,"Then I'll have it all."],[7624,7728,"Who's giving fatherless"],[7728,7811,"behavior now?"],[7878,8103,"Get over yourself and gr