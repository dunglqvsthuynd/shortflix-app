ve three little"],[1951,2102,"bastards sitting at this table now,"],[2102,2189,"can we?"],[2243,2377,"Well, take a real good look,"],[2377,2502,"because here's the DNA report"],[2519,2627,"confirming that they're"],[2627,2786,"my real brothers."],[3032,3161,"Give me a fucking break."],[3332,3582,"Isaac, you are a leech,"],[3603,3728,"who married into this family,"],[3753,3866,"got kicked out,"],[3866,3958,"and now has to repay"],[3958,4087,"your debt that you made."],[4120,4220,"So why do you think"],[4250,4391,"that this behavior is acceptable?"],[4600,4721,"On the basis that I'm your"],[4721,4804,"fucking father,"],[4884,4988,"and the rightful successor"],[4988,5088,"to the Beaumont family,"],[5113,5150,"not some"],[5188,5296,"silly little girl who hasn't"],[5296,5480,"even graduated high school yet."]],"67":[[20,137,"Isaac Beaumont,"],[166,287,"have you gone senile?"],[350,458,"Grandpa chose me"],[487,663,"to be the successor a long time ago."],[754,880,"You're just a parasite"],[880,1046,"with a fancy executive title"],[1046,1201,"that doesn't mean anything."],[1234,1343,"Do you really think you"],[1343,1493,"deserve to run this family?"],[1522,1614,"Mr. Beaumont,"],[1639,1705,"she's right."],[1718,1881,"She has the family crest."],[1931,2097,"And if Mr. Thomas Beaumont finds out,"],[2210,2298,"we're screwed."],[2481,2560,"Here's a little advice"],[2560,2644,"from your old man."],[2656,2890,"Old dogs always have new tricks."],[3107,3186,"Oh, tricks."],[3253,3411,"Oh, are you delusional?"],[3440,3566,"I am the successor because"],[3566,3745,"I have the family crest."],[3762,3849,"And that means..."],[4258,4371,"What's so funny?"],[4508,4667,"I'm just laughing at your stupidity."],[5100,5221,"It's insane."],[5221,5292,"Spit it out."],[5321,5476,"What are you talking about?"],[5580,5613,"Well,"],[5747,5851,"you said it yourself."],[5964,6114,"Whoever holds the crest"],[6243,6343,"is the rightful heir"],[6343,6460,"to the Beaumont family."],[6790,6923,"Now I call the shots."],[7182,7244,"The crest!"]],"68":[[0,129,"When the hell did he get his hands"],[129,208,"on the crest?"],[216,342,"I kept it locked up!"],[342,442,"What do you have to say for yourself,"],[442,513,"Blair?"],[1451,1622,"Blair uses her mother's birthday"],[1622,1810,"for all her important passcodes!"],[2481,2640,"Blair, oh Blair."],[2698,2873,"I thought you were smarter than this."],[3136,3332,"Isaac, you're despicable!"],[3461,3595,"Now that the family crest is"],[3595,3666,"in my hands,"],[3707,3824,"I'm the rightful successor."],[3883,3958,"Not you."]],"69":[[33,258,"Ms. Blair, you just saw what happened."],[342,621,"Mr. Isaac now has the crest."],[621,742,"We must listen to him."],[975,1067,"Who cares?"],[1088,1238,"If he has the crest,"],[1238,1363,"everybody knows that my grandpa"],[1393,1497,"is the one who actually"],[1526,1655,"assigns the next successor."],[1847,2131,"My orders come first."],[2143,2239,"You're right about one thing."],[2306,2389,"No one cares about this"],[2431,2515,"silly little crest."],[2560,2660,"These gentlemen have been"],[2660,2686,"with your"],[2686,2848,"grandfather since day one."],[2873,2948,"Good."],[3003,3128,"I'm glad you understand."],[3182,3315,"Now hand over the crest,"],[3395,3557,"or there's going to be hell to pay."],[3866,3953,"Watch out."],[3987,4070,"Stop daydreaming."],[4183,4346,"There's one thing I want more"],[4366,4500,"than the silly little crest."],[4554,4679,"Then what's your real goal?"],[4808,4900,"I want you"],[4988,5125,"to leave the Beaumont family"],[5155,5209,"for good."]],"70":[[25,79,"Me?"],[141,266,"Out of the Beaumonts?"],[325,533,"Are you actually insane, Isaac?"],[596,675,"Mr. Beaumont,"],[709,930,"you're being a bit unreasonable."],[946,1121,"No matter how you spin it,"],[1121,1355,"she's still the Beaumont heiress."],[1388,1559,"If Thomas finds out..."],[1559,1664,"Don't, Mr. Scott."],[1689,1760,"We shouldn't butt"],[1760,1918,"into their family business."],[1960,2031,"But it's-"],[2031,2139,"Isaac Beaumont,"],[2139,2310,"you married into this family."],[2369,2598,"And you think that you can kick me"],[2640,2736,"out of the Beaumonts?"],[2877,2990,"The audacity!"],[3007,3061,"Ms. Blair,"],[3078,3228,"don't talk to your father like that."],[3228,3290,"More importantly,"],[3324,3465,"your ridiculous proposal"],[3486,3661,"will only hurt our shareholders."],[3687,3787,"Beaumont Enterprise"],[3787,4045,"will be better off headed by Isaac."],[4129,4208,"Isn't that right?"],[4208,4287,"I agree, sir."],[4287,4341,"Yeah."],[4341,4416,"Exactly."],[4592,4692,"-Of course. -Yeah."]],"71":[[129,337,"If Isaac Beaumont hadn't stepped in,"],[383,529,"three total strangers would be"],[529,621,"ended up on the board."],[621,759,"Mr. Beaumont does have more"],[759,900,"experience than Ms. Blair."],[967,1184,"Perhaps having him replace her"],[1184,1301,"would actually be good"],[1301,1422,"for Beaumont Enterprises."],[1430,1518,"Silence!"],[1572,1647,"Everybody out!"],[1676,1797,"Now!"],[2193,2277,"You know what to do."],[2344,2481,"Sign the contract."],[2481,2606,"And if I don't?"],[2606,2702,"Then things are going to get"],[2702,2786,"real ugly,"],[2786,2827,"Blair."],[2861,2940,"What do you mean?"],[2977,3178,"What I mean is, remember your poor,"],[3219,3424,"poor sick mother?"],[3516,3649,"Let go of my mom!"]],"72":[[37,191,"Let go of my mom!"],[304,521,"Sign the contract or else."],[529,608,"Or else."],[642,734,"I'll kill her."],[817,1026,"Blair, don't worry about me."],[1051,1155,"Just please sign."],[1192,1301,"Hurry, please."],[1330,1397,"Hailey?"],[1459,1584,"Hey, stop."],[1634,1718,"Just calm down."],[1730,1826,"Don't do anything rash."],[1826,1993,"We can talk this through slowly."],[2031,2185,"Isaac, she was your wife."],[2218,2373,"She treated you with so much love."],[2373,2506,"How could you do this to her?"],[2527,2744,"I just need a ladder to get to the top."],[2861,2998,"If you want to save her,"],[3094,3261,"now sign the fucking contract."],[3566,3632,"I..."]],"73":[[0,58,"I..."],[229,275,"Fine."],[275,333,"I'll sign."],[688,775,"Blair!"],[863,1051,"I am so, so sorry."],[1051,1192,"I realize I really screwed up,"],[1192,1288,"but you have to understand, too."],[1288,1401,"He boily fucked me."],[1401,1493,"He played me as well."],[1547,1697,"I'm a victim, okay?"],[1697,1826,"We were siblings growing up."],[1826,1901,"I was good to you."],[1910,2006,"Get look in your heart."],[2006,2097,"Please forgive me."],[2097,2185,"Forgive me, please."],[2364,2469,"You abandoned me!"],[2552,2619,"How could you?"],[2623,2840,"Betray me and ruin my fucking life!"],[3499,3586,"AH!!!"]],"74":[[141,254,"Mom, are you okay?"],[412,625,"Isaac Beaumont, this is game over!"],[688,800,"Fucking shit!"],[871,1017,"No, it's not over."],[1051,1163,"It's just getting started!"],[1172,1247,"Isaac!"],[1288,1363,"You were the husband"],[1363,1459,"my mother loved."],[1468,1639,"The father I respected!"],[1726,1860,"And you got to enjoy it, too."],[1897,2010,"But you were too greedy."],[2035,2227,"So greedy that you betrayed your wife"],[2227,2335,"and your daughter."],[2406,2544,"You did this to yourself."],[2544,2606,"No!"],[2677,2752,"Isaac Beaumont?"],[2869,2915,"No."],[2982,3090,"Isaac Jenkins."],[3174,3253,"From this day forward,"],[3253,3411,"you will no longer be my father."],[3490,3611,"You will spend the rest of your life"],[3653,3799,"rotting in jail"],[3845,3920,"for what you've done."],[3920,3978,"No!"],[4162,4258,"Oh, Blair!"],[4325,4458,"I know I screwed up big,"],[4458,4633,"but please, you're such a good person."],[4633,4733,"Look into that heart of yours."],[4750,4938,"Forgive me, I'll do literally anything."],[4959,5021,"I promise."],[5117,5255,"After what you did to my mom."],[5351,5422,"Ah!"],[6126,6252,"I'll never forgive you."],[6981,7203,"Oh God, I know I screwed up!"],[7203,7303,"I was stupid!"],[7303,7457,"Stupid, stupid, stupid!"],[7457,7540,"I'm sorry!"]],"75":[[796,859,"Keep it down."],[875,959,"Mom's still a little"],[959,1092,"sensitive from the shock."],[2748,2781,"Mom,"],[2886,3040,"my three brothers are here."],[3724,3924,"Oh, my boys."],[3991,4149,"I missed you so much."],[4479,4529,"Now no one"],[4529,4688,"can separate our family again."],[5025,5088,"Or us."]]}