{"1":[[381,545,"We gather here today"],[562,741,"to mourn the loss of a loved one."],[816,904,"May God forgive you"],[904,987,"as you forgave others..."],[987,1129,"Let go of me!"],[1216,1280,"Stepmother."],[1372,1520,"Late to my father’s funeral?"],[1600,1656,"How rude."],[1712,1852,"Allen, you drove the company"],[1852,1928,"into the ground"],[1928,2036,"and your father into a grave."],[2036,2092,"And now what?"],[2092,2228,"You're pretending to mourn?"],[2236,2352,"What the hell!"],[2512,2632,"You got a fucking death wish?"],[2697,2792,"Show some respect."],[2840,2900,"Dexon,"],[2936,3080,"is now head of the Smith family."],[3128,3168,"You"],[3216,3352,"aren’t even worth watching him."],[3580,3744,"You are the head of the Smith family?"],[3776,3924,"The most powerful mafia?"],[3996,4084,"Oh, no, no."],[4136,4256,"No, no, no, no, no, no."],[4256,4376,"No, this can't be."],[4564,4632,"Come now."],[4668,4764,"Do me a favor."],[4868,4968,"If you hadn't beaten me"],[4968,5048,"and left me to die,"],[5084,5192,"I wouldn't have found my way back"],[5192,5296,"to my grandfather."],[5328,5548,"It was your father who ruined your life,"],[5548,5600,"not me."],[5628,5784,"It wasn't my idea to throw you"],[5784,5852,"out of the house."],[6304,6464,"Oh, Allen. Please!"],[6464,6580,"Your father’s already dead."],[6580,6872,"I have nothing left. Please, please."],[6872,7124,"You’ve already had your revenge."],[7124,7232,"Spare me!"],[7268,7588,"Please, just give me one more chance."],[7660,7836,"Please..."],[8948,8996,"Go!"],[9012,9048,"Drink!"],[9048,9320,"Drink! Drink! Drink! Drink! Drink! Drink!"],[9440,9476,"Woo!"],[9644,9824,"I can make you even happier if you want."],[10268,10308,"Hello."],[10384,10448,"What's going on?"],[10492,10612,"Harry Callis is dead."],[10660,10804,"His company's gone under too."],[10852,10904,"Word is,"],[10940,11116,"his son Allen’s deep in debt..."],[11124,11296,"working at a bar as a male escort."],[11340,11540,"Allen? As an escort?"],[13140,13360,"Get your filthy hands off my man!"]],"2":[[72,124,"Alright."],[224,324,"Congratulations!"],[324,484,"Congratulations."],[620,672,"Cheers."],[700,764,"Cheers."],[1040,1128,"Aunt Kim."],[1164,1232,"Aunt Jane."],[1380,1552,"I appreciate the celebration,"],[1600,1732,"but I have somewhere I need to be."],[1948,2040,"No way."],[2128,2284,"Tonight’s your victory party!"],[2300,2552,"Time to go all out, drink like a fish,"],[2552,2708,"and party till the sun comes up."],[2716,2844,"Exactly!"],[3088,3288,"Why is there blood on your shirt?"],[3668,3772,"You two were"],[3780,3952,"enemies back in high school."],[3964,4132,"You should be happy he's bankrupt."],[4156,4348,"But you don't look happy."],[4460,4516,"Happy?"],[4548,4660,"Of course I'm happy."],[4768,5096,"Well, Allen wasn’t just handsome."],[5096,5244,"He also got a hot body."],[6208,6404,"Get your filthy hands off my man!"],[6468,6608,"Your man?"],[9272,9396,"And who the hell are you?"],[9416,9560,"Your man, since when?"],[9620,9652,"Oh,"],[9672,9828,"we've been together since high school."],[9900,9956,"Got that?"]],"3":[[979,1079,"Oh, Honey."],[1087,1245,"Do you even know who we are?"],[1345,1470,"I don't care who you are."],[1537,1670,"Whatever you're offering him,"],[1712,1787,"I'll double."],[1820,2050,"No, I'll triple it."],[2091,2337,"Starting today, he's my sugar baby."],[2391,2570,"So stay the hell away from him."],[2662,2770,"Oh, Dexon."],[2800,2954,"Are you really gonna be kept?"],[3045,3162,"I guess you're not coming home"],[3162,3266,"with us anymore."],[3570,3658,"So,"],[3712,3850,"are you staying here with them,"],[3870,3987,"or are you coming home with me?"],[4079,4162,"Are you sure?"],[4345,4537,"Keeping me isn’t exactly cheap."],[4650,4741,"Don't worry, doll."],[4795,5070,"I can do everything and more."],[5125,5262,"You got nothing on me."],[5425,5495,"Well, then."],[5645,5770,"Guess what. I'll be with you tonight."],[6233,6308,"Ladies,"],[6391,6470,"have a good night."],[6600,6720,"Stop looking at them."],[6779,6858,"As you wish."],[6962,7025,"Yes, ma'am."],[7208,7395,"I guess we should let Dad know that"],[7395,7537,"his precious grandson"],[7537,7666,"isn't coming home tonight."],[7708,7879,"He might bring someone back home."],[7954,8037,"Maybe even two."],[8070,8125,"Or three."],[9987,10083,"I once heard..."],[10170,10312,"you had seven men in one night."],[10475,10595,"Having trouble with a button?"]],"4":[[4244,4364,"Oh my God, what did I do"],[4364,4424,"last night?"],[5196,5268,"Miss Cruz."],[5488,5560,"Leaving so soon?"],[6308,6408,"Here's your payment."],[6432,6496,"Payment?"],[6624,6796,"You promised me a full sponsorship"],[6796,6856,"last night."],[7180,7296,"Here's the contract."],[7516,7592,"Care to sign?"],[7864,7904,"Allen,"],[8048,8140,"I'm going to keep you."],[8208,8328,"You’ll be my little canary."],[8380,8488,"Yes, my master."],[8584,8808,"I'll be your personal pet."],[9172,9236,"Umm..."],[9348,9496,"I don't remember any of that."],[9508,9672,"Oh, really?"],[9724,9840,"I have lots of recordings."],[9872,10148,"The videos are nice and clear."]],"5":[[208,312,"Are you serious?"],[388,568,"All I did was touch you a couple of times,"],[568,628,"and now you’re making me"],[628,756,"“responsible” for you?"],[928,964,"Fine."],[1032,1140,"If you want to cancel the deal,"],[1180,1252,"so be it."],[1268,1400,"I can find a new benefactor."],[1488,1688,"This face of mine is in very high demand..."],[2196,2300,"Oh my God!"],[2300,2532,"Is Allen confessing to your sister?"],[3932,4052,"Paying off debt is rough."],[4060,4172,"Being a canary is hard."],[4216,4444,"So, if my sugar mama is playing me, then."],[4484,4568,"It’s a big part."],[4604,4652,"Okay!"],[4728,4780,"Okay."],[4916,5020,"Let’s talk about this."],[5936,6012,"Number one."],[6124,6284,"Party A : Leah Cruz agrees to"],[6284,6560,"financially support Party B : Allen Callis"],[6560,6680,"under the conditions of"],[6680,6832,"this sponsorship contract."],[6864,6948,"Number two."],[6948,7208,"Party B must obey all demands from Party A."],[7244,7348,"Number three."],[7348,7472,"The contract cannot be"],[7472,7636,"terminated by Party A."],[7696,7792,"Number four."],[7792,7904,"One billion shall be..."],[7980,8088,"One billion!"],[8160,8312,"Why don’t you just go rob a bank?"],[8336,8460,"Fine, fine."],[8460,8548,"I guess you’re right."],[8600,8692,"I’ll find someone else."],[8764,8808,"Fine!"],[8856,8900,"Fine."],[8980,9060,"I’ll sign it."],[9428,9564,"Just one billion, anyway."],[10300,10428,"And one condition."]],"6":[[48,128,"What condition?"],[164,284,"You must get rid of all these women"],[284,412,"that are trying to sponsor you."],[444,636,"I'm the only one allowed to be your..."],[744,796,"owner."],[928,972,"Got it?"],[1024,1124,"Sure thing."],[1600,1864,"Why do I feel like I just got played?"],[3772,3928,"Now that my grandson Dexon"],[3984,4132,"has returned to the Smith family,"],[4184,4436,"it’s time to honor the marriage pact"],[4452,4556,"with the Cruz family."],[4772,4880,"Go make the arrangements."],[4916,4968,"Yes, sir."],[5756,5908,"Which one of you is Miss Cruz?"],[5956,6088,"I'm just the stepfather."],[6108,6192,"Nothing to do with me."],[6192,6260,"This is her mother."],[6260,6344,"You should talk to her."],[6480,6580,"Sir..."],[6648,6860,"Did my daughter get into"],[6860,7072,"some kind of trouble?"],[7176,7408,"I'm here to discuss the marriage agreement"],[7408,7532,"between the Smith family"],[7540,7616,"and Miss Cruz."],[8732,8960,"Leah, you lucky bitch..."],[8996,9120,"How the hell do you have"],[9120,9244,"a marriage deal with them?"],[9696,9772,"Mr. Mark,"],[9892,10012,"I’m Miss Cruz."],[10164,10280,"You can call me Lisa."]],"7":[[212,272,"Miss Cruz."],[316,548,"Our boss settled the appointment with you"],[548,616,"this afternoon."],[668,728,"I will send you"],[728,860,"the detailed location soon."],[900,944,"Be ready."],[1016,1072,"Don't worry."],[1088,1224,"We'll be totally prepared."],[1348,1400,"Thank you."],[1440,1476,"Let's go."],[1520,1576,"Thank you."],[1868,2044,"Oh, Lisa, Lisa."],[2044,2164,"What were you thinking,"],[2164,2376,"impersonating your sister?"],[2412,2572,"Come on. It's not a big deal."],[2596,2720,"If that bitch can have it all,"],[2720,2804,"why can't I?"],[2828,3052,"Deceiving the Smith family?"],[3064,3176,"Oh, God."],[3220,3492,"They will destroy us if they find out."],[3500,3592,"Just chill."],[3660,3800,"A lie stays true as long as"],[3800,3900,"no one catches it."],[4132,4248,"It's time to arrange"],[4248,4500,"a nice little marriage for our Leah."],[5884,5952,"So,"],[6040,6120,"what's next?"],[6148,6204,"Top?"],[6268,6340,"Or bottom?"],[6416,6620,"Allen I'm exhausted. Let me rest."],[6640,6804,"You have to get your money’s worth."],[7004,7064,"Leah!"],[7088,7152,"Open up!"],[7200,7316,"I know you're in there!"],[7332,7396,"Lisa?"],[7496,7564,"Oh, hide!"],[7564,7656,"She can’t see you here."],[7676,7836,"Oh, why?"],[7884,7980,"You got ashamed of me?"]],"8":[[208,264,"Shut up!"],[308,396,"Don't make a sound."],[980,1108,"What the hell are you doing here?"],[1208,1260,"Leah."],[1320,1524,"Dad arranged a nice marriage for you."],[1540,1608,"That's right."],[1624,1792,"Everything's set for this afternoon"],[1792,1908,"at the Flex Hotel."],[2008,2076,"Marriage?"],[2156,2240,"I don't need it."],[2272,2492,"Oh, don't be so quick to say no."],[2604,2804,"We are doing this for your happiness."],[2864,3020,"You should be thankful."],[3136,3260,"You agreed to this too?"],[3304,3432,"Your father thought"],[3432,3572,"it would be a good idea."],[3596,3776,"My father is dead."],[3788,3920,"Don't try to replace him."],[4204,4256,"Leah."],[4284,4468,"You've been dying to join the company."],[4560,4852,"Go on the blind date and I'll get you a spot."],[4892,4996,"Start tomorrow."],[5072,5244,"If I can get into the company,"],[5288,5420,"I'll have a chance to take back"],[5420,5544,"Dad's legacy."],[5804,5856,"Fine."],[5940,6164,"Since my stepfamily cares so much"],[6164,6256,"about my future."],[6328,6380,"I'll go."],[6712,6788,"What was that?"],[7124,7180,"Lisa."],[7592,7684,"Now I see."],[7724,7832,"You were too busy"],[7832,7968,"playing with your boy toy"],[7968,8100,"to answer the door, right?"],[8140,8252,"Let's see what kind of loser"],[8252,8396,"caught your eye this time."],[8516,8584,"Let me see."],[8948,9020,"Allen?"],[9316,9364,"Hi."]],"9":[[244,292,"Hi."],[1080,1136,"Hi."],[1232,1284,"Hi."],[2904,3052,"Allen’s always liked Lisa..."],[3088,3312,"He’s probably upset she saw him like that."],[3468,3724,"Allen? What the hell are you doing here?"],[3800,3888,"You two..."],[3928,4164,"And how is that any of your business?"],[4352,4592,"Oh, now I get it."],[4684,4920,"I heard a gossip that your family's broke,"],[4932,5096,"and you’re selling your body"],[5096,5208,"to get rid of your debts."],[5320,5368,"Leah."],[5416,5544,"How much are you paying him?"],[5608,5712,"I will double it."],[5944,6032,"If you come with me..."],[6232,6404,"You think you can steal my man?"],[6440,6496,"Please,"],[6556,6684,"you’re not even worthy."],[6916,7008,"You psycho."],[7108,7164,"Allen!"],[7268,7428,"You really want to stay with a..."],[7512,7672,"violent bitch like her?"],[7708,7824,"My lady has her reasons"],[7824,7896,"for everything."],[7976,8124,"Oh, you want to see violence?"],[8172,8336,"I'll show you violence."],[8508,8572,"Get out!"],[8624,8680,"Get out!"],[8712,8832,"Don't forget our deal."],[8832,8952,"Get out!"],[9164,9356,"She hasn't changed one bit."],[9752,9980,"If I want to take back my father's company,"],[10004,10116,"I have to go through"],[10116,10244,"with this arranged date."],[10276,10372,"Where was it again?"],[10420,10532,"Flex Hotel?"],[10692,10924,"Oh, I just remembered I have a client meeting."],[10944,11092,"I have to head back to the office."],[12084,12140,"Hello."],[12180,12260,"My boy."],[12276,12444,"I've set up a blind date for you"],[12444,12560,"at the Flex Hotel."],[12576,12660,"Don't forget to go."]],"10":[[104,264,"Grandpa, I'm not going."],[312,516,"Come on. It's an old agreement."],[536,640,"Just meet the girl."],[640,780,"And if you don't like her,"],[780,896,"you just refuse it."],[928,1064,"Alright. Bye."],[1176,1348,"I finally got close to Leah."],[1404,1528,"I need to take care of this"],[1528,1652,"before she finds out."],[2440,2508,"Allen?"],[2892,3024,"Already regret it?"],[3224,3428,"Came asking me to sponsor you?"],[3468,3572,"Not today."],[3600,3792,"I've got a date with Mr. Smith."],[3872,3928,"Wait."],[3948,4144,"You’re Dexon Smith's blind date?"],[4172,4304,"I don't think he's interested in"],[4304,4436,"a gold digger like you."],[4640,4856,"And you think a broke loser like you"],[4856,5016,"knows anything about him?"],[5124,5220,"I don't think so."],[5700,5836,"Go get me some coffee."],[5980,6112,"If I feel generous,"],[6124,6264,"I might give you a dollar tip."],[6600,6720,"You want coffee?"],[6896,6972,"Here you go!"],[7712,7824,"You crazy bitch."],[7868,8136,"This makeup was $150, and my outfit?"],[8376,8656,"You ruined my date. You’re dead, Leah!"],[8716,8924,"No need to worry, your date's canceled."],[9016,9132,"Who do you think you are?"],[9188,9380,"You think you just canceled my date?"],[9880,9964,"You see?"],[10012,10204,"Smith’s family already calling to check in."]],"11":[[372,456,"Miss Cruz."],[492,636,"The meeting is canceled."],[668,800,"You can go home now."],[1020,1180,"Allen, you really jinxed it."],[1308,1424,"Poor Lisa."],[1444,1616,"Your dreams are ruined."],[1712,1792,"Leah."],[1856,2092,"You will regret this, you little bitch."],[2716,2800,"Why are you here?"],[2880,3000,"I thought you had a business meeting."],[3092,3212,"Oh, umm..."],[3236,3396,"The client changed the locations"],[3396,3472,"last minute..."],[3588,3736,"Why are you here?"],[3820,4040,"Me? I... had an interview."],[4092,4240,"Ran into Lisa by chance."],[4424,4540,"Do you know Dexon Smith?"],[4576,4712,"How did you know her date would"],[4712,4792,"get canceled?"],[4880,4924,"Boss!"],[5112,5196,"Boss, Boss."],[5284,5488,"I'm terribly sorry for any inconvenience"],[5488,5584,"you had today."],[5692,5876,"Boss? I thought you were bankrupt."],[5892,6128,"I pretended to run a company."],[6160,6304,"I want to take some pressure off you."],[6304,6492,"So I applied for a job."],[6804,6948,"I like the place."],[6948,7060,"No complaints here."],[7168,7264,"Love to work here."],[7264,7312,"So,"],[7404,7520,"do I have the job?"],[7924,8028,"Yes, Yes."],[8028,8088,"Of course!"],[8112,8156,"Great!"],[8228,8308,"I'll do my best."],[8328,8444,"Yeah..."],[9056,9112,"Thank you."],[9564,9668,"Nice boss."],[9708,9768,"Yeah."],[9852,9956,"Pretty polite."],[10072,10128,"So..."],[10192,10256,"how did you know"],[10256,10380,"Lisa’s date would fall through?"],[10620,10684,"Oh, that?"],[10772,10940,"Dexon Smith is a mafia boss."],[11016,11200,"He has women all over him."],[11256,11468,"Lisa is not his type."],[11532,11612,"Lucky guess."],[11772,11928,"Lucky guess..."],[11992,12252,"Tell me, how does a broke man like you"],[12252,12460,"own a million dollar watch?"]],"12":[[72,320,"Tell me, how does a broke man like you"],[320,528,"own a million dollar watch?"],[768,824,"This?"],[888,1088,"Nine bucks at a street stall."],[1484,1640,"Pretty well made."],[1708,1816,"I thought it was real."],[2004,2144,"You shouldn't wear fakes like this."],[2172,2288,"I'll buy you the real one."],[2344,2412,"Toss this."],[2620,2820,"If you don't like it, it's gone."],[3088,3296,"So... all finished for today?"],[3404,3508,"Going home together?"],[3576,3624,"Dinner?"],[3664,3800,"Oh, umm..."],[3876,4024,"I have another client meeting!"],[4176,4236,"Gotta go!"],[4872,4980,"Oh, wow!"],[5352,5420,"Can I..."],[5700,5748,"Thanks."],[5788,5836,"Thanks!"],[7572,7676,"Miss Cruz!"],[8140,8248,"Here's your payment."],[8292,8508,"Go back and tell Tom that..."],[8552,8640,"you're impressed with me."],[8660,8728,"And let's say we're gonna"],[8728,8844,"get married next month."]],"13":[[148,188,"Why?"],[324,448,"You look like you hate my guts."],[488,572,"You don't need to know."],[580,796,"If you want the money, do what I say."],[896,980,"At least..."],[1076,1192,"have a coffee with me?"],[3316,3552,"Your dear sister told me to take"],[3552,3728,"very good care of you."],[4008,4072,"I'm sorry."],[4092,4168,"Are you okay?"],[4200,4272,"Who sent you?"],[4308,4372,"No one."],[5020,5080,"Shit."],[5372,5448,"Felix!"],[5512,5616,"Bring all our men."],[5648,5796,"Close down the entire hotel."],[5812,5892,"Now!"],[7184,7244,"Leah."],[7376,7468,"Your body’s even better"],[7468,7560,"than I imagined."],[8184,8344,"Don't pretend to be shy now."],[8388,8488,"Your sister said"],[8488,8664,"you’re a total slut."],[9072,9244,"Let's see if you live up to the hype."]],"14":[[496,676,"Please, Mr. Smith!"],[780,904,"Have mercy. I'm sorry."],[948,1024,"I had no idea..."],[1296,1376,"Say something!"],[1404,1468,"Tell him!"],[1504,1560,"I'll talk!"],[1580,1700,"I'll take you to her right now."],[2536,2616,"Come on!"],[2960,3012,"Leah!"],[3040,3120,"Asshole!"],[3140,3376,"Son of a bitch!"],[3536,3584,"Leah."],[3736,3796,"Allen."],[3852,3928,"Is that you?"],[4096,4168,"You alright?"],[4240,4316,"Did he hurt you?"],[4488,4592,"What did you do to her?"],[4640,4700,"I just..."],[4720,4836,"I, I didn't..."],[4864,4928,"Boys!"],[5172,5252,"Take him away."],[5332,5432,"I want him to know what it feels like"],[5432,5528,"when someone messes with"],[5528,5584,"my woman."]],"15":[[744,828,"Mrs. Smith!"],[892,964,"You’re awake!"],[1040,1160,"Mrs. Smith?"],[1264,1372,"What the hell?"],[1624,1724,"Mr. Smith?"],[1764,1876,"Your wife is awake!"],[1908,1944,"Wait!"],[2032,2096,"Come back here!"],[2136,2264,"I don't want to marry him."],[6124,6200,"Why are you hiding?"],[6308,6436,"Mr. Smith? I..."],[6512,6604,"You've got the wrong person."],[6604,6712,"I'm not your fiancée."],[6808,6912,"What are you talking about?"],[7008,7200,"My fiancée can only be you."],[7260,7344,"Please..."],[7356,7420,"Let me go..."],[7476,7668,"I don't want to marry into a Mafia family."],[7748,7864,"It's too dangerous."],[7912,8056,"I want to live to a hundred."],[8088,8164,"Dangerous?"],[8248,8336,"I'll protect you."],[8384,8488,"You have nothing to fear."],[8504,8692,"No! No, no..."],[8716,8780,"I mean,"],[8848,8948,"what I mean is..."],[9008,9148,"I'm not worthy of you."],[9388,9464,"Worthy?"],[9556,9688,"Without even seeing me yet?"],[9784,9832,"Once you do,"],[9832,10024,"I'm sure you'll change your mind."]],"16":[[4,264,"Please, please."],[264,436,"We're from two different worlds!"],[540,648,"What makes you say that?"],[740,856,"People say Dexon Smith is"],[856,1032,"a cold-blooded killer."],[1032,1148,"I'm not like that."],[1172,1364,"I cried when my hamster died."],[1400,1696,"So you're scared of the Smith name?"],[1780,1888,"What do you think will happen to you"],[1888,2012,"when you turn me down?"],[2176,2212,"You..."],[2268,2396,"You can't force me."],[2464,2580,"I already have someone I like."],[2720,2884,"She likes someone else..."],[3264,3436,"Tell me his name and I'll let you go."],[4200,4352,"You aren’t afraid of that I'll kill you"],[4424,4552,"if you don't tell me?"],[4620,4792,"I can't let him know about Allen."],[4960,5016,"Go ahead."],[5076,5148,"Kill me."],[5196,5388,"You'd rather die than give him up?"],[5472,5528,"Yes."],[5636,5752,"I'd rather die."],[6044,6180,"Look, Mr. Smith."],[6300,6436,"Lisa is your fiancée."],[6472,6620,"She'd be thrilled to marry you."],[6648,6764,"I don't want Lisa."],[6968,7176,"Listen, I need a marriage"],[7176,7284,"to get out of the engagement"],[7284,7496,"my grandfather made for me years ago."],[7540,7604,"How about"],[7704,7884,"we do a contract marriage?"],[7992,8108,"Contract marriage?"],[8152,8232,"Yes."],[8288,8460,"You'll be paid substantially."],[8504,8680,"You can live your life as you please."],[8744,8896,"I won't meddle in your affairs."],[8988,9124,"He won't interfere?"],[9168,9364,"So... I can still support Allen"],[9364,9488,"without any problems?"],[9560,9884,"So, if I use your money to..."],[10044,10328,"keep a lover, you wouldn't care?"]],"17":[[268,460,"I'm kidding, I'm kidding, I'm kidding."],[512,740,"If I agree to this contract marriage,"],[780,900,"I could use his influence"],[900,1080,"to reclaim my father's company."],[1144,1360,"This might actually be worth it."],[1512,1617,"Look, if you're not interested,"],[1637,1728,"just say so."],[1804,1944,"I’ll have someone escort you home."],[2188,2256,"I'll do it."],[2400,2500,"But on one condition."],[2608,2672,"Name it."],[2776,3108,"Wow, he's really that desperate?"],[3188,3352,"My stepfather and half sister,"],[3352,3512,"they took over my father's"],[3512,3620,"company and estate."],[3716,3868,"I need you to help me get them back."],[4012,4112,"If you were just Leah Cruz,"],[4112,4228,"I wouldn't lift a finger."],[4280,4388,"But as Mrs. Smith?"],[4492,4708,"Your problems are my problems."],[4840,4900,"Deal."],[4940,5016,"Excellent."],[5092,5240,"I look forward to our partnership,"],[5240,5312,"Mrs. Smith."],[5392,5504,"I’ll have my assistant bring over"],[5504,5648,"the marriage paperwork soon."],[6564,6700,"Dexon Smith..."],[6792,6908,"Mafia boss."],[6964,7108,"That was terrifying."],[7216,7472,"He probably has a lot of scars"],[7472,7572,"and maybe a..."],[7572,7700,"bullet wound on his shoulder."],[7824,7964,"If Allen ever met him,"],[7992,8172,"he’d be scared out of his mind."]],"18":[[316,408,"Mrs. Smith,"],[424,620,"your marriage is now officially registered."],[720,908,"Here’s thirty million as per the agreement."],[988,1064,"Thank you."],[1432,1532,"I'll be on my way now."],[2344,2408,"Allen?"],[2568,2696,"What's he doing here?"],[2784,2840,"Uncle,"],[2928,3044,"I'd like you to look into the man"],[3044,3160,"that Leah has been seeing."],[3312,3436,"So you've been married for..."],[3472,3564,"ten minutes?"],[3592,3708,"She's already cheating on you?"],[3740,3856,"This lady got a death wish."],[3880,4000,"No, it's not like that."],[4068,4188,"I just want him looked into."],[4228,4304,"That's all."],[4476,4548,"Fine."],[4644,4780,"What do you want me to do if I find him?"],[4824,4876,"Kill him?"],[4916,4956,"No."],[5088,5180,"I don't want her hurt."],[5256,5440,"You really care about this chick."],[5600,5696,"It's not like that."],[6264,6436,"Allen, what are you doing here?"],[6660,6728,"Well..."],[6728,6924,"Is he trying to make you pay off debts?"],[7252,7456,"Mr. Smith, please."],[7496,7604,"Just a few more days."],[7628,7816,"I beg you."],[8188,8228,"What?"],[8288,8396,"You know the deal."],[8520,8684,"Dad’s gone, companies tanked."],[8684,8848,"Juggling all these different jobs."],[8876,9096,"Just a few more days."],[9148,9224,"Please."],[9300,9528,"Oh... that debt."],[9560,9628,"Debt... yeah..."],[9792,10016,"Stop with the intimidation already."],[10032,10236,"Me? Intimidating?"],[10316,10424,"How much does he owe you?"],[10528,10812,"Allen... remind my memory?"],[10812,10912,"What's the number?"],[10932,11116,"Thirty million dollars."],[11132,11196,"Right."],[11200,11372,"I must have slipped my mind."],[11440,11492,"Well."],[11564,11652,"Thirty million."],[11740,11832,"Thirty million?"],[11916,11960,"Okay."],[12216,12340,"Here's thirty million."],[12368,12504,"Now stop harassing him."],[12656,12708,"Let's go."],[12804,12876,"Let's go!"],[13176,13348,"Man... she's feisty."],[13432,13568,"Think she'll end up abusing him?"]],"19":[[272,504,"Thank God I managed to fool that Henry guy."],[528,700,"I almost couldn't keep up with the act."],[808,988,"Allan, you really should stay away"],[988,1068,"from the mafia."],[1096,1180,"We can't afford to"],[1180,1284,"mess with people like that."],[1400,1540,"Mafia is not that bad."],[1560,1632,"Really?"],[1688,1828,"Come on, admit it."],[1848,1968,"If it weren’t for me, they’d probably"],[1968,2180,"cut off one of your pretty fingers by now."],[2220,2336,"I'm sure you're right."],[2440,2532,"You know,"],[2532,2652,"you put on quite the performance"],[2652,2720,"back there."],[2788,2908,"If I didn't know better,"],[2952,3144,"I’d say you’re a mafia boss’s wife."],[3464,3528,"Yeah."],[3528,3608,"What's that?"],[3732,3804,"In your hand."],[3976,4036,"This,"],[4120,4300,"This is just a contract."],[4320,4404,"Contract?"],[4492,4556,"Yeah."],[4712,4824,"You're here on business?"],[4824,5060,"Yeah, something like that."],[5140,5240,"Listen, Allen."],[5240,5432,"If another creditor gives you trouble,"],[5484,5604,"you tell me, okay?"],[5628,5804,"I made some money from this deal"],[5804,5956,"with the Smith family, so I got you."],[6020,6216,"Turns out she's been trying to help me"],[6216,6348,"pay off my debt."],[6648,6728,"Don't worry."],[6796,7020,"Might be a canary, but I have my pride."],[7164,7392,"I promise to not give trouble or burden"],[7392,7512,"to my benefactor."],[8496,8628,"These shoes..."],[8752,8792,"Yes."],[8912,9028,"Dexon Smith..."],[9028,9208,"was wearing these shoes earlier."]],"20":[[196,284,"Black shoes."],[340,472,"Mass-produced, right?"],[628,692,"What?"],[760,940,"Two men can have the same shoes."],[996,1064,"Really?"],[1252,1444,"Allen, I hate being lied to."],[1444,1652,"And I hate betrayal even more."],[1652,1992,"So if you're lying to me, you better stop now."],[2336,2684,"Ah, my dear grandson! You're back!"],[2720,2824,"Good afternoon, sir."],[3300,3388,"Grandson?"],[3512,3588,"Sir?"],[3644,3804,"Are you the owner of this mansion?"],[3920,3980,"Well..."],[4004,4292,"You must be my future granddaughter-in-law."],[4336,4508,"Aren't you going to introduce us?"],[4624,4708,"Allen,"],[4792,4868,"explain."],[4912,5020,"Yes, just a second."],[5252,5376,"This is my grandfather."],[5528,5644,"He's the gardener here."],[5676,5752,"The gardener?"],[5760,5836,"Gardener?"],[5836,5888,"Yes."],[5992,6152,"He worked here ever since he was young"],[6152,6216,"and the..."],[6288,6592,"owners kindly let him live here in peace."],[6652,6728,"Gardener?"],[6768,6908,"Peaceful retirement?"],[7040,7256,"I own this estate."],[7344,7520,"And why would you be lying"],[7520,7700,"to your future wife like this?"],[7840,7988,"Are you lying to me?"]],"21":[[120,344,"I am not lying."],[820,1024,"Sometimes he gets confused"],[1060,1224,"and thinks he is the rightful owner"],[1224,1316,"of this house."],[1356,1504,"Oh dear."],[1572,1736,"Oh my memory."],[1780,1916,"I can't seem to..."],[1976,2124,"remember clearly."],[2148,2244,"Grandpa,"],[2312,2460,"you really must take your medicine."],[2500,2732,"The doctor said don't skip your doses."],[2840,2928,"Medication?"],[3012,3096,"Oh, my medi..."],[3096,3292,"Where is my medicine?"],[3324,3528,"My grandfather is a bit eccentric."],[3592,3812,"He confused you for someone else before."],[3812,4004,"I'm sorry if he confused you."],[4108,4316,"My apologies, young lady."],[4404,4592,"I seem to be rambling a lot."],[4676,4752,"It’s alright."],[5196,5320,"Oh, you’d better go..."],[5440,5556,"Oh, dear..."],[5832,6192,"Your grandfather is a... really unique."],[6288,6356,"Unique?"],[6456,6544,"In what way?"],[6612,6884,"He’s quite... charming for his age."],[7076,7384,"You’re the first person to ever say that."],[7512,7576,"Really?"],[8088,8232,"She thinks a ruthless mafia boss"],[8232,8384,"is innocent and charming?"],[8500,8588,"What a woman..."]],"22":[[224,500,"Leah had Eric beaten so badly"],[568,724,"and he got paralyzed."],[852,1152,"And then her and that stupid loser Allen..."],[1248,1384,"humiliated me."],[1464,1716,"Nobody humiliates my precious daughter."],[1824,1992,"Leah needs to be taught a lesson."],[2040,2336,"But Tom, our entire family,"],[2336,2472,"including the company,"],[2508,2680,"survives on the inheritance"],[2680,2844,"left by Leah’s father."],[3064,3216,"So let's find out the way"],[3216,3432,"how to get that inheritance for us!"],[3540,3628,"Go ahead."],[3652,3748,"I dare you."],[4060,4188,"But just so we're clear,"],[4188,4372,"my father’s will clearly says"],[4372,4492,"that all his assets are mine."],[4668,4796,"You won't get a penny."],[4976,5208,"You've been living off us for years."],[5268,5492,"Eating our food. Enjoying this home."],[5556,5652,"The least you can do"],[5652,5824,"is share the inheritance."],[5912,5996,"Share?"],[6192,6316,"You two think so too?"],[6384,6480,"Of course."],[6516,6720,"Lisa has a point, Leah."],[6756,7016,"Over the years, it was uncle Tom"],[7016,7136,"who raised you."],[7164,7364,"And let you live as you please."],[7424,7644,"It's only right"],[7660,7980,"that you share the inheritance."],[8136,8240,"Is that right?"],[8308,8436,"You expect me to share?"],[8816,8888,"Fine."],[8988,9096,"I'll consider it."],[9204,9348,"On one condition."],[9484,9612,"You give me back full control"],[9612,9756,"of my father's company."],[9756,9984,"Otherwise, you won't get a single cent!"],[10316,10460,"You greedy bitch!"],[10532,10676,"You got the whole inheritance,"],[10692,10840,"and now you want company too?"],[11080,11156,"Leah!"],[11156,11364,"I let it slide the first time you hit your sister,"],[11364,11500,"but this time I won't let it go."],[11620,11692,"Shut up!"],[11740,11832,"You’re just a chauffeur"],[11836,11996,"who leashed off my dad after he died."],[12036,12228,"You dare raise your voice at me?"],[12272,12444,"You worthless parasite."],[12452,12712,"Leah, how can you treat your stepfather"],[12712,12892,"and sister like this?"],[13024,13100,"Stepfather?"],[13184,13268,"Sister?"],[13344,13492,"They don't deserve those titles."],[13596,13668,"And what about you?"],[13668,13832,"Why do you always side with them, Lamia?"],[13872,14024,"Am I not your daughter too?"],[14116,14284,"Or am I just an outsider to you?"]],"23":[[36,248,"Of course, you are my daughter"],[248,600,"and I love you as much as I love Lisa."],[660,852,"Please don't be angry."],[852,1000,"We are family."],[1052,1132,"Family."],[1308,1440,"Yet, no matter what it is—"],[1440,1592,"be it clothes,"],[1612,1756,"gifts, praise..."],[1848,2040,"Lisa always gets more than me."],[2100,2232,"Do you think I haven't noticed it?"],[2308,2540,"But she's your little sister."],[2712,2804,"Some sister."],[2884,3032,"Just moments ago, she was"],[3032,3204,"planning to kick me out of the house"],[3204,3308,"and steal my inheritance."],[3308,3380,"Wasn't she?"],[3428,3620,"And you claiming to love me?"],[3668,3804,"You're actually just interested in"],[3804,3900,"spending my money?"],[4308,4380,"Sister,"],[4540,4736,"I was just upset earlier."],[4764,4844,"I didn't mean it."],[4952,5068,"I'm really sorry."],[5124,5432,"See, your sister is apologizing."],[5456,5668,"She's being so understanding."],[5760,5940,"Please forgive her."],[6088,6192,"I'll forgive you."],[6292,6560,"As soon as you and your family"],[6600,6808,"pack up and leave this house."],[7092,7184,"We'll move."],[7184,7380,"Just give us some time to pack."],[7512,7628,"You have one day."],[7712,7976,"I'll be back tomorrow to reclaim the house."],[8980,9048,"Tom,"],[9096,9284,"what are we going to do now?"],[9468,9512,"Mom,"],[9656,9780,"why does the Smith family"],[9780,9932,"have a marriage pact with Leah?"],[10000,10144,"Leah's father once"],[10144,10284,"saved the Morgan’s life."],[10544,10612,"Perfect."],[10728,10900,"We'll go to the Smith family"],[10964,11060,"and make them settle"],[11060,11292,"the inheritance dispute in our favor."],[11328,11464,"They won't help us."],[11464,11620,"They will side with Leah."],[11748,11940,"According to the marriage pact,"],[11940,12200,"now I am the rightful heiress."],[12264,12428,"I'm gonna be the legitimate"],[12428,12528,"Cruz daughter."],[12556,12728,"But the marriage was canceled."],[12784,12908,"That’s just a formality."],[12968,13268,"All we need to do is play our cards right."],[13308,13540,"And the inheritance will be ours."],[13584,13748,"Lamia, stop hesitating."],[13788,13884,"We’re about to be thrown out"],[13884,13964,"on the streest."],[13964,14088,"If you want to survive,"],[14132,14256,"you’ll follow Lisa’s lead."]],"24":[[132,364,"My grandson is the best."],[384,488,"Look at this."],[528,684,"He met the eldest daughter"],[684,828,"of the Cruz family once."],[892,1112,"They already registered the marriage!"],[1348,1508,"A marriage certificate?"],[1524,1640,"Where did you find this?"],[1652,1816,"We found it while snooping around"],[1816,1940,"in Dexon’s office."],[2304,2384,"I don't know."],[2468,2724,"Something still feels off."],[2756,3004,"Knowing Dexon, he would never agree"],[3004,3172,"to a family arranged marriage."],[3172,3464,"So why would he, now..."],[3580,3796,"It means that Dexon has matured."],[3804,3952,"Finally, he knows what it means"],[3952,4120,"to honor my wishes."],[4164,4304,"That’s because you're out of the loop."],[4324,4464,"They knew each other beforehand."],[4508,4664,"Yeah, we've met the Cruz girl before."],[4696,4772,"She's pretty nice."],[4800,4868,"Nice?"],[4996,5180,"We talking about the same person?"],[5208,5368,"Because last time"],[5368,5572,"Mark paid a visit to their place,"],[5572,5732,"he didn't exactly have anything"],[5732,5940,"nice to say about her."],[6000,6204,"Are you questioning my judgment?"],[6236,6360,"Mark’s been working"],[6360,6484,"for Dad for years."],[6504,6792,"His judgment isn't exactly bad either."],[7016,7092,"Enough."],[7184,7296,"They're already married."],[7424,7552,"Old Cruz is gone."],[7632,7680,"But"],[7856,8016,"she must have a mother somewhere,"],[8036,8072,"right?"],[8228,8384,"Mark's been to their place."],[8404,8704,"You can call him in and get him to confirm."],[8868,8912,"But"],[9016,9164,"something still doesn't feel right."],[9964,10092,"Uncle Morgan."],[10164,10360,"Do you still remember me?"]],"25":[[76,144,"Lamia."],[392,504,"What brings you here?"],[700,940,"This is my husband, Tom."],[972,1048,"Mr. Smith."],[1128,1368,"Well, no need for formalities."],[1368,1484,"We are family now."],[1600,1672,"Sit down."],[1740,1836,"Family?"],[1876,2016,"I thought the marriage agreement"],[2016,2144,"was canceled."],[2172,2332,"Did I get it wrong?"],[2440,2596,"Yes, yes!"],[2596,2692,"Family."],[2812,2944,"Yes, yes."],[3000,3068,"Family."],[3224,3480,"Well, you came for a reason."],[3580,3632,"Speak."],[4140,4232,"Uncle Morgan."],[4260,4480,"After Mr. Cruz passed away,"],[4560,4880,"he left behind an inheritance."],[4920,5284,"And there's been some disagreement"],[5284,5476,"among the children over"],[5476,5704,"how it should be distributed."],[5744,6172,"So I was hoping you could help."],[6344,6528,"Maybe you can help."],[6768,6940,"Inheritance disputes?"],[6996,7064,"Well."],[7064,7372,"But I don't meddle in other people's"],[7372,7480,"family business."],[7732,7844,"My husband"],[7896,8256,"fell gravely ill before he passed."],[8384,8628,"His mind became muddled,"],[8628,8736,"and he..."],[8852,9096,"forgot to include my name in the will."],[9216,9516,"So who did he leave the inheritance to?"],[9528,9600,"His cold,"],[9700,9816,"heartless,"],[9876,10072,"and selfish daughter."],[10104,10184,"Heartless?"],[10212,10292,"Selfish?"],[10496,10576,"Lamia."],[10576,10776,"Do you understand the consequences"],[10776,11024,"of lying to someone like me?"],[11148,11364,"Mr. Smith, we wouldn't dare lie to you."],[11404,11548,"Lamia is telling the truth."],[11572,11784,"Well, then tell me."],[11800,12028,"How many daughters does Mr. Cruz have?"]],"26":[[108,160,"One."],[232,332,"No two."],[356,428,"Yes, yes!"],[428,596,"Two daughters, two."],[968,1388,"So which one is my grand daughter-in-law?"],[1404,1620,"And why isn’t she here today?"],[1812,2028,"She was overwhelmed"],[2028,2288,"by the stress of the inheritance dispute."],[2312,2456,"And it's made her ill."],[2456,2652,"She's resting at home."],[2796,2996,"She is recovering right now."],[3116,3416,"Two daughters and one wife."],[3524,3980,"It seems old Cruz did lose all his faculties"],[3980,4080,"before he passed."],[4120,4228,"Uncle Morgan."],[4300,4460,"We didn't want to trouble you."],[4520,4716,"But we've run out of options."],[4952,5064,"It's okay, Lamia."],[5092,5144,"It's okay."],[5340,5436,"I understand."],[5468,5544,"Don't cry."],[5928,5980,"Henry,"],[6028,6140,"help Mrs. Cruz."],[6188,6388,"Oh, wait, Tom."],[6440,6572,"What is your surname?"],[6608,6764,"Weiss. Tom Weiss."],[6800,6944,"Assist Mrs. Weiss"],[6944,7268,"with the division of Mr. Curz’s inheritance."],[7420,7532,"Isn't that..."],[7604,7756,"a bit inappropriate, Dad?"],[7908,8184,"Mr. Cruz saved my life."],[8196,8304,"His daughter is going to be"],[8304,8540,"the future matriarch of the Smith family."],[8668,8828,"How is that inappropriate?"],[9116,9272,"Thank you, Uncle Morgan."],[9272,9420,"Thank you so much."]],"27":[[832,980,"I wish Allen were here."],[1780,1924,"When did you get here?"],[2240,2396,"Massaging your shoulders,"],[2444,2576,"warming your bed..."],[2672,2836,"Isn’t that what a pampered little canary"],[2836,2960,"like me should be doing?"],[3264,3432,"First of all, you need my permission"],[3432,3540,"to get on my bed."],[3792,3992,"Why? I thought you were feeling down"],[3992,4092,"and thought I'd surprise you."],[4152,4268,"What's the problem?"],[4572,4708,"Don't underestimate me."],[4756,4836,"I might be a canary,"],[4836,4984,"but I have my connections."],[5076,5216,"I can smooth over your troubles."],[5304,5376,"It's fine."],[5408,5496,"I can handle it."],[5612,5672,"Then..."],[5748,5852,"How about we comfort each other"],[5852,5944,"in a different way?"],[8280,8332,"Okay."],[8372,8460,"I'm a busy man."],[8484,8604,"But I’ve brought you the best lawyer."],[8652,8716,"Asher."]],"28":[[76,184,"Greetings. I'm Asher."],[224,296,"In my career,"],[296,528,"I've handled over 2700 cases"],[528,656,"without a single defeat."],[704,868,"I'm here on behalf of Mr. Smith"],[868,1052,"to assist with your inheritance issue."],[1188,1308,"With you on our side,"],[1308,1492,"I'm completely reassured."],[1644,1740,"I'll leave this with you."],[3068,3256,"Current evidence is not in our favor."],[3540,3644,"What should we do then?"],[3844,3916,"Relax."],[3940,4116,"No matter who the opposing lawyers is,"],[4116,4236,"I have the skills to make them"],[4236,4356,"accept defeat."],[4512,4620,"Is that so?"],[5000,5088,"Leah, isn't it?"],[5116,5268,"You came to fight for your inheritance"],[5268,5476,"without hiring a professional lawyer?"],[5504,5616,"I'm all the lawyer I need."],[6048,6188,"Here are the records of Lamia"],[6188,6408,"using my money to purchase jewelry."],[6532,6792,"This is proof of Tom illegally"],[6792,6976,"seizing my father's company."],[7096,7208,"And this one"],[7292,7456,"is evidence of Lisa"],[7456,7640,"embezzling my inheritance."],[7744,7984,"Everything complete with photographs"],[7984,8096,"and recordings."],[8244,8408,"And this is my father's will,"],[8408,8620,"with a complete list of assets he left for me."],[8748,8832,"Everything is documented"],[8832,8908,"in black and white."],[9012,9092,"So, Asher,"],[9184,9252,"do you still think"],[9252,9356,"you have a winning chance?"]],"29":[[72,160,"Mr. Asher."],[248,384,"With all your experience,"],[384,512,"you must have a plan, right?"],[672,764,"Leah, I’ll admit."],[784,884,"You’re impressive."],[916,1020,"These documents are"],[1020,1160,"meticulous and thorough,"],[1196,1364,"even surpassing most lawyers."],[1508,1632,"When you've been through what I have,"],[1632,1796,"you learn to protect yourself."],[2004,2084,"Interesting."],[2128,2348,"In all my years, I've never experienced"],[2348,2476,"defeat this thoroughly."],[2540,2620,"Defeated?"],[2684,2924,"Mr. Asher, we can’t give up like this."],[3152,3228,"Do you understand"],[3228,3412,"that I represent the Smith family?"],[3440,3612,"I don't care who you represent."],[3644,3788,"Even if the president himself were here,"],[3788,3924,"my stance wouldn't change."],[3988,4188,"If you understand who I represent,"],[4280,4360,"then you know."],[4596,4752,"I could tear away your inheritance"],[4752,4860,"right here and now"],[4860,5020,"under the Smith's family name."],[5052,5176,"What would you do then?"],[5536,5784,"Leah, you've lost."]],"30":[[160,304,"Smith's family might be powerful,"],[308,468,"but even they should act with reason."],[652,848,"We don't care about the reasons."],[924,1192,"We're going to take all your inheritance"],[1236,1396,"and leave you with nothing."],[1508,1692,"What are you gonna do, sister?"],[1772,1932,"No one will help you,"],[1956,2108,"and no one even dares."],[2316,2424,"It's not my fault"],[2440,2584,"that I'm luckier than you."],[2664,2864,"And I've got myself a place"],[2868,2992,"with the Smith family."],[3236,3356,"Poor thing."],[3380,3724,"Oh, Leah, why don't you just apologize?"],[3756,3960,"If we get the inheritance,"],[3964,4192,"maybe we will be kind enough"],[4196,4360,"to leave you a little."],[4552,4664,"Apologize?"],[4896,4964,"Never."],[5084,5192,"Then get out."],[5452,5504,"All right?"],[5924,6036,"Are you trying to die?"],[6156,6264,"Ladies and gentlemen,"],[6316,6444,"are we really going to harass"],[6448,6600,"my adorable sponsor?"],[6692,6896,"How utterly uncouth!"],[7056,7112,"Allen."],[7152,7288,"You still think you're some kind of"],[7292,7368,"rich playboy?"],[7396,7488,"Look at yourself."],[7552,7700,"And do you know who's backing us up?"],[7820,7972,"The Smith family."],[8100,8184,"Smith family, huh?"],[8304,8512,"And who is representing them?"],[8616,8688,"Of course."],[8692,8756,"It's a..."],[8928,8996,"It's not me."],[9076,9260,"Not me... I'm not qualified."]],"31":[[52,212,"Asher, what's going on?"],[252,356,"Are you scared of him?"],[432,580,"He's just a broken nobody."],[684,804,"Why is he afraid of him?"],[876,972,"I'm sorry."],[1036,1140,"I won't dare anymore."],[1236,1316,"I won't dare."],[1404,1528,"Why are you scared?"],[1592,1684,"Just a broken nobody,"],[1792,1928,"not Dexon Smith."],[2004,2144,"I don't kill people"],[2172,2260,"for no reason."],[2276,2456,"Sir, I understand."],[2616,2740,"I'll do anything you ask."],[2796,2896,"Just spare me."],[3008,3100,"Don't make me tell you"],[3100,3244,"how to do your fucking job."],[3612,3660,"Leah!"],[3760,3840,"I'm sorry."],[3940,4052,"I deserve to die."],[4088,4152,"Asher, please."],[4152,4260,"You don't have to do this."],[4304,4492,"This is between me and my family."],[4492,4644,"It's really not your problem."],[4644,4684,"Miss,"],[4728,4836,"can you forgive me?"],[4872,4996,"I was blind to the truth."],[5016,5136,"Yes, yes, I forgive you."],[5136,5232,"Please, stand up."],[5272,5428,"Sir, may I?"],[5532,5616,"Get lost."],[5648,5812,"Thank you! Thank you both!"],[5952,6064,"I don't think the Smith family"],[6064,6180,"will interfere in this again."],[6316,6476,"But if you want their heads on a platter,"],[6596,6700,"just say the word."],[7500,7664,"Awaiting your orders, Miss Cruz."]],"32":[[40,180,"Allen, what are you doing?"],[204,320,"A little revenge for you."],[364,424,"What do you think?"],[456,532,"Do you like it?"],[1236,1392,"Tell them to put the guns down."],[1436,1484,"Why?"],[1556,1724,"After everything they've done to you,"],[1772,1948,"surely they deserve to die."],[1956,2148,"I told you, I despise the Mafia."],[2148,2232,"If you act like this,"],[2232,2420,"how are you any better than those thugs?"],[2668,2748,"Put the guns down."],[3120,3280,"Leah, I did all of this for you."],[3280,3428,"Why can't you understand that?"],[3576,3656,"Please leave."],[3728,3908,"No one dares speak to me that way."],[3960,4052,"Except you."],[4288,4372,"Page one,"],[4380,4540,"clause one of the contract."],[4824,4960,"The canary must obey"],[4960,5100,"his master's commands."],[5148,5208,"Leave."],[5300,5372,"Fine."],[5740,5808,"Allen,"],[5808,5888,"I'm sorry."],[5984,6108,"They’re still my family."],[6108,6240,"I can't destroy them."]],"33":[[68,176,"I'm not heartless."],[240,424,"I'll leave you 10% of my father's inheritance"],[424,548,"so you can support yourselves."],[936,1016,"Sign this."],[1044,1248,"And once you do, we're done."],[1340,1464,"No more ties between us."],[1772,1892,"Are you mocking us?"],[1984,2084,"Think whatever you want."],[2792,2924,"How dramatic, Leah."],[3020,3216,"Did you hire Allen and all these actors"],[3216,3368,"with toy guns to scare me?"],[3428,3652,"You can fool Asher, but not me."],[3704,3980,"That inheritance is rightfully mine!"],[4004,4080,"You got it?"],[4228,4312,"Leah."],[4340,4544,"Leah, do you know how hard"],[4544,4700,"it was to raise you?"],[4744,5024,"And now you throw this measly sum"],[5024,5188,"at your own mother?"],[5236,5548,"You humiliated us in front of strangers."],[5580,5740,"You ungrateful brat!"],[5768,6056,"We never should have raised you, you filthy..."],[6440,6492,"Go on,"],[6584,6664,"keep talking."]],"34":[[320,392,"Actors?"],[452,540,"Toy guns?"],[572,768,"Anyone want to test that theory?"],[856,1080,"So I wasn’t your family obvioulsy."],[1252,1396,"That's what you really think of me?"],[1472,1608,"Then I won't hold back anymore."],[1820,2008,"This last file contains a detailed account"],[2008,2128,"of every dollar spent"],[2128,2256,"from my father's inheritance,"],[2292,2732,"totaling 284,210,500 dollars and five cents."],[2968,3096,"Leah, just say the word."],[3132,3300,"Anything you want, I'll make it happen."],[3436,3516,"Fine me a lawyer."],[3540,3712,"I want every cent of that money back."],[3812,3924,"Absolutely."],[3984,4052,"First,"],[4160,4276,"let me teach them a lesson."],[4432,4520,"You must die."]],"35":[[1004,1184,"Lisa, you are right."],[1296,1380,"The gun is fake."],[1696,1812,"I made this just for you."],[1876,1980,"A special token."],[2436,2572,"Return the money I want."],[2664,2840,"If you don't, you won't be so lucky next time."],[2868,2920,"What?"],[2964,3264,"No, let me go!"],[3296,3352,"Don’t touch me!"],[3724,3912,"I can walk myself!"],[4904,4984,"Are we..."],[5112,5224,"bankrupt now?"],[5240,5372,"Not just bankrupt."],[5412,5608,"We're drowning in debt."],[5664,5788,"Dad, dad!"],[5816,5916,"You can fix this, right?"],[6008,6060,"Fix it?"],[6088,6216,"Do you know how much trouble"],[6216,6336,"you've caused me?"],[6336,6448,"Are you crazy?"],[6448,6628,"Why did you hit my daughter?"],[6648,6732,"Greedy."],[6732,6900,"The both of you are so greedy."],[6936,7132,"Wasn't 10% enough?"],[7164,7308,"What more did you want?"],[7356,7428,"But Dad,"],[7492,7660,"you agreed with us before."],[7744,7876,"The house is gone,"],[7948,8112,"the money's gone."],[8116,8336,"It's all over. We're finished."]],"36":[[432,588,"Dinner’s ready, Miss Benefactor."],[652,732,"What’ll it be,"],[800,964,"dinner first or me?"],[1240,1340,"Who are you, really?"],[1528,1692,"Why was Asher so terrified of you?"],[1748,1788,"Me?"],[1896,2024,"Your canary, of course."],[2180,2328,"Maybe my acting’s so good,"],[2328,2464,"I played the Mafia boss."],[2676,2920,"Forget dinner, open a bottle of champagne."],[2976,3084,"I need a little buzz."],[4164,4288,"Shall I have some too?"],[4812,4892,"Sweet."],[5364,5464,"I nearly forgot."],[5560,5712,"Dexon is getting married,"],[5820,5920,"and we haven't prepared"],[5920,6028,"any proper gifts!"],[6072,6120,"So,"],[6296,6416,"here's ten properties."],[6468,6556,"Not worth much,"],[6592,6732,"but good enough for them."],[6900,6992,"Jeez, Dad."],[7056,7224,"How am I supposed to impress them"],[7240,7436,"with a few dozen luxury cars"],[7436,7628,"if you're giving them all these properties?"],[7636,7700,"Come on,"],[7720,7928,"a lady from a wealthy family like Miss Cruz"],[7928,8116,"wouldn't care about flashy cars."],[8144,8216,"Exactly."],[8236,8396,"She would appreciate fine jewelry"],[8396,8484,"much more."],[8544,8620,"You’re right!"],[8620,8692,"Good thinking."],[9360,9448,"Hello, everybody."]],"37":[[148,272,"What is that?"],[992,1104,"What are we looking at today?"],[1188,1288,"What agreements... huh?"],[1472,1616,"So, when are you gonna"],[1616,1748,"bring Miss Cruz over for dinner?"],[1864,2092,"We've prepared some wedding gifts for her."],[2496,2572,"Come on, Dexon."],[2572,2780,"We already know you married her in secret."],[2812,2984,"And we're thrilled about it."],[3016,3256,"Yes, just bring her to live with us already."],[3372,3528,"No, it's not time yet."],[3528,3600,"She's not ready."],[3860,4044,"You just don't want us to meet her."],[4176,4268,"No, it's not that."],[4268,4372,"My wife's busy."],[4444,4684,"She can't just drop everything at once"],[4684,4776,"to see you guys."],[4900,5000,"What’s she busy with?"],[5124,5188,"Are you letting"],[5188,5360,"my granddaughter -in-law work?"],[5460,5528,"She's taken over"],[5528,5700,"my father's bankrupt company."],[5868,6008,"Renamed it ‘FLEX Group’."],[6072,6192,"It's doing quite well."],[6264,6372,"And about to go public."],[7452,7644,"With this much debt,"],[7644,7896,"how will we ever pay it off?"],[8184,8308,"Have you heard the news?"],[8360,8560,"Harry's company is going public."],[8584,8820,"Harry? But he's dead."],[8860,9044,"Someone named Brad bought it"],[9044,9240,"and renamed it ‘FLEX Group’."],[9540,9840,"If we can strike a deal with this Brad,"],[9876,10016,"we might have a chance."],[10128,10332,"Lisa, put on something nice."],[10392,10540,"We're going to FLEX Group."]],"38":[[216,388,"A proper canary should not only please"],[388,492,"your benefactor in bed,"],[492,796,"but also help ease all business burdens."],[856,964,"Business burdens?"],[1036,1196,"Doing that business in your office?"],[1284,1344,"Fine."],[1428,1728,"I’ll strip now and wait for you inside."],[1836,2016,"Welcome, Miss Cruz!"],[2040,2128,"What are you doing?"],[2128,2244,"People are watching!"],[2468,2556,"Miss Cruz,"],[2592,2656,"I haven't seen you"],[2656,2804,"since you took over our company."],[2868,2976,"Well, it seems"],[2976,3168,"the business is very well-managed."],[3216,3316,"This is Allen Callis."],[3348,3424,"I'll be appointing him"],[3424,3536,"as the new vice president."],[3536,3748,"He'll be in charge of all final decisions"],[3748,3836,"from now on."],[3864,3960,"Nice to meet you."],[4032,4144,"Dexon Smith?"],[4216,4404,"Oh my god, how is he willing to be"],[4404,4544,"Miss Cruz's subordinate?"],[4676,4736,"Brad?"],[4776,4844,"What's wrong?"],[4984,5064,"Do you know him?"],[5192,5268,"Of course..."]],"39":[[548,756,"I mean... of course not."],[872,1024,"I'll be sure to fully support"],[1024,1084,"Mr. Smi-"],[1488,1676,"Vice President Callis."],[1904,1976,"Great."],[2068,2172,"Come on, Allen."],[2172,2308,"I'll show you around the business."],[2852,2972,"This is insane."],[3132,3204,"Excuse me."],[3424,3720,"Are you the CEO of the FLEX Group,"],[3720,3840,"Mr. Brad?"],[3956,4080,"Yes, that's me."],[4104,4240,"But I don't meet with strangers."],[4464,4612,"Oh, sir."],[4672,4816,"Wasn't Harry the previous owner"],[4816,4912,"of the Flex Group?"],[5056,5196,"The Cruz company used to be"],[5196,5388,"the closest business partners of him."],[5432,5588,"If you check the records, you'll see."],[5632,5708,"Also,"],[5788,5932,"if you want a merger,"],[6028,6180,"we can offer you the lowest prices"],[6180,6300,"in this industry."],[6436,6520,"Lowest prices?"],[6648,6736,"Interesting."],[6908,6984,"But our new VP"],[6984,7124,"will handle those decisions."],[7272,7488,"Could you introduce us to him, please?"]],"40":[[160,232,"Fair warning."],[304,536,"Our new VP has a nasty temper,"],[588,708,"So don't cause any trouble."],[732,816,"Of course not."],[816,960,"We'll be on our best behavior."],[1056,1112,"Good."],[1236,1492,"16th floor, second door on the left."],[1584,1700,"You can go on your own."],[1740,1928,"I am not brave enough to see him again."],[2044,2112,"Come on,"],[2136,2260,"you're the CEO."],[2364,2480,"Why would you be scared of"],[2480,2572,"your own VP?"],[2700,2860,"You'll understand once you meet him."],[3028,3176,"And don't mention that I sent you."],[3212,3416,"I want nothing to do with this mess."],[4404,4552,"And this is your office."],[4744,4828,"What do you think?"],[5804,5900,"What are you doing?"],[5968,6040,"Page one,"],[6084,6220,"clause four of the contract."],[6260,6492,"Canary must relieve stress."],[6564,6800,"Purposely twisting my words, aren't you?"],[6884,7016,"Twisting your words?"],[7168,7296,"Is that what you think?"],[7500,7540,"Hello?"],[7568,7672,"Is the VP in?"]],"41":[[208,384,"Today's your first day as VP."],[488,592,"Show me what you’ve got."],[744,824,"Come in."],[1316,1396,"Allen?"],[1436,1504,"Leah?"],[1812,1944,"What are you two doing here?"],[2104,2236,"So that's why"],[2236,2404,"none of you answered earlier."],[2436,2680,"You two were sneaking around"],[2680,2996,"making love in a vice president's room?"],[3040,3104,"Lisa,"],[3220,3344,"what if I told you"],[3452,3620,"the vice president of this company"],[3704,3776,"is me?"],[3876,3920,"You?"],[4104,4224,"Vice president?"],[4232,4348,"Please."],[4372,4572,"You think I will fall for your tricks again?"],[4612,4780,"You're probably just a janitor"],[4780,4924,"cleaning this office."],[4948,5080,"Get out of that seat!"],[5124,5224,"You're a janitor."],[5224,5312,"You have no business"],[5312,5472,"in the vice president's seat."],[5496,5628,"Watch your mouth, Tom."],[5668,5892,"You don't get to talk to my man like that."],[5956,6068,"So now you don't even call me"],[6068,6180,"‘Dad’ anymore."],[6212,6360,"Let's see how I deal with you both."]],"42":[[32,228,"Leah, how dare you hit me?"],[344,472,"What, one slap isn’t enough?"],[492,616,"You want another one?"],[700,900,"Let's wait untill a real vice president"],[900,968,"comes in."],[988,1204,"I can't wait to see you being dragged out"],[1204,1332,"and humiliated."],[1380,1592,"You and your stupid janitor"],[1668,1888,"will kiss your jobs goodbye."],[2112,2220,"Do you want to know why"],[2244,2376,"you've never been able to beat me"],[2376,2536,"despite all your efforts"],[2536,2676,"to take everything from me?"],[2744,2884,"It's because you don't have a brain."],[2884,2940,"You..."],[2964,3048,"Tell me."],[3096,3216,"Do you think a janitor"],[3260,3444,"would wear a expensive,"],[3444,3728,"tailored suit to work like Allen does?"],[3804,3880,"Oh, please."],[3948,4168,"This is the same guy who staged"],[4168,4496,"that fake scene with actors and toy guns."],[4516,4672,"Nothing will surprise me anymore."],[4728,4968,"By the way, who did you sleep this time"],[4996,5104,"to get this job?"],[5172,5340,"Whose mistress are you this time?"],[5472,5560,"How much longer are you"],[5560,5680,"going to slander her?"],[5976,6120,"Did your hand hurt from that slap?"],[6184,6296,"Don’t worry, I'm gonna make it better."],[6412,6540,"Pretty good at this."],[6604,6696,"How many rich women"],[6696,6820,"have you served before me?"],[6848,6896,"None."],[6896,6996,"You're my first."],[7308,7476,"You two just shut up already?"],[7572,7780,"This is not your personal dating spot."],[8072,8184,"What's all this noise about?"]],"43":[[168,260,"Mr. President,"],[292,480,"it’s these two troublemakers."],[508,732,"They’re sitting in a vice president chair"],[776,1004,"and even assaulted an important guest."],[1212,1312,"Say that again."],[1368,1492,"Who assaulted you?"],[1604,1856,"This stupid janitor and his mistress."],[2180,2288,"Janitor?"],[2324,2548,"That man is our vice president."],[2612,2792,"I apologize for this disturbance."],[2884,3128,"These suppliers must have wandered in"],[3128,3260,"here and started causing trouble."],[3340,3516,"You were absolutely right to hit them."],[3588,3796,"People like this deserve it."],[3820,3876,"Brad."],[3932,4064,"The company's security measures"],[4064,4176,"need improvement."],[4228,4400,"How did two stinky rats"],[4400,4540,"crawl in from the sewers?"],[4596,4692,"You're absolutely right."],[4692,4836,"I'll make the necessary adjustments"],[4836,4928,"immediately."],[5076,5140,"What are you waiting for?"],[5140,5312,"Get these rats out of here."],[5336,5548,"Mr. president, there must be some mistake."],[5548,5656,"Exactly."],[5656,5908,"There’s no way this stupid janitor is a VP."],[5920,6088,"Shut up and get out!"],[6108,6200,"There’s no way..."],[6304,6472,"You’ll regret this!"],[6552,6692,"It’s time to let me go!"],[6768,7028,"Please forgive this incident."],[7100,7188,"It's all right."],[7632,7860,"So where were we?"],[8020,8228,"Well, from what I remember,"],[8296,8484,"a couple of these were already undone."],[8624,8776,"Then why don’t you undo the rest of it."]],"44":[[36,104,"Enough."],[148,296,"If Dexon won't let me meet"],[296,476,"my beloved granddaughter-in-law,"],[588,708,"I'll go find her myself."],[768,1000,"Dad, you don't even know where she lives."],[1028,1140,"How are you gonna find her?"],[1264,1376,"I might be old,"],[1456,1628,"but I'm not senile."],[1700,1820,"Finding someone's address"],[1820,2000,"is child's place for the Smith family."],[2028,2140,"Dad just stop."],[2200,2384,"I think the Cruz girl is upset with us."],[2424,2544,"Even if you go there,"],[2548,2700,"I don't even think she'll see you."],[2732,2992,"But why would she be upset with us?"],[3036,3200,"Well, I mean, think about it."],[3252,3372,"She married into our family,"],[3372,3548,"and we didn't even give her a gift"],[3548,3708,"or host a proper ceremony."],[3740,3856,"Of course, she'd be mad."],[4164,4308,"I guess you got a point."],[4452,4556,"What should we do?"],[4584,4696,"So here's the plan."],[4756,4896,"We spend the next two days"],[4896,5024,"blowing up balloons"],[5024,5152,"and decorating the place."],[5204,5332,"We'll throw Dexon and Leah"],[5332,5468,"a surprise wedding."],[5684,5864,"I don't think this is a good idea."],[5940,6196,"Something still feels odd."],[6412,6604,"Stop talking and use this time"],[6604,6720,"to blow up balloons instead."],[6756,6808,"Okay."],[6868,7100,"Dexon surprised us with a secret wedding."],[7132,7336,"Now it's our turn to surprise him and Leah."],[7540,7612,"Great."],[7632,7744,"That's what we'll do."],[8760,8980,"So... she kept this?"]],"45":[[332,448,"What are you looking at?"],[492,556,"Nothing."],[736,808,"Let me see."],[920,1036,"Let me see!"],[2388,2496,"You got married."],[2532,2660,"Why didn't you tell me?"],[2768,2900,"Allen, let me explain."],[2920,3116,"I guess this sugar baby is out of a job."],[3204,3316,"Allen, relax."],[3396,3520,"Marriage is marriage."],[3556,3680,"Being a boy toy is a completely"],[3680,3752,"different thing."],[3808,3884,"Boy toy?"],[4004,4148,"So I’m your sidepiece now?"],[4220,4472,"If you had to choose between him or me,"],[4500,4604,"who would you pick?"]],"46":[[84,240,"Of course, I'd choose you."],[264,336,"Allen,"],[404,512,"don’t be sad."],[624,844,"One day, I'll explain everything to you."],[1152,1292,"Who knows if you're serious?"],[1392,1524,"I guess a canary like me"],[1524,1696,"can’t dream of being the real deal."],[1764,1864,"You don't believe me?"],[1976,2028,"Fine."],[2108,2248,"I'll go divorce him right now."],[2416,2492,"Oh oh.."],[2524,2640,"I pushed it too far."],[2692,2896,"No, that's, that's unnecessary."],[2992,3132,"Being my sugar baby"],[3132,3268,"means you need to feel secure."],[3288,3456,"I'm going to prove that to you right now."],[3536,3632,"Leah, wait!"],[3648,3788,"I'm fine being the sedepiece."],[4564,4700,"I can’t wait to see how romantic"],[4700,4856,"the wedding will be when Dexon and Leah"],[4856,4912,"show up."],[4960,5048,"Right."],[5048,5272,"I'm sure he's going to be crying tears of joy."],[5320,5416,"Seriously?"],[5932,6056,"What are you guys doing?"],[6200,6256,"Nothing."]],"47":[[160,268,"Enough nonsense."],[268,404,"Leah's going to be here soon."],[472,568,"If she asks,"],[616,756,"tell her I left the country."],[756,804,"Got it?"],[836,1008,"Dexon, what kind of trouble"],[1008,1136,"have you gotten yourself into?"],[1160,1396,"If you have made my granddaughter angry,"],[1452,1608,"I'm going to break your legs."],[1608,1676,"Grandpa."],[1676,1856,"You didn't cheat on her, did you?"],[1896,1960,"No!"],[1984,2060,"Jesus christ."],[2124,2272,"I knew this was going to be happen..."],[2432,2560,"Are you serious?"],[2628,2716,"Enough!"],[2760,2972,"Just say I'm not here,"],[2972,3144,"and keep your mouth shut"],[3144,3272,"about who I really am."],[3368,3464,"I'll explain later."],[4272,4356,"Where's Dexon?"],[4560,4744,"He’s out of the country."],[4752,4852,"Why do you ask?"],[5124,5216,"Wait a minute."],[5308,5516,"I've seen the two of you"],[5516,5628,"before somewhere."],[5820,6004,"You're the two rich ladies"],[6004,6180,"that were trying to sponsor Allen."],[6288,6444,"What are you doing in Dexon's house?"],[6564,6816,"We shouldn't be here?"],[6816,7052,"Yeah, actually, I think we should leave."],[7128,7200,"Hold on."],[7408,7560,"Something is off."],[7836,8028,"You're not telling me something."],[8540,8684,"And I'm going to find out what it is."]],"48":[[76,196,"Yeah."],[196,388,"Something's not right."],[480,608,"You're not right."],[672,800,"None of you are."],[820,1128,"I mean, this is just ridiculous."],[1132,1252,"You misunderstand."],[1268,1384,"What did I say? - I didn’t to anything!"],[1392,1536,"One at a time!"],[1824,2000,"Shut up and let me think!"],[2196,2260,"Okay."],[2400,2444,"So."],[2844,3204,"You. Allen's grandpa,"],[3276,3628,"but also the Smiths family's gardener."],[3672,3768,"Sure."],[3768,3880,"Technically speaking."],[3880,3956,"Sure."],[4236,4812,"You, Allen's creditor, but also Dexon's uncle."],[4888,4960,"Facts."],[5208,5388,"So, by this logic..."],[5432,5584,"Finally, it's our turn."],[5608,5956,"You two are Allen's backers"],[5956,6120,"which means you would be"],[6120,6316,"the Smiths family’s..."],[6332,6632,"Yes. Go on, spit it out."],[6728,6796,"Got it."],[6824,7108,"You are the Smiths family's nannies,"],[7108,7200,"aren’t you?"],[7288,7388,"Damn, rich people."],[7388,7540,"Even the nannies are loaded."],[7552,7832,"Uh… kid, I think you're a little off here."],[7912,8144,"Yeah. See, let me explain. So..."],[8144,8332,"Nope. I didn't come here for this."],[8332,8412,"Where’s Dexon?"],[8472,8640,"I don't believe for a single second"],[8640,8820,"that he happened to be out of town."],[8976,9068,"Get him out here."],[9192,9276,"Now!"]],"49":[[212,312,"Come on now."],[336,452,"Let's talk things over."],[532,732,"There's no need to get so angry."],[748,888,"There's nothing to talk about."],[888,1056,"Just call Dexon out here."],[1248,1332,"I warn you."],[1452,1608,"I'm not someone to mess with."],[1688,1800,"Let go of me, grandpa."],[1800,1952,"I don't hit the elderly."],[2488,2604,"Come on, jump already!"],[2604,2780,"If you don't, we won't be able to help you."],[2780,2952,"Auntie, it's the third floor."],[2952,3144,"Less talking, more jumping!"],[3144,3200,"No!"],[3236,3300,"Hurry up!"],[3300,3468,"If she catches you, you're done for."],[4336,4416,"What was that?"],[4652,4884,"Oh, it was... Windy."],[4884,5040,"We're just closing the window"],[5040,5188,"to keep us from catching a cold."],[5192,5232,"Yeah."],[5232,5364,"And I... I was helping."],[6092,6168,"Leah."],[6168,6404,"No matter why you're looking for Dexon,"],[6480,6768,"I, as the most trusted gardener"],[6768,6916,"of the Smith family,"],[6996,7120,"I have something to say to you."],[7256,7332,"Go ahead."],[7356,7568,"Well, I understand that"],[7568,7856,"every girl dreams of a grand wedding."],[7860,7972,"I know you're upset"],[7972,8160,"because Dexon didn't give you that."],[8220,8372,"No. That's not."],[8372,8452,"Hold on."],[8452,8616,"Let me finish, right?"],[8760,8860,"To make it up to you,"],[8892,9108,"we prepared a wedding ceremony"],[9108,9192,"for you,"],[9208,9384,"at FLEX Hotel tomorrow."],[9556,9824,"Oh, no no no no, I..."],[9824,10040,"I came here to divorce Dexon."],[10140,10248,"Divorce?"]],"50":[[32,96,"Leah."],[96,256,"Couples fights sometimes."],[256,360,"It's normal."],[380,520,"You don't have to take it this far."],[540,764,"Yeah, just take some time to cool off,"],[764,928,"and it should be okay."],[1132,1260,"Leah, listen."],[1260,1504,"I have known Dexon since he was a boy."],[1544,1664,"His life has been..."],[1692,1764,"tragic."],[1780,2032,"Actually, he told me not to say anything."],[2032,2344,"But you absolutely can’t divorce him."],[2468,2624,"What doesn’t he want you to tell me?"],[3484,3584,"Grandpa."],[3584,3784,"Does Dexon have a terminal illness?"],[3976,4144,"No, it's not that."],[4284,4492,"Actually, yes."],[5080,5388,"Dexon does have a tragic backstory"],[5388,5596,"and is terminally ill."],[5596,5684,"As his uncle,"],[5784,5932,"I would know better than anybody."],[6016,6300,"All we want is for him to be happy"],[6300,6420,"and have a wife."],[6452,6524,"Right!"],[6524,6824,"And I can testify as one of his..."],[6876,6964,"caretakers."],[6964,7092,"Please don't divorce him."],[7132,7280,"You guys are perfect for each other."],[7404,7724,"So if I stay married to Dexon,"],[7748,8068,"I'll inherit the entire Smith family fortune,"],[8084,8224,"pay off Allen's debts,"],[8228,8360,"and even gather enough money"],[8360,8540,"to buy back my father's company."],[8572,8704,"This works out perfectly."],[8744,8868,"I understand."],[9036,9152,"I'm guessing Dexon told you"],[9152,9288,"to tell me all of this."],[9400,9520,"I don't want to cause any trouble"],[9520,9672,"or risk your jobs."],[9836,9928,"Good girl."],[9948,10056,"So considerate."],[10104,10232,"Not exactly."],[10292,10408,"I'll attend the wedding."],[10552,10668,"But I have one condition."],[10732,10812,"And what is that?"]],"51":[[68,236,"The wedding should be simple."],[236,516,"No hotel weddings, no grand ceremony,"],[516,684,"no unnecessary guests."],[816,920,"Can you arrange that?"],[1056,1300,"Oh, well, as most trusted gardener"],[1336,1444,"of the Smith family,"],[1444,1604,"and since you're helping us"],[1604,1720,"save on expenses,"],[1784,1876,"I can do that."],[1992,2192,"As long as Allen doesn't find out,"],[2236,2456,"everything will go smoothly."],[2516,2604,"Alright."],[2668,2748,"I'll be there."],[3080,3200,"I'll go prepare now."],[4008,4188,"See? I told you."],[4188,4380,"All she wanted was a proper wedding."],[4428,4572,"Did you see how happy she was"],[4572,4680,"when I mentioned it?"],[4724,4928,"You really did a great job, father."],[4960,5260,"You played the role of gardener perfectly."],[5352,5444,"I don't know."],[5484,5620,"Something still feels off."],[5724,5800,"What's off?"],[5828,5976,"It means Leah and Dexon made up."],[6004,6168,"Yeah, we are amazing."],[6492,6572,"Oh. Wait."],[6572,6656,"Wait a second."],[6656,6776,"I almost forgot."],[6868,7100,"We're holding a wedding tomorrow."],[7124,7316,"Shouldn’t we inform her family?"],[7624,7708,"Mark!"],[7904,7960,"Yes, boss."],[7988,8152,"Get all the most valuable gifts"],[8152,8260,"that we have"],[8340,8560,"and deliver the invitation to her family."],[8664,8756,"Boss,"],[8788,8996,"are you sure about making such a..."],[9052,9152,"difficult woman"],[9224,9440,"the future leader of our family?"],[9668,9924,"You're my most trusted assistant."],[10084,10264,"Are you doubting my judgment?"],[10424,10592,"No. I apologize."],[10704,10904,"Less talk, more action."],[11036,11092,"Understood."],[11684,11880,"This Lisa woman doesn't seem fit to"],[11880,12056,"be the future head of the family."],[12088,12268,"Is the boss losing his touch?"],[12580,12716,"They almost killed me."],[13080,13168,"Allen?"]],"52":[[92,200,"What are you doing here?"],[300,476,"I'm just here to pay my debt."],[476,612,"There's still some left."],[720,808,"Are you hurt?"],[864,996,"Did somebody bully you?"],[1128,1176,"Let’s go."],[1176,1276,"We'll settle this right now."],[1276,1412,"No. It's nothing."],[1496,1676,"Smiths are just a bit difficult."],[1848,1920,"By the way,"],[2028,2120,"how did your talk about"],[2120,2240,"divorcing Dexon go?"],[2340,2492,"Oh, he's out of town."],[2688,2768,"That's good."],[2820,2868,"Great."],[2936,3020,"Great?"],[3068,3224,"Shouldn't you be disappointed?"],[3308,3492,"Why are you so happy about it?"],[3852,4048,"Don't tell me you like being the second man."],[4108,4224,"No, it's not that."],[4288,4416,"It's just like you said,"],[4460,4656,"a sugar baby should know his place."],[4688,4880,"So, the arrangement suits me. Just fine."],[4980,5044,"Okay."],[5096,5228,"As long as you understand."],[5264,5376,"By the way,"],[5472,5576,"what did they tell you?"],[5760,5828,"Nothing."],[5852,5956,"Absolutely nothing."],[6160,6284,"Hang in there, Allen."],[6336,6536,"Once I secure the inheritance,"],[6552,6764,"you will get a promotion to husband."],[6876,7044,"Why do I feel like something bad"],[7044,7120,"is going to happen?"]],"53":[[252,380,"So Pretty."],[508,844,"10 mansions, 20 luxury cars."],[888,1028,"And here is your jewelry"],[1028,1108,"and wedding dress"],[1108,1204,"you're going to wear tomorrow."],[1316,1404,"Oh my god!"],[1452,1644,"Mr. Smith really wants to marry me."],[1788,1928,"I'm finally going to marry"],[1928,2048,"into a wealthy family."],[2124,2200,"Miss Cruz,"],[2236,2456,"The Smith family doesn't tolerate"],[2456,2644,"any gold digger"],[2644,2828,"or reckless behavior."],[2828,3056,"So, please act accordingly."],[3092,3288,"Mark, you're just an assistant."],[3316,3444,"Who gives you the right"],[3444,3704,"to criticize the future Mrs. Smith?"],[4052,4100,"Alright."],[4100,4228,"If there's nothing else,"],[4228,4384,"I'm going to take a leave."],[4904,4988,"Lisa, Lisa."],[5020,5172,"Did you hear him calling you"],[5172,5304,"Miss Cruz just now?"],[5408,5588,"Aren't you afraid your lie"],[5588,5780,"about impersonating your sister?"],[5820,5944,"We'll be exposed."],[6040,6120,"Afraid?"],[6168,6268,"Of what?"],[6316,6420,"From now on,"],[6460,6624,"I'm the real Miss Cruz."],[6744,6820,"Leah."],[6844,7120,"As soon as I become Mrs. Smith."],[7224,7516,"I'll make sure you're out of the picture"],[7516,7600,"forever."],[9312,9496,"Hey, what's the rush?"],[9612,9748,"I was hoping for a little morning review"],[9748,9924,"with my favorite classmate."],[9980,10044,"Next time."],[10068,10228,"I have something really important today."],[10428,10552,"What's more important than me?"]],"54":[[120,284,"Mr. Callis, today you're going to"],[284,412,"stay put in your cage"],[412,568,"like a good little canary."],[2120,2260,"There's something you're not telling me."],[2444,2536,"Is there someone else?"],[2628,2732,"Another canary?"],[2916,3068,"Don't be ridiculous."],[3296,3368,"When the time is right,"],[3368,3520,"I'll tell you everything."],[3596,3656,"For now,"],[3736,3808,"just rest."],[5152,5232,"Leah?"],[5280,5388,"Why are you locking the door?"],[5388,5544,"Allen, relax."],[5596,5740,"You're the only one I love."],[5784,5928,"Just wait for the good news."],[6008,6108,"Leah!"],[6856,7020,"Oh, wonderful."],[7092,7256,"It looks like I'll finally have"],[7256,7412,"some great-grandkids."],[7456,7532,"Right."],[7564,7864,"Dexon's going to look so handsome today."],[7944,8156,"Dad, the stage is almost ready."],[8156,8268,"We're going to start soon."],[8428,8532,"But, Henry,"],[8532,8696,"why haven't I seen Dexon yet?"],[8760,9004,"Didn't you tell him the wedding is today?"],[9072,9284,"Wait, you didn't tell him either?"],[9312,9548,"Hold on. Did nobody tell him?"],[9628,9792,"Weren’t we trying to surprise him?"],[10348,10400,"Hello?"],[10468,10532,"What?"],[10636,10760,"I'm getting married?"],[10884,10984,"I did not know this."],[11496,11696,"Boss, the wedding is about to start."],[11740,11832,"We got to move now."]],"55":[[96,160,"Miss Cruz,"],[216,332,"You look stunning today."],[348,408,"Thank you."],[408,548,"Congratulation."],[576,752,"Marrying into the Smith family,"],[816,900,"this is a dream come true"],[900,1016,"for so many girls."],[1052,1108,"Oh, yes."],[1132,1372,"Lisa is my favorite daughter."],[1420,1580,"Now that she's suddenly"],[1580,1684,"getting married,"],[1712,1900,"oh, I can't help feeling a bit..."],[1968,2168,"a bit sentimental."],[2168,2248,"Oh, mom."],[2328,2484,"Thank you. - My baby."],[2508,2636,"Well, cheers to that."],[2704,2780,"Oh, yeah."],[2780,2888,"Thank you for coming."],[2912,3044,"Cheers!"],[3184,3280,"Excuse me."],[3360,3480,"Could you tell me where Mr. Smith’s"],[3480,3656,"wedding is being held?"],[3996,4084,"Leah?"],[4336,4408,"Lisa."],[4464,4596,"What are you doing here?"],[4772,4900,"Who are you getting married to?"],[4980,5180,"Obviously Dexon Smith."],[5260,5360,"And what about you?"],[5436,5584,"Who's the poor fool"],[5584,5724,"that you snagged this time?"],[5772,5916,"What a coincidence."],[5916,6100,"It seems like we have the same groom."],[6160,6324,"I'm getting married to Dixon Smith, too."],[6388,6440,"Wait."],[6468,6620,"Why are there two brides?"],[6648,6768,"And they’re sisters."],[6800,6920,"They're both aiming to marry"],[6920,7032,"into the Smith family."],[7172,7228,"Leah,"],[7312,7532,"this is your sister's wedding"],[7532,7808,"and you should be congratulating her,"],[7808,7940,"not causing trouble."],[7968,8052,"Interesting."],[8076,8224,"Because this is my wedding too."],[8244,8408,"Why aren't you congratulating me?"],[8476,8592,"You..."],[8696,8840,"Miss Cruz, are you ready?"],[8840,9036,"We need to rehearse the ceremony process."],[9060,9180,"Yes. I'm ready. - Yes. I'm ready."],[9324,9456,"What the hell are you doing?"],[9504,9648,"I'm the real bride here."]],"56":[[132,200,"Funny..."],[200,420,"because I could swear you’re just a fake."],[600,656,"Leah."],[808,1032,"How long you will keep fighting with me?"],[1092,1284,"Why are you being so malicious?"],[1332,1420,"Miss Cruz?"],[1464,1664,"Let's not waste time on people like..."],[1756,1820,"this."],[1868,2020,"Come now, let's move on."],[2068,2224,"Mr. Smith wouldn't want you"],[2224,2500,"to be so upset on such an important day."],[2532,2684,"Yes. You're right."],[2760,2920,"I appreciate your guidance."],[2948,3016,"By the way,"],[3112,3300,"I'm not that familiar with this venue."],[3372,3500,"Could you escort me, please?"],[3520,3700,"It would be my honor, miss Cruz."],[4336,4468,"Miss Cruz?"],[4556,4752,"Since when did you get my last name?"],[5624,5804,"I've always been Lisa Cruz."],[6104,6260,"Then who’s Lisa Weiss?"],[6340,6484,"That name doesn't ring a bell?"],[6660,6748,"What do you mean?"],[6832,6996,"I don't know any Lisa Weiss."],[7076,7332,"My name is Lisa Cruz."],[7452,7544,"Relax."],[7572,7688,"I'm just curious."],[7768,7872,"Why are you so jumpy?"],[8232,8448,"Oh, look at you."],[8572,8704,"It's shaking."],[8728,8812,"Tell me,"],[8892,9044,"what are you so nervous about?"],[9112,9244,"Why are you shaking so much?"]],"57":[[48,192,"Let go of me!"],[256,356,"Let me go!"],[372,440,"Leah."],[524,588,"Leah,"],[600,852,"do you have to ruin your sister's wedding?"],[900,1024,"Are you alright, Lisa?"],[1392,1584,"You're quite the actress, aren't you?"],[1692,1900,"Well, today, I'm going to expose"],[1900,2172,"to everyone your true colors."],[2200,2484,"How dare you raise your hands"],[2484,2696,"on Mr. Smith's wife?"],[2780,2836,"Guards!"],[2868,2992,"I have one question."],[3068,3188,"How are you so sure that"],[3188,3356,"she's the real Mrs. smith?"],[3432,3544,"Because the daughters of"],[3544,3724,"the Cruz family are refined"],[3724,3848,"and well-mannered."],[3904,4204,"Unlike you, who barges in like a wild animal."],[4208,4300,"Look at her."],[4356,4532,"Decked out in jewels"],[4532,4716,"and a designer wedding dress,"],[4768,4996,"all gifts from the Smith family."],[5096,5272,"What more proof do you need, Leah?"],[5308,5488,"She's just being jealous"],[5488,5716,"because my life turned out"],[5716,5856,"way better than hers."],[5928,6208,"Sam, get this miserable woman"],[6208,6300,"out of here."],[6404,6612,"Every second she stays here,"],[6612,6776,"she ruins my mood."],[7268,7380,"I can walk out on my own."],[7480,7572,"Unlike you,"],[7612,7784,"I don't need to sponge off a man."],[10216,10280,"Leah,"],[10352,10456,"you’re the star of this wedding."],[10540,10604,"If you leave, how can"],[10604,10720,"the ceremony continue?"],[10816,10960,"Allen, what do you mean?"]],"58":[[24,112,"What are you doing here?"],[112,252,"I told you to stay back home."],[308,356,"Let's go."],[440,552,"My lady needs me."],[632,732,"Do you think I would do nothing?"],[792,864,"Don't worry."],[956,1096,"I'll take care of this quickly."],[1752,1804,"Jesus!"],[1872,2032,"Don't worry, don't panic."],[2088,2264,"I'm just here to expose a fraud."],[2376,2524,"If any of you side with her,"],[2552,2776,"I will personally send you to hell."],[2884,2940,"You,"],[3104,3256,"You.. you're Mr. Smith."],[3372,3500,"My deepest apologies,"],[3512,3624,"we've made a mistake."],[3724,3812,"Listen carefully."],[3892,4036,"If you want to keep working with us,"],[4116,4320,"strip that fraud of her wedding dress."],[4368,4428,"Now!"],[4640,4740,"Y...Yes, sir."],[4944,5072,"You're Dexon Smith?"],[5192,5288,"I’ll explain everything."],[5316,5376,"I promise."],[5612,5672,"No!"],[5784,5908,"I'm the real one."],[5948,6084,"I'm the real Mrs. Smith."],[6084,6216,"You had the nerve to"],[6216,6384,"impersonate Mrs. Smith?"],[6388,6532,"You'll regret this."],[6548,6660,"Sam, Sam. There..."],[6660,6856,"there has to be a misunderstanding."],[6876,7056,"Please, please don't hurt her."],[7080,7216,"Stop right there!"],[7388,7640,"How dare you touch Mrs. Smith’s body."]],"59":[[144,288,"She's not Mrs. Smith,"],[364,504,"and she never will be."],[644,820,"Allen, nice outfit."],[820,940,"How many rich women did you"],[940,1120,"have to sleep with to afford it?"],[1244,1328,"What do you think?"],[1408,1612,"I think you and Leah are both frauds."],[1648,1792,"Listen up everyone."],[1844,1932,"Think carefully"],[1932,2144,"before you do anything rash."],[2216,2364,"You don't want to offend the real"],[2364,2608,"Mrs. Smith just for these two frauds."],[2676,2744,"What?"],[2880,3000,"He’s not Mr. Smith?"],[3088,3252,"You all heard that, right?"],[3292,3520,"You all must be idiots and blind."],[3960,4056,"I get that."],[4112,4276,"You must be so jealous that"],[4276,4492,"I'm going to marry into a wealthy family."],[4648,4776,"But have you thought about"],[4812,4948,"what will happen to you"],[5008,5204,"and your stupid pathetic man"],[5276,5496,"when the real Mr. Smith arrives?"],[5676,5948,"You claim to be Dexon Smith’s fiancée."],[6076,6176,"Do you have any proof?"],[6256,6356,"Proof?"],[6532,6652,"Look at my dress,"],[6692,6900,"my elegance, my beauty."],[7044,7264,"Aren’t those proof enough for you?"],[7368,7452,"Of course,"],[7504,7668,"you just feel like a slut."],[7788,7968,"You can't even compare to me."],[8308,8460,"Who is Mrs. Smith?"],[8692,8784,"I don't know."],[8864,8988,"Take a look."],[8988,9084,"What do you see?"],[9180,9264,"Oh."],[9296,9504,"Certificate of marriage,"],[9552,9772,"with Dexon Smith?"],[9876,10000,"Impossible."],[10044,10180,"Where did you get that?"],[11148,11280,"Everyone seems to think that is"],[11280,11556,"a grand honor to marry into the Smith's family."],[11604,11876,"But I'm telling you, I don't care."],[11988,12072,"Leah,"],[12172,12264,"wait a second."],[12396,12480,"Lisa,"],[12564,12684,"in one minute,"],[12744,12944,"I will show you the true meaning of regret."]],"60":[[160,220,"Oh."],[296,480,"I don't even need a one minute."],[512,812,"I'll get you thrown out of here right now."],[916,968,"You’re not worried"],[968,1108,"your lies will be exposed?"],[1180,1352,"You're the ones who should be afraid."],[1440,1568,"Allen, why don't you and Leah"],[1568,1704,"get down on your knees"],[1704,1844,"and lick my shoes?"],[1884,1992,"Maybe then,"],[1992,2212,"I'll spare your worthless lives."],[2280,2380,"Lick your shoes..."],[2484,2628,"I hope you remember those words."],[2900,2968,"Alright."],[3064,3156,"That's time."],[5648,5844,"Mr. Mark, you're finally here."],[5852,5908,"There..."],[6104,6176,"Lisa."],[6236,6308,"Miss Leah,"],[6372,6548,"I sincerely apologize."],[6624,6764,"We've made a terrible mistake."],[6852,7072,"Leah Cruz is the rightful bride"],[7072,7172,"of this wedding."],[7272,7348,"Guards!"],[7412,7564,"Take these imposters away!"],[7636,7700,"No!"],[7700,7784,"Don’t touch me!"],[7884,7956,"Lisa!"],[8136,8228,"Let me go!"],[8244,8300,"Lisa!"],[8612,8704,"Allen,"],[8788,8912,"why did you lie to me?"],[9284,9364,"Actually..."],[9640,9776,"Give this to Leah, please."],[10184,10272,"It's so cute."],[10564,10664,"This is for you."],[10848,10880,"I..."],[10988,11108,"I can’t accept this."],[11416,11624,"You know, I've always liked your sister."],[12060,12188,"I wrote you so many letters."],[12308,12444,"I didn't know Lisa was deceiving you"],[12444,12524,"all along."],[12644,12780,"I just wanted you to stop hurting."],[13236,13296,"Leah."],[13476,13572,"Will you marry me?"],[13772,14036,"Is that Allen or Dexon who’s proposing?"],[14104,14192,"Who do you want?"],[14328,14388,"Allen."],[14460,14512,"So..."],[14628,14792,"Has this canary been promoted to husband?"],[16588,16676,"Let’s go."],[16728,16848,"For our wedding."]]}