{"1":[[767,817,"Welcome in!"],[817,963,"What can I get for you today?"],[1192,1263,"How about a kiss"],[1263,1359,"from the love of my life?"],[1739,1901,"Julian, you're back!"],[2706,2831,"I have a surprise for you."],[2998,3123,"Regina,"],[3707,3841,"will you marry me?"],[3966,4137,"Yes, I will."],[4166,4316,"Of course I will."],[4587,4779,"I've been waiting for you this whole time."],[4792,4963,"Wherever you are, I'll always find you."],[6894,6981,"Julian's gonna be"],[6981,7203,"so happy when he finds out!"],[7503,7557,"Dad!"],[7557,7624,"What are you doing?"],[7624,7728,"Don't touch my stuff!"],[7849,7945,"Where'd you hide the money?"],[7945,8062,"Give it to me now!"],[8062,8187,"You're gambling again?"],[8187,8262,"Your debts have nothing"],[8262,8370,"to do with me anymore!"],[8370,8466,"Don't kid yourself!"],[8466,8675,"I took out a loan in your name this time!"],[8675,8837,"You're in this as much as I am,"],[8837,8896,"and if the gangs"],[8896,9013,"don't get their money soon,"],[9013,9096,"who knows what they're gonna"],[9096,9213,"do to you?"],[9705,9793,"No!"],[9793,9855,"Don't touch that!"],[9855,9989,"That belongs to Julian!"],[10001,10139,"Piece of shit, it's not even gold."],[10139,10243,"I don't want this."],[10564,10719,"You are useless, I'm leaving."],[10990,11144,"Look at your life."],[11207,11361,"What a mess."]],"2":[[187,333,"I knew I was right to push you to"],[333,492,"break it off with my son."],[492,563,"Mrs. Brooks,"],[563,679,"what is that supposed to mean?"],[679,930,"Julian is about to join the Navy SEALs,"],[930,1096,"and then he's on to the Pentagon."],[1105,1313,"He has a future in politics,"],[1313,1522,"and you will only drag him down."],[1772,2122,"Two hundred thousand dollars."],[2214,2331,"Pay off your debts,"],[2331,2481,"just break up with him."],[2535,2602,"Please,"],[2665,2831,"just let me talk to Julian."],[3128,3299,"You're pregnant?"],[3407,3595,"It doesn't matter anyway."],[3595,3749,"You get rid of it!"],[3749,3945,"Julian has sacrificed enough"],[3945,4058,"cleaning up your messes,"],[4058,4145,"and I will not let you"],[4145,4262,"drag him down again!"],[4308,4546,"Don't you ever think about going behind"],[4546,4717,"my back either."],[5901,5960,"Hey."],[6056,6147,"Last day of leave,"],[6147,6289,"you wanna go see a movie?"],[6348,6477,"Julian, let's break up."],[6719,6802,"Are you joking?"],[6802,6990,"Because that's not funny."],[7182,7403,"Here."],[7403,7524,"I'm sick of doing long distance"],[7524,7603,"with you."],[7624,7791,"I don't understand."],[7832,7941,"You know I love you."],[7941,8041,"I don't love you."],[8120,8254,"Not anymore."],[8287,8404,"I need someone who's gonna be there"],[8404,8462,"for me."],[8754,8892,"Owen's always there for me,"],[8892,9067,"especially with my dad's debts."],[9125,9355,"He's someone I can actually count on."],[9355,9451,"I'm gonna be with him."],[9513,9655,"I don't understand."],[9680,9809,"Regina, baby,"],[9834,9939,"come on, we're gonna be late."],[9972,10051,"I have to go."],[10064,10126,"No!"],[10247,10297,"This is it?"],[10297,10410,"You're moving on?"],[10456,10543,"When I'm out there in"],[10543,10639,"the middle of the ocean,"],[10639,10769,"you're all I think about."],[10835,10969,"Regina, please."],[11002,11165,"I love you."],[11236,11361,"We're done, Julian."],[11411,11528,"Let go."],[11711,11824,"If you're really done,"],[11824,11936,"then prove it."]],"3":[[108,204,"This dog tag has"],[204,312,"represented everything."],[312,492,"It's there for you when I'm not."],[513,600,"So if you're really done,"],[600,679,"then just throw it away."],[679,821,"Go on, show me it's over."],[3090,3219,"Now do you believe me?"],[3269,3432,"I don't love you anymore."],[3586,3720,"Goodbye, Julian."],[4646,4900,"Regina Scott, you're a heartless woman."],[5634,5801,"I'm sorry, Julian."],[5864,6043,"I have no other choice."],[6143,6239,"Regina,"],[6331,6481,"you should go be with him."],[6598,6685,"His future will be"],[6685,6852,"better without me holding him back."],[7094,7207,"He'll be the Navy captain"],[7207,7290,"of his dreams,"],[7290,7357,"and..."],[7390,7511,"I'll work hard in Belkova to"],[7511,7628,"pay off my debt."],[7628,7761,"Our lives just..."],[7786,7962,"they're on different paths."],[10464,10623,"The Civil War in Belkova is"],[10623,10794,"putting our people at risk."],[10794,10915,"Things are escalating quickly."],[10915,10981,"We need to get our"],[10981,11161,"American citizens out of there."],[11615,11695,"Captain?"],[11695,11886,"I'll lead the mission in Belkova."]],"4":[[0,108,"What are you doing here?"],[108,262,"Aren't you supposed to be on leave?"],[279,462,"I'm a former SEAL, sir."],[462,583,"I know more about rescue missions"],[583,746,"than anyone else in this room."],[767,946,"The situation in Belkova is complex,"],[946,1101,"and I'm the best man for the job."],[1101,1230,"You're the youngest captain here."],[1230,1334,"Don't you think you have something"],[1334,1634,"better to do than go on a rescue mission?"],[1634,1718,"Nothing is more important than"],[1718,1860,"saving American lives, sir."],[2056,2173,"And I have personal reasons for"],[2173,2318,"being on the ground this time."],[2548,2623,"All right."],[2677,2873,"Contact me directly if you need anything."],[2915,2982,"Sir."],[4095,4358,"It's been six years, Regina."],[5613,5768,"Mommy, what's going on?"],[5901,6039,"There's a civil war in Belkova,"],[6039,6218,"so we have to go back to America."],[6218,6318,"And if we stay here,"],[6318,6468,"we could get hurt too, so,"],[6468,6598,"we have to leave now."],[6598,6735,"I hate civil wars."],[6735,6890,"Will we ever get to see my friends"],[6890,7002,"and my teacher again if we"],[7002,7136,"go to America?"],[7136,7265,"Yes, baby, you will."],[7265,7353,"You will."],[7353,7515,"Are we gonna see daddy?"],[7707,7887,"We're done, Julian."],[7887,7987,"Let go."],[8070,8170,"You will, honey,"],[8170,8254,"someday."],[8612,8850,"Dad, when are they coming to get us?"],[8850,8950,"Don't worry,"],[8950,9092,"they should be here today."],[9100,9213,"Captain Brooks is"],[9213,9334,"personally leading the mission."],[9342,9501,"We need to make a good impression."],[9534,9617,"He's like"],[9617,9818,"the hottest guy in DC right now."],[9855,10060,"This is my chance."],[10506,10639,"Hey, Regina,"],[10673,10769,"you can't come in."],[10806,11002,"You're not on the evacuation list."],[11081,11169,"What?"]],"5":[[12,187,"But I submitted all the paperwork."],[225,333,"Blaze is just a child."],[333,383,"He should be on the"],[383,563,"priority of evacuation."],[563,688,"You can't leave us out here."],[688,809,"Things are getting serious."],[834,934,"I'm sorry,"],[934,1109,"but you are just a cook."],[1109,1292,"Embassy staff and their families are"],[1292,1409,"getting priority."],[1463,1659,"You and your son will have to wait."],[1659,1810,"This isn't fair!"],[1810,1989,"Blaze and I, we're American citizens!"],[1989,2227,"We have a right to be evacuated!"],[2227,2427,"I am the daughter of a diplomat."],[2427,2598,"I make decisions here."],[2681,2911,"I really don't wanna be stuck on a plane"],[2911,3061,"with some annoying little kid."],[3061,3098,"No."],[3098,3257,"He'll mess up my sleep schedule."],[3257,3428,"He'll be quiet, I promise."],[3474,3699,"Vanessa, please,"],[3699,3812,"let us in."],[3812,3962,"We just wanna go home."],[4016,4166,"Look, I'll give you everything I have."],[4166,4254,"Just take Blaze."],[4295,4358,"I just want him,"],[4358,4512,"I want him to be safe."],[4512,4767,"Don't touch me with those filthy hands."],[4963,5088,"Was I not clear enough?"],[5121,5363,"You'll need to wait for your turn."],[5376,5513,"Mommy, are you okay?"],[5513,5622,"I don't wanna leave."],[5622,5780,"I wanna be with you."],[5780,5889,"Oh my God."],[5889,6043,"So annoying."],[7152,7282,"Oh my God,"],[7282,7557,"Captain Julian Brooks is really here."],[9743,9872,"Daddy, you're here."]],"6":[[133,329,"Daddy, you're here."],[779,996,"That boy looks a lot like Captain."],[2702,2790,"Are you all right?"],[2894,2977,"Daddy,"],[2977,3078,"this is our home."],[3078,3244,"They won't let us in."],[3311,3390,"What's going on?"],[3516,3782,"Oh, it's not what you think, Captain."],[3812,3866,"This woman is"],[3866,3999,"not on the evacuation list."],[3999,4158,"I am just following the rules."],[4158,4300,"Well, I make the rules now,"],[4300,4412,"and every U.S. citizen"],[4412,4562,"has a right to enter the embassy."],[4562,4754,"So let them in, now!"],[4825,5105,"So happy to see you here again, Captain."],[5159,5305,"This is all a misunderstanding."],[5338,5451,"Regina, come on in."],[5451,5689,"Regina and the kid are coming with me."],[5689,5847,"I need to figure out what's going on here,"],[5847,5955,"and that's an order."],[6001,6097,"Understood, sir."],[6156,6385,"Regina, you know how to behave, right?"],[7244,7357,"You stupid girl!"],[7357,7532,"You got caught red-handed."],[7532,7640,"If Regina tells,"],[7640,7741,"we're gonna be in deep shit!"],[7761,7949,"It's all that bitch's fault!"],[8003,8208,"I'm gonna make her regret this."]],"7":[[296,383,"Thank you, Daddy."],[383,508,"You're my hero."],[508,600,"Blaze,"],[600,725,"stop calling him daddy."],[775,905,"We have to call him Captain."],[905,955,"Okay? -But he"],[955,1180,"looks just like the daddy in my dreams."],[1180,1447,"Mr. Captain is my daddy."],[2085,2206,"How old are you, Blaze?"],[2206,2268,"Four!"],[2331,2431,"He's four."],[2444,2552,"But Mommy, I'm fi-"],[2861,3015,"You had a kid four years ago?"],[3115,3199,"No."],[3199,3307,"Julian,"],[3307,3403,"we,"],[3403,3553,"we had a kid."],[3620,3820,"When he saw me, he called me daddy."],[3883,3995,"Tell me the truth, Regina."],[3995,4070,"Is Blaze my-"],[4070,4241,"Blaze is not your son, Julian."],[4391,4596,"I had him after we came to Belkova."],[4596,4792,"His father was a chef from America,"],[4792,4904,"but he passed away"],[4904,5050,"just before he was born."],[5075,5242,"He calls you daddy because..."],[5330,5476,"he really wants a father."],[5622,5743,"Right, you broke it off with me."],[5743,5935,"Why would you want a kid with me?"],[6018,6085,"Hey, Blaze,"],[6085,6206,"is it okay if I take your"],[6206,6272,"mom for a minute?"],[6302,6360,"Yeah."],[7182,7353,"Captain, what do you wanna know?"],[7353,7474,"If it's about Blaze's father-"],[7474,7674,"I'm not interested in your love life."],[7974,8087,"You're injured."],[8245,8350,"Let's go find a first aid kit."],[8350,8454,"I'll clean you up."]],"8":[[417,704,"Ending things was the right choice."],[704,900,"He's a captain now,"],[900,1113,"just like he's always dreamed."],[1176,1313,"Keep that dry."],[1622,1639,"Why?"],[1639,1760,"Do I have something on my face?"],[1760,1822,"Or"],[1822,1960,"maybe you're finally starting to regret"],[1960,2127,"dumping me all those years ago?"],[2210,2323,"Look,"],[2323,2552,"Captain, I'm sorry for how things ended,"],[2552,2719,"but if you need me to stay, that's fine."],[2719,2798,"Just"],[2923,3086,"please take Blaze with you."],[3269,3449,"Do you have that little faith in me?"],[3645,3757,"Regina, as long as I'm here,"],[3757,4012,"you and Blaze are getting home safely."],[4233,4371,"I gotta ask,"],[4546,4733,"how did you end up in Eastern Europe?"],[4838,5021,"Did Owen not treat you right?"],[5063,5146,"I..."],[5205,5288,"we broke up."],[5363,5463,"I needed a fresh start,"],[5463,5613,"so I came to Belkova."],[5613,5647,"It's my"],[5647,5768,"grandmother's hometown."],[5918,6110,"That explains why I couldn't find you."],[6235,6393,"You were looking for me?"],[6539,6673,"Well,"],[6673,6790,"when a guy gets broken up with,"],[6790,6898,"he's curious."],[6927,7073,"You know, just how she's doing,"],[7144,7253,"if she regrets it."],[7545,7640,"I gotta say Regina,"],[7640,7753,"for a while you made me really"],[7753,7916,"stop believing in love."],[8058,8166,"But..."],[8249,8400,"now I see things haven't been easy"],[8400,8566,"for you either."],[8708,8833,"Yeah."],[8900,9034,"Yeah, you could say that."],[9209,9330,"Here I am, a single mom"],[9330,9542,"stuck in Eastern Europe,"],[9542,9655,"counting on you,"],[9672,9876,"a Navy captain, to get me back home."],[9876,10018,"Does that satisfy you?"],[10072,10185,"If you're done guilting me,"],[10185,10256,"then"],[10289,10402,"I'll be heading to the kitchen"],[10402,10477,"to make dinner."],[10477,10685,"So if you don't mind, we're done."]],"9":[[458,579,"Relax, Regina."],[650,825,"You know it's nothing I haven't seen before."],[1434,1580,"I love you, Regina."],[3132,3232,"Why are you so nervous?"],[3361,3461,"Is there"],[3461,3628,"something you didn't say six years ago,"],[3628,3682,"or,"],[3707,3937,"or is there something between us now?"],[4487,4688,"Captain, there's an emergency."],[4942,5042,"Attention, everyone."],[5055,5171,"The rescue plane scheduled for"],[5171,5426,"tomorrow was hit by a terrorist missile."],[5426,5609,"The White House is now involved."],[5609,5722,"Unfortunately,"],[5722,5822,"due to severe weather in"],[5822,5926,"Eastern Europe,"],[5926,6051,"a replacement plane won't be able to"],[6051,6239,"take off for another five days."],[6277,6377,"In the meantime,"],[6377,6569,"my team and I will be staying with you all."],[6635,6848,"Now, your safety is our top priority,"],[6848,6969,"so please,"],[7002,7077,"remain calm."],[7182,7332,"We're in good hands with you here,"],[7332,7424,"Captain."],[7570,7691,"Regina,"],[7691,7816,"it's almost time for dinner."],[7816,7953,"Let's make something special"],[7953,8149,"for Captain Brooks and his team."],[8571,8717,"I am warning you,"],[8717,8863,"keep your mouth shut,"],[8863,9025,"and stay away from the Captain."],[9063,9171,"If you don't,"],[9171,9321,"I'll make sure you and your son will"],[9321,9480,"never see America again."],[10030,10181,"My daughter's still single."],[10206,10435,"You two are about the same age."],[10481,10731,"I think you'll make a great couple."],[10731,10898,"Truly an honor to share this"],[10898,11002,"meal with you."],[11002,11077,"Thank you."],[11077,11269,"I'm here on a mission,"],[11269,11398,"not on a date."],[11465,11561,"Besides,"],[11619,11832,"I already have my eye on someone."]],"10":[[37,175,"Don't waste your time on me,"],[175,283,"Ms. Thornton."],[283,575,"Come on, it's not like you're married."],[608,863,"I am sure my family background could"],[863,1126,"be a big asset to your career."],[1126,1172,"For me,"],[1172,1447,"love and career are entirely separate,"],[1505,1710,"and it doesn't matter her background as"],[1710,1822,"long as I love her."],[1939,2072,"I'm a soldier,"],[2072,2252,"loyalty is what's important."],[2381,2523,"How did you know that the Captain was"],[2523,2606,"left-handed?"],[2677,2765,"And..."],[2781,2936,"you didn't give him any tomatoes."],[3119,3249,"Do you two know each other?"],[3374,3482,"Crap."],[3482,3636,"I didn't even realize."],[3712,3903,"We're from the same hometown."],[3903,4112,"We've known each other for a long time."],[4112,4333,"Known each other for a long time?"],[4333,4491,"Oh, it's you!"],[4491,4650,"You're the one our boss has never"],[4650,4796,"been able to forget about."],[4796,4959,"No wonder he dropped everything"],[4959,5080,"when he saw the rescue list and"],[5080,5188,"rushed here."],[5276,5338,"Oh."],[5355,5488,"That's ridiculous!"],[5509,5705,"Regina is just a lowly cook,"],[5705,5826,"and a single mom."],[5834,5930,"She came here"],[5930,6085,"running from a pile of debt!"],[6085,6222,"What makes her worthy of being"],[6222,6339,"compared to someone like"],[6339,6402,"the Captain?"],[6402,6581,"Vanessa, watch your mouth!"],[6581,6773,"Ms. Thornton is right."],[6773,6948,"There's nothing between us."],[6998,7086,"We're from completely"],[7086,7186,"different worlds."],[7286,7494,"Now, if you'll excuse me,"],[7494,7678,"I'll be heading back to the kitchen."],[8216,8379,"Let me make this clear."],[8379,8512,"There will be no bullying or"],[8512,8746,"discrimination of any kind while I am here,"],[8746,8983,"especially against Regina!"],[8992,9129,"That is an order."],[9330,9467,"Vanessa, shut up."],[9880,10105,"Julian has a future in politics,"],[10105,10335,"and you will only drag him down."],[10660,10806,"Why'd you deny our past?"]],"11":[[20,141,"Was I that unbearable to"],[141,221,"be with?"],[221,396,"The past is in the past."],[396,513,"Let it go."],[558,704,"There's no point in getting hung up on it."],[704,834,"We're better off as strangers."],[834,1059,"Every little thing that you say or do,"],[1059,1146,"I'm hung up."],[2089,2277,"Why'd you tell daddy that I'm four?"],[2277,2431,"I'm five."],[2431,2644,"Baby, you gotta stop calling him daddy."],[2644,2777,"He's not your daddy."],[2844,3048,"Fine, but can I still play with him?"],[3048,3190,"I like him."],[3190,3370,"Please?"],[3370,3470,"Fine,"],[3470,3645,"but only if he's not busy, okay?"],[3682,3933,"Okay, I'll behave, I promise."],[4033,4179,"I know keeping the truth from"],[4179,4429,"Blaze and Julian isn't fair,"],[4429,4621,"but if I tell them,"],[4650,4850,"I could lose Blaze,"],[4850,5084,"and it might ruin Julian's career."],[5205,5401,"All right, it's time for bed."],[5401,5559,"Mommy still has some work to do."],[6114,6197,"Good night, baby."],[6197,6322,"Good night, Mommy."],[8958,9084,"I double checked, sir."],[9084,9255,"Regina Scott and Blaze Scott are both"],[9255,9438,"placed on the priority rescue list."],[9492,9580,"Got it."],[9617,9705,"But..."],[9705,9834,"that boy,"],[9834,9926,"Blaze,"],[9926,10110,"he looks a lot like you, sir."],[10110,10347,"And you've known Regina for a while."],[10402,10443,"Could-"],[10443,10543,"Watch it."]],"12":[[20,62,"Could-"],[62,162,"Watch it."],[1151,1213,"Is Blaze my-"],[1213,1393,"Blaze is not your son, Julian."],[1455,1580,"You have no idea"],[1580,1776,"how much I wish that wasn't true."],[2102,2339,"I had to switch to room G108."],[2339,2519,"My bathtub's broken."],[2548,2686,"I'm gonna take a bath,"],[2686,2815,"so bring some red wine,"],[2815,2994,"and essential oils to my room."],[3061,3148,"Okay."],[3853,4037,"Just wait until Julian"],[4037,4216,"finds out about this."],[4216,4425,"Soon you'll be known as the bitch who's"],[4425,4696,"trying to seduce his lieutenant."],[5217,5321,"Vanessa?"],[5438,5584,"I brought the wine and the essential oils"],[5584,5697,"you asked for."],[8099,8199,"Julian."]],"13":[[8,87,"Julian."],[567,829,"God, he's even hotter than before."],[1372,1534,"I saw it with my own eyes."],[1534,1768,"Regina snuck in with a bottle of red wine."],[1797,1985,"She's definitely trying to seduce"],[1985,2118,"Lieutenant Phillip!"],[2118,2281,"We need to tell the Captain."],[2302,2515,"The Captain is going to be disgusted"],[2515,2598,"when he finds out"],[2598,2798,"Regina's involved with other men."],[2911,2990,"What are you doing here?"],[3061,3144,"What?"],[3144,3353,"You're not in the room?"],[3353,3507,"Then, then who's in there?"],[3507,3645,"The Captain, of course."],[3645,3749,"This is his room."],[3832,3991,"You say Regina snuck in?"],[3991,4129,"What?"],[4129,4250,"She's got some nerve,"],[4250,4458,"trying to make a move on the Captain!"],[4458,4617,"I can't let that happen!"],[4704,4742,"I mean,"],[4742,4975,"we can't let her ruin his reputation!"],[5201,5321,"Enjoying the view?"],[6539,6740,"What are you doing in my room?"],[6740,6886,"I thought this was Vanessa's room."],[6886,6965,"She asked me to bring-"],[6965,6998,"Shh!"],[7311,7419,"Someone's here."],[7791,7882,"Here it is,"],[7882,7974,"the wine."],[8033,8220,"I knew she was up to something!"],[8233,8420,"You need to do something about it!"],[8420,8612,"Put her in detention or whatever."],[8646,8825,"She's in the bathroom right now!"],[8825,8929,"Go get her!"],[8963,9117,"I'm not seducing you."],[9125,9171,"I-"],[9171,9338,"Regina, come out."],[9338,9522,"Don't make us come get you."],[10268,10402,"Be quiet."]],"14":[[8,154,"Regina, come out."],[154,325,"What are you doing in my room?"],[325,429,"Oh, Julian."],[437,542,"That bitch Regina,"],[542,692,"she's here to seduce you."],[692,892,"I am here to get her out."],[1109,1188,"Regina?"],[1213,1351,"I'm the only one in here."],[1359,1572,"And who gave you the right to barge in?"],[1630,1743,"Leave, now."],[1743,1843,"That's an order."],[1843,1947,"My apologies, Captain."],[1947,1985,"Right away."],[1985,2027,"No!"],[2056,2235,"How is this possible?"],[2235,2344,"I saw her coming in."],[2344,2485,"She must be hiding somewhere."],[2485,2711,"I said get out of my room."],[3182,3253,"Ms. Thornton,"],[3253,3390,"you need to leave."],[3407,3561,"How is it possible?"],[3632,3791,"Are you out of your mind?"],[3791,3970,"Stop embarrassing me in front of"],[3970,4079,"everyone, will you?"],[4104,4237,"Go back to your room!"],[4250,4421,"My apologies, everyone."],[4466,4542,"Regina,"],[4542,4675,"I know you're inside!"],[4763,4938,"I'll be watching you tonight."],[5563,5726,"Can you let me go now?"],[5776,5926,"I need to get back to my room."],[6560,6765,"Vanessa said she'd be waiting for you."],[6765,6848,"So it looks like you're gonna have"],[6848,6961,"to spend the night here."]],"15":[[542,671,"I'll get up early"],[671,767,"in the morning."],[855,1080,"Scout ahead, check if the coast is clear."],[1234,1401,"And I'll sleep on the couch."],[1468,1601,"You can take the bed."],[1801,1997,"I'll, I'll sleep on the couch."],[2027,2177,"It's too small for you."],[2281,2489,"So what, you care about me now?"],[2677,2761,"I'll take the bed."],[2819,2898,"Good night."]],"16":[[829,859,"You know,"],[859,1034,"you can help put the medicine on."],[1063,1234,"And you can look as long as you'd like."],[2456,2560,"This is new."],[2594,2702,"What happened?"],[2752,2852,"Saved someone on the way to"],[2852,2965,"the embassy."],[3082,3215,"Got hit in the back."],[3520,3641,"What about this?"],[3728,3749,"You know,"],[3749,3883,"if you're asking about all my scars,"],[3883,4020,"we'll be here all night."],[4099,4237,"Aren't you tired?"],[4350,4500,"This is a gunshot wound."],[4675,4904,"Who are you to care about me?"],[4934,5046,"I thought it didn't matter to you"],[5046,5176,"if I was alive or dead"],[5176,5376,"the way you abandoned me."],[6210,6468,"Why do you have to be so cruel, Regina?"],[6560,6831,"I'm doing this for you, Julian."],[9613,9768,"Regina,"],[9793,9943,"why do you keep pushing me away,"],[9943,10072,"if you care about me?"],[10301,10372,"We'll form a wedge"],[10372,10502,"to push through any resistance."],[10502,10689,"I need you at the rear covering our six."],[11453,11661,"This kid really looks like the captain."],[11728,11857,"Daddy!"]],"17":[[4,62,"Blaze,"],[62,233,"you can't just barge in here like this."],[233,462,"Don't be so hard on him, he's just a kid."],[525,629,"What's going on, Blaze?"],[629,709,"Daddy!"],[709,817,"Oh, sorry."],[817,996,"Mommy doesn't want me to call you daddy."],[1188,1301,"Blaze is not your son."],[1305,1497,"His father was a chef from America."],[1547,1626,"Sir,"],[1626,1793,"Mommy said I can play with you"],[1793,1910,"when you're not busy."],[1910,2047,"Are you busy right now?"],[2064,2122,"Of course the captain-"],[2202,2289,"Of course not."],[2444,2531,"Philip, get going."],[2531,2702,"Organize the plan we discussed."],[2915,3123,"Captain, this is my favorite toy."],[3123,3290,"I wanted to give it to you."],[3349,3432,"Thank you."],[3674,3812,"Do you like the Navy SEALs?"],[3812,3883,"Of course,"],[3883,4016,"Mommy says the Navy SEALs"],[4016,4095,"are the best."],[4095,4266,"I wanna be a Navy SEAL soldier when"],[4266,4479,"I grow up so I can protect her."],[4479,4587,"Oh, attaboy."],[4954,5030,"How could you let"],[5030,5196,"Regina get away like this?"],[5196,5372,"You are literally useless."],[5463,5534,"We need to get rid of"],[5534,5755,"all these classified files."],[6410,6585,"I think I have an idea."],[7369,7503,"Regina,"],[7503,7732,"my dad needs your help in the courtyard."],[7786,7891,"Right away."],[9901,10047,"There's a file missing!"],[10076,10293,"These files contain sensitive diplomatic"],[10293,10527,"information between the U.S. and Belkova."],[10527,10652,"We need to find it."],[10652,10785,"Everyone, start looking."],[10785,10960,"I found the lost file."],[11023,11161,"It's in Regina's menu."],[11382,11465,"Regina,"],[11465,11715,"I never thought you were a spy."]],"18":[[196,296,"I'm not a spy."],[329,454,"You work in the kitchen,"],[454,604,"the menu's yours too."],[604,775,"The kitchen is a public space!"],[775,905,"Everybody can enter."],[905,992,"By your logic,"],[992,1126,"everyone here is a suspect,"],[1126,1205,"including you."],[1247,1309,"Please."],[1326,1484,"You're the biggest suspect here"],[1484,1622,"because you are the only one who's"],[1622,1760,"desperate for cash."],[1785,1939,"Those documents are worth"],[1939,2106,"hundreds of thousands,"],[2106,2252,"even millions."],[2252,2548,"I get that it's hard being a single mom,"],[2548,2765,"but that's no excuse for treason."],[2798,2869,"Dad,"],[2869,3078,"let's kick her out now."],[3078,3153,"Regina,"],[3153,3332,"explain this, right now."],[3332,3449,"I'm just a cook,"],[3449,3549,"and I love my country."],[3549,3699,"I would never be a spy."],[3891,4041,"You're the one that set me up!"],[4208,4308,"Daddy!"],[4383,4571,"Mommy's in danger."],[4642,4813,"Don't even try."],[4813,4900,"Paul,"],[4900,5096,"hurry up and catch the spy."],[6373,6602,"I'll make you confess with this."]],"19":[[412,579,"Hurt her again and I'll make you regret it"],[579,688,"for the rest of your life!"],[725,863,"Don't hurt my mom!"],[871,1105,"Julian, you hit the wrong person!"],[1117,1226,"Regina's the one hiding our"],[1226,1376,"confidential documents!"],[1376,1488,"She's a spy!"],[1497,1572,"You all right, Regina?"],[1580,1718,"I'm okay."],[1718,1801,"I'm not a spy."],[1801,1939,"Something's going on here."],[2256,2369,"Robert, the file."],[2448,2702,"What is this for, Captain?"]],"20":[[329,458,"There are grease and syrup stains"],[458,521,"on the menu,"],[521,638,"but the file is clean."],[638,829,"That means it was placed in here today."],[863,1042,"I was in the kitchen all day."],[1042,1126,"There's no way I could"],[1126,1251,"get my hands on this file!"],[1931,2022,"There are carrot stains on"],[2022,2152,"Regina's hands,"],[2177,2327,"but the file is clean."],[2389,2515,"That means it wasn't her."],[2652,2952,"Now, as for who our real suspect is..."],[3332,3486,"The file smells like your perfume,"],[3486,3570,"Vanessa."],[4004,4187,"This is Vanessa's perfume."],[4187,4291,"You are the spy!"],[4291,4421,"I didn't do it!"],[4804,4942,"I'm guessing it was just a big"],[4942,5163,"misunderstanding today, Captain."],[5171,5372,"Sorry for interrupting your rest."],[5384,5488,"Regina,"],[5488,5684,"take the day off, get some rest."],[5722,5847,"And you, Vanessa,"],[5847,5989,"you're grounded in your room until"],[5989,6068,"dinner."],[6185,6302,"And not so fast."],[6460,6606,"Apologize to Regina."],[6623,6719,"Me?"],[6719,6923,"Apologizing to a cook?"],[6923,7077,"It's just a misunderstanding."],[7077,7223,"What's the big deal?"],[7236,7432,"And I am the real victim here!"],[7432,7595,"My wrist almost broke!"],[7595,7711,"It wasn't a misunderstanding"],[7711,7761,"when you tried to"],[7761,7957,"stab her with an iron stick!"],[7957,8153,"Don't make the Captain angry!"],[8191,8291,"Fine!"],[8333,8475,"I'm sorry."],[8475,8583,"Happy now?"],[8979,9079,"Mommy,"],[9079,9259,"I went to go get Mr. Captain"],[9259,9434,"when I saw you getting bullied."],[9434,9488,"Next time,"],[9488,9718,"I don't want you to stand up for me,"],[9718,9813,"and don't go bothering"],[9813,9909,"the Captain again."]],"21":[[8,108,"I'm all right, Captain."],[108,187,"You can put me down."],[204,304,"Don't move."],[312,433,"I either carry you like this"],[433,550,"or I throw you over my shoulder."],[550,633,"It's your choice."],[713,905,"This feels just like before."],[905,1042,"There's nowhere in this world more"],[1042,1184,"comforting than here."],[2035,2139,"Captain, really."],[2160,2214,"I'm all right."],[2214,2352,"You don't have to worry about me."],[2352,2435,"I'm not."],[2544,2635,"I'm not worried about you."],[2635,2711,"I'm worried about Blaze,"],[2711,2815,"he almost cried."],[3103,3178,"I'm sorry,"],[3178,3236,"darling."],[3253,3315,"Mommy,"],[3315,3474,"Mr. Captain is worried about"],[3474,3549,"you too."],[3561,3778,"The way he saved you was so cool."],[3787,3937,"Why can't he be my dad?"],[3945,4116,"I want a dad just like him."],[4116,4187,"Okay, stop,"],[4187,4250,"Blaze."],[4517,4662,"The Captain just saved us."],[4696,4859,"We should be thanking him,"],[4859,4967,"instead of calling him your dad."],[4967,5084,"He's not your dad."],[5084,5230,"He'll get mad if you keep doing this."],[5230,5355,"It's very disrespectful."],[5392,5538,"Sorry, Mommy."],[5538,5689,"It won't happen again."],[5905,6018,"I'm not gonna get mad at him."],[6018,6093,"He's a kid."],[6106,6227,"Why, why do you always do this?"],[6227,6398,"Why do you make me to be the bad guy?"],[6673,6785,"Are you trying to purposefully"],[6785,6881,"separate us?"],[6994,7123,"Because I can't let you know"],[7123,7232,"he's your son."],[7248,7428,"That's not gonna do you any good."],[7624,7757,"You're overthinking."],[7828,7907,"He's just energetic."],[7907,8012,"I don't want him bothering you,"],[8012,8083,"that's all."],[8863,8913,"Just..."],[8979,9067,"no more"],[9067,9196,"keeping me from hanging out with"],[9196,9263,"Blaze."],[9330,9417,"End of conversation."],[9417,9488,"Captain-"]],"22":[[4,70,"Captain-"],[1843,2043,"I need to sort things out with Julian,"],[2043,2223,"and stay clear from him."],[2435,2494,"Vanessa,"],[2494,2640,"what are you doing in my room?"],[2648,2702,"Get out,"],[2702,2902,"and don't test my patience again!"],[2902,3128,"Why can Regina do it and I can't?"],[3128,3265,"She's just a cook."],[3265,3407,"I am the one who's right for you."],[3407,3528,"Shut your mouth!"],[3545,3703,"I don't hit women, so don't push me!"],[3703,3812,"Now get out!"],[4241,4320,"Regina,"],[4341,4487,"you're here to flirt with the Captain,"],[4487,4550,"aren't you?"],[4567,4717,"No, I'm, I'm just passing through."],[4788,4963,"Just because Julian helped you today"],[4963,5159,"doesn't mean you're special to him."],[5209,5334,"Once we're back home,"],[5334,5463,"he'll be a captain."],[5480,5609,"Then you'll still be"],[5609,5818,"a poor single mom."],[5818,5926,"Don't kid yourself,"],[5926,6076,"you're worlds apart."],[6076,6268,"You'll never be good enough for him,"],[6268,6427,"and he'd never want you."],[6427,6594,"This has nothing to do with you."],[6706,6835,"Julian can back me up for what"],[6835,6952,"happened today."],[6952,7107,"And if I were to press charges,"],[7107,7194,"that's not gonna do any good"],[7194,7328,"to your reputation."],[7419,7561,"Let's see about that."]],"23":[[529,596,"Mommy,"],[596,684,"what's going on?"],[684,796,"Are you sad?"],[1280,1426,"I'm just remembering some unhappy"],[1426,1547,"memories from before,"],[1572,1726,"but you make me happy, Blaze."],[1780,2081,"You went to return Mr. Captain's jacket."],[2081,2243,"Did he make you upset?"],[2256,2327,"No."],[2385,2489,"Don't worry about me."],[2502,2660,"I'm gonna get washed up, okay?"],[2848,3003,"Don't kid yourself,"],[3003,3194,"you're worlds apart."],[3194,3386,"You'll never be good enough for him,"],[3386,3549,"and he'd never want you."],[3762,3870,"Go to sleep first."],[5976,6097,"Blaze,"],[6168,6260,"what are you doing here so late,"],[6260,6327,"little man?"],[6327,6506,"I'm mad at you, Mr. Captain."],[6506,6685,"I wanna ask you something."]],"24":[[12,158,"Mommy came to see you tonight,"],[158,279,"and when she came back,"],[279,433,"she looked really upset."],[433,575,"Did you bully her?"],[588,692,"I haven't seen her tonight."],[692,930,"Yeah, she was here to return your jacket,"],[930,1088,"and you made her upset."],[1188,1280,"Blaze,"],[1326,1430,"I'm the one who gets upset"],[1430,1505,"because of your mom."],[1505,1614,"It's not the other way around."],[1981,2114,"Unless..."],[2114,2206,"She must have bumped into"],[2206,2314,"Vanessa."],[2314,2519,"She get jealous or something?"],[2519,2681,"Does that mean she still cares for me?"],[3048,3094,"Come on."],[3432,3511,"Let's go ask your mom"],[3511,3611,"why she's upset."],[3807,3945,"I'm sorry, Alex,"],[3945,4066,"for bothering you so late at night,"],[4066,4225,"but please help me find Blaze."],[4254,4379,"It's all right, Regina."],[4379,4496,"Don't worry about it."],[5030,5130,"Well, Blaze,"],[5171,5301,"looks like your mom is finding you a"],[5301,5380,"new dad."]],"25":[[204,275,"Blaze,"],[275,346,"where were you?"],[346,471,"Mommy was so worried."],[471,583,"Sorry, Mommy."],[583,738,"I just don't want you to be upset"],[738,888,"because of Mr. Captain."],[909,1096,"I know you two love each other,"],[1096,1301,"and I want him to be my dad."],[1768,1893,"Stop joking around."],[1926,2052,"Don't be rude to Mr. Captain."],[2052,2168,"I'm not joking!"],[2168,2310,"I'm a big boy now."],[2310,2460,"I know what's going on."],[2460,2540,"You two are in-"],[2540,2615,"Stop!"],[2744,2819,"Go to bed,"],[2827,2886,"now."],[3415,3478,"Sir, I,"],[3499,3603,"I, I just wanted to see"],[3603,3724,"if there's anything to eat."],[3724,3807,"Be careful,"],[3807,3874,"Alex."],[3908,4058,"Regina is my woman."],[4095,4220,"Now if there's nothing else,"],[4220,4475,"hurry up and get back to work."],[4533,4625,"Yes, Captain."]],"26":[[955,1042,"Again?"],[1130,1317,"I am not eating this."],[1384,1622,"And, Regina, my dad and the others"],[1622,1735,"are in a meeting right now."],[1735,1935,"Make sure to bring them lunch."],[2869,2957,"Wow, thank you."],[3003,3098,"No worries."],[3098,3215,"If you get hungry later tonight,"],[3215,3294,"let me know and I'll make you a"],[3294,3365,"sandwich."],[3745,3945,"Actually, no, it's okay."],[3945,4054,"I don't want to disturb you."],[4108,4191,"Okay,"],[4191,4312,"I'll put it in the fridge then."],[4325,4487,"The supplies are tight with the war."],[4542,4671,"Everyone gets their allotted amount of"],[4671,4713,"food."],[4713,4888,"No extras, and no wasting."],[5009,5096,"Captain, there's plenty of"],[5096,5205,"food in the storage."],[5205,5292,"I think we should make sure"],[5292,5401,"everyone gets enough to eat."],[5401,5484,"It's not wasting."],[5484,5597,"I'm the Captain."],[5597,5726,"I make the rules."],[6335,6556,"That arrogant asshole!"]],"27":[[379,508,"What are you doing, Captain?"],[508,700,"You and Alex seem to have gotten close."],[713,834,"Asking if he's full,"],[834,917,"do you like him?"],[917,1042,"What are you talking about?"],[1042,1126,"I'm a cook."],[1138,1326,"It's my job to make sure everyone is full."],[1326,1576,"Plus, Alex is here to help save us."],[1576,1785,"Obviously, I would be respectful to him."],[1785,1918,"Respectful?"],[2006,2127,"You didn't think about that when you"],[2127,2302,"dumped me all those years ago."],[2460,2544,"Don't think you can just"],[2544,2656,"fall in love with anyone."],[2694,2869,"This has nothing to do with you."],[3094,3228,"This has everything"],[3228,3324,"to do with me."],[6131,6285,"I'm not gonna let you go."]],"28":[[162,354,"God, Julian, clean it up."],[383,542,"I don't want people to misunderstand."],[942,1059,"Misunderstand?"],[1121,1222,"You seem just fine with them"],[1222,1363,"misunderstanding you and Alex,"],[1363,1484,"but with me, it's an issue."],[1493,1655,"What are you hiding, Regina?"],[1722,1826,"Are you jealous?"],[1826,1976,"Or are you just trying to embarrass me?"],[2181,2281,"You can't see?"],[2569,2794,"I'm so jealous I could lose it."],[7695,7816,"Blaze, what are you doing here?"],[7816,8087,"Sorry, Mommy, I'm just too hungry."],[8212,8299,"Well, speaking of that,"],[8299,8437,"why doesn't Blaze eat with us?"]],"29":[[33,150,"Because Ms. Thornton"],[150,296,"says I'm too loud."],[296,479,"She doesn't want me to be here."],[479,592,"Blaze,"],[592,650,"you're too little"],[650,825,"to be eating with the grown-ups, okay?"],[846,955,"We usually eat in our room just"],[955,1084,"so we don't bother anyone."],[1209,1372,"Well, Blaze is a big boy."],[1451,1564,"Why don't you eat with us?"],[1618,1826,"Yay, thank you, Mr. Captain."],[1826,1993,"I like eating with everyone."],[2281,2435,"Why do you have Mommy's lipstick"],[2435,2623,"on your cheek, Mr. Captain?"],[2623,2761,"Did you two kiss?"],[2761,2894,"Blaze!"],[2894,3023,"Stop joking around, okay?"],[3023,3169,"Mommy's about to get real upset."],[3174,3303,"I'm not joking."],[3303,3541,"I want Mr. Captain to kiss Mommy"],[3541,3674,"because I want Mr. Captain"],[3674,3820,"to be my dad."],[4229,4312,"Unfortunately,"],[4312,4458,"I'm still working on that one,"],[4458,4517,"but..."],[4579,4700,"I guess I'll have to try even harder"],[4700,4792,"just for you, Blaze."],[6126,6252,"Miss, I've got the lilies and the"],[6252,6385,"sunflowers you wanted."],[6631,6827,"Mommy, my nose is itchy."],[6998,7248,"Left-handed, allergic to pollen,"],[7248,7461,"these are all traits in my family."],[7532,7661,"Could it be?"]],"30":[[204,379,"Mommy, I feel sick."],[508,654,"Shoot, we're out of Loratadine."],[654,746,"Just write down a list"],[746,817,"of anything he needs."],[817,917,"I'll make sure we get it."],[1188,1267,"Okay."],[1330,1451,"Any of these would work."],[3578,3757,"Thank God, Blaze is okay now."],[3820,3966,"The person you should be thanking"],[3966,4058,"is the Captain."],[4091,4195,"He didn't want me to say anything,"],[4195,4241,"but"],[4241,4500,"we ran all over town to find those meds,"],[4537,4612,"and,"],[4612,4775,"there were riots on the way,"],[4804,4963,"which is why we got back so late."],[4963,5013,"But"],[5013,5088,"don't worry,"],[5113,5196,"everyone's fine."],[5246,5313,"Just..."],[5376,5442,"the Captain."],[5451,5509,"What?"],[5555,5638,"What happened to him?"],[5638,5822,"We found an abandoned drugstore"],[5822,5997,"and a chandelier fell,"],[5997,6177,"and it hit him on the shoulder."],[6177,6222,"Anyway,"],[6239,6293,"those,"],[6293,6489,"these meds were not easy for us to get."],[6523,6627,"And please,"],[6627,6752,"don't say anything to him, okay?"],[7111,7374,"Mommy, Mr. Captain helped us again."],[7374,7503,"You should make him my favorite"],[7503,7590,"apple pie."],[7590,7749,"That will make him happy."],[7803,8033,"Apple pie is Julian's favorite dish too."],[8033,8108,"Him and Blaze really"],[8108,8220,"have a lot in common."],[8370,8466,"All right."],[8504,8608,"Mommy will make your favorite"],[8608,8746,"apple pie, okay?"]],"31":[[37,196,"Thank God, there's somebody selling"],[196,266,"fruits here."],[704,829,"Hand over everything you have."],[829,1013,"Bitch, give us your money, eh?"],[1013,1167,"Oh, I like the pearls."],[1167,1280,"I like this here."],[1322,1401,"Hey!"],[1401,1484,"What are you doing? -What've we got here."],[1484,1539,"Look at this."],[1539,1601,"Firecracker!"],[1601,1659,"Don't touch her!"],[1659,1856,"Whoa, whoa, whoa!"],[2156,2202,"Look what we got."],[2298,2398,"What's she got in here?"],[2398,2473,"Oh, look"],[2473,2523,"at this. -Don't touch"],[2523,2569,"my apples!"],[2569,2665,"Oh, I like it."],[2665,2736,"Get off!"],[2736,2806,"Yes!"],[3132,3215,"Get out of here!"],[4237,4312,"What are you doing?"],[4312,4454,"You know how dangerous this is?"],[4475,4525,"I'm sorry, I-"],[4525,4633,"Let's go, now!"],[5438,5518,"I'm sorry."],[5572,5734,"I shouldn't have gone out on my own."],[5751,5910,"I was gonna make an apple pie,"],[5943,6126,"but there was no more apples left."],[6335,6406,"What?"],[6448,6569,"Alex get hungry?"],[6627,6731,"You like him so much that you'd"],[6731,6844,"risk your life for him?"]],"32":[[12,120,"Of course not."],[120,196,"It was for you."],[387,517,"You saved Blaze, so,"],[517,675,"I thought I'd make your favorite food."],[763,900,"You should have come to me first."],[900,938,"I mean,"],[938,996,"what if something"],[996,1096,"bad would've happened to you?"],[1121,1263,"I, I don't know what I would do if"],[1263,1355,"something happened."],[1418,1484,"What?"],[1609,1730,"I mean, think of Blaze."],[1839,1956,"Okay, who's gonna take care of him,"],[1956,2102,"if something happens to you?"],[2160,2339,"What you did was irresponsible."],[2448,2560,"Irresponsible?"],[2577,2765,"Julian, you have no right to say that."],[2806,3007,"You know nothing about me or my life!"],[3336,3395,"You're right."],[3591,3728,"I can't imagine how hard it must have"],[3728,3858,"been to raise him on your own."],[3887,3991,"You should just come to me."],[3991,4145,"I, I want to protect you."],[4329,4450,"That won't be necessary,"],[4496,4550,"because I want"],[4550,4675,"nothing to do with you."],[4696,4829,"We're worlds apart."],[4854,5030,"We were back then and we still are."],[5109,5167,"Just"],[5192,5267,"let it go."],[7057,7190,"I can't let you go."],[7461,7636,"You can't do this to me."]],"33":[[58,137,"I don't have time to"],[137,304,"play this game of love with you."],[600,738,"You think I would've come all this way"],[738,834,"and risked my own life to"],[834,942,"play some game?"],[1071,1159,"I've been looking for you for"],[1159,1280,"six years, Regina!"],[1280,1380,"Six years!"],[1651,1735,"Nevermind."],[2260,2348,"Julian,"],[2394,2556,"there's just too much between us,"],[2556,2635,"and a child."],[2635,2794,"And I just wanna live a peaceful life with"],[2794,2907,"Blaze, so,"],[2969,3094,"we shouldn't do this."],[3094,3219,"Blaze likes me."],[3253,3399,"He wants me to be his dad,"],[3399,3482,"and I want it too."],[3482,3574,"I can be that."],[3595,3774,"Regina, I can be his father."],[3866,3987,"He's right."],[3987,4083,"They're drawn to each other"],[4083,4204,"biologically."],[4241,4400,"Blaze has never been happier than when"],[4400,4500,"he's with Julian."],[4500,4579,"But"],[4579,4738,"I just can't."],[4804,4992,"You are nothing but a nobody"],[4992,5167,"from the wrong side of town,"],[5167,5401,"and you will only drag him down."],[5588,5701,"Let's wait until we get back into the"],[5701,5805,"country, okay?"],[5955,6114,"I'll reconsider what you said,"],[6177,6239,"if needed."],[6535,6664,"And hopefully you'll wake up from your"],[6664,6794,"dream by then."],[7107,7294,"I wanna give you two the best life I can."],[7311,7403,"I promise."],[7590,7774,"Mommy, am I interrupting you"],[7774,7932,"kissing Mr. Captain?"]],"34":[[37,204,"Mommy, am I interrupting you"],[204,371,"kissing Mr. Captain?"],[442,554,"Of course not."],[613,700,"What's going on?"],[709,834,"I'm hungry."],[3286,3424,"Apple pie is my favorite."],[3440,3549,"I haven't had it in years."],[3582,3732,"I didn't know you like apple pie"],[3732,3928,"as much as I do, Mr. Captain."],[4070,4170,"Next year, I'm gonna have"],[4170,4379,"six candles on my apple pie."],[4850,4959,"Blaze is five?"],[5055,5201,"He doesn't remember his age."],[5372,5530,"No, I think there's more to it than that."],[5668,5789,"He's left-handed,"],[5801,5939,"and although I'm not allergic to pollen,"],[5939,6089,"it runs in my family."],[6156,6272,"I thought Blaze was four,"],[6272,6398,"and that means he couldn't been my kid."],[6398,6510,"But if he's five..."],[6635,6785,"Regina, tell me the truth."]],"35":[[16,175,"I know you like Blaze,"],[196,342,"but please don't overthink this."],[396,521,"If he really was your child,"],[521,675,"I would've told you back then."],[1330,1418,"Understood."],[1476,1609,"I'll keep everyone calm."],[2248,2381,"Now I know you've all heard by now"],[2381,2585,"that the rescue plane isn't coming."],[2610,2752,"I understand your frustrations,"],[2752,2994,"but please just remain calm."],[3015,3161,"I prepared a military vessel"],[3161,3357,"to pick us up in three days time."],[3411,3486,"I swear,"],[3503,3632,"on my job as your captain,"],[3632,3812,"I will get us all home safely."],[3866,3991,"We'll still miss Christmas"],[3991,4245,"even though we go back in three days."],[4750,4909,"Don't be sad, everyone!"],[4909,5109,"We could celebrate Christmas together!"],[5109,5330,"I learned how to sing Jingle Bells!"],[6664,6881,"Wow, mashed potatoes and gravy."],[6881,6986,"It's my favorite."],[6986,7073,"Thanks, Regina."],[7073,7248,"And my favorite, roasted ham."],[7303,7407,"Thanks, Regina."],[7407,7515,"Must have taken a lot of work"],[7515,7611,"to prepare all this."],[7611,7766,"Oh, no, I'm just"],[7766,7878,"making sure everyone enjoys"],[7878,7912,"their meal."],[7912,8003,"It's just my job."],[8258,8408,"That's all we've got?"]],"36":[[329,446,"Not even a turkey?"],[513,592,"Seems like someone"],[592,725,"pocketed food money."],[738,892,"How can you even say that?"],[892,1096,"We all contributed to dinner tonight,"],[1096,1226,"including Blaze,"],[1226,1368,"while you were in your room"],[1368,1443,"the whole time."],[1468,1555,"Honestly,"],[1555,1718,"you don't even deserve to be here."],[1835,1876,"Daddy,"],[1876,2047,"they're ganging up on me again."],[2047,2198,"Why don't you say something?"],[2198,2306,"Vanessa, cut it out."],[2306,2435,"It's Christmas Day."],[2460,2598,"Don't ruin our mood."],[2744,2840,"Me?"],[2861,3007,"Ruining your mood?"],[3007,3219,"I never wanted to eat this shit anyway."],[3228,3399,"Enjoy your trash food."],[3411,3511,"I'm out of here."],[3728,3795,"Sorry."],[3832,3945,"She's too spoiled."],[3945,4041,"Just ignore her."],[4062,4162,"Alright, everyone,"],[4204,4295,"let's carry on."]],"37":[[75,145,"Wow,"],[145,296,"this mashed potato tastes just like"],[296,404,"my mom's food."],[500,613,"God, I miss her."],[888,1009,"Too young to realize this,"],[1009,1080,"but..."],[1172,1330,"it's the happiest thing on earth"],[1330,1434,"to spend time"],[1447,1576,"with the people you love."],[2339,2402,"Okay,"],[2402,2565,"enough sad stories."],[2565,2686,"Let's have some fun today."],[2715,2882,"I'll sing for everyone."],[3007,3165,"Dashing through the snow,"],[3165,3340,"in a one-horse open sleigh."],[3340,3507,"Oh, what fun it is to ride and sing"],[3507,3661,"in a one-horse open sleigh."],[3661,3695,"Hey!"],[3695,3870,"Jingle bells, jingle bells,"],[3870,4020,"jingle all the way."],[4020,4200,"Oh, what fun it is to ride"],[4200,4354,"in a one-horse open sleigh."],[4354,4396,"Hey!"],[4396,4562,"Jingle bells, jingle bells,"],[4562,4725,"jingle all the way."],[4725,4871,"How much fun it is to ride..."],[4871,5042,"I got something special for you."]],"38":[[479,592,"Oh my God."],[984,1113,"What a beautiful dress."],[1113,1234,"Where did you find it?"],[1234,1376,"I have my connections."],[1413,1559,"Since the last one got torn,"],[1580,1697,"I wanted to get you a new one."],[1760,1843,"Thank you,"],[1864,1931,"Julian."],[2456,2535,"I love it."],[4441,4650,"You look so pretty in this dress, Mommy."],[4921,5109,"Stop looking at her, Alex."],[5142,5280,"That dress Regina is wearing"],[5280,5451,"is a gift from the Captain."],[5451,5526,"Wait,"],[5526,5651,"you mean the Captain"],[5651,5860,"risked his life yesterday just to,"],[5860,5964,"for this dress?"],[5997,6072,"Gosh."],[6131,6206,"I don't know what happened"],[6206,6310,"between them,"],[6310,6360,"but..."],[6452,6581,"there's no doubt"],[6581,6702,"that the Captain loves her."],[7094,7173,"Sir,"],[7173,7232,"team,"],[7232,7336,"we need to have a meeting."],[7665,7782,"This is Belkova's"],[7782,7995,"most expensive embroidery."],[8028,8199,"It's at least five grand."],[8199,8291,"How could a cook like you"],[8291,8400,"could afford it, Regina?"],[8425,8508,"This is the proof,"],[8508,8658,"you stole our food money."]],"39":[[33,258,"Julian gave this dress to me as a gift."],[283,387,"How dare you"],[387,621,"call him by his first name."],[621,821,"He's the Captain, for God's sake."],[850,1109,"It's impossible that he'll prepare you"],[1109,1230,"a Christmas gift"],[1230,1451,"out of everyone else here."],[1472,1580,"He'll prove you wrong."],[1622,1793,"You really think the Captain has"],[1793,1881,"something for you?"],[1926,2131,"He just feels sorry because you're a"],[2131,2331,"pathetic single mom."],[3319,3478,"Don't hurt my mom!"],[3478,3674,"Get out of my way, you bastard!"],[3849,4020,"Don't touch my son!"],[4270,4408,"Regina Scott,"],[4437,4612,"you're a dead person."]],"40":[[4,158,"You're a dead person."],[191,246,"Stop!"],[425,542,"I told you I wasn't gonna have any"],[542,608,"more of this."],[688,829,"I caught Regina stealing our"],[829,917,"food money!"],[917,1017,"Look at this dress."],[1017,1172,"There's no way a cook like her"],[1172,1238,"could afford it."],[1255,1409,"She's not that kind of woman."],[1451,1564,"And this dress was a gift"],[1564,1701,"that I gave her myself."],[1701,1843,"It's impossible."],[1872,2002,"There's a war here."],[2022,2206,"There's no way to buy a dress like this"],[2206,2318,"anywhere now."],[2348,2502,"Well, I once saved a man by the name of"],[2502,2619,"General Ivanov."],[2640,2748,"He owed me a favor."],[2769,2936,"So I called it in and got him to put"],[2936,3107,"this dress together for me today."],[3136,3294,"A favor from General Ivanov?"],[3294,3357,"That's worth more than a"],[3357,3449,"gold mine here!"],[3482,3636,"And you used it on a dress?"],[3670,3837,"Regina's smile is more valuable"],[3837,4004,"than a thousand gold mines."],[4004,4145,"Regina is my woman."],[4183,4337,"Vanessa, if you have a problem with her,"],[4337,4450,"come at me."],[4475,4600,"No, no, no, no."],[4600,4708,"This can't be."],[4708,4896,"And you know the value of this dress."],[4938,5100,"You'll pay for what you've done."],[5150,5296,"And I'm gonna file a report to my"],[5296,5476,"superior as soon as we get back."],[5501,5630,"You had it coming, Vanessa."],[5776,5910,"Philip's gonna take over with the"],[5910,6035,"evacuation meeting."],[6047,6227,"I have other business to attend to."]],"41":[[158,371,"Now, Blaze, you were very brave today,"],[371,479,"and as a thank you,"],[479,558,"I..."],[642,746,"got you this."],[888,1113,"Wow, a Navy medal!"],[1159,1351,"Is this my Christmas gift?"],[1372,1551,"Thank you, Mr. Captain,"],[1551,1764,"but this is not what I wished for."],[1826,1926,"What did you wish for?"],[1926,2047,"Maybe I can make it happen."],[2072,2256,"For you to be my dad."],[2256,2335,"Blaze!"],[2398,2515,"Well,"],[2535,2736,"I don't think I can do that now,"],[2736,2819,"but"],[2819,2944,"when we get back to the States,"],[2944,3128,"maybe you can talk to your mom."],[3224,3336,"We'll see what happens."],[3336,3545,"All right, enough joking around."],[3545,3682,"You had too much fun today, Blaze."],[3682,3782,"It's time for bed."],[3803,3999,"Can I sleep with Mr. Captain?"],[3999,4170,"Yeah, we could do a boys night."],[4316,4529,"Mommy, please?"],[4646,4746,"All right."],[4783,4871,"All right."],[6448,6648,"It's the crescent moon birthmark"],[6648,6806,"that runs in my family."],[6886,7073,"Why did Regina never tell me?"],[7148,7298,"What, is it a coincidence or is"],[7298,7461,"Blaze my son?"],[7494,7665,"My mom has the same necklace."],[7665,7824,"Looks just like yours."]],"42":[[1459,1559,"What's going on?"],[1605,1751,"I got another gift for you."],[1881,2056,"When I went to visit General Ivanov,"],[2056,2198,"I didn't just get the dress."],[2198,2364,"I also"],[2364,2477,"got these."],[2548,2640,"They're walkie-talkies"],[2640,2777,"with GPS."],[2777,2965,"The communications array in Belkova isn't"],[2965,3073,"great, but"],[3090,3228,"with these,"],[3228,3440,"you should be able to reach me anytime,"],[3440,3586,"any place, and"],[3586,3720,"I'll come find you,"],[3720,3820,"no matter what."],[4112,4200,"Give them a try."],[4654,4767,"Hello,"],[4767,4888,"this is Regina."],[4888,4959,"Over."],[4992,5080,"Read loud and clear."],[5080,5205,"This is Julian Brooks,"],[5205,5451,"Number 0914, Navy SEAL Captain."],[5538,5697,"I have something to report."],[5839,5943,"I miss you."]],"43":[[25,112,"Julian,"],[112,154,"I-"],[154,258,"You don't..."],[312,487,"you don't have to say anything."],[738,925,"I just want you to know that I..."],[1026,1192,"I'm gonna be by your side,"],[1230,1334,"no matter what."],[1726,1843,"Thanks for the gift."],[1956,2106,"Don't you think I deserve a little more"],[2106,2189,"than"],[2189,2281,"just a thank you?"],[3507,3691,"Do you have any baby photos"],[3691,3799,"of Blaze?"],[3853,3962,"I want to see"],[3962,4074,"what I've missed."],[4667,4796,"He's adorable."],[4829,4888,"You should have seen him"],[4888,5038,"when he was a troublemaker."],[5113,5263,"Stories that I have changing his diaper,"],[5263,5397,"you do not want to know."],[5438,5538,"I'm sure."],[5943,6043,"Did he have a lot of"],[6043,6156,"medical issues growing up?"],[6156,6222,"You know, I know a"],[6222,6389,"great doctor back stateside."],[6389,6452,"When we go back,"],[6452,6519,"I can"],[6519,6623,"get you an appointment."],[6865,6969,"Wait..."],[7165,7240,"He has"],[7240,7361,"B-negative blood type?"]],"44":[[37,158,"Don't you think there are just too many"],[158,291,"coincidences?"],[308,417,"I mean, he's just like me,"],[417,592,"left-handed, allergic to pollen,"],[592,675,"B-negative blood."],[675,738,"And I saw the"],[738,846,"crescent mark birthmark,"],[846,1042,"that he has it behind his ear just like mine."],[1055,1213,"They're just coincidences."],[1213,1326,"Don't overthink it."],[1559,1785,"Too many coincidences"],[1785,2006,"must mean there's a connection."],[2006,2202,"They really are just coincidences."],[2281,2419,"Blaze is my son,"],[2419,2531,"and the most important person"],[2531,2615,"to me in this world,"],[2615,2802,"no matter who his father is."],[2802,2990,"Please, Julian, no more questions."],[3386,3507,"Okay, fine."],[3624,3803,"We don't have to talk about it."],[3999,4149,"I'm just trying to say that"],[4250,4358,"I wanna make a life with"],[4358,4504,"the two of you when we get back."],[4650,4817,"At the very least, just"],[4863,4934,"don't leave without"],[4934,5100,"saying anything again."],[5209,5334,"Can you promise me that?"]],"45":[[850,1001,"I know I shouldn't give Julian any"],[1001,1130,"false hopes."],[1197,1284,"There will be countless"],[1284,1488,"challenges ahead of us."],[1526,1659,"But right now,"],[1659,2002,"all I want is to stay in his arms forever."],[4133,4270,"The diplomat's daughter has"],[4270,4462,"strawberry blonde hair, with bangs,"],[4462,4558,"green eyes,"],[4558,4729,"and a birthmark on her neck."],[4729,4975,"She has an illegitimate child too."],[4975,5221,"They're going back to America tomorrow."],[5221,5488,"Today's your last chance."],[5488,5701,"You can get millions if you get her."],[6060,6231,"Regina Scott,"],[6231,6410,"tomorrow will be your last"],[6410,6552,"day on Earth."]],"46":[[500,771,"Hey, Regina, can you come over for a sec?"],[771,871,"Relax, I just"],[871,1105,"wanted to apologize for what I did."],[1226,1334,"That's new."],[2077,2127,"Regina,"],[2127,2339,"I admit we didn't exactly get along"],[2339,2519,"these past few years,"],[2519,2748,"but it makes me sad thinking I may never"],[2748,2894,"see you again."],[2894,2986,"Look,"],[3019,3157,"I don't need your apology,"],[3244,3395,"but I'd be grateful if you stop bothering"],[3395,3536,"me for the next few days."],[3636,3895,"Oh, you've got me wrong, Regina."],[3895,3966,"I meant"],[3966,4220,"we're not gonna see each other again,"],[4279,4533,"because you're going to hell, bitch."],[4533,4642,"What are you talking-"]],"47":[[0,187,"Mommy, where are you?"],[187,342,"We're gonna find her,"],[342,421,"I promise."],[1801,1881,"Captain,"],[1881,2006,"we've searched all over the embassy."],[2006,2102,"She's not here."],[2102,2173,"I'm"],[2173,2314,"afraid something bad happened."],[2619,2786,"Mr. Diplomat,"],[2786,2986,"I have your daughter,"],[2986,3240,"and if you want to see her alive again,"],[3240,3507,"you have one million dollars ready."],[3549,3661,"What, Vanessa?"],[3737,3812,"Vanessa!"],[3928,4079,"Oh, thank God you're here."],[4141,4270,"That's not my daughter."],[4270,4525,"What, this is not diplomat's daughter?"],[4525,4596,"Doesn't she have"],[4596,4783,"birthmark on her neck, damn it!"],[5121,5221,"You said there was a birthmark?"],[5221,5317,"Was it..."],[5330,5526,"Is it pale and red on the neck?"],[5568,5672,"That's Regina."],[5672,5809,"She's kidnapped."],[5809,5939,"All right, you listen very closely."],[5939,6085,"Don't do anything."],[6085,6247,"This is Navy Captain Julian Brooks."],[6247,6289,"You have someone"],[6289,6377,"very important to me."],[6377,6493,"I'll give you anything you want."],[6493,6577,"All right,"],[6577,6769,"have three million dollars"],[6769,7002,"ready in cash by today."]],"48":[[33,120,"Alex,"],[120,367,"Phillip, you take over the evacuation."],[367,471,"I'm gonna stay behind to get"],[471,592,"Regina home safely."],[617,850,"Julian, you're out of your mind!"],[850,950,"She's just a cook!"],[950,1130,"She's not worth the risk!"],[1130,1272,"It's impossible to"],[1272,1484,"gather three million dollars in cash"],[1484,1647,"in this middle of nowhere."],[1647,1847,"I'm an American soldier."],[1847,2006,"It is my responsibility to protect"],[2006,2193,"every single American civilian,"],[2193,2369,"and Regina is my woman."],[2369,2464,"If I can't protect her,"],[2464,2673,"how can I protect my country?"],[2673,2790,"Alex, did you hear me?"],[2790,2911,"Yes, Captain."],[2911,3069,"Julian, you're crazy!"],[3069,3282,"Just get in the car, just get in the car!"],[3591,3812,"Daddy, you're gonna find Mommy, right?"],[3824,3953,"I trust you."],[3966,4062,"I'll find her."],[4116,4291,"I'm gonna bring her home safe."]],"49":[[859,996,"Regina, can you hear me?"],[996,1067,"Don't be scared."],[1067,1142,"I'm on my way to you."],[1142,1288,"Just don't irritate them."],[1288,1347,"Keep your-"],[1438,1572,"So,"],[1601,1885,"you are this Navy captain's woman?"],[2052,2239,"You've got some looks."],[2535,2665,"Aren't you afraid of kidnapping the"],[2665,2861,"family of a U.S. naval officer?"],[2982,3128,"Unfortunately for you,"],[3128,3395,"we're not in United States."],[3