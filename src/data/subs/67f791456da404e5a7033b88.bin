"Mama,"],[767,875,"what are you doing here?"],[980,1067,"It's you."],[1155,1230,"Who?"],[1230,1393,"You're the woman in the alley."],[1476,1593,"When I was coming here,"],[1618,1689,"these two men,"],[1689,1772,"they tried to rob me."],[1772,1935,"This girl, she saved my life."],[1935,1989,"No."],[1989,2052,"Yes,"],[2052,2210,"and don't be hurting her."],[2210,2335,"Let them go."],[2598,2686,"Okay, I get help."],[2686,2761,"Hold on."],[2969,3090,"Don't worry."],[3144,3257,"I am helping you."],[3315,3453,"He's going to be fine."],[3883,3978,"Elena,"],[3999,4162,"thank you for taking care of Julian."],[4333,4479,"It's almost time."],[4479,4592,"Go to your gate."],[5618,5768,"Mommy, you're finally here!"],[5768,5935,"I missed you so much!"],[6010,6089,"Captain,"],[6089,6189,"you're back."],[6385,6489,"Phillip, take care of"],[6489,6598,"Regina and Blaze for me."],[6598,6723,"Register them as members of"],[6723,6794,"my family."]],"53":[[112,262,"Copy that, Captain."],[275,350,"Come on, kid."],[913,1059,"Regina, I heard what you said."],[1184,1276,"Don't you wanna know who his"],[1276,1347,"father is?"],[1418,1547,"When I was injured,"],[1593,1705,"about Blaze's father,"],[1705,1768,"I..."],[1810,1951,"I'll be waiting for an answer."],[2243,2331,"Right."],[3299,3495,"Did you finally agree to let the Captain"],[3495,3595,"be my dad?"],[3728,3883,"Blaze, honey,"],[3883,4020,"why do you want Julian to be your dad"],[4020,4116,"so badly?"],[4124,4316,"He's tall, and handsome,"],[4316,4483,"and the most important part is"],[4483,4604,"I know you love him,"],[4604,4808,"and I want you to be happy, Mommy."],[4904,4979,"Come here."],[5305,5522,"Blaze, you are the best gift from God."],[5522,5651,"Did you know that?"],[6331,6552,"Captain, Mommy cooked lots of food,"],[6552,6744,"and she has a surprise for you!"],[6956,7094,"Aren't you still injured?"],[7094,7186,"You should put him down."],[7228,7382,"No, I'm not that weak."],[7382,7457,"I probably have room"],[7457,7595,"for another if you're interested."],[7786,7866,"I can save that."],[7920,7978,"So,"],[7978,8087,"what's my surprise?"],[8133,8279,"Let's"],[8279,8391,"eat first."],[8804,8983,"Don't keep me waiting,"],[8983,9075,"Regina."],[9255,9338,"Tell me the truth."],[9338,9517,"Is, is Blaze my son?"],[9901,10126,"That bastard is not your son."]],"54":[[16,162,"Mom,"],[162,254,"what are you doing here?"],[266,467,"I am here to tell you the truth"],[467,621,"about this bitch,"],[633,754,"and her kid."],[863,1184,"This child is not your son, Julian."],[1188,1447,"Regina Scott is using him to get to you."],[1468,1576,"This can't be."],[1576,1856,"That DNA test result is fake."],[1856,2006,"Julian, I'm not using anyone."],[2006,2185,"I don't know how to explain this."],[2185,2302,"By the way, Regina,"],[2335,2448,"I guess you haven't had a chance"],[2448,2619,"to call your dad, have you?"],[2631,2681,"Well,"],[2681,2865,"he's in prison for stealing."],[2882,3057,"Couldn't make ends meet apparently."],[3157,3336,"I don't care about some test."],[3365,3582,"I'm choosing to treat Blaze like my son."],[3603,3674,"What?"],[3695,3912,"Have you lost your mind?"],[3912,4208,"It was her who left you six years ago!"],[4208,4358,"She wasn't good enough for you then,"],[4358,4537,"and she never will be!"],[4537,4642,"Don't say that to my mom!"],[4642,4838,"She's the best mom in the world!"],[4838,5005,"Shut your mouth!"]],"55":[[0,145,"Shut your mouth!"],[175,371,"Don't do that to Blaze!"],[396,500,"Julian,"],[500,729,"what has gotten into you?"],[729,1084,"This is a very crucial time in your career."],[1084,1297,"You need a rich woman,"],[1297,1497,"not a broke single mom!"],[1497,1584,"My love life has"],[1584,1718,"nothing to do with you!"],[1743,1843,"Regina is all I want."],[1843,1968,"That was true six years ago,"],[1968,2097,"and it's still true today."],[2097,2318,"Even if she's bringing a bastard along?"],[2318,2577,"Don't call Blaze a bastard!"],[2640,2831,"I love Regina, and I wanna make her"],[2831,2940,"my wife someday."],[2977,3232,"If you can't take that, Mom, then leave."],[3244,3378,"I'm sorry, but you're not welcome here"],[3378,3436,"tonight."],[3474,3553,"Regina,"],[3553,3770,"if you have any dignity left,"],[3770,3974,"you will just leave."],[3987,4054,"Mrs. Brooks,"],[4054,4245,"I know that you have never liked me,"],[4275,4366,"but I can show you"],[4366,4529,"that I deserve to be with Julian."],[4612,4771,"That's hilarious."],[4979,5055,"All right,"],[5055,5192,"well,"],[5192,5413,"there's a tea party tomorrow afternoon"],[5413,5492,"being hosted by"],[5492,5659,"General Stanton's daughter."],[5659,5784,"Perhaps"],[5834,5976,"if you can make a good impression,"],[5976,6097,"I'll reconsider."],[6110,6302,"But I highly doubt it."]],"56":[[50,104,"Hey."],[229,308,"Hey, you okay?"],[308,387,"That was scary."],[387,554,"I'm okay, I'm brave."],[554,675,"Yeah, you are."],[846,975,"Regina, you okay?"],[988,1159,"Look, I'm sorry my mom said that."],[1192,1288,"Just ignore it."],[1363,1480,"I'm fine."],[1497,1726,"Okay."],[1726,1868,"Let's go get some food."],[1939,2152,"Then you can share your surprise."],[2185,2310,"Let's eat first."],[2310,2460,"Okay, come on."],[3516,3670,"She wasn't good enough for you then,"],[3670,3849,"and she never will be."],[3849,4070,"If you have any dignity left,"],[4070,4270,"you will just leave."],[4362,4554,"What am I supposed to do?"]],"57":[[617,692,"Well,"],[859,1059,"and Blaze is finally asleep."],[1126,1330,"That kid has so much energy."],[1714,1830,"Oh, what's wrong?"],[1910,2052,"You seem distracted."],[2164,2235,"Nothing."],[2381,2573,"Maybe I'm just not used to being home."],[2594,2736,"There's something you wanted"],[2736,2836,"to tell me today?"],[2902,3048,"Nothing special."],[3349,3465,"I wanted to thank you"],[3465,3641,"for hosting Blaze and I."],[3820,3966,"But I'm"],[3966,4058,"thinking of"],[4058,4250,"going back to my hometown."],[4592,4704,"You're leaving?"],[4758,4871,"That's your surprise?"],[5025,5150,"Look, Julian,"],[5263,5547,"I really, really wanna thank you,"],[5547,5630,"but..."],[5709,5876,"I don't belong here."],[6101,6227,"What makes you say that?"],[6318,6481,"That's what my mom said."],[6690,6894,"Oh, Regina, I'm so sorry about that."],[6894,7019,"I don't know how she got the test,"],[7019,7148,"but it doesn't matter."],[7211,7282,"It doesn't matter."],[7282,7382,"I've made up my mind."],[7382,7494,"I love you."],[7582,7757,"I want to be Blaze's father."],[7832,7937,"Come on."],[8158,8354,"Do I really deserve all of this?"],[8379,8541,"What your mom said was right."],[8550,8687,"I don't have anything."],[8821,8996,"I'm no good for your career,"],[8996,9067,"and..."],[9129,9234,"I'm not ready to be"],[9234,9388,"in a relationship with you."],[9430,9559,"Not ready?"],[9759,9880,"Regina, after everything we've"],[9880,9989,"been through?"],[10026,10147,"Look at me."],[10614,10714,"I never said yes to"],[10714,10890,"being in a relationship with you."],[11052,11223,"I appreciate what you did back in"],[11223,11336,"Belkova, but..."],[11465,11599,"things just aren't the way that"],[11599,11724,"they used to be."],[11845,11995,"Our relationship is in the past,"],[11995,12091,"and, and..."],[12253,12420,"we just have to move forward."]],"58":[[0,183,"No, don't ever say that again."],[417,558,"No matter how"],[558,709,"hard you try to push me away,"],[709,905,"I'm not letting you go, not again."],[1184,1372,"You have to let us go."],[1488,1609,"Not in this lifetime."],[1939,2131,"I know you love me."],[3707,3912,"This is the proof, Regina."],[4091,4258,"Just say you want it too."],[4475,4592,"I want it."],[8712,8804,"I know there's something"],[8804,8917,"bothering you."],[9071,9259,"Whatever it is, I'll take care of it."],[9601,9709,"But just promise me you won't"],[9709,9843,"disappear again."],[9939,10035,"I don't know what I would"],[10035,10135,"do if I lost you."],[10135,10272,"So just..."],[10339,10460,"promise me."],[10543,10639,"Okay."]],"59":[[633,688,"Hi,"],[688,775,"Nora."],[817,884,"Could you take care of"],[884,1001,"Blaze for me today?"],[1172,1397,"Sorry, I left my invitation in the car,"],[1397,1551,"but I'm on the guest list."],[1551,1776,"I've seen plenty of people like you."],[1789,1914,"You're just another bottom feeder"],[1914,2010,"trying to sneak in."],[2010,2114,"Get lost."],[2122,2235,"Don't block the entryway."],[2673,2806,"Ma'am, are you all right?"],[2806,2936,"Thank you."],[2936,3065,"How could you?"],[3065,3182,"Wait, Paul?"],[3199,3303,"Regina?"],[3328,3436,"What are you doing here?"],[3436,3599,"I'm not gonna let you sneak in."],[3678,3791,"I was invited."],[4124,4212,"You're"],[4212,4320,"Mrs. Brooks now?"],[4320,4421,"Oh my God, my bad."],[4421,4525,"Please forgive me."],[4646,4754,"Please enter here."],[4792,4896,"Come on, ma'am."],[4896,4988,"Let's go."],[5480,5609,"Ma'am, what is your name?"],[5626,5789,"Just call me Iris."],[5818,5914,"You're"],[5914,6051,"Captain Brook's wife?"],[6147,6256,"Not yet."],[6256,6423,"It's complicated."],[6452,6652,"Sorry, I'm, I'm a little nervous."],[6652,6777,"This is my first time here."],[7186,7394,"Oh, it's my first time too."],[7394,7499,"Came all this way from my"],[7499,7624,"daughter's wedding."],[7624,7866,"Otherwise, wouldn't even have bothered."],[7899,8016,"Regina?"],[8137,8295,"How did you sneak in?"]],"60":[[296,417,"I was invited."],[417,654,"This is a party for socialites only."],[688,813,"Who the hell are you?"],[871,1017,"Aren't you ashamed"],[1017,1113,"to be here?"],[1113,1267,"Vanessa, do you know her?"],[1272,1384,"Regina?"],[1384,1589,"She was my maid and a cook"],[1589,1755,"back in Belkova."],[1839,2014,"I can't mess this up."],[2014,2131,"Sure,"],[2131,2277,"I'm a cook,"],[2277,2498,"but that means that I'm good at cooking."],[2506,2573,"I brought some"],[2573,2723,"homemade cupcakes."],[2790,2923,"Feel free to take some."],[3486,3670,"These are adorable."],[4045,4220,"And it tastes amazing."],[4220,4416,"You're great at baking, Regina."],[4742,4838,"These are really good."],[4875,5092,"You really think a couple of cupckaes"],[5092,5296,"will get you into the upper class?"],[5342,5451,"Everyone,"],[5484,5680,"let me tell you who she really is."]],"61":[[20,145,"She's broke,"],[145,262,"in debt,"],[312,425,"and a single mom."],[442,538,"And..."],[538,700,"she's trying to hook up with Captain"],[700,859,"Julian Brooks for some perks."],[1026,1151,"She's just a"],[1151,1326,"delusional gold digger."],[1422,1509,"Yes."],[1647,1835,"I come from a humble family,"],[2006,2260,"but I believe that a person's values"],[2260,2489,"come from their virtues,"],[2489,2660,"not their social class."],[2660,2761,"Vanessa,"],[2761,2865,"you're the one hiding"],[2865,2977,"behind your appearances,"],[2977,3119,"because"],[3119,3219,"deep down,"],[3311,3424,"you're empty,"],[3424,3499,"and insecure."],[3641,3853,"How dare you talk to me like that!"]],"62":[[58,196,"You don't have to like me,"],[283,529,"but you cannot ruin the food that I make!"],[529,675,"Food?"],[675,863,"I'd rather die than eat something"],[863,1105,"made with this kind of cheap cream."],[1105,1322,"You can just do whatever you want,"],[1322,1426,"but don't forget that there are"],[1426,1559,"people in this world"],[1559,1760,"who go hungry every single day."],[2056,2289,"Maybe you people don't realize this,"],[2289,2381,"but"],[2381,2481,"Vanessa,"],[2481,2715,"you just came back from Belkova, right?"],[2715,2848,"You know how"],[2848,3065,"limited resources are in a war zone."],[3065,3349,"So if you had even the slightest bit"],[3349,3453,"of empathy,"],[3453,3620,"any human decency,"],[3620,3803,"you wouldn't ruin food!"],[3803,4037,"I don't want to hear your lecture, okay?"],[4104,4279,"I'd rather starve to death"],[4279,4396,"than eat your food."],[4450,4579,"I just know you're upset"],[4579,4854,"because you wasted your money on it."],[4921,5005,"Fine!"],[5034,5125,"I'll pay."],[5171,5246,"All right?"],[5701,5851,"Stop!"],[5901,6031,"What are you doing?"],[6235,6352,"Who are you?"],[6352,6535,"A Walmart cashier?"],[6535,6694,"You also want money?"],[6706,6798,"Fine!"]],"63":[[100,354,"How dare you talk to me like that!"],[371,462,"Bitch!"],[479,675,"My dad is a diplomat."],[684,750,"Well,"],[750,1034,"I don't care who your father is,"],[1034,1142,"you should be thankful"],[1142,1313,"that I'm teaching you a lesson here."],[1351,1463,"Security!"],[1505,1705,"Get these bitches out of here!"],[1780,2002,"You two are done for."],[2002,2243,"Tonight is Bianca Stanton's party."],[2264,2356,"And she is the"],[2356,2515,"daughter of the General, so..."],[2552,2652,"just wait to get"],[2652,2815,"kicked out of Washington."],[2823,2948,"What's going on here?"],[3215,3324,"Let's see who's gonna get"],[3324,3428,"kicked out of here."],[3457,3574,"Ms. Stanton,"],[3574,3661,"two homeless people"],[3661,3853,"tried to sneak into our party."],[3870,4116,"I've asked security to kick them out."],[4141,4233,"Mom?"],[4884,5196,"She's the wife of General Stanton?"]],"64":[[162,337,"I, I didn't know you were"],[337,454,"Mrs. Stanton."],[529,650,"I'm so sorry!"],[650,775,"Please forgive me."],[775,909,"Mrs. Stanton?"],[1051,1213,"Did you just call me bitch?"],[1330,1451,"Too late."],[1451,1576,"Bianca,"],[1576,1780,"she's not welcome here at our party."],[1822,1906,"Security,"],[1906,2006,"escort her out!"],[2160,2268,"And she's not welcome at our"],[2268,2419,"parties anymore."],[2419,2527,"No!"],[2606,2698,"No!"],[3278,3445,"So, you're Mrs. Stanton."],[3474,3582,"Hi, Regina,"],[3582,3862,"let me properly introduce myself."],[3862,4087,"I'm Iris Stanton."],[4087,4391,"Bianca, this is my new friend, Regina."],[4391,4504,"I couldn't"],[4504,4729,"have gotten in here if it wasn't for her."],[4763,4954,"Nice to meet you, Regina."],[4954,5105,"Thanks for helping out my mom."],[5171,5417,"I'm sorry about your cupcakes,"],[5417,5551,"I'd like to make it up to you."],[5618,5726,"That's okay."],[5726,5847,"I have an idea."],[5910,6022,"Bianca,"],[6076,6252,"aren't you looking for a pastry chef"],[6252,6343,"for your wedding?"],[6343,6756,"I think Regina would be a great choice."],[6756,6902,"That's right."],[6902,6944,"Really?"],[6944,7044,"Yeah."],[7086,7290,"Thank you so much for offering."],[7290,7386,"Also Regina,"],[7386,7649,"I'd like to invite you over to our place."],[7649,7899,"Bianca's dad will be there too."],[7899,7974,"Bring"],[7974,8087,"Captain Brooks with you,"],[8087,8166,"maybe they'll have"],[8166,8304,"something to talk about."],[8316,8546,"Bianca's father,"],[8546,8792,"that's General Stanton?"],[8792,8900,"Is Iris trying to connect"],[8900,9129,"Julian with the General?"],[9184,9325,"I'd love to."],[9325,9559,"Thank you so much, Mrs. Stanton."],[9559,9705,"I mean, Iris."],[9751,9951,"Bianca,"],[9951,10064,"Mrs. Stanton,"],[10064,10172,"how is everything?"],[10285,10472,"Oh my God, Owen!"],[10489,10589,"Regina?"],[10677,10814,"You know each other?"],[10814,10935,"Yeah."]],"65":[[95,287,"It was really nice to meet you today,"],[287,387,"Regina."],[387,550,"Same here, Iris."],[550,650,"And you, Bianca."],[700,796,"Owen,"],[796,917,"drive Regina home."],[917,1034,"You can catch up with each other on"],[1034,1134,"the way."],[1134,1205,"Of course."],[1272,1380,"Goodbye."],[2131,2227,"We're here."],[2310,2373,"Thank you."],[2402,2489,"Of course."],[2523,2673,"Crazy coincidence today."],[2786,2948,"You're back with Brooks,"],[2973,3157,"even after all these years."],[3244,3440,"Have you explained everything to him?"],[3561,3636,"No,"],[3657,3741,"not yet."],[3766,3824,"I'm..."],[3937,4087,"It's a bit complicated."],[4116,4166,"Honestly,"],[4166,4400,"it's been really stressful for me."],[4400,4717,"Hey, if you ever need someone to talk to,"],[4767,4879,"I'm here."],[4879,5030,"And I'll always be your friend."],[5042,5138,"I missed you."],[5138,5255,"I missed you too."],[5438,5543,"And what are you doing?"]],"66":[[141,237,"Julian."],[734,934,"Julian, it's okay."],[934,1113,"I was at the Stanton family party today,"],[1113,1197,"and"],[1197,1468,"it turns out Owen is Ms. Stanton's fiancé,"],[1468,1668,"we just happened to run into each other."],[1668,1772,"Captain Brooks,"],[1818,2027,"please don't be so rude to Regina."],[2027,2218,"And who are you to tell me that?"],[2281,2473,"You just a friend or"],[2473,2602,"the father of her son?"],[2602,2706,"What?"],[2752,2898,"You have a son?"],[2998,3032,"Is he-"],[3032,3069,"No."],[3169,3411,"I'd rather not talk about this right now."],[3528,3812,"Julian, it doesn't matter who I am,"],[3812,3970,"you can't treat her like this."],[4004,4191,"You're about to be someone's groom."],[4283,4483,"Best to keep your eyes on yourself."],[4521,4612,"Come Regina,"],[4612,4738,"we need to have a talk."],[4796,4942,"Regina didn't say yes."],[5050,5196,"You need to respect her decision."],[5647,5701,"Okay,"],[5759,5864,"calm down!"],[5889,6014,"I have some errands to run,"],[6014,6085,"so,"],[6122,6314,"maybe you two could just stay here and-"],[6314,6427,"I'll come with you."]],"67":[[583,667,"Looks like someone's been"],[667,792,"skipping his workouts."],[884,967,"Listen,"],[984,1155,"I may not be as strong as you,"],[1205,1343,"but I have more time."],[1405,1584,"Unlike our Captain here who never has"],[1584,1726,"time for you, Regina."],[1830,2022,"Next time you need to go shopping,"],[2060,2131,"give me a call."],[2189,2281,"At least I'm not marrying"],[2281,2381,"someone else."],[2381,2573,"At least I don't have an evil mother"],[2573,2752,"who's always rude to Regina."]],"68":[[333,450,"Thank you, Owen."],[450,654,"Yes, thank you, Mr. Clark."],[742,867,"Maybe it's time you go."],[880,1051,"I'm sure Regina would want me"],[1051,1176,"to stay for a coffee."],[1226,1418,"Sure, I'll go make the coffee."],[1418,1539,"So I'm the one who's unwanted in"],[1539,1639,"my own house."],[1801,1914,"Julian,"],[1914,2018,"don't say that,"],[2043,2248,"I just want to talk to Owen."],[2248,2364,"Oh, about what?"],[2439,2569,"About how you left me for him"],[2569,2652,"six years ago,"],[2652,2794,"or about Blaze's father?"],[2794,2902,"Julian."],[2919,3082,"What's your blood type, Owen?"],[3240,3349,"B-negative?"],[3632,3741,"I better excuse myself."],[3749,3832,"Wait!"],[3832,4012,"Julian, this is not what you think it is."],[4012,4195,"Well, then tell me what to think."],[4713,4846,"What?"],[4846,4967,"Blaze is in the hospital?"]],"69":[[75,179,"Is Blaze all right?"],[179,258,"I'm sorry, Regina."],[258,396,"I am so, so sorry."],[396,483,"Blaze fell and he"],[483,625,"accidentally hit his head."],[642,775,"He's in surgery right now."],[950,1088,"He's okay for now,"],[1088,1297,"but we do need to do a blood transfusion"],[1297,1476,"for his next surgery."],[1476,1618,"Take mine, I'm his mother."],[1618,1776,"We can't do blood transfusions"],[1776,1956,"between blood family members."],[1956,2064,"It has to be processed"],[2064,2152,"differently,"],[2152,2231,"in order to avoid"],[2231,2419,"serious complications."],[2419,2510,"Blaze has"],[2510,2723,"RH-negative B blood,"],[2723,2973,"which is a really rare blood type,"],[2973,3119,"and they're still pulling from"],[3119,3249,"the blood banks."],[3265,3432,"Do you know anyone with this blood type?"],[3432,3486,"Me!"],[3486,3503,"I have-"],[3503,3545,"I can do it."],[3545,3599,"B-negative."],[3599,3787,"Julian can't be the donor, take Owen's."]],"70":[[0,212,"Julian can't be the donor, take Owen's."],[229,383,"Why can't it be me, Regina?"],[613,738,"Please, Owen."],[779,921,"Please, follow me."],[1180,1322,"What's going on, Regina?"],[1889,2072,"Blaze is my son, isn't he?"],[2085,2252,"Daddy, you're here!"],[2252,2377,"Daddy!"],[2377,2510,"He looks a lot like you, sir."],[2510,2677,"He has B-negative blood type?"],[2773,2919,"My nose is itchy."],[3107,3324,"For you to be my dad."],[3541,3636,"Fine, if you don't want to talk,"],[3636,3707,"then,"],[3707,3878,"then I'll just go and get a DNA test done"],[3878,3987,"for me and Blaze myself,"],[3987,4191,"and I'll find out the truth myself."],[4216,4387,"Just no more lies, Regina."]],"71":[[20,129,"You're not gonna speak?"],[300,437,"That won't be necessary."],[671,796,"Blaze is your son."],[863,971,"He's my son."],[1092,1213,"I have a son?"],[1242,1309,"Yeah."],[1493,1634,"Feel free to hate me,"],[1634,1764,"whatever you want to do."],[1764,1956,"You gave birth to our son six years ago,"],[1956,2085,"and you never told me?"],[2085,2227,"That was my plan,"],[2260,2331,"but I"],[2331,2456,"changed my mind"],[2456,2606,"after we got back."],[2669,2869,"I wanted to tell you, I did."],[2869,2965,"I'm not lying."],[3023,3132,"Then tell me now,"],[3194,3328,"tell me everything."],[3328,3545,"I didn't have any options back then."],[3611,3674,"Six years ago,"],[3674,3828,"my dad took out a loan"],[3828,3937,"using my information,"],[3937,4091,"and my credit score"],[4091,4350,"spiraled down like crazy."],[4350,4471,"And if I stayed with you,"],[4471,4587,"you wouldn't have even passed"],[4587,4729,"the Navy SEAL screening test."],[4729,4779,"So,"],[4779,4929,"I didn't want to ruin your dream."],[4929,5055,"That was your reason?"],[5055,5259,"Do you think I wanted to leave you?"],[5434,5622,"I loved you more than anything."],[5722,5880,"While I was giving birth to Blaze,"],[6001,6135,"do you know what I saw?"],[6235,6285,"You."],[6473,6648,"I had hallucinations of you."]],"72":[[16,166,"You can't imagine"],[166,412,"how hard it is being a single mother."],[504,684,"But I had no other choice,"],[750,913,"because you were a soldier."],[996,1101,"And I'd have to do a"],[1101,1322,"screening as your partner."],[1355,1472,"And they'd have access to"],[1472,1668,"all my personal information."],[1668,1822,"And everyone would've found out"],[1822,1960,"that you married a woman who was"],[1960,2060,"broke."],[2093,2289,"We're worlds apart, Julian,"],[2289,2456,"whether you like it or not."],[2577,2777,"And I didn't want to ruin your future,"],[2777,2857,"so..."],[2915,3057,"I just left you."],[3595,3716,"Why do you always think you need to"],[3716,3807,"make these decisions"],[3807,3895,"on your own?"],[3941,4145,"I don't care about any of that."],[4320,4496,"Fuck the promotions."],[4496,4646,"Fuck the rank."],[4646,4842,"They mean nothing to me"],[4842,5063,"because you are all that I care about."],[6131,6281,"Blaze is my son."]],"73":[[362,462,"Hey."],[650,784,"Mommy, Captain,"],[784,971,"I had so many dreams."],[1059,1142,"Blaze,"],[1180,1305,"you were injured."],[1334,1493,"Thank God you're okay."],[1568,1664,"Listen, there's something"],[1664,1780,"that I have to tell you."],[1780,1981,"Is it about Mr. Captain?"],[2056,2173,"Yeah, it's about me."],[2173,2456,"I'm so, so sorry that I've been keeping"],[2456,2552,"this from you,"],[2552,2660,"but actually,"],[2660,2715,"your dad is-"],[2715,2907,"Is Mr. Captain my dad?"],[3011,3115,"Yay!"],[3115,3286,"I was lying to you, Blaze."],[3286,3395,"I'm so sorry."],[3395,3511,"It's okay, Mommy."],[3511,3666,"I understand."],[3666,3924,"Can I call you Daddy now, Mr. Captain?"],[3924,4062,"Yes."],[4083,4233,"Of course you can."],[4316,4537,"I've been waiting for that since the,"],[4537,4704,"the first time I saw you."],[4704,4959,"Daddy, are you gonna marry Mommy?"],[5242,5334,"Yes."],[5334,5409,"She's the only woman"],[5409,5518,"I'll ever marry."],[6268,6318,"You know what,"],[6318,6464,"I have some good news."],[6473,6627,"I met Ms. Stanton the other day."],[6731,6948,"She invited us to the General's house."]],"74":[[208,321,"I wasn't expecting the General"],[321,508,"to be so easy to get along with."],[508,596,"Thank you."],[679,779,"Regina, without you,"],[779,863,"I would've never gotten this"],[863,946,"opportunity."],[971,1076,"Now, the General even said,"],[1076,1184,"he was gonna introduce me to"],[1184,1297,"some more higher-ups."],[1384,1497,"That's amazing!"],[1584,1685,"There is one thing."],[1805,1939,"I filed for a report on the"],[1939,2043,"Thornton family,"],[2043,2143,"and..."],[2143,2281,"Robert said he was the one"],[2281,2448,"who was abusing all the power."],[2473,2677,"He said Vanessa had nothing to do with it."],[2777,2861,"He took the hit,"],[2861,2998,"so she's gonna walk free."],[3032,3157,"She's gonna pay for everything,"],[3157,3228,"she's done."],[3807,3970,"Okay, here's what I got from the"],[3970,4079,"private investigator,"],[4079,4250,"including her credit history."],[4550,4667,"Perfect."],[4700,4792,"Regina,"],[4792,4967,"you put my dad in jail,"],[4967,5150,"ruined my family,"],[5150,5430,"I'll make sure you pay for what you did."],[5430,5563,"Are you sure you wanna do this,"],[5563,5668,"Vanessa?"],[5668,5855,"She's got the Captain behind her."],[5855,5972,"I know you're upset about what"],[5972,6068,"happened to your dad,"],[6068,6235,"but I'm still here for you."],[6393,6581,"What are you even talking about?"],[6656,6861,"Do you offer me to give up my Chanel"],[6861,7002,"for your Walmart?"],[7140,7257,"No, thank you."],[7257,7490,"If anyone finds out that you plotted to"],[7490,7582,"kidnap Regina,"],[7582,7753,"you're going to prison too."],[7782,7974,"You should keep it on the low for now."],[8128,8270,"Are you threatening me?"]],"75":[[8,120,"I just don't want you to lose"],[120,254,"everything you have now."],[358,492,"Come over, Paul,"],[492,679,"there's something I need to tell you."],[704,767,"What is it?"],[980,1042,"You know,"],[1042,1167,"I only trust"],[1167,1330,"dead people,"],[1380,1559,"because they can keep a secret."],[1576,1643,"What?"]],"76":[[204,350,"I was told back in Belkova,"],[350,633,"you abandoned the entire rescue team"],[633,713,"for a woman."],[725,863,"You better give me a damn good reason,"],[863,913,"Brooks."],[913,1134,"I was acting as every single soldier should,"],[1134,1217,"Sir."],[1217,1347,"Regina is an American citizen,"],[1347,1405,"and my lover,"],[1405,1559,"I wasn't gonna leave her behind."],[1659,1735,"This"],[1735,1864,"Regina's father"],[1881,2035,"has a criminal record,"],[2056,2181,"and so does she!"],[2181,2285,"Have you not read the news?"],[2285,2414,"The entire city"],[2414,2590,"is talking about how she's a gold digger."],[2590,2665,"Sir, that is untrue."],[2665,2811,"Regina is not that kind of woman."],[3011,3098,"Julian,"],[3190,3303,"you're this close"],[3303,3411,"to making Rear Admiral."],[3411,3507,"You're a good kid."],[3507,3774,"Don't go down the wrong path now."],[4066,4225,"With all due respect, Sir,"],[4225,4371,"I'm not giving up on Regina."],[4479,4542,"Fine."],[4583,4658,"You can get ready for"],[4658,4763,"three days in the brig,"],[4763,4896,"and maybe then you can come up with a"],[4896,4984,"better reason."]],"77":[[29,275,"Thank you for taking care of Blaze for me."],[350,487,"I don't want him to see me like this"],[487,725,"now that Julian's in solitary confinement."],[725,771,"Oh,"],[771,884,"don't worry about it,"],[884,1092,"he's welcome any time here."],[1263,1463,"It's all your fault."],[1543,1647,"Julian would not be in"],[1647,1772,"solitary confinement"],[1772,1943,"now if it wasn't for you!"],[2006,2189,"Mrs. Brooks, calm down."],[2248,2435,"I'm sure all of those allegations are false,"],[2435,2552,"he'll be fine."],[2552,2715,"He will never be fine"],[2715,2865,"as long as you're here!"],[2919,3119,"Now get out of my house!"],[3353,3566,"I'm not who I was six years ago."],[3641,3858,"How dare you talk to me like that."],[3891,3958,"I will..."],[4041,4120,"never..."]],"78":[[588,809,"How are you feeling, Mrs. Brooks?"],[809,938,"It's you."],[1021,1209,"I thought you'd leave me to die."],[1209,1280,"No."],[1280,1401,"I would never do that."],[1505,1622,"Sure, we don't get along,"],[1622,1680,"but..."],[1722,1935,"I would never leave you to die."],[1976,2089,"You're Julian's mother,"],[2089,2160,"after all."],[2268,2444,"Don't forget, I'm a mother too."],[2610,2769,"Maybe I was wrong."],[2848,3065,"You're a good girl, Regina."],[3224,3403,"I apologize."],[3474,3603,"You really hurt me,"],[3603,3687,"Marie."],[3903,4029,"But you're Julian's mother,"],[4137,4250,"Blaze's grandmother,"],[4250,4325,"and..."],[4404,4592,"I don't want to hold it against you forever."],[4754,4892,"Who knows, maybe you could,"],[4984,5063,"you could take care of"],[5063,5226,"Blaze for me on the weekends."],[5993,6197,"Long time no see,"],[6197,6343,"Regina Scott."],[6931,7040,"Look at you,"],[7040,7198,"you walking jinx."],[7232,7419,"Got Julian under investigation,"],[7419,7603,"and his mother sick?"],[7603,7661,"How did you know"],[7661,7828,"Julian was under investigation?"],[7941,7995,"Right,"],[8016,8133,"I should've guessed."],[8183,8345,"So, you're the rat all along."],[8345,8475,"Calm down."],[8475,8712,"I am not the bad guy here."],[8712,8913,"You have only yourself to blame."],[8954,9096,"Julian wouldn't abandon the whole"],[9096,9280,"team if it wasn't for you."],[9288,9572,"You are the spy who got us all in danger."],[9638,9734,"Spy?"],[9809,10001,"What are you talking about?"],[10030,10130,"Regina Scott,"],[10243,10368,"we have evidence that suggests"],[10368,10447,"you are a spy"],[10447,10668,"sent by the Belkova terrorist factions,"],[10668,10844,"to infiltrate the U.S."],[10869,10994,"You're officially under arrest."]],"79":[[8,154,"Sources reveal a suspicious"],[154,250,"kidnapping case"],[250,362,"during a recent Belkova"],[362,517,"evacuation mission."],[517,654,"The woman in question whose"],[654,859,"identity remains undisclosed,"],[859,1138,"reportedly had close ties to local criminal"],[1138,1326,"and terror organizations."],[1326,1430,"The question now,"],[1430,1597,"is she an innocent victim,"],[1597,1830,"or a spy hiding in plain sight?"],[1830,1960,"This incident also involves"],[1960,2156,"a high-ranking U.S. Navy officer."],[2156,2273,"According to witnesses,"],[2273,2448,"he even broke military protocol"],[2448,2569,"for her."],[2569,2756,"Does it mean he's been aware of her"],[2756,2998,"true identity all along?"],[3203,3378,"All eyes are on us right now,"],[3378,3445,"and they're saying there's a"],[3445,3578,"traitor among us."],[3578,3678,"Brooks,"],[3678,3845,"stay away from that woman,"],[3845,3945,"if you want to keep your rank."],[3945,4066,"Otherwise, I can't promise what's"],[4066,4112,"gonna happen."],[4112,4162,"Look,"],[4195,4304,"bottom line,"],[4337,4412,"stay"],[4412,4600,"away from her hearing."],[4688,4859,"General Walker, you know I can't do that."],[4929,5046,"She's innocent and I know it!"],[5046,5196,"I can't let her go through that alone!"]],"80":[[33,229,"I can prove that Regina Scott"],[229,467,"is highly suspicious of being a spy."],[487,592,"While we were destroying"],[592,734,"classified documents,"],[734,1013,"she hid one file in her menu."],[1013,1163,"It's obvious that she was trying"],[1163,1363,"to obtain sensitive information."],[1363,1543,"Sir, this is a setup, she's lying!"],[1543,1655,"Quiet!"],[1714,1810,"Ms. Thornton,"],[1810,1914,"please continue."],[1914,2018,"Officers,"],[2056,2223,"she was kidnapped by Belkova's"],[2223,2348,"most dangerous gang,"],[2364,2435,"and somehow"],[2435,2573,"walked away unharmed."],[2585,2702,"That alone proves she has"],[2702,2802,"close ties with them."],[2827,2948,"Please take a look at the evidence"],[2948,3007,"I've submitted,"],[3007,3232,"which would prove everything I said."],[3244,3378,"You're the one who told the gangs"],[3378,3511,"that I'm the diplomat's daughter,"],[3511,3653,"and had me kidnapped."],[3682,3807,"Otherwise, why would they kidnap"],[3807,3933,"a cook like me?"],[3978,4066,"Once they realized that"],[4066,4216,"they had the wrong person,"],[4216,4325,"they would've killed me"],[4325,4433,"to cover their tracks,"],[4433,4617,"and that's exactly what you wanted!"],[4671,4863,"Do you have any evidence?"],[4863,5205,"Your only witness is dead now."],[5205,5301,"Ms. Scott,"],[5301,5355,"if you're found to"],[5355,5501,"be involved in any activities"],[5501,5684,"that are a threat to national security,"],[5709,5868,"you're facing life imprisonment,"],[5885,6010,"even the death penalty."]],"81":[[4,95,"Ms. Scott,"],[95,283,"we noticed that you have a close"],[283,625,"relationship with a certain naval officer,"],[633,875,"one who broke military protocols"],[875,1013,"to save you."],[1013,1167,"How do you define your relationship"],[1167,1363,"with Julian Brooks?"],[1363,1476,"Me and Julian,"],[1530,1664,"Captain Brooks,"],[1714,1814,"we were in a relationship"],[1814,1926,"when we were younger."],[1968,2056,"After"],[2056,2335,"we broke up, I came to Belkova alone,"],[2335,2523,"thinking that I would never see him again."],[2544,2573,"But-"],[2573,2777,"So you admit that your relationship is"],[2777,2923,"beyond normal."],[2973,3161,"Do you plan to use Captain Brooks"],[3161,3353,"to obtain more classified"],[3353,3524,"information from the higher-ups?"],[3632,3766,"I'm not a spy!"],[3795,3995,"And I'm not trying to use anyone!"],[4033,4250,"You're a helpless liar."],[4270,4375,"Let Brooks in!"],[5530,5626,"Captain Brooks,"],[5634,5759,"can you tell me exactly what led"],[5759,5922,"you to abandoning your rescue mission"],[5922,6060,"to rescue Regina Scott?"],[6060,6139,"At that point in time,"],[6139,6302,"Regina became the priority."],[6393,6569,"Any American citizen"],[6569,6656,"who had been kidnapped"],[6656,6781,"would've become the priority."],[6781,6915,"That's all great,"],[6915,7127,"but you failed your primary mission,"],[7127,7436,"and put the lives of your team at risk"],[7436,7695,"due to your personal feelings."],[7732,7962,"Isn't that a serious mistake in your"],[7962,8053,"judgment?"],[8053,8195,"I don't believe it is a mistake in my"],[8195,8270,"judgment."],[8291,8458,"On the contrary, I'm glad"],[8458,8608,"that I went to rescue Regina."],[8641,8825,"She's an American citizen and my lover."],[8825,8933,"If I hadn't rescued her,"],[8933,9059,"I would've regretted it for the rest of"],[9059,9142,"my life."],[9267,9421,"I'm afraid that your testimony"],[9421,9601,"no longer holds any credibility"],[9601,9818,"due to the involvement of your"],[9826,9926,"feelings."],[10873,10965,"Brooks, what are you doing?"],[10965,11106,"Are you out of your mind?"],[12132,12303,"I swear on my life"],[12303,12487,"that Regina is not the spy."]],"82":[[16,112,"You're a solider, and these are"],[112,262,"the most important things to you."],[262,383,"What are you saying, Captain Brooks?"],[383,492,"Are you willing to throw away your"],[492,554,"career for her?"],[554,750,"Julian, that woman is going to jail!"],[750,900,"She's not worth the risk!"],[900,1117,"Let's proceed with the investigation."],[1117,1301,"Then let me bring in the next witness."],[2464,2544,"Paul?"],[2673,2719,"You're-"],[2719,2915,"Too bad I'm not dead, Vanessa,"],[2952,3082,"and I also got evidence of your"],[3082,3148,"crimes."],[3148,3332,"He has evidence that supports the claim"],[3332,3457,"that Vanessa was conspiring"],[3457,3611,"with local gangs for the kidnapping."],[3878,4095,"They're going back to America tomorrow."],[4095,4337,"Tomorrow is your last chance."],[4337,4558,"You can get millions if you get her."],[4558,4725,"Regina Scott,"],[4725,4909,"tomorrow will be your last"],[4909,5025,"day on Earth."]],"83":[[83,154,"So,"],[154,221,"that night,"],[221,354,"I heard some noise,"],[354,567,"and I found Vanessa planning with"],[567,692,"someone on the phone to"],[692,846,"kidnap the diplomat's daughter."],[846,925,"I felt weird because"],[925,1088,"she's the diplomat's daughter."],[1088,1326,"And next day, Regina was taken away,"],[1326,1455,"and that's when I knew she wanted to"],[1455,1534,"get rid of Regina."],[1534,1614,"You're lying!"],[1614,1751,"After we got back to the country,"],[1751,1931,"I tried to talk you out of it,"],[1956,2022,"but who would've thought she"],[2022,2168,"wanted to get rid of me too."],[2185,2289,"She stabbed me and"],[2289,2402,"threw me into the sea,"],[2402,2510,"but luckily I got away."],[2510,2610,"This can't be!"],[2677,2769,"How much did Julian"],[2769,2919,"pay you for your testimony?"],[2919,3069,"And you had me look into Regina to"],[3069,3186,"get her credit record!"],[3199,3340,"I have proof of everything I said."],[3340,3436,"Shut up!"],[3461,3599,"Don't say anything else!"]],"84":[[95,183,"Regina!"],[4058,4183,"Regina Scott."],[4608,4692,"Not guilty."],[5893,5968,"Ms. Thornton,"],[5997,6131,"you're now under arrest for murder"],[6131,6218,"and defamation."],[6218,6302,"Oh, no."],[6339,6410,"No!"],[6569,6744,"Mommy! Daddy!"],[6785,6956,"I have your bag, Regina."],[6956,7098,"I think Mr. Brooks would like"],[7098,7248,"to see what's inside."]],"85":[[533,633,"Does this mean..."],[713,784,"Yes."],[888,1046,"Julian, we're having another kid."],[1134,1201,"God."],[1338,1430,"I love you."],[1451,1605,"Are you ready for this?"],[1655,1739,"For us?"],[1776,1868,"For all of us?"],[1993,2060,"Always."]]}