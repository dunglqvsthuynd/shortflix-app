{"1":[[458,538,"It took all night,"],[538,650,"but it was worth it."],[800,967,"Don't tell me that's the cake"],[967,1134,"for my engagement party."],[1272,1401,"Goddess,"],[1434,1597,"I knew you were cursed mute,"],[1597,1768,"but are you blind too?"],[1801,1989,"I really thought I did a good job."],[2314,2502,"What was I expecting though?"],[2540,2711,"What would you know about beauty?"],[3161,3261,"It's ugly."],[3499,3599,"Just"],[3628,3682,"like"],[3741,3812,"you."],[4020,4087,"Wren,"],[4120,4258,"this is a disaster."],[4275,4491,"Clean yourself up, you're disgusting."],[4763,4934,"Isn't she always though, babe?"],[5050,5130,"Get up, Wren."],[5146,5280,"How dare you make such a mess"],[5280,5405,"on the day of Anneliese's"],[5405,5530,"engagement party."],[5580,5714,"Why am I always blamed"],[5714,5851,"when it's not my fault?"],[6339,6468,"Are you blaming me?"],[6468,6635,"For your clumsiness?"],[6894,7082,"Have you forgotten your place?"],[7119,7244,"Your father might have been"],[7244,7361,"Alpha of this pack,"],[7415,7536,"but he left it to me,"],[7590,7707,"your stepmother."],[7728,7899,"Instead of his own daughter,"],[7974,8141,"because why...?"],[8241,8383,"Because you're a mute,"],[8383,8483,"ugly,"],[8483,8596,"useless werewolf"],[8596,8742,"who doesn't even have a wolf."],[8775,8942,"You're lucky we let you be our cook."],[8942,9104,"No other pack would take you."],[9104,9280,"It's not like we can marry you off."],[9280,9421,"I mean, look at yourself."],[9492,9613,"Who would have you as a mate?"],[9667,9801,"Wouldn't you agree, Wren?"],[9980,10122,"I asked you a question,"],[10139,10239,"you cursed freak."],[10385,10518,"Wouldn't you agree, Wren?"],[10548,10723,"That you're ugly and useless."],[10769,10965,"And no one will ever want you."]],"2":[[166,333,"Unlike our Anneliese,"],[333,558,"who has suitors lining out the door."],[633,792,"A perfect match for Nikolaus,"],[817,984,"our strongest warrior."],[1001,1142,"Now go clean yourself up."],[1213,1255,"Oh,"],[1272,1338,"and remember."],[1372,1522,"No showering or bathing"],[1522,1593,"in our house."],[1626,1764,"We don't want you sullying any more"],[1764,1876,"than you already do."],[2815,2865,"Right."],[2890,3015,"The nearest creek is"],[3015,3274,"in the territory of Alpha Hunter Silver,"],[3274,3499,"who eats virgins for breakfast."],[3570,3712,"And that's our problem..."],[3712,3787,"how?"],[3787,3949,"Don't forget to scream."],[3949,4041,"Oh, wait."],[4083,4175,"You can't?"],[5096,5259,"You know, cursing Wren mute"],[5259,5376,"has got to be the best thing"],[5376,5484,"you've ever done."],[5484,5684,"I couldn't stand her going on and on."],[5684,5851,"Please, let me see the will."],[5851,5910,"Oh,"],[5910,6060,"her father's will."],[6110,6260,"That would be bad."],[6260,6373,"Don't worry, dear."],[6373,6502,"The curse can only be broken"],[6502,6694,"if someone says I love you to her."],[6719,6944,"And that will never happen."],[9034,9184,"Anneliese was lying, right?"],[9275,9371,"There's no Alpha here"],[9371,9480,"who eats people..."],[9588,9688,"Virgins..."],[9718,9818,"like me."]],"3":[[246,287,"Wren."],[300,387,"It's just me."],[458,583,"Why so shy, Wren?"],[617,746,"We're all family here."],[917,1051,"At least we will be"],[1117,1272,"when I marry your stepsister."],[1272,1334,"No!"],[1372,1422,"No!"],[1434,1518,"Leave me alone!"],[1518,1580,"You know,"],[1626,1835,"since I'm marrying the Alpha's daughter."],[1918,2064,"I'll eventually be your Alpha."],[2489,2627,"I'll keep you safe in the kitchen,"],[2648,2736,"and you'll spread your legs"],[2736,2848,"for me in the bedroom."],[2990,3123,"Why are you being so difficult, Wren?"],[3211,3315,"I know you want this."],[3395,3511,"You stripped for me in the forest."],[3645,3762,"Practically beggged for it."],[4283,4325,"Wow.."],[4375,4554,"I didn't know you'd be so feisty, Wren."],[4629,4871,"Luckily, I brought some friends."],[6523,6652,"Damn, Alpha Hunter!"],[6660,6773,"Those Eclipse Pack wolves"],[6773,6890,"didn't stand a chance against you,"],[6890,6965,"Alpha Hunter!"],[6998,7069,"Running with their tail"],[7069,7303,"between their legs, bro, literally!"],[7361,7461,"It was nothing."],[7978,8070,"There's someone in danger"],[8070,8153,"in our territory."],[8245,8283,"Wait,"],[8308,8366,"I got it."],[8387,8525,"If you shift again so soon,"],[8525,8658,"your curse is gonna make it harder..."],[8812,8971,"for you to shift back."]],"4":[[104,271,"No, please don't do this."],[271,379,"Hey, when's it gonna be our turn?"],[462,563,"Let me have her first."],[1659,1722,"Take her."],[1764,1868,"I'll handle this guy."],[2243,2302,"Fuck!"],[2339,2481,"This isn't worth dying over!"],[2544,2585,"Shit."],[2602,2656,"Come on!"],[2673,2723,"Come on!"],[2852,2994,"He just beat two wolves"],[2994,3103,"like it was nothing?"],[3178,3278,"Who is he?"],[3307,3365,"Who is she?"],[4400,4554,"How dare you lay hands on me?"],[4637,4808,"I'm gonna be Alpha of the Wolfhart clan."],[8066,8128,"It's okay."],[8216,8329,"I'm not going to hurt you."],[8450,8554,"I'm just gonna check, alright?"],[9547,9701,"No one has ever touched me"],[9747,9864,"so gently before."],[9905,9993,"You should be alright."],[10193,10314,"He's so handsome."],[10618,10798,"She has beautiful eyes."],[13388,13450,"This girl,"],[13517,13588,"she's my mate."]],"5":[[58,162,"What was that?"],[496,550,"Alpha?"],[642,700,"Alpha!"],[1209,1359,"Why are you so fast?"],[1597,1697,"What's that smell?"],[3011,3065,"It's cake."],[3274,3345,"It's good."],[3428,3574,"At least someone liked it."],[3666,3757,"What time is it?"],[3949,4099,"I'm gonna be late for the party."],[4863,4959,"Can she not speak?"],[5534,5588,"Wait!"],[5772,5847,"Who was that?"],[6156,6264,"Thank you for your help."],[6264,6485,"Wren Wolfhart, Wolfhart Castle."],[6581,6669,"Beta Clay,"],[6740,6802,"prepare the gifts"],[6802,6906,"for an engagement offering."],[6981,7040,"What?"],[7111,7232,"That girl is my mate."],[7378,7482,"So that means..."],[7707,7832,"She can break my curse."]],"6":[[629,838,"Congratulations on your engagement."],[838,975,"The Alpha's daughter"],[975,1151,"and our strongest warrior."],[1159,1230,"Isn't it."],[2081,2314,"Isn't she the former Alpha's daughter?"],[3549,3703,"Oh, you've ruined my dress,"],[3703,3841,"you stupid little bitch!"],[3949,4129,"Isn't that the new wolfless girl"],[4129,4233,"from their pack?"],[4233,4354,"Of course she's trying to ruin"],[4354,4521,"Anneliese's engagement party."],[4537,4675,"She's jealous because she knows"],[4675,4800,"she'll never get one."],[5100,5184,"You're always trying to blame someone"],[5184,5372,"else for your shortcomings."],[5501,5676,"I won't let you blame my fiancé,"],[5676,5772,"you bitch!"],[5955,6118,"Laugh all you want, Nikolaus."],[6118,6252,"I'm gonna tell them the truth."],[6877,7061,"I don't need your excuses, Wren."],[7102,7152,"Wren,"],[7211,7311,"maybe you were cursed mute"],[7311,7378,"for a reason."],[7432,7578,"The Moon Goddess herself"],[7578,7716,"wanted you to shut the fuck up."],[7824,7870,"No."],[7953,8133,"I'm not letting him get away with this."],[8658,8783,"In the woods today,"],[8783,9017,"Nikolaus tried to force himself on me."]],"7":[[1238,1397,"Force himself on you?"],[1484,1522,"Oh,"],[1543,1589,"Wren,"],[1605,1672,"please."],[1672,1805,"As if anyone would want"],[1805,2043,"a piece of that underdeveloped ass."],[2043,2156,"What a little liar."],[2285,2389,"I'm not lying."],[2419,2527,"Can she help me?"],[2527,2606,"Get off me."],[2606,2794,"You disgusting, lying creature."],[2844,2986,"I should have kicked you to the woods"],[2986,3194,"and let that virgin-eater Alpha"],[3194,3303,"Hunter have you."],[3549,3724,"You always were a desperate,"],[3724,3862,"jealous little whore."],[3966,4175,"But you've gone too far this time."],[4200,4350,"I think you're right, Anneliese."],[4437,4587,"It's time we remove"],[4587,4767,"this embarrassment from our pack."],[4838,4996,"No, I don't have a wolf."],[5063,5184,"I'll die without a pack."],[5830,6039,"As Alpha of the Wolfhart Pack,"],[6085,6327,"I hereby banish you, Wren Wolfheart,"],[6327,6439,"to the woods."],[6464,6606,"From here on out,"],[6627,6781,"you are a rogue."],[6977,7107,"How long till Alpha Hunter"],[7107,7240,"kills her, do you think?"],[7328,7507,"Anyone want to place bets?"],[8516,8621,"I smell my mate."],[8704,8808,"She's in danger."],[8879,8996,"Let's go!"]],"8":[[37,225,"Anyone want to place bets?"],[767,829,"We gotta finish"],[829,975,"what we started in the woods, huh?"],[975,1088,"Freaky little thing,"],[1096,1259,"we'll do you a favor and pop your cherry"],[1259,1484,"before we hand you off to that sick fuck,"],[1501,1580,"Alpha Hunter."],[2056,2185,"Somebody has to help me."],[2193,2277,"Anybody!"],[5422,5497,"It's him."],[5626,5718,"What the fuck are you doing"],[5718,5784,"to my mate?"]],"9":[[383,450,"It's him."],[517,679,"The man who saved me in the woods."],[771,909,"I thought I took care of you two earlier."],[1021,1121,"Or are you back for more?"],[1889,1960,"Are you alright?"],[2556,2656,"How's the face?"],[2731,2861,"Who is that?"],[2894,3107,"I could have a whole pack of his pups."],[3186,3340,"Look at his body."],[3378,3499,"He's got to be an Alpha."],[3520,3670,"Did he say he's here for his mate?"],[3691,3807,"My name is Hunter Silver."],[3878,4041,"I am the Alpha of the Silver Pack."],[4104,4225,"I'm here to claim my mate."],[4362,4462,"Alpha Hunter?"],[4471,4575,"The Virgin Eater?"],[4575,4708,"I thought he was a monster."],[4708,4871,"I heard he has the most powerful wolf"],[4871,5038,"any pack has ever seen."],[5038,5209,"But even he can't control it."],[5255,5367,"You must be another one"],[5367,5526,"of Anneliese's suitors."],[5572,5743,"Unfortunately, you've come too late."],[5797,6035,"Anneliese is already engaged to Nikolaus."],[6060,6189,"I have zero interest in your daughter,"],[6189,6272,"Alpha Gertrude."],[6314,6414,"I'm here for Wren."],[6523,6606,"Me?"],[6840,6927,"Wren?"],[6944,7019,"No."],[7086,7178,"This can't be."],[7178,7328,"That would mean..."],[7478,7636,"That Wren Wolfhart is my mate."],[7699,7799,"My Luna."],[7866,7999,"Queen of the Silver Pack."]],"10":[[0,208,"The pack maid is his mate?"],[233,342,"How is that possible?"],[358,567,"She was rejected and banished."],[717,917,"So what if she's your mate?"],[938,1117,"You're just a cursed wolf anyway."],[1134,1205,"I bet you don't even"],[1205,1322,"have anything to offer her."],[1330,1405,"Bring the gifts."],[1931,2031,"Is this...?"],[2039,2127,"The famous locket"],[2127,2256,"of ancient werewolf Luna,"],[2293,2402,"Queen Lycandra."],[2527,2619,"So what?"],[2631,2740,"It's just a hand-me-down."],[2748,2977,"It's worth five million dollars."],[3232,3345,"A 10-carat ruby ring"],[3345,3474,"with a platinum band,"],[3486,3712,"valued at $12,000,000."],[3799,3899,"Yeah, well,"],[3899,3974,"I'm wearing"],[3974,4149,"the Gerwulf family heirloom."],[4200,4421,"That's gotta be worth at least..."],[4421,4491,"Shut up."],[4508,4683,"It's worth half a million at best!"],[4817,4963,"My final gift for Wren."],[5121,5213,"The deed for a summer castle"],[5213,5271,"up north."],[5409,5605,"Is this $75,000,000?"],[5622,5755,"Are you kidding?"],[5776,5880,"For Wren?"],[5880,5980,"Yes, Wren."],[6026,6110,"My mate."],[6202,6277,"My Luna."],[6460,6556,"These are yours."]],"11":[[33,166,"She's worth this much and more."],[258,508,"All of these gifts are mine?"],[529,629,"Wren Wolfhart."],[696,775,"My mate."],[784,855,"My one and only."],[1326,1430,"Will you marry me?"],[1543,1743,"Maybe I could have a real family again."],[2957,3157,"Gosh, she doesn't deserve any of this."],[3157,3324,"She can't even speak."],[3374,3453,"Trust me,"],[3499,3570,"she does."],[3682,3832,"I have one more present for my Luna."],[4016,4154,"What the hell?"]],"12":[[133,225,"Alpha Hunter."],[291,417,"You may be Alpha,"],[417,654,"but you're in my territory in my home."],[679,742,"It's in my rights"],[742,892,"for what he tried to do to my Luna."],[909,1013,"He tried to rape my Luna."],[1076,1180,"That was a lie."],[1205,1313,"He wouldn't do that."],[1430,1476,"No."],[1514,1614,"I was there."],[1693,1839,"I was the one who stopped him."],[1851,1964,"And I saw him run off,"],[2006,2106,"after Alpha Hunter"],[2106,2218,"kicked his ass."],[2248,2448,"And he does have that black eye."],[2502,2690,"And he wouldn't say how he got it."],[2723,2844,"What a piece of shit."],[2973,3157,"I guess the mute girl wasn't lying."],[3249,3365,"They believe me."],[3503,3757,"For the first time in ever."],[3824,3995,"Someone's finally on my side."],[4008,4149,"Nikolaus Gerwulf has to pay"],[4149,4295,"for his crimes against my mate."],[4320,4504,"I challenge him to a ritual combat."],[5434,5580,"Kick his ass, Nikolaus."],[5609,5726,"Show him why you're the next"],[5726,5843,"Wolfheart Alpha."],[5947,6001,"Yeah."],[6026,6126,"This'll be easy."],[6185,6256,"You're right."],[6327,6435,"This will be easy."]],"13":[[688,750,"I yield!"],[800,896,"Nikolaus!"],[900,1026,"How embarrassing."],[1034,1263,"This is our next pick for Alpha?"],[1338,1514,"What a terrible choice."],[1551,1639,"Now apologize"],[1639,1789,"and tell me why I shouldn't kill you."],[1872,2018,"She tried to seduce me in the woods."],[2039,2152,"She stripped for me."],[2218,2335,"No, he lied!"],[2344,2544,"God, you desperate little whore!"],[2544,2644,"Silence!"],[2669,2819,"Wren, what do you want to say?"],[3445,3620,"She said she had to bathe in the creek"],[3620,3674,"because you wouldn't let"],[3674,3770,"her shower in the house?"],[3795,3949,"I did it for the health of the pack."],[4020,4058,"Who knows"],[4058,4195,"how dirty a maid could be?"],[4195,4270,"Seriously?"],[4300,4491,"Not letting the girl shower inside?"],[4542,4671,"That's inhumane."],[4863,4984,"I should tear you apart."]],"14":[[517,583,"Oh my God."],[604,704,"It's Fenris."],[709,875,"Alpha Hunter's cursed wolf."],[1722,1847,"He's gonna kill us all!"],[1860,1964,"Apologize to her."],[1964,2035,"Now!"],[2039,2139,"I'm sorry."],[2235,2335,"I'm sorry!"],[2419,2485,"You know what?"],[2494,2665,"On second thought, that's not enough."],[2694,2798,"We should kill him."],[2798,2894,"Alpha Hunter!"],[2915,2986,"Mother..."],[2986,3053,"Shut up!"],[3061,3244,"Our reputation's already been ruined."],[3269,3436,"I can't let him become the monster"],[3436,3553,"everyone thinks he is."],[6331,6368,"Wren."],[6677,6773,"You're not a monster."],[7319,7361,"Alright."]],"15":[[62,191,"You broke my fucking nose!"],[216,275,"It'll be a lot more"],[275,379,"if you don't get out of here."],[684,825,"Nikolaus, seriously?"],[867,1013,"We are so over!"],[1071,1163,"Thanks for having us."],[1222,1322,"We'll be going now."],[1413,1514,"Great party."],[2761,2915,"This is a disaster!"],[2977,3107,"Clean yourself up."],[3119,3219,"You're disgusting."],[3232,3415,"And no one would ever want you."],[3499,3653,"It's time to find a new home."],[4550,4608,"Couldn't resist."],[4775,4879,"Hold on tight, Little Bird."],[5668,5818,"I'll make those two pay."]],"16":[[371,487,"Welcome to your new home."],[496,600,"Wow, I've never seen"],[600,717,"a place so beautiful."],[855,1034,"I can't believe I get to live here..."],[1351,1418,"...with him."],[1430,1476,"Let's go."],[1885,1939,"Alpha!"],[2047,2156,"It's your injury from earlier."],[2235,2314,"You've been fighting all day."],[2314,2385,"You've probably strained it"],[2385,2435,"even more."],[2477,2581,"Let's get you to the med bay."],[2610,2719,"I just need a med bath."],[2781,2907,"Of course, Alpha."],[2907,3028,"I'll have the healer come see you."],[3040,3090,"No."],[3144,3232,"I just need Wren."],[3478,3549,"You're my mate."],[3657,3720,"He's right."],[3795,3987,"And he helped me so much at the party."],[4037,4170,"This is the least I can do."]],"17":[[725,863,"Get it together, Wren."],[892,963,"He's hurt,"],[963,1113,"and you're acting like a little kid"],[1113,1280,"just because he's naked?"],[1322,1451,"It probably took a lot for him"],[1451,1614,"to ask for help taking a bath."],[2961,3061,"Thanks, Little Bird."],[3094,3194,"That's real nice."],[3762,3837,"I'll be fine."],[3970,4058,"A med bath and seeing your"],[4058,4204,"pretty face are all I need to feel better."],[4341,4558,"Is this really all he needs?"],[4633,4771,"He looked hurt earlier."],[4863,4942,"Typical man."],[5005,5125,"He's probably hiding his pain"],[5125,5213,"and needs more help"],[5213,5342,"than he's willing to admit."],[5505,5605,"Wren, it's okay."],[5693,5843,"He was probably too embarrassed"],[5843,6093,"to ask the healer, but I'm his mate."],[6110,6231,"And this is what being mates"],[6231,6297,"is about."],[6393,6481,"It's really okay."],[6911,6961,"Okay."],[7115,7232,"Do whatever you want with me."],[8425,8525,"This might be easier"],[8525,8641,"if I just get in with him."],[9451,9542,"What are you doing?"],[11453,11540,"That's easier."],[11811,11911,"Does she not know how much"],[11911,12057,"she's testing me right now?"]],"18":[[212,312,"Guess not."],[383,429,"Cute."],[479,579,"Thanks, Little Bird."],[821,913,"We're mates?"],[1071,1213,"So you're okay being mates"],[1213,1313,"with a cursed alpha?"],[1735,1843,"You're cursed as well?"],[1960,2072,"Do you know how to break it?"],[2198,2381,"My curse is turning me into a beast."],[2460,2552,"My wolf is taking more"],[2552,2619,"and more control"],[2619,2740,"of my emotions every day."],[2957,3040,"Still,"],[3040,3253,"I can't imagine someone so kind"],[3253,3353,"being anything like"],[3353,3503,"the beast people call him."],[3528,3636,"I know that my mate is the key"],[3636,3749,"to breaking my curse."],[3820,3891,"I am?"],[3941,4045,"Maybe after we're bonded,"],[4045,4175,"your curse will break too."]],"19":[[33,158,"Is that really possible?"],[241,354,"Could my curse break?"],[429,475,"But..."],[592,746,"I want to get to know you better first."],[871,963,"Do you have any hobbies?"],[1659,1726,"What's that?"],[1797,1856,"Cooking?"],[2085,2185,"What are you cooking?"],[2656,2719,"Uhm..."],[2719,2848,"Are you mixing"],[2911,2982,"eggs?"],[3065,3228,"This is how you mix eggs."],[3449,3557,"So that's how you mix eggs."],[3578,3724,"My finger's a fork, okay."],[4262,4354,"You can still laugh"],[4354,4454,"even though you can't speak?"],[4612,4713,"I like your laugh."],[5055,5192,"I'd like to hear it more often."],[5296,5455,"He's so kind."],[5534,5626,"She's so"],[5668,5772,"soft."],[5914,5951,"Hey,"],[6185,6281,"let me do you now."],[7436,7536,"Is this okay?"],[7720,7895,"I've never felt like this before."],[7962,8137,"I feel strange, but..."],[8320,8433,"You want me to stop?"],[8625,8754,"I feel so good."]],"20":[[387,437,"Wren."],[913,1063,"Did I seriously just climb"],[1063,1205,"into his med bath with him?"],[1205,1351,"He probably thinks I'm insane."],[2565,2648,"I'm covered now."],[3103,3211,"Oh, Goddess."],[3365,3465,"Thanks for the help."],[3945,4041,"Good night, Little Bird."],[6110,6318,"He's so handsome and kind."],[6398,6502,"I want to prove to him"],[6502,6631,"that he should keep me around."],[6785,7011,"What should I make Hunter?"],[7040,7161,"I want to impress him."],[7962,8179,"So you're the new Luna."],[8400,8571,"Can't say I'm impressed."],[8754,8975,"Why would he choose you over me?"],[9021,9225,"She's interested in Hunter, too?"],[9242,9371,"And she's gorgeous."],[9388,9471,"What makes you think"],[9471,9613,"you're good enough for our Alpha?"],[9705,9793,"Am I?"]],"21":[[41,112,"What makes you think"],[112,258,"you're good enough for our Alpha?"],[354,429,"Am I?"],[471,533,"She's good enough"],[533,713,"if I say she's good enough, Belladonna."],[804,967,"Alpha, I was just..."],[984,1055,"Leaving?"],[1155,1201,"Good."],[1301,1363,"And don't let me"],[1363,1459,"catch you with her again."],[1622,1730,"Even strangers know"],[1730,1876,"I'm not good enough for him."],[1897,2081,"I need to show him I can earn my keep."],[2798,2886,"What do you need?"],[2923,2986,"Oh."],[3107,3169,"Mmm..."],[3257,3365,"What was I looking for?"],[3465,3570,"I wanna kiss her."]],"22":[[337,417,"Paprika?"],[1001,1051,"I don't know"],[1051,1155,"if you'll need this, though."],[1655,1810,"I wasn't sure what you liked, so..."],[1876,1968,"I got a bit of everything."],[2077,2206,"I had these brought up from Paris."],[2448,2548,"Thank you, Rosemary."],[2923,3032,"Because you deserve it."],[3199,3299,"Take what you want."]],"23":[[333,421,"Big fan of bacon?"],[1146,1263,"It's my first time."],[1301,1438,"Stepmother never let me have it."],[1526,1593,"Well,"],[1797,1864,"you can have as much of it"],[1864,1935,"as you want now."],[2093,2147,"Rosemary?"],[2218,2314,"More bacon, please?"],[3294,3482,"What does she have that I don't?"],[3524,3578,"And how we gonna"],[3578,3674,"get rid of her now?"],[3695,3858,"Alpha won't even let me near her."],[3883,3970,"Too bad about"],[3970,4191,"losing out on Luna, Belladonna."],[4208,4366,"Yeah, I can't believe Alpha Hunter"],[4366,4562,"chose some random girl over you."],[4884,5121,"How about we get rid of her then?"],[5367,5609,"Accidents happen, don't they?"]],"24":[[287,383,"I have some work to do,"],[383,412,"but..."],[462,588,"we'll go over wedding plans later."],[671,700,"Okay?"],[1305,1409,"I'll see you later, beautiful."],[2348,2477,"He called me beautiful."],[2590,2702,"Did he really mean that?"],[3244,3407,"Alpha Hunter asked us to come get you."],[3474,3582,"Wedding prep, you know."],[3616,3724,"He did say we were gonna"],[3724,3874,"talk about the wedding later."],[3874,3987,"Every Silver Pack Luna"],[3987,4145,"takes a bath in one of our springs"],[4145,4291,"to purify herself"],[4291,4450,"before she forms her mating bond."],[4479,4675,"Like the spring from last night?"],[4721,4929,"It's really important to our traditions."],[4954,5171,"And it wants the future Luna"],[5171,5288,"with her packmates."],[5321,5480,"I do want to fit in here."],[5726,5847,"They are so nice."],[6214,6272,"So,"],[6289,6406,"you can't talk, right?"],[6460,6660,"So you can't call for help or anything?"],[6723,6873,"Why would they ask me that?"]],"25":[[467,529,"Don't worry."],[567,684,"Acacia was just curious"],[684,788,"about your condition."],[842,955,"Did I freak you out?"],[955,1105,"I'm sorry, I didn't mean to."],[1117,1213,"You are our Luna."],[1230,1338,"You can trust us."],[1363,1434,"It's so nice to have"],[1434,1551,"another girl in the pack."],[1685,1843,"I hope we can be good friends."],[1876,1918,"Yeah,"],[1935,1964,"let's..."],[2039,2189,"Maybe I was overreacting."],[2223,2318,"They seem nice,"],[2318,2348,"and"],[2377,2444,"I've never had"],[2444,2577,"any real friends before."],[3420,3636,"This is where Silver Pack Lunas"],[3636,3753,"purify themselves."],[3799,3858,"You'll have to"],[3858,3970,"submerge yourself completely."],[4004,4287,"It looks really deep, and I can't swim."],[4312,4425,"Don't be scared."],[4425,4629,"All the silver-packed Lunas use it."],[4642,4813,"It's not dangerous or anything."],[4829,4925,"We wouldn't trick you."],[4979,5100,"This feels off."],[5234,5405,"It only takes a few minutes,"],[5405,5543,"but you have to get in completely."],[5543,5659,"I need to get out of here."],[5726,5776,"Come on!"],[5814,5930,"Acacia, help me!"],[5960,6035,"Stop!"],[6076,6210,"Please, I can't swim!"]],"26":[[792,871,"Belladonna,"],[921,1013,"what the hell is this?"],[1088,1230,"Just showing you what you're missing."],[1280,1418,"I'm not interested in you like that."],[1463,1559,"And I'm taken now."],[1689,1760,"Cover up."],[2185,2239,"Alpha."],[2444,2585,"You can keep Wren,"],[2610,2702,"if you want."],[2761,2898,"You can have as many other women"],[2898,2982,"as you want."],[3065,3215,"Just make me your Luna."],[3319,3420,"I love you."],[3445,3586,"Think of what we can achieve."],[3616,3712,"That's not what I want."],[3787,3908,"All I want is Wren."],[4408,4479,"Wren's in trouble."],[4479,4550,"I have to go."],[4550,4650,"Alpha, wait!"],[4783,4913,"No!"],[5196,5409,"Just let the water purify you!"],[5409,5505,"Yeah, if it's burning,"],[5505,5689,"it's just the purification of..."],[5755,5826,"Or wait,"],[5855,6060,"is it the wolfsbane in the water?"],[6101,6172,"Oops."],[6172,6360,"You're right, Acacia."],[6389,6573,"This spring's infused with wolfsbane."],[6614,6727,"It's poisonous."],[6777,6852,"Darn!"],[7073,7203,"Enjoy your swim, Luna."],[7340,7444,"I'm gonna drown!"],[7482,7540,"Help!"],[7574,7695,"Someone help!"]],"27":[[1493,1534,"Shit!"],[1580,1676,"The wolfsbane!"],[1722,1793,"Are you okay,"],[1822,1864,"Wren?"],[1897,1972,"Are you hurt?"],[2298,2348,"Wait."],[2494,2635,"Why didn't the wolfsbane burn you?"],[2656,2840,"I was safe because I don't have a wolf."],[2907,3098,"Hunter doesn't know I can't shift."],[3144,3194,"Wren."],[3274,3390,"I don't want him to know."],[3428,3507,"I don't want him to think"],[3507,3699,"I'm worthless like everyone else does."],[3732,3820,"Why didn't the wolfsbane"],[3820,3899,"affect you?"],[4462,4546,"Whoever did it,"],[4546,4642,"I'm gonna let them pay."],[5426,5480,"You don't have to"],[5480,5605,"answer me right now, Little Bird."],[5668,5743,"It's alright."],[5864,5905,"But..."],[6131,6218,"stop avoiding me."],[6385,6485,"I'm sorry, Hunter."],[6544,6706,"I swear I'll tell you the truth soon."],[6706,6773,"I just..."],[6802,6894,"want you to like me"],[6894,7011,"for a little bit longer."],[7090,7169,"Besides,"],[7290,7344,"I'm just glad"],[7344,7428,"that you weren't hurt."],[7499,7565,"I won't see a mark"],[7565,7695,"on that pretty skin of yours."],[7866,7970,"Unless I'd left it."],[8445,8500,"Come in."],[8541,8608,"We've captured"],[8608,8750,"the perpetrators of Luna's attack."],[8800,8854,"Good."],[8921,9000,"I'll show them what happens,"],[9000,9113,"when they mess with my mate."]],"28":[[829,913,"You have deliberately"],[913,1046,"put your Luna in danger."],[1084,1134,"For that,"],[1238,1363,"you must be punished."],[1376,1472,"We didn't, Alpha!"],[1509,1609,"She's lying."],[1634,1780,"How can you believe her over us?"],[1839,1943,"She's been here a day,"],[1943,2114,"we've been pack our whole lives!"],[2114,2177,"That's true."],[2189,2314,"We don't even know this girl."],[2364,2481,"What if she's lying?"],[2506,2681,"What if she's lying about us, too?"],[2802,2919,"They all think I'm lying."],[2948,3111,"What if Hunter thinks that, too?"],[3165,3253,"Silence!"],[3403,3478,"How dare you question"],[3478,3591,"your Luna's morality?"],[3616,3699,"Alpha, please."],[3724,3795,"Show mercy."],[3824,3858,"No,"],[3858,3978,"I will show you the same treatment"],[3978,4104,"that you showed your Luna."]],"29":[[1743,1843,"Don't look, Little Bird."],[1935,2052,"You don't need to see this."],[2181,2335,"Is this what it's like to have someone"],[2335,2448,"you can depend on?"],[2540,2681,"I could get used to this."],[3553,3741,"How dare they try to hurt my Luna?"],[3933,3983,"Alpha,"],[4145,4241,"you need to calm down."],[4325,4450,"You...your curse is acting up."],[4483,4637,"What I need is for Wren to be safe."],[4721,4783,"Okay."],[4817,4879,"Then..."],[4979,5100,"Let's move the wedding up."],[5134,5242,"Once she's officially Luna,"],[5242,5388,"the pack won't dare touch her."],[5834,5943,"And your curse will break."],[6252,6368,"Two birds, one stone!"],[6544,6610,"I am moving the wedding"],[6610,6669,"to tomorrow night."],[6735,6777,"Yes."],[6831,6873,"It's right."]],"30":[[50,171,"I've never had anyone"],[171,321,"stand up for me before."],[371,517,"I can't believe everyone says"],[517,667,"Alpha Hunter's a monster."],[880,963,"So you turned Alpha"],[963,1096,"against his own pack members."],[1213,1313,"Congratulations."],[1405,1443,"Oh,"],[1472,1530,"I bet you think"],[1530,1705,"that you're all that now, huh?"],[1860,2018,"But I know what you truly are,"],[2093,2185,"which is nothing."],[2327,2414,"And soon Alpha Hunter"],[2414,2540,"will realize that, too."],[2802,2957,"I don't want to believe Belladonna."],[3111,3186,"But is she right?"],[3374,3453,"Hey, Little Bird."],[3495,3545,"I was..."],[3774,3824,"What's wrong?"],[4195,4233,"Hmm..."],[4354,4421,"Talk to me."],[4704,4775,"Overwhelmed?"],[5042,5146,"Yeah, I get that."],[5597,5655,"But, um..."],[5693,5772,"I think I have something"],[5772,5876,"that will make you feel better,"],[6006,6068,"hopefully."],[6715,6769,"Wow."],[6865,6948,"They're gorgeous."],[7011,7115,"Anything stand out?"],[7186,7286,"I want your favorite flowers"],[7286,7332,"at our wedding."],[7424,7553,"He got all this,"],[7553,7695,"so I could pick my favorite?"],[7791,7920,"I can't believe he did this"],[7920,8037,"for someone like me."],[8808,8925,"Are you sure you want to marry"],[8925,9134,"a useless nobody like me?"],[9300,9388,"Why would you say something"],[9388,9513,"like that about yourself, Little Bird?"],[9551,9651,"He still doesn't know"],[9651,9751,"I don't have a wolf."],[10039,10181,"I don't have a wolf."],[10489,10606,"Will he accept me?"]],"31":[[91,246,"Everyone who has ever met me"],[246,392,"has told me I'm nothing."],[462,625,"I feel like you should know, too."],[996,1201,"You are the opposite of nothing,"],[1201,1272,"Little Bird."],[1338,1409,"You are"],[1438,1505,"everything."],[1722,1801,"You know why I got so much"],[1801,1893,"lily of the valley?"],[2014,2114,"Because I wanted it."],[2256,2473,"He must really like lily of the valley."],[2623,2698,"I never cared about"],[2698,2823,"flowers before, but..."],[2911,3057,"that's what your scent smells like."],[3161,3278,"Now I can't get enough."],[3382,3495,"I'll put these in every room"],[3495,3611,"just so I can be reminded of you."],[3841,4004,"Oh, that's because of me."],[4124,4229,"I'm moving our wedding up."],[4371,4458,"Because I just can't stand not"],[4458,4575,"being with you any longer,"],[4646,4725,"if it's okay."],[4796,4934,"I don't know if Hunter will change"],[4934,5021,"his mind about me,"],[5021,5050,"but..."],[5075,5226,"I want to be with him anyway."],[5263,5401,"He's worth the possibility"],[5401,5472,"of heartbreak."]],"32":[[404,521,"I have an announcement."],[679,825,"I'm moving the wedding ceremony"],[825,909,"to tomorrow night."],[959,1071,"As of tomorrow's full moon,"],[1071,1167,"Wren will officially be"],[1167,1305,"Luna of the Silver Pack."],[1814,2064,"We have a lot of work to do tomorrow"],[2064,2156,"for the celebration,"],[2156,2193,"so..."],[2298,2406,"enjoy yourselves tonight."],[2469,2673,"To Alpha Hunter and Luna Wren!"],[2898,3090,"Alpha, you've got an urgent phone call."],[3115,3186,"Alright."],[3824,3983,"Why couldn't you just die,"],[4008,4074,"bitch?"]],"33":[[0,158,"Why couldn't you just die,"],[183,250,"bitch?"],[321,471,"Silver Pack tradition states"],[471,654,"that a wolf can challenge another"],[654,742,"to a mate"],[742,905,"to ritual combat."],[905,1013,"So I challenge you,"],[1059,1172,"Luna Impostor,"],[1192,1347,"to ritual combat."],[1505,1622,"But I can't shift!"],[1622,1714,"Since it's tradition,"],[1714,1860,"we shouldn't get involved, right?"],[1889,2081,"We're to accept the challenge."],[2118,2348,"They're just going to let this happen?"],[2414,2498,"Let's go."],[2606,2723,"What am I gonna do?"],[2756,2936,"How could Alpha Hunter choose you?"],[3044,3282,"A pathetic weakling."],[3353,3511,"Not even pretty."],[3728,3803,"Come on."],[3837,3949,"Put up a fight."],[4104,4329,"Is this how little you want Alpha Hunter?"],[4441,4554,"I do want him."],[4612,4692,"Come on."],[4704,4767,"Shift."],[4842,4979,"When I win Alpha Hunter's hand,"],[4979,5063,"I want to let him know"],[5063,5134,"it was a fair fight."],[5134,5388,"And that you were just far outmatched."],[5480,5593,"I have to try."],[5930,6093,"Seriously, shift!"],[6143,6373,"What kind of ritual combat is this?"],[6418,6627,"Why isn't she shifting?"],[6639,6806,"It's dangerous if she doesn't."],[6819,6952,"I did hear the Wolfhart Pack"],[6952,7119,"had a werewolf who couldn't shift..."],[7140,7203,"You don't think..."],[7203,7323,"She doesn't have a wolf."],[7386,7449,"They know."],[7716,7924,"You can't shift into a wolf?"]],"34":[[0,208,"You can't shift into a wolf?"],[554,675,"Oh my Goddess,"],[675,863,"you think you can be our Luna"],[863,1046,"and you don't even have a wolf?"],[1238,1384,"I don't even need these."],[1710,1789,"How could you"],[1789,1951,"be Alpha Hunter's mate?"],[1993,2114,"A wolf-less,"],[2160,2381,"worthless little creature like you?"],[2439,2569,"I think she put a spell"],[2569,2690,"on Alpha Hunter."],[2827,2886,"What?"],[3040,3144,"Do you think that could be true?"],[3161,3299,"I mean, it makes sense."],[3299,3424,"How else would a wolf-less girl"],[3424,3599,"get a mate like Alpha Hunter?"],[3624,3820,"She has to pay for her treachery."],[4241,4416,"What did I do to deserve this?"],[4441,4621,"All because I don't have a wolf?"],[4671,4763,"That's the least you deserve"],[4763,4884,"for tricking our Alpha."],[5155,5226,"You're right."],[5397,5501,"You deserve death."],[5663,5784,"For the crime of bewitching"],[5784,5872,"our Alpha,"],[5955,6114,"I sentence you to death."],[6114,6214,"Hunter!"],[6356,6406,"Alpha!"],[6473,6627,"Alpha Hunter, I was just..."],[6690,6815,"Trying to murder my mate?"],[6856,6981,"She can't be your mate."],[7023,7148,"She doesn't have a wolf."],[7207,7336,"Now everyone knows."],[7424,7536,"Will him abandon me?"]],"35":[[33,179,"She can't be your mate."],[204,325,"She doesn't have a wolf."],[342,379,"So?"],[412,517,"So what if she doesn't have a wolf?"],[517,667,"That doesn't change anything."],[759,896,"He truly loves me."],[909,1076,"How could you choose her over me?"],[1117,1272,"Wren is everything I've ever wanted."],[1313,1401,"And you, Belladonna,"],[1430,1514,"are not!"],[1526,1672,"I've had enough."],[1710,1906,"You are banished from the Silver Pack."],[2252,2293,"Wren,"],[2327,2402,"are you okay?"],[2435,2519,"Did she hurt you?"],[2652,2761,"Forgive me, Alpha."],[2790,2923,"No, I did it for your own good."],[2957,3107,"She's a wolfless embarrassment."],[3107,3290,"She doesn't deserve you like I do."],[3415,3566,"I think you need a reminder"],[3591,3707,"that I rejected you."],[3745,3862,"And that I will always"],[3862,3974,"choose Wren over you!"],[4738,4896,"I want you all to remember this"],[4896,4979,"the next time you think"],[4979,5096,"to insult my Luna."],[5188,5380,"I won't show mercy."]],"36":[[58,212,"I want you all to remember this"],[212,300,"the next time you think"],[300,429,"to insult my Luna."],[521,700,"I won't show mercy."],[717,771,"Alpha!"],[925,1009,"That's enough!"],[1292,1426,"You're gonna kill her, Alpha!"],[1818,1889,"Alpha!"],[1960,2064,"Your curse!"],[2093,2139,"This"],[2210,2256,"is"],[2285,2394,"Hunter's curse?"],[2452,2519,"Alpha,"],[2556,2727,"please, I'm sorry."],[2765,2977,"You dare call my mate worthless"],[2977,3123,"in front of me!"],[3123,3207,"Alpha!"],[3299,3382,"Alpha!"],[3461,3611,"Calm down!"],[3636,3737,"What should we do?"],[3757,3849,"No one knows how to handle"],[3849,3895,"Alpha Hunter"],[3895,3999,"when he's like this."],[4316,4366,"Luna,"],[4425,4475,"no."],[4575,4704,"It's too dangerous."]],"37":[[29,79,"Luna,"],[137,187,"no."],[279,404,"It's too dangerous."],[784,900,"Come back to me, Hunter."],[1272,1343,"Come on, Hunter."],[1368,1455,"Come back to me."],[2427,2477,"Wow."],[2631,2802,"You must actually be his mate."],[2982,3036,"Wren."],[3278,3399,"I'm so sorry."],[4083,4250,"I'm sorry you had to see me like that."],[4508,4579,"I never"],[4587,4742,"want you to see me like that."],[5042,5130,"When I told you my wolf"],[5130,5221,"was turning me into a beast,"],[5221,5351,"I wasn't lying."],[5438,5588,"I'm constantly battling my wolf"],[5588,5676,"for my emotions."],[5839,5939,"It makes me dangerous."],[6181,6268,"The last thing I want to do"],[6268,6364,"is put you in danger."],[6915,6977,"And I'd understand"],[6977,7082,"if you don't want to be with me."],[7244,7399,"Wanna leave and not come back."],[7469,7570,"You have your engagement gifts."],[7570,7645,"You can always sell them"],[7645,7716,"and live a good life."],[7916,8053,"I could live on my own."],[8091,8262,"Away from everyone who judges me"],[8262,8441,"for being mute and wolfless."],[8462,8717,"But then I'd be away from Hunter, too."],[8858,8983,"You can take one of the cards."]],"38":[[12,125,"You can take one of the cars."],[2819,2936,"Scared I'll hurt you."],[2957,3098,"His hands are so big."],[3299,3428,"But I'm not scared."],[3461,3566,"I just feel good."],[5405,5472,"Don't."],[5609,5730,"I wanna hear you this time."],[6493,6585,"Is this okay?"],[7761,7916,"I know this must all be new for you."],[8191,8283,"Show you?"],[8433,8550,"Yeah, I can show you."]],"39":[[5572,5689,"I love you, Little Bird."]],"40":[[1760,1872,"See you at the wedding."],[2752,2811,"You look"],[2831,2923,"beautiful."],[3357,3490,"I can't believe it."],[3578,3757,"I really do feel pretty."],[4667,4863,"This is where Wren lives?"],[4929,5067,"Dealing with Alpha Hunter's curse"],[5067,5246,"is nothing compared to all this."],[5951,6043,"Oh my Goddess."],[6093,6281,"This must be worth thousands."],[6385,6527,"All of this for Wren?"],[6614,6748,"This should all be mine."],[6944,7098,"Alpha's getting married."],[7132,7273,"Alpha's getting married."],[7457,7549,"Look at you, bro."],[7565,7724,"Who's to say it can't be mine?"],[7878,8049,"No man can say no to me."]],"41":[[838,984,"I'll go see if they're ready for you."],[1422,1618,"I really want to see Hunter right now."],[1693,1797,"I feel like seeing him"],[1797,1943,"would calm my nerves."],[2002,2223,"Just a peek should be okay, right?"],[3674,3816,"He looks so handsome."],[5163,5296,"Oh, Alpha Hunter."],[5296,5417,"You saved me."],[5626,5864,"Is Anneliese trying to seduce Hunter?"],[5955,6101,"That's her classic move."],[6272,6423,"Everyone always said Anneliese"],[6423,6539,"was the Wolfhart sister"],[6539,6698,"favored by the Moon Goddess."],[6735,6977,"They said she was prettier, stronger,"],[6977,7203,"better than me in every single way."],[7286,7436,"But I won't let her have Hunter."]],"42":[[475,538,"Beta Clay,"],[617,729,"I think I need a new jacket."],[754,905,"She got her scent all over this one."],[950,1055,"Excuse me?"],[1226,1297,"The smell is giving me"],[1297,1380,"a headache already."],[1526,1722,"My scent is incredible!"],[1826,2064,"Every werewolf I've ever met goes..."],[2064,2185,"Would you like me to burn it, sir?"],[2185,2318,"...crazy over it."],[2318,2439,"Are you serious?"],[2690,2740,"Just..."],[2844,2969,"There, just try it again."],[3040,3123,"Like I said,"],[3123,3307,"all wolves love my scent."],[3791,3853,"Oh,"],[3853,3941,"Wren!"],[3987,4149,"It's so good to see you!"],[4216,4366,"Congratulations on your wedding."],[4671,4846,"I seem to have hurt my ankle!"],[4954,5025,"Alpha Hunter,"],[5025,5155,"could you help me sit down?"],[5155,5213,"No."],[5271,5451,"He's not interested, Anneliese."]],"43":[[0,166,"He's not interested, Anneliese."],[246,350,"Wren, you're talking!"],[550,738,"My curse is broken?"],[1213,1247,"What?"],[1276,1351,"How?"],[1426,1568,"It must have happened last night."],[1668,1793,"Something we did."],[1814,1914,"Something we did?"],[1997,2193,"You... with her?"],[2231,2444,"But you said no to me!"],[2519,2594,"He did,"],[2652,2827,"even though you tried so hard."],[2848,3003,"Anneliese's desperation"],[3003,3219,"is almost performance art."],[3219,3286,"Seriously,"],[3307,3386,"what was she doing?"],[3386,3507,"So embarrassing."],[3507,3661,"We need to bring back shame."],[4137,4320,"Her scent gave me a migraine, Little Bird."],[4412,4504,"Luckily you smell good enough"],[4504,4600,"to make me feel all better."],[4913,5009,"We should get married now."],[5238,5317,"Let's do it."],[5797,5885,"Maybe break another curse"],[5885,5955,"while we're at it?"]],"44":[[87,141,"Now,"],[200,304,"take each other's hands"],[304,467,"to establish the mating bond."],[709,925,"You are now bonded and married."],[963,1180,"The Alpha may now kiss his Luna."],[2027,2081,"Now,"],[2118,2331,"as per Silver tradition,"],[2364,2531,"the Alpha will shift and pay thanks"],[2531,2648,"to the Moon Goddess."],[2715,2852,"He'll finally be free."],[4829,4900,"Alpha."],[5196,5267,"I'll go after him."],[5313,5388,"Don't worry, Luna."],[5609,5684,"It didn't work."],[5784,5885,"I didn't work."],[6143,6306,"I bet you thought you were all that"],[6306,6464,"now that you could speak again."],[6493,6564,"But it looks like"],[6564,6685,"you're just as worthless"],[6685,6798,"as you've always been."]],"45":[[212,346,"Anneliese is wrong."],[467,646,"Hunter won't think I'm worthless."],[1714,1918,"I know Hunter must be disappointed,"],[1918,2110,"especially since he broke my curse"],[2110,2273,"but I couldn't break his."],[2573,2711,"But I can still save this."],[2781,2961,"I can show him I'm not worthless."],[3599,3657,"Come in."],[4133,4270,"Now's not a good time, Little Bird."],[4308,4408,"I brought you dinner."],[4421,4521,"I made it myself."],[4604,4642,"Thanks,"],[4642,4725,"but I'm not hungry."],[4854,4950,"You can eat it later."],[4950,4992,"I'll just-"],[4992,5071,"Wren, not now!"],[5347,5488,"Wren, get out of here right now!"],[5638,5734,"Did he have someone"],[5734,5830,"in there with him?"],[5951,6106,"Was it another woman?"],[6352,6443,"I'm sorry, Wren."],[6502,6702,"But I don't want you to see me like this."],[7077,7232,"How much longer do you think"],[7232,7340,"you can fight me?"]],"46":[[116,275,"Hand over control, Hunter."],[304,529,"A war is coming, and only I can stop it."],[563,646,"And I'll hurt her"],[646,759,"if she gets in my way."],[775,905,"I'll never let you do that."],[963,1063,"We'll see."],[1539,1726,"I think it's time I started the life"],[1726,1830,"I always wanted."],[1885,1951,"Just me,"],[2006,2093,"on my own,"],[2147,2260,"with no one else."],[2877,2927,"No,"],[2969,3078,"I don't need those."],[3136,3294,"They'll just be painful reminders."],[3486,3712,"But there is one thing I want."],[5847,5901,"Yes."],[5968,6139,"I'll get my father's pocket watch."],[6189,6289,"A reminder that someone"],[6289,6452,"actually loved me once."],[7720,7824,"Even if I have to go back"],[7824,7999,"to Wolfhart Castle to get it."]],"47":[[1455,1509,"Wow."],[1568,1685,"I haven't been in here"],[1685,1822,"since my father died."],[2802,2857,"Hey, Dad."],[2973,3178,"What do you call a pile of cats?"],[3374,3486,"a meow-tain."],[4863,4959,"This is where my father"],[4959,5130,"would have kept his pocket watch."],[5876,6010,"He used my birthday."],[6039,6206,"Maybe he didn't leave me the pack,"],[6235,6410,"but he still loved me most."],[7966,8033,"Goddess,"],[8033,8112,"I can't believe"],[8112,8254,"Wren thought she was special enough"],[8254,8429,"to break Alpha Hunter's curse."],[8579,8729,"Seeing her miserable little face"],[8729,8879,"made it worth the trip indeed."],[9063,9230,"Well, that and the champagne."],[9325,9471,"Have you sobered up enough?"],[9492,9713,"All the cool air did us both some good."],[10114,10289,"You need to get it together, Mother."],[10310,10468,"Or else I'll curse you mute"],[10477,10606,"just like you did to Wren."],[10727,10844,"They did what?"]],"48":[[95,221,"They did what?"],[221,392,"So cruel to your mother."],[404,496,"Besides, do you know"],[496,675,"how much I had to pay that old wizard"],[675,809,"to make me that curse?"],[825,888,"They always said"],[888,1021,"it was the Moon Goddess herself"],[1021,1105,"who cursed me."],[1155,1247,"That I had done something"],[1247,1343,"to deserve it."],[1418,1501,"Does that wizard know"],[1501,1664,"how to break curses?"],[1676,1893,"If I can break Alpha Hunter's curse,"],[1893,2018,"he'll marry me."],[2018,2152,"And we'll be rich."],[2218,2394,"He might know how it can be done, but"],[2464,2606,"wizards only make curses."],[2606,2719,"They don't break them."],[2806,3007,"He might have told Wren that"],[3061,3169,"she needed someone to say"],[3169,3324,"I love you to her."],[3378,3657,"But he couldn't break it for her."],[3682,3799,"So that was the cure?"],[3908,4016,"Did Hunter"],[4058,4220,"tell me he loved me?"],[4275,4412,"I thought I dreamt that."],[4475,4633,"I thought it was impossible, but..."],[4708,4842,"Clearly Alpha Hunter told Wren"],[4842,4942,"he loved her."],[5030,5084,"Well..."],[5184,5392,"He must have said it without thinking,"],[5426,5576,"before he knew"],[5576,5751,"that she couldn't break the curse."],[5805,5905,"Now he's going to be"],[5905,6047,"looking for a new Luna."],[6189,6423,"And you would be perfect."],[6506,6648,"He deserves..."],[6690,6852,"one much better and prettier"],[6852,7011,"than Wren, of course."],[7178,7411,"Mother, why is that window open?"]],"49":[[141,271,"You little sneak!"],[287,462,"How dare you break into our castle!"],[462,604,"And how dare you curse me!"],[688,742,"Yeah,"],[775,859,"I heard you admit it!"],[859,917,"So what?"],[942,1013,"You deserve it."],[1067,1263,"Always yapping and causing trouble."],[1263,1338,"Mother!"],[1359,1547,"What if she tells Alpha Hunter?"],[1559,1647,"She won't."],[1705,1868,"There's a reason why she's here."],[1935,2114,"He probably kicked her out."],[2389,2552,"Oh, Wren."],[2573,2673,"Is that true?"],[2706,2848,"He dumped your sorry ass"],[2848,2911,"when he realized"],[2911,3032,"what a worthless waste"],[3032,3136,"of space you are?"],[3136,3190,"No!"],[3203,3265,"He didn't."],[3265,3328,"Enough!"],[3328,3478,"I don't want to hear any lies anymore."],[3507,3616,"You were trespassing"],[3616,3732,"on our territory."],[3762,3878,"We're justified"],[3878,4012,"in killing you."],[4408,4508,"Let's start here."],[4550,4767,"I'm tired of this ugly face."],[4829,4921,"No, please!"],[5171,5330,"Don't fucking touch my mate!"]],"50":[[41,175,"Don't fucking touch my mate!"],[604,750,"She was in our territory"],[750,888,"breaking into our castle."],[921,1067,"You know we're well within our rights"],[1067,1205,"to punish trespassers."],[1263,1409,"Why did you come here, Little Bird?"],[1476,1676,"He's just going to call me Little Bird"],[1676,1780,"like nothing happened?"],[1780,1830,"Wren?"],[2773,2915,"How dare you steal"],[2965,3094,"a Wolfhart heirloom?"],[3094,3194,"This was my father's."],[3257,3407,"This belongs to me, as the current Alpha."],[3436,3636,"Give it here, you insolent little..."],[3862,4016,"This is an Alpha's pocket watch."],[4029,4179,"That's why it's so valuable to me."],[4254,4475,"That's where my husband named me"],[4475,4612,"Alpha of the Wolfhart pack."],[4729,4846,"So give it here."],[6085,6202,"How dare you?"],[6202,6318,"How dare you?"],[6389,6523,"You stole the Wolfhart Pack!"],[6539,6694,"Wren is the rightful successor."],[6785,6835,"What?"],[7161,7365,"Wren is the Alpha of the Wolfhart Pack."]],"51":[[66,250,"Wren is the Alpha of the Wolfhart Pack."],[350,496,"And you two have committed treason."],[600,738,"Clearly I misunderstood"],[763,888,"my husband's instructions..."],[888,963,"Silence!"],[1226,1317,"His curse."],[1901,1968,"How would you like me"],[1968,2097,"to punish them, Little Bird?"],[2193,2298,"Should I kill them for you?"],[2369,2406,"Wren,"],[2435,2560,"please, have mercy!"],[2598,2669,"We're sorry."],[2715,2831,"Don't kill us."],[2844,2944,"As the rightful"],[2944,3078,"Alpha of the Wolfhart pack,"],[3136,3244,"you're banished."],[3553,3616,"Please."],[3666,3795,"Please reconsider."],[3878,3941,"This is our home."],[3941,4079,"This was my ancestral home."],[4112,4225,"And you had no problem"],[4225,4333,"driving me out of it."],[4362,4416,"Now leave."],[4466,4517,"Now!"],[4517,4579,"Wait."],[4746,4813,"What are you doing?"],[4900,5113,"Are you showing us mercy, Alpha Hunter?"],[5167,5359,"I'd be happy to show you my gratitude."],[5422,5522,"I could certainly make"],[5522,5647,"a much prettier wife"],[5647,5739,"than Wren ever could."],[5864,5993,"Wren is beautiful inside and out."],[6189,6272,"Unlike you."],[6402,6448,"No."],[6498,6577,"I stopped because"],[6577,6685,"we still have a score to settle."],[6765,6865,"You tried to hurt my mate."],[6973,7098,"I can't let that go unpunished."]],"52":[[183,321,"For your crimes against Wren,"],[329,437,"and for your vanity."],[1138,1272,"My beautiful hair!"],[1322,1413,"Now get out of here"],[1413,1572,"before I cut more than just your hair."],[1589,1630,"Hurry."],[1647,1685,"Hurry."],[1718,1755,"Get up."],[1760,1814,"Get up."],[1826,1893,"Let's go."],[1906,1960,"Hurry."],[2498,2556,"Thank you"],[2590,2690,"for saving me"],[2731,2786,"again."],[2944,2969,"But"],[3036,3132,"I haven't forgotten"],[3132,3274,"how you treated me yesterday."],[3424,3524,"As you shouldn't..."],[3636,3712,"I was..."],[3732,3795,"just..."],[4141,4183,"Now,"],[4216,4308,"let's go inside."],[4763,4896,"What are we gonna do?"],[5221,5309,"Need a ride?"],[5476,5634,"I think we have a lot to discuss."]],"53":[[1051,1176,"You better stay for the night."],[1668,1730,"Little Bird?"],[2093,2206,"He's acting nice now,"],[2206,2339,"but what about last night?"],[2373,2473,"You're cold."],[2502,2623,"You should take a hot shower."],[2723,2815,"We'll talk tomorrow."],[2986,3128,"I should give her some space."],[3424,3566,"He's giving up that easily?"]],"54":[[262,312,"I don't know"],[312,508,"how I feel about Hunter right now."],[525,688,"He was so dismissive earlier,"],[688,909,"but he did save me again tonight."],[1126,1238,"Those ups and downs."],[1267,1380,"Is it really worth it?"],[1480,1555,"Are you"],[1589,1689,"Hunter's wolf?"],[1789,1901,"Hunter's wolf."],[1926,2027,"I am Fenris,"],[2052,2152,"a warrior wolf spirit"],[2152,2268,"that's been reincarnated"],[2268,2369,"for thousands of years."],[2410,2544,"You can read my mind?"],[2569,2706,"I am the most powerful wolf spirit"],[2706,2777,"in existence."],[2806,3007,"I can read minds, conquer armies,"],[3007,3128,"change fates."],[3199,3299,"Change fates?"],[3349,3545,"So you can break Hunter's curse?"],[3545,3628,"Why would I?"],[3628,3803,"I want to take control of Hunter."],[3837,3928,"There's a war coming,"],[3928,4066,"and only I can stop it."],[4066,4233,"Unlike that fool, Hunter."],[4233,4329,"I don't care how much blood"],[4329,4383,"will be spilled,"],[4383,4542,"I'll do whatever needs to be done."],[4571,4692,"You think Hunter's a fool"],[4692,4846,"because he has humanity?"],[4846,5034,"Perhaps you're just as naive as Hunter."],[5096,5242,"Or maybe not."],[5288,5380,"Let's see."],[5401,5593,"The fate I can change is yours."],[5626,5709,"What do you mean?"],[5747,5880,"I can unlock your wolf."],[6118,6210,"So you mean,"],[6289,6410,"I could be normal?"],[6468,6552,"Yes."],[6585,6702,"All you have to do is break"],[6702,6810,"your mate bond with Hunter,"],[6848,7019,"and I can give you your wolf."]],"55":[[162,304,"All you have to do is break"],[304,408,"your mate bond with Hunter,"],[421,583,"and I can give you your wolf."],[892,1009,"I wasn't sure if you had dinner,"],[1009,1201,"so I brought you something."],[1805,1864,"Please."],[2377,2477,"It's delicious."],[2598,2702,"It's my specialty."],[2752,2861,"You made this?"],[3057,3148,"I haven't had someone"],[3148,3345,"cook for me in so long."],[3390,3490,"Really?"],[3503,3628,"I'd like to cook for you more."],[3695,3807,"We could cook together."],[3883,4037,"That does sound nice."],[4412,4537,"I'm sorry about yesterday."],[4625,4696,"I should have never"],[4696,4808,"spoken to you like that."],[4900,5005,"I understand"],[5005,5167,"that you're disappointed in me"],[5209,5372,"since I couldn't break your curse."],[5434,5609,"Especially since you broke mine."],[5726,5826,"I'm sorry."]],"56":[[50,100,"No,"],[100,216,"don't apologize."],[291,437,"I wasn't disappointed in you."],[450,550,"Not ever."],[671,800,"I was disappointed in myself."],[909,1088,"I couldn't control my curse that night."],[1096,1222,"I was scared I would hurt you."],[1259,1297,"So,"],[1347,1509,"you weren't with anyone last night?"],[1543,1672,"No, of course not."],[1726,1885,"Unless you count Fenris, my wolf."],[1997,2127,"He took control of my arm."],[2189,2352,"I tried to fight back, but..."],[2435,2535,"He's powerful."],[2802,2973,"I can unlock your wolf."],[3094,3178,"I promise you,"],[3215,3386,"I'll do my best to break my curse."],[3445,3595,"And that's not on you, that's on me."],[3903,3983,"All I want is for you"],[3983,4091,"to be safe and happy."],[5188,5288,"You have goosebumps."],[5347,5426,"Are you cold?"],[5601,5734,"It's because of him."],[5805,5939,"How he touches me."],[6085,6214,"I'll make us some hot chocolate."],[6544,6639,"Have you thought about our deal?"],[6719,6865,"He told you how powerful I am."],[7023,7123,"I won't take it."],[7186,7290,"I don't need a wolf."],[7349,7457,"I just need Hunter."],[7545,7670,"Ugh, you'll regret it."],[7682,7828,"Foolish girl."]],"57":[[433,479,"Hey."],[646,750,"Here's your hot chocolate."],[1188,1309,"You have a little, uh..."],[3853,3924,"Fuck."],[4133,4237,"You're gorgeous."],[5705,5772,"This time,"],[5834,5968,"I want to hear you say my name."],[7052,7144,"Hunter."],[7186,7369,"Just like that, Little Bird."],[7499,7661,"It feels so good."],[8179,8287,"Does it, baby?"]],"58":[[325,400,"Are you okay?"],[446,554,"I'm so sorry, I..."],[671,792,"I'll go get some bandages."],[1814,1868,"You know she'll never"],[1868,1939,"be safe with you."],[1989,2118,"I'll never let her be."],[2239,2406,"I can't let her get hurt because of me."],[3232,3353,"Hunter, I'm okay."],[3457,3520,"Wren..."],[3862,3941,"I told you"],[3978,4045,"that all I want"],[4045,4200,"is for you to be safe and happy."],[4387,4546,"Even if that means not being with you."],[4562,4642,"But I'm happy"],[4654,4758,"because I'm with you."],[4954,5021,"I,"],[5021,5176,"Alpha Hunter Silver,"],[5209,5422,"break my mate bond with Wren Wolfhart."]],"59":[[563,654,"Trust me, Little Bird."],[775,850,"I love you."],[959,1038,"I'll do whatever it takes"],[1038,1121,"to keep you safe."],[2077,2110,"Hunter!"],[2552,2590,"I,"],[2627,2756,"Alpha Hunter Silver,"],[2811,3007,"break my mate bond with Wren Wolfhart."],[3257,3399,"I can't believe you broke our bond."],[3791,3903,"This whole house"],[3999,4087,"is all mine."],[4179,4295,"No stepmother."],[4366,4479,"No Anneliese."],[4575,4658,"Just me,"],[4758,4825,"alone,"],[4959,5159,"living a quiet, peaceful life."],[5347,5484,"Which is what I've always wanted."],[5601,5755,"But it's not what you want anymore."],[5885,5960,"I'm Athena,"],[6001,6068,"your wolf."],[6135,6235,"My wolf?"],[6297,6423,"I'm sorry that it took me"],[6423,6514,"so long to arrive."],[6552,6690,"But I've come just in time."],[6765,6911,"Your mate is in danger."],[6952,6998,"Hunter?"],[7570,7670,"What did I just see?"],[7720,7807,"That's your mate's sight."],[7866,7945,"It lets you know"],[7945,8045,"when your mate needs help,"],[8099,8237,"and Hunter needs you now."],[8270,8345,"What's wrong with him?"],[8391,8579,"His curse is making him very sick,"],[8604,8762,"and enemy forces are about to"],[8762,8888,"attack Silver Castle."],[8925,9009,"You can stay here"],[9009,9159,"and live the life you always wanted,"],[9217,9338,"or you can go save your mate."],[9405,9530,"The choice is yours."],[10602,10714,"I'm coming, Hunter."]],"60":[[342,479,"Our allies are doing well"],[479,613,"against the Silver Pack."],[675,809,"Now all that's left"],[809,909,"is to kill their Alpha"],[996,1172,"and get the revenge we deserve."],[1580,1634,"Alpha!"],[1755,1881,"Our pack is holding up okay."],[1922,2068,"But their army is larger than ours."],[2469,2531,"Hey!"],[2585,2669,"I got this."],[2756,2844,"Save your strength."],[3257,3353,"Why now..."],[4091,4204,"That's what you didn't know"],[4204,4300,"about your curse."],[4329,4466,"If you break a mate bond,"],[4500,4654,"you damage your human spirit."],[4713,4796,"You'll die,"],[4796,4979,"unless you give control over to me."],[5526,5701,"I'm at my most powerful now,"],[5701,5755,"Hunter."],[5809,5947,"I can save your pack."],[5980,6181,"Just give control over to me."],[6210,6335,"Don't do it, Hunter!"]],"61":[[225,291,"Wren?"],[346,513,"Don't be foolish, human."],[546,804,"Only I can save the Silver Pack now."],[842,888,"No."],[913,1034,"Then stay away from her!"],[1105,1242,"And if I have to dispose of you"],[1242,1338,"to save my pack,"],[1380,1480,"then I'll consider it"],[1480,1639,"a worthy sacrifice."],[1647,1693,"No!"],[2014,2093,"That's my wolf,"],[2127,2185,"Athena."],[2260,2398,"You have a wolf, Little Bird."],[2419,2494,"Exactly."],[2560,2698,"So you won't have to fight alone."],[2781,2923,"It's time I break your curse."],[3082,3240,"It's been a long time, Athena."],[3274,3340,"It's not a pleasure"],[3340,3495,"to see you again, Fenris."],[3528,3641,"This is the first time"],[3641,3866,"you've awoken in 500 years."],[3899,3978,"And this time,"],[3978,4108,"I will take you down for good."],[4533,4713,"We don't know how to break my curse."],[4713,4850,"I can figure this out!"],[4917,5067,"I'll start with this one first."],[5267,5355,"I love you."],[6110,6277,"I'm still happy you told me."],[6418,6548,"What if we bond again?"],[7674,7803,"You may be bonded again,"],[7803,7966,"but the damage is done."]],"62":[[37,179,"You may be bonded again,"],[179,337,"but the damage is done."],[400,521,"If I let you take over,"],[729,880,"you promise not to hurt Wren..."],[892,971,"Hunter, no!"],[1071,1222,"I'll agree to those terms."],[1393,1493,"Then I'll do it."],[1509,1609,"I won't let you!"],[1668,1722,"No!"],[1805,1968,"Foolish girl."],[2010,2135,"I'm taking control"],[2135,2302,"whether you like it or not."],[2344,2498,"Wren, get out of the way!"],[2498,2711,"No, I won't let you take Hunter!"],[2731,2790,"No!"],[2886,2973,"Wren!"],[3586,3778,"You were willing to stand in harm's way"],[3778,3874,"to save him."],[3908,4074,"Your act of selfless love"],[4074,4183,"broke the curse."],[4233,4316,"Good work, Wren."],[4808,4863,"Wren?"],[5075,5209,"I think you broke my curse."],[5376,5434,"I did?"],[5718,5764,"We did!"],[5839,5997,"We broke each other's curse!"],[6698,6773,"I'm sorry."],[6806,6952,"Are we interrupting something?"],[7332,7499,"This should be fairly easy, right?"],[7532,7586,"I mean,"],[7615,7691,"Alpha Hunter may be"],[7691,7807,"a worthy opponent, but"],[7849,7970,"Wren's a liability."],[7987,8120,"Why don't we see about it, then?"],[8270,8304,"Wait,"],[8337,8391,"what?"]],"63":[[75,108,"Wait,"],[141,196,"what?"],[254,417,"Ready to hash it out, Anneliese?"],[608,688,"Try me."],[2289,2410,"Found the old lady hiding out"],[2410,2527,"about a mile from here."],[2540,2715,"I had nothing to do with this!"],[2715,2923,"They ratted you out already."],[3169,3345,"As the heads of the Silver Pack"],[3345,3482,"and the Wolfheart Pack,"],[3482,3611,"we have decided your punishment."],[3741,3845,"Wizard Lucian?"],[4237,4304,"That's"],[4329,4471,"the wizard that..."],[4487,4633,"Made the curse that you put on Wren?"],[4713,4763,"Yes,"],[4813,4859,"that's him."],[4988,5117,"He's here to return the favor."],[5163,5263,"He will curse you mute,"],[5296,5484,"and he will strip you of your wolves."],[5492,5605,"You can't do this."],[5734,5943,"Please, please, anything but that!"],[5960,6060,"This is impossible."],[6093,6214,"Even you don't have the money for"],[6235,6327,"that level of magic."],[6327,6393,"We do,"],[6393,6489,"actually."],[6506,6594,"It was about the cost"],[6594,6773,"of a summer castle up north."],[6773,6819,"You know,"],[6881,6931,"one of my"],[6931,7077,"engagement presents."],[7190,7240,"Please,"],[7265,7374,"go ahead, Wizard Lucian."],[7565,7611,"No."],[7736,7799,"No."],[7895,7978,"Luna"],[7995,8083,"dea,"],[8116,8204,"silentium"],[8254,8412,"in aeternum. - Don't do it!"],[8412,8537,"Stop! No!"],[8537,8700,"How about those be the last curses"],[8700,8846,"we face in our lives, Little Bird?"],[8908,9009,"Sounds like a plan."]]}