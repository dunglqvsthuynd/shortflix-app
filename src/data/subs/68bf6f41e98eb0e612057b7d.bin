8062,8208,"scrubbing the floors"],[8208,8354,"while the entire school"],[8354,8466,"treats me like garbage!"],[8525,8575,"Should we start"],[8575,8712,"calling her Cinderella?"],[8792,8954,"Cinderella at least got a prince."],[8988,9104,"I heard she put out for"],[9104,9305,"Eli Haines and he won't touch her"],[9321,9471,"with a ten-foot pole now."]],"28":[[16,120,"It's so nice to see"],[120,271,"everything in its place."],[271,429,"Everyone where they belong."],[775,850,"What's wrong, brother?"],[946,1038,"I don't know."],[1130,1326,"Is everything really in its"],[1326,1530,"right place, sis?"],[1601,1689,"Zane, cut it out."],[1760,1864,"Don't worry about him, sis."],[1885,2027,"He's just a moody bastard."],[2460,2619,"Katie Walker is an orphan"],[2619,2731,"discovered by her adopted"],[2731,3044,"mother in an alley 13 years ago."],[3061,3132,"I need more."],[3528,3670,"Zane's getting suspicious."],[3728,3845,"I need you to get me another"],[3845,4062,"DNA test from Dr. Addams."],[4329,4654,"Well, well, well."],[4792,4917,"Look who finally"],[4917,5030,"got a promotion."],[5142,5280,"Are you deaf, bitch?"],[5330,5451,"Or are you just too"],[5451,5593,"stupid to hear me?"],[5843,6106,"Whoever gets this trash to"],[6106,6377,"lick a plate wins a grand."],[6489,6685,"Think she's desperate enough?"],[6685,6781,"Come on, lick the plate."],[6781,6848,"You know you want it."],[6848,6956,"I'd rather die."],[6998,7090,"Go ahead, try me."],[7924,8041,"Lick it, Katie."],[8062,8112,"Come on."],[8179,8274,"Oh..."],[8291,8466,"What's wrong, Katie?"],[8533,8675,"You don't wanna play?"],[8875,8946,"Come on."],[8958,9138,"Almost there."],[9430,9505,"Lick it!"],[9505,9693,"Or I'll do more than get your"],[9693,9851,"trash mother fired."],[9922,10022,"I'll get her ki-"],[10085,10281,"I think that's enough, sis,"],[10477,10548,"don't you?"]],"29":[[150,275,"Zane, this bitch almost"],[275,425,"ruined our lives."],[462,654,"Nothing will ever be enough."],[717,959,"And yet, you're the one who's"],[959,1126,"embarrassing this family now."],[1197,1317,"You want to be a Maddox?"],[1359,1584,"Then start acting like one."],[1618,1764,"Because right now,"],[1810,2068,"you're nothing more than a disgrace."],[3495,3570,"Are you alright?"],[3703,3766,"It's fine."],[3795,3853,"I'm used to it."],[4245,4354,"What if I helped you find"],[4354,4462,"your real family?"],[4583,4721,"I don't have any family."],[5226,5301,"Baby,"],[5355,5488,"you can't let them get"],[5488,5609,"to you like this."],[5714,5855,"You have to go to homecoming"],[5855,6031,"and just enjoy yourself."],[6318,6402,"I'd rather die."],[6448,6502,"There's just no way"],[6502,6589,"I am going back in there."],[6727,6785,"I don't even"],[6785,6877,"have a dress anymore."],[6973,7107,"Oh, honey."]],"30":[[350,421,"Ms. Walker,"],[421,525,"I'm here for Katie."],[550,617,"Come in!"],[875,963,"This is for you."],[1368,1422,"Will you be my date"],[1422,1505,"for homecoming?"],[1651,1693,"Wait."],[1810,1914,"What about your parents?"],[2139,2273,"You're the real Maddox heiress,"],[2273,2335,"aren't you?"],[2556,2598,"I don't know."],[2852,2936,"I found this photo of you"],[2936,3019,"from freshman year."],[3048,3182,"You're wearing the bracelet."],[3182,3319,"It's been yours all along."],[3432,3511,"It doesn't matter, Eli."],[3511,3607,"Nobody believes me."],[3607,3707,"I believe you."],[3753,3874,"You have to show them."],[3883,4024,"Right now, at homecoming."],[4037,4124,"You deserve to know your"],[4124,4220,"family, Katie."],[4329,4408,"You and your mother shouldn't"],[4408,4496,"have to be alone."],[4984,5084,"What about your parents?"],[5109,5242,"You're the Maddox heiress."],[5321,5434,"They'll be thanking me once I"],[5434,5547,"reunite you with your brothers."]],"31":[[600,679,"It's so nice when"],[679,804,"everyone loves me."],[1743,1889,"Well, well, well."],[2010,2052,"Look who can"],[2052,2139,"clean themselves up..."],[2177,2256,"literally."],[2994,3053,"This is it."],[3069,3169,"I'm finally gonna get a"],[3169,3357,"chance to prove that I am the"],[3357,3578,"lost Maddox heiress, not Solane."],[3578,3695,"They have to believe me."],[3791,3849,"You know,"],[3899,4041,"now that I see her in a dress,"],[4062,4120,"she really does"],[4120,4191,"look like Mom."],[4270,4316,"Come on, bro."],[4316,4421,"You're imagining things."],[4546,4646,"Are you serious?"],[4984,5046,"I can't let them"],[5046,5180,"see who she really is."],[5196,5372,"This is my family now."],[5459,5593,"We need to do something."],[5593,5655,"Do what?"]],"32":[[855,975,"I'd like to show you something."],[1067,1130,"What could possibly"],[1130,1213,"be left to show us."],[1388,1455,"Let her speak."],[1647,1872,"Well, Eli has proved that I'm actually-"],[1872,2173,"Ladies and gentlemen!"],[2506,2644,"As your class president,"],[2669,2877,"it is my honor to announce this"],[2877,3153,"year's Homecoming Queen!"],[3465,3570,"Usually,"],[3578,3774,"this category is all locked up"],[3803,3937,"days in advance."],[3987,4112,"But at the last minute,"],[4141,4329,"we had a surge of votes."],[4416,4466,"So,"],[4537,4700,"I'd like you all to join me"],[4738,4959,"in welcoming this year's"],[4959,5067,"Homecoming Queen"],[5067,5251,"to the stage!"],[5355,5522,"Katie Walker."],[6227,6322,"What's going on?"],[6456,6744,"Oh, how unexpected!"],[6781,6873,"Come on, Katie."],[7040,7161,"Come get your crown."],[8141,8179,"Sir,"],[8220,8299,"it's Katie Walker."],[8337,8375,"What?"],[8412,8450,"Now?"],[8491,8608,"There she is."],[8771,8942,"Doesn't she look beautiful?"],[10860,11102,"Here she is, everyone!"],[11123,11473,"Trash Queen of Kingston High."],[11540,11803,"Sir, I believe Katie Walker"],[11803,11945,"is your true sister."]],"33":[[759,863,"Please, no."],[880,971,"She's lying."],[1021,1142,"I am your real sister."],[1142,1301,"I'm sure you are."],[1405,1534,"I have proof!"],[1634,1726,"Then speak."],[2002,2047,"Here."],[2160,2252,"I found these photos of Katie"],[2252,2373,"wearing your family brac