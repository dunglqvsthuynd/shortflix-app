{"1":[[2156,2231,"Checkmate."],[2882,2948,"Hold on."],[3290,3407,"This is about my baby sister."],[3528,3586,"Mr. Maddox,"],[3616,3674,"we found her."],[3716,3770,"You’ve found our"],[3770,3887,"long lost sister?"],[3920,3987,"The Maddox heiress"],[3987,4083,"has been located?"],[4141,4204,"Where is she?"],[4250,4358,"Kingston High School."],[5551,5626,"Can’t wait for Ryan to see"],[5626,5684,"me in my dress"],[5684,5797,"at the Homecoming Dance."],[5843,5968,"You're beautiful, Katie."],[5993,6122,"I'm sure he won't be able to"],[6122,6264,"take his eyes off you."],[6285,6356,"Mom..."],[6402,6519,"don't say that at school."],[6573,6690,"I have something for you."],[7015,7165,"It's nothing extravagant."],[7228,7286,"But it's all"],[7286,7394,"that I could afford."],[7532,7628,"It's perfect."],[7678,7753,"I can't believe I get to"],[7753,7832,"go to Homecoming with the"],[7832,7920,"principal's son."],[8003,8083,"The boy I’ve had a crush on"],[8083,8174,"since..."],[8174,8274,"Kindergarten."],[8616,8675,"I couldn’t have done it"],[8675,8750,"without you, Mom."],[8783,8904,"Thank you for adopting me,"],[8996,9113,"raising me like your own,"],[9129,9246,"even when you had nothing."],[9288,9346,"Life was already"],[9346,9434,"so hard for you."],[9496,9697,"You are my daughter, Katie."],[9726,9909,"I wouldn't change anything."],[10331,10393,"Ryan is here."],[10447,10510,"I'll see you later."]],"2":[[100,166,"Hey, Ryan."],[554,621,"Hey, Ryan."],[658,709,"Katie,"],[729,850,"you finished my AP English"],[850,909,"midterm paper?"],[934,984,"Yeah."],[1034,1092,"I was thinking maybe next time"],[1092,1205,"I can tutor you,"],[1222,1343,"so you know it's not..."],[1376,1443,"cheating."],[1576,1710,"This bitch is the stupidest"],[1710,1830,"nerd I've ever seen."],[1868,1960,"How could she think I would"],[1960,2031,"ever date a"],[2031,2152,"glorified maid for real?"],[2223,2314,"At least she could write an essay"],[2314,2406,"on Shakespeare."],[2419,2540,"You sure it's perfect?"