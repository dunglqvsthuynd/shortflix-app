atie, wait."],[296,346,"No,"],[408,454,"Eli."],[563,621,"What do you mean?"],[633,734,"There must be a way."],[759,880,"You need to leave me alone."],[967,1113,"But, but I don't want to."],[1172,1255,"You have to."],[1430,1518,"Your family's already going"],[1518,1584,"to kill you for what"],[1584,1664,"you've done for me."],[1810,1935,"You insulted the Maddoxes."],[2181,2264,"You need to leave me alone."],[2306,2369,"Katie..."],[2473,2540,"Please."],[2798,2890,"Please."],[3019,3086,"No."],[3578,3670,"Fuck."],[4700,4738,"Where are you"],[4738,4796,"running off,"],[4796,4913,"looking like that?"],[4917,4975,"mon dieu."],[5092,5280,"Like a modern interpretation"],[5280,5380,"of Les Misérables?"],[5605,5693,"Sorry, I..."],[5801,5914,"Say no more, I understand"],[5914,5997,"very well the"],[5997,6156,"tragedies of adolescence."],[6227,6335,"But you are..."],[6335,6393,"Katie Walker."],[6460,6519,"Are you not?"],[6802,6906,"The talented one."],[7273,7407,"But the talent is"],[7407,7503,"nothing without the"],[7549,7640,"resilience."],[7686,7741,"Ma chérie."],[7937,8003,"Do you have that?"],[8504,8554,"Come."],[8900,8971,"Let's talk."]],"36":[[408,500,"Cartonné."],[613,692,"Katie."],[813,938,"You are wasted here."],[2323,2402,"Katie,"],[2414,2569,"you're needed in the cafeteria."],[2665,2748,"Five more minutes."],[2852,2907,"Do you want to"],[2907,3028,"keep your scholarship?"],[3144,3215,"Of course I do."],[3224,3315,"Then hustle."],[3357,3457,"You need to earn your place"],[3457,3549,"here at Kingston."],[3945,4012,"Yes, ma'am."],[4162,4270,"Yeah, well, I don't really"],[4270,4366,"have much of a choice."],[4567,4667,"You have spent your life"],[4667,4817,"doing what is necessary."],[4867,5046,"Okay, but, ma chérie,"],[5146,5313,"now is the time"],[5313,5572,"to claim what is yours."]],"37":[[20,187,"I am not only an art teacher."],[367,479,"It amuses me to let people"],[479,625,"think so, but..."],[763,950,"I am a curator at"],[950,1138,"Louvre in Paris."],[1217,1267,"Yep."],[1422,1493,"Wait...What?"],[1626,1755,"My husband is also the"],[1755,1906,"richest man in France."],[2072,2168,"How do you say?"],[2206,2464,"He is the CEO of the biggest"],[2464,2610,"fashion houses."],[2635,2711,"Jean Moret,"],[2752,2865,"perhaps you've heard of him?"],[3053,3294,"So, Katie, we are having a show"],[3332,3566,"opening in two months."],[3745,3912,"Come to Paris with us."],[4066,4179,"Stay at our château."],[4287,4354,"You will homeschooled"],[4354,4491,"for a few months."],[4592,4650,"Katie, there is"],[4650,4821,"potential in you."],[4921,5055,"Let's see what happens when"],[5092,5230,"you are free to chase it."],[5447,5555,"I can't."],[5676,5780,"Mom is in a wheelchair."],[5855,5968,"I have to take care of her."],[6177,6231,"Tomieux,"],[6272,6339,"bring her."],[6423,6581,"We have the best physical"],[6581,6664,"therapists in the"],[6664,6748,"south of France."],[6823,6890,"We will help her"],[6890,6986,"get better too."],[7194,7378,"Katie, you must come."],[7449,7494,"Okay?"],[7778,7945,"I've always wanted a protégé."],[7974,8041,"Oui?"]],"38":[[487,638,"Katie Walker was a no-show."],[638,775,"Maybe she transferred."],[817,963,"Or maybe Sloane had her killed."],[1413,1476,"You're telling me"],[1476,1564,"you found nothing."],[1564,1676,"Nothing, sir."],[1735,1876,"No credit card activity,"],[1876,1976,"no flight records,"],[2022,2139,"no phone signal."],[2198,2339,"It's as if she simply"],[2373,2502,"ceased to exist."],[2569,2652,"That's impossible."],[2765,2890,"Someone must know something."],[2923,3161,"Or perhaps, Master Zane,"],[3228,3353,"she doesn't want to be found."],[3457,3541,"She's my sister."],[3687,3845,"That has yet to be proven."],[3891,3949,"You believe it?"],[4037,4162,"You told me so."],[4162,4220,"I do."],[4312,4550,"But belief and evidence are"],[4583,4662,"not the same thing."],[5163,5213,"Find me proof."]],"39":[[2093,2193,"Who is that?"],[4471,4592,"Who's that?"],[4600,4704,"Catherine Moret,"],[4704,4796,"the French heiress."],[4796,5017,"Her family basically owns Paris."],[5017,5121,"That watch is a"],[5121,5292,"one of a kind Rolex."],[5305,5392,"I heard Chanel"],[5392,5551,"custom-made her uniform."],[5572,5651,"Kingston let her"],[5651,5751,"skip the dress code."],[5751,5864,"She might even be"],[5864,5985,"richer than you, Sloane."],[6014,6101,"Are you going to invite her"],[6101,6252,"to the Maddox banquet, Sloane?"],[6277,6356,"Mm-hmm."],[6464,6519,"We'll see."]],"40":[[1851,1906,"Katie?"],[2022,2085,"How'd you know?"],[2114,2214,"Oh, come on."],[2243,2348,"You really thought a haircut"],[2348,2435,"would fool me?"],[2456,2535,"I always saw you for"],[2535,2610,"who you really are."],[2627,2731,"What happened to you?"],[2806,2886,"I looked but..."],[3691,3782,"I was in Paris."],[3791,3903,"It was amazing."],[3945,4095,"The Moret's adopted me."],[4158,4312,"So me and my mom were free."],[4375,4504,"That's incredible."],[4637,4688,"I know."],[4867,5017,"I never forgot about you."],[5263,5309,"You know?"],[6039,6135,"I have some..."],[6193,6327,"unfinished business."],[6348,6398,"Sloane?"],[6468,6573,"One of the things."],[6610,6677,"How can I help?"],[6810,6902,"A few ways."],[6981,7144,"But first I need an invite to"],[7144,7257,"the Maddox banquet."],[7319,7407,"Consider it done."]],"41":[[141,291,"I'll need something stunning"],[291,479,"for the banquet, of course."],[521,654,"Ooh, custom?"],[704,946,"I think 50K minimum."],[1001,1051,"Can you do that"],[1051,1167,"for me, Archer?"],[1167,1238,"Of course."],[1255,1372,"Anything for my sister."],[1422,1493,"To coming out to"],[1493,1618,"society as a Maddox."],[1634,1743,"Nothing is too grand."],[2264,2364,"Those are the new limited"],[2364,2485,"edition Louboutins."],[2485,2635,"No one has those yet."],[3186,3395,"OMG, she's so chic."],[3445,3574,"Oh my gosh, how much is that?"],[3574,3645,"I don't know."],[3674,3820,"Is she trying to outdo you, Sloane?"],[3912,4008,"She does have that"],[4008,4120,"je ne sais quoi."],[4229,4425,"Who is that?"],[4487,4629,"She's the new girl."],[4629,4704,"Something..."],[4708,4813,"Moret."],[4863,4988,"French heiress."],[5005,5080,"A Moret?"],[5176,5246,"Sloane."],[5271,5317,"They're the"],[5317,5442,"richest family in France."],[5755,5897,"You know, it's funny."],[5947,6101,"A Moret in town, and not a single"],[6101,6210,"Maddox has bothered to"],[6210,6302,"befriend her yet."],[6548,6619,"An oversight."],[6660,6706,"Really."],[6773,6873,"We should fix that."],[7002,7052,"Sloane?"],[7152,7290,"Invite her to the banquet."],[7407,7540,"I find her tacky."],[7565,7786,"You're a Maddox, Sloane."],[7820,7895,"We don't dismiss"],[7895,8028,"potential allies."],[8204,8358,"Fine, brother."]],"42":[[592,729,"Katherine!"],[746,867,"Darling!"],[867,963,"Sloane?"],[1001,1055,"To what do I"],[1055,1117,"owe the pleasure?"],[1172,1297,"I've been meaning to extend"],[1297,1401,"an invitation."],[1434,1539,"There's a banquet this"],[1539,1701,"weekend at the Maddox estate"],[1701,1818,"to announce me as the"],[1818,2027,"official heiress."],[2143,2344,"I'd love for you to come."],[2410,2510,"Love to."],[2523,2656,"I'm sure it'll be..."],[2723,2827,"memorable."],[3486,3641,"The bracelet is beautiful."],[3749,3832,"Where'd you get it?"],[4166,4333,"It's a family heirloom."],[4371,4466,"It's exquisite."],[4558,4625,"Congrats."],[4721,4938,"What the hell was that about?"],[4996,5084,"Could she know?"],[5192,5301,"There's no way."]],"43":[[179,229,"Ryan?"],[258,312,"Ryan!"],[458,525,"Oh, hey, Sloane."],[588,692,"What's wrong with you?"],[834,892,"Nothing."],[921,1084,"Well, where have you been?"],[1101,1201,"I need help picking my dress"],[1201,1317,"for the banquet tonight."],[1388,1576,"Yeah, of course."],[1697,1747,"I gotta go."],[1747,1822,"Maybe after school."],[1822,1885,"I gotta go."],[1893,1972,"I gotta go."],[2781,2927,"Hey, fuck you, man."],[2986,3136,"Keep dragging this out."],[3182,3265,"I know."],[3286,3345,"I know."],[3407,3478,"So..."],[3641,3716,"When are you gonna tell people"],[3716,3787,"about us."],[3937,4045,"I told you."],[4099,4195,"I need a Maddox family to"],[4195,4350,"get me into college first."],[4379,4491,"You think I'm gonna spoil my"],[4491,4621,"chances over this?"],[4704,4796,"Sloane needs to think I'm"],[4796,4884,"obsessed with her."],[4904,5055,"She is just a spoiled brat but-"],[5055,5109,"So..."],[5121,5313,"You're gonna keep using her"],[5313,5530,"until you get what you want,"],[5547,5593,"huh?"],[5626,5701,"Don't pretend like it"],[5701,5814,"doesn't get you off."],[6222,6356,"Maybe a little..."],[7223,7315,"Once a liar,"],[7315,7399,"always a liar."]],"44":[[575,654,"Daniel Moyer."],[1559,1626,"Relax."],[1655,1697,"I just have a"],[1697,1805,"proposition for you."],[1910,2014,"You and Ryan."],[2097,2177,"It's real between you,"],[2177,2223,"isn't it?"],[2310,2385,"I don't know what you're"],[2385,2444,"talking about."],[2494,2590,"I'm sure you do."],[2656,2815,"I think it's time you stop waiting"],[2815,2944,"around for him to go public."],[3078,3315,"And you care why?"],[3399,3557,"Just say I like seeing things"],[3557,3611,"work out the way"],[3611,3699,"that they should."],[3787,3832,"And right now"],[3832,3933,"you're both stuck."],[4024,4070,"What exactly"],[4070,4166,"are you offering?"],[4216,4396,"Just pushing the"],[4396,4491,"right direction."],[4658,4783,"But I need something first."],[4825,4938,"Being so close to Ryan,"],[4938,5088,"you must have a lot"],[5088,5201,"of dirt on Sloane."],[5438,5634,"You have no idea."],[5647,5822,"Tell me everything."]],"45":[[1138,1222,"Wow, sis."],[1247,1351,"You look unreal."],[1455,1526,"I know."],[1693,1868,"Tonight has to be perfect."],[1926,2060,"Who could possibly go wrong?"],[2139,2198,"Zane."],[2306,2369,"I feel like he's"],[2369,2531,"never really accepted me."],[2585,2631,"Well Zane's a"],[2631,2731,"bastard half the time."],[2752,2848,"He'll get over it."],[2886,2994,"Besides, the DNA"],[2994,3119,"test proved you're our sister."],[3144,3240,"What more does he need?"],[3807,3937,"I'm gonna go find Ryan."],[5109,5142,"You're being"],[5142,5230,"fucking weird, bro."],[5296,5384,"It can't be her."],[5430,5601,"Zane, it's too late for this."],[5618,5689,"We're about to announce her"],[5689,5789,"and you have no proof."],[5839,5926,"But that girl..."],[6035,6122,"Katie Walker?"],[6139,6272,"Are you still stuck on her?"],[6377,6485,"She disappeared, bro."],[6498,6569,"Probably fled"],[6569,6681,"the city in shame."],[6706,6777,"Enough already."],[6798,6906,"I won't risk losing my sister"],[6906,6969,"again over your"],[6969,7073,"gut feeling, Zane."],[7415,7536,"Where are you, Katie?"],[9163,9284,"Should be fun."]],"46":[[312,471,"Could it be her?"],[1021,1138,"For years,"],[1138,1280,"we searched for our sister."],[1384,1497,"Every lead,"],[1497,1714,"every whisper, every fake."],[1755,1856,"It all led us here."],[1906,1993,"To this moment."],[2064,2248,"Sloane, from the moment that"],[2248,2406,"we met you, I knew you had"],[2406,2627,"this presence, this fire,"],[2648,2836,"this unmistakable Maddox"],[2836,2894,"blood running"],[2894,2998,"through your veins."],[3086,3174,"Our family has built"],[3174,3403,"something great, something powerful,"],[3411,3490,"and tonight,"],[3528,3712,"we honor what was once lost."],[3774,3895,"To Sloane Maddox."],[4959,5125,"I told you already, I need"],[5125,5238,"the Maddox family to get me"],[5238,5355,"into college first."],[5363,5480,"You think I'm gonna spoil my"],[5480,5605,"chances over this?"],[5630,5734,"Sloane needs to think I'm"],[5734,5839,"obsessed with her."],[5939,6076,"She's just a spoiled brat, but..."],[6156,6385,"So you're gonna keep using her"],[6385,6527,"until you get what you want."],[6556,6656,"Don't pretend like it"],[6656,6773,"doesn't get you off."],[6819,6890,"Maybe a little."],[7545,7624,"You think I"],[7624,7791,"actually care about school?"],[7828,7924,"Please."],[7953,8128,"I barely passed junior year."],[8187,8237,"Maddox money"],[8237,8324,"fixes everything."],[8425,8479,"Maddox money"],[8479,8571,"fixes everything."],[8637,8808,"That was taken out of context."],[8808,8913,"Technically,"],[8963,9142,"I'm not even a real Maddox."],[9955,10035,"Sloane, what the"],[10035,10135,"hell does that mean?"],[10414,10543,"You don't understand."],[10573,10668,"I meant I didn't"],[10668,10827,"feel like a real Maddox."],[11540,11703,"You."]],"47":[[20,66,"Katie?"],[162,246,"Is it really you?"],[375,521,"I think my work here is done."],[642,771,"Enjoy your new sister."],[884,988,"Katie, you have some"],[988,1084,"explaining to do!"],[1084,1138,"Wait!"],[1739,1847,"You're our real sister,"],[1893,1951,"aren't you?"],[1993,2102,"You think? Or you know?"],[2135,2202,"I just..."],[2281,2398,"I need proof."],[2502,2619,"Let me get this straight."],[2681,2790,"You humiliated me."],[2848,2932,"That bracelet it's mine."],[2948,3003,"Give it back."],[3028,3119,"She's lying."],[3382,3461,"Abandoned me."],[3707,3774,"Let the entire"],[3774,3924,"school tear me apart."],[4175,4295,"And still you need proof?"],[4454,4633,"Save your breath, Maddox."],[4892,4963,"Do you think I want to be"],[4963,5055,"related to you?"],[5234,5321,"To the brothers who threw me"],[5321,5447,"away like I was garbage?"],[5784,6026,"Go back inside and enjoy the"],[6026,6151,"sister you deserve."],[6644,6702,"I'm tired of"],[6702,6848,"waiting around for answers."],[6865,7019,"I gotta find them myself."]],"48":[[62,233,"That bitch Katie has clearly"],[233,383,"come back to ruin me."],[487,650,"Ah, that jealous cow."],[746,779,"She'll do"],[779,917,"anything to tear me down."],[975,1030,"Why did you say"],[1030,1109,"you weren’t technically"],[1109,1209,"the Maddox heiress?"],[1343,1443,"She edited what"],[1443,1559,"I said with AI."],[1601,1710,"And all those other videos?"],[1710,1839,"Deep fake."],[2223,2364,"You have to believe me."],[2377,2469,"Baby sister,"],[2519,2615,"of course we believe you."],[3036,3111,"We believe you,"],[3169,3278,"but your actions affect our"],[3278,3403,"family's reputation."],[3436,3566,"You have to be extra careful."],[3566,3632,"Understand?"],[3766,3866,"Of course."],[3895,4008,"I'm here for you, sis."],[4045,4133,"Now, let's go pay"],[4133,4229,"that Katie a visit."],[4254,4304,"No one messes"],[4304,4408,"with my baby sister."],[5568,5663,"We need to talk."]],"49":[[1142,1234,"Oh wow,"],[1276,1351,"what an honor."],[1401,1451,"To what do I owe"],[1451,1564,"this little house visit?"],[1897,1968,"Drop the act."],[2181,2264,"Don't know what you could be"],[2264,2369,"possibly talking about."],[2373,2481,"That stunt you pulled?"],[2510,2627,"The one where I exposed your"],[2627,2702,"fake sister and her"],[2702,2815,"cheating boyfriend?"],[2848,2936,"Yeah, real shame."],[2957,3065,"Sloane is our sister."],[3240,3303,"If you say so."],[3357,3399,"You're making"],[3399,3516,"powerful enemies."],[3553,3632,"So are you."],[3703,3845,"How dare you frame our sister"],[3845,3933,"and insult me?"],[3999,4049,"You keep this up"],[4049,4137,"and we'll destroy you."],[4229,4291,"That trick doesn't"],[4291,4404,"work twice, Maddox?"],[4433,4533,"Who do you think you are?"],[4733,4967,"She is Katherine Moret now."],[5030,5134,"Mr. Maddox."],[5326,5405,"Madame Moret?"]],"50":[[20,100,"Madame Moret?"],[258,375,"Yes, perhaps you gentlemen"],[375,492,"have heard the news."],[517,692,"I have legally adopted Katie"],[692,942,"and she is the newest heir of"],[942,1101,"the Moret fortune."],[1142,1251,"Let her go, Archer."],[1301,1359,"It doesn't matter."],[1359,1413,"This bitch tried"],[1413,1505,"to ruin our family."],[1505,1651,"And is anything of what she"],[1651,1793,"revealed untrue?"],[1860,1939,"Of course."],[2010,2160,"So you think to"],[2160,2285,"physically attack her?"],[2352,2485,"Archer, let go of her."],[2556,2648,"With all due respect,"],[2711,2773,"Madam Moret."],[2852,2965,"Sloane is my sister,"],[3019,3123,"and I'm going to do whatever it"],[3123,3269,"takes to protect her."],[3449,3541,"Archer, no!"],[3561,3712,"Get the fuck away from them."]],"51":[[633,767,"Are you fucking crazy, Zane?"],[892,992,"I'm crazy?"],[1042,1201,"You waltzed into Jean Moret's"],[1201,1326,"home and attacked his wife"],[1326,1447,"and adopted daughter."],[1447,1568,"She set Sloane up!"],[1584,1676,"I had my men"],[1697,1830,"look into those videos."],[1872,1943,"They're real."],[2206,2298,"If you don't believe me,"],[2360,2452,"ask your sister."],[2510,2702,"Now get the fuck out of here."],[3628,3883,"I apologize for my brother."],[3941,4016,"Are you all right?"],[4133,4208,"He didn't do much"],[4208,4308,"damage to me,"],[4366,4462,"Mr. Maddox."],[4800,4904,"Katie, I-"],[4904,5013,"Please just go."],[5221,5317,"Katie, please."],[5347,5505,"I know you're my real sister."],[5618,5684,"In here."]],"52":[[0,79,"Please, Katie,"],[91,204,"I spoke to Eli."],[237,375,"He swore he had a photo that"],[375,462,"someone deleted,"],[492,592,"so I went back through"],[592,709,"old yearbooks, looked at"],[709,900,"thousands and thousands of photos"],[930,1001,"over the years."],[1084,1172,"I found this."],[1267,1422,"Sloane stole everything from you,"],[1472,1589,"and pretended to be you."],[1614,1710,"Stop it, Zane."],[1739,1818,"You guys were the ones who"],[1818,1918,"called me a dirty liar."],[2022,2135,"Katie, listen to me."],[2135,2348,"Just take another DNA test."],[2389,2469,"You listen to me."],[2489,2631,"You found your heiress,"],[2665,2744,"so leave."],[2786,2902,"Stay away from me."],[2982,3144,"You have every right to hate"],[3144,3269,"us for trusting"],[3269,3411,"Sloane over you."],[3474,3536,"I know how much"],[3536,3645,"we hurt you, but..."],[3774,3820,"Leave."],[4346,4425,"Your sister is"],[4425,4537,"waiting for you at home."],[4571,4700,"I will make things right."],[4738,4875,"I'm not giving up on you, Katie."],[5793,5935,"Stupid Katie."],[5968,6085,"What the fuck happened?"],[6293,6393,"Those videos are real."],[6423,6485,"Aren't they Sloane?"],[6556,6652,"Of course not."],[6840,6952,"You believe me, don't you?"],[6998,7073,"Of course."],[7561,7653,"We'll get through this."],[8274,8508,"I need to get rid of this"],[8508,8833,"bitch once and for all."]],"53":[[246,429,"Ryan, how could you do this?"],[475,554,"What's going on?"],[592,679,"It's been brought to our"],[679,863,"attention that your AP"],[863,1105,"English Midterm, History final,"],[1105,1301,"Biology labs were done by"],[1301,1388,"another person."],[1438,1580,"This is a violation of the"],[1580,1751,"honor code and the worst case"],[1751,1901,"of cheating we have ever seen"],[1901,2006,"in the district."],[2014,2081,"What?"],[2081,2298,"Ryan Gaines, you are hereby"],[2298,2552,"expelled from Kingston High"],[2552,2740,"for gross plagiarism."]],"54":[[563,729,"What are you doing here?"],[788,905,"I came get you back, baby."],[934,1126,"Ugh, get off me."],[1647,1785,"How badly do you want to get"],[1785,1910,"revenge on Katie?"],[1960,2027,"Kill that fucking"],[2027,2131,"bitch if I could."],[2335,2385,"Then I have the"],[2385,2540,"perfect job for you."],[4383,4462,"What are you doing?"],[4904,5013,"Hello Katie dear."],[5772,5922,"Come on, where is she?"]],"55":[[296,408,"Why weren't you at school today, bro?"],[496,579,"I've been busy."],[713,763,"Fuck you for taking"],[763,880,"that girl Katie's side."],[930,975,"She practically"],[975,1088,"ruined our banquet."],[1130,1288,"Archer, you have no idea what"],[1288,1372,"you're talking about."],[1384,1484,"I know that that bitch has"],[1484,1601,"you by the throat and you'll"],[1601,1714,"do whatever she says."],[1764,1839,"Where's your loyalty?"],[1856,1947,"My loyalty?"],[1976,2064,"How are you gonna feel when"],[2064,2131,"you realize you've been"],[2131,2268,"torturing your own sister?"],[2444,2506,"Clue in, bro."],[2581,2690,"What the hell's going on?"],[2736,2882,"I thought you'd never ask."],[2952,3032,"Bring him in."],[3261,3340,"Dr. Addams?"]],"56":[[4,87,"Dr. Addams?"],[275,362,"Who did this to you?"],[475,550,"I deserve much worse"],[550,646,"for what I've done."],[663,742,"Please forgive me."],[842,909,"For what?"],[980,1213,"For switching the DNA tests."],[1697,1735,"What the fuck"],[1735,1822,"did you just say?"],[1864,2039,"Sloane, she made me do it."],[2093,2164,"Her father's the"],[2164,2256,"chief of the hospital."],[2256,2356,"She threatened me."],[2389,2519,"She was gonna have me fired,"],[2519,2602,"but she"],[2602,2740,"couldn't pass the test."],[2869,2932,"So I..."],[2952,3111,"just changed the results."],[3182,3269,"And Katie?"],[3549,3745,"Katie's your real sister."]],"57":[[0,191,"Katie's your real sister."],[191,304,"You cowardly dick!"],[504,579,"Where's Sloane?"],[955,1017,"Where is she?"],[1117,1163,"Who?"],[1180,1230,"Katie."],[1284,1343,"We were supposed to"],[1343,1426,"meet this afternoon."],[1438,1589,"She's not answering my phone."],[2548,2606,"You did this to"],[2606,2773,"yourself, you stupid bitch."],[2861,3036,"You got me expelled!"],[3107,3194,"You deserve it,"],[3236,3324,"you monster."],[3586,3645,"You're gonna die"],[3645,3741,"down here, Katie."],[3908,3987,"In the Maddox"],[3987,4108,"family basement."],[4137,4312,"Forgotten and ignored."],[4387,4542,"The Lost heiress,"],[4612,4750,"who never was."]],"58":[[108,162,"Hey!"],[392,487,"You motherfucker!"],[542,600,"Katie,"],[642,721,"are you okay?"],[1626,1726,"How'd you guys find me?"],[1730,1830,"When you got back from Paris,"],[1830,1893,"I added you to"],[1893,1960,"my cell phone."],[2031,2089,"I don't want to"],[2089,2210,"lose you ever again."],[2565,2694,"You saved my life, Eli."],[3132,3178,"He's gonna bury"],[3178,3290,"my body down here."],[3503,3574,"What the hell was she doing in"],[3574,3649,"your basement?"],[3670,3749,"Don't look at me!"],[3749,3820,"I didn't let him in."],[3924,4045,"How'd you get in here?"],[4058,4116,"Who let you in?"],[4175,4262,"You know who."],[4479,4546,"Sloane."],[4587,4700,"That evil bitch."],[4700,4821,"She's gonna pay for this."]],"59":[[70,120,"Katie,"],[162,221,"I'm sorry for not"],[221,287,"believing you."],[408,458,"I just wanted to"],[458,567,"find my baby sister."],[696,746,"I..."],[880,967,"I lost my way."],[1026,1130,"You are our real sister."],[1155,1263,"We should've known all along."],[1397,1534,"But why'd you want it to be"],[1534,1655,"Sloane so badly?"],[1751,1856,"Was I so unworthy"],[1856,1964,"of being a Maddox?"],[2085,2181,"It's not you."],[2235,2327,"It was us."],[2419,2506,"We're your brothers."],[2506,2565,"We're supposed"],[2565,2644,"to protect you."],[2677,2781,"But you got taken"],[2781,2890,"under our watch."],[2936,3090,"And then we finally found you,"],[3123,3261,"and saw how tough your life had been."],[3261,3395,"And there was Sloane"],[3395,3495,"who'd had it easy."],[3536,3624,"It made us feel less guilty"],[3624,3691,"over losing our"],[3691,3807,"sister for it to be her."],[3920,4037,"What's the difference now?"],[4166,4195,"You want me"],[4195,4266,"to forgive you?"],[4354,4483,"Guess what, I don't need you anymore."],[4558,4658,"And I sure as hell do not"],[4658,4775,"need to be tied to a family"],[4775,4884,"full of pig-headed,"],[4884,5025,"self-righteous assholes!"],[5492,5584,"Katie, wait!"],[6589,6706,"Katie, it's okay."],[6986,7069,"It's okay."],[8191,8337,"This feels familiar."],[8908,8975,"You feeling okay?"],[9071,9171,"It could be worse."],[9175,9325,"Yeah, you could be Sloane."],[9476,9547,"What do you think they're"],[9547,9613,"gonna do to her?"],[9617,9701,"Oh, I have no idea,"],[9701,9859,"but I can't wait."],[10406,10523,"You always believed me."],[10577,10744,"You did save my life."],[10794,10927,"Is that the only reason?"],[10969,11161,"Not because you're a Moret,"],[11194,11298,"or a Maddox,"],[11319,11386,"or because you saved"],[11386,11507,"me from an evil van."],[11649,11857,"You're just special."]],"60":[[304,517,"Students, please make your way to the"],[517,629,"gymnasium for a"],[629,788,"surprise assembly."],[796,959