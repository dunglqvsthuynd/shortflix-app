{"1":[[421,538,"Six years..."],[613,796,"finally out of the Dar War Zone."],[905,1055,"Ethan, what happened to you?"],[1159,1255,"Rachel, I love you."],[1459,1650,"You promised you'd come back."],[1650,1789,"But after six years,"],[1805,1974,"I waited six years."],[2022,2115,"You never did."],[2285,2519,"Mommy, where's Daddy?"],[2548,2711,"We're going to find him now."],[3257,3386,"2307 Bay Street."],[3415,3531,"This is where Ethan lives."],[3574,3692,"Why does it look abandoned?"],[3824,4047,"Mommy, I'm thirsty."],[4062,4112,"Okay, sweetie."],[4141,4283,"Just stay by the gate."],[4283,4408,"I'll go find us some water."],[4633,4704,"Thank you, babe."],[4704,4804,"Today's the election for"],[4804,4934,"deputy hospital director."],[4975,5063,"I think I'm gonna nail that."],[5063,5159,"Relax."],[5180,5355,"My dad already pulled some strings."],[5380,5509,"That position's yours."],[5876,5918,"Hey, buddy,"],[5947,6039,"once this is done,"],[6039,6147,"Dad's gonna buy you a robot."],[6168,6218,"Deal?"],[6239,6360,"Yeah, robots."],[6364,6577,"I want tons of robots."],[7820,7907,"Whose kid is this?"],[8045,8179,"What? Are you trying to get killed?"],[8641,8721,"Daddy!"]],"2":[[0,83,"Daddy!"],[250,291,"Dad!"],[496,665,"Stop calling me that."],[771,850,"I'm not your dad."],[863,955,"You are!"],[980,1071,"Look!"],[1071,1276,"You made this bracelet yourself."],[1793,1868,"Rachel..."],[1868,1972,"Rachel, I love you."],[1972,2062,"I'm sorry this is all"],[2062,2173,"I can give you right here."],[2173,2331,"This bracelet instead of a ring."],[2857,2944,"Your mom is..."],[2944,3107,"Sophie, Mommy is back-"],[4262,4341,"Ethan!"],[4487,4550,"Ethan."],[4550,4704,"I finally found you."],[4704,4921,"Rachel... how did you make it back?"],[4921,5142,"I waited for you for six years."],[5192,5317,"Why didn't you find me?"],[5613,5689,"It's okay."],[5689,5759,"You're okay."],[5759,5915,"That's what matters."],[5964,6110,"Oh, this is Sophie,"],[6110,6206,"our daughter."],[6206,6402,"I found out I was pregnant after you left."],[6548,6610,"Go on, honey,"],[6610,6694,"call him Daddy."],[7140,7210,"Dad."],[8095,8191,"Ethan,"],[8245,8366,"who is she?"]],"3":[[75,158,"Ethan?"],[266,404,"Who is she?"],[521,721,"Uh, hi, I'm Ethan's..."],[779,834,"Cousin."],[938,1046,"She's my cousin."],[1046,1188,"She's here asking for help."],[1455,1559,"Cover your face."],[1726,1914,"Ha! Figures."],[2027,2257,"The election starts in three hours."],[2260,2456,"Deal with your poor relative before then."],[2827,2990,"Ethan, why'd you call me your cousin?"],[3011,3086,"Today's my shot at"],[3086,3219,"deputy hospital director."],[3219,3299,"What would people think of me"],[3299,3428,"if you showed up like this?"],[3461,3626,"Deputy director of the hospital?"],[3674,3820,"Ethan, you're a doctor now?"],[3820,3970,"That's amazing."],[3970,4109,"Sophie has had a heart condition"],[4109,4183,"since birth."],[4183,4366,"Please, you have to help her."],[4533,4688,"Oh, here's a bank card."],[4688,4796,"There's 50 grand."],[4808,4971,"I saved up for Sophie's treatment."],[5105,5179,"What's the pin?"],[5234,5330,"Your birthday."],[5484,5588,"Alright, I'll get you an"],[5588,5699,"appointment with Dr. Barron."],[5699,5804,"He's the best heart surgeon"],[5804,5914,"at RW Hospital."],[5914,6156,"Dr. Barron at RW Hospital?"],[6172,6327,"I knew you still cared about us."],[6327,6473,"Well, I have things to do."],[6473,6539,"I'm leaving."],[6539,6602,"Wait, Ethan."],[6727,6856,"Would you find us a place to stay?"],[7132,7278,"Well, I'm a little strapped for cash"],[7278,7399,"because of the election, but..."],[7499,7706,"Here's $20. Go stay at a motel."],[7706,7820,"Wait for my call."],[8641,8733,"Sophie!"]],"4":[[196,250,"Mr. Harrington,"],[250,387,"what brought you back so suddenly?"],[492,762,"Today marks 25 years since"],[762,904,"my daughter's been missing."],[1000,1272,"I came back hoping for a miracle."],[1326,1534,"My daughter, where are you?"],[1672,1789,"Sophie! Sophie!"],[1789,1868,"Don't scare Mommy."],[1868,1976,"Wake up! Wake up!"],[2010,2231,"Somebody please save my daughter."],[2248,2356,"Baby."],[2369,2452,"Stop!"],[3082,3382,"Don't scare Mommy. Sophie, wake up."],[3410,3475,"You're-"],[3574,3703,"You're the man from the airport."],[3703,4008,"Please, my daughter's having a heart attack."],[4099,4212,"Please!"],[4233,4358,"That face..."],[4387,4504,"Baby..."],[4508,4696,"Sophie wake up, please."],[4713,4867,"Come with me, quickly."],[4867,4929,"Okay."],[6043,6285,"The resemblance... it's uncanny."],[6552,6610,"Oh,"],[6648,6817,"sir, thank you so much"],[6817,6932,"for saving my daughter."],[6948,7080,"I should be thanking you"],[7080,7178,"for saving me."],[7228,7399,"Sir? Sir!"],[7399,7549,"Sir, can you hear me?"],[8108,8262,"Thank God."],[8437,8550,"What is your name?"],[8612,8708,"Rachel Black."],[8825,8950,"Oh, I'm sorry."],[8950,9084,"I didn't mean to startle you."],[9104,9175,"That scar..."],[9205,9355,"have you had it since you were young?"],[9355,9426,"No,"],[9451,9567,"I've had it for a few years."],[9567,9663,"I got it from saving"],[9663,9802,"my husband from a landmine."],[9834,9920,"What?"],[10076,10219,"What about your parents?"],[10256,10410,"I don't have any."],[10435,10539,"I grew up in an orphanage."],[10777,10839,"Boss,"],[10856,10980,"the deputy director ceremony"],[10980,11056,"is about to start."],[11077,11227,"One of the candidates is Ethan Black."],[11294,11379,"Ethan Black?"],[11394,11493,"That's my husband."]],"5":[[16,229,"Ethan Black is your husband?"],[241,485,"Yeah, we've been married for six years."],[504,608,"Ethan's a candidate"],[608,892,"for deputy director at RW Hospital."],[896,1034,"Logically,"],[1034,1234,"you shouldn't be wearing so..."],[1401,1722,"I... I was... uh... I was living abroad"],[1722,1956,"when I got caught in a war zone."],[1960,2077,"I just returned."],[2214,2318,"I see."],[2519,2660,"Does he treat you well?"],[2698,2761,"Yeah,"],[2819,2943,"he just got an appointment"],[2943,3132,"with Dr. Barron for Sophie's condition."],[3211,3261,"Boss."],[3282,3399,"The election's about to start."],[3440,3638,"Dr. Barron's office is upstairs."],[3638,3740,"Go talk to him"],[3740,3895,"about your daughter's treatment plan."],[4237,4396,"Tell Julian to appoint"],[4396,4533,"Ethan as deputy director."],[4533,4679,"Consider it a repayment"],[4679,4888,"for Rachel saving my life."],[4888,5121,"And arrange a DNA test"],[5121,5309,"for both Rachel and me."],[5309,5430,"Yes, sir."],[5451,5627,"Rachel, could you be the daughter"],[5627,5758,"I've been searching for"],[5758,6005,"these past 25 years?"],[6143,6302,"Hi, Sophie, baby."],[6343,6567,"Mommy's gonna go see Dr. Barron, okay?"],[6594,6694,"Rest well."],[7002,7065,"Hello?"],[7069,7161,"You are?"],[7194,7340,"I'm Sophie Black's mom."],[7340,7507,"I'm here about her heart treatment plan."],[7741,7907,"I don't have a patient by that name."],[7957,8033,"You don't?"]],"6":[[0,137,"No, that's impossible."],[196,371,"My husband arranged for you to treat her."],[371,425,"Please, doctor,"],[425,608,"could you just... check again?"],[638,754,"My husband, he works here,"],[754,859,"Dr. Ethan Black."],[1051,1205,"Ethan Black?"],[1217,1338,"Yeah, that's him."],[1372,1564,"Ethan is with his wife and kid"],[1580,1743,"upstairs in the conference room."],[1743,1906,"And you, a scared freak,"],[1906,2064,"dare impersonate his family?"],[2093,2173,"Get out of here."],[2231,2385,"Stop wasting my time."],[2982,3036,"Daddy!"],[3532,3790,"Don't worry, my dad's got it handled."],[3791,4043,"Deputy director's in the bag."],[4512,4596,"You like it, babe?"],[4604,4729,"It's the new design."],[4750,5047,"This must cost... what... 50 grand?"],[5055,5206,"Thanks to that idiot Rachel"],[5206,5359,"handing over her money."],[5372,5447,"Don't worry."],[5451,5563,"I've got plenty to spare."],[5588,5659,"Let's go."],[5897,5993,"Boss, should I..."],[5993,6089,"let everyone know you're here?"],[6089,6247,"No need."],[6264,6448,"I came here for personal reasons"],[6448,6493,"this time."],[6493,6627,"I don't want others to know."],[6669,6794,"I just wanna see Rachel's"],[6794,6931,"husband's inauguration."],[7082,7190,"And then we'll leave."],[7265,7540,"Congratulations to Dr. Ethan Black,"],[7624,7844,"our new deputy director."],[7866,8045,"Please come up and share a few words."],[8546,8633,"Thank you all."],[8679,8875,"But I owe special thanks to my wife"],[8900,9071,"for her unwavering support."],[9117,9171,"Come up and share"],[9171,9263,"this moment with me, honey."],[10406,10489,"Daddy!"]],"7":[[16,237,"Isn't Ethan the director's son-in-law?"],[279,483,"Why is this little girl calling him \"Daddy\"?"],[600,817,"Isn't Ethan Rachel's husband?"],[829,1084,"How can he be the dean's son-in-law?"],[1142,1434,"Aaron, dig into this and get a DNA test"],[1434,1555,"for Ethan and Sophie."],[1614,1668,"Yes, sir."],[1739,1947,"Ethan, how could you lie to me?"],[2277,2381,"No, it has to be a mistake."],[2540,2811,"Ethan? Who is she?"],[2811,2988,"And why is she calling you \"Daddy\"?"],[2988,3123,"If you're cheating on me,"],[3123,3324,"my father and I will destroy you."],[3361,3586,"This is my cousin's daughter."],[3624,3791,"Alright, come on, Sophie."],[3791,3891,"Let's go find your mom."],[3891,4070,"No need to bother your uncle."],[4099,4278,"But you are my daddy!"],[4346,4408,"Ah!"],[4408,4592,"You stinky little beggar!"],[4592,4809,"Don't try to steal my daddy, you brat."],[4850,4975,"You're my daddy."],[5025,5280,"Ethan, what is with that photo?"],[5568,5714,"My cousin's husband left her."],[5714,5883,"She faked this photo to fool her kid."],[5951,6039,"You crazy brat."],[6039,6139,"You're just like your mom."],[6156,6302,"Don't call me dad."],[6302,6435,"Security, get her out."],[6464,6577,"Stop ruining my ceremony."],[6698,6760,"No!"],[6881,6944,"No!"],[7311,7507,"That's my mommy's favorite thing."],[7749,7853,"Get lost."],[8433,8520,"Sophie!"],[8754,8881,"Ethan, she's your daughter."],[8881,9013,"How could you do that to her?"]],"8":[[16,162,"Ethan! She's your daughter!"],[162,281,"How could you do that to her?"],[362,481,"Ethan, I thought you said"],[481,650,"this monster was your cousin!"],[671,909,"My love, this is my cousin."],[917,1098,"Besides, I can never fall for"],[1098,1405,"a disfigured freak like her."],[1693,1768,"Watch out!"],[2435,2540,"Freak?"],[2560,2749,"Don't you remember how I got this scar"],[2749,2936,"saving you from that landmine?"],[3378,3449,"You're delusional!"],[3449,3545,"I don't even know you!"],[3553,3699,"Who is this woman to Ethan,"],[3720,3828,"his mistress?"],[3841,3916,"No way."],[3928,4035,"Ethan and Madeline have been"],[4035,4223,"flaunting their love for six years."],[4320,4429,"Six years?"],[4429,4554,"I got this scar for you!"],[4554,4717,"I gave up my spot to go home,"],[4717,4871,"so that you could leave the war zone!"],[4871,5030,"Don't you have a conscience?"],[5255,5376,"Who are you?"],[5401,5490,"What is your"],[5490,5693,"relationship to my husband?"],[5709,5797,"Who am I?"],[5935,6206,"I'm Ethan's wife of over six years!"]],"9":[[12,58,"Wife?"],[137,337,"Ethan, this is your so-called cousin?"],[425,608,"You're insane! Stop making things up!"],[729,834,"Babe, trust me."],[834,946,"I could never be interested in"],[946,1059,"a freak like her."],[1363,1521,"Boss, Sophie's DNA result"],[1521,1618,"just came back."],[1618,1764,"Get it for me right now!"],[1797,1903,"Back in the war zone, you said"],[1903,2055,"you'd love me forever."],[2064,2177,"Have you forgotten?"],[2206,2283,"Look at you!"],[2352,2444,"How could I ever love a"],[2444,2608,"disfigured monster like you?"],[2644,2985,"Exactly, Ethan is a San Francisco elite."],[3002,3182,"He's never been to some war zone."],[3203,3315,"Elite?"],[3390,3624,"No, Ethan was just another American"],[3624,3778,"trapped in Dar with me."],[4104,4383,"My husband, a refugee?"],[4425,4596,"Don't make me laugh."],[4596,4934,"This piece alone costs 50 grand."],[4950,5067,"He just gave it to me."],[5113,5184,"50 grand?"],[5367,5534,"You didn't give the doctor"],[5534,5722,"Sophie's treatment money, did you?"],[5780,5993,"Shut up! Stop spouting nonsense!"],[6126,6214,"Get out!"],[6264,6360,"No, I'm not gonna leave!"],[6360,6464,"You lied to me and stole my"],[6464,6602,"daughter's lifesaving money!"],[6623,6727,"Oh, you're not leaving, huh?"],[7203,7349,"Boss, Rachel's your daughter,"],[7349,7553,"and Ethan is Sophie's biological father."],[7605,7728,"You try to ruin me?"],[7728,7868,"You brought this on yourself!"],[8079,8165,"Stop!"]],"10":[[4,54,"Stop!"],[216,443,"Aaron, dig up everything you can"],[443,600,"about Ethan's background."],[696,777,"Yes, sir."],[1142,1267,"Who is this old man?"],[1267,1359,"I've never seen him before,"],[1359,1505,"but he looks very familiar."],[1735,1918,"Grandpa William."],[1964,2214,"Sophie, no one will hurt you"],[2214,2292,"while I'm around."],[2298,2515,"Who are you? Who let you in?"],[3153,3428,"Your wife was scarred for you,"],[3428,3670,"and this is how you treat her?"],[3716,3924,"Are you even human?"],[3928,4024,"You old fool!"],[4024,4162,"This is none of your business!"],[4170,4385,"Well, I'll make it my business."],[4675,4967,"Ladies and gentlemen, I hereby declare"],[4967,5184,"that Ethan Black will not take the"],[5184,5388,"deputy director's seat tonight."],[5488,5672,"What a joke!"],[5693,5917,"My father approved this appointment."],[5918,6014,"You think you could just"],[6014,6202,"waltz in here and get it revoked?"],[6210,6435,"You ugly freak."],[6502,6594,"You came here with"],[6594,6748,"this old man, didn't you?"],[6748,6961,"You came here just to stir up trouble!"],[6973,7115,"Dragging out this little bastard"],[7115,7236,"to scam us for money!"],[7786,7916,"You're a coward who won't"],[7916,8037,"own up to what they've done."],[8049,8212,"Fine, you say Sophie's my kid?"],[8220,8320,"Where's the proof?"],[8333,8408,"Proof?"],[8487,8717,"This is the paternity test."],[8725,9029,"You are Sophie's biological father!"]],"11":[[638,792,"You son of a bitch!"],[792,950,"How dare you lie to me!"],[955,1076,"Babe, let me explain."],[1080,1167,"Explain?"],[1188,1363,"It's right here in black and white."],[1363,1501,"This brat is your kid!"],[1522,1691,"No... I swear, babe. I have nothing"],[1691,1881,"to do with this freak or her kid."],[2031,2131,"Nothing?"],[2160,2333,"You swore before God"],[2333,2464,"that you would love me alone."],[2477,2548,"Shut up!"],[2690,2773,"You have to believe me."],[2773,2957,"We can't let them tear our family apart."],[3478,3566,"Our son needs you."],[3603,3712,"Mom, I don't want to be"],[3712,3874,"a kid without his dad!"],[3891,4033,"I can't tell who's telling the truth."],[4033,4145,"Could it be that Madeline,"],[4145,4245,"the dean's daughter,"],[4245,4396,"is actually the mistress?"],[4404,4471,"Who knows?"],[4471,4621,"After today, Madeline's going to"],[4621,4792,"be the laughingstock of high society."],[5013,5238,"Babe, you know my family's status."],[5238,5392,"Why would I ever be with a"],[5392,5601,"broke, ugly freak like her?"],[5630,5764,"Let's take care of these troublemakers"],[5764,5885,"before they make a spectacle."],[6869,7027,"This report is fake."],[7036,7207,"My husband would never do this."],[7232,7424,"What else you gotta say, freak?"],[7457,7599,"I'm gonna tell everyone that"],[7599,7788,"you stole our daughter's medical money."],[7788,7920,"You monster!"],[7932,8216,"My husband is a high-society gentleman."],[8258,8495,"Steal... from a con artist like you?"],[8596,8888,"The report is from your own hospital."],[8892,9038,"It's real."],[9038,9351,"The real con artist is him!"]],"12":[[658,888,"Ethan Black, born a nobody."],[905,1184,"He went abroad to work 10 years ago,"],[1209,1413,"and returned 6 years ago"],[1413,1651,"as a hospital janitor!"],[1697,2039,"You made a fool of me in front of everyone!"],[2039,2164,"No, no, no. He's lying!"],[2239,2469,"Madeline, you have seen it all."],[2489,2631,"If he abandoned me today,"],[2631,2786,"he will abandon you tomorrow."],[2786,2940,"He's a vain hypocrite!"],[2961,3086,"Well, who would have thought?"],[3098,3345,"The dean's son-in-law, a janitor!"],[3541,3628,"No way."],[3661,3832,"I won't be the city's laughingstock."],[4283,4429,"Who are you to lecture me?"],[4441,4612,"Madeline, we're in this together."],[4612,4788,"You have to back me up, please."],[4850,4934,"Enough!"],[4934,5200,"Some lowlife freak spouting nonsense."],[5226,5480,"Everyone, I trust my husband."],[5501,5613,"He's always been a"],[5613,5768,"devoted husband and father."],[5809,6039,"As for them, they're here to"],[6039,6322,"slander my husband and extort money."],[6322,6550,"Security! Break their legs"],[6550,6748,"and throw them out."],[6760,7044,"No one disrupts my husband's ceremony."],[7069,7228,"Please, no, please!"]],"13":[[12,50,"No..."],[171,392,"Madeline, blind for right and wrong."],[404,613,"Who gave you the right to do this?"],[1113,1238,"My dad's the dean."],[1242,1380,"One flick of our finger,"],[1380,1589,"and we crush lowlifes like you."],[1589,1901,"As I told you, Ethan will not get the"],[1901,2056,"deputy director position."],[2077,2231,"And as to whether"],[2231,2519,"your father keeps his dean's seat..."],[2519,2731,"That is a question too!"],[2736,2886,"You've got some nerve."],[2886,3002,"Do you know what happens when"],[3002,3178,"you cross the Rhodes family?"],[3257,3507,"William, you have done enough already."],[3516,3653,"Please go. I don't need you"],[3653,3782,"getting dragged into this."],[3858,4012,"As long as I'm here,"],[4012,4166,"no one will lay a hand on you."],[4191,4371,"Pathetic, still flirting even"],[4371,4504,"when you're about to be crushed."],[4508,4738,"Chasing an ugly woman like her?"],[4738,4959,"Not afraid she'll scare you to death in bed?"],[5238,5562,"Freak, get on your knees and beg."],[5562,5764,"Maybe then I'll let you walk out of here."],[5985,6227,"I'll count from three, last chance."],[6302,6373,"Three."],[6539,6585,"Two."],[6760,6823,"One."],[7369,7811,"I'm sorry. Please... Please just let us go."],[7836,8091,"Rachel, you've done nothing wrong."],[8091,8274,"Why did you apologize to them?"],[8316,8508,"William, you have done so much"],[8508,8632,"for me already, but I don't want"],[8632,8775,"you getting hurt because of me."],[8775,8925,"They will not hurt me."],[8925,9050,"And I will not let"],[9050,9196,"them hurt you either."],[9200,9563,"Still talking tough? Guards, do it!"],[9567,9743,"Nobody lays a hand on us."]],"14":[[12,225,"No one lays a hand on us!"],[546,775,"This old man, could he be important?"],[825,1038,"He's just a senile old man."],[1038,1180,"How important could he be?"],[1317,1430,"The Rhodes family,"],[1555,1793,"what fine morals you have shown."],[1839,2047,"You filthy old man!"],[2047,2164,"How dare someone of"],[2164,2327,"your class question us!"],[2448,2544,"Wake up, Rachel!"],[2631,2858,"You're destined to be a nobody."],[2965,3057,"Even a freak like you"],[3057,3182,"couldn't sell herself!"],[3282,3632,"Ethan, I regret saving you in that war."],[3849,4262,"William, thank you so much."],[4262,4387,"We may not win today,"],[4387,4617,"but I swear we will get justice."],[4738,4942,"I'm going to the media to expose them."],[5163,5309,"Did I say you could leave?"],[6823,7057,"How dare you hit me!"],[7962,8066,"Who the hell is making"],[8066,8199,"a scene in my hospital?"]],"15":[[175,367,"Who the hell is making a scene"],[367,483,"in my hospital?"],[633,763,"What is going on?"],[1084,1226,"Dad, you're finally here."],[1226,1363,"This old man hit me."],[1547,1776,"William has done so much for me."],[1793,1947,"I can't let him get dragged down"],[1947,2027,"because of me."],[2039,2139,"You..."],[2164,2364,"This isn't about William, Dean Mark."],[2431,2531,"I'm Ethan's wife."],[2531,2652,"Shut up."],[2831,3007,"Ethan and I met six years ago"],[3007,3098,"in the Dar War Zone."],[3119,3307,"We got married and we had a child."],[3307,3532,"I gave him my only evacuation slot."],[3532,3749,"And when he got back, he abandoned us."],[3749,3962,"And now, he stole my money"],[3962,4091,"for Sophie's treatment."],[4179,4433,"Mr. Rhodes, please don't listen to her."],[4433,4517,"I mean,"],[4533,4613,"why would I ever go for"],[4613,4788,"a disfigured freak like her?"],[4788,4888,"That's not true."],[4888,4979,"I got this scar"],[4979,5105,"saving him in a landmine."],[5105,5192,"Enough!"],[5288,5534,"Why couldn't that landmine just kill you?"],[5755,5914,"Mr. Rhodes, this is my"],[5914,6051,"deputy director ceremony."],[6051,6247,"Please kick them out."],[6677,6840,"Mr. Rhodes, why did you hit me?"],[6840,7140,"Madeline, you would divorce"],[7140,7349,"this lying little turd"],[7349,7503,"right now."]],"16":[[16,183,"You would divorce"],[183,329,"this lying little turd"],[329,429,"right now!"],[734,855,"Let's go."],[863,1092,"They ran a DNA test at our hospital."],[1117,1284,"I tore it up, I said it was fake."],[1409,1572,"Dad, for the Rhodes family reputation,"],[1572,1685,"it has to be fake."],[2427,2515,"Everyone!"],[2573,2702,"This is just..."],[2731,2889,"It's a big misunderstanding."],[2915,2973,"Miss,"],[3019,3215,"this is an internal hospital meeting."],[3215,3403,"I'm going to have to ask you to leave."],[3449,3516,"No."],[3778,3883,"Mr. Rhodes,"],[3883,3958,"don't worry."],[3958,4149,"At the hospital, I'll follow your lead."],[4233,4458,"Miss, excuse yourself,"],[4504,4583,"now!"],[4596,4696,"Dad,"],[4704,4934,"letting them just walk out is too easy!"],[4950,5125,"This old man had the audacity to say"],[5125,5288,"you couldn't keep your seat as dean!"],[5292,5372,"Yes, Mr. Rhodes,"],[5405,5501,"he claimed no one could take"],[5501,5630,"the deputy director's seat!"],[5880,6085,"Oh, that's interesting because I believe"],[6085,6272,"that President Harrington"],[6272,6498,"who I believe is in Switzerland"],[6498,6569,"is the only one"],[6569,6706,"who has the authority over me."],[6735,6861,"Vice President Julian?"],[6861,6977,"He's practically the president's"],[6977,7065,"right hand man."],[7073,7115,"Yeah,"],[7115,7286,"the president hasn't shown up in ages."],[7298,7453,"Julian runs most of the company."],[7482,7683,"The dean's got the President backing him?"],[7703,7941,"The Rhodes family is about to soar."],[7957,8195,"Also, Vice President Julian will be coming"],[8195,8437,"here to preside over the"],[8437,8629,"deputy director appointment."],[8808,8983,"That Vice President Julian"],[8983,9159,"that you're talking about?"],[9275,9430,"He's my son!"]],"17":[[16,179,"He's my son!"],[458,583,"You're saying"],[583,834,"Vice President Julian is your son."],[834,1046,"You're President Harrington?"],[1059,1217,"Everyone knows President Harrington"],[1217,1317,"lives in Switzerland."],[1317,1480,"He hasn't been back for years."],[1493,1632,"How dare you impersonate him?"],[1643,1814,"I tell you what, I'll make you a deal."],[1814,2060,"You leave quietly, and I'll go easy on you."],[2060,2189,"A bunch of fools!"],[2360,2515,"William, thank you so much."],[2527,2677,"Please, you don't have to do this."],[2873,3048,"Rachel, if you don't leave now,"],[3048,3211,"don't blame me when no doctor dares"],[3211,3360,"to treat that brat."],[3378,3482,"Sophie's your daughter."],[3482,3586,"I don't claim her!"],[3586,3699,"She's nothing but a bastard."],[4454,4692,"Mr. Rhodes, I tried to reason with her,"],[4692,4804,"but she hit me."],[4829,4896,"Letting her go would"],[4896,5001,"only cause more trouble."],[5030,5323,"Dad, we can't let her walk out of here."],[5323,5515,"She's about to expose us to the media."],[5534,5651,"I have an idea."],[5651,5926,"How about we take these two lunatics"],[5926,6093,"and we throw them in an asylum?"],[6110,6193,"You can't do this!"],[6193,6309,"You're a doctor, aren't you?"],[6309,6448,"Where are your medical ethics?"],[6481,6794,"Security, get them out of here!"],[7065,7265,"Don't you dare!"],[8120,8187,"William!"],[8233,8372,"Listen, old man."],[8372,8577,"This is my hospital."],[8600,8808,"And if I say someone's insane,"],[8842,8975,"they are insane!"],[8975,9331,"Oh, you're such a powerful dean!"],[9346,9574,"Scared, old man? My father-in-law's not"],[9574,9637,"just the dean,"],[9637,9813,"he's favored by the president himself."],[9876,10022,"You can't touch him."],[10335,10548,"Julian, fire the dean of"],[10548,10755,"the RW Hospital immediately!"]],"18":[[692,834,"Fire the dean of the"],[834,1051,"RW Hospital immediately!"],[1680,1893,"Look everyone, he's calling his \"son\"!"],[2014,2102,"Pathetic!"],[2110,2177,"Dad?"],[2293,2510,"Something's wrong! Drive faster!"],[2623,2706,"Vice President"],[2706,2877,"Julian's arriving any minute."],[3044,3136,"Security!"],[3136,3319,"I said to get them out of here!"],[3340,3461,"No, no..."],[4008,4112,"Mommy!"],[4133,4325,"Don't touch my mommy!"],[4329,4537,"Don't you dare!"],[4546,4825,"Someone needs to teach you a lesson."],[4846,5096,"No one slaps the Rhodes family"],[5096,5201,"in the face!"]],"19":[[750,963,"Sir, you have impeccable timing."],[963,1076,"This fraud here is trying"],[1076,1288,"to impersonate your father!"],[1413,1555,"Please, sir."],[1634,1742,"I'll take whatever punishment,"],[1742,1835,"just spare him."],[1918,2039,"Mr. Vice President Julian,"],[2039,2206,"don't fall for her act."],[2206,2293,"She's just a whore"],[2293,2427,"and this old man is her lover!"],[2660,2756,"Dad?"],[2911,3002,"Dad!"],[3490,3586,"Wait, Mr. Willian,"],[3586,3695,"you really are the president?"],[3707,3782,"The real deal."],[3824,3962,"Mr. Vice President, sir,"],[3962,4170,"I thought your father was in Switzerland."],[4183,4312,"You think I don't recognize"],[4312,4421,"my own father?"],[4579,4738,"No, no, no, this can't be."],[4750,4925,"Sir, no. Mr. President,"],[4925,5109,"we didn't know it was you."],[5121,5317,"So it would be okay to bully me,"],[5317,5503,"if I wasn't the president?"],[5522,5680,"No, Mr. Willian."],[5680,5856,"This is just a misunderstanding."],[5864,5972,"We're sorry."],[6001,6197,"Just give us another chance."],[6252,6473,"You think I don't know how much"],[6473,6706,"you abused your power as the dean?"],[6723,7019,"You, victim yourself, yet you chose to"],[7019,7161,"protect your reputation"],[7161,7353,"by harming another victim?"],[7364,7453,"And you,"],[7561,7724,"you're worst of all."],[7732,7924,"Rachel bore you a child,"],[7924,8070,"and you abandoned them."],[8070,8287,"You even tried to hurt her."],[8475,8575,"Mr. President,"],[8575,8758,"we're just hospital management."],[8758,8846,"There's no need to ruin us"],[8846,8983,"over some disfigured nobody."],[9776,9955,"Say again."],[9955,10090,"I hereby declare"],[10090,10359,"that both Mark and Ethan are fired"],[10359,10477,"from the hospital"],[10477,10656,"and banned from the company"],[10677,10773,"forever."],[10789,10977,"No, no... sir. We're sorry."],[10977,11194,"Please, just one more chance."],[11215,11448,"Yes, sir, we know we were wrong."],[11453,11586,"Just go!"]],"20":[[29,191,"Just go!"],[725,996,"Grandpa William, you're so awesome!"],[1238,1476,"Rachel, as long as I'm here,"],[1476,1835,"no one will ever bully you again."],[1843,1960,"Why are you helping us?"],[1997,2181,"Come with me. You'll find out."],[4049,4124,"Mommy,"],[4124,4408,"this place is beautiful!"],[4608,4683,"You like it?"],[4683,4772,"Yes!"],[4808,4959,"Grandpa's giving it to you."],[5092,5292,"Oh, Mr. William, please."],[5292,5401,"You've done enough already."],[5401,5488,"You don't have to do that."],[5522,5622,"It's not enough."],[5810,6014,"If only Anna could see this."],[6039,6246,"Dad, it's not too late."],[6297,6389,"You're right."],[6389,6581,"Come on, let's go inside."],[6819,6998,"Why's there a picture of Sophie up there?"],[7006,7144,"That's not Sophie."],[7144,7316,"It was taken years ago."],[7328,7540,"No, Mr. William, you have to be joking."],[7550,7695,"I think that girl looks exactly"],[7695,7841,"like Sophie. How could it..."],[8158,8475,"Wait, is... is that me?"],[8508,8558,"Yes."],[8683,8754,"That's you."],[8775,8896,"You were just a little kid."],[8963,9029,"Rachel."],[9213,9305,"You're my daughter."]],"21":[[12,137,"You're my daughter."],[250,325,"The one I've been"],[325,529,"looking for all these years."],[575,641,"No."],[746,913,"Mr. William, you have to be mistaken."],[925,1063,"I'm just an orphan."],[1109,1209,"A child nobody wanted."],[1530,1672,"You're my little girl."],[2068,2097,"Dad,"],[2198,2256,"your health."],[2748,2877,"Try not take it too worked up."],[2890,2972,"I can't be sure."],[3040,3132,"What if it's a mistake?"],[3712,3895,"This is the DNA test between you and Dad."],[3933,4003,"You're a Harrington."],[4162,4245,"Sweetheart,"],[4350,4504,"finally found you."],[5367,5467,"Mr. Harrington..."],[5759,5805,"Dad."],[5972,6125,"Can I ask how I was lost?"],[6131,6402,"You were kidnapped many years ago,"],[6456,6548,"and just disappeared."],[6577,6740,"Everyone thought you were gone."],[6748,6835,"And Mom..."],[6861,6986,"she died of a broken heart."],[7073,7336,"Your mother made me promise"],[7336,7585,"to find you before she passed."],[7599,7782,"And I've been looking ever since."],[7828,7924,"Now you're here."],[7962,8145,"I am so sorry"],[8145,8320,"for everything you've gone through."],[8450,8562,"Sophie..."],[8575,8679,"It's okay, Sophie."],[8679,8767,"Sophie, don't be scared."],[8767,8900,"Let grandpa get a good look at you."],[8900,9023,"Grandpa."],[9509,9655,"Look just like your mother"],[9676,9763,"when she was young."],[9805,9859,"Don't worry,"],[9905,10130,"I'll get the best doctors to"],[10130,10293,"cure Sophie's heart condition."],[10347,10472,"And I swear,"],[10506,10656,"as long as I'm alive,"],[10681,10994,"no one will ever hurt you."]],"22":[[479,914,"Mommy, this bed is so comfy!"],[934,1109,"This place is huge."],[1255,1408,"It's a bit bare-bones for now, but"],[1408,1543,"I'll get it spruced up tomorrow."],[1543,1739,"You set this all up for us?"],[1739,1885,"Yep, do you like it?"],[2715,2886,"So Rachel, do you like your room?"],[3286,3353,"Yeah."],[3357,3461,"Uh, sweetie,"],[3461,3640,"Grandpa's got a ton of new dolls."],[3640,3762,"Want to come check them out?"],[3770,3862,"Come on."],[3916,4012,"Yay!"],[4208,4325,"I'll go too."],[4325,4404,"Yep."],[5793,5960,"Thank you, Mr. Harrington."],[5960,6068,"It's just Julian."],[6068,6218,"Rachel, truth is,"],[6218,6439,"I've been waiting for you all these years."],[7082,7228,"We can't... we're siblings."],[7328,7494,"I'm not a Harrington by blood."]],"23":[[0,136,"I'm not a Harrington by blood."],[154,275,"Then who are you?"],[396,492,"Is this family"],[492,608,"really that messed up?"],[608,721,"What's going on in that"],[721,871,"wild imagination of yours?"],[871,996,"It's not what you're thinking."],[1134,1243,"You really don't remember who"],[1243,1376,"brought me into the Harrington family?"],[1409,1493,"Who?"],[1626,1722,"Me?"],[1835,1939,"I was that brave?"],[1956,2014,"Yep,"],[2031,2167,"you're the one who dragged me home."],[2423,2640,"Every princess needs a knight,"],[2640,2765,"and you're mine now."],[2765,2952,"And your name is Julian."],[3094,3277,"But I failed you as your knight."],[3370,3507,"I couldn't protect my princess."],[3507,3653,"No, Julian, you have"],[3653,3845,"done more than enough."],[4429,4512,"Get some rest."],[5380,5547,"From nothing to an heiress,"],[5547,5684,"seems like a dream."],[5943,6197,"Julian, with Rachel in this state..."],[6227,6385,"Dad, no matter what happens,"],[6385,6569,"my feelings for Rachel won't change."],[6723,6777,"Good."],[6790,6886,"Take care of her."],[7349,7394,"I will."]],"24":[[225,300,"Good morning."],[325,412,"Good morning."],[684,829,"Oh, wow."],[909,1055,"Did you sleep well, Rachel?"],[1076,1245,"Yeah, I did. Thanks, Dad."],[1409,1484,"Where's Sophie?"],[1514,1589,"She's playing ball"],[1589,1726,"in the yard after breakfast."],[1814,1922,"Now that you're back,"],[1935,2027,"how about you learn"],[2027,2189,"the family business from Julian?"],[2227,2289,"Me?"],[2406,2535,"I wouldn't even know where to start."],[2635,2698,"You'll learn."],[2698,2937,"I think you'll be the best heir ever."],[3069,3165,"Where do things stand"],[3165,3282,"between Ethan and you?"],[3290,3490,"Oh, we're done, completely."],[3490,3674,"What do you think about Julian?"],[3949,4183,"Julian? He's great."],[4200,4421,"Got any sparks for him?"],[4466,4579,"Dad,"],[4579,4713,"right now I just want to"],[4713,4833,"focus on Sophie's treatment"],[4833,5030,"and spend time with you and her."],[5221,5355,"I'm gonna check on Sophie."],[5609,5910,"Julian's got a long road to win her over."],[6631,6848,"Where did this brat come from?"],[6869,7115,"Oh, got my skirt dirty."],[7123,7248,"I'm not a brat."],[7248,7390,"You mouthy little punk,"],[7432,7528,"talking back?"],[7549,7766,"Oh, I will teach you a lesson."],[8141,8245,"Stop it!"],[8358,8537,"What are you doing to my daughter?"]],"25":[[0,175,"Why are you touching my daughter?"],[362,454,"You okay?"],[471,567,"Let's go home."],[600,800,"You filthy beggar."],[813,933,"You think you can put your"],[933,1172,"hands on me and then just walk away?"],[1172,1301,"What did you want?"],[1309,1739,"Your daughter got my designer skirt dirty."],[1768,1872,"It's not much."],[1956,2093,"Just pay me 50 grand."],[2102,2277,"Mommy, I didn't mean to..."],[2277,2339,"It's okay."],[2339,2469,"Your skirt's not even dirty."],[2469,2581,"Why should we pay for it?"],[2581,2861,"You two scream \"slum-dwellers\""],[2861,3036,"from a mile away."],[3036,3144,"But you can't afford it?"],[3144,3203,"Fine,"],[3203,3361,"just you and your kid..."],[3378,3453,"kneel..."],[3570,3682,"and apologize."],[3966,4099,"It's just a skirt."],[4099,4195,"I can cover it."],[4220,4316,"Now leave us alone."],[4316,4408,"We're going home."],[4408,4667,"Oh, you broke beggar."],[4667,4900,"Where did you get all these cash?"],[4904,5092,"Sneaking around the rich neighborhood."],[5096,5180,"Stolen,"],[5213,5271,"Huh?"],[5342,5580,"Keep your grubby hands off of me."],[5580,5734,"My cash is none of your business."],[6156,6343,"You're a scarred-up freak too."],[6360,6552,"No wonder your kid's such a mess."],[6569,6719,"What's with the death stare?"],[6740,6819,"Am I wrong?"],[6823,7048,"A freak and her little beggar."]],"26":[[458,617,"You scarred freak."],[617,734,"You hit me?"],[1601,1772,"Julian?"],[1776,2017,"I'm the VIP at the WS Group,"],[2017,2181,"partners with Harrington."],[2198,2239,"You know,"],[2239,2527,"I just got a fine bottle of wine."],[2556,2740,"Want to come check it out at my place?"],[2748,2827,"You okay?"],[3040,3420,"This scarred freak isn't your maid, is she?"],[3420,3566,"She's probably just a thief."],[3595,3699,"Fire her quick."],[3707,3837,"Apologize to her."],[3891,3987,"Julian..."],[3995,4091,"Apologize,"],[4133,4193,"now!"],[4250,4366,"Or I won't mind showing you"],[4366,4496,"what low class feels like."],[4558,4650,"Fine,"],[4662,4796,"I'll apologize."],[5109,5188,"I'm sorry."],[5789,5864,"Come on."],[6598,6794,"Who has been bullying you two?"],[6802,6919,"Mean people,"],[6940,7023,"hurt Mommy."],[7077,7223,"They call us beggars."],[7265,7478,"Someone dare to insult my"],[7478,7649,"daughter and granddaughter?"],[7670,7866,"No one outside knows that the heiress of"],[7866,7982,"Harrington Group is back."],[8208,8420,"At the company gala next month,"],[8420,8579,"I'll publicly announce"],[8579,8704,"Rachel's identity"],[8704,8879,"as the heir to the group."],[8933,9017,"Thank you, Dad."]],"27":[[0,204,"Thanks, Dad. I'll do my best."],[221,337,"Don't worry. I got you."],[454,563,"Come on, Sophie."],[571,734,"Grandpa got you some new toys."],[734,892,"Let's go upstairs and check them."],[1384,1463,"I get it now."],[1463,1618,"If you want people walking all over you,"],[1618,1780,"you have to stand up for yourself."],[1780,1939,"I want to be the real heiress."],[1976,2064,"Will you help me?"],[2064,2164,"I've got you."],[2214,2298,"I'll take care of it."],[2298,2423,"I'll get it all set up."],[5730,5993,"Three days to master aristocratic etiquette."],[5993,6126,"If it weren't for your scar,"],[6126,6364,"you would be the finest lady in high society."]],"28":[[3,63,"I'm sorry,"],[63,200,"I got caught up in a meeting"],[200,343,"but I'll come find you guys"],[343,420,"as soon as it's over."],[420,553,"Oh, no worries, Sophie and I"],[553,670,"can wander around for a bit."],[1134,1251,"Let's go look at it!"],[1771,1997,"It's in perfect condition."],[2038,2108,"Oh, uh..."],[2125,2332,"So yeah, let's go to the bar."],[2332,2449,"Hit the bar tonight."],[2449,2612,"They've got a new hot bartender."],[2645,2801,"I would love that."],[2852,2979,"Mama, look,"],[2989,3183,"it's the mean lady from before."],[3226,3336,"It's okay."],[3793,3950,"What's with this freak?"],[3956,4110,"She's got style now."],[4481,4731,"Well, look at you, freak."],[4738,4864,"These clothes cost thousands a pop."],[4864,4984,"You think you can afford them?"],[5091,5218,"Could you wrap this up for us?"],[5365,5445,"Come on, honey."],[6441,6509,"Hey."],[6900,6960,"There you go."],[6996,7097,"Thank you."],[7857,8044,"Oh! Oh my god!"],[8111,8288,"Why is the alarm going off?"],[8321,8475,"Is someone stealing?"],[8475,8634,"Miss, I need to check your bag."],[8855,9115,"This is ridiculous, I didn't take anything."],[9769,9933,"Not stealing, huh?"],[10193,10326,"Then, what is this then?"]],"29":[[3,126,"Then, what is this then?"],[443,505,"No way!"],[550,727,"No, I... I didn't take that necklace!"],[797,817,"Hmm..."],[890,917,"Sure..."],[990,1131,"Guess a slum rat like you"],[1131,1293,"just can't resist shiny things."],[1314,1438,"You're a broke nobody."],[1471,1581,"Stealing with a kid in tow?"],[1671,1808,"Bet she's a little thief, too."],[2168,2382,"Swipe it! I'll pay for triple the dress."],[2382,2559,"Now apologize to my daughter!"],[2592,2819,"Babe, how much do we sell a handbag for?"],[2829,2866,"Uh..."],[2972,3086,"Oh, Rachel?"],[3113,3