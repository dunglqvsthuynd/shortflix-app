,18368,"You're just a gigolo."],[18391,18570,"Stop playing hard to get!"],[18658,18812,"If you can't pay,"],[18841,18987,"then stay here"],[18997,19333,"and be my husband!"],[19470,19579,"I am Prince Liam,"],[19604,19754,"commanding 100,000 troops in the northwest."],[19779,19854,"How dare you expect me"],[19858,19937,"to submit to you?"],[19991,20066,"Insolence!"]],"18":[[0,154,"Oh,"],[158,316,"Prince Liam,"],[329,550,"commanding 100,000 troops in the northwest"],[575,712,"You're just making up stories!"],[716,812,"Huh?"],[1125,1204,"Insolence!"],[1515,1621,"What?"],[1641,1783,"With your weak skills,"],[1795,2054,"you want to go head-to-head with me?"],[2091,2387,"Just because your scars are gone,"],[2416,2504,"you think you can"],[2529,2691,"start acting tough again!"],[2825,2970,"This fat woman is strong as an ox."],[3029,3150,"I'm still injured,"],[3154,3270,"so I shouldn't fight her head-on."],[3308,3379,"Fine."],[3395,3525,"A real man knows when to yield."],[3536,3611,"What do you want?"],[4084,4263,"What do you think?"],[4433,4529,"Don't think that I will"],[4533,4670,"submit to your tyranny."],[5046,5208,"See that big vat?"],[5216,5375,"Fill it up with water first."],[5412,5537,"I am Prince Liam,"],[5541,5620,"who dominates the northwest!"],[5625,5687,"Enough."],[5750,5920,"Would it kill you to stop bragging?"],[6125,6258,"Fill the vat first."],[6329,6520,"There's plenty more work to do."],[6566,6716,"Chopping wood, boiling water,"],[6720,6916,"fertilizing, and planting."],[6938,7013,"You!"],[7062,7141,"Hm?"],[7525,7666,"I can't go head-to-head"],[7670,7754,"with this fat woman right now."],[7841,7920,"Fine!"],[7995,8087,"I'll do it!"],[8089,8162,"Good."],[8909,8954,"Mhm."],[8988,9080,"Hurry up!"],[9158,9295,"I still have a lot of work to do!"],[9573,9686,"Fatty!"],[9741,10012,"You'd better not let me get my hands on you!"],[10126,10250,"Mama."],[10715,10821,"What did you call her?"],[10825,10925,"Mama?"],[10937,11033,"How old is she?"]],"19":[[41,137,"I'm five."],[1052,1137,"Five years old."],[1194,1304,"The age matches."],[1366,1450,"Who is your Daddy?"],[1515,1629,"You ask too many questions."],[1630,1725,"Get back to work!"],[1861,1908,"Mama,"],[1979,2045,"tell me,"],[2058,2129,"since Uncle"],[2133,2229,"looks so much like me,"],[2258,2387,"could he be my"],[2400,2445,"Daddy?"],[2512,2570,"Candy,"],[2619,2687,"you really have a knack"],[2691,2882,"for saying the wrong thing!"],[2958,3029,"Is she really"],[3033,3087,"She's not."],[3182,3250,"I don't believe you!"],[3641,3720,"Here is the proof."],[3758,3850,"You still dare to deny it?"],[3942,4037,"Isn't this just a"],[4041,4116,"birthmark?"],[4554,4654,"What else do you have to say?"],[4871,5004,"Wow,"],[5020,5120,"Uncle actually has"],[5125,5191,"the exact same birthmark"],[5195,5337,"as I do!"],[5387,5425,"Mama,"],[5441,5554,"he must be"],[5558,5641,"mine and my brother's"],[5729,5804,"He's still on probation,"],[5841,5920,"so it's not time to come clean yet."],[5941,6050,"You country bumpkin,"],[6141,6229,"you actually went behind my back"],[6233,6330,"and gave birth to my child,"],[6353,6441,"hoping to use the child for status."],[6465,6536,"Let me tell you,"],[6604,6700,"I will acknowledge this child,"],[6702,6872,"but I am the great Prince Liam,"],[6891,6958,"ruler of the northwest."],[6962,7004,"My army of a hundred thousand"],[7078,7166,"would never accept"],[7170,7275,"a village bumpkin like you as my wife."],[7308,7400,"So just give up!"],[7408,7504,"Heh."],[7541,7675,"You're addicted to bragging, aren't you?"],[7725,7904,"Oh, Daddy!"],[7945,8108,"This is Laxpus Stronghold."],[8120,8287,"You're the one gaining status thanks to your daughter!"],[8325,8387,"Mama is actually"],[8391,8516,"very powerful!"],[8537,8670,"You should just behave"],[8691,8837,"and submit to Mama!"]],"20":[[37,166,"Did you hear that?"],[276,421,"If you behave yourself,"],[470,570,"who knows?"],[587,720,"I might even grant you"],[723,887,"the position of Husband!"],[891,1025,"But if you don't listen,"],[1062,1254,"even if you are Candy's biological father,"],[1283,1441,"a disobedient man"],[1462,1607,"is only fit to be"],[1610,1770,"a concubine!"],[1829,1891,"Insolence!"],[1937,2020,"You village bumpkin!"],[2079,2225,"How dare you humiliate me like this!"],[2295,2387,"I am the mighty Prince Liam,"],[2400,2454,"ruler of the northwest"],[2458,2554,"Enough!"],[2608,2704,"You sound like a broken record,"],[2708,2816,"saying the same thing over and over."],[2887,2970,"Even if you bragged about"],[2975,3125,"being the Emperor, it wouldn't matter!"],[3162,3320,"In Laxpus Stronghold,"],[3345,3516,"dragons must coil,"],[3536,3750,"and tigers must crouch!"],[3762,3816,"You!"],[3991,4045,"Mama,"],[4058,4145,"I just ran the numbers."],[4175,4237,"If we"],[4241,4400,"want to open a restaurant in the city,"],[4416,4525,"it'll cost five hundred taels."],[4558,4600,"Mama,"],[4625,4768,"let me break it down for you!"],[4783,4825,"You!"],[4912,5004,"You call her \"Mama\" too?"],[5025,5058,"Oops,"],[5416,5687,"Brother got caught!"],[5770,5837,"Huh?"],[5881,5950,"Wait,"],[6000,6145,"no one told me"],[6179,6354,"this was a family reunion!"],[6425,6454,"You shrew!"],[6517,6645,"You really have some nerve,"],[6691,6787,"daring to hide my"],[6791,6870,"son and daughter."],[6974,7053,"Fine."],[7104,7200,"I'll stop pretending."],[7262,7362,"Since you found out,"],[7383,7479,"I admit it."],[7483,7666,"But what can you do?"],[7687,7762,"Hmph."]],"21":[[58,245,"Don't think you can use the kids for status."],[279,395,"Just because the two children are here,"],[408,545,"doesn't mean you can make demands."],[554,604,"Hmph."],[608,833,"As my captive husband,"],[845,954,"if I tell you to go east,"],[958,1116,"you don't go west!"],[1120,1258,"If I tell you to stand,"],[1262,1400,"you don't sit!"],[1404,1550,"If I say massage my legs,"],[1554,1729,"you don't rub my shoulders."],[1820,1837,"Hmph."],[1879,2004,"Get to work!"],[2639,2797,"That shrew."],[2861,2981,"When my army storms this mountain,"],[3000,3070,"and I retrieve"],[3075,3195,"my son and daughter,"],[3229,3387,"I'll make you beg for life"],[3500,3625,"yet unable to die!"],[3762,3850,"Tsk, tsk, tsk."],[3895,3991,"Look at that waist."],[3995,4150,"It's actually quite strong."],[4500,4633,"No wonder the Chief"],[4637,4804,"took him as her captive husband!"],[4930,5070,"Bunch of country bumpkins."],[5191,5275,"Oh my."],[5279,5395,"This pretty boy"],[5400,5512,"is quite thin-skinned."],[5583,5687,"We just said a few words,"],[5691,5829,"and he's already blushing!"],[5841,5916,"Hmph."],[5933,6070,"Just like a gigolo."],[6091,6237,"He looks innocent on the surface,"],[6241,6337,"but behind our backs,"],[6341,6429,"who knows how he"],[6433,6537,"seduces Miss!"],[6629,6787,"No matter how handsome a man is,"],[6825,6941,"if he lacks male virtue,"],[6966,7054,"he's bound to be drowned in a pig cage."],[7095,7195,"Drowned in a pig cage!"],[7395,7537,"You bunch of crude women"],[7554,7708,"are just like that fatty."],[7720,7825,"You're so foul-mouthed."],[7904,7991,"I won't stoop"],[7995,8075,"to your level!"]],"22":[[512,566,"Who?"],[729,820,"Time to eat!"],[2125,2208,"Who are you?"],[2241,2337,"Why do you look so much like"],[2341,2404,"Lionel and Candy?"],[2533,2629,"Because they're my brother"],[2633,2700,"and sister."],[2725,2820,"We share the same mom,"],[2829,2925,"so of course we look alike!"],[2991,3070,"What did you say?"],[3100,3166,"Don't tell me you're also...?"],[3941,4025,"Nora,"],[4079,4166,"exactly how many of my children"],[4170,4287,"have you been hiding?"],[5277,5354,"Nora,"],[5391,5470,"that child named Mia,"],[5472,5533,"what's the deal with her?"],[5641,5787,"It is what it is!"],[5962,6058,"What's with the attitude?"],[6245,6295,"Hey,"],[6300,6387,"since you're here,"],[6391,6500,"sit down and have some."],[6596,6775,"Truly a crude village woman,"],[6820,6979,"eating such filthy bugs."],[8045,8137,"Since you"],[8141,8312,"are trying so hard to please me,"],[8333,8454,"I'll force myself"],[8458,8495,"to accept it!"],[9270,9370,"Hmph."],[9375,9525,"Tastes pretty good, right?"],[9850,9962,"It's passable."],[10387,10516,"This fatty actually"],[10520,10637,"isn't completely useless."],[10654,10787,"Her cooking is strange,"],[10791,10937,"but it has a unique flavor."],[10945,11016,"Those three children"],[11020,11108,"are raised well, too."],[11145,11225,"In these famine years,"],[11229,11329,"they haven't gone hungry or cold."]],"23":[[141,237,"By the way, Nora,"],[241,320,"Hm?"],[433,537,"during these famine years,"],[658,704,"how did you manage to raise"],[708,816,"these three children?"],[1004,1158,"Well"],[1425,1558,"Whoa, whoa, whoa!"],[1562,1662,"Oh, geez!"],[2604,2720,"Oh my god!"],[2958,3245,"Ouch, ouch!"],[3408,3633,"Who in their right mind has to handle"],[3637,3787,"four kids at once?"],[3870,4070,"Me!"],[4921,5055,"What?"],[5079,5270,"Are you captivated by my charm?"],[5450,5525,"Hey,"],[5550,5745,"don't worry."],[5808,6012,"I promised you the title of male wife,"],[6016,6258,"and I'll never go back on that!"],[6428,6554,"Who wants to be the male wife"],[6558,6795,"of a village bumpkin like you?!"],[7165,7295,"Wow,"],[7308,7416,"Daddy and Mama"],[7420,7691,"are such a perfect match!"],[7712,7858,"Such a beautiful scene."],[7904,8120,"If I could paint this,"],[8137,8412,"how many taels of silver would it sell for?"],[8508,8687,"Just looking at Daddy and Mama's physiques,"],[8725,8904,"they seem perfect for acupuncture."],[8958,9105,"With this scene before me,"],[9107,9325,"I just want to recite a poem."],[9425,9508,"Who's there?"],[10833,11094,"One, two, three, four."],[11261,11454,"Is he also...?"],[12994,13099,"Nora,"],[13134,13339,"exactly how many of my children have you hidden?"],[13462,13566,"That's really it."],[13591,13754,"This is the last one!"],[13758,14033,"You have to understand, one body,"],[14037,14204,"no matter how fertile"],[14208,14412,"My patience has its limits!"],[15165,15286,"Daddy,"],[15601,15779,"with this scenery,"],[15783,15916,"I just want to recite a poem."],[15920,16029,"Shut up!"],[16033,16220,"Don't ruin the mood!"],[17050,17137,"Since we're done eating,"],[17141,17270,"take the grill and dishes,"],[17275,17408,"and clean everything up."],[17662,17770,"Let's go."],[18179,18408,"I knew this fat woman"],[18412,18591,"was up to no good!"],[19862,19975,"You fat woman!"],[20022,20200,"Wait until my army comes up the mountain,"],[20226,20345,"I'll make sure you know"],[20350,20504,"the meaning of regret!"]],"24":[[1166,1262,"As a young woman,"],[1270,1416,"do you have no sense of decency?"],[1441,1587,"How dare you barge into a man's room!"],[1629,1779,"You have absolutely no shame!"],[1816,1941,"Pfft."],[2000,2112,"Is there any part of your body"],[2116,2287,"that I haven't seen?"],[2300,2420,"I even know how many taels"],[2437,2583,"of meat you have down there!"],[2616,2700,"You!"],[2950,3025,"Nora,"],[3095,3229,"are you even a woman?"],[3283,3395,"I didn't come here"],[3400,3512,"to argue with you"],[3516,3591,"about this nonsense."],[3616,3754,"If you don't want me"],[3758,3908,"barging into your room again,"],[3976,4083,"then you'd better remember"],[4087,4333,"to get up when the rooster crows."],[4354,4570,"I took you as my captive husband"],[4600,4745,"not to live in luxury,"],[4754,4912,"but to work!"],[5070,5175,"Get moving!"],[5179,5262,"My dear husband,"],[5913,6084,"since you dared to ask me to do laundry,"],[9020,9154,"go chop wood!"],[9212,9300,"You shrew,"],[9304,9420,"don't push me too far!"],[9900,10058,"You d*mn fat woman!"]],"25":[[800,991,"Work hard and don't slack off!"],[1441,1608,"Go till the soil over there."],[2962,3079,"What is this?"],[3133,3250,"Why have I never seen it"],[3254,3383,"in Great Yusphis?"],[3542,3691,"Of course you haven't."],[3695,3912,"This is called a potato."],[3916,3987,"In your dynasty,"],[3991,4108,"it hasn't been introduced yet!"],[4112,4270,"It's a foreign crop."],[4541,4637,"During this famine,"],[4644,4795,"many crops are hard to grow."],[4823,4937,"The people have no harvest"],[4941,5029,"and are displaced."],[5037,5216,"When even proper grains"],[5220,5300,"can't survive in the fields,"],[5312,5375,"you're planting these"],[5379,5516,"weird things?"],[5522,5716,"It's a waste of land and manpower!"],[6010,6175,"You don't know sh*t!"],[6179,6300,"It's precisely because of the famine"],[6304,6408,"that we need to plant potatoes."],[6412,6504,"This stuff"],[6508,6666,"is hardy, grows fast,"],[6670,6779,"and yields a lot."],[6783,6858,"How else do you think"],[6862,6958,"I get this huge stronghold"],[6962,7125,"through the famine?"],[7158,7350,"Is it really as miraculous as you claim?"],[7362,7566,"I originally planned"],[7570,7716,"to wait for my army"],[7720,7858,"and flatten Laxpus Stronghold."],[7862,7987,"But now it seems,"],[7991,8166,"this woman has many secrets"],[8170,8316,"worth digging into."],[8350,8450,"Of course!"],[8697,8872,"If this potato"],[8879,9137,"is truly as magical as she claims,"],[9141,9333,"it could end Great Yusphis'"],[9337,9545,"years of famine."],[9550,9658,"The army and the people"],[9662,9875,"won't have to go hungry anymore."],[9879,10004,"For Great Yusphis,"],[10008,10166,"no matter how much I suffer,"],[10170,10325,"it's all worth it!"],[11054,11137,"You're still here"],[11141,11245,"putting on an act, huh?"],[11250,11441,"Get to work!"],[11708,11895,"You peasant!"]],"26":[[2191,2387,"Looking at his face now,"],[2391,2454,"he doesn't seem"],[2458,2608,"quite as annoying anymore."],[3504,3587,"Hey!"],[3887,3987,"What?"],[4133,4300,"You worked really hard today."],[4341,4429,"Here, take this."],[4437,4529,"It's your wages."],[4688,4866,"Don't think a few bits of silver"],[4870,4987,"can buy me off!"],[5141,5220,"Do you want it or not?"],[5225,5337,"If not, I'm keeping it!"],[5448,5537,"Why wouldn't I want it?"],[5541,5650,"I earned this"],[5654,5729,"with my hard labor!"],[5741,5933,"I can't give you all of it! Give it back!"],[9385,9514,"Come on, everyone."],[9547,9680,"Dinner's ready."],[9704,9883,"This setting"],[9887,10112,"inspires me to recite a poem."],[10120,10337,"Rice scent fills the misty village,"],[10341,10537,"fried chicken smoke gently drifts."],[10570,10775,"Hungry dogs bark in the alleys,"],[10791,10970,"greedy chickens cluck in the pot."],[11000,11395,"Alright, you can sit down now!"],[11991,12108,"Daddy,"],[12125,12270,"do you know what candied hawthorns"],[12275,12420,"taste like?"],[12450,12525,"Of course!"],[12641,12891,"Do you mean you don't know?"],[12991,13208,"My brother, little sister, and I"],[13212,13433,"have never eaten them!"],[13856,13952,"Sigh."],[13983,14270,"I really want to know what candied hawthorns"],[14275,14520,"taste like!"],[15212,15366,"Daddy has some silver here."],[15370,15525,"It's enough for you each to buy a stick."],[16075,16154,"Oh my."],[16204,16341,"You kids,"],[16362,16504,"and that little stash of yours."],[16508,16629,"That's barely enough for you to squander!"],[16679,16837,"And you still had to trick your Daddy"],[16854,17037,"out of these measly"],[17041,17175,"pieces of silver."],[17241,17316,"Sigh."],[17366,17487,"He's stupid to begin with."],[17591,17670,"You"],[17920,18016,"Mama,"],[18020,18129,"who would say no"],[18133,18287,"to easy money?"],[18575,18720,"Candied haws definitely aren't"],[18725,18920,"as tasty as Mama's fried chicken."],[19300,19425,"Let's eat! Let's eat!"]],"27":[[425,554,"The Prince sent word,"],[575,712,"he's likely trapped nearby."],[716,770,"This has to be the place."],[812,945,"Everyone, search carefully!"],[958,1037,"Yes, sir."],[1350,1437,"Go, check over there."],[1441,1520,"Hurry up!"],[5979,6137,"Greetings, Prince!"],[6158,6245,"At ease."],[6320,6400,"How are things going"],[6404,6512,"with the assassins?"],[6550,6645,"We got them to talk."],[6650,6787,"They were assassins from the Barbarian Kingdom."],[6859,6975,"Just as I thought."],[7116,7191,"Prince,"],[7225,7329,"should I send troops"],[7333,7466,"to attack Laxpus Stronghold?"],[7508,7608,"No need."],[7629,7766,"Laxpus Stronghold is full of women"],[7770,7850,"who have never committed"],[7854,7958,"arson, murder, or looting."],[7975,8104,"They live off the land."],[8108,8216,"Besides, this stronghold"],[8220,8408,"is still useful to me."],[8416,8600,"Since the Barbarians failed this time,"],[8604,8720,"they're bound to make another move."],[8725,8812,"Staying here"],[8816,8937,"works to my advantage!"],[8979,9108,"Prince,"],[9112,9254,"you plan to stay here?"],[9275,9375,"Yes."],[9433,9525,"Go back to the Princely Manor for now."],[9583,9670,"Wait and see what happens,"],[9704,9779,"and act when the time is right!"],[9941,10045,"Yes, Prince."],[11700,11775,"Miss,"],[11779,11858,"slow down!"]],"28":[[708,875,"So Quinn is staying right here!"],[891,954,"Yes."],[966,1037,"The spy Guard Hayes sent"],[1041,1137,"to track him last night"],[1141,1216,"said exactly that!"],[1580,1687,"What are you doing here?"],[1704,1837,"What's with that attitude?"],[1850,1958,"Do you have any idea"],[1962,2050,"who our Miss is?"],[2053,2200,"You bunch of lowlifes!"],[2204,2304,"When you see Princess Vivian,"],[2308,2375,"you'd better hurry up"],[2379,2487,"and kneel down and kowtow!"],[2541,2700,"Kneel and kowtow to her?"],[2704,2837,"Who the hell does she think she is?"],[2858,2975,"In Laxpus Stronghold,"],[3004,3108,"our Chief said we don't kneel to anyone,"],[3145,3320,"not even God."],[3345,3504,"Is she greater than God?"],[3537,3595,"Insolence!"],[3600,3675,"Joanna Drake,"],[3679,3741,"slap her face!"],[4195,4320,"You unruly peasants, how dare you—"],[4808,4900,"Ah!"],[4904,4970,"I'm going to have you all"],[4975,5075,"executed!"],[5375,5462,"Miss!"],[5725,5875,"Ah!"],[5895,5987,"Stop hitting me!"],[7005,7154,"I am Princess Vivian!"],[7250,7362,"How dare you treat me like this!"],[7425,7504,"Miss!"],[7508,7650,"Miss, are you okay?"],[7945,8058,"Qu...inn"],[8062,8120,"Oh, right."],[8125,8258,"I have to find Quinn."],[8262,8375,"Quail?"],[8400,8593,"You're still thinking about eating quail?"],[8616,8679,"Do you have any idea"],[8683,8837,"what kind of situation you're in?"],[8854,9054,"Why are you so greedy?"],[9712,9837,"Eat Brother."],[9887,10037,"Eat Brother."],[10179,10237,"Eat Brother."],[10241,10316,"Oh no."],[10320,10470,"Why is she here!"]],"29":[[116,166,"Miss."],[191,308,"It's those two,"],[312,425,"causing a scene at the gate."],[454,562,"We've caught them!"],[741,916,"They got beaten up pretty bad."],[920,1170,"They don't even look human anymore!"],[1216,1287,"Eat Brother."],[1291,1429,"It's me! It's me!"],[1433,1562,"I'm Vivian!"],[1566,1737,"W-what are you doing here?"],[1741,1816,"You know them?"],[1820,1895,"Two pigs"],[2091,2170,"I mean, two people."],[2175,2258,"Oh."],[2262,2370,"She's my cousin."],[2375,2454,"Your cousin?"],[2458,2558,"Then she's one of us."],[2562,2666,"Untie them! Untie them!"],[2683,2729,"Oh."],[3262,3366,"Quinn."],[3529,3683,"I want them executed,"],[3687,3837,"dumped in the mass grave,"],[3841,3937,"and fed to the dogs!"],[4031,4100,"Hey."],[4123,4287,"Keep hugging me and I'll charge you!"],[4458,4620,"Where did this sl*t come from?"],[4887,5004,"This woman really has"],[5008,5187,"endless brute strength!"],[5225,5437,"I'm your cousin-in-law!"],[5441,5575,"Impossible."],[5604,5754,"My Quinn is the grand Prince Liam,"],[5758,5904,"commanding 100,000 troops in the northwest."],[5908,6000,"How could he ever go for"],[6004,6145,"a country bumpkin sl*t like you!"],[6151,6308,"Are you really the Prince?"]],"30":[[0,120,"There are too many loose lips here."],[125,270,"If the Barbarians"],[275,337,"find out that I'm"],[341,445,"hiding here,"],[450,579,"it could bring disaster"],[583,691,"to Laxpus Stronghold."],[695,854,"I shouldn't reveal my identity yet."],[1075,1150,"My cousin"],[1154,1275,"watches too many plays."],[1279,1387,"She loves spouting nonsense."],[1566,1704,"You two cousins"],[1708,1825,"are pretty funny!"],[1829,2000,"You both have wild imaginations."],[2004,2187,"What imagination?"],[2191,2287,"My Quinn is clearly"],[2291,2375,"Enough!"],[2379,2500,"There is no Prince Liam here."],[2504,2616,"Stop talking nonsense!"],[2620,2716,"Go back down the mountain, now!"],[2720,2879,"Don't make your parents worry."],[2925,2995,"Quinn,"],[3025,3158,"then come with me!"],[3183,3254,"Hey now."],[3533,3687,"You can leave,"],[3733,3862,"but not him!"],[3920,4137,"No way!"],[4141,4404,"Right now,"],[4408,4900,"he is my captive husband!"],[4904,5050,"You sl*t!"],[5054,5212,"How dare you threaten Quinn!"],[5329,5387,"Hah."],[5458,5570,"If any more"],[5575,5637,"of that filth"],[5641,5808,"comes out of your mouth,"],[5812,5945,"I'm going to knock"],[5950,6066,"all your teeth out!"],[6200,6287,"W-What are you doing?"],[6291,6475,"Just let her go down the mountain!"],[6479,6587,"I'm not leaving!"],[6641,6820,"As long as I can stay here"],[6825,7000,"I'll do anything!"],[7220,7416,"Really? Anything?"]],"31":[[316,437,"Tonight,"],[441,545,"you guys can stay here."],[625,704,"You wench!"],[708,787,"My Miss"],[791,887,"is of such noble birth,"],[891,1037,"how dare you put her in a woodshed?"],[1058,1250,"Stay if you want, or get out!"],[1254,1395,"You're spoiled rotten."],[2158,2304,"This country bumpkin's maid"],[2308,2437,"is so terribly uncouth!"],[2441,2537,"Miss,"],[2541,2645,"are you alright?"],[2650,2829,"That fat woman is such a bully."],[2833,3004,"Maybe we should just"],[3008,3108,"That fat woman obviously"],[3112,3241,"has designs on Quinn."],[3270,3354,"I can't let"],[3358,3475,"her scheme succeed."],[3525,3587,"Right."],[3754,3887,"Go ask around and find out"],[3891,4054,"which room Quinn is staying in."],[4091,4216,"Tonight,"],[4233,4366,"I'm going to seal the deal!"],[4391,4454,"Okay."],[5183,5387,"Miss, I found out."],[5391,5541,"The Prince is staying in"]],"32":[[262,537,"Quinn."],[1450,1654,"Quinn."],[1845,1908,"What are you doing?"],[1912,2008,"Quinn,"],[2012,2104,"that country bumpkin"],[2108,2233,"actually made me sleep in the woodshed!"],[2258,2404,"Touch me."],[2458,2550,"My heart"],[2554,2675,"is so lonely,"],[2679,2775,"so empty,"],[2795,2892,"and so cold."],[2958,3025,"Let go!"],[3029,3170,"Men and women should keep their distance."],[3737,3850,"Auntie,"],[3854,4025,"why don't you let me feel your heart"],[4058,4266,"to see exactly how lonely,"],[4270,4550,"empty, and cold it is?"],[4583,4704,"Quinn,"],[4708,4816,"why is there a"],[4820,4916,"little girl in your bed?"],[5620,5787,"Why does Quinn"],[5791,5925,"have so many kids"],[5929,6008,"popping up around him?"],[6012,6237,"Because he's our Daddy."],[6270,6369,"What!"]],"33":[[458,570,"Quinn,"],[575,720,"I just had a"],[725,870,"really terrible dream."],[875,958,"I dreamt that you had"],[962,1050,"four children!"],[1075,1333,"Auntie, are you talking about us?"],[1337,1454,"Th-th-this isn't real!"],[1458,1570,"Quinn,"],[1575,1666,"I must be dreaming."],[1670,1737,"Tell me this is definitely"],[1741,1820,"just a dream!"],[1825,1908,"You're not dreaming."],[1941,2033,"These four"],[2091,2208,"really are my children."],[2212,2325,"That's impossible!"],[2341,2512,"Quinn has always stayed away from women."],[2529,2616,"How could he possibly have"],[2620,2725,"children this old?"],[2729,2804,"Besides, in this world,"],[2808,2887,"other than me,"],[2904,2979,"who else could possibly bear"],[2983,3075,"Quinn's children?"],[3179,3466,"That woman would be me."],[3945,4054,"Quinn's woman"],[4058,4125,"how could she be"],[4129,4237,"a 300-catty fatty like you?"],[4258,4354,"That's impossible!"],[4358,4554,"If I lost weight,"],[4583,4787,"I'd definitely be a beauty."],[4791,4887,"Unlike you,"],[4891,5045,"who's still ugly even when skinny."],[5050,5137,"You d*mn fatty!"],[5141,5237,"How dare you call me ugly!"],[5325,5508,"I am Great Yusphis's most beautiful woman!"],[5512,5637,"Auntie,"],[5641,5841,"even the lady selling tofu here"],[5845,5945,"is prettier than you."],[5950,6120,"And you still claim to be"],[6125,6329,"Great Yusphis's top beauty?"],[6404,6754,"You sure have thick skin."],[6842,6937,"Auntie,"],[6941,7120,"you've got quite a mouth on you."],[7125,7366,"How about I prescribe you some meds"],[7370,7554,"to fix that bad breath?"],[7558,7725,"To mark this occasion,"],[7729,7958,"I'd like to recite a poem"],[7962,8204,"dedicated to this Auntie."],[8208,8466,"A toad in a well calls herself a queen,"],[8470,8720,"Ruling her puddle, a tiny scene."],[8725,8958,"She sees a sky the size of a plate,"],[8962,9237,"And swears she is the greatest of the great."],[9241,9490,"You... You guys"],[9655,9962,"You finally got one thing right!"]],"34":[[237,341,"Miss,"],[345,491,"stop crying, Miss."],[495,650,"You'll ruin your eyes."],[866,966,"That fat woman"],[970,1079,"She definitely used"],[1083,1233,"some cheap tricks"],[1237,1308,"to bear"],[1312,1566,"Quinn's children."],[1570,1658,"Miss,"],[1662,1770,"you are Princess Vivian."],[1775,1875,"The Empress Dowager will personally"],[1879,2006,"appoint you as the future Princess Vivian."],[2007,2166,"Even if that village bumpkin"],[2170,2312,"had four kids, so what?"],[2316,2475,"She can't surpass you."],[2483,2629,"Even if she uses her sons"],[2633,2770,"to enter the Princely Manor,"],[2775,2908,"she'll only be a concubine."],[2916,3075,"You are the lady of the house."],[3079,3154,"Are you afraid you can't handle"],[3158,3306,"a lowly concubine?"],[3418,3481,"That's right."],[3612,3670,"A lowly village girl"],[3675,3812,"like her,"],[3816,3875,"even if she bore"],[3879,3945,"Quinn's children,"],[3950,4016,"so what?"],[4020,4112,"Only I am fit to be"],[4116,4233,"Quinn's wife,"],[4237,4438,"the high-and-mighty Princess Vivian."],[4439,4474,"Exactly."],[5833,5958,"Still sleeping?"],[5962,6120,"Get up and work!"],[6125,6237,"How dare you tell my Miss"],[6241,6320,"to work?"],[6325,6470,"You don't have to work."],[6475,6613,"Then get off the mountain."],[6700,6841,"Oh my!"],[6916,7112,"Quinn loves girls"],[7116,7362,"who work hard!"],[7366,7525,"Especially someone like me,"],[7529,7608,"who is so capable."],[7641,7804,"I can fetch water,"],[7808,7941,"chop wood,"],[7945,8050,"do laundry,"],[8054,8220,"and cook."],[8225,8295,"Oh, my."],[8300,8466,"He really loves me"],[8470,8725,"with all his heart."],[9000,9150,"Hey, wait."],[9210,9328,"It's just work, isn't it?"],[9350,9499,"I'll do whatever you ask."],[10204,10291,"Come on, then."],[10295,10479,"Start by cleaning the latrine."],[10483,10545,"You bi*ch!"],[10674,10836,"How dare you make me clean the latrine!"],[10895,11100,"If you can't even clean the latrine,"],[11104,11256,"how could Quinn possibly"],[11260,11409,"ever like you?"],[11456,11502,"You"],[11666,11783,"I'll clean it."]],"35":[[500,595,"Quinn!"],[920,1037,"Quinn!"],[1450,1595,"Why do you smell like sh*t?"],[1750,1891,"I spent the whole morning"],[1895,2013,"cleaning the latrine."],[2025,2170,"Now the latrine is so clean,"],[2175,2279,"it's practically sparkling."],[2337,2425,"Quinn,"],[2425,2505,"don't worry."],[2522,2579,"From now on,"],[2583,2716,"I'll learn to do every chore."],[2720,2800,"I'll definitely be better than Nora,"],[2804,2904,"that country bumpkin."],[3083,3145,"Good luck with that."],[3232,3307,"Quinn!"],[3308,3358,"Oh,"],[3446,3570,"I just remembered,"],[3575,3687,"I still have wood to chop."],[3700,3754,"I gotta go."],[3762,3849,"Don't come over here!"],[4170,4316,"I cleaned the latrine all morning,"],[4379,4454,"so why is Quinn still"],[4458,4570,"giving me the cold shoulder?"],[4641,4729,"In what way am I inferior to"],[4733,4845,"Nora, that d*mn fatty?"],[5016,5074,"Miss,"],[5100,5179,"if you ask me,"],[5183,5350,"that bumpkin is holding back."],[5391,5495,"She didn't teach you"],[5500,5566,"the real secret."],[5612,5666,"Think about it."],[5670,5770,"The Prince is such a catch."],[5800,5870,"Would she really be willing"],[5875,5970,"to give the Prince up to you?"],[6204,6337,"You have a point."],[6408,6537,"I'm going to find out"],[6625,6787,"what tricks that bi*ch used"],[6791,6920,"to bewitch Quinn."],[6979,7058,"I don't believe"],[7095,7275,"I can't find dirt on that bi*ch."],[7341,7404,"Hmm."],[8191,8246,"This"],[8329,8462,"is this the thing we planted last time"],[8466,8583,"called \"potatoes\"?"],[8658,8712,"Yeah,"],[8737,8837,"they're ready for harvest."],[8916,9004,"They grew so fast."],[9091,9175,"Is this thing"],[9208,9295,"really edible?"],[9337,9375,"Hey,"],[9379,9466,"I promise it's delicious."],[10000,10158,"Wow,"],[10275,10466,"it smells so good."],[10516,10787,"Haven't had griddled potatoes in ages."],[10841,10916,"Is this stuff"],[10962,11050,"really safe to eat?"],[11225,11295,"Just try it."],[11479,11616,"I won't eat something of unknown origin."],[11662,11754,"Even if I starve to death"],[11795,11887,"or jump off from here,"],[11908,12025,"I absolutely won't take a single bite."],[12191,12237,"Is it good?"],[12554,12629,"It's delicious!"]],"36":[[161,279,"Baked potatoes,"],[283,379,"Fried potatoes,"],[387,470,"Pan-fried potatoes,"],[516,673,"French fries!"],[720,825,"Oh, potatoes,"],[829,970,"you really are the kindest food"],[975,1137,"in the entire world."],[1195,1345,"Even though I've never heard of"],[1350,1479,"the dishes she mentioned,"],[1529,1712,"they sound strangely delicious."],[1854,2054,"If I hadn't asked Joanna Drake"],[2058,2245,"to walk around the stronghold today,"],[2333,2475,"I never would've known"],[2479,2579,"that this place is hiding so many"],[2583,2695,"women with filthy diseases!"],[3308,3391,"What's all the noise?"],[3641,3766,"Didn't I tell you not to wander around"],[3779,3900,"until you've recovered?"],[3954,4062,"These two young ladies"],[4066,4208,"found where we live"],[4229,4379,"and threatened to report us to the officials."],[4408,4575,"We were afraid of implicating the Chief,"],[4579,4658,"so we came out."],[4908,5050,"This is my stronghold."],[5091,5220,"Without my permission,"],[5233,5420,"no one can kick you out!"],[5466,5508,"Tsk."],[5575,5641,"Nora,"],[5675,5812,"so what if you're the chief?"],[5816,5945,"They have a filthy disease!"],[5970,6075,"Once discovered,"],[6112,6170,"they must all be"],[6175,6304,"handed over to the authorities."],[6533,6679,"Quinn,"],[6733,6837,"in this fat woman's stronghold,"],[6841,6970,"she's hiding so many women with the pox."],[7012,7050,"Who knows"],[7054,7187,"what shady business goes on here."],[7191,7320,"Maybe this stronghold"],[7325,7462,"is just a whorehouse for these women!"],[7576,7712,"Where are your manners?"],[7762,7820,"Did Uncle"],[7825,7854,"and Aunt"],[7891,7925,"teach you"],[7929,8029,"to spout such nonsense?"],[8100,8225,"Am I wrong?"],[8241,8345,"In such a big stronghold,"],[8362,8429,"there isn't a single man."],[8433,8525,"It's all women."],[8541,8708,"If they don't sell their bodies for money,"],[8712,8844,"how do they support themselves?"],[8874,8912,"Ah!"]],"37":[[95,195,"You dare hit me?"],[312,500,"How dare you hit my Miss?"],[525,629,"I'll make you pay!"],[725,787,"Ah!"],[1041,1187,"Ah!"],[1229,1354,"I'm gonna kill you!"],[1391,1524,"Ah!"],[1541,1595,"Quinn,"],[1600,1718,"help me!"],[2120,2252,"I didn't say anything!"],[2441,2523,"Ah!"],[2634,2734,"I slapped you because,"],[2796,2926,"as a woman yourself,"],[3018,3118,"you actually spouted"],[3133,3249,"that bullsh*t about how"],[3258,3354,"women cannot survive"],[3358,3470,"without men!"],[3575,3675,"In Laxpus Stronghold,"],[3711,3787,"every single woman"],[3791,3925,"can hold up half the sky."],[4004,4100,"They farm,"],[4112,4200,"chop wood,"],[4208,4375,"practice medicine, and trade."],[4445,4579,"In these famine years,"],[4662,4800,"they've all relied on their own skills"],[4804,4870,"to survive."],[4983,5045,"But you,"],[5112,5279,"with your slut-shaming,"],[5283,5354,"you dismissed"],[5358,5541,"everyone's hard work!"],[5664,5787,"The Chief is a good person."],[5800,5866,"If it weren't for her,"],[5891,5975,"those of us with"],[5979,6054,"these 'dirty diseases'"],[6083,6204,"would have long been caught by officials"],[6208,6337,"and burned alive."],[6387,6545,"We shouldn't drag the Chief down."],[6608,6654,"Right."],[6725,6837,"If not for the Chief,"],[6845,6954,"we would have died long ago!"],[7004,7200,"Laxpus Stronghold is our home."],[7216,7337,"The Chief is a good person,"],[7341,7458,"and we shouldn't be a burden to her."],[7491,7508,"Yeah."],[7558,7687,"If you leave the stronghold like this,"],[7704,7816,"you won't stand a chance out there."],[7870,7920,"Since I brought you"],[7925,8016,"into the stronghold,"],[8066,8220,"I'll take full responsibility for you!"],[8262,8337,"But"],[8429,8541,"I always thought this fat woman"],[8545,8670,"was greedy and lustful."],[8708,8791,"I never expected she"],[8795,8916,"had a side like this."],[8929,9000,"Could it be"],[9004,9183,"this is her true self?"],[9335,9475,"Rest easy here and recover."],[9491,9541,"No one will dare cause"],[9545,9645,"trouble for your Chief."],[9825,9937,"I couldn't tell,"],[9983,10087,"but you're actually quite responsible."],[10180,10320,"Has Quinn been so easily"],[10325,10462,"bewitched by this woman?"],[10479,10554,"No."],[10566,10700,"I must find a way"],[10704,10866,"to win back Quinn's heart."],[10870,10950,"I don't believe"],[10954,11045,"I can't beat Nora,"],[11050,11154,"that d*mn fat woman."]],"38":[[1,50,"Miss."],[134,209,"Joanna Drake."],[312,395,"Miss."],[445,608,"I walked the mountain paths all night,"],[650,779,"and I finally figured out"],[800,916,"the reason the Prince is staying here"],[920,1033,"with that fat woman."],[1062,1115,"Really?"],[1129,1216,"Tell me, quick."],[1291,1366,"That fat woman"],[1395,1558,"bore the Prince four children."],[1641,1737,"The Prince is staying at the stronghold"],[1758,1916,"solely for the sake of the children."],[2000,2045,"You're right."],[2108,2200,"Why didn't I think of that?"],[2258,2337,"That fat woman is just using"],[2341,2437,"the children to secure her status."],[2450,2491,"Exactly."],[2541,2637,"As long as Quinn realizes"],[2641,2725,"that I can also take good care"],[2729,2791,"of those children,"],[2812,2954,"he'll surely kick that d*mn fat woman"],[2979,3054,"to the curb!"],[3070,3120,"Mhm."],[3179,3220,"Yeah."],[4733,4829,"Focus, everyone."],[4884,4963,"No slacking off."],[5007,5108,"I'm going to cook."],[6858,6950,"What?"],[6991,7116,"Did you not get enough"],[7120,7187,"of a beating last night?"],[7212,7304,"Do you want me"],[7312,7429,"to slap you again?"],[7491,7612,"You missed."],[7616,7679,"Tch."],[7760,7901,"What exactly do you want?"],[8029,8120,"I want to take care of the children."],[8304,8383,"What?"],[8462,8545,"I said,"],[8562,8745,"I want to help Quinn raise the children."],[8799,8887,"After all, I'm going to"],[8891,9029,"marry Quinn in the future."],[9075,9166,"Eventually,"],[9170,9237,"they'll all be raised under my name"],[9245,9356,"as their legal mother."],[9360,9500,"So I might as well"],[9504,9612,"get to know them now."]],"39":[[205,400,"Are you sure you want to raise children?"],[434,487,"How many?"],[666,787,"As long as they're Quinn's children,"],[791,850,"I'll raise them all."],[886,994,"Oh."],[1091,1150,"Are you sure?"],[1233,1329,"Of course I'm sure."],[1854,1904,"What are you doing?"],[2054,2137,"Didn't you say you wanted to raise kids?"],[2175,2262,"I'll teach you how."],[2279,2320,"Here,"],[2337,2437,"start by chopping vegetables."],[2598,2690,"Fine, I'll chop."],[3316,3375,"Ouch!"],[3441,3537,"Alright, alright."],[3551,3694,"It's just a scratch."],[3712,3837,"Bandage it up, and you'll be fine."],[5241,5304,"Keep going."],[6933,6970,"Let's go."],[6987,7101,"I have a surprise for you."],[7491,7568,"Quinn!"],[7588,7717,"Where are you guys going?"],[8208,8504,"Quinn!"]],"40":[[182,229,"Look."],[707,850,"Don't get the wrong idea."],[893,1012,"I just brought you here."],[1212,1325,"Wow."],[1329,1566,"Did you dig all these potatoes?"],[1759,1820,"Sort of."],[2241,2291,"Your Highness."],[2350,2470,"I received the carrier pigeon order"],[2500,2587,"and rushed here overnight."],[2645,2704,"Could it be"],[2733,2825,"that the steppe tribes are invading again?"],[3291,3450,"If those barbarian scoundrels dare attack,"],[3491,3533,"we"],[3575,3637,"volunteer to be the vanguard."],[3675,3754,"We'll strike straight at their heart,"],[3816,3937,"take the enemy chieftain's head,"],[3963,4123,"and sacrifice it to the Great Yusphis flag!"],[4654,4766,"It is not about the steppe tribes."],[4833,4925,"I summoned you here"],[5063,5195,"to dig potatoes."],[5379,5450,"Potatoes?"],[5508,5529,"Yes."],[5641,5754,"This crop grows quickly,"],[5795,5875,"has an astonishing yield,"],[5904,5983,"and withstands cold and drought."],[6012,6125,"If introduced to the army,"],[6150,6254,"our forces' provisions"],[6283,6408,"will no longer be a constraint."],[6654,6729,"Ooh."],[6754,6895,"You truly are the one I chose"],[6904,7056,"as my captive husband."],[7103,7187,"You woman"],[7198,7329,"Do you have no modesty at all?"],[7379,7512,"We haven't even performed the wedding rites."],[7575,7645,"How can your behavior"],[7670,7770,"be so frivolous?"]],"41":[[233,350,"So you mean,"],[354,537,"if we perform the wedding rites,"],[541,666,"I can be"],[700,858,"as frivolous with you as I please?"],[1050,1079,"I"],[1125,1229,"When did I ever say that?"],[1316,1387,"You woman,"],[1392,1497,"stop talking nonsense!"],[1733,1883,"Strange."],[1887,2058,"Usually when that woman talks like that,"],[2062,2195,"I just feel annoyed."],[2200,2270,"Why do I today"],[2275,2425,"actually feel a hint of anticipation?"],[2429,2525,"I must be crazy."],[2529,2704,"How could I look forward to this fat woman?"],[3262,3363,"My little potatoes,"],[3384,3597,"I'll take you down the mountain tomorrow"],[3613,3770,"and sell you for a good price."],[4041,4133,"I must really be hungry."],[4191,4254,"I actually think"],[4258,4366,"this ogre-like fat woman"],[4425,4525,"is kinda cute."],[5158,5191,"Hey,"],[5245,5370,"pack them properly one by one."],[5379,5450,"On the way down the mountain,"],[5454,5582,"don't let the potatoes get bruised."],[6162,6216,"Hurry up."],[6220,6295,"Find a place to sit tight."],[6300,6354,"We're leaving."],[6441,6554,"I"],[7570,7650,"Let's go."],[7991,8054,"Tch."],[8229,8408,"Quinn,"],[8485,8600,"where are you going?"],[9391,9841,"Stepmother,"],[9845,10025,"we're hungry."],[10029,10208,"Hurry up and cook."],[10212,10529,"Stepmother, hurry and cook."],[10533,10853,"No!"],[10859,11259,"Don't leave me behind!"]],"42":[[458,608,"Potatoes! Potatoes!"],[641,841,"Fresh and delicious potatoes!"],[862,1070,"Step right up! Don't miss out!"],[1379,1487,"What are you staring at?"],[1491,1558,"You think you're posing?"],[1562,1670,"Start hawking!"],[1925,1991,"Potatoes"],[2025,2125,"Potatoes for sale."],[2250,2395,"That's no good."],[2441,2504,"Watch and learn."],[2754,2895,"Potatoes!"],[2933,3187,"Potatoes! Something you've never seen!"],[3229,3387,"More filling than rice,"],[3391,3545,"cheaper than coarse grains!"],[3550,3712,"Fills your belly and saves your money!"],[3716,3954,"Take a basket home for ten copper coins!"],[4075,4145,"Ma'am! Ma'am!"],[4150,4220,"Come take a look."],[4262,4325,"Potatoes."],[4354,4545,"Tasty, cheap, and filling!"],[4729,4829,"Just dirt clods"],[4833,4929,"dug out of a wild field."],[4975,5087,"In all my years,"],[5091,5187,"I've never even heard of them."],[5308,5487,"Aren't you afraid of poisoning people?"],[5558,5687,"So heartless."],[5691,5733,"Pah!"],[5983,6237,"Did someone's pickle jar come to life"],[6241,6354,"and come here to act high and mighty?"],[6358,6416,"Buy or get lost!"],[6420,6475,"Hey, hey, hey."],[6479,6566,"Don't stoop to her level."],[6591,6666,"Good stuff"],[6670,6779,"always finds a buyer."],[6791,6854,"Yeah."],[7154,7311,"Potatoes! Potatoes!"],[7562,7604,"Come on,"],[7608,7687,"come take a look!"],[7691,7866,"Premium white rice!"],[8204,8287,"With today's rice prices"],[8291,8466,"How come it's 57 copper coins a peck?"],[8645,8845,"Wasn't it 42 yesterday?"],[8895,9008,"Yesterday was yesterday."],[9012,9108,"It's not the same as today."],[9191,9295,"Don't you see the situation?"],[9308,9395,"It's a famine year!"],[9408,9479,"Even the imperial troops"],[9483,9600,"are barely getting fed."],[9721,9795,"If you're not buying,"],[9808,9920,"don't waste my time."],[10095,10175,"All this rice of yours"],[10179,10295,"is stale grain from years ago."],[10325,10425,"It's full of bugs."],[10791,10875,"So what if there are bugs?"],[10891,11008,"You're lucky to have anything to eat."],[11041,11108,"If you're not buying"],[11112,11204,"and don't have copper coins, get lost!"],[11545,11687,"Step right up, come take a look!"],[11716,11820,"Premium white rice!"],[11825,11945,"Buy now before it's gone!"],[12229,12400,"Take a look."],[12761,12920,"What is this weird stuff?"],[13027,13131,"Is it edible?"],[13275,13437,"Not only is it edible,"],[13441,13504,"but actually,"],[13508,13679,"it's more filling than rice."],[13875,13937,"If you don't believe me,"],[13941,14037,"I'll show you right now."]],"43":[[1875,1920,"Wow."],[1925,2083,"What smells so good?"],[2179,2379,"I think it's coming from over here."],[2870,2987,"Let's go take a look."],[2991,3120,"Rice is getting more expensive every day,"],[3125,3220,"and it's just wormy old rice."],[3225,3298,"- Exactly. Let's go. - Let's go."],[3301,3400,"Hey, wait!"],[3466,3504,"Hmph."],[3550,3654,"Fine, suit yourselves."],[3658,3795,"It's a famine year anyway."],[3841,3954,"I'm not worried you won't buy."],[4041,4287,"Tomorrow I'll raise the price another forty coins."],[4383,4616,"I'll take the moldy old rice in the warehouse"],[4620,4737,"and sell it all off."],[6395,6617,"It's edible and safe."],[6932,7150,"This is my husband."],[7272,7558,"Here."],[8084,8204,"Look, the young couple both ate it."],[8208,8329,"Seems like they're fine."],[8422,8541,"I can't stand it anymore."],[8575,8720,"Who cares if it's poisonous?"],[8725,8850,"I'm going to try it no matter what."],[9908,10008,"I"],[10025,10117,"I've been poisoned!"]],"44":[[62,116,"I"],[120,220,"I've been poisoned!"],[1079,1179,"You're poisoned,"],[1183,1270,"yet you keep eating?"],[1275,1404,"Why aren't you dead yet?"],[1654,1933,"- I want some! - I want some!"],[1959,2108,"Don't rush, everyone! No need to rush!"],[2133,2287,"Don't worry if you can't grab one."],[2320,2470,"These potatoes are very cheap."],[2487,2604,"Ten copper coins a basket."],[2608,2745,"Take them home and roast them slowly."],[2750,2920,"Enough for the whole family for a long time!"],[2952,3054,"Come on."],[3058,3133,"I want one! I want one!"],[3150,3295,"Give me one."],[3300,3409,"Give me another one."],[3441,3512,"Here, take it."],[3516,3579,"Give me one more."],[3691,3770,"Here, here, take it."],[3775,3795,"Come on."],[3800,3870,"I want one! I want one! I want one!"],[4479,4504,"Hey."],[4508,4570,"Ma'am,"],[4604,4745,"what is that thing you bought?"],[4750,4837,"It's of unknown origin,"],[4841,4937,"and you dare bring it home?"],[4941,5054,"These are potatoes."],[5058,5187,"Ten copper coins a basket."],[5208,5404,"You can fry, boil, or roast them."],[5512,5650,"Wild poisonous lumps,"],[5654,5758,"and you dare eat them?"],[5779,5887,"Aren't you afraid your whole family"],[5891,5954,"will end up vomiting and having diarrhea?"],[6012,6075,"Tch."],[6158,6204,"Hey,"],[6241,6354,"the potato sellers,"],[6358,6500,"the young lady and her husband,"],[6504,6700,"cooked and fried them on the spot,"],[6750,6929,"and ate their fill first."],[6962,7108,"If they were poisonous"],[7125,7212,"Would that young couple"],[7229,7450,"risk their own lives for a show?"],[7491,7604,"If you ask me,"],[7608,7837,"your stockpile of stale rice"],[7841,7954,"won't sell,"],[7990,8129,"so you're crazy for copper coins."],[8225,8308,"I am selling"],[8312,8425,"top-grade polished rice from Jita."],[8433,8604,"Even the officials eat it!"],[8654,8704,"You bunch of"],[8708,8837,"ignorant bumpkins,"],[8908,8975,"just wait until"],[8977,9070,"those... those"],[9075,9175,"dirt lumps of unknown origin"],[9179,9258,"burst your bellies."]],"45":[[1137,1250,"After deducting the copper coins"],[1254,1487,"for room and board these last two days,"],[1491,1620,"the rest"],[1625,1787,"is the total profit"],[1791,2000,"from selling potatoes."],[2620,2800,"Is this the smell of money?"],[2845,3072,"It smells amazing."],[3137,3225,"Vulgar."],[3379,3520,"You're so high and mighty,"],[3633,3837,"but you still eat, drink, and sh*t."],[3837,3881,"You"],[4050,4116,"How crude."],[5099,5162,"By the way,"],[5221,5320,"my room"],[5371,5470,"needs to be paid for today."],[5616,5762,"Aren't you high and mighty?"],[5854,6029,"Don't you think money"],[6066,6187,"is vulgar?"],[6295,6391,"If you want a nice room,"],[6395,6550,"figure it out yourself."],[7598,7745,"I'm going to sleep."],[8225,8295,"Serves you right."],[8300,8408,"That's what you get for being a snob."],[9741,9858,"Get ready to set up the stall."],[10025,10145,"Now do you see"],[10175,10366,"the benefits of money?"],[11741,11870,"What the h*ll is this?"]],"46":[[133,304,"Where did you mangy dogs come from?"],[308,470,"Didn't sniff around to see whose turf this is?"],[475,512,"Beat it!"],[891,966,"You fat b*tch."],[995,1079,"I don't have a rule"],[1083,1270,"against hitting women."],[1419,1495,"Well, well."],[1529,1654,"Is this that pretty boy"],[1658,1725,"you're keeping?"],[1741,1904,"I bet he has no b*lls."],[1908,2012,"He just hides behind a woman's"],[2016,2158,"skirt and plays mute."],[3079,3362,"You look pretty hot when you fight."],[3441,3587,"You aren't worthy of hearing me speak."],[3691,3754,"Speak."],[3791,3900,"Who sent you?"],[4154,4225,"Him."],[4229,4295,"It was him."],[4300,4470,"Chapman, the rice merchant."],[4475,4654,"He was jealous of your booming business,"],[4658,4858,"so he hired us to cause trouble."],[4862,4920,"Let's go, move it!"],[4925,4954,"Go!"],[4958,5008,"Go, go, go!"],[5012,5070,"Hurry!"],[5104,5158,"Bullsh*t!"],[5162,5237,"That's slander!"],[5266,5295,"I"],[5300,5454,"I'm a reputable rice merchant!"],[5483,5550,"They're selling some"],[5554,5675,"shady lumps of dirt!"],[5679,5725,"Who knows?"],[5729,5887,"Eating that stuff implies death someday."],[5983,6079,"Oh lord!"],[6083,6183,"My poor mother!"],[6510,6786,"Everyone, be the judge!"],[6954,7062,"My mom ate"],[7066,7187,"stale rice from Chapman's store yesterday,"],[7191,7300,"and not only did she get the runs,"],[7304,7429,"today she's foaming at the mouth!"],[7433,7562,"She's unconscious!"],[7616,7708,"Impossible!"],[7712,7900,"I only sell polished rice."],[7904,8037,"How could anything go wrong?"],[8041,8116,"This old hag must have eaten"],[8120,8266,"something dirty."],[8325,8404,"Don't try to frame me!"],[8425,8470,"Hey!"],[8558,8612,"Oh!"],[8616,8745,"I figured it out."],[8750,8875,"It's those dirt clods they're selling!"]],"47":[[75,129,"It's her!"],[358,458,"It's her! It's definitely them!"],[658,708,"Your mother must have eaten"],[712,787,"those sketchy things they're selling,"],[791,895,"stuff of unknown origin."],[1054,1125,"Everyone, take a look."],[1183,1295,"Look at what they're selling."],[1325,1387,"It's misshapen and weird."],[1412,1512,"No one has ever seen it before."],[1550,1654,"Just because they say it's edible doesn't mean it is."],[1750,1804,"For all we know,"],[1841,1937,"there's filth inside,"],[1941,2004,"or even poison."],[2104,2266,"It wouldn't be surprising if it killed someone."],[2491,2575,"So my mom ate"],[2579,2641,"your stuff!"],[2662,2762,"You'll pay for my mom's life!"],[3150,3304,"Watch what you say."],[4650,4787,"Do you just believe whatever he tells you?"],[4850,4937,"If your mother were conscious,"],[4970,5087,"she'd die of anger."],[5220,5387,"I remember very clearly."],[5425,5504,"This lady"],[5525,5679,"never bought our potatoes."],[5850,5970,"My rice has been a staple food"],[5975,6087,"for hundreds of years."],[6112,6216,"How could there be anything wrong with it?"],[6295,6391,"It has to be this"],[6395,6475,"wicked couple,"],[6541,6662,"harming people with poison lumps"],[6666,6766,"and trying to pin it on me!"],[6958,7091,"As for who's actually wicked,"],[7137,7245,"we'll find out when she wakes up"],[7250,7358,"and explains everything."],[7429,7600,"Who knows if she'll even wake up?"],[7616,7716,"You're just saying"],[7720,7795,"whatever suits you."],[8305,8420,"Move."],[8500,8570,"Hey!"],[9671,9770,"W-What are you doing?"],[9904,9987,"Are you trying to"],[9991,10037,"kill my mom?"],[10041,10145,"Scared she'll wake up and expose you?"],[10558,10658,"I'm a doctor."],[10662,10770,"If you want your mother to live,"],[10775,10875,"then do exactly as I say."],[11095,11225,"She's just a potato seller,"],[11229,11379,"but now she claims to be a doctor?"],[11391,11487,"Who'd believe that?"],[12275,12408,"Shut your mouth."],[14779,14808,"You"],[15083,15150,"You vicious woman!"],[15154,15261,"- Let go of my mom! - Let her go!"],[15263,15338,"Let go of my mom!"],[15338,15462,"Let her go!"],[15708,15795,"Look! Hurry and look!"],[15804,15875,"This fat woman is about to"],[15879,15966,"kill someone with her treatment!"],[15991,16058,"She's coughing up blood!"],[16520,16625,"You hit me again!"],[16650,16720,"I told you"],[16775,16841,"to shut your mouth."]],"48":[[1225,1379,"She's awake! She's awake!"],[1383,1533,"- She's cured! - Oh my, she really woke up!"],[1537,1612,"She's alive!"],[1650,1779,"Wow, is it really that miraculous?"],[2220,2275,"Mom!"],[2350,2445,"Mom, you're awake!"],[2454,2550,"Mom, come on, get up."],[2582,2750,"Are you okay?"],[2754,2804,"How do you feel?"],[2825,2916,"Does it hurt anywhere?"],[3007,3050,"No."],[3111,3187,"I'm fine."],[3370,3466,"It's so strange."],[3704,3854,"I feel relieved all over."],[3891,4125,"Yesterday's gut-wrenching pain,"],[4129,4237,"the dizziness,"],[4333,4395,"and the nausea"],[4441,4537,"are all gone."],[4966,5054,"- Thank you, thank you! - Thank you!"],[5095,5237,"Please accept a bow from us brothers."],[5245,5337,"Thank you so much."],[5487,5604,"There's no need for that."],[5758,5891,"Since Auntie is awake,"],[5941,6062,"please tell everyone here"],[6066,6137,"clearly,"],[6208,6420,"whose grain did you eat"],[6470,6720,"to cause this disaster?"],[6963,7079,"Yesterday, I ate"],[7083,7137,"his stale rice,"],[7141,7216,"and that's what made me sick."],[7408,7562,"- Oh, so it was him! - It was him!"],[7583,7758,"How heartless."],[7808,7995,"I'll never buy his rice again."],[8129,8295,"You must be in cahoots,"],[8300,8395,"framing me on purpose!"],[8516,8712,"The officers are here!"],[8962,9170,"Who is causing a disturbance here?"],[9241,9320,"Officer,"],[9383,9529,"you have to bring me justice!"],[9533,9637,"It's that Chapman."],[9641,9758,"He's selling rotten, stale rice!"],[9762,9870,"My mom got sick after eating it."],[9875,10012,"She almost died!"],[10041,10075,"Officer,"],[10079,10154,"it's him!"],[10175,10320,"Arrest this crooked merchant right now!"],[10829,10941,"I'm innocent, Sir!"],[10945,11058,"I only sell quality rice."],[11258,11400,"I would never do such a thing!"],[11529,11637,"Despicable."],[12012,12254,"You claim your rice isn't tainted,"],[12375,12504,"but look at this woman."],[12541,12700,"How do you explain her condition?"],[12983,13079,"It was them!"],[13350,13445,"Officer, please listen!"],[13470,13554,"They're the ones who sold"],[13558,13666,"poisonous earth lumps"],[13670,13745,"that harmed people."],[13775,13987,"Now they're trying to frame me!"]],"49":[[66,183,"It's these strange earth lumps you sold,"],[187,337,"coming from who knows where,"],[358,508,"that almost killed someone!"],[525,629,"They caused the poisoning!"],[854,925,"No!"],[1041,1237,"It was Chapman's tainted rice that did it!"],[1575,1737,"Who's the official here, me or you?"],[1791,1870,"Do I need you to teach me"],[1875,1995,"how to judge a case?"],[2075,2162,"If you don't shut your mouths,"],[2183,2275,"I'll arrest every last one of you,"],[2279,2379,"charge you with disrupting the army,"],[2383,2513,"and throw you in jail!"],[2870,2993,"Arrest them!"],[4025,4216,"What kind of bullsh*t judgment is this?"],[4241,4337,"You ignore the evidence"],[4354,4437,"and take bribes first!"],[4504,4587,"You've got Chapman's dirty money"],[4591,4708,"stuffed in your belt,"],[4712,4820,"so naturally you'd speak for him!"],[5004,5070,"Guards!"],[5108,5258,"Throw this fat woman in jail"],[5262,5358,"and torture her!"],[5983,6100,"I dare any of you to touch her!"],[7983,8045,"Prince."],[8095,8150,"Miss!"],[8291,8420,"Prince Liam is here!"],[8425,8537,"Who dares to be insolent?"],[8841,8954,"Prince"],[9137,9387,"- Your Highness. - Your Highness."],[9991,10150,"You don't seem surprised."],[10500,10604,"You're a Prince."],[10625,10795,"Didn't you tell me that a long time ago?"],[10833,10954,"You knew I was a Prince?"],[11012,11158,"Then why did you make me carry water,"],[11162,11337,"chop wood, and plant potatoes?"]],"50":[[416,479,"Oh, well"],[491,670,"I just wanted you to"],[683,870,"experience life in the real world,"],[925,1091,"and the hardships of the people."],[1237,1337,"By that logic,"],[1420,1566,"I should be thanking you."],[1641,1779,"No need to be so polite."],[1908,2108,"Just reward me with,"],[2125,2304,"ten thousand taels of gold."],[2308,2383,"Stop right there."],[2579,2754,"If I listen to another word from you,"],[2791,2937,"I'll probably lose ten years of my life."],[3362,3466,"But you have a point."],[3570,3637,"This time,"],[3750,3887,"I really did experience"],[3891,3979,"life in the real world"],[4004,4120,"and the hardships of the people."],[4395,4529,"How can he be a Prince?"],[5233,5375,"I have offended Prince Liam."],[5379,5487,"I deserve to die!"],[5512,5629,"Please forgive me, Your Highness."],[5675,5745,"Good heavens!"],[5800,5900,"Does that mean that"],[5904,6016,"potato-selling girl"],[6020,6100,"is the Princess?"],[6170,6200,"See?"],[6262,6337,"I knew it!"],[6358,6516,"That gentleman has such an extraordinary air."],[6591,6720,"Chapman has really"],[6725,6804,"messed with the wrong person this time."],[6820,6895,"Exactly."],[7133,7320,"Prince, Princess, have mercy!"],[7358,7429,"You are noble and generous,"],[7450,7541,"please spare my lowly life!"],[7545,7779,"I'll never sell tainted rice again!"],[7866,7975,"It's not that you know you're wrong,"],[8012,8120,"it's that you know fear."],[8300,8437,"Go inspect his rice stall."],[8544,8670,"Yes, Your Highness."],[10362,10445,"Reporting, Your Highness."],[10491,10620,"This rice is moldy,"],[10637,10716,"spoiled,"],[10750,10970,"and even infested with bugs."],[11258,11358,"Guards!"],[11366,11491,"Take this ruthless merchant who risks lives"],[11537,11670,"by selling shoddy goods,"],[11695,11787,"and throw him in prison."],[11858,11979,"Punish him under the laws of Great Yusphis."],[12035,12104,"Hmph."],[13070,13158,"As for you,"],[13204,13350,"you were meant to protect this region,"],[13429,13570,"yet you accepted bribes"],[13575,13762,"and twisted the truth to aid the wicked."],[13808,13870,"Effective immediately,"],[13933,14020,"you are stripped of your rank"],[14050,14158,"and exiled to the Liginia Area."],[14175,14375,"All your illicit gains are confiscated."],[14441,14587,"Hand every penny over to the authorities."],[14608,14695,"Your Highness, have mercy!"],[14695,14805,"Mercy, Your Highness!"],[14805,14925,"Please, have mercy!"],[15116,15237,"- Great! - Yes!"],[15241,15387,"- Serves him right! - Great! Good!"]],"51":[[415,500,"Where is Nora?"],[525,587,"Is she not here yet?"],[641,687,"Uh"],[708,762,"The Princess,"],[766,858,"is getting ready."],[1108,1245,"Who told you she's the Princess?"],[1302,1575,"Well, yesterday at the market,"],[1633,1750,"when the locals called her \"Princess,\""],[1854,1975,"you didn't deny it, did you?"],[2058,2204,"I just didn't want to waste my breath on them."],[2312,2425,"It's beneath my dignity."],[2470,2579,"Right, right."],[2583,2691,"You are the Prince,"],[2791,2904,"you're always right."],[6125,6233,"She's still the same,"],[6241,6387,"has absolutely no sense of propriety."],[6541,6604,"Never mind."],[7958,8170,"This carriage is so grand,"],[8233,8412,"must be worth a lot of copper coins!"],[9054,9116,"Nora."],[9187,9487,"Having you is truly a blessing for me."],[9745,9787,"Ethan,"],[9875,9983,"the contract I asked you to draft yesterday,"],[9987,10050,"is it ready?"],[10175,10258,"It is."],[10291,10425,"Show it to her."],[10450,10491,"Yes, sir."],[11754,12075,"Potato Sales Contract."],[12248,12433,"Read it in the carriage."],[13229,13375,"You mean you want me to"],[13379,13508,"sell the potatoes to the army"],[13512,13658,"as military rations?"],[13691,13775,"The army can offer you"],[13779,13891,"a higher price."],[13933,14070,"And you won't have to worry about sales."],[14112,14283,"For you and the border soldiers,"],[14304,14387,"it's a win-win."]],"52":[[491,600,"If you had such good connections,"],[608,704,"why didn't you tell me sooner?"],[904,1025,"If I had told you earlier,"],[1091,1170,"would you still have taken the potatoes"],[1175,1254,"to the market to sell?"],[1325,1454,"And would a food staple like potatoes"],[1525,1658,"have reached ordinary households"],[1662,1775,"quite so quickly?"],[2133,2254,"Selling the crops you grew yourself,"],[2283,2345,"doesn't that make you"],[2412,2579,"feel a huge sense of honor?"],[3079,3229,"Well, thanks a lot."],[3375,3525,"No need to thank me."],[3554,3637,"Don't go thinking"],[3641,3720,"that you're special."],[3775,3837,"I"],[3862,4058,"have always been this considerate."],[4129,4254,"And don't flatter yourself,"],[4291,4420,"thinking I have"],[4425,4520,"feelings for you."],[5275,5366,"You shrew!"],[5370,5508,"Screw your thanks!"],[5541,5700,"You clearly had a channel to sell potatoes,"],[5704,5804,"but you just had to mess with me"],[5808,5945,"and make me sell them at the market!"],[5987,6116,"I yelled every day until"],[6120,6270,"my throat was on fire,"],[6325,6575,"just to earn those peanuts!"],[6641,6812,"And you're talking to me about honor?"],[6904,7137,"I'm going to strangle you!"],[7250,7404,"What is honor worth?"],[7445,7554,"What I want is"],[7558,7733,"money, money, money!"],[8175,8266,"You shrew!"],[8308,8437,"I have nothing to say to you."],[8525,8654,"I'm taking the children back to the manor."],[8700,8770,"I will never interact"],[8775,8845,"with a shrew like you again!"],[9104,9200,"No, no, wait!"],[9287,9608,"We can talk this out!"],[9858,9954,"If he really takes the kids"],[9958,10037,"back to the Princely Manor,"],[10075,10287,"it'll be hard to see them again."]],"53":[[191,283,"I swear,"],[341,466,"I promise!"],[470,562,"From now on,"],[566,675,"I will absolutely respect you"],[679,833,"and keep my hands to myself."],[837,1087,"You're a big-hearted Prince."],[1095,1245,"Surely you wouldn't bicker"],[1250,1458,"with a petty woman like me?"],[1591,1658,"Nora."],[1737,1875,"This is my final warning."],[1933,2095,"If you can't control these claws,"],[2200,2370,"I won't mind chopping them off for you."],[2633,2704,"Hahaha!"],[2741,2854,"Never again! Never again!"],[3379,3495,"I'll just stall him for now."],[3541,3666,"Then I'll ravish him and kill him."],[3670,3787,"Ravish him, then kill him."],[4141,4229,"Ouch."],[4279,4537,"Finally home."],[4750,4887,"Stepmother! Stepmother!"],[4892,4954,"- Stepmother! - Ahh!"],[4983,5066,"Don't follow me!"],[5150,5220,"- Stepmother! - Stepmother!"],[5233,5329,"- Don't leave us behind! - Don't leave us behind!"],[5333,5404,"- Stepmother! - Stepmother!"],[5408,5566,"- Please don't go! - Please don't go!"],[5570,5637,"- Stepmother! - Stepmother!"],[5641,5770,"Don't leave!"],[5779,5850,"Stepmother!"],[5854,5987,"You have excessive internal heat."],[5991,6108,"Let me stick you with a few needles."],[6125,6191,"Ah! No!"],[6195,6245,"Go away!"],[6258,6370,"I don't want any more needles!"],[6387,6479,"This scene"],[6483,6629,"I simply must recite a poem"],[6633,6841,"for Stepmother!"],[6845,7020,"Ahh! I'm not listening! I'm not listening!"],[7025,7095,"Go away!"],[7383,7566,"Cousin."],[7583,7675,"Stepmother."],[7804,7887,"We're not meant to be."],[7891,8037,"I'll tell Auntie when I get back,"],[8041,8175,"that I already have someone I like."],[8179,8220,"Haha."],[8316,8366,"Hey!"],[8370,8445,"Miss!"],[8470,8587,"Miss, wait for me!"],[8641,8775,"Wait for me, Miss!"]],"54":[[0,104,"Aw."],[145,358,"Stepmother got away just like that."],[404,583,"That's no fun."],[691,950,"How about I go to Stepmother's house,"],[958,1150,"stuff her in a sack, and carry her back?"],[1158,1237,"Yeah, yeah, yeah!"],[1270,1425,"To keep her from going crazy,"],[1454,1612,"I'll stick her with a few needles."],[1650,1787,"Then I'll have to get Stepmother"],[1791,1925,"a poetry book,"],[1929,2020,"to welcome her back."],[2216,2295,"You"],[2391,2570,"are really a handful."],[2591,2704,"She was a perfectly fine person,"],[2708,2895,"but you nearly drove her insane."],[2954,3037,"Sigh."],[3041,3295,"- It's Stepmother's fault. - It's Stepmother's fault."],[3300,3520,"- for being so fragile. - for being so fragile."],[3720,3862,"You four are truly mischievous."],[3925,4004,"You're just like your Mama,"],[4054,4137,"through and through."],[4212,4310,"- Daddy. - Daddy."],[4337,4550,"- We're sorry. - We're sorry."],[4625,4687,"However,"],[4725,4850,"you do have a knack for things."],[4875,4958,"You managed to do what even Daddy"],[4962,5054,"couldn't do."],[5400,5537,"If I knew it was this simple"],[5541,5679,"to make Vivian give up,"],[5708,5925,"I wouldn't have been troubled for so long."],[6208,6287,"Vivian,"],[6345,6508,"is everything you said true?"],[6541,6745,"Quinn has children?"],[6787,6887,"Absolutely true,"],[6891,6958,"Auntie."],[6962,7045,"I"],[7108,7208,"already have someone I like,"],[7229,7337,"and I don't want to marry Cousin anymore."],[7362,7566,"It doesn't matter, it doesn't matter."],[7620,7729,"From now on,"],[7758,7995,"Of the talented young men in the capital,"],[8070,8183,"you may pick whichever one you want."],[8225,8379,"Whoever catches your eye,"],[8400,8470,"I"],[8491,8645,"will arrange the marriage for you."],[8708,8795,"Thank you, Aunt."],[8808,8875,"Hurry,"],[8908,9050,"go tell the Emperor to draft a decree."],[9125,9204,"Order that brat"],[9208,9404,"to bring my grandson and granddaughter"],[9420,9500,"back here."],[9520,9587,"I"],[9604,9704,"can hardly wait"],[9708,9833,"to see them."],[9865,9965,"Yes, Your Majesty."]],"55":[[1100,1204,"Where do you think you're going?"],[1320,1370,"Oh!"],[1387,1408,"Uh"],[1491,1620,"Heh heh heh heh"],[1641,1745,"Heh heh."],[1825,1908,"Haha."],[1925,2066,"If I said to you I'm taking them for a"],[2100,2166,"night jog"],[2191,2300,"Yeah, exactly."],[2308,2391,"Would you believe me?"],[2451,2587,"Do you think I believe that?"],[2658,2808,"I guess you don't."],[2841,2954,"The Imperial Decree has arrived,"],[2987,3054,"and yet you still plan"],[3058,3154,"to run away with the children?"],[3291,3379,"Nora, Nora"],[3437,3550,"You really have some nerve."],[3558,3675,"If you were me,"],[3704,3820,"and someone tried to snatch your children,"],[3841,3958,"would you just give in without a fight?"],[3970,4004,"Your children"],[4008,4100,"are mine, too."],[4129,4179,"The one trying to snatch them"],[4212,4337,"is standing right in front of me."],[4633,4708,"When did I say I was taking them"],[4754,4820,"away from you?"],[4925,5079,"I'm taking the children to the capital."],[5133,5233,"As their mother,"],[5312,5366,"you naturally have to"],[5370,5470,"come back with us."],[5504,5570,"Huh?"],[5641,5775,"You're taking me to the capital?"],[5891,5945,"Yes."],[6125,6220,"Once we're back in the capital,"],[6345,6491,"drop that bandit attitude."],[6612,6687,"You represent"],[6741,6870,"the face of the Princely Manor."],[6904,7008,"Ugh."],[7183,7258,"Let's go, children."],[7262,7400,"Stop fooling around with your Mama."],[7404,7479,"Hurry back and rest."],[7491,7545,"Tomorrow,"],[7591,7704,"I'm taking you back to the capital."],[7741,7770,"Let's go."],[7941,8087,"What does that b*st*rd mean?"],[8158,8262,"Don't tell me"],[8404,8454,"Hey!"],[8470,8570,"What do you mean?"],[8583,8654,"Figure it out yourself."]],"56":[[83,145,"My son,"],[229,537,"your brother Quentin finally has heirs."],[620,712,"When the time comes,"],[716,929,"give that common woman a sum of money"],[950,1120,"and send her far away."],[1175,1262,"Then, for Quinn,"],[1266,1437,"we'll find a legal wife."],[1470,1595,"And place the children"],[1633,1837,"under the legal mother's care."],[1908,2037,"You're absolutely right, Mother."],[2133,2250,"At Quentin's age,"],[2295,2375,"it is time"],[2379,2495,"he had a mistress of the house"],[2525,2650,"to manage the household."],[2683,2733,"Mm."],[2866,2904,"Hey,"],[3925,4025,"I rode my pony"],[4029,4220,"here before."],[4254,4387,"This is where I carried Daddy"],[4395,4504,"off in a sack."],[4891,5008,"We're almost at the imperial palace."],[5025,5154,"Remember to watch your words and actions."],[5229,5304,"Do you hear me?"],[5320,5416,"Watch our words and actions."],[5491,5525,"Mm."],[5662,5737,"You too."],[6795,6870,"Your Highness,"],[6966,7125,"the Prince is here"],[7141,7229,"with his four children."],[7270,7312,"Quick,"],[7329,7420,"bring them in."],[7525,7579,"And"],[7633,7858,"the children's mother is here too."],[8091,8158,"Quinn actually brought"],[8162,8316,"that commoner woman"],[8320,8425,"into the capital."],[8529,8666,"Invite her in as well."],[8679,8775,"Yes, Your Highness."],[9258,9325,"Your Highness,"],[9912,10029,"Greetings, Mother."]],"57":[[108,237,"Greetings, Mother."],[254,400,"Wishing you peace and good health."],[658,800,"Greetings, Your Highness."],[850,1187,"- Greetings, Grandmother. - Greetings, Grandmother."],[1220,1300,"Come, come."],[1308,1470,"Come here to Grandmother."],[1487,1687,"Let me get a good look at you."],[1875,1970,"Oh my."],[2025,2150,"You're so adorable."],[2187,2337,"You look just like Quinn"],[2341,2454,"when he was little."],[3083,3170,"Didn't they say"],[3175,3375,"the children's birth mother"],[3379,3520,"was brought here too?"],[3533,3616,"Where is she?"],[3641,3729,"Bring her in,"],[3733,3870,"let me see her."],[3908,3979,"Mother,"],[4070,4166,"she's right here."],[4575,4679,"What did you say?"],[4770,4945,"I didn't see clearly just now."],[5008,5170,"I thought she was your guard."],[5220,5370,"You... you"],[5383,5558,"You brought her into my palace."],[5629,5758,"Don't tell me"],[5779,5925,"you intend to marry her."],[5991,6066,"Mother,"],[6137,6275,"she bore my children,"],[6337,6487,"so I must take responsibility."],[6620,6820,"He really wants to marry me."],[7270,7400,"Fine, fine."],[7508,7670,"She'll merely be a concubine."],[7733,7929,"She doesn't have to socialize,"],[7958,8087,"so she won't need to be seen."],[8179,8270,"Sigh."],[8270,8481,"What am I to do?"],[8900,8975,"Mother,"],[9041,9325,"I want to take Nora as my wife."],[9425,9587,"What did you say?"],[9587,9783,"I will never agree."]],"58":[[12,137,"Absolutely not."],[725,795,"Mother,"],[845,920,"all these years,"],[925,1025,"I have never asked you for anything."],[1066,1204,"This is the only thing I ask of you."],[1237,1308,"I"],[1358,1479,"intend to take Nora as my wife."],[1683,1795,"Grandmother."],[1841,2004,"Don't be mad at Daddy"],[2012,2200,"and Mama anymore."],[2220,2375,"Okay?"],[2591,2654,"Sigh."],[2725,2812,"And you?"],[2841,3008,"Are you just going to stand there?"],[3091,3295,"Have you nothing to say to me?"],[3325,3387,"I"],[3700,3745,"Your Majesty!"],[3750,3791,"Mother!"],[3808,3929,"Grandmother!"],[3958,4095,"Her Majesty's headache is flaring up!"],[4112,4154,"Quick,"],[4187,4275,"summon the imperial physician!"],[4308,4370,"Wait."],[4420,4491,"I'm a doctor."],[4525,4637,"Let me examine Her Majesty."],[4666,4745,"Miss,"],[4791,4950,"even though Prince Liam"],[4954,5045,"brought you here,"],[5083,5308,"Her Majesty's health is paramount,"],[5379,5525,"so I cannot be negligent."],[5562,5629,"Nanny,"],[5687,5954,"my Mama is an amazing doctor."],[5975,6087,"Just let Mama"],[6091,6287,"treat Grandmother."],[6325,6400,"Yeah!"],[6470,6570,"It's an emergency."],[6629,6737,"I trust Nora's medical skills."],[6766,6820,"Step aside."],[6841,6900,"Your Highness,"],[6929,6995,"but"],[7204,7287,"What do you need me to do?"],[7408,7525,"Prepare a folding screen,"],[7558,7608,"and have Mia"],[7625,7720,"be my assistant."],[7750,7775,"Alright."],[8077,8161,"At once."],[9227,9350,"System,"],[9350,9416,"redeem a medical kit."],[9429,9504,"Redemption successful."]],"59":[[2458,2766,"Was it you who cured me?"],[2830,2879,"Yes."],[2975,3133,"It's truly a miracle."],[3250,3529,"Whenever my chronic headaches flare up,"],[3683,3937,"sometimes I'm in pain for weeks."],[4063,4149,"But this time,"],[4229,4479,"the pain is gone so quickly."],[4641,4754,"Grandmother,"],[4758,4887,"I told you,"],[4933,5066,"my Mama is"],[5070,5208,"the best doctor ever!"],[6041,6275,"You cured my headache"],[6354,6516,"because you want me to approve"],[6520,6733,"your marriage to Quinn, right?"],[6783,6958,"I didn't think that far ahead."],[7012,7141,"I'm a free-spirited"],[7145,7154,"ruler of the mountains."],[7233,7370,"Why would I trap myself"],[7375,7554,"in this deep, walled-in compound?"],[7591,7658,"I was just worried about"],[7662,7745,"my children,"],[7775,7908,"so I followed them to the imperial palace."],[7958,8145,"Do you really have no feelings"],[8150,8287,"for Quinn at all?"],[8325,8404,"I"],[9162,9250,"I"],[9304,9500,"won't meddle in your affairs anymore."],[9525,9666,"It's for you young people"],[9708,9816,"to figure out yourselves."],[9908,9966,"By the way,"],[10045,10237,"how long will this thing take?"],[10316,10450,"It looks quite peculiar."],[10504,10645,"Your Majesty,"],[10650,10770,"you're changing the subject"],[10775,10937,"really awkwardly."],[11035,11183,"It won't take long."],[11183,11279,"Once the liquid in the bottle"],[11279,11441,"finishes dripping, I can remove it."],[11441,11525,"Why don't"],[11591,11695,"you take a seat?"],[11733,11995,"Don't all crowd around me."],[12025,12158,"It's a bit rude."],[12229,12375,"At a moment like this,"],[12416,12654,"I just want to recite a poem."],[12662,12908,"The falling flower pines for the stream,"],[12958,13254,"but the stream has no heart for the flower."],[13316,13583,"How tragic."]],"60":[[262,387,"Pair of threes."],[458,562,"Pair of fours."],[595,683,"Pair of Kings."],[825,900,"Pass."],[1175,1237,"Pass."],[1370,1470,"Bomb!"],[1470,1615,"Whoa."],[1693,1801,"Three with one."],[1933,2020,"That boy of mine"],[2058,2208,"has quite the temper."],[2208,2383,"Growing up,"],[2383,2475,"he was always the one"],[2479,2566,"doing the rejecting."],[2604,2716,"No one has ever"],[2720,2850,"turned him down before."],[3025,3154,"Pass."],[3164,3212,"Sigh."],[3308,3441,"The imperial palace is so boring."],[3458,3537,"If not for the free meals,"],[3541,3637,"who would live here?"],[3675,3750,"Pass."],[4054,4185,"Pair of twos."],[4241,4387,"A three."],[4443,4680,"Darn."],[4683,4795,"I lost again."],[4829,4966,"You're right."],[5104,5295,"Whether or not you fight with my son,"],[5308,5437,"you're still my dear girl."],[5437,5562,"From now on,"],[5562,5654,"come to the imperial palace often"],[5658,5725,"and keep me company."],[5800,5866,"This imperial palace"],[5870,6041,"really is too boring."],[6079,6170,"You got it."],[6279,6354,"Recently,"],[6391,6487,"envoys from the barbarian lands are coming."],[6554,6629,"While you're in the palace,"],[6675,6833,"try not to wander around."],[6933,7058,"You must avoid those"],[7062,7245,"uncivilized barbarians."],[7279,7329,"Mhm."],[7366,7429,"Did you hear me?"],[7429,7475,"Yeah, yeah,"],[7475,7537,"I heard you."],[9254,9483,"Watching the sky at dawn, the clouds at dusk,"],[9625,9837,"thinking of you when I walk,"],[9908,10066,"thinking of you when I sit."],[10158,10350,"You sold out my love,"],[10404,10558,"forcing me to leave."],[10633,10879,"When I finally learned the truth,"],[10883,11104,"my tears fell down."],[11108,11234,"Hahaha."],[11238,11329,"You sold out my love,"],[11329,11545,"you sold out my love."],[11595,11670,"Oh, my."],[11712,11858,"What a truly spirited"],[11862,11920,"performance."]],"61":[[70,170,"Hold on a second."],[275,345,"Gavin,"],[362,445,"what brings you here?"],[525,579,"Quentin,"],[595,654,"the Steppe Kingdom’s mission"],[658,737,"will arrive in the capital soon."],[755,866,"Prince Stephen"],[879,937,"has surely made"],[941,1083,"thorough preparations."],[1091,1187,"This time,"],[1191,1387,"it's going to be a tough battle."],[1391,1608,"Since you've struck out in love,"],[1628,1741,"on this battlefield,"],[1763,1954,"you should at least win a round."],[2008,2191,"That last part was unnecessary."],[2758,2862,"Nora,"],[2908,3025,"in recognition of your contribution"],[3041,3200,"to the royal bloodline,"],[3237,3387,"I hereby grant you"],[3394,3545,"a seat next to Prince Liam,"],[3595,3808,"with the honors of a Princess Consort."],[3870,3995,"Thank you, Your Majesty."],[4158,4229,"Quinn,"],[4250,4300,"I"],[4304,4433,"have done all I can for you."],[5008,5158,"Mother is such a busybody."],[5200,5329,"Don't touch me."],[6041,6150,"Why are you sitting so far away?"],[6191,6295,"It's not like I'm going to eat you."],[6325,6425,"Quentin,"],[6429,6545,"if you keep acting smug,"],[6550,6595,"I swear"],[6600,6650,"I'll take Lionel and the others"],[6654,6737,"back to the stronghold right now"],[6758,6887,"and marry a dozen bandit husbands."],[6925,7000,"You wouldn't dare."],[7070,7270,"Seeing this scene,"],[7275,7545,"I just want to recite a poem."],[7587,7862,"Ask the world, what is love?"],[7908,8195,"It just makes people argue every day."],[8220,8408,"It's better to be single."],[8450,8608,"No drama."],[8679,8762,"Daddy, Mama,"],[8812,8879,"I think your"],[8883,9037,"tempers are flaring."],[9041,9187,"How about I give you a few needles?"],[9216,9350,"- You're itching for a spanking. - You're itching for a spanking."],[9400,9479,"- Uh-oh. - Uh-oh."],[10033,10220,"The Barbarian Envoy has arrived."]],"62":[[230,289,"Who is this?"],[975,1108,"Prince Stephen."],[1129,1254,"He leads the delegation for an audience."],[1259,1375,"May Your Majesty and the Empress Dowager"],[1379,1483,"enjoy eternal peace."],[1716,1787,"Aunt!"],[1891,2004,"Vivian?"],[2058,2204,"Vivian!"],[2412,2554,"Insolence!"],[2629,2720,"Since you married me,"],[2725,2854,"and became Subutai's wife,"],[2891,3025,"you must know your place."],[3037,3233,"I won't have you weeping here."],[3266,3395,"I never should have been"],[3400,3479,"so blinded by foolishness,"],[3483,3587,"vowing to marry a warrior"],[3591,3716,"better than my cousin,"],[3720,3870,"only to be tricked by Subutai."],[4354,4470,"You sl*t!"],[4500,4550,"Are you still"],[4554,4687,"pining for your cousin?"],[4820,4887,"How dare you!"],[5246,5392,"My apologies, Your Highness."],[5500,5700,"That's how we are in the steppe tribes."],[5758,5887,"If a wife misbehaves,"],[5929,6016,"the husband has the right"],[6029,6150,"to teach her a lesson."],[6212,6369,"That is simply barbaric!"],[6441,6587,"This is the imperial palace of Great Yusphis,"],[6608,6658,"not the royal tent"],[6662,6775,"of your steppe tribes."],[6979,7045,"Enough."],[7059,7150,"Subutai."],[7254,7395,"Daddy, Mama,"],[7433,7666,"Stepmother looks so pitiful."],[7708,7745,"Since when"],[7750,7854,"did she become your stepmother?"],[7900,7937,"Hmph."],[7941,8037,"I hate this kind of"],[8041,8154,"scumbag who beats women."],[8341,8427,"This is a diplomatic exchange,"],[8429,8529,"so do not be rash."],[8579,8675,"- Humph. - The Barbarian Kingdom obviously"],[8679,8766,"came prepared this time."],[8808,8887,"The more impulsive you are,"],[8908,8969,"the easier you'll fall"],[8969,9070,"into their trap."]],"63":[[58,154,"Your Majesty, Empress Dowager,"],[187,225,"on this visit,"],[229,316,"I actually brought along"],[320,400,"a wonderful treasure."],[1354,1458,"It's the Jade Coral!"],[1495,1595,"Such a peerless treasure,"],[1608,1750,"there is only one in the world."],[1966,2137,"The treasure is fine,"],[2170,2258,"but the wolves"],[2270,2370,"are eyeing us hungrily."],[2662,2854,"To cement the bond between our nations,"],[2933,3120,"I will wager this Jade Coral"],[3125,3212,"as a stake"],[3233,3391,"to challenge Great Yusphis to a contest."],[3429,3545,"If my Barbarian Kingdom loses,"],[3579,3700,"we will obediently hand over"],[3704,3808,"the Jade Coral."],[3858,4191,"How about one city per question?"],[4433,4537,"These Barbarian scoundrels"],[4541,4670,"truly have sinister intentions."],[4725,4850,"We cannot gamble with our cities!"],[4865,4950,"Your Majesty,"],[4954,5112,"you absolutely must not agree!"],[5175,5316,"Does the Yusphis dynasty"],[5350,5454,"really not have"],[5545,5679,"a single person"],[5683,5770,"capable of competing?"],[5775,5829,"Ah!"],[5833,5987,"Hahaha!"],[6225,6320,"You see?"],[6345,6408,"You people of Great Yusphis"],[6470,6591,"are all a bunch of cowards!"],[6910,7100,"Haha."],[7191,7275,"Emperor,"],[7325,7437,"if you refuse,"],[7454,7558,"it would inevitably tarnish the prestige"],[7566,7720,"of my Great Yusphis."],[7862,8070,"I accept."],[8162,8337,"A decisive answer, Your Majesty."],[8608,8708,"Here is the first question."],[8728,8866,"Then I shall accept the challenge."],[8879,9054,"I am the First Warrior,"],[9058,9183,"titled by the King of the Steppe himself."],[9204,9287,"Today,"],[9329,9491,"I will challenge"],[9529,9729,"the War Hero of Great Yusphis."],[10625,10745,"I accept."],[12112,12170,"Prince Liam"],[12179,12287,"truly lives up to his title as"],[12291,12370,"the Kingdom of Yusphis's War Hero."],[12386,12479,"Indeed,"],[12500,12616,"he is far superior to those"],[12620,12795,"scoundrels from the Barbarian Kingdom."],[12891,12995,"The Barbarian Kingdom"],[13012,13166,"has really suffered a double loss this time."],[13183,13275,"Hahahaha!"],[13300,13395,"What a disgrace."],[13458,13533,"Subutai,"],[13600,13704,"aren't you the Barbarian Kingdom's"],[13708,13787,"First Warrior?"],[13808,13879,"Where's that arrogance"],[13883,13987,"you had when you made promises to me"],[14025,14133,"back in your country?"],[14675,14801,"- You cheated! - You cheated!"],[14962,15063,"Go to hell!"],[15479,15537,"Hmph."],[15541,15679,"Die, you bastard!"]],"64":[[83,150,"Are you all right?"],[191,270,"I'm fine."],[308,375,"Where's the imperial physician?"],[408,512,"Summon the imperial physician!"],[1908,2008,"Prince Stephen,"],[2086,2185,"is this the Barbarian Kingdom's"],[2191,2341,"way of doing things?"],[2591,2729,"Prince, watch your words."],[2775,2895,"If we lose the cities"],[2900,2995,"because of your actions today,"],[3058,3191,"and the King blames us,"],[3250,3404,"can you bear the responsibility?"],[3729,3829,"Since ancient times,"],[3854,4012,"history is written by the victors."],[4041,4170,"You people of Great Yusphis,"],[4175,4254,"are nothing but weaklings."],[4312,4395,"You're no match for"],[4400,4554,"my Barbarian warriors."],[4725,4854,"Hah!"],[4857,5008,"Hoo! Hoo! Hoo!"],[5041,5275,"You shameless Barbarian brat!"],[5715,5793,"Your Majesty,"],[5829,5962,"I volunteer to fight."],[5966,6091,"I challenge this Barbarian warrior,"],[6154,6329,"wagering two cities"],[6370,6483,"on the outcome."],[6520,6683,"How dare she?"],[6887,6987,"Preposterous."],[6991,7129,"These are crucial military matters,"],[7133,7283,"not a game for a woman."],[7475,7587,"Your Majesty, please reconsider."],[7591,7679,"This wager"],[7712,7904,"concerns the safety of our borders."],[7983,8058,"Emperor,"],[8062,8295,"Nora is trustworthy."],[8441,8620,"I allow it."],[9029,9112,"We already lost one city."],[9116,9195,"Is that not enough?"],[9216,9387,"Are we going to lose three in a row?"],[9559,9658,"Present the first question."],[9658,9787,"The Barbarian Kingdom set the first challenge,"],[9826,9922,"so this one"],[9950,10079,"will be set by Great Yusphis."],[10079,10291,"Subutai,"],[10291,10425,"do you dare accept?"],[10429,10612,"I'm a mighty warrior."],[10637,10741,"Why would I fear"],[10745,10770,"a lowly woman"],[10775,10850,"like you?"],[12691,12770,"Whoever can"],[12795,12958,"reach into this pot of boiling oil"],[12975,13108,"and retrieve this copper coin,"],[13175,13229,"will be the one"],[13233,13345,"to keep"],[13350,13512,"the two cities."]],"65":[[29,95,"What did you say?"],[245,370,"Retrieve a copper coin"],[375,445,"from this boiling oil?"],[656,977,"Is the Barbarian warrior so weak"],[1008,1154,"that he's actually scared?"],[1329,1400,"Subutai!"],[1466,1633,"Two cities are at stake here."],[1750,1866,"If you dare back out,"],[1929,2200,"I'll tell Father when we return,"],[2204,2308,"and he'll hack you to pieces!"],[2608,2745,"I don't believe she dares to retrieve"],[2750,2808,"a copper coin from this oil pot."],[4800,4975,"I won."],[5054,5220,"Good."],[5275,5520,"Excellent!"],[5579,5745,"She is truly worthy of the one"],[5750,5833,"Mother and Quentin favor."],[5925,6004,"Impossible."],[6104,6166,"I don't believe it."],[6233,6420,"There must be a trick to this copper pot."],[7791,7858,"Subutai!"],[7929,8045,"The Barbarian Kingdom has no need"],[8050,8137,"for useless trash like you."],[8375,8420,"Your hand!"],[8620,8650,"You"],[8654,8754,"How did you do it?"],[8941,9233,"Perhaps the Eternal Heaven protects me."],[9291,9487,"It cannot tolerate the Barbarian Kingdom"],[9491,9654,"or the shameless behavior"],[9658,9775,"of such despicable villains!"],[9900,10012,"O Eternal Heaven,"],[10112,10283,"please forgive us!"],[10500,10625,"Sure enough, using faith"],[10629,10720,"is the best way to scare them."]],"66":[[179,266,"Your Majesty,"],[304,387,"regarding this contest,"],[429,583,"we concede defeat wholeheartedly."],[645,820,"We willingly offer the Jade Coral"],[825,920,"and a city"],[975,1091,"to maintain the peace between our nations."],[1320,1425,"No need for formalities, Prince."],[1450,1537,"Go and get some rest."],[1784,1828,"Let's go."],[2675,2752,"Nora,"],[2812,2950,"you served your country well this time."],[3062,3170,"I hereby bestow this Jade Coral"],[3191,3279,"upon you as a reward."],[3395,3595,"I also grant you ten thousand taels of gold"],[3654,3754,"and a thousand acres of fertile land."],[3850,4050,"I'm rich!"],[4054,4325,"My stronghold can expand again! - I'm rich!"],[4441,4912,"I'm so rich!"],[4962,5041,"Thank you, Your Majesty."],[5075,5279,"Long live Your Majesty!"],[5420,5529,"Don't be in a hurry to thank me."],[5591,5716,"I haven't finished rewarding you yet."],[5816,5970,"I also confer upon you the title of"],[5975,6079,"Lady of the First Rank,"],[6137,6270,"grant you a mansion,"],[6275,6437,"and set a date for your marriage to Prince Liam."],[6737,6829,"Who would want"],[6833,6970,"to start digging their own grave by getting married?"],[7025,7150,"I still wanted to snatch a dozen"],[7154,7325,"handsome men to be my captive husbands!"],[7447,7582,"Now I'm doomed."],[7638,7754,"Don't you dare."],[7754,7850,"Defying the decree means losing your head."],[8158,8289,"Oh my!"],[8291,8537,"I think finding love after marriage"],[8541,8679,"is actually quite nice!"],[9125,9220,"Alas,"],[9225,9320,"Quentin,"],[9325,9537,"I've done all I can for you."],[9941,10004,"Nora."],[10162,10212,"Cousin,"],[10287,10370,"I just want to have a few words"],[10375,10470,"with my cousin-in-law."],[10525,10620,"Don't be so nervous."],[10832,10923,"About what?"],[11141,11391,"Just private girl talk."],[12599,12708,"Daddy,"],[12708,12820,"what on earth is Mama saying"],[12825,12954,"to Stepmother?"],[13079,13158,"Don't call her Stepmother."],[13479,13558,"My husband's hand"],[13562,13704,"is rotting like a pig's trotter now."],[13741,13837,"And a country like the Barbarian Kingdom"],[13862,14004,"that worships martial power"],[14079,14191,"naturally has no use"],[14195,14275,"for a man like him."],[14350,14441,"And all of this"],[14579,14691,"is because of you."]],"67":[[287,458,"Are you actually planning"],[495,629,"to stick with that rotten man?"],[691,837,"After how he treated you,"],[841,945,"you still won't divorce him?"],[950,1050,"Are you saving him for the holidays?"],[1262,1387,"Of course I won't divorce him."],[1658,1791,"We women of Great Yusphis"],[1797,1937,"are loyal and devoted."],[2033,2145,"Since the Barbarian Kingdom doesn't want him,"],[2225,2375,"I'll keep him here in the Yusphis dynasty."],[2450,2550,"He is my husband,"],[2608,2845,"so naturally, I'll take good care of him."],[3008,3137,"Are you alright?"],[3200,3300,"Is a man like that"],[3333,3487,"worth all this sacrifice?"],[3725,3816,"Of course he is."],[4216,4287,"Thank you."],[4900,5000,"Why do I get the feeling"],[5029,5137,"that something is off about her?"],[5962,6066,"These past few days,"],[6070,6200,"Daddy has been recovering,"],[6204,6295,"and eating that"],[6300,6462,"bland, watery food with him"],[6483,6637,"has been absolute torture."],[6737,6791,"In a bit,"],[6795,6883,"make sure you all"],[6887,6979,"wipe your mouths clean."],[6995,7133,"We can't let him find out, okay?"],[7208,7487,"Got it, Mama."],[7737,7904,"Mama, add two eggs."],[7929,7975,"Sure."],[9183,9366,"Mama, add some sausage."],[9370,9454,"Okay."],[9525,9745,"Add two veggie packs, too."],[9750,9825,"You got it."],[10250,10520,"And some beef cubes!"],[10558,10691,"Coming right up!"],[12975,13279,"It's so delicious!"]],"68":[[625,675,"By the way,"],[727,823,"where are the Princess Consort and the children?"],[1025,1250,"The Princess Consort and the children"],[1254,1387,"are in the ancestral hall"],[1391,1529,"praying for you, Your Highness."],[1804,1937,"Is this what having a family feels like?"],[2208,2295,"Keep an eye on the time."],[2341,2420,"Don't let them get too tired."],[2462,2554,"It would break my heart."],[2633,2654,"Yes, sir."],[2736,2777,"Oh,"],[2779,2837,"by the way, Your Highness,"],[2916,3087,"Prince Stephen of the barbarian lands"],[3108,3225,"has brought gifts to visit you."],[3279,3408,"He's likely here to apologize"],[3412,3508,"for Subutai's trickery"],[3575,3745,"and for injuring you."],[3791,3862,"What a hassle."],[3987,4037,"Send them in."],[4054,4170,"I'll say a few words and send them on their way."],[4254,4295,"Yes, sir."],[4320,4354,"Prince,"],[5070,5237,"does the War Hero of Great Yusphis"],[5262,5358,"really live in a place like this?"],[5379,5412,"Yes."],[5525,5633,"These square walls"],[5666,5804,"really box people in."],[5958,6000,"You look ahead,"],[6029,6179,"and can't see the grasslands at all."],[6675,6800,"Where is that delicious smell coming from?"],[7041,7187,"Prince, Prince, you can't go over there!"],[7212,7329,"That... that is"],[7333,7458,"where the Princely Manor's family lives!"],[7783,7970,"Great Yusphis sure has a lot of lousy rules."],[8145,8220,"Prince! Prince!"]],"69":[[758,875,"I can't believe there's such"],[879,979,"an overpowering fragrance in this world."],[1066,1158,"Just smelling it"],[1162,1300,"is enough to make"],[1304,1420,"my stomach growl like crazy."],[2408,2591,"You must be the Barbarian Prince."],[3070,3112,"Miss Nash."],[3129,3304,"With such delicious food right here,"],[3329,3408,"I wonder if I"],[3479,3662,"might beg a bowl to taste?"],[3733,3804,"Of course."],[3820,3870,"Come on, come on."],[3887,3958,"We treat our guests right."],[3970,4087,"Can't just let you watch."],[4141,4179,"Wait."],[4341,4479,"You have to pay."],[4891,4945,"Take it all."],[5162,5225,"Here, come on."],[5254,5358,"Everyone gets a share."],[5554,5637,"Wait a sec, wait a sec."],[5641,5725,"Let me pass them out."],[7562,7679,"You people of Great Yusphis,"],[7775,7870,"live such stifled lives."],[7904,7950,"Your rules are more numerous"],[8041,8120,"than hairs on an ox."],[8191,8254,"Exactly."],[8258,8337,"It's so hypocritical."],[8475,8541,"Unlike you."],[8629,8708,"You're very interesting."],[8962,9195,"Will you return to the grasslands with me?"],[9400,9487,"The sky is high and the land is wide,"],[9575,9650,"leaving you free to roam."],[9904,10037,"Nora is my wife."],[10100,10208,"Who gave you the nerve"],[10241,10341,"to dare come into my Princely Manor"],[10358,10445,"and try to take her away?"],[10604,10695,"But I've heard"],[10812,10887,"Miss Nash"],[11004,11154,"is very unhappy staying in the Princely Manor."],[11633,11691,"You don't want to stay?"],[11891,12004,"No, no, no, no."],[12075,12145,"I'm willing."],[12150,12229,"More than willing."],[12525,12595,"Guards,"],[12666,12725,"see the guest out."],[14641,14720,"Actually,"],[14841,14958,"if you don't want to be trapped here,"],[15029,15116,"I suppose I could"],[15120,15225,"go back to Laxpus Stronghold with you"],[15291,15420,"and continue being your captive husband."],[15483,15541,"Really?"],[15691,15837,"That's great!"]],"70":[[341,537,"Honey, time to eat."],[591,645,"I cooked this"],[650,808,"personally for you."],[891,954,"Come on, try it."],[1600,1679,"Why aren't you eating?"],[1679,1741,"Honey?"],[1791,1920,"Isn't this your favorite?"],[2050,2133,"I can't eat anymore."],[2241,2337,"Can't eat anymore?"],[2525,2684,"But you'd have an appetite with another woman?"],[2750,2837,"You're just a cripple."],[2883,3016,"If I didn't support you,"],[3070,3166,"do you think you could still live"],[3170,3308,"such a pampered life?"],[3391,3462,"Vivian."],[3462,3500,"You"],[3500,3575,"What?"],[3633,3704,"I, Princess Vivian,"],[3708,3804,"cooked for you personally."],[3829,3904,"What is there to be unhappy about?"],[4183,4225,"Eat."],[4270,4416,"I said eat!"],[4833,4925,"You madwoman."],[4975,5037,"You good-for-nothing!"],[5041,5120,"You dare push me?"],[5154,5200,"Guards!"],[5225,5300,"Hold him down!"],[5391,5441,"What are you doing?"],[6104,6195,"A divorce."],[6200,6375,"I want a divorce, you madwoman!"],[6391,6475,"Divorce?"],[6608,6737,"If a cripple like you leaves me,"],[6741,6854,"where would you go?"],[7012,7058,"Speak!"],[7116,7204,"Are you hooking up with"],[7208,7304,"some tramp outside?"],[7795,7829,"You"],[7862,7937,"What are you doing?"],[8008,8100,"Break his legs."],[8204,8275,"Then you won't be able to run."],[8879,8975,"My leg!"],[9191,9300,"My leg!"],[9670,9812,"Husband,"],[9841,9908,"please forgive me."],[9975,10020,"I was wrong."],[10079,10112,"From now on,"],[10116,10216,"I won't treat you like this again."],[10270,10462,"Let's live happily together."]]}