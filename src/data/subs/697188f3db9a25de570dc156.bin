t feel like"],[1216,1400,"Quinn doesn't seem to have"],[1491,1545,"romantic feelings"],[1550,1687,"for that Vivian girl."],[1758,1887,"You worry too much, Your Highness."],[1979,2112,"Prince Liam focuses all his attention"],[2150,2350,"on government and military affairs."],[2375,2491,"It's only natural"],[2525,2608,"that he's a bit slow"],[2658,2750,"when it comes to romance."],[2883,3154,"Princess Vivian is gentle and virtuous,"],[3237,3437,"and she's deeply devoted to the Prince."],[3500,3654,"After spending time together,"],[3691,3783,"Prince Liam"],[3787,3920,"will surely understand"],[3925,4050,"your good intentions."],[4108,4254,"I only hope"],[4258,4354,"Quinn can soon"],[4358,4604,"give me a grandson."],[5141,5220,"Quinn!"],[5404,5479,"Princess Vivian."],[5533,5658,"Quinn,"],[5700,5779,"why are you acting"],[5783,5900,"so distant toward me?"],[5975,6058,"I am your"],[6062,6358,"dearest cousin, after all!"],[6441,6608,"Aunt summoned us to the palace today"],[6633,6800,"to arrange our marriage."],[6833,7037,"We'll be united as husband and wife."],[7100,7254,"You will be me,"],[7341,7475,"and I will be you."],[7491,7575,"What did you say?"],[7641,7800,"Mother summoned me to the palace"],[7853,7918,"actually to arrange a marriage"],[7922,8029,"for me and Vivian?"],[8041,8216,"After I went to the palace to see Mother,"],[8258,8358,"I refused the marriage."],[8525,8595,"I'm telling you,"],[8654,8729,"Auntie is about to"],[8733,8808,"grant us a marriage."],[8891,9037,"Oh, I'm so embarrassed."],[9054,9179,"Princess Vivian, there's a child ahead."],[9283,9387,"Watch where you're going!"],[9612,9700,"You have a death wish!"],[9725,9858,"How dare you block my path?"],[9891,10070,"Kid, get out of my way right now!"],[10120,10250,"He's so handsome!"],[10300,10437,"I should snatch him"],[10441,10654,"to be Mama's bandit husband."],[10691,10754,"Mama loves pretty boys,"],[10825,10908,"so she'll definitely like him!"],[10958,11045,"Prince Liam, prepare to die!"],[11091,1118