{"1":[[104,154,"Sir!"],[225,270,"Speak."],[316,408,"After your wife divorced you,"],[412,504,"she lost nine pounds."],[541,629,"So, did she admit she was wrong?"],[675,720,"No."],[725,770,"She"],[775,879,"took the money from the divorce,"],[891,925,"and hired"],[929,1020,"108 male escorts."],[1033,1091,"What?"],[1150,1195,"Well,"],[1220,1300,"Madam is now"],[1304,1358,"rich, beautiful,"],[1362,1429,"and in great shape."],[1441,1566,"She also has a medical PhD."],[1579,1637,"Her suitors"],[1641,1758,"are lined up from here to France,"],[1762,1895,"circling the globe three times!"],[3025,3066,"Well, well!"],[3112,3229,"Look who it is."],[3258,3370,"If it isn't"],[3391,3487,"the couple living happily"],[3491,3591,"with your precious first love?"],[3595,3670,"The sh*meless pair?"],[3733,3900,"And the b*st*rd of the bunch,"],[3933,4008,"Mr. Sterling."],[4091,4154,"Nora."],[4191,4279,"Don't go too far."],[4320,4437,"You're degrading yourself!"],[4541,4641,"Degrading?"],[5437,5512,"Buddy,"],[5595,5716,"take a good look."],[5858,6020,"Look at his abs."],[6091,6179,"Then look at"],[6254,6312,"yourself."],[6316,6450,"That potbelly of yours."],[6508,6608,"If I were you,"],[6691,6858,"I'd be too ashamed to speak."],[6891,6970,"Nora!"],[7058,7170,"I can hear you!"],[8287,8350,"Mr. Sterling,"],[8416,8529,"men,"],[8554,8645,"once they pass twenty-five,"],[8683,8787,"are practically fifty-two."],[8858,8950,"You be careful."],[9020,9104,"One day,"],[9162,9320,"you'll die at the hands of your dream girl!"],[9441,9508,"Nora!"],[9525,9620,"I'll help your grandma cross the street,"],[9633,9745,"take your grandpa on the swings,"],[9783,9916,"take your mom to the supermarket,"],[10004,10087,"I'll take your dad"],[10091,10195,"to play bumper cars,"],[10204,10258,"and then for you,"],[10262,10387,"take a family photo all by myself."],[10712,10787,"Quentin!"],[10895,10975,"What is it?"],[11025,11162,"In the villa you gave me,"],[11254,11354,"the toilet"],[11445,11562,"It's glowing!"],[12037,12137,"Quentin,"],[12279,12458,"did you hide gold in the toilet?"],[13304,13458,"Nora! Nora!"],[14041,14170,"Miss,"],[14466,14612,"Miss, are you awake?"],[14704,14858,"Where am I?"],[15554,15637,"Holy cr*p,"],[15708,15966,"did the toilet suck me in?"],[16058,16166,"Miss,"],[16208,16350,"you're finally awake!"],[16408,16600,"Thank goodness I followed you,"],[16654,16775,"otherwise I never would have"],[16779,16987,"seen you again in this life."],[17433,17570,"Miss, what's wrong?"],[19025,19083,"This wine"],[19133,19220,"It's poisoned."],[19500,19595,"If it weren't for the"],[19600,19708,"secret Blossom Brew recipe in your hands,"],[19729,19854,"a talent like me, Arnold,"],[19891,19970,"How could he ever fall for"],[19975,20087,"an ugly fat woman like you?"],[20133,20204,"You"],[20470,20612,"you d*mn fatty."],[20651,20720,"Did you really think"],[20725,20820,"Arnold would marry you?"],[20970,21120,"Selena,"],[21175,21237,"you guys"],[21304,21408,"You pair of"],[21441,21587,"cheating sc*mbags!"],[21870,21966,"Cousin,"],[21970,22045,"why don't you take a look"],[22050,22137,"at yourself?"],[22191,22287,"For Arnold, sleeping with you"],[22291,22429,"is no different than sleeping with a pig."],[22841,22891,"Guards!"],[22933,23008,"Drag her to the back hill"],[23012,23083,"and feed her to the wolves!"],[23441,23516,"I…"],[23541,23737,"I've transmigrated."],[23825,23904,"The original owner"],[23966,24150,"saved Arnold by the roadside."],[24241,24329,"She thought"],[24333,24450,"she had found herself"],[24454,24587,"the perfect husband."],[24641,24725,"Unexpectedly,"],[24750,24837,"Arnold"],[24841,24945,"was not only ungrateful,"],[24979,25166,"but also seized her family's wealth!"],[25233,25379,"He secretly had an affair"],[25383,25558,"with the original owner's cousin,"],[25595,25700,"drove all the old loyal staff"],[25704,25854,"out of the winery,"],[25891,26137,"and eventually took over the Nash family!"],[26975,27050,"Where is my"],[27075,27287,"killer figure?"],[27541,27758,"I, a distinguished 21st-century"],[27762,27945,"medical doctor,"],[28020,28300,"actually transmigrated into Chubby?"],[28429,28645,"Are you seriously playing me like this?"]],"2":[[0,120,"Miss,"],[233,429,"what should we do now?"],[454,583,"Hmm"],[591,641,"Well,"],[737,908,"we definitely can't go back to the Nash family."],[945,987,"It must be crawling"],[991,1104,"with Arnold's men."],[1112,1350,"Let's go find Steward."],[1408,1462,"Right."],[1466,1541,"Wait,"],[1633,1900,"Miss, have you forgotten?"],[1904,2062,"Because of Arnold's instigation,"],[2083,2183,"you kicked Mr. Walters out"],[2187,2304,"and sent him back to his hometown."],[2333,2504,"Will he forgive us?"],[2700,2887,"Steward is loyal through and through."],[2908,2987,"He definitely won't watch"],[2991,3116,"Arnold steal the family fortune."],[3175,3250,"Let's go!"],[4191,4250,"Hold it!"],[4808,4845,"Miss,"],[4879,5025,"it looks like we've run into a hitman."],[5170,5266,"Run for it!"],[6208,6358,"You took over my body,"],[6370,6566,"so I want you to save this man."],[6641,6804,"I've set my sights on him!"],[6862,6925,"I want him to"],[6929,7004,"take my"],[7008,7225,"virginity."],[7279,7579,"Or else I'll haunt you,"],[7591,7687,"haunt you forever!"],[7741,7825,"Lady,"],[7925,8045,"look at the situation!"],[8108,8187,"If you want to have a lovesick episode,"],[8191,8300,"pick a better time!"],[8370,8416,"How about this,"],[8420,8466,"later on, I'll"],[8470,8545,"find you a good catch,"],[8550,8620,"okay?"],[8641,8725,"No way."],[8870,9175,"He's even hotter than Arnold."],[9279,9445,"I want him!"],[9470,9525,"Wait,"],[9550,9604,"I haven't even seen"],[9608,9737,"his face clearly yet."],[9758,9895,"How do you know he's hot?"],[9991,10220,"My eyes never lie!"],[10308,10445,"Within ten miles,"],[10450,10520,"there isn't a single hottie"],[10525,10720,"that I can't spot!"],[10725,10837,"You shallow simp."],[10850,10985,"Even death didn't teach you a lesson."],[11000,11152,"Ah!"],[11241,11320,"Alright, alright."],[11370,11416,"I'll save him."],[11483,11629,"I'll go save him, okay?"],[13541,13637,"Body slam!"],[15187,15255,"Hey."],[15304,15387,"Still breathing?"],[16270,16366,"Thank you, Miss,"],[16450,16545,"for saving my life."],[16679,16737,"You!"],[16825,16887,"You!"],[16925,17266,"Quentin, you d*mn scumbag!"],[17279,17358,"You actually transmigrated"],[17362,17500,"here with me?"],[17529,17687,"If I hadn't divorced you,"],[17700,17858,"I wouldn't have ended up within here!"],[17870,18250,"I-I-I'm gonna strangle you!"],[18358,18450,"Strangle you!"],[18541,18608,"Stop!"],[18633,18850,"I am not who you speak of."],[19070,19163,"No, you can't, you can't!"],[19170,19458,"He's a top-tier hottie!"],[19654,19750,"Alright, alright."],[19775,19900,"I won't touch him, okay?"],[20641,20900,"You... really aren't Quentin?"],[21083,21158,"No."],[21250,21487,"Speak. Since you saved me,"],[21575,21670,"what reward do you want?"],[22004,22137,"Even though looking at your face"],[22183,22295,"really ticks me off,"],[22504,22650,"I can't help that someone likes it."],[22725,22829,"You want to repay me?"],[22875,22987,"Sure."],[23029,23329,"Then be mine!"]],"3":[[158,229,"You fat woman,"],[266,383,"how dare you covet my body!"],[429,491,"Shameless!"],[762,837,"Listen, man,"],[870,937,"do you think you have"],[941,1087,"the right to refuse?"],[1737,1804,"Miss,"],[1858,1933,"I brought the sack"],[2070,2154,"you asked for."],[2237,2316,"Say, Miss,"],[2387,2533,"what do you need the sack for?"],[3779,3843,"Luckily, the original owner's dad"],[3848,3967,"left me a house."],[3978,4163,"It finally comes in handy."],[4845,4908,"Maggie,"],[4929,5008,"come here!"],[5083,5208,"Go boil some water."],[5245,5366,"Your Miss here"],[5425,5491,"is going to handle"],[5516,5629,"some adult business."],[6008,6062,"Oh."],[7479,7579,"Whoa."],[8329,8429,"Listen, man,"],[8491,8579,"now's the time"],[8620,8837,"for you to repay me!"],[8900,8975,"No,"],[9020,9075,"no way!"],[9095,9254,"I can't!"],[9787,9841,"A man"],[9904,9987,"can never say"],[10000,10162,"he can't."],[11000,11112,"Come on!"],[11154,11316,"Let's have fun!"],[11433,11593,"My back... my back"],[11620,11713,"My back"],[11745,11883,"Check it out."]],"4":[[666,766,"I gotta hurry"],[802,936,"and find Mr. Walters!"],[1741,1987,"I'll just pretend I slept with a gigolo."],[2608,2804,"Just seeing his face annoys me."],[2808,2979,"He's not worth it!"],[3775,3854,"His performance was terrible."],[3866,3975,"Deduct another two coins."],[4032,4077,"Hmph!!"],[6316,6483,"That damned fat woman."],[6487,6675,"She actually treated me like a gigolo,"],[6708,6800,"thinks I was bad in bed,"],[6804,6929,"and only worth two copper coins."],[7045,7212,"That fat woman"],[7220,7437,"That is too much!"],[7862,7920,"Your Highness!"],[8191,8266,"Your Highness!"],[8315,8638,"I was... late to the rescue."],[8825,8920,"You two,"],[8925,9012,"get out!"],[9016,9058,"Yes, sir!"],[9416,9575,"Your Highness, this is"],[9579,9716,"In the capital, there are so many"],[9720,9775,"noble ladies"],[9779,9933,"who admire and adore you."],[9975,10008,"But,"],[10025,10104,"but now,"],[10108,10212,"to let these scoundrels"],[10216,10279,"take advantage of you"],[10325,10379,"I…"],[10383,10429,"I…"],[10566,10645,"I can only"],[10733,10837,"atone with my death!"],[10908,10941,"I"],[10950,11100,"will make sure that fat woman"],[11454,11587,"Your Highness,"],[11591,11666,"here,"],[11704,11775,"don't catch a cold."],[11920,12045,"Help me up."],[12125,12208,"I will personally"],[12212,12341,"bring that fat woman to justice."],[12408,12550,"How dare she say I can't perform!"],[12554,12604,"Ah!"],[12608,12687,"My back! My back!"],[13104,13254,"Prince,"],[13329,13445,"are you alright?"],[13554,13608,"Don't tell me"],[13629,13804,"your back is giving out?"],[13858,13975,"I am"],[14020,14120,"perfectly capable."],[14775,14875,"Pass on my order."],[14916,15100,"Investigate that woman's background."],[15162,15320,"Take her to the Princely Manor dungeon,"],[15350,15425,"and interrogate her strictly!"],[15445,15479,"Yes, sir!"],[15504,15554,"Prince!"],[15679,15770,"Remember,"],[15804,15937,"I'll interrogate her personally!"]],"5":[[666,737,"Miss,"],[812,1008,"I didn't expect Mr. Walters"],[1012,1145,"to pass away so soon after going home."],[1208,1391,"What should we do now?"],[1508,1620,"Don't worry."],[1625,1808,"We'll find a way."],[1825,1904,"It's getting late,"],[1920,2004,"so let's find an inn"],[2008,2070,"and get some rest."],[2095,2137,"Okay."],[3716,3812,"Hello? Anyone here?"],[4341,4420,"Welcome."],[4458,4620,"Here for a meal or a room?"],[4658,4720,"We need a room."],[4737,4850,"And bring some hot water and food"],[4854,4937,"up to our room!"],[4991,5050,"Let's go."],[6633,6754,"I'll leave these here"],[6758,6845,"on the table for you ladies."],[6912,6966,"Okay."],[7008,7120,"Just put it there."],[7500,7537,"Maggie,"],[8137,8262,"this smells so good!"],[8279,8404,"I'm starving!"],[8741,8804,"Lately,"],[8808,8937,"we've been traveling non-stop,"],[8950,9100,"sleeping rough,"],[9170,9270,"so why does my waist"],[9329,9416,"feel like it's gained"],[9420,9583,"an extra layer of fat?"],[9633,9695,"Miss,"],[9725,9804,"hurry up and eat!"],[9808,9854,"If it gets cold,"],[9858,9945,"it won't taste good."],[9975,10045,"Ugh,"],[10104,10154,"forget it."],[10254,10379,"I need to get full"],[10391,10562,"to have the energy to diet!"],[10912,10954,"Wait!"],[11054,11145,"Miss,"],[11220,11366,"I suddenly feel"],[11433,11520,"so sleepy."],[11754,11804,"Maggie!"]],"6":[[883,945,"You guys,"],[1004,1145,"go carry the fat one."],[1225,1358,"I'll carry this skinny one."],[1404,1479,"Lock them in the cellar first,"],[1558,1650,"along with"],[1662,1816,"the other women!"],[1858,1970,"This shady inn"],[1991,2079,"They're repeat offenders."],[4141,4229,"Ty,"],[4266,4350,"what should we do?"],[4383,4516,"This woman is so fat,"],[4541,4650,"she won't fit in the cage."],[4666,4737,"When the time comes,"],[4758,4875,"how do we ship her to Qxasall?"],[4908,5054,"Those painters are real sickos."],[5058,5137,"They insist on using women's blood"],[5141,5250,"to make their paint."],[5279,5337,"Luckily,"],[5412,5537,"thanks to those perverts,"],[5562,5645,"we can make"],[5650,5737,"a fortune in these famine years,"],[5804,5908,"filling our pockets,"],[5937,6104,"and having meat and wine at every meal."],[6204,6287,"Stop yapping!"],[6295,6387,"Use the iron chains"],[6391,6508,"to lock up this fat woman"],[6533,6616,"first!"],[7308,7370,"What the"],[7416,7558,"You're actually fine!"],[7625,7662,"Everyone,"],[7683,7766,"get her!"],[8354,8429,"Spare me, Lady Hero!"],[8454,8545,"I was blind"],[8550,8691,"not to recognize your greatness."],[8700,8745,"We"],[8758,8833,"were forced into this, too."],[8837,8925,"We had no choice"],[8962,9070,"but to get into this"],[9075,9270,"wicked business."],[9335,9466,"Don't believe his lies!"],[9491,9562,"Who knows how many girls"],[9566,9662,"they've sold!"],[9854,9908,"Watch out!"]],"7":[[2145,2287,"Trying to run?"],[3904,3945,"Maggie."],[4329,4470,"I wish I had some silver needles."],[4525,4666,"The innkeeper's room should have some."],[4708,4858,"I overheard someone say so earlier."],[4891,5008,"Someone got hurt,"],[5012,5104,"and wanted him to treat the injury."],[5225,5283,"Thanks."],[5300,5400,"I'll take her to the room first,"],[5425,5512,"then go look for the medical kit."],[5550,5650,"I can help find the kit."],[5704,5750,"Miss,"],[5762,5816,"let us help you."],[5820,5912,"We'll carry her to the room together."],[5933,6020,"Hurry over and help!"],[7191,7275,"Miss"],[7358,7487,"What happened to me?"],[7525,7650,"This is a shady inn."],[7654,7754,"After you ate that plain bread,"],[7758,7841,"you passed out."],[8044,8204,"A... shady inn?"],[8366,8504,"Then we have to run!"],[8575,8670,"Don't be scared."],[8691,8737,"Those guys,"],[8775,8887,"I've already handled them."],[8920,9004,"You just get some rest."],[9008,9104,"I'll go boil some water."],[9112,9195,"No, don't!"],[9258,9387,"Don't leave me alone."],[9412,9495,"I'm scared!"],[9516,9570,"Oh boy."],[9620,9720,"If you're this timid,"],[9741,9870,"how will you survive with me?"],[10108,10187,"Let's go."],[10891,10991,"Miss,"],[11008,11116,"please let us come with you!"]],"8":[[141,187,"Miss,"],[225,350,"I know you're a good person."],[370,500,"If I go back like this,"],[533,679,"I'd be walking right back into a trap."],[700,804,"My parents sold me to a trafficker"],[808,995,"for just two taels of silver."],[1020,1087,"Then that trafficker"],[1091,1195,"was killed by the people at this inn,"],[1283,1404,"and I fell into their hands."],[1458,1604,"My dad wanted to trade me in marriage"],[1608,1737,"so my brother could get a wife."],[1741,1820,"He has already"],[1825,1958,"beaten several wives to death at home."],[1962,2066,"I ran away"],[2070,2150,"just to survive."],[2162,2229,"I didn't expect"],[2233,2370,"to get caught by this shady inn."],[2375,2445,"There was a plague"],[2487,2637,"in my hometown."],[2666,2870,"I escaped"],[2875,2987,"with the rest of my village,"],[3025,3120,"but on the way,"],[3141,3345,"I was caught and brought here."],[3416,3525,"My husband owed gambling debts"],[3562,3687,"and sold me off."],[3704,3787,"Last year, my husband"],[3791,3912,"was dragged off to be a soldier,"],[3954,4095,"and he never came back!"],[4170,4245,"Miss,"],[4312,4466,"they're so pitiful!"],[4758,4920,"They are all poor souls,"],[4970,5037,"but it's no use"],[5041,5145,"telling me all this."],[5191,5312,"I can barely protect myself right now."],[5454,5495,"Miss,"],[5541,5604,"we know"],[5608,5704,"that you're capable."],[5741,5816,"You can fight"],[5829,5895,"and you know medicine."],[5925,5995,"At least in this"],[6000,6095,"To protect ourselves in the chaos."],[6108,6220,"Savior, rest assured,"],[6235,6352,"we all know how to work."],[6383,6483,"We definitely won't be freeloaders!"],[6514,6579,"All the copper coins we earn"],[6591,6670,"will be given to you."],[6683,6725,"We only ask,"],[6833,6937,"we only ask that you teach us"],[6941,7000,"a move or two!"],[7058,7125,"So we can"],[7129,7225,"protect ourselves in this chaos."],[7300,7404,"Please, Savior!"],[7408,7516,"Teach us a move or two!"],[7683,7804,"We beg you!"],[7841,7900,"They just"],[7904,7995,"want to survive."],[8041,8154,"But how can I feed"],[8158,8295,"and protect so many people?"],[8325,8425,"Detected strong collective"],[8429,8516,"will to survive"],[8520,8679,"and Host's potential leadership."],[8700,8787,"Conditions met."],[8804,8862,"Binding"],[8866,8975,"Congratulations, Host Nora."],[8979,9029,"Successfully activated"],[9033,9204,"the Wartime System."],[9208,9270,"Ultimate Goal:"],[9275,9345,"Amidst the chaos,"],[9350,9479,"establish a peaceful"],[9483,9637,"and prosperous sanctuary."],[9658,9762,"Novice Mission released:"],[9766,9845,"Accept the first batch"],[9850,9887,"of refugees (0/11)"],[9891,9970,"and provide them with"],[9975,10045,"safe shelter."],[10054,10112,"Mission Rewards:"],[10120,10279,"Simple Settlement Gift Pack x1,"],[10283,10408,"System Points +100."],[10658,10787,"It's not a hallucination."],[10862,11054,"It really is the System."],[11200,11379,"Oh my god!"],[11404,11520,"In this lousy ancient world,"],[11545,11866,"I'm finally saved!"]],"9":[[45,141,"Miss,"],[241,304,"what's wrong?"],[333,470,"Is your hysteria acting up?"],[620,725,"I'm fine, really."],[827,940,"Everyone, stop kneeling."],[958,1066,"Get up, hurry!"],[1215,1425,"Benefactor, please,"],[1433,1537,"I beg you!"],[1550,1620,"I'll work like an ox in my next life"],[1625,1695,"to repay you!"],[1825,1920,"I said,"],[1962,2070,"get up!"],[2091,2175,"Since"],[2179,2308,"you're willing to follow"],[2312,2395,"and trust me,"],[2441,2500,"then today,"],[2504,2604,"I, Nora,"],[2608,2720,"accept you."],[2841,2908,"I can't promise"],[2912,3075,"you'll live in luxury,"],[3091,3241,"but as long as I have food,"],[3264,3372,"I won't let you starve!"],[3444,3565,"As long as I can stand,"],[3633,3675,"I will do my best"],[3679,3775,"to protect you!"],[3908,3987,"Stop!"],[4158,4279,"My first rule here"],[4295,4350,"is that you are not allowed"],[4354,4470,"to kneel to anyone anymore."],[4475,4587,"Let's pack up"],[4591,4720,"and leave this place of trouble."],[4725,4770,"We'll find a place"],[4775,4879,"to settle down!"],[5004,5075,"Great!"],[5204,5316,"Receiving first batch of refugees:"],[5325,5412,"11/11."],[5416,5466,"Completed."],[5470,5570,"Simple Settlement Gift Pack"],[5583,5695,"has been sent to System Space."],[5704,5808,"Please check, Host."],[5820,5920,"Plus one hundred points to the System."],[5995,6079,"I didn't expect"],[6091,6170,"to finish the Novice Mission"],[6175,6262,"so quickly."],[6400,6450,"Maggie,"],[6491,6548,"help pack up"],[6554,6634,"anything useful."],[6691,6845,"Everyone, lend a hand."],[6854,6908,"We need to"],[6912,7008,"leave immediately!"],[7050,7095,"Yes!!"],[8379,8512,"Keep up, everyone!"],[8741,8875,"Watch your step!"],[8937,9050,"Stay safe!"],[10133,10208,"Everyone,"],[10308,10395,"let's rest here"],[10441,10575,"for the night!"],[10675,10745,"Where are we?"],[10981,11093,"What is this place?"],[11125,11187,"I know"],[11220,11354,"there's nothing here."],[11362,11437,"Now,"],[11441,11612,"we've been reduced to refugees,"],[11650,11758,"homeless,"],[11783,11891,"with an uncertain future."],[11895,12016,"But precisely because we"],[12020,12108,"have nothing,"],[12154,12220,"we have"],[12225,12354,"nothing to fear."],[12525,12654,"The government abandoned us."],[12700,12858,"The world turned its back on us."],[12895,12945,"So we will"],[12962,13129,"look after ourselves!"],[13162,13204,"Right!"],[13270,13366,"From today on,"],[13400,13554,"this is our home,"],[13625,13837,"and we are each other's family."],[13850,14070,"The ancients said strangers can be brothers."],[14100,14245,"Who needs blood ties?"],[14291,14420,"From this day forth,"],[14491,14658,"We'll support each other"],[14662,14770,"and stick together!"],[14825,14958,"In this chaotic world,"],[15004,15179,"we'll carve out a path to live."],[15383,15475,"Survive!"],[15637,16254,"Survive!"],[16308,16416,"Sur"],[16558,16620,"Benefactor."],[16820,16879,"Benefactor."],[17004,17092,"Miss."],[17102,17224,"Miss, what's wrong?"],[18104,18145,"I"],[18150,18375,"I... I'm pregnant."],[18437,18545,"No wonder lately"],[18550,18708,"even drinking water makes me gain weight."],[18733,18950,"It's because I'm pregnant."],[19112,19270,"Good Lord."],[19291,19408,"Don't play such a"],[19412,19566,"joke on me, okay?"]],"10":[[358,570,"Hello, Chief!"],[741,800,"Hi, Chief!"],[833,934,"You have to watch your health!"],[966,1054,"Hello, hello."],[1058,1195,"Hello, Chief!"],[1254,1370,"Hi there."],[1391,1454,"Chief,"],[1600,1637,"here!"],[1708,1775,"Have some fruit."],[1870,1954,"Freshly picked."],[1983,2070,"It's really sweet!"],[2145,2225,"In times like these,"],[2266,2416,"only our village has such a good harvest."],[2470,2645,"We eat meat and rice every meal."],[2675,2704,"Yeah!"],[2725,2820,"It's all thanks to"],[2825,2895,"our Chief."],[3055,3187,"Hey, Chief,"],[3200,3293,"you gotta take it easy!"],[3370,3475,"Aren't you due soon?"],[3550,3637,"That's right, Miss!"],[3650,3745,"Daisy said"],[3750,3845,"it'll be any day now."],[4054,4187,"I'm the one who taught Daisy"],[4191,4337,"everything she knows about medicine."],[4358,4450,"I know my own body"],[4454,4533,"better than anyone."],[4558,4625,"It won't be for at least"],[4629,4766,"another half a month."],[4979,5041,"Oh my God"],[5066,5141,"What's going on?"],[5516,5608,"Chief,"],[5691,5787,"what's wrong?"],[5791,5945,"The baby's coming! Maggie!"],[6333,6437,"Why hasn't she delivered yet?"],[7200,7329,"What is taking so long?"],[7900,7970,"Oh my!"],[7995,8066,"A miracle!"],[8083,8170,"It's a miracle!"],[8183,8329,"The Chief's child must be"],[8375,8487,"A true prodigy!"],[8591,8654,"Push harder!"],[8687,8829,"The baby's almost out!"],[8887,9008,"Great, great!"],[9020,9070,"Chief,"],[9108,9220,"i