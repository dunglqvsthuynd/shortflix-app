,2064,"Will the boss come after us?"],[2081,2152,"No."],[2152,2231,"She's Karen."],[2268,2456,"And she is a nothing."],[2460,2565,"Who do you think will win?"],[2598,2652,"Go on."],[2673,2831,"Whatever happens, I'll take the blame."],[3357,3445,"Jesse!"],[3841,3891,"Sophie?"],[3978,4095,"What the fuck are you doing?"],[4554,4612,"You okay?"]],"49":[[54,200,"Jesse, they tried to kill me."],[254,316,"It's okay."],[500,600,"I shouldn't have let you go."],[625,688,"You okay?"],[788,842,"Alright."],[842,925,"I'll take care of this."],[1076,1155,"You have a problem,"],[1155,1230,"you come to me."],[1238,1334,"You don't drag her into this."],[1334,1459,"You're overreacting,"],[1459,1534,"baby."],[1539,1672,"We were just playing around."],[1672,1768,"You're just playing?"],[1768,1805,"Yeah."],[1805,1868,"Let's play."],[1868,1931,"How about that?"],[2193,2419,"Jesse, you're doing this to me"],[2419,2523,"for some slut."],[2548,2781,"Boss, you can't do this to your fiancée."],[2781,2898,"She's nothing."],[2898,3023,"Yes, when your relationship"],[3023,3119,"was falling apart,"],[3144,3353,"Karen begged you over and over"],[3353,3486,"and you still broke up with her."],[3490,3570,"Exactly."],[3586,3716,"And now you're ready to hurt Karen"],[3716,3820,"for some mistress?"],[3832,3928,"You jerk!"],[4008,4108,"Should we tell them the truth?"],[4170,4250,"Mistress?"],[4304,4391,"There was no mistress."],[4391,4483,"She was the one that was cheating."]],"50":[[29,70,"No."],[129,204,"You wouldn't."],[221,266,"Yeah."],[279,383,"You love me."],[429,613,"I stopped loving you a long time ago."],[633,813,"After all the lying, and the cheating,"],[813,913,"and the drug use."],[1005,1055,"No."],[1176,1242,"You're a horrible"],[1242,1284,"person"],[1284,1405,"disguised with a beautiful face."],[1405,1505,"And no one"],[1514,1614,"will ever love you."],[1651,1755,"OMG."],[1797,1926,"She was the cheater?"],[1926,2089,"What a bitch!"],[2089,2339,"We all thought Jesse was the liar."],[2352,2464,"Jesse..."],[2464,2519,"You, you,"],[2519,2652,"you know who my father is."],[2686,2819,"And you know what happens"],[2819,2894,"when you cross me."],[2894,2961,"Yeah, I do."],[2994,3073,"If he wants war"],[3073,3132,"I'll give him one."],[3215,3299,"Are you threatening"],[3299,3353,"me?"],[3374,3432,"I'm not threatening"],[3432,3486,"you, no."],[3516,3566,"I'm telling you"],[3566,3699,"don't fuck with people I care about."]],"51":[[533,663,"Any one of you that touched her,"],[696,792,"I better have your resignation"],[792,863,"on my desk tomorrow,"],[863,934,"or I swear to God"],[934,1017,"I'll bury every one of you."],[1067,1259,"Mr, Mr. Delancey, wait, please."],[1259,1397,"I can't lose this job!"],[1438,1505,"Wait!"],[2369,2456,"It's all my fault."],[2502,2548,"I shouldn't have"],[2548,2585,"dragged you"],[2585,2635,"into this."],[2660,2744,"Jesse."],[2890,2961,"I'm here."],[3078,3207,"Jesse, I love you."],[3249,3340,"Don't leave."],[3578,3657,"I love you too,"],[3716,3812,"but you're not safe with me."],[3899,3974,"You have to go."],[4700,4892,"George, we have to talk."],[4984,5071,"It's about your daughter."]],"52":[[1042,1121,"I trusted you!"],[1121,1313,"I trusted you with my only daughter!"],[1334,1530,"Dad, why are you here?"],[1651,1718,"Sweetheart,"],[1931,2006,"you're awake."],[2118,2273,"You scared me to death!"],[2327,2423,"It was an accident."],[2435,2540,"Jesse wasn't even there."],[2560,2677,"Do not defend him!"],[2677,2886,"You are coming home with me."],[2927,3048,"I'm not leaving."],[3303,3399,"I start school soon."],[3420,3516,"It's closer to here."],[3532,3707,"I will drive you."],[3762,3916,"I'm not going back."],[3995,4254,"Sophie, go with your father."],[4416,4512,"Do you want me to leave?"]],"53":[[175,250,"Yes."],[279,437,"You're exhausting,"],[437,508,"and a distraction"],[508,579,"and I'm done"],[579,684,"babysitting children."],[684,859,"Do not talk to her like that."],[950,1021,"You mean that?"],[1230,1338,"You'd be better off at home."],[1418,1497,"And I have to work."],[1680,1726,"Come on."],[1768,1889,"Come on, we are leaving."],[1976,2043,"Dad, I..."],[2056,2152,"Just wait in the car."],[2152,2318,"I have to pack my stuff really quick."],[2339,2410,"And, uh..."],[2439,2510,"Say goodbye"],[2660,2756,"to Uncle Jesse."],[3465,3570,"So you're really doing this?"],[3611,3666,"Men like me"],[3666,3787,"shouldn't be with girls like you."],[3791,3858,"So that's it?"],[3878,3962,"But what about our deal?"],[3962,4074,"You said that after I-"],[4074,4300,"I was just stalling"],[4300,4416,"to get you off my back."],[4600,4738,"You're such a coward,"],[4738,4829,"Jesse Delancey."]],"54":[[437,608,"Thank you, Uncle Jesse,"],[638,759,"for your hospitality."],[792,867,"I don't think we're gonna"],[867,959,"see each other again."],[1051,1276,"I tried so hard to make things work."],[1330,1509,"But every time I make progress,"],[1509,1701,"you just recoil back into your shell"],[1701,1843,"like a scared little boy."],[1947,2156,"I was willing to die on this hill for us,"],[2156,2277,"but I can't be brave"],[2277,2398,"for the both of us anymore."],[2615,2698,"I hope one day"],[2698,2861,"you find a girl worth fighting for."],[3078,3153,"Goodbye, Jesse."],[3591,3724,"I'm in love with you, Jesse."],[4533,4646,"Jesse, I love you."],[4704,4783,"Don't leave."],[4967,5071,"I love you too, Sophie."]],"55":[[3078,3165,"Hey, Dad."],[3207,3395,"I decided to go to China"],[3395,3490,"and take a gap year."],[3528,3657,"Sweetheart, did you say China?"],[3691,3824,"Is everything okay, sweetheart?"],[3858,4004,"Yeah, I'm fine, Dad."],[4062,4220,"I just need a change of scenery."],[4220,4287,"And if I can help"],[4287,4404,"some people along the way,"],[4454,4542,"even just one person,"],[4542,4633,"I'll be happy."],[4721,4817,"Okay, sweetheart."],[4863,4963,"I support you."],[5005,5080,"Thanks, Dad."]],"56":[[262,321,"George."],[346,412,"What are you doing here?"],[412,462,"I just came here"],[462,613,"to talk to you about Sophie."],[717,775,"Something's off"],[775,834,"with her."],[880,992,"Did Sophie tell George?"],[1084,1205,"Maybe I should just come clean."],[1251,1413,"Listen, I'm sorry that I kicked her"],[1413,1472,"out of the house."],[1472,1543,"Don't worry about that."],[1543,1739,"I heard you two got into an argument."],[1797,1901,"She'll come around."],[1935,2039,"I don't think that's it."],[2223,2364,"Look, I haven't been a good father."],[2364,2652,"I'm always late and always working."],[2686,2811,"Getting remarried."],[2848,2986,"Look, I have some issues."],[2986,3182,"But, but I love my daughter"],[3182,3274,"with all my heart."],[3411,3578,"I just know there's something else."],[3641,3778,"Either somebody broke up with her"],[3778,3883,"or somebody cheated on her,"],[3883,4004,"because she's moving to China."],[4141,4225,"She's what?"]],"57":[[4,79,"Calm down."],[79,208,"Your reaction's bigger than mine."],[208,367,"She's only going there for a year."],[387,479,"She wants to teach English"],[479,654,"to young kids in rural Yunnan."],[675,713,"You're just gonna"],[713,800,"let your 21-year-old"],[800,838,"daughter"],[838,913,"go to China?"],[984,1101,"George, what the fuck?"],[1126,1255,"She doesn't speak the language."],[1255,1409,"We don't know anybody over there."],[1409,1497,"What if something happens to her?"],[1497,1572,"What if she gets killed,"],[1572,1668,"she ends up in a ditch?"],[1689,1830,"Jesse, she's gonna be fine."],[1830,1981,"She's joining a group out there."],[1981,2072,"I came here because I thought"],[2072,2173,"you would know something."],[2364,2419,"You, you don't,"],[2439,2585,"you don't think she's pregnant, do you?"],[2648,2798,"Did she mention anything about..."],[2861,2965,"about a boyfriend?"],[3115,3186,"George, the thing is-"],[3186,3345,"Why, the hell would you know anyway?"],[3374,3490,"You're my best friend."],[3524,3557,"You practically"],[3557,3670,"watched her grow up."],[3670,3812,"Why would she tell you anything?"],[3845,4008,"I guess I just need to be patient and"],[4037,4187,"let her tell me when she's ready."],[4262,4316,"Anyway."],[4383,4425,"All right, well,"],[4425,4491,"I'll get out of your hair."],[4491,4642,"I know you're a busy guy."],[4696,4817,"Want to go golfing this weekend?"],[4900,4942,"Yeah."],[4954,5017,"Yeah."],[5092,5176,"When's her flight?"],[5221,5296,"She already left."],[5296,5367,"I took her to the airport"],[5367,5438,"about an hour ago."],[5618,5684,"Excuse me."]],"58":[[125,183,"Sorry."],[729,921,"I was willing to die on this hill for us,"],[971,1084,"but I can't be brave"],[1084,1209,"for the both of us anymore."],[1276,1430,"I hope one day you find a girl"],[1430,1526,"worth fighting for."],[1597,1772,"You are worth fighting for, Sophie."],[2239,2285,"Fuck!"],[2464,2552,"Breaking news."],[2552,2836,"Flight MT878 from LAX to Beijing"],[2836,3028,"has crashed shortly after a take-off."],[3028,3199,"The entire LAX airport"],[3199,3299,"has shut down."],[3332,3507,"Emergency services are on site."],[3507,3749,"287 passengers are on board."],[3774,4004,"No survivors are confirmed so far."],[4154,4262,"That's Sophie's flight."]],"59":[[0,175,"This is a live report from Los Angeles"],[175,279,"International Airport,"],[283,446,"where chaos has erupted following"],[446,575,"an unexpected incident-"],[583,633,"I'm sorry, sir."],[667,742,"No one's getting into"],[742,829,"the airport tonight."],[829,975,"LAX is shut down."],[975,1059,"My girlfriend's on that flight."],[1059,1155,"I gotta see if she's okay."],[1155,1359,"Sir, like I said,"],[1359,1418,"no one's"],[1418,1488,"getting in there."],[1514,1584,"Now you can wait here"],[1584,1672,"with everyone else."],[1714,1822,"And we'll have some information"],[1822,1881,"for you soon."],[2414,2485,"If I didn't push her away,"],[2485,2615,"she wouldn’t have got on that flight."],[4783,4838,"Jesse?"]],"60":[[1801,1889,"I thought I lost you."],[2052,2152,"I thought you were on that flight."],[2214,2327,"That wasn't my flight."],[2327,2431,"My flight's to Hong Kong,"],[2431,2548,"but it got cancelled."],[2656,2731,"Thank God."],[2819,2902,"I'm still leaving"],[2902,2969,"Jesse."],[3065,3153,"I'm tired of"],[3153,3257,"playing these games with you."],[3257,3365,"Okay? It's exhausting."],[3449,3536,"It was good to see you."],[3803,3883,"You're worth fighting for."],[3937,3991,"What?"]],"61":[[25,83,"The night you left,"],[83,196,"you told me"],[196,279,"you hoped that one day"],[279,392,"I'd find somebody worth fighting for,"],[392,500,"but I have."],[654,734,"It's you."],[763,821,"Alright? I wanna-"],[821,925,"just give me one more chance"],[925,1005,"and I will prove to you"],[1005,1084,"that I'm done"],[1084,1117,"running."],[1117,1209,"I'm done running away"],[1209,1292,"from my feelings."],[1347,1488,"I'm ready to sit on this mountain for us"],[1488,1572,"and die on this mountain"],[1572,1651,"for both of us."],[1664,1755,"And if the sky falls,"],[1755,1897,"I'll be the man to hold it up for you."],[2043,2177,"Just give me one more chance."],[2277,2394,"But what about my dad?"],[2394,2494,"You said he'll kill you."],[2515,2565,"I'll,"],[2644,2740,"get him not to."],[2848,2952,"And what about waiting"],[2952,3065,"until after college?"],[3065,3244,"I'm only young once."],[3244,3328,"You're really wasting"],[3328,3411,"my years here, Jesse."],[3457,3524,"Anytime."],[3586,3678,"Whatever you want."],[3707,3799,"Whenever you want."],[3945,4062,"Then what are you waiting for?"],[4062,4149,"Take me home."]],"62":[[266,371,"Oh my God."],[392,571,"I'm finally gonna lose my virginity"],[571,696,"to the man I love."],[1405,1463,"Can I join you?"],[3428,3549,"Does that feel good?"],[3549,3641,"Yes."],[3732,3866,"I'll make you feel even better."],[5292,5367,"Hurry up."],[5501,5580,"I'm not gonna hurry."],[5634,5730,"It's your first time."],[5830,5980,"I'm gonna get you as wet as possible"],[5980,6064,"so it doesn't hurt."],[8516,8700,"Finally, I have you all to myself, Sophie."]],"63":[[596,809,"You know, I can't believe this is real."],[863,963,"You half naked"],[963,1113,"in the kitchen cooking breakfast?"],[1159,1326,"I think I've had dreams about this."],[1551,1668,"Yeah, I feel the same way too."],[1772,1847,"How can a"],[1964,2064,"middle aged man,"],[2064,2189,"a divorced man like me"],[2189,2273,"get a girl like you?"],[2273,2364,"I don't deserve you."],[2398,2560,"You're not old, okay?"],[2560,2686,"Forties are a man's best year."],[2711,2765,"Oh yeah?"],[2844,2952,"Well, I better make breakfast for you"],[2952,3007,"every morning"],[3007,3132,"because I'm gonna die"],[3132,3282,"way before you do."],[3299,3357,"I don't know who's gonna"],[3357,3440,"take care of you then."],[3478,3595,"That's why you need to quit smoking."],[3636,3762,"And then I'll start smoking"],[3762,3887,"and then we can die at the same age."],[4020,4120,"Eat your breakfast."],[4149,4208,"As soon as you're done,"],[4208,4295,"I gotta drop you off at home."],[4346,4446,"Why, I can't stay?"],[4446,4546,"I have something to do today."],[4562,4658,"It's pretty important, so..."],[4904,4971,"I called your dad."],[4971,5034,"I came clean."]],"64":[[20,87,"You what?"],[87,266,"Jesse, you did not."],[296,387,"I'm a man, Sophie."],[387,442,"A man has to do"],[442,533,"what a man has to do."],[600,696,"I have to take responsibility"],[696,788,"for what I did last night."],[788,838,"Especially because"],[838,921,"you're George's daughter."],[921,1005,"I don't want you to be here"],[1005,1067,"when he gets here."],[1067,1146,"He's coming at noon."],[1222,1322,"It might get violent."],[1351,1514,"Jesse, I can't go."],[1514,1584,"Are you crazy?"],[1584,1655,"You said it yourself."],[1655,1776,"He will shoot you dead."],[1776,1964,"Like graveyard dead."],[2010,2097,"He's not gonna shoot me."],[2114,2227,"He might punch me in the face,"],[2227,2327,"but he's not gonna shoot me."],[2731,2861,"You motherfucker!"],[2861,2986,"I know your ass is in here!"],[2986,3103,"Get your ass out!"],[3148,3290,"Well, looks like it's too late"],[3290,3353,"for me to go."],[3353,3436,"We're in this together."]],"65":[[54,246,"I had a bad feeling, you motherfucker."],[246,442,"I am gonna fucking kill you."],[475,550,"Sophie."],[550,696,"Sophie, get out of the way."],[713,880,"Sophie, go to your bedroom."],[880,950,"Let me talk to your dad."],[955,1109,"That is my line."],[1109,1226,"You can't tell her that."],[1292,1534,"Sophie, go to your room."],[1572,1680,"Daddy, you can't kill him."],[1680,1826,"Oh, I'm gonna kill him, alright."],[1826,1981,"It's not his fault, okay?"],[1981,2106,"I chased Jesse first."],[2106,2264,"You were just a dumb kid."],[2264,2456,"And you, you ought to know better."],[2473,2569,"You're twice her age."],[2569,2786,"How could you do that to my child?"],[2819,3115,"Daddy, your new wife is literally 30."],[3148,3244,"How can you judge us?"],[3244,3349,"That is different."],[3349,3495,"He’s not right for you!"],[3532,3657,"You're 21 years old."],[3657,3824,"You have your whole life in front of you."],[3837,3983,"Why would you want to be with somebody"],[3983,4120,"that's twice your age?"],[4137,4233,"I love him."]],"66":[[12,171,"I've loved him ever since I met him."],[171,275,"And he's the only person"],[275,362,"I've ever loved."],[362,508,"And I've spent a decade"],[508,600,"trying to outgrow it,"],[600,704,"but I just can't."],[921,1126,"My heart skips a beat"],[1126,1280,"every time I see him."],[1301,1463,"I don't know how to explain it"],[1463,1530,"or what it is,"],[1530,1710,"but I know he's the one."],[1768,1797,"Okay?"],[1797,1906,"He's always been the one."],[2010,2102,"So if you're gonna shoot him,"],[2102,2206,"you have to shoot me, too."],[2902,3007,"You're gonna marry my daughter?"],[3111,3174,"What?"],[3211,3269,"Yes."],[3336,3511,"Yes, I would love to."],[3511,3586,"With your permission."],[3586,3653,"Of course!"],[3716,3807,"If you break her heart,"],[3849,3945,"I'm gonna kill you."],[4054,4175,"If you cheat on her,"],[4175,4325,"I'm gonna chop your dick off"],[4325,4521,"and slice it into fucking pieces."]],"67":[[33,145,"That won't be necessary."],[145,300,"I think the world of your daughter."],[300,429,"All I want for her is to make sure"],[429,646,"that she feels loved and happy."],[742,796,"Alright."],[1167,1280,"That's the deal then."],[1343,1443,"Don't break it."],[1931,1985,"Oh my God!"],[1985,2052,"Jesse."],[2093,2164,"Dad!"],[2202,2452,"As my daughter, you have my blessing."],[2535,2623,"As for you..."],[2644,2844,"He's a man he understands."],[2927,2990,"It's alright."],[3032,3144,"I probably deserve that."],[3249,3361,"Send me a bill for the wedding."],[3449,3628,"Until then, don't talk to me."],[4295,4537,"Sophie, I love you."],[4612,4700,"I love you more."]],"68":[[229,508,"Finally, after a decade of waiting,"],[508,725,"I landed the man of my dreams."],[725,800,"We got married"],[800,946,"right after I graduated college."],[946,1151,"I couldn't wait to be Mrs. Delancey."],[1151,1288,"As for my dad,"],[1288,1380,"I cannot believe"],[1380,1497,"I'm getting a baby brother."],[1518,1755,"Jeez, Dad, you're like almost 50."],[1789,2018,"Well, ladies, moral of the story is..."],[2018,2097,"you shouldn't give up"],[2097,2202,"on finding real love—"],[2202,2264,"not the kind"],[2264,2419,"that fades or gets replaced,"],[2419,2590,"but the kind that stays with you."],[2623,2690,"quietly,"],[2690,2811,"even through the years."],[2852,2969,"Because when it's real,"],[2969,3107,"it has a way of finding its way"],[3107,3174,"back to you."],[3215,3386,"Love like that doesn't disappear."],[3386,3470,"It just waits"],[3524,3607,"for the right time."],[3949,4041,"You're not getting away"],[4041,4141,"from me, Jesse."],[4158,4287,"And I'm not gonna lose you"],[4287,4562,"to some dumb blonde little bitch."],[4633,4854,"Just you wait."]]}