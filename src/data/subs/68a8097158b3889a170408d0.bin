company."],[1722,1810,"Don't take it away."],[1843,1931,"It's all I've got."],[1964,2173,"Please, let me go!"],[2235,2352,"You brought this on yourself."],[2419,2565,"I wouldn't worry about your company."],[2627,2794,"It won't matter where you're going."],[2865,3086,"You're going to rot in prison"],[3103,3232,"and you'll never hurt another"],[3249,3445,"powerless girl again."],[3503,3607,"I can't go to prison."],[3628,3732,"Don't send me to prison."],[3770,3933,"I'm 68 years old!"],[3941,4095,"I'll die in there!"],[4337,4379,"Lucy!"],[4441,4496,"What's wrong?"],[4550,4600,"I'm okay."],[4600,4775,"I just need to go home."],[4833,4904,"To see Mama."],[4967,5071,"I'll take you to Mama right now."],[5317,5363,"Lucy?"],[5417,5476,"Lucy!"],[5547,5588,"Hunter,"],[5647,5751,"call an ambulance!"]],"43":[[955,1034,"Lucy!"],[1051,1092,"Mama?"],[1284,1372,"Are you okay?"],[1451,1497,"Are you hurt?"],[1497,1597,"Why are you in the hospital?"],[1664,1747,"Is it because of me?"],[1818,1910,"I'm fine."],[1951,2014,"You being back"],[2014,2139,"is all that matters, Lucy."],[2339,2464,"They hit you, didn't they?"],[2594,2706,"Did that bastard-"],[2706,2898,"No, Taylor saved me."],[2898,3023,"She got to me just in time"],[3023,3207,"and she punished Mr. Brown,"],[3207,3349,"good and hard."],[3645,3716,"Where is she?"],[4208,4304,"You're both awake."],[4567,4629,"Taylor."],[4717,4788,"Oh."]],"44":[[91,204,"Oh, let me see you."],[221,275,"Oh,"],[421,529,"you got taller."],[550,692,"New clothes, too."],[763,855,"You're beautiful."],[925,980,"Thanks, Mama."],[1071,1172,"I've missed you and Lucy"],[1172,1267,"something awful."],[1305,1405,"Oh, I haven't had a"],[1405,1543,"good night's sleep in years."],[1643,1776,"Wondering if my girl's hungry,"],[1805,1968,"if she has a place to stay"],[1968,2056,"when it rains."],[2081,2264,"It's been ten years."],[2523,2681,"Now I can finally rest."],[2711,2852,"Taylor's a superstar now."],[2882,3098,"She's the CEO of TLP Biotech."],[3115,3165,"Really?"],[3286,3457,"My daughter's the boss?"],[3570,3628,"More than that."],[3691,3770,"My company's made me"],[3770,3912,"the richest woman in the world."],[3966,4158,"I worked day and night all these years"],[4158,4229,"so I could come back"],[4229,4325,"and get you and Lucy"],[4325,4454,"out of the shack and horrors"],[4454,4554,"and into a better life."],[4696,4750,"I did it."],[4821,4875,"Mama."],[4963,5009,"Lucy."],[5084,5242,"We never have to be apart again."],[6489,6527,"Come on,"],[6748,6835,"let's get you changed."],[6886,7032,"It's time for a new life to begin."]],"45":[[1739,1906,"Taylor, isn't this a bit much?"],[1972,2127,"I feel a little weird"],[2152,2268,"dressed up so fancy."],[2281,2448,"It must have cost a fortune."],[2460,2610,"Relax, I can afford it."],[2660,2761,"And it's nothing compared to"],[2761,2869,"what I have waiting for you."],[3824,3928,"Well, don't just stand there."],[3953,4024,"You've got to get in"],[4024,4133,"if you're gonna see our new house."],[4166,4262,"Oh, Lucy,"],[4287,4408,"there's a surprise in the back seat,"],[4433,4500,"just for you."]],"46":[[487,588,"It's my acceptance letter."],[625,684,"I got in!"],[771,871,"I went back to the old house"],[871,925,"to get it."],[955,1088,"I knew you had it in you."],[1105,1163,"Mom, I'm going to"],[1163,1292,"Rhode Island's School of Design!"],[1326,1472,"That's wonderful."],[1497,1559,"It's like a dream."],[1609,1705,"When they sold me to that creep,"],[1705,1835,"I thought my life was over."],[1839,1968,"That's behind us now, Lucy."],[1993,2122,"I've got your tuition covered."],[2143,2289,"And I even started a scholarship"],[2289,2348,"in your name"],[2348,2444,"for poor kids like us"],[2444,2556,"who didn't have a chance."],[2581,2656,"You did that,"],[2719,2769,"for me?"],[2907,3028,"But what about Dad and Brody?"],[3028,3119,"What if they catch us?"],[3891,3974,"Step aside."],[4045,4149,"Who the hell are you?"],[4220,4337,"This ain't no drive-thru."],[4350,4471,"You can't just storm in the house"],[4471,4592,"of the richest woman in the world."],[4637,4825,"And we can do whatever the hell"],[4859,4913,"that we want!"],[4913,5113,"Because we are her family!"]],"47":[[20,208,"I'm Taylor Hicks's father!"],[258,312,"That's funny."],[371,450,"Last time we checked,"],[496,588,"the lady of the house's name"],[588,638,"is Marlow."],[900,1055,"Yeah well, fuck you! - Fuck you!"],[1455,1543,"Taylor!"],[1851,2056,"Taylor, damn, sweetheart."],[2106,2239,"This place is a castle."],[2285,2419,"What room do you have picked out"],[2419,2556,"for your dear old daddy?"],[2631,2786,"There's no room for either of you."],[2827,2994,"We're done, Waylon."],[2994,3115,"You're both dead to me."],[3194,3236,"You think"],[3236,3386,"you can cut off your own family."],[3440,3607,"Throw out your own father and brother."],[3682,3908,"We are gonna see you in court."],[3941,4112,"You fucking bitch!"]],"48":[[8,79,"Peggy Sue,"],[91,179,"say something!"],[221,379,"Even if you hate my guts,"],[412,558,"in the eyes of the Lord,"],[596,746,"I'm still your husband!"],[763,909,"And Brody's your son."],[980,1096,"And that brat, Taylor,"],[1126,1251,"cost him his job."],[1305,1409,"And because of her,"],[1480,1572,"his girlfriend,"],[1572,1676,"the mayor's daughter,"],[1676,1735,"dumped him."],[1789,2106,"Our poor boy ain't got nothing left!"],[2189,2381,"Mama, please."],[2535,2635,"I'm your only son"],[2635,2752,"and you have to help me."],[2877,2932,"Drive."],[2961,3019,"Help me."],[3253,3319,"No! - No."],[3336,3382,"No!"],[3403,3457,"Mama!"],[3999,4129,"Remember their faces."],[4154,4254,"If they show up again,"],[4287,4358,"throw them out."],[4371,4429,"Yes, ma'am."],[4892,4921,"You."],[4921,4950,"Hold on, hold on."],[4950,5021,"You'll never - Hold on, hold on."],[5021,5092,"get rid of us."],[5092,5217,"You hear me, Taylor?"],[5242,5305,"Never!"]],"49":[[492,550,"Let's go."],[575,671,"On to the next stop."],[775,846,"But Taylor,"],[880,938,"you've already spent"],[938,1063,"a hundred grand today!"],[1063,1155,"Lucy's right,"],[1176,1297,"I don't need all this."],[1313,1413,"Just being with you,"],[1413,1551,"is the most important thing."],[1593,1735,"We're just getting started."],[1751,1947,"I've got ten years to make up for."],[2114,2181,"There they are!"],[2402,2464,"Ms. Marlow,"],[2506,2698,"is it true that your father"],[2698,2848,"is in critical condition"],[2890,3019,"and you refuse to pay"],[3019,3111,"his medical bills?"],[3132,3186,"You've been out"],[3186,3307,"spending a ton of money"],[3307,3415,"and your father is fighting"],[3415,3486,"for his life."],[3511,3636,"What kind of daughter are you?"],[3787,3937,"Your brother says that you"],[3958,4137,"gave your father a heart attack"],[4137,4291,"and you're leaving him to die?"],[4341,4383,"Wait,"],[4387,4496,"what did you just say?"]],"50":[[296,387,"Taylor Marlow,"],[408,521,"the world's richest woman,"],[521,617,"is being accused of"],[617,767,"abandoning her sick father"],[767,880,"and leaving him to deal with"],[880,1021,"a mountain of medical bills."],[1042,1230,"Her brother has filed a lawsuit"],[1230,1409,"seeking financial responsibility."],[1476,1655,"My boy's a damn shark."],[1726,1951,"faking a little hospital stay"],[1951,2068,"and boom,"],[2235,2360,"the whole world turns against"],[2360,2560,"that ungrateful bitch."],[2606,2736,"I can give you one more day."],[2831,3011,"Her stock price continues to tank,"],[3011,3161,"and she's gonna come begging"],[3186,3290,"for our forgiveness."],[4704,4863,"Hey there, sis."],[4938,5030,"How you holding up?"],[5067,5217,"Because it looks like the internet"],[5271,5409,"has got their pitchforks out."],[5455,5551,"What do you want, Brody?"]],"51":[[0,120,"You're still acting high and mighty?"],[158,216,"Well, here's the deal."],[246,479,"You wire me five billion dollars"],[525,604,"and me and Daddy"],[658,842,"disappear for good."],[875,1017,"From pimp to extortionist,"],[1017,1088,"huh, Brody?"],[1101,1247,"You best think twice