orry, Mr. Brown."],[6331,6389,"Because see,"],[6402,6548,"I will personally make sure"],[6556,6735,"that the banquet goes smoothly"],[6756,6840,"tomorrow night."],[6877,7036,"That's my boy, Brody."],[7052,7253,"Got promoted to sales manager."],[7290,7469,"You got your own fancy apartment,"],[7469,7603,"fancy girlfriend,"],[7620,7695,"and you're meeting"],[7695,7966,"the legendary CEO."],[8033,8170,"You're on a roll, son!"],[8179,8312,"That's great, Brody!"],[8370,8521,"Make sure you say thank you"],[8521,8658,"to the CEO when you meet him."],[8679,8746,"Things have really"],[8746,8854,"been looking up for us"],[8854,9063,"since TLP took over the Brown plant."],[9063,9146,"Things could have changed"],[9146,9288,"around here a long time ago"],[9288,9426,"if you hadn't let Taylor run off."],[9451,9559,"Did you really think"],[9559,9768,"that girl was gonna go to college?"],[9797,9864,"Come on!"],[9984,10160,"I heard she's out on the street corner"],[10189,10331,"selling herself."],[10356,10514,"Brody's the overachiever,"],[10539,10731,"and he's stuck with her as his sister."],[10794,10910,"That's not true!"],[10965,11140,"I bet Taylor's doing just fine,"],[11165,11265,"better than ever, even."],[11344,11394,"And seriously"],[11394,11478,"it's been ten years"],[11478,11615,"you're still trash talking her?"],[12345,12379,"Ah!"],[12504,12579,"There's plenty more"],[12579,12708,"where that came from."]],"6":[[62,175,"Oh, no!"],[191,304,"My Lucy!"],[354,546,"Whoa, whoa, whoa."],[554,667,"Daddy, daddy, daddy, daddy, daddy."],[692,842,"Calm down, okay?"],[842,946,"You kill her,"],[946,1021,"we don't have anyone else"],[1021,1138,"to give to Mr. Brown, all right?"],[1259,1368,"What's that supposed to mean?"],[1393,1514,"You two helped Taylor"],[1514,1643,"escape ten years ago,"],[1672,1801,"if I didn't offer someone"],[1801,1868,"to Mr. Brown,"],[1868,1985,"he'd have my head."],[2022,2227,"You ought to be grateful,"],[2227,2356,"he's not pedophile"],[2402,2515,"and he actually waited"],[2515,2648,"til you were of age."],[2648,2740,"Mr. Brown's men"],[2740,2882,"should be here any minute now."],[2907,3257,"And you are so lucky, Lucy."],[3257,3374,"You just hop into bed with him,"],[3428,3503,"you're set for life."],[3511,3574,"No!"],[3628,3695,"I'm supposed to hear back"],[3695,3745,"from the design schools"],[3745,3899,"I applied to, any day now!"],[3983,4095,"I'm not throwing my life away"],[4095,4245,"to sleep with some gross old man!"],[4304,4483,"Well okay, I'd say it's about time."],[4592,4654,"Come on in!"],[4796,4842,"That's her."],[4842,4979,"No, no, please!"],[5030,5075,"Please!"],[5113,5201,"Please, she's the only"],[5201,5309,"daughter I have left!"],[5330,5413,"Brody, please."],[5472,5572,"Take, take this necklace,"],[5605,5718,"give it to Jolene,"],[5743,5839,"your girlfriend!"],[5876,5960,"Take anything you want,"],[5960,6085,"but, but not my daughter,"],[6085,6256,"she's the last daughter I have."],[6289,6339,"Brody!"],[6356,6569,"Do not make this any harder than it is,"],[6573,6760,"and get this rusty piece of crap"],[6765,6856,"out of my face."],[6861,7027,"Jolene wouldn't want that crap!"],[7107,7269,"She's the mayor's daughter,"],[7294,7407,"for fuck's sake."],[7436,7536,"Pure class."],[7565,7645,"Fucking grab her!"],[7645,7691,"Grab her!"],[7707,7807,"No, no!"],[7862,7962,"No!"],[8012,8191,"Somebody help my daughter!"]],"7":[[0,158,"No! No! No!"],[225,316,"Let go now!"],[905,996,"No!"],[1030,1076,"No!"],[1109,1238,"Give me back my daughter,"],[1238,1363,"you bastards!"],[1409,1609,"Brody, I'll never forgive you!"],[1864,1918,"Mama!"],[1976,2068,"Find Taylor!"],[2102,2248,"She's the only one who can save me!"],[2264,2327,"Mom!"],[2335,2389,"No!"],[2448,2506,"Lucy!"],[3282,3420,"Do you know how bad"],[3424,3532,"you're making me look?"],[3557,3674,"You fucking cripple!"],[3928,3974,"Taylor!"],[4154,4262,"CEO Marlow,"],[4346,4446,"the mayor's office sent over"],[4446,4546,"a special invitation to you"],[4546,4667,"for the welcoming banquet tonight."],[4733,4829,"Did the personal shopper"],[4829,4925,"deliver the evening gowns"],[4925,5013,"for Mama and Lucy?"],[5034,5113,"I spoke with Grant,"],[5113,5205,"the hotel manager."],[5234,5342,"A wide selection arrived"],[5342,5492,"and is in the suite reserved for you."],[5547,5705,"I can't wait to see Mama and Lucy"],[5705,5809,"try on their new clothes."],[5885,6072,"I don't even know how tall Lucy is now,"],[6101,6206,"I just hope it fits."],[6289,6327,"Oh,"],[6327,6464,"and the supportive shoes for Mama"],[6464,6610,"so her leg doesn't hurt all night."],[6644,6706,"And next week,"],[6706,6785,"the world's best"],[6785,6931,"orthopedic surgeon is flying in."],[7019,7119,"Her leg can be fixed."],[7186,7236,"I just know it."],[7832,7878,"Taylor!"],[7899,7987,"Lucy's in trouble!"],[8016,8066,"Please,"],[8108,8237,"you need to save her! - Mama?"],[8324,8379,"Mama!"],[8395,8445,"Taylor!"],[8445,8521,"Give me that!"],[8616,8725,"Step on it, Hunter!"],[8846,8938,"I need bodyguards sent to"],[8938,9063,"the Hicks house immediately."],[9100,9217,"As many as you can get!"]],"8":[[437,517,"Let me go!"],[517,658,"I gotta get Lucy!"],[658,738,"Are you done"],[738,896,"running your damn mouth?"],[946,1067,"You keep screwing this up"],[1067,1159,"for Brody and me,"],[1159,1280,"and I swear to God,"],[1309,1451,"I will beat you so bad"],[1451,1622,"your own mama won't recognize you!"],[1622,1814,"Go ahead and beat me to death!"],[1814,1947,"I don't got anything left to"],[1947,2077,"live for anymore!"],[2085,2193,"I think I will!"],[2385,2481,"Maybe that way,"],[2494,2711,"you'll shut the hell up!"],[2715,2831,"Taylor!"],[2990,3048,"Ah!"],[3240,3299,"Taylor!"],[3324,3495,"You gotta save your little sister!"],[3520,3661,"That run away whore,"],[3737,3866,"she don't give a shit about"],[3866,3987,"her crippled mama!"],[4016,4141,"Taylor ain't coming back!"],[4208,4300,"She ain't coming,"],[4300,4446,"don't you understand?"],[4508,4612,"She's probably out there"],[4612,4771,"flashing those tits somewhere"],[4771,4892,"for cash!"],[4963,5096,"Ah, ah!"],[6172,6231,"Follow me."],[6560,6765,"You got a little fight left in ya."],[6810,6898,"We'll see how much"],[6898,6961,"you have - No!"],[6994,7219,"after I finish off that bum leg!"],[7240,7294,"No!"],[7303,7407,"Please!"],[7540,7691,"Get away from my Mama!"]],"9":[[496,588,"Search the house."],[658,767,"Oh, Taylor."],[838,909,"You're here."],[913,1021,"You're really here."],[1067,1159,"Mama, I'm sorry."],[1192,1309,"I'm so sorry I'm late."],[1309,1426,"Is it really you?"],[1518,1601,"It's me, mama."],[1647,1705,"I'm home."],[2427,2552,"Daddy did this to you?"],[2648,2698,"Yeah,"],[2744,2844,"he went out the back door"],[2882,3057,"when those fancy cars pulled up."],[3182,3336,"I'll make that bastard pay"],[3365,3445,"for hurting you."],[3482,3524,"Damn!"],[3624,3766,"Somebody's rich as sin."],[3766,3883,"Who is it, Daddy?"],[3883,4062,"The fuck I know who they are, Brody."],[4124,4258,"But they look like trouble."],[4358,4533,"I get these gambling debts paid off"],[4533,4688,"with that money I'm getting from Lucy,"],[4754,4859,"all this shit will be gone."],[5088,5125,"No."],[5159,5251,"We don't have time."],[5288,5467,"We, we have to go get Lucy."],[5530,5588,"They took her."],[5613,5701,"Who's they, Mama?"],[5701,5772,"What's going on?"],[5772,5872,"Where's Lucy?"]],"10":[[33,325,"Lucy was screaming and crying"],[325,563,"and I, I tried to stop him but,"],[646,779,"they sold..."],[804,1051,"they, they sold your baby sister!"],[1063,1217,"Just tell me who they sold her to."],[1280,1347,"It was..."],[1539,1597,"it was."],[1872,1931,"Mama?"],[1981,2039,"Mama!"],[2469,2556,"I need an ambulance"],[2569,2719,"at 101 Sycamore Lane."],[2765,2819,"It's my mother."],[2823,2923,"She's unconscious,"],[2952,3057,"please, hurry!"],[3082,3144,"Hunter!"],[3378,3553,"My brother took Lucy to be sold."],[3953,4158,"I just arranged to meet Brody Hicks"],[4195,4320,"to welcoming banqu