1739,"are you prepared"],[1747,1922,"to pay all medical expenses"],[1951,2160,"and five billion dollars"],[2193,2369,"for pain and suffering?"],[2456,2794,"I won't give them one penny."],[2865,3061,"Absolutely outrageous."],[3061,3148,"Did you hear that?"],[3257,3432,"So a multi-billionaire"],[3432,3570,"won't even spare a cent"],[3607,3778,"for her own dying daddy."],[3849,3970,"He looks pretty bad."],[3978,4066,"How can she just sit there,"],[4066,4133,"doing nothing?"],[4225,4291,"I'll tell you why."],[4429,4617,"Unfortunately, my sister Taylor"],[4667,4896,"is an ice-cold one-percenter"],[4896,4963,"who wouldn't even"],[4963,5150,"piss on her own family"],[5150,5226,"if they was on fire."],[5238,5330,"No, no, no, no, no."],[5330,5534,"She would walk right over our bodies"],[5534,5739,"in them fancy designer heels."]],"58":[[8,171,"Taylor is the most generous,"],[171,333,"and caring person I know."],[383,650,"My daughter is not a bad person!"],[959,1121,"The law says I owe him care"],[1134,1242,"because his sperm"],[1242,1368,"was used to help make me."],[1393,1551,"But my father never took care of me"],[1580,1705,"a day in my life."],[1735,1972,"I worked my ass off to get where I am."],[2085,2168,"And now I'm rich,"],[2223,2414,"but I did that in spite of him,"],[2439,2527,"not because of him."],[2673,2744,"I'd rather give"],[2769,2973,"every last cent that I own"],[2986,3136,"to complete strangers"],[3148,3311,"than give those two bastards"],[3324,3528,"a single penny."],[3570,3762,"Taylor, how about you drop the act"],[3803,3962,"and you dare accuse us"],[3962,4054,"of extorting you?"],[4104,4187,"How about some proof?"],[4225,4283,"Any proof?"],[4483,4533,"You want proof?"],[4629,4671,"Fine."],[4725,4863,"Let's all hear what Brody Hicks"],[4863,4942,"had to say"],[5009,5109,"right before this trial."],[5184,5238,"Shit!"],[5271,5430,"The bitch recorded the call."],[5609,5684,"Well, here's the deal,"],[5730,5926,"you wire me five billion dollars"],[5951,6035,"and me and daddy"],[6035,6185,"disappear for good."]],"59":[[16,112,"No, no, that is not,"],[171,291,"that is not what it sounds like."],[325,446,"The five billion dollars is very clearly"],[446,600,"for my daddy's broken heart."],[625,750,"So Brody Hicks,"],[838,921,"you confirmed that"],[921,1084,"the recording is true."],[1105,1255,"A heart transplant"],[1255,1443,"doesn't cost five billion."],[1501,1555,"Brody,"],[1605,1780,"how could you treat Taylor like this?"],[1972,2060,"Where's the patient?"],[2548,2610,"Right there."],[2648,2761,"And make sure you give him a"],[2802,3003,"thorough exam."],[3853,3966,"Slight irregular heartbeat."],[4033,4137,"Did you hear all that?"],[4183,4325,"So a licensed"],[4333,4475,"medical professional"],[4475,4600,"agrees that my father"],[4621,4717,"has a failing heart,"],[4717,4909,"which means that that selfish bitch"],[4984,5167,"of a sister owes us,"],[5192,5276,"Five billion dollars."],[5280,5363,"And frankly at this point,"],[5363,5572,"we are not accepting a penny less."],[5605,5689,"Whoa, slow down."],[5747,5926,"Stress, sleep deprivation, anxiety,"],[5926,6043,"all of these things can cause"],[6043,6126,"an irregular heartbeat."],[6126,6235,"It doesn't necessarily mean that"],[6235,6339,"he's having a heart attack."],[6398,6477,"So,"],[6577,6694,"it isn't a heart attack?"],[6735,6852,"It doesn't appear to be,"],[6852,6969,"if it were, we would know by now."]],"60":[[0,133,"So the dad really is faking it?"],[191,358,"They were trying to scam the courts!"],[375,492,"Five billion?"],[492,579,"That's outrageous."],[608,725,"No, no, no, no."],[725,913,"She, she's clearly lying"],[913,1067,"because Taylor paid her off!"],[1780,1906,"Who checks a bad ticker"],[1906,2027,"with just a quick,"],[2043,2135,"quickie, listen?"],[2173,2268,"No EKG?"],[2277,2389,"No blood work?"],[2406,2448,"What?"],[2506,2702,"This is a travesty, I tell you!"],[2765,3065,"You wicked bitch!"],[3136,3261,"You have everything."],[3336,3478,"You're gonna burn in hell!"],[3507,3691,"You're the one who'll burn in hell."]],"61":[[0,100,"What the hell is that supposed to mean?"],[100,266,"I am your eldest son!"],[316,383,"You're really going to side with"],[383,467,"Taylor over me?"],[521,596,"Yes, Brody,"],[638,767,"you were my firstborn."],[813,909,"I gave you too much love,"],[909,1026,"I ruined you."],[1084,1251,"Made you greedy and cruel."],[1393,1493,"But, but Taylor,"],[1493,1634,"she never did anything wrong."],[1664,1785,"And yet, you beat her down"],[1785,1901,"again and again,"],[1960,2081,"just because she was"],[2081,2198,"smarter than you."],[2318,2448,"If it wasn't for Taylor,"],[2515,2619,"me and Mama would have been"],[2619,2752,"crushed by the two of you."],[2815,2902,"Neither you or daddy"],[2902,3015,"deserve to be called family."],[3132,3257,"Brody, I, I side with Taylor."],[3411,3465,"Mama."],[3561,3616,"Lucy."],[3878,4079,"You useless bitch!"],[4129,4291,"You wanna talk back to me?"],[4320,4471,"I swear to God,"],[4500,4688,"I'll beat the living hell out of you!"],[4721,4875,"You won't lay a single hand"],[4892,5013,"on my Mama again!"],[5196,5284,"Just a minute,"],[5317,5409,"weren't you just having"],[5409,5492,"a heart attack?"],[5597,5751,"Why are you standing there?"]],"62":[[83,216,"Ms. Marlow is telling the truth."],[254,383,"Waylon Hicks is faking it!"],[500,542,"Your Honor,"],[667,800,"perhaps it's time for a ruling?"],[1080,1276,"Has the jury reached a decision?"],[1534,1609,"Your Honor,"],[1676,1768,"Waylon Hicks"],[1814,2022,"has failed his duties as a father."],[2064,2139,"He has faked"],[2139,2243,"a medical condition here"],[2243,2335,"in this courtroom."],[2448,2644,"This is malicious litigation."],[2806,2907,"We unanimously vote"],[2994,3194,"to reject his claim for support."],[3274,3353,"No!"],[3974,4045,"The claim"],[4070,4258,"brought by Mr. Waylon Hicks"],[4258,4371,"is hereby dismissed."],[4416,4500,"And furthermore,"],[4567,4704,"both Mr. Waylon Hicks"],[4704,4846,"and Mr. Brody Hicks"],[4904,4963,"are remanded"],[4963,5105,"to the District Attorney"],[5117,5276,"under suspicion of fraud."],[5509,5647,"This case is closed."],[6773,6911,"I won, Brody."],[7107,7211,"Here's the evidence of your"],[7211,7407,"human trafficking and abuse."],[7469,7599,"I'm sure the District Attorney"],[7599,7732,"will find it enough to arrest you."],[7832,7916,"Garbage like you"],[7932,8158,"deserves to rot in prison."],[8516,8637,"Oh Taylor,"],[8858,9184,"I'll fucking kill you, bitch!"]],"63":[[308,346,"Taylor!"],[396,446,"Taylor!"],[471,521,"Taylor!"],[633,771,"Don't press charges."],[788,875,"I can't go to jail."],[875,942,"You can't put"],[942,1113,"your dear old daddy in jail."],[1163,1317,"It's up to the prosecutors now,"],[1317,1384,"Waylon."],[1451,1589,"You belong in prison."],[1689,1780,"This is goodbye,"],[1981,2031,"forever."],[2227,2264,"No."],[2277,2352,"No, Taylor!"],[2406,2464,"Taylor!"],[2535,2565,"No."],[2610,2669,"No!"],[2719,2773,"Taylor!"],[2840,2898,"No!"],[2957,3136,"I had a shot at the good life."],[3507,3670,"It's your fault, Brody!"],[3707,4054,"You shouldn't have sued Taylor!"],[4287,4346,"Daddy?"],[4529,4587,"Daddy!"],[4721,4850,"Fuck you, Taylor!"]],"64":[[329,412,"Taylor Marlow,"],[412,638,"CEO of TLP Biotech"],[675,817,"and one of the wealthiest people"],[817,880,"in the world"],[900,1017,"has just announced that"],[1017,1180,"her new foundation will be building"],[1209,1334,"100 public schools"],[1359,1447,"in our nation's"],[1447,1564,"poorest communities."],[1589,1685,"CEO Marlow,"],[1710,1805,"what inspired you"],[1805,1960,"to start building schools"],[1981,2198,"and to launch the scholarship fund?"],[2318,2444,"Because I know how it feels"],[2444,2531,"to grow up thinking"],[2531,2665,"that the world forgot about you."],[2748,2940,"Every child deserves a chance"],[2940,2998,"to learn,"],[3086,3165,"to dream,"],[3249,3382,"to fight for a future"],[3382,3520,"that isn't defined"],[3520,3632,"by where they came from."],[3712