{"1":[[350,417,"There are some dreams"],[417,517,"so impossible,"],[558,684,"you don't even dare imagine."],[888,1109,"This is one of those dreams."],[1284,1463,"Please, universe, please."],[2081,2239,"It is my pleasure to offer you"],[2239,2427,"a full ride scholarship to MIT."],[2485,2552,"Yee!"],[3182,3244,"I got in!"],[3290,3332,"Mama!"],[3361,3395,"Lucy!"],[3399,3524,"I got into MIT!"],[3561,3762,"OMG, Taylor, that's awesome!"],[3891,4033,"Sweetie, I'm so proud of you."],[4054,4200,"You got into college."],[4287,4421,"I didn't even go to high school."],[4491,4604,"Don't put yourself down, Mama."],[4679,4763,"Daddy got you knocked up,"],[4763,4892,"and forced you to quit school."],[4925,5046,"Your daddy's old fashioned."],[5096,5146,"He don't think"],[5146,5280,"women need an education."],[5309,5430,"Well, I'm gonna prove him wrong."],[5543,5693,"I'll pave the way for you, little sis."],[5776,5897,"Peggy Sue!"],[6093,6147,"Mama,"],[6181,6260,"what're you doing?"],[6268,6327,"You have to go."],[6360,6402,"Now!"],[6406,6506,"Before your father and brother"],[6506,6548,"come home."],[6548,6664,"What, why?"],[6690,6777,"I heard them talking,"],[6827,7023,"they want to marry you off for money."],[7027,7165,"No, they can't do that, right?"],[7219,7361,"I'm still in high school!"],[7390,7561,"Your brother said Deacon Brown"],[7561,7649,"will give him enough money"],[7649,7749,"to get a business started."],[7770,7924,"Your daddy was all for it."],[7962,8062,"You have to go now"],[8074,8174,"and never look back."],[8183,8383,"You have a future."],[8400,8575,"Don't let them take that from you."],[9004,9200,"Peggy Sue, you crippled bitch!"],[9263,9417,"This girl's a cash cow"],[9451,9605,"and you're trying to help her escape!"],[9809,9922,"Where the hell"],[9951,10114,"do you think you're going?"],[10160,10206,"Oh!"],[10214,10281,"Mama!"],[10460,10673,"You uppity little shit,"],[10673,10898,"with your head always in the books."],[10919,11031,"That ends now."],[11040,11140,"I got this, Daddy."],[11152,11252,"Wise up, Taylor,"],[11315,11386,"Deacon Brown"],[11386,11569,"is the richest man in town."],[11574,11765,"He's uh, taken a liking to you."],[11824,11928,"Soon you're gonna have a real"],[11928,12016,"pampered life,"],[12016,12153,"lots of nice things."],[12157,12208,"No!"],[12258,12391,"I got into MIT!"],[12458,12575,"I'm not some toy"],[12575,12796,"you can sell off to a rich pervert."],[12825,13008,"Your body's worth ten times"],[13008,13321,"as much money as a useless diploma."],[13417,13709,"MIT can kiss my ass!"],[13709,13784,"That's mine!"],[13834,13897,"No!"]],"2":[[1034,1130,"Let that be a lesson"],[1130,1347,"to all you stupid bitches."],[1422,1630,"I'm your flesh and blood."],[1685,1739,"You're supposed to"],[1739,1872,"want a better life for me!"],[1872,1939,"Clue in,"],[1964,2102,"Taylor, you're just a girl."],[2122,2185,"That's right."],[2264,2335,"Brody here"],[2335,2510,"is the real future of this family."],[2544,2694,"You need to learn your place."],[2761,3098,"Your job is to service the men."],[3294,3399,"Screw you both."],[3482,3645,"You don't own me."],[4049,4233,"You can tear up my acceptance letter,"],[4287,4462,"but I'm still going to college!"],[4487,4667,"You ungrateful brat!"],[4813,4971,"I should have strangled you"],[5030,5213,"the day you were born!"],[5217,5255,"No!"],[5276,5321,"No!"],[5397,5534,"Waylon, you'll kill her!"],[5547,5647,"Taylor, please!"],[5655,5814,"Just tell Daddy you'll do what he says!"],[5826,5930,"You're not a father!"],[6001,6268,"You're a lazy, drunk, coward,"],[6302,6406,"and a parasite!"],[6727,6810,"Ah!"]],"3":[[45,108,"Ah!"],[496,713,"Mama's got you, baby girl."],[713,838,"You're bleeding a lot."],[900,1030,"Brody, call an ambulance!"],[1117,1230,"What the fuck, Daddy?"],[1238,1426,"Okay, you scare Taylor"],[1430,1514,"all you want,"],[1514,1689,"but you don't touch her fucking face,"],[1689,1760,"okay?"],[1772,1860,"Deacon Brown"],[1860,2006,"is paying money for the pretty smile."],[2177,2256,"Mama's hurt,"],[2289,2377,"do something!"],[2385,2444,"Come on, please."],[2444,2548,"I've been hit by a beer bottle"],[2548,2644,"plenty of times."],[2656,2831,"You bastard, Brody."],[2923,3169,"Taylor, you need to learn your place."],[3203,3311,"Cause Deacon Brown"],[3311,3424,"already bought you."],[3457,3541,"Listen, there's no"],[3541,3674,"shame in using your body"],[3674,3791,"to make a little bit extra dough."],[3791,3928,"And you play your cards, right?"],[3995,4145,"You could pocket a tiny little fortune"],[4145,4279,"by the time he's done with you."],[4354,4512,"Lock that mouthy bitch up."],[4537,4575,"Come here!"],[4587,4621,"No!"],[4642,4838,"Brody, let go of me, you asshole!"],[4842,4963,"Come here!"],[5509,5618,"Brody, you know what I"],[5618,5722,"freaking deserve?"],[5768,5964,"It's a new F-150,"],[6014,6072,"diesel!"],[6151,6281,"It'll come tomorrow, you'll have that"],[6281,6381,"and a whole lot more."],[6381,6464,"You know how much"],[6464,6564,"a chick's virginity is worth!"],[6564,6606,"Haha."],[6831,6902,"Yeah!"],[6940,7011,"Woo!"],[7144,7278,"If I stay here, I'm done for."],[7382,7524,"I can't give up."],[7674,7811,"I've gotta get out of this place."]],"4":[[0,58,"Mama?"],[79,246,"Come with me, baby."],[804,859,"I'm sorry."],[888,1055,"This is all I could scrape together."],[1222,1393,"I'll always be with you, Taylor."],[1459,1580,"Right here."],[1743,1864,"This is for college."],[1931,1968,"Quick,"],[1976,2022,"get in."],[2043,2206,"Before Daddy and Brody see us."],[2268,2331,"Come with me."],[2394,2456,"Both of you."],[2515,2731,"If you stay here, they'll kill you!"],[2761,2923,"I'm useless with this leg."],[2948,3107,"I'd just slow you down."],[3178,3278,"And if you take Lucy,"],[3315,3415,"your daddy will accuse you"],[3415,3511,"of kidnapping a minor"],[3511,3641,"and sic the law on ya."],[4099,4262,"You're an eagle, Taylor."],[4383,4617,"And eagles are meant to fly."],[4700,4921,"So spread your wings, baby girl."],[5