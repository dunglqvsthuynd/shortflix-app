[1847,1935,"Alex..."],[3228,3403,"Um, I'm sorry, Mr. Hill."],[3403,3486,"I shouldn't."],[3591,3678,"Who said you shouldn't"],[3678,3799,"have anything?"]],"36":[[3257,3424,"Grace, you're so fucking sexy."],[3616,3732,"Alex, I want you."],[3899,3970,"What do you want?"],[4095,4258,"I want you inside of me."],[4483,4550,"Good girl."],[5530,5676,"This is insane."],[5964,6097,"You drive me insane."],[6185,6297,"I can't get enough of you."]],"37":[[700,892,"I can't believe last night happened."],[963,1013,"I..."],[1084,1255,"I slept with my boss?"],[1317,1543,"Alex Hill, the richest man in the city?"],[1589,1626,"But..."],[1722,1856,"God, it felt so good."],[3078,3148,"Make sure you eat."],[3148,3303,"My mother's bringing Luna back soon."],[3649,3728,"This is your new phone."],[3728,3862,"Call me if you need anything."],[3912,3970,"Alex."],[5584,5643,"Good morning."],[5689,5789,"You must be Mrs. Hill."],[6097,6189,"My baby."],[6272,6439,"She's the birth mom of Luna."],[6594,6748,"Grace White?"],[6823,7007,"What the hell are you doing here?"],[7269,7340,"You know me?"]],"38":[[54,120,"You know me?"],[508,709,"Oh, did you miss me, baby?"],[709,750,"Yeah."],[800,1026,"You're the nanny Alex hired?"],[1176,1255,"That's right."],[1343,1514,"Here, I can take over."],[1559,1676,"Okay, let's go."],[1722,1822,"She has no idea."],[1872,2031,"This is just a coincidence."],[2064,2189,"But she can't stay here."],[2243,2381,"Alex can never know"],[2381,2519,"she's Luna's real mother."],[3015,3157,"Luna's down for a nap, but,"],[3224,3336,"I have coffees and pastries"],[3336,3424,"while you wait."],[4008,4108,"Oh dear."],[4358,4537,"Can't even carry a tray properly."],[4579,4733,"And you're supposed to be Luna's nanny."],[4796,5050,"Um, I can get you a new cup of coffee."],[5088,5167,"Don't bother."],[5209,5380,"I'm certain you'll just mess it up again."],[5601,5659,"Ma'am."],[5722,5847,"Something important."],[5885,6051,"I pulled this from the company files."],[6281,6523,"Oh my God."],[6577,6706,"You were in prison."],[6773,7119,"You disgusting, filthy criminal."],[7194,7353,"What, were you waiting for"],[7353,7586,"my poor little Luna to fall asleep"],[7586,7716,"so you could steal her away?"],[7716,7870,"Maybe sell her for cash?"],[7982,8183,"No, Ms. Hill, please just let me explain."]],"39":[[70,233,"No, Ms. Hill, please just let me explain."],[233,283,"Luke,"],[346,513,"get this dangerous woman"],[513,754,"out of Alex's house now."],[838,988,"Ms. White, come with me."],[1021,1084,"Mrs. Hill, please,"],[1084,1251,"I can take care of Luna."],[1284,1393,"She's already attached to me."],[1393,1505,"She trusts me."],[1505,1776,"You really think you deserve"],[1776,1926,"to be in this house?"],[1943,2018,"A criminal"],[2072,2218,"masquerading as a nanny?"],[2248,2469,"Luna is the daughter of a billionaire."],[2494,2598,"What makes you think"],[2598,2706,"someone like you"],[2752,2861,"is fit to touch her?"],[2936,3098,"Please, Ms. Hill, I..."],[3315,3403,"Are you deaf?"],[3432,3578,"I said get the hell out of here."],[3603,3699,"I don't ever want to see you"],[3699,3837,"in this house ever again!"],[3924,4012,"What the hell is going on here?"],[4149,4354,"Oh, Alex, perfect timing."],[4387,4508,"I just fired this criminal"],[4508,4633,"masquerading as a nanny."]],"40":[[129,275,"Oh, Alex, perfect timing."],[275,446,"I just fired this criminal"],[446,563,"masquerading as a nanny."],[771,821,"You okay?"],[1005,1051,"I'm fine."],[1159,1209,"You mind telling me"],[1209,1297,"what's going on here, Mom?"],[1372,1609,"I'm sorry, you're asking me that?"],[1651,1856,"How could you let someone like her"],[1856,1931,"around Luna?"],[1972,2052,"A convict."],[2122,2206,"A criminal."],[2281,2619,"Lowlives like these lie and steal."],[2686,2790,"And God knows what else."],[2827,2957,"She's probably just waiting"],[2957,3032,"to sell your kid"],[3032,3174,"the second you turn your back."],[3207,3324,"Someone's past doesn't determine"],[3324,3403,"who they are."],[3440,3595,"And she's not even a criminal."],[3670,3766,"And she's done more for Luna"],[3766,3887,"than anybody in this house."],[3953,4087,"So apologize to her now."],[4216,4391,"You seriously expect me"],[4391,4587,"to apologize to a prison rat?"],[4671,4704,"Ha."],[4733,4825,"Are you joking?"],[4842,4875,"I've never"],[4875,4971,"been more serious. - She's-"],[5046,5100,"And"],[5146,5242,"Grace isn't just a nanny."],[5518,5601,"She's also my girlfriend."]],"41":[[112,246,"How could this have happened?"],[262,446,"I've kept Grace's identity"],[446,571,"hidden all these years."],[571,775,"And yet, they still found each other?"],[800,850,"I'm sorry."],[850,942,"Your what?"],[971,1071,"Grace White."],[1134,1272,"You seriously think"],[1272,1518,"you are good enough for my son?"],[1572,1697,"Just breathing the same air"],[1697,1818,"as you makes me sick."],[1839,2002,"You should have just rotted in prison."],[2002,2072,"That's enough."],[2227,2302,"You don't get to determine"],[2302,2389,"who's worthy or not."],[2439,2489,"Alex,"],[2535,2690,"let me make myself clear."],[2719,2890,"Your future is in business"],[2911,2994,"and in power."],[3053,3207,"You will have a proper marriage"],[3207,3332,"and a real wife."],[3395,3632,"If you think I'm going to stand by"],[3632,3762,"while you make this woman"],[3795,3874,"Luna's mother?"],[3933,4045,"You're mistaken."]],"42":[[162,250,"I'm really sorry."],[287,400,"I didn't think she was going to act like that."],[517,692,"I mean, she's right."],[863,1063,"My past isn't exactly clean and"],[1130,1276,"someone like you shouldn't be"],[1276,1438,"marrying someone like me."],[1438,1568,"We, we shouldn't- - Grace."],[1676,1881,"I don't need some rich girl"],[1881,2006,"from some nice family."],[2006,2068,"I don't need that."],[2147,2227,"All I want is you."],[2298,2398,"You can't be replaced."],[2494,2631,"I thought I'd been abandoned"],[2631,2711,"by the world."],[2773,2877,"But here he is,"],[2915,3036,"standing in front of me."],[3123,3186,"Telling me"],[3215,3361,"I'm irreplaceable."],[3424,3536,"Luna's birthday is next week."],[3557,3661,"We're going to throw a party."],[3661,3732,"And"],[3791,3895,"when that day comes,"],[3983,4091,"I want everyone to know,"],[4158,4220,"you're mine."],[4575,4617,"Okay?"]],"43":[[1401,1530,"Ms. White,"],[1555,1751,"these suit you beautifully."],[1914,2002,"Thank you."],[2940,3165,"You look breathtaking."],[3478,3541,"Like an angel."],[4033,4099,"Mr. Hill,"],[4208,4400,"your conference call is waiting."],[4754,4863,"Take Luna to the banquet."],[4963,5038,"I'll meet you there."]],"44":[[1355,1451,"Okay, sweetheart."],[1451,1551,"It's your big day."],[1605,1705,"You're turning four."],[1851,1964,"Everyone here"],[2018,2122,"is here to see you."],[2156,2281,"So you don't have to be scared."],[2406,2485,"Excuse me, ma'am."],[2498,2627,"I see you're with Luna Hill."],[2640,2731,"Can you tell us your"],[2731,2836,"relationship with her?"],[3032,3144,"Oh, uh."],[3157,3224,"Oh-"],[3224,3286,"Don't bother."],[3286,3395,"She's just a nanny!"],[4366,4579,"Ladies and gentlemen,"],[4617,4742,"I would like to formally"],[4742,4929,"introduce to you Selina Madison,"],[4963,5150,"heiress of the Madison group"],[5150,5326,"and Alex's fiancée."]],"45":[[16,258,"Alex has a fiancée?"],[291,392,"As you all know,"],[392,542,"our family sits at the top"],[542,650,"of the wealth chain."],[679,775,"And only someone"],[775,1105,"as accomplished and refined as Selina"],[1142,1355,"is worthy of standing by my son."],[1472,1626,"And I have no doubt that"],[1626,1856,"she will be a wonderful mother"],[1856,1922,"to Luna."],[2448,2656,"Luna hates being held by strangers."],[2698,2777,"Where's Grace?"],[2861,2940,"She should have arrived."],[3520,3582,"No, I-"]],"46":[[100,162,"Where's Grace?"],[316,371,"Grace?"],[425,538,"Why would she be here?"],[558,709,"She's just a nanny, dear."],[750,867,"A party like this"],[892,984,"isn't really appropriate"],[984,1080,"for someone like her."],[1130,1301,"Mr. Hill, congratulations."],[1301,1488,"You and Selina make the perfect match."],[1509,1655,"We've overheard that you guys"],[1655,1722,"have known each other"],[1722,1810,"since childhood."],[1856,2006,"Have you guys been together ever since?"],[2035,2156,"Rumors of an engagement"],[2156,2306,"have been flying for months."],[2327,2469,"Can you tell when the wedding will be?"],[2531,2677,"I feel incredibly honored"],[2677,2819,"to be a part of this family."],[2836,3019,"Luna deserves the world and..."],[3082,3219,"um, I'm gonna love her"],[3219,3319,"like she's my own daughter."],[3445,3586,"Ms. Hill wanted me to remind you"],[3616,3753,"nannies don't belong"],[3753,3908,"at a billionaire's birthday party."],[3966,4058,"Please leave."],[5021,5096,"Look right here!"]],"47":[[137,291,"Grace, who do you think you are?"],[342,433,"An ex-con."],[467,608,"A nobody."],[608,725,"Luna isn't your daughter"],[725,930,"and Mr. Hill isn't your man."],[992,1076,"Stop dreaming."],[1534,1593,"Grace, where are you?"],[1668,1739,"I went home."],[1906,1951,"I"],[1951,2052,"I know about everything."],[2323,2469,"Mr. Hill, you're getting married."],[2548,2615,"That was my mother's"],[2615,2656,"announcement,"],[2656,2723,"not mine."],[2786,2890,"Alright, I'm taking care of it."],[2932,2973,"But."],[3036,3098,"No buts."],[3178,3244,"Just trust me."],[3307,3399,"Look, I gotta do some things here,"],[3399,3445,"but just."],[3474,3557,"just wait for me, okay?"],[3641,3695,"Okay."],[3812,3899,"I'll wait for you."],[5563,5684,"Mrs. Hill, uh,"],[5714,5855,"you don't think Alex would be upset"],[5855,5947,"that I just"],[5989,6139,"moved in without asking?"],[6181,6310,"Don't be silly, dear."],[6327,6448,"You're family now."],[6448,6610,"Besides, it's only right"],[6610,6744,"that you bond with Luna."],[7157,7261,"The little nanny"],[7311,7486,"is still leeching off of us."]],"48":[[95,279,"That's the ex-con nanny?"],[329,392,"God,"],[458,613,"just looking at her makes me sick."],[721,784,"Luke,"],[784,850,"get rid of her."],[950,1042,"Mr. Hill said"],[1042,1205,"no one's allowed to throw her out."],[1326,1426,"What a nuisance."],[1480,1530,"Fine."],[1572,1655,"I suppose the house"],[1655,1822,"does need a servant or two."],[2227,2289,"Hi Luna."],[2377,2498,"You must be so tired"],[2498,2669,"from all the birthday celebrations."],[2790,2877,"Let's take you to bed."],[3374,3520,"Why does Luna like her so much?"],[3666,3741,"Listen to me."],[3795,4024,"You're the woman I chose to marry Alex."],[4058,4245,"My son is only bewitched"],[4245,4312,"by that woman"],[4312,4496,"because of Luna's attachment to her."],[4554,4717,"She's nothing compared to you."],[4813,5042,"That low-class bitch."],[5105,5213,"Who does she think she is,"],[5213,5355,"playing mother to his child?"]],"49":[[233,396,"Oh, that's so good, Luna."],[479,592,"Let's look at this one, huh?"],[1084,1197,"Hi, Luna."],[1242,1455,"Your new mommy's got you some toys."],[1839,1976,"Can you say mommy?"],[2402,2573,"She doesn't speak yet."],[2677,2773,"Relax."],[2815,2940,"I just got her some toys."],[3274,3386,"Don't you like it, Luna?"],[3774,3945,"Take the toy, Luna."],[4879,4984,"It's okay, sweetheart."],[4984,5055,"I'm fine."],[5380,5530,"Luna's shy around strangers."],[5530,5651,"You have to be tender with her."]],"50":[[45,137,"It's okay, sweetheart."],[137,275,"You like this, don't you?"],[371,471,"If she wasn't Alex's kid,"],[471,563,"I wouldn't even bother."],[788,967,"If you're only here for Alex,"],[984,1146,"you don't deserve to be Luna's mother."],[1334,1514,"Do you really think you can judge me?"],[1580,1651,"Look at you."],[1747,1910,"You're a washed-up ex-con"],[1939,2110,"who won't leave a rich man's house."],[2177,2298,"Who do you think you are?"],[3073,3261,"She's supposed to be your future mother,"],[3261,3440,"but she doesn't care about you at all."],[3474,3645,"How am I supposed to leave you"],[3645,3766,"with someone like that?"]],"51":[[171,229,"Um."],[258,400,"Luna's already asleep, Mr."],[567,617,"You're hurt."],[675,725,"What happened?"],[759,817,"Nothing."],[817,959,"It was just an accident."],[1893,1956,"Come to my room."],[1956,2014,"I'll treat it."],[3228,3294,"Let me help you."],[3403,3461,"It's fine."],[3461,3566,"It's not a big deal."],[3653,3757,"It's not a big deal, Grace."],[3832,3895,"Why is it every time"],[3895,4004,"that you're hurt it's not important?"],[4608,4692,"I think that we should"],[4692,4779,"keep our distance."]],"52":[[329,458,"You think we should keep our distance?"],[650,829,"We don't belong in the same world."],[942,1038,"He deserves someone better"],[1038,1126,"suited for him."],[1313,1451,"I don't see you in that way."],[2602,2731,"I think we both know that's not the truth."],[2919,3023,"I didn't agree to have Selina"],[3023,3128,"and my mom move in here."],[3219,3303,"I'll kick them out."],[3303,3395,"I'll end the engagement."],[3395,3503,"I'll do whatever it takes."],[3578,3691,"The only thing I care about is you."],[5714,5784,"Alex?"],[5839,5918,"Are you in there?"],[6014,6081,"You want her to know"],[6081,6143,"that I'm your man?"],[7082,7161,"Let her hear you."]],"53":[[992,1059,"You like that?"],[1242,1330,"Yes, please."],[1363,1484,"Alex, more."],[1522,1597,"Please."],[1926,2022,"Yes, yes."],[2060,2139,"Yes, please."],[2264,2406,"You filthy bitch."],[2452,2540,"Just wait."],[2602,2648,"I'll make sure"],[2648,2794,"you're thrown out of this house for good."],[3370,3461,"Okay Luna."],[3516,3716,"It's still too hot, so you have to wait."],[3807,3928,"I'm gonna toast some bread."],[3966,4062,"You hold tight, okay?"],[6239,6343,"There you go, baby girl."],[6406,6506,"Now you can reach it."],[7419,7482,"Oh my God."],[7490,7628,"Luna, what happened?"],[7686,7761,"Mrs. Hill?"],[7786,7932,"What is going on here?"],[7932,8112,"The incompetent nanny."],[8241,8362,"She must have burned her."]],"54":[[150,321,"Jesus Christ, look at her poor little hand."],[321,437,"It's all red."],[467,550,"Don't worry, sweetheart."],[550,721,"We'll take you to the hospital right away."],[721,821,"And Grandma's gonna"],[821,1001,"make that woman pay for this."],[1201,1272,"Alex,"],[1272,1480,"that ex-con nanny bitch you hired"],[1480,1664,"just tried to kill my granddaughter."],[1764,1814,"Go on."],[1868,1964,"Say something."],[2010,2085,"Oh, wait."],[2085,2147,"You can't."],[2189,2318,"You mute little brat."],[2515,2615,"Okay, come on, sweetie."],[2615,2686,"Let's go."],[2686,2806,"Grandma's got you."],[2806,2944,"You can have whatever you want."],[2944,3140,"We'll get you some ice cream."],[4721,4779,"What?"],[4900,4988,"Luna's hurt?"],[5059,5159,"I, I'm on my way."],[5171,5242,"I'm on my way."],[6277,6398,"Luna, what happened?"],[6423,6606,"Don't you play dumb."],[6648,6794,"You know exactly what happened."],[6823,6915,"You poured scorching"],[6915,7007,"hot milk on her."]],"55":[[221,417,"You abused my granddaughter."],[779,821,"No."],[880,1042,"I would never do something like that."],[1134,1247,"Grace would never hurt Luna."],[1305,1368,"Oh yeah?"],[1409,1522,"And you just believe her?"],[1618,1689,"I told you."],[1714,1897,"She is rotten to the core."],[1914,2085,"She knows Luna can't talk back,"],[2085,2281,"so she did whatever she wanted."],[2331,2431,"See for yourself."],[2798,2919,"How could you do something"],[2919,3007,"like this to her?"],[3082,3203,"Luna, baby,"],[3203,3324,"how did this happen?"],[3324,3478,"Luna, I'm so sorry."],[3478,3632,"Don't touch her."],[3661,3795,"Don't act like you care."]],"56":[[233,300,"Alex,"],[337,437,"someone like her"],[458,608,"has no place in our home."],[625,742,"You need to get rid of her."],[759,817,"Now."],[871,984,"Luna, baby, I,"],[984,1059,"I'm so sorry."],[1059,1197,"I should have been more careful."],[1197,1309,"Oh, please."],[1330,1463,"Stop with the charades."],[3428,3553,"No, no."],[3582,3712,"Not Mama."]],"57":[[29,166,"No, no."],[200,333,"Not Mama."],[1509,1568,"What?"],[1605,1735,"What did you just call me?"],[1856,1960,"Mama."],[2185,2314,"Say it again, baby."],[2314,2398,"Mama."],[2498,2548,"She,"],[2581,2698,"she's talking."],[2969,3061,"Luna, sweetheart,"],[3153,3240,"what are you trying to say?"],[3261,3324,"Ow."],[3482,3628,"Touch pain."],[3737,3824,"No, no."],[3824,3958,"Not Mommy did."],[4016,4200,"Luna did it."]],"58":[[0,83,"Luna did it?"],[158,241,"Luna spilled the milk"],[241,329,"and burned your hand?"],[629,734,"No, that's okay, baby."],[734,800,"Daddy's here."],[1292,1384,"It's my fault."],[1451,1593,"I shouldn't have left her alone."],[1639,1697,"No."],[1697,1868,"Not Mommy did it."],[1939,2143,"She's really talking."],[2289,2394,"This has been a misunderstanding."],[2594,2702,"I don't want to hear another word"],[2702,2781,"about Grace leaving."],[3240,3340,"And another thing, Selina?"],[3461,3582,"Luna doesn't feel safe around you."],[4087,4158,"It's okay."]],"59":[[371,492,"Luna called her mom."],[571,621,"Her."],[684,784,"An ex-con like her"],[784,946,"doesn't deserve to be Luna's mother."],[996,1038,"I'm the one"],[1038,1209,"who's supposed to be marrying Alex."],[2227,2364,"You think Luna"],[2364,2515,"calling her Mom is bad?"],[2552,2665,"Oh, sweetheart."],[2715,2827,"You have no idea"],[2827,2982,"how bad it really is for us."],[3078,3140,"What do you mean?"],[3219,3470,"Grace is Luna's real mother."],[3903,3974,"No, no."],[4049,4175,"What are you even talking about?"]],"60":[[25,196,"Alex has been searching"],[196,312,"for Luna's birth mother"],[342,433,"this whole time."],[475,608,"And the ugly truth is,"],[650,734,"it's Grace."],[796,967,"She gave birth to Luna in prison."],[1034,1276,"And, naturally, I hid the truth."],[1338,1518,"I wasn't about to let a criminal like her"],[1518,1672,"step foot into this family."],[1785,1931,"Once Alex finds out,"],[1993,2089,"you'll be nothing."],[2352,2506,"You don't even stand a chance."],[2544,2781,"She doesn't belong by his side."],[2802,2969,"She should have never come back."],[2990,3211,"I'll make sure she disappears."],[3716,3787,"That's it, baby."],[3787,3883,"Blow on it, okay?"],[3999,4074,"Yes."],[4104,4275,"Pain, pain, fly away."],[4842,4938,"We're going to go home."],[4938,5038,"Fuck!"],[5063,5130,"That's it, baby."],[5142,5201,"Blow on it."]],"61":[[504,546,"Hey."],[608,650,"Hey."],[767,880,"Is Luna okay?"],[909,971,"Yeah, yeah."],[971,1013,"She's okay."],[1013,1071,"She's fine."],[2394,2456,"Oh my God."],[2523,2627,"Thank God Luna's okay."],[2669,2719,"I never thought"],[2719,2861,"Selina would react like that"],[2861,3019,"to hearing that Grace is Luna's mom."],[3274,3324,"What?"],[3541,3682,"Grace is Luna's biological mother?"],[3962,4024,"Mr. Hill."],[4237,4379,"Here's the maternity test result."],[4587,4700,"The result says"],[4750,4884,"that it was Miss White"],[4946,5113,"who gave birth to Luna."],[5422,5505,"And you've known about this"],[5505,5605,"the whole entire time, haven't you?"],[5834,5955,"Grace just put her life on the line"],[5955,6043,"to save Luna."],[6060,6172,"She's in the ER right now,"],[6172,6235,"fighting for her life,"],[6235,6348,"and you're still hiding the truth"],[6348,6393,"from me?"],[6552,6685,"Yes, Alex."],[6865,7052,"Grace is Luna's mother."],[7207,7273,"She's the woman"],[7273,7353,"you've been looking for"],[7353,7419,"all along."]],"62":[[33,120,"How long have you known this?"],[321,446,"Since before Luna was born."],[821,871,"Why?"],[1184,1334,"She went to prison, Alex."],[1397,1614,"A criminal has no place in our home."],[1614,1714,"She was framed."],[1776,1847,"And because of you,"],[1847,1943,"Luna's been without a mother"],[1943,2035,"for three years!"],[2064,2122,"Alex,"],[2156,2335,"everything I did,"],[2364,2494,"I did for this family."],[2702,2781,"You haven't done anything"],[2781,2852,"for this family,"],[2923,3007,"except destroy it."],[3140,3269,"You hurt me and you hurt Luna."],[3490,3557,"Take her home."],[3674,3737,"Both her and Selina"],[3737,3837,"can answer for the accident."],[5230,5296,"Hey, hey."],[5367,5426,"Hey, it's okay."],[5426,5480,"You're safe."],[5593,5684,"We're gonna get you out of here soon."],[5901,6072,"I put Luna in danger."],[6085,6185,"No, no."],[6185,6256,"You saved her."],[6352,6456,"Luna's safe because of you."],[6552,6673,"Grace, I need to ask you something."],[6898,7032,"That night at the Queen's Hotel."],[7223,7294,"Do you remember that?"]],"63":[[33,208,"How do you know about that?"],[308,421,"Because the man from that night."],[608,663,"That was me."],[1639,1722,"Room 1110."],[1793,1906,"She's drugged and ready for you."],[1981,2047,"Damn, bro."],[2122,2318,"Selling your own girl for hard cash."],[2369,2498,"That's some next-level business."],[2594,2665,"Let me buy you a drink"],[2665,2765,"for your services."],[2861,2919,"My treat."],[3853,3920,"So"],[3999,4070,"hot."],[4216,4300,"What the hell did they give me?"],[6035,6189,"That, that was you?"],[6585,6681,"And I've finally found you."]],"64":[[108,200,"It was you."],[696,742,"Then."],[817,896,"Then my baby."],[1146,1197,"Yeah."],[1317,1397,"Luna's your baby."],[1643,1705,"Our baby."],[1981,2047,"My mother,"],[2131,2210,"she took her from you"],[2210,2298,"the day she was born."],[2560,2727,"So Luna's really my baby."],[2831,2877,"Yeah."],[3353,3470,"Now I understand why she chose you"],[3470,3553,"from the very beginning."],[3732,3824,"I'm just grateful that"],[3878,3995,"fate brought us back together."],[4959,5013,"Wait."],[5109,5255,"I need to see my baby."],[5255,5359,"I need to see Luna."],[5547,5605,"Not yet."],[5868,5989,"I'm not done kissing you yet."]],"65":[[3211,3265,"Grace."],[3395,3495,"I'm so sorry."],[3753,3841,"It's in the past."]],"66":[[354,458,"You want to take Mama's flowers?"],[625,721,"Thank you."],[1026,1188,"I've been waiting for this day for so long."],[1292,1351,"Me too."],[1555,1639,"Alex Hill,"],[1639,1751,"do you take Grace White"],[1793,1885,"to be your wife,"],[1935,2052,"to love and cherish her"],[2052,2173,"in good times and bad,"],[2227,2364,"in sickness and in health,"],[2439,2535,"for richer or poorer,"],[2560,2686,"until the end of your days?"],[2765,2819,"I do."],[3386,3461,"Grace White,"],[3503,3641,"do you take Alex Hill"],[3670,3766,"to be your husband,"],[3828,3933,"to love and cherish him,"],[3983,4099,"in good times and bad,"],[4145,4258,"in sickness and health,"],[4304,4400,"for rich or for poorer,"],[4491,4637,"until the end of your days?"],[4767,4825,"I do."],[5021,5192,"Then by the power vested in me,"],[5234,5413,"I pronounce you husband and wife."],[5442,5497,"Alex,"],[5518,5618,"you may kiss your bride."],[7912,7991,"Mom, Dad,"],[7991,8103,"it's your wedding day!"],[8587,8679,"Look, flowers."],[8892,8979,"Isn't that nice?"],[8979,9075,"Come on, let's get out of here."],[9259,9330,"Thank you, sir."]]}