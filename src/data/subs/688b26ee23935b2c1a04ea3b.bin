{"1":[[254,367,"Hang in there, baby."],[575,717,"Check out that pregnant chick."],[746,871,"How big the belly is."],[925,1092,"Daddy's coming for us real soon."],[1985,2081,"Mark, finally."],[2293,2385,"Let's get out of here."],[2489,2590,"You really think"],[2635,2798,"that I'm bailing your ass out, bitch?"],[3203,3265,"But,"],[3315,3503,"You said that if I took the fall that..."],[3628,3782,"that I'd be out in no time and..."],[3849,3949,"that we'd get married."],[3983,4066,"You two?"],[4137,4225,"Married?"],[4571,4688,"Amanda?"],[4704,4767,"Don't you"],[4854,4904,"think"],[4984,5071,"that's funny?"],[5138,5213,"Amanda?"],[5347,5422,"Mike,"],[5422,5568,"you're screwing my cousin?"],[5638,5693,"Hmm?"],[5747,5834,"Oh."],[5905,5968,"Sweetie,"],[5968,6139,"Mark was never yours."],[6193,6381,"He was only using you to take the fall,"],[6381,6552,"you clueless bitch."],[6589,6698,"No, no, that's..."],[6740,6848,"That's not possible."],[6927,6981,"I..."],[7086,7194,"I'm pregnant with your baby."],[7194,7294,"You wouldn't do that."],[7294,7399,"Oh, come on, Grace."],[7457,7599,"That bastard is not mine."],[7624,7707,"No chance."],[7849,7932,"No, that's imposs-"],[7932,8033,"I remember that night."],[8033,8095,"That night?"],[8187,8258,"That wasn't me."],[8366,8487,"I dosed you up."],[8591,8746,"Then I sold you off to the highest bidder."],[8825,8950,"You sold me?"],[9154,9221,"No."],[9296,9363,"No."],[9442,9517,"No, no, no."],[9517,9559,"Ow!"],[9759,9830,"Oh my God!"],[10089,10181,"She's in labor!"],[10201,10364,"Get her to the infirmary now!"],[10452,10535,"Aw,"],[10535,10668,"poor little jail bird."],[10694,10823,"Looks like you're gonna rot here"],[10823,10910,"for a while."],[11119,11327,"Ah!"],[11423,11494,"You're alright."],[11494,11615,"Breathe and push."],[11649,11724,"Push. Come on. Come on."],[11724,11774,"Breathe."],[11828,11878,"Okay, yeah,"],[11878,11991,"she's losing too much blood."],[11991,12124,"Her blood pressure's getting way too high."],[12149,12220,"I'm gonna call a surgeon."],[12220,12316,"Ah!"],[13138,13242,"It's been nine months, Sam."],[13338,13425,"You still haven't found the woman"],[13425,13475,"from that night."],[13988,14093,"I don't care how long it takes"],[14093,14180,"or how much it costs."],[14226,14301,"Just get it done."],[14326,14393,"Of course, sir."],[14806,14898,"Where is this girl?"]],"2":[[880,950,"My baby."],[1167,1251,"Where's..."],[1251,1338,"Where's my baby?"],[1418,1501,"It was a girl."],[1597,1680,"But..."],[1718,1860,"She was born with defects."],[1860,1956,"She barely cried"],[1956,2135,"before she stopped breathing."],[2489,2556,"Baby."],[3332,3415,"The baby is here."],[3415,3520,"Now where's my money?"],[3570,3641,"Who would have thought"],[3641,3720,"someone like her"],[3720,3787,"would be the one"],[3787,3903,"carrying Hill blood?"],[3949,4116,"A criminal will never be"],[4116,4241,"a part of the Hill family."],[4304,4433,"No one can ever know"],[4454,4612,"she gave birth to an heir."],[4775,4846,"Grace White."],[5013,5109,"You're out on parole."],[5146,5238,"That means you need to"],[5238,5347,"find a steady job,"],[5367,5451,"and fast."],[5476,5647,"If you don't, they'll revoke it"],[5647,5755,"and throw you right back in."],[6548,6673,"We've got a strict policy"],[6673,6802,"about prior convictions."],[6815,7015,"Sorry, we don't hire ex-cons."],[7215,7374,"Only one month left."],[7390,7536,"If I still can't find a job,"],[7611,7757,"I'll have to go back to prison."],[7832,7949,"I don't want to go back."],[8074,8166,"Now hiring"],[8224,8299,"live-in nanny"],[8299,8454,"for billionaire's daughter."],[8500,8654,"$10,000 per week."],[8687,8858,"Room and board included."],[10381,10623,"Sweetheart, what is this look?"],[10623,10752,"Are you interviewing"],[10752,10852,"for a nannying gig"],[10852,10998,"or a soup kitchen?"],[11069,11198,"What's wrong with my outfit?"],[11269,11394,"Girl, you really don't know"],[11394,11515,"who the boss is, do you?"],[11561,11866,"Alex freaking Hill."],[11891,11974,"Billionaire."],[11974,12199,"Drop-dead gorgeous."],[12199,12454,"Most eligible single dad in town."],[12483,12691,"This job is a golden ticket"],[12691,12867,"to becoming Mrs. Moneybags."],[12925,13050,"And you show up looking like"],[13050,13213,"you crawled out of a Goodwill's"],[13213,13288,"bargain bin?"],[13517,13659,"This is the best I've got."],[13742,13847,"My last chance."],[13918,13988,"How am I supposed to"],[13988,14084,"compete with them?"],[14547,14631,"Oh my God."],[14652,14798,"It's really Mr. Hill."],[14810,14935,"He's looking this way."],[14964,15065,"Is my hair okay?"],[15094,15202,"My lipstick?"],[15202,15411,"He's even more handsome"],[15411,15590,"than in the magazines."],[16099,16153,"Why?"],[16278,16466,"Why does he feel so familiar?"]],"3":[[804,871,"Mr. Hill,"],[942,1076,"here are the final applicants"],[1138,1255,"for Luna's nanny position."],[1322,1443,"I have three PhDs."],[1476,1547,"Psychology,"],[1576,1718,"education and business."],[1768,1918,"I can not only take care of Luna,"],[1976,2106,"but I can also assist you"],[2248,2323,"at work."],[2464,2660,"Childcare runs in my blood."],[2660,2877,"My family has raised elite children"],[2877,2977,"for generations."],[3007,3161,"My mother was the personal nanny"],[3161,3286,"for the President's kids."],[3691,3749,"Oh God."],[3824,4012,"I am way out of my league."],[4070,4179,"I've got nothing."],[4179,4546,"Um, I don't have any fancy degrees"],[4546,4771,"or an impressive resume, but..."],[5134,5234,"I love kids."],[5392,5593,"And I promise I'll take care of Luna"],[5593,5701,"with all of my heart."],[6310,6389,"There's only one requirement"],[6389,6439,"for this job."],[6527,6627,"Whoever Luna likes,"],[6669,6731,"that's who gets it."],[7048,7173,"Ready to tell me who you like, sweetheart?"],[9809,9868,"Okay."],[9980,10039,"How about her?"]],"4":[[16,83,"How about her?"],[1626,1701,"Hi, Luna."],[1776,1885,"My name's Grace."],[2072,2210,"If my baby had lived,"],[2260,2406,"she'd be Luna's age now."],[2827,2977,"Luna never lets strangers near her,"],[3082,3182,"let alone kisses them."],[3440,3541,"I guess we have our answer."],[3712,3770,"You're hired."],[3987,4070,"The rest of you can go."],[5201,5313,"Find out everything you can on her."],[5926,6043,"Are you ticklish?"],[8062,8208,"It has to be a coincidence."],[8900,9000,"Grace, you've been to prison?"]],"5":[[54,300,"I, I have, but I, I can explain."],[300,375,"Don't bother!"],[408,487,"I'm not going to trust my daughter"],[487,542,"with a criminal."],[542,663,"Wait, please."],[696,734,"Please."],[734,900,"I, I can take good care of Luna."],[942,984,"And..."],[1063,1159,"I've studied"],[1159,1251,"childhood development."],[1251,1397,"I know everything that there is."],[1455,1530,"Please, I..."],[1530,1651,"I really need this job."],[1651,1747,"I have nowhere else to go."],[1889,1972,"Have some dignity."],[2047,2118,"Hand her to me now."],[2485,2552,"Come on, baby."],[2719,2781,"Come on."],[3015,3073,"Come on, Luna."]],"6":[[487,571,"Fix your clothes."],[1605,1664,"Go on."],[1664,1780,"Your dad's waiting for you."],[1830,1935,"I have to go now."],[2356,2427,"How about this?"],[2481,2623,"I'll come and visit you"],[2623,2765,"sometime soon, okay?"],[3186,3257,"Mama."],[4220,4266,"Luna,"],[4320,4466,"she's never spoken before."],[4517,4600,"Not a single word."],[4717,4825,"But now she's trying..."],[4892,4946,"for her."],[5263,5330,"It's Grace, right?"],[5426,5480,"Yeah."],[5651,5739,"I'll give you one month."],[5826,5918,"We'll call it a trial period."],[5964,6085,"But if you mess up, you're done."],[6151,6189,"You think you can"],[6189,6272,"take care of my daughter?"],[6364,6443,"Yes. Yes."],[6443,6514,"Absolutely."],[6539,6723,"Thank you so much, Mr. Hill."],[6819,6877,"Go ahead and go home."],[6877,6956,"Get settled in."],[7073,7144,"This is your new phone."],[7165,7240,"If I call you,"],[7240,7357,"it's an emergency for Luna."],[7357,7474,"So if you miss it, you're done."],[7553,7782,"Yes. I, I'll be on call 24-7."],[8354,8466,"I guess that means that we get to"],[8466,8633,"spend more time together, huh?"],[9342,9438,"Luna can't speak."]],"7":[[25,112,"Luna can't speak."],[179,258,"Doctors don't know why,"],[258,304,"but"],[350,471,"it just means that you need to give her"],[471,538,"whatever she needs"],[538,633,"before she has to ask."],[692,750,"You understand?"],[859,1042,"A sweet, perfect little girl."],[1105,1263,"And she can't even ask for help."],[1347,1564,"I'll take care of her like she's my own."],[2068,2156,"Just so we're clear,"],[2156,2339,"there are three rules to this house."],[2398,2452,"One,"],[2477,2673,"Luna always comes first."],[2711,2748,"Two,"],[2781,2973,"when Mr. Hill calls, you answer,"],[2973,3061,"no matter what."],[3090,3165,"And three,"],[3244,3461,"keep your distance from Mr. Hill,"],[3553,3678,"if you know what's good for you."],[3728,3891,"The last girl that crossed the line,"],[3962,4108,"she was out of the city by morning."],[4195,4312,"Please put on your uniform."],[4558,4767,"I worked so hard to land this job."],[4854,4963,"If I screw it up,"],[5063,5205,"I'm going back to prison."],[6076,6206,"I need to take a shower."],[6623,6698,"Oh yeah."],[6752,6911,"Finally a real bath."],[9300,9367,"Where is she?"],[9864,9972,"If I call you,"],[9972,10068,"you miss it, you're done."],[10143,10193,"Shit!"],[10218,10381,"Shit! Shit! Shit! Shit! Shit! Shit!"],[11061,11173,"I told you when the phone rings,"],[11173,11215,"you answer-"]],"8":[[45,125,"I hired you to work,"],[125,208,"not to lounge around."],[387,454,"Luna's..."],[508,592,"Look, she can't sleep."],[592,638,"You gotta go..."],[658,725,"You gotta go help her."],[725,846,"Yeah, I'm sorry, I..."],[896,1084,"Let me just get changed."],[1276,1317,"Alright."],[1822,1868,"What's wrong - What's wrong"],[1868,1926,"with me? - with me?"],[2031,2089,"Why is my - Why is my"],[2089,2189,"heart still pounding - heart still pounding"],[2189,2273,"like this? - like this?"],[2957,3199,"I am so sorry I took so long, Luna."],[3290,3420,"How about I read you"],[3420,3561,"my favorite bedtime story"],[3561,3687,"from when I was a young girl?"],[3824,3899,"Okay."],[3953,4029,"Perfect."],[4154,4220,"Okay."],[4458,4517,"So,"],[4696,4829,"once upon a time,"],[4867,5071,"in a kingdom far, far away,"],[5171,5292,"lived a little girl"],[5326,5547,"whose skin was as fair as snow..."],[6569,6685,"Well, I'll be damned."],[6748,6877,"She's actually good at this."],[6936,6994,"Still,"],[7052,7178,"she's a woman fresh out of prison."],[7178,7261,"I can't trust her."],[7349,7407,"Not yet."],[12212,12341,"Wait, did I just kiss him?"]],"9":[[0,79,"Just a dream."],[120,200,"Stay still."],[254,346,"Stay asleep."],[387,508,"He won't notice."],[1384,1526,"Is she trying to seduce me?"],[2181,2348,"No, it's just an accident."],[2394,2548,"Calm down. Forget about it."],[2886,3115,"Jesus, Grace, what the hell was that?"],[3174,3332,"You just kissed your boss."],[3841,4049,"Her lips were so soft."],[4512,4583,"Mr. Hill,"],[4679,4796,"would you like some breakfast?"],[5513,5580,"No need."],[5630,5697,"I gotta head out."],[6126,6243,"Did I piss him off?"],[6285,6364,"Is he acting weird"],[6364,6468,"because of last night?"],[7524,7645,"I left a file in the study."],[7695,7753,"Get it for me."],[8550,8621,"Mr. Hill,"],[8683,8812,"I have the file on the lounge."],[8812,8892,"I'll be right down."],[8908,8950,"Babe,"],[9025,9175,"my cousin pulled a lot of strings"],[9175,9280,"to get us this meeting."],[9351,9538,"We have to lock in this deal."],[9538,9647,"Relax, baby."],[9667,9772,"I've got this."],[9851,9959,"I know you do."],[10510,10585,"Grace."],[10681,10785,"She's out."],[11227,11432,"What the hell are you doing here?"],[11524,11615,"Who let you in?"]],"10":[[16,108,"Who let you in?"],[129,196,"I work here."],[308,504,"A worthless ex-con like you"],[504,667,"doesn't belong in a place like this."],[734,829,"You should get the hell out of here"],[829,942,"before someone recognizes"],[942,1005,"who you are."],[1021,1101,"Grace,"],[1130,1334,"let's be smart about this."],[1368,1509,"You've done time."],[1543,1739,"Don't embarrass yourself any further."],[1797,1935,"Embarrass myself?"],[2177,2327,"I did nothing wrong."],[2364,2535,"And you, you're, you're my cousin."],[2565,2727,"You fucked my boyfriend."],[2727,2882,"And then pinned his crimes on me"],[2882,3023,"and let me rot in prison,"],[3053,3182,"while you two lived it up."],[3228,3324,"Tell me, Amanda,"],[3324,3461,"do you have a conscience?"],[3570,3703,"Or did you sell that too?"],[3741,3816,"You..."],[3887,3962,"bitch."],[4029,4141,"Mark, we cannot let her"],[4141,4241,"screw up this deal"],[4241,4316,"with Mr. Hill."],[4371,4450,"Do something."],[4838,4888,"Luna!"],[4942,5092,"Get this bastard out of here now!"],[5184,5388,"Mark, this kid is giving me"],[5388,5442,"a headache."],[5442,5572,"Just kick them out."],[5601,5834,"Touch one fucking finger on her"],[5876,6010,"and I will bury you both."],[6031,6210,"How about I kick you instead?"],[6402,6460,"Bitch."],[6535,6602,"Criminal."],[6765,7032,"You're too trashy for the Hill group."],[7211,7374,"Get out of here now."],[7394,7707,"Or I'll bury you and that little brat."],[8199,8324,"Don't you dare touch her!"]],"11":[[262,312,"Bitch."],[921,1051,"Don't you dare touch her!"],[1497,1618,"You even breathe wrong around her,"],[1618,1701,"I'll make you regret it."],[2018,2068,"You okay?"],[2147,2243,"Who the fuck are you?"],[2289,2494,"I'm here to handle Mr. Hill's business."],[2531,2660,"That has nothing to do with you."],[2660,2798,"You're dealing with Mr. Hill's business?"],[2798,2869,"Yeah, that's right."],[2907,3111,"So I suggest you"],[3111,3253,"back the fuck off."],[3299,3395,"And you don't know who I am?"],[3574,3737,"Lookie lookie at you."],[3766,4041,"All dressed up like some big shot."],[4066,4258,"I bet you are a nobody,"],[4287,4483,"who is trying to get a deal with Mr. Hill."],[4542,4738,"I hate to break the news for you,"],[4800,5146,"but we have connections."],[5167,5363,"One wrong move"],[5397,5488,"and you won't even be able"],[5488,5630,"to get a meeting."],[5663,5834,"That is Mr. Hill."],[5885,5972,"You moron."],[6076,6193,"Now get the hell out of here"],[6231,6314,"before you embarrass"],[6314,6410,"yourselves further."],[6519,6677,"Mr. Hill."],[6698,6790,"Yeah. Okay."],[6869,6965,"Oh."],[6986,7115,"I see what's going on here."],[7173,7382,"You're her little boy toy, huh?"],[7399,7503,"Thought you could come in here and"],[7503,7611,"pretend to be Mr. Hill,"],[7611,7749,"so you protect the girl."],[7891,7949,"Pathetic."],[7978,8070,"She's nothing but a,"],[8095,8220,"a used-up slut"],[8220,8333,"that I tossed aside,"],[8333,8391,"and I-"],[8700,8771,"Fuck!"],[8771,8883,"Did you just hit me?"],[8938,8967,"Let me tell you"],[8967,9038,"what's gonna happen."],[9100,9217,"You're gonna apologize to her,"],[9230,9275,"then you're gonna get the"],[9275,9359,"hell out of here."],[9488,9609,"You motherfucker!"],[9638,9847,"Do you know who my girlfriend's cousin is?"],[9847,9926,"Get him, baby."],[9926,10035,"The sales director"],[10047,10085,"Yeah."],[10101,10168,"of Hill Group."],[10218,10289,"Security!"],[10377,10472,"Security!"],[10472,10635,"Can you get this piece of trash"],[10635,10702,"out of here?"],[10769,10831,"Perfect."],[10831,10981,"Look, it's my cousin Bob."],[10981,11244,"Bob, this man is harassing us."],[11277,11357,"That's right, Bob."],[11390,11557,"Get this piece of trash out of here,"],[11599,11695,"so I can handle business"],[11695,11778,"with Mr. Hill."],[11978,12124,"What the hell, Bob?"],[12170,12237,"Why did you hit me?"],[12237,12333,"You're supposed to hit him."],[12333,12408,"You moron."],[12445,12537,"That's Mr. Hill."],[12595,12650,"What?"]],"12":[[4,100,"Mr. Hill, I'm sorry."],[141,233,"I had no idea"],[233,367,"they'd be so much out of line."],[408,517,"I'll take care of everything."],[621,746,"That's not possible."],[746,900,"Wait, no, Mr. Hill."],[946,1071,"This is all just really"],[1071,1226,"big misunderstanding."],[1226,1280,"See,"],[1280,1363,"we..."],[1363,1484,"we didn' know who you were."],[1589,1655,"Silly us."],[1693,1789,"Because she tricked us."],[1856,1968,"This is all her fault."],[1968,2072,"This is because of her."],[2072,2189,"Yeah, that's right, Mr. Hill, yeah."],[2231,2419,"This woman right here is an ex-con."],[2444,2560,"I don't even know how she got in here."],[2560,2673,"I, I, I tried to throw her out."],[2673,2765,"I was trying to help you."],[2765,2844,"Oh, you wanted to help me?"],[2844,2919,"Yeah, yeah, that's right."],[2944,3103,"Yeah, she even had the audacity"],[3103,3161,"to come in here"],[3161,3299,"and act like she was working here."],[3345,3490,"A bitch like this could never-"],[3490,3586,"She does work here."],[3666,3770,"She's my daughter's nanny."],[3782,3870,"So if you say one more word,"],[3870,3928,"we're going to find out"],[3928,4012,"how much shit you can talk"],[4012,4108,"to a broken jaw."],[4133,4279,"No, no, Mr. Hill, that-"],[4304,4508,"She's nothing but a, a worthless criminal."],[4508,4596,"A whore."],[4725,4859,"Bob, do something."],[4900,5155,"From now on, Mr. Hill will be doing"],[5155,5367,"no further business with these two."],[5367,5447,"Spread the word."],[5509,5718,"Blacklist them across the industry."],[5759,5809,"Please, no."],[5809,5885,"No, no, no."],[5885,5989,"Mr. Hill, please."],[5989,6026,"Please."],[6085,6239,"Please, just give us another chance."],[6252,6327,"No, no, no."],[6327,6373,"Help me."],[6373,6431,"What are you doing?"],[6431,6548,"Please just read the contract."],[6548,6627,"Get your hands off me."],[7411,7461,"You okay?"],[7607,7716,"I'm fine."],[7766,7820,"You know them?"],[7937,8091,"That's my ex"],[8091,8262,"and, um, my cousin."],[8370,8637,"I'm sorry I, I dragged you into this mess."],[8692,8796,"Maybe they're right."],[8879,8971,"I am an ex-con."],[9054,9154,"Maybe I don't deserve"],[9154,9280,"to be Luna's nanny."],[9455,9588,"A person's past has nothing to do"],[9588,9655,"with who they are."],[9951,10018,"And everyone deserves"],[10018,10101,"a second chance."]],"13":[[12,175,"I almost put her in danger."],[175,216,"No."],[258,350,"I saw the whole thing."],[437,500,"You protected her."],[550,608,"You did good."],[896,938,"Right?"],[1159,1205,"Well,"],[1251,1334,"Sam will take you home."],[1413,1488,"I'll be there soon."],[1847,1918,"Bye, baby."],[2460,2585,"I'll bring you milk in just a moment,"],[2585,2656,"sweetheart."],[2823,2965,"A person's past doesn't define"],[2965,3032,"who we are."],[3278,3374,"Maybe Mr. Hill isn't"],[3374,3520,"such a bad boss after all."],[3908,4008,"Shit!"],[5351,5447,"I'm coming, Luna."],[5463,5576,"Let me just put some clothes on."],[7278,7444,"What did I do with my bra?"],[7469,7520,"Miss White?"],[7849,7924,"You looking for this?"]],"14":[[992,1159,"Oh my God, Grace, what are you doing?"],[1188,1347,"You're on parole and he is your boss."],[1359,1438,"Get it together."],[1438,1509,"Keep your distance"],[1509,1680,"or you'll end up back in prison."],[1680,1914,"I wasn't trying to do anything."],[1914,1956,"I..."],[1993,2064,"Well,"],[2064,2189,"I spilled milk on my dress"],[2189,2373,"and then, well, Luna was crying"],[2373,2494,"and I couldn't find"],[2494,2560,"anything else to wear,"],[2560,2686,"so then I just put on your shirt,"],[2686,2736,"and I-"],[2736,2781,"It's fine."],[2781,3007,"Just go put something else on."],[3040,3165,"Okay, yeah, absolutely."],[3165,3228,"Let me just..."],[4688,4850,"She has the exact same moles"],[4850,4909,"as that woman."],[4979,5088,"Could she be Luna's mother?"],[5584,5647,"Sorry."],[5730,5876,"I should be changing."],[5922,5980,"Grace."],[6164,6243,"Four years ago,"],[6314,6431,"did you ever go to the Queen's Hotel?"]],"15":[[20,129,"What did you just say?"],[275,437,"I should check things out for myself first."],[721,796,"You forgot this."],[1217,1288,"Thank you. Thank you."],[3186,3249,"