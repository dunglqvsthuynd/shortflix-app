{"1":[[329,608,"This is so pretty."],[1142,1422,"I think Harrison will like this."],[2602,2677,"Shh,"],[2719,2802,"stay quiet."],[2865,2948,"I won't hurt you."],[3311,3386,"See that side."],[3399,3532,"You go from this end."],[3553,3591,"Ah,"],[3595,3670,"he's this way."],[4604,4642,"Jeez,"],[4642,4704,"get a room."],[4767,4854,"He went this way."],[5426,5509,"How dare you?"],[6852,6915,"Oh my God,"],[6948,7015,"you're bleeding."],[7219,7319,"Don't touch me."],[7415,7565,"You've been shot by a silver bullet"],[7565,7678,"covered in wolfsbane."],[7745,7878,"If it's not removed immediately,"],[7878,7974,"it could kill you."],[8454,8566,"It's gonna hurt."],[8996,9029,"Okay,"],[9067,9138,"bullet's out."],[9713,9797,"But we still need to get you"],[9797,9918,"to a hospital quickly."],[10639,10856,"Is she?"],[11323,11586,"My love, I finally found you."],[11686,11761,"You're my mate."],[13229,13309,"You're insane!"],[13338,13475,"I already found my mate,"],[13492,13609,"and I'm marrying him"],[13676,13726,"soon."],[14134,14280,"Why can't she feel our bond?"],[14773,14860,"Alpha Dominic,"],[14902,15052,"we need to get you to the hospital."],[15102,15160,"I'm alright."],[15302,15448,"I need you to find my mate first."]],"2":[[16,87,"Alpha Dominic,"],[133,233,"we've captured the traitors"],[233,291,"who ambushed you."],[346,404,"Should we..."],[471,517,"No."],[608,817,"I'm not like your former Alpha."],[834,930,"Banish the traitors."],[1005,1197,"Let them rot like rogue wolves."],[1447,1584,"Since the Ironclaw Pack"],[1630,1714,"killed your mother,"],[1755,1910,"it's been five years."],[2602,2731,"I miss her too, Dad."],[2781,2902,"It didn't have to be Mom."],[2923,3036,"If only I had my wolf,"],[3036,3119,"I could have been the one"],[3119,3232,"protecting our pack."],[3257,3440,"Oh, it’s not your fault, Evelyn,"],[3478,3712,"but you are the best healer"],[3712,3841,"we've ever had."],[3945,4012,"Thanks, Dad."],[4149,4216,"Alpha Justin,"],[4362,4662,"the new leader of the Ironclaw Pack"],[4662,4721,"is here."],[4742,4879,"Tell him to fuck off!"],[4988,5259,"He's the world's strongest warrior."],[5309,5551,"We can't afford to provoke him."],[5597,5634,"Dad,"],[5743,5839,"let's see what he wants."]],"3":[[4254,4320,"Mr. Walker,"],[4408,4508,"I'm Dominic Crawford,"],[4525,4717,"the new Alpha of the Ironclaw Pack."],[4817,4946,"It's a pleasure seeing you again."],[5046,5146,"What do you want?"],[5163,5326,"Watch your attitude."],[5326,5367,"You old-"],[5388,5426,"Luke,"],[5522,5576,"I told you,"],[5626,5768,"I don't operate like previous Alpha."],[5805,5876,"Let's keep it civil."],[5910,6056,"I'm here to claim my mate,"],[6264,6339,"Evelyn Walker."],[6360,6639,"My daughter can't be your mate."],[6756,6827,"But she is."],[6931,7032,"And I want your blessing"],[7052,7136,"to marry her,"],[7203,7399,"and make her Luna of the Ironclaw Pack."],[7403,7595,"You arrogant piece of shit."],[7632,7874,"You think that you can show up here"],[7937,8099,"and just take my daughter away?"],[8103,8270,"Let me rephrase, sir."],[8358,8495,"I'm trying to be respectful here."],[8933,9113,"I will marry her,"],[9246,9467,"with or without your blessing."]],"4":[[45,100,"Let me go."],[346,604,"I'll never marry you."],[717,938,"How about we all calm down?"],[959,1255,"Alpha Dominic is our guest, after all."],[1280,1547,"Let's take it inside, talk it out."],[1659,1897,"There is nothing to talk about."],[2698,2815,"Alpha Dominic,"],[2836,3053,"let me jog your weak memory."],[3094,3199,"Five years ago,"],[3261,3445,"your pack attacked us"],[3499,3791,"and killed our Luna, my wife."],[3949,4058,"I'm sorry for your loss,"],[4112,4270,"but that was done by the previous Alpha."],[4366,4429,"I'm different."],[4487,4617,"I will amend his mistake."],[4629,4875,"Your pack committed the crime."],[4909,5038,"And I will die"],[5059,5221,"before I will have my daughter"],[5221,5388,"marrying into your pack."],[5930,6018,"My apologies,"],[6068,6256,"I should have made my offer more clear."],[7040,7169,"Once I marry your daughter,"],[7319,7578,"I will protect her and your pack."],[7599,7753,"No one will touch your pack."],[7766,7995,"Is this an offer or an order,"],[8058,8208,"dear grand Alpha Dominic,"],[8279,8354,"or a threat?"],[8412,8454,"Offer,"],[8521,8579,"of course."],[8746,8950,"But no one says no to my offer."],[9059,9188,"Sounds like a threat to me."],[9388,9488,"Only if you're scared."],[9576,9655,"Are you scared?"],[10035,10231,"What if I say no?"]],"5":[[100,212,"You don't wanna find out."],[329,442,"I'll never marry you."],[517,621,"I already found my mate,"],[621,746,"and I'm engaged to him."],[767,875,"Call off the engagement."],[996,1092,"You got a wrong guy."],[1146,1267,"I am your only mate."],[1409,1547,"That's my fiancée, bastard."],[1547,1601,"Hey!"],[1739,1797,"No!"],[1835,1893,"Harrison."],[2314,2423,"Remember this,"],[2485,2681,"because I won't use my words next time."],[2907,2982,"Evelyn Walker"],[3082,3165,"belongs to me."],[3261,3424,"I belong to no one but myself."],[3787,3841,"Feisty."],[3991,4049,"I like it."],[4112,4233,"I'll let you two cool off now,"],[4258,4371,"but I will see you very soon,"],[4558,4642,"my future Luna."],[5313,5367,"Harrison,"],[5534,5605,"are you okay?"],[5643,5839,"Evelyn, what the hell just happened?"]],"6":[[87,229,"Harrison, please believe me."],[300,392,"I had no idea"],[392,625,"he was the Alpha of the Ironclaw Pack"],[625,754,"when I saved him last week."],[809,950,"He told me he was my mate,"],[950,1059,"and, and I just,"],[1092,1188,"I thought he was crazy."],[1197,1326,"But then he comes here today."],[1355,1534,"Alpha Dominic is your mate?"],[1580,1685,"I don't care about that."],[1714,1789,"I chose you."],[1835,1935,"No one can change that."],[1985,2064,"You two,"],[2106,2260,"you need to get married soon."],[2302,2452,"We've got no time to waste."],[2519,2681,"When Harrison marks you,"],[2702,2898,"Dominic must back down."],[2948,3157,"What if Dominic flips out"],[3178,3365,"and declares war on us?"],[3415,3532,"Dominic is an Alpha"],[3586,3845,"and an Alpha would never declare war"],[3845,3916,"over a woman."],[3941,4187,"He certainly wouldn't be the first."],[4283,4400,"What do you say, Evelyn?"],[4496,4554,"Marry me now."],[4562,4758,"I promise to protect you"],[4758,4950,"and cherish you forever."],[5100,5142,"Yes,"],[5209,5284,"of course."],[5363,5447,"I trust you."],[6289,6423,"Your surgery went well, Aaron,"],[6460,6535,"but you'll need to rest"],[6535,6610,"for a few months"],[6610,6694,"to fully recover."],[6731,6810,"Thank you, Ms. Walker."],[7298,7382,"What are you doing here?"],[7499,7595,"I came to see you,"],[7778,7832,"my Luna."]],"7":[[112,183,"You're deluded."],[204,433,"I am not your Luna and will never be."],[517,638,"Your pack killed my mom."],[796,955,"I would rather be dead than marry you."],[1096,1230,"I'm sorry for your loss,"],[1292,1493,"but you can't blame me for something"],[1493,1647,"that was done by the previous Alpha."],[1805,1897,"I'm not like him."],[2352,2569,"I will bring a new era of peace"],[2585,2698,"to all werewolves."],[3011,3061,"Peace?"],[3161,3207,"Really?"],[3315,3395,"My patient, Aaron,"],[3403,3578,"almost died because of your pack."],[3595,3691,"You expect me to believe"],[3691,3883,"you're some sort of peace-loving hero?"],[3958,4024,"Holy shit."],[4033,4108,"Alpha Dominic?"],[4141,4187,"Aaron?"],[4312,4471,"Thank you so much for helping us"],[4471,4546,"fight the invaders"],[4546,4625,"and ending the war."],[4654,4804,"You've brought peace to our pack."],[4821,4917,"You're a true hero."]],"8":[[25,200,"I only did what was right."],[275,429,"And I'm sure my Luna approves it."],[513,567,"Come with me."],[621,721,"I have a surprise for you."],[813,875,"I'm busy."],[1013,1109,"Aaron needs care."],[1180,1372,"Peace can't heal his war wounds."],[1497,1555,"But I can."],[3161,3294,"Thank you, Alpha Dominic."],[3553,3757,"Ms. Walker, you are so lucky."],[3974,4004,"Now,"],[4279,4320,"shall we?"],[4909,5109,"Let me down, you jerk."],[5480,5551,"Let me go."],[6035,6160,"Who do you think you are?"],[6835,6969,"Are you ready for your surprise?"]],"9":[[1163,1276,"How did you get this?"],[1388,1534,"I've never shared it with anyone."],[1797,1931,"We're mates, Evelyn."],[2072,2214,"Whatever our souls are made of,"],[2256,2323,"we are one."],[2502,2577,"I know you better"],[2577,2731,"than anyone ever will."],[2848,3061,"And soon, you will know too."],[3086,3194,"You need to stop this."],[3361,3457,"I'll never be yours."],[3958,4120,"The Ironclaw Pack"],[4137,4300,"is the strongest in the world."],[4375,4471,"Be my Luna,"],[4596,4721,"and everything I have,"],[4767,4934,"money, power, fame,"],[4971,5046,"will be yours."],[5217,5292,"You may have money,"],[5292,5434,"power, and fame,"],[5526,5647,"but when it comes to love,"],[5714,5855,"you're nothing but pathetic."],[5968,6151,"I don't love you and I never will."],[6364,6627,"I'm offering you to love me."],[6719,6873,"We're destined to be together."],[6927,7086,"Stop fighting it!"],[7520,7632,"I'm gonna mark you now."],[7686,7753,"You're mine."]],"10":[[0,70,"You're mine."],[212,258,"Don't."],[492,658,"Or I'll report you to the council."],[980,1238,"You are looking at the soon to be"],[1251,1338,"head of that council."],[3048,3123,"You're aroused."],[3186,3274,"I can smell it."],[4850,4900,"Don't cry."],[5046,5117,"I won't hurt you."],[5292,5388,"Then don't mark me."],[5914,5964,"Okay,"],[6081,6172,"I won't mark you now."],[6227,6377,"But I will mark you one day"],[6452,6539,"when you ask me to."],[6694,6790,"In your dreams."],[6911,7082,"Run all you want Evelyn."],[7148,7311,"You will come back to me."]],"11":[[283,346,"Dominic."],[458,688,"How dare you break off our engagement?"],[725,855,"I deserve to be your Luna."],[900,1076,"No one else can give you a stronger heir"],[1076,1117,"than me."],[1151,1209,"You know it."],[1317,1413,"I found my mate,"],[1522,1622,"and she'll be my Luna."],[1626,1747,"You're seriously"],[1805,1993,"willing to throw away our alliance"],[2039,2268,"over some worthless bitch?"],[2273,2519,"Evelyn Walker is my mate"],[2577,2677,"and my future Luna."],[2773,2882,"Disrespect her again,"],[2994,3065,"and your pack"],[3078,3228,"will be in a very big danger."],[3319,3357,"Get it?"],[3883,3933,"Dominic,"],[4137,4212,"you shouldn't have spoken"],[4212,4312,"to Jessica like that."],[4408,4600,"Now you're just getting started"],[4642,4742,"as your pack's Alpha."],[4817,4888,"But you're gonna need"],[4888,4992,"her pack's support."],[4992,5150,"All I need is Evelyn."],[5150,5188,"No."],[5338,5484,"No, your pack comes first."],[5580,5626,"Besides,"],[5663,5714,"did you know that"],[5722,5885,"she is a wolf-less Omega?"],[5955,6114,"Forget about her being your Luna,"],[6147,6377,"but a weak she-wolf like her?"],[6439,6619,"She can't give you a strong heir."],[6681,6827,"Evelyn doesn't have a wolf?"],[6965,7169,"That explains why she can't feel"],[7169,7248,"our mate bond."],[7298,7386,"Wolf-less or not,"],[7461,7557,"Evelyn is my mate."],[7599,7786,"And she'll make an excellent Luna."],[7820,7920,"She doesn't need a wolf."],[8008,8128,"She is powerful herself."],[8128,8187,"Dominic,"],[8249,8299,"listen to me-"],[8299,8512,"Mateo, I respect you as my uncle,"],[8554,8641,"but I'm the Alpha,"],[8679,8775,"and I'm calling the shots."],[9609,9688,"Are you nuts?"],[9709,9897,"Marrying Alpha Dominic's mate?"],[9909,10118,"You're asking to be killed, you moron."],[10118,10218,"I don't care, Mom."],[10256,10352,"Evelyn chose me."],[10410,10472,"We're in love."],[10523,10681,"You really think she'll still love you"],[10681,10835,"when she finds out what you've done?"],[10919,10998,"Mom, please."],[11081,11190,"You, you can't tell her."]],"12":[[1284,1363,"Dreaming about me?"],[1893,1939,"What the,"],[2039,2177,"how the hell did you get in here?"],[3232,3303,"Let me go,"],[3349,3428,"or I'll scream."],[3553,3607,"Please,"],[3670,3716,"go ahead."],[3757,3820,"Scream."],[3899,4024,"Let everybody know"],[4024,4145,"that I'm in your bedroom."],[4229,4304,"I’m okay with that."],[4354,4512,"How many times do I need to remind you?"],[4558,4671,"I'm already engaged."],[4671,4779,"I have a mate."],[4800,4875,"And how many times"],[4875,5017,"do I have to remind you"],[5025,5209,"that Harrison is not your mate?"],[5342,5513,"He doesn't stand a chance before me."],[5547,5672,"Harrison respects me,"],[5718,5764,"which is something"],[5764,5893,"you'll never understand."],[6072,6185,"Don't push it, Evelyn."],[6268,6473,"I do not tolerate disobedience."],[6485,6681,"And I don't tolerate being ambushed."],[6752,6898,"I want you out of my life."],[7257,7340,"But I love you."],[7436,7520,"You're my mate."],[7586,7674,"Oh, so it's all about"],[7674,7816,"the mate bond then, is it?"],[7953,7978,"Well then"],[7978,8170,"I have an easy solution for you."],[8254,8283,"What?"],[8387,8666,"I, Evelyn Walker of the Moonridge Pack,"],[8696,8779,"reject you,"],[8792,9000,"Dominic Crawford of the Ironclaw Pack."]],"13":[[271,583,"Accept the rejection, the pain will be gone."],[1042,1276,"I refuse your rejection."],[1914,2068,"I will help you find your wolf,"],[2289,2385,"even if it kills me."],[2519,2723,"This is the only way I can prove"],[2811,2944,"that we're meant to be together."],[3098,3199,"I don't have a wolf."],[3278,3461,"But why does my heart ache for him?"],[3820,3891,"Alpha Dominic,"],[4091,4241,"should we keep an eye on Evelyn"],[4250,4383,"in case she gets married secretly?"],[4491,4550,"She won't."],[4717,4829,"She's about to find out"],[4863,5017,"that no one can love her more than me."]],"14":[[41,129,"Harrison Warren,"],[183,404,"do you agree to take Evelyn Walker"],[425,521,"as your wife?"],[688,813,"Yes, I do."],[950,1113,"You take care of my daughter, Harrison."],[1272,1359,"Evelyn Walker,"],[1405,1589,"do you agree to take Harrison Warren"],[1589,1689,"as your husband?"],[1814,1856,"Yes,"],[1918,1947,"I-"],[4112,4158,"No."],[4254,4283,"No."],[4283,4400,"Stop, please."],[4400,4462,"I warned you."],[4517,4558,"No."],[4558,4708,"Evelyn Walker is mine."],[4713,4796,"Please, no."],[4808,4904,"Don't kill him."],[5584,5643,"Let him go."],[5872,5955,"Are you going to shoot me?"],[6193,6256,"Go ahead."],[6723,6773,"Do it!"],[7098,7244,"I know you better than anybody."],[7511,7640,"Then you know I'd do this."]],"15":[[296,342,"Don't!"],[462,500,"Don't."],[538,654,"You win, Evelyn."],[792,867,"Put the guns down."],[975,1051,"I've let him go."],[1088,1134,"Please."],[1347,1418,"Don't hurt yourself."],[1672,1856,"No one needs to get hurt."],[1889,2018,"Let's resolve it peacefully."],[2848,2940,"Just walk away,"],[2986,3148,"and all these are yours."],[3445,3495,"For real?"],[3607,3661,"Harrison?"],[4504,4675,"You really thought a billion dollars"],[4675,4842,"could buy you true love?"]],"16":[[29,133,"I always knew you're pathetic,"],[133,196,"Dominic."],[271,316,"But I didn't know"],[316,433,"you're also stupid."],[496,700,"I'll never leave Evelyn."],[734,838,"Not for a billion dollars,"],[838,980,"not for a billion years."],[1080,1138,"Harrison,"],[1159,1305,"you're the pathetic and stupid one."],[1380,1463,"Alpha Dominic,"],[1522,1622,"please don't listen to my son."],[1634,1705,"He's lost it."],[1801,1897,"One billion dollars,"],[1897,2064,"and we'll cut all ties"],[2064,2235,"to Evelyn and her family."],[2248,2352,"Mom, stop."],[2394,2464,"You fool."],[2548,2619,"How could you say no"],[2619,2765,"to all this money for a woman?"],[2798,2869,"She's nothing but"],[2977,3086,"trouble and shame,"],[3086,3182,"plus she doesn't have a wolf."],[3290,3495,"This is how you see my daughter?"],[3599,3787,"It's about the money and not her?"],[3832,3953,"I'm just being honest."],[4037,4124,"Any sane person"],[4124,4241,"would make the same choice."],[4387,4587,"This wedding is off!"],[4662,4829,"Evelyn, we're leaving."],[5046,5088,"Evelyn."],[5100,5167,"Follow her,"],[5176,5321,"and you're no longer my son."],[5455,5588,"Hey, Evelyn, come on."],[5747,5939,"You just don't get it, do you?"],[6022,6285,"No one can treat or protect you"],[6285,6364,"better than I can."],[6539,6723,"You are mine, Evelyn."],[6773,6919,"We are getting married"],[6919,7082,"in three days."],[7219,7269,"Be ready."]],"17":[[20,275,"Alpha Dominic will be here tomorrow"],[296,383,"to claim Evelyn."],[421,713,"I think Evelyn should go away."],[734,784,"No."],[875,1009,"I'm not leaving, Dad."],[1026,1080,"And I'm certainly"],[1080,1205,"not abandoning our pack."],[1230,1313,"You should leave."],[1376,1401,"But-"],[1401,1514,"It's for the best."],[1526,1655,"I am gonna go speak"],[1664,1826,"to the council president tomorrow."],[1881,2122,"An Alpha cannot go against"],[2122,2231,"a werewolf pack."],[3253,3315,"Alpha Dominic,"],[3415,3516,"we've searched the whole house."],[3570,3645,"Ms. Walker's not here."],[3928,3978,"Keep looking."],[4083,4262,"And do whatever it takes to find her."],[5113,5226,"Just as I expected."]],"18":[[221,312,"Mr. President,"],[337,525,"I am Alpha Justin."],[571,684,"I'm here to ask that"],[684,875,"you hold Dominic Crawford"],[875,950,"accountable"],[1042,1226,"for him forcing my daughter"],[1267,1363,"into marrying him."],[2252,2377,"Always delighted to see you,"],[2385,2448,"Alpha Justin."],[2623,2690,"Dominic?"],[2823,2936,"What are you doing here?"],[2969,3132,"Where is the council president?"],[4045,4149,"You're looking at him."],[4320,4466,"I'm the new council president."],[4658,4808,"You monster."],[5005,5205,"You now have the council"],[5205,5380,"under your fucking control?"],[5484,5576,"So be it."],[5659,5734,"I'm leaving."],[5764,5784,"Hey."],[5876,5905,"Hey."],[6164,6264,"You're not going anywhere."]],"19":[[12,129,"What do you want from me?"],[204,266,"I won't hurt you."],[396,513,"But I need you to stay here"],[588,709,"so Evelyn can come and get you."],[909,1138,"You can't use me to get to my daughter,"],[1138,1301,"you son of a bitch!"],[1555,1722,"Dominic's holding my dad hostage?"],[1964,2027,"Turn around."],[2118,2268,"We're not going to the airport anymore."],[2769,2902,"I've been waiting for you, my Luna."],[3073,3132,"Let him go."],[3374,3470,"Is that an order?"],[3703,3732,"No."],[4250,4329,"I'm begging you."],[4487,4554,"Please,"],[4650,4708,"let him go."],[5163,5313,"You know my soft spot,"],[5384,5426,"don't you?"]],"20":[[1434,1493,"Marry me,"],[1555,1651,"and become my Luna."],[1685,1797,"I'll let your father go,"],[1847,2043,"and I'll protect your pack with my life."],[2302,2402,"What if I refuse?"],[2919,3028,"I'll still let him go."],[3090,3370,"But I will never stop pursuing you"],[3445,3528,"until you're mine."],[3724,3762,"Fine."],[3991,4066,"I'll marry you."],[4149,4245,"But just to end this."],[4491,4525,"Hey."],[4700,4796,"Don't cry, Evelyn."],[4959,5246,"This marriage will be the new beginning."],[5338,5401,"You'll see it"],[5601,5651,"with time."]],"21":[[442,542,"Why are you here?"],[638,696,"Are you okay?"],[834,984,"Take them home, safely."],[1222,1355,"Don't forget your promise, Evelyn."],[1639,1751,"What did you promise him?"],[2147,2193,"Dad."],[2331,2373,"Dad!"],[2464,2527,"Say something."],[2635,2969,"You of all people, Evelyn."],[3011,3328,"How could you agree to marry Dominic"],[3399,3599,"and become his Luna?"],[3653,3757,"Did you forget"],[3799,3991,"that his pack killed your mother?"],[3999,4170,"I had to save you, Dad."],[4179,4366,"You are such a disappointment."],[4404,4592,"I never thought I would be ashamed"],[4592,4729,"to call you my daughter."]],"22":[[633,675,"Uncle."],[1009,1180,"Evelyn and I are getting married"],[1184,1263,"in three days."],[1405,1564,"Make sure the invitations go out"],[1564,1685,"to every single Alpha."],[1689,1914,"Don't you think that's a bit rushed?"],[2018,2102,"No it's not."],[2210,2302,"I've been waiting for this day"],[2310,2352,"long enough."],[2369,2410,"Dominic,"],[2498,2598,"marry Jessica,"],[2598,2857,"the trade empire falls into place."],[2957,3207,"Do you really think a wolf-less Omega"],[3278,3490,"is worthy of becoming your Luna?"],[3495,3624,"She is worthy"],[3682,3795,"if I say she is."],[3853,3970,"Anyone who doubts that"],[4008,4120,"can try challenging me."],[5488,5651,"So you're Evelyn Walker,"],[5722,5789,"the worthless-"],[5789,5818,"oops,"],[5876,6047,"I mean wolf-less Omega."],[6101,6185,"And who are you?"],[6214,6348,"I'm Jessica Santoro."],[6410,6510,"Dominic's fiancée."]],"23":[[116,229,"Aren't you going to invite me in?"],[850,913,"What do you want?"],[1017,1101,"Leave Dominic."],[1130,1242,"He's my fiancé."],[1368,1514,"Please, keep him."],[1543,1764,"Dominic is forcing me to marry him."],[1826,1868,"Believe me,"],[1868,1985,"nobody would be happier than me"],[1985,2131,"if this wedding is cancelled."],[2156,2268,"Oh please."],[2310,2406,"Don't play victim."],[2444,2598,"If you hadn't messed with his head"],[2610,2794,"using that ridiculous mate bond,"],[2794,2936,"he never would have broken off"],[2936,3128,"our engagement for someone like you."],[3157,3249,"Someone like me?"],[3265,3311,"Uh huh."],[3345,3616,"You're a useless, wolf-less Omega."],[3649,3720,"I know your type."],[3803,3883,"You think because you"],[3883,3995,"caught the eye of an Alpha"],[3995,4108,"that you hit the jackpot?"],[4166,4362,"You're nothing but a gold digging slut,"],[4400,4621,"desperate to crawl her way up."],[4658,4783,"Get out of my house."],[4884,4934,"Aww."],[4979,5055,"Truth hurts."],[5084,5130,"Doesn't it?"],[5251,5380,"Leave Dominic,"],[5380,5580,"or I swear I'll bury you"],[5580,5718,"and your filthy family."],[6126,6210,"Don't you dare."],[6277,6544,"No one touches my family!"]],"24":[[237,412,"You fucking bitch!"],[804,1096,"You can't steal my fiancé,"],[1184,1343,"you worthless whore."],[1722,1818,"I'll kill you"],[1906,2189,"before you lay your filthy Omega hands"],[2189,2318,"on my Dominic."]],"25":[[154,325,"Let go of my mate."],[1021,1088,"Dominic,"],[1151,1313,"she humiliated me first."],[1322,1484,"I was just defending myself."],[1730,1918,"Evelyn Walker is my mate,"],[1943,2043,"and the future Luna"],[2043,2177,"of the Ironclaw Pack."],[2239,2431,"You lay your hand on her again,"],[2502,2594,"you perish."],[2623,2865,"Our trade ends here."],[2898,2990,"Seriously?"],[3086,3261,"Threatening me for this bitch?"],[3311,3440,"Don't forget, Dominic."],[3549,3641,"Messing with me"],[3703,3899,"means starting a war with my pack."],[4187,4358,"I will never start a war,"],[4579,4838,"but I will definitely defend my pack"],[4975,5205,"and punish whoever started it."],[5213,5534,"He is willing to start a war just for me?"],[6385,6431,"You okay?"],[6819,7136,"No, Evelyn, you shouldn't fall for him."],[7136,7273,"I think you should go."],[7499,7582,"I don't wanna see you."],[7866,7966,"But I just saved you."],[8254,8279,"Oh,"],[8379,8479,"should I thank you?"],[8612,8675,"If it weren't for you,"],[8683,8721,"none of this"],[8721,8808,"would have happened to me."],[9192,9275,"I'll see you at the wedding."]],"26":[[58,175,"You fucking bitch!"],[266,392,"I'll kill you before you know it."],[975,1105,"I can help you with that."],[1685,1814,"I'm so happy for you."],[1860,1964,"Congratulations."],[2352,2435,"What are you doing here?"],[2552,2694,"I thought I told you to fuck off."],[2773,2857,"Walk away, now."],[2907,2977,"Dominic,"],[3053,3219,"I know we've had our differences,"],[3219,3415,"but let's bury the past."],[3449,3578,"I'm here to make peace"],[3591,3778,"and celebrate you and Evelyn."],[3849,3949,"One wrong move,"],[4070,4154,"and you'll regret it."]],"27":[[237,346,"He killed your mother."],[412,600,"You are such a disappointment."],[638,825,"I never thought I would be ashamed"],[825,967,"to call you my daughter."],[1322,1405,"Mrs. Walker,"],[1459,1547,"why aren't you dressed?"],[1547,1672,"The wedding is about to start!"],[1751,1835,"Leave me alone."],[1968,2031,"Honestly,"],[2056,2227,"if I was a wolf-less Omega like you,"],[2227,2306,"I would be grateful"],[2306,2481,"if Alpha Dominic even considered"],[2481,2610,"marrying a low-life like me."],[2848,2944,"Then why don't you go tell him"],[2944,3090,"to fucking cancel the wedding!"],[4454,4537,"Alpha Dominic,"],[4587,4679,"I, I tried to help,"],[4679,4738,"but she just wouldn't"],[4738,4833,"put the wedding gown on."],[4950,5080,"Did I ask for your opinion?"],[5780,5872,"But please, no."],[5872,5926,"Alpha Dominic,"],[5926,6018,"I'm so sorry."]],"28":[[37,154,"You don't like the dress, do you?"],[187,312,"I'll have some more sent over."],[433,567,"Not the goddamn dress."],[633,709,"Don't you get it?"],[742,855,"I just can't marry you."],[1026,1088,"Look at me."],[1180,1267,"I've been waiting"],[1267,1459,"since the moment you saved my life."],[1576,1772,"Saving you was the biggest mistake"],[1772,1847,"of my life."],[2298,2398,"You will change your mind"],[2398,2473,"after the wedding."],[2623,2698,"I can't wait,"],[2781,2919,"see you falling in love with me,"],[2919,3098,"desperately, day by day,"],[3111,3365,"until you realize you burn for me"],[3457,3582,"as much as I burn for you."],[4233,4337,"Now, get dressed, my Luna."],[4446,4537,"The guests are waiting."],[5476,5530,"Ms. Walker,"],[5643,5747,"it's time to head to the church."],[6531,6652,"Evelyn can't marry Dominic."],[6981,7102,"She's my fiancée!"]],"29":[[95,187,"Congratulations."],[367,483,"You're going to make a great couple."],[1680,1705,"Oh."],[1956,1993,"Ah."],[2723,2790,"Are you okay?"]],"30":[[367,446,"Don't blame me."],[504,621,"Blame Alpha Dominic"],[621,700,"for marrying you."],[1180,1217,"Mate."],[1384,1455,"Alpha Dominic,"],[1526,1597,"it's Ms. Walker."],[1659,1755,"Something happened to her."],[1780,1976,"No, that can’t be."],[2335,2435,"Mission accomplished."]],"31":[[116,158,"Stay back."],[158,225,"It's too dangerous."],[287,367,"Let me through."],[375,450,"Hey, sir, sir."],[458,546,"She's not dead."],[554,663,"I'm sorry for your loss!"],[667,742,"I can save her."],[788,880,"I will save her!"],[2581,2648,"No."],[2852,2973,"Evelyn."],[3140,3265,"This is all my fault."],[3762,3974,"You didn't deserve this."]],"32":[[250,350,"Find who's responsible."],[454,600,"They will pay with their blood."],[667,767,"Yes, Alpha Dominic."],[1780,1830,"Evelyn,"],[1901,2106,"I've missed you every single day."],[2223,2356,"I would do anything"],[2369,2485,"just to see you again."],[2494,2565,"Alpha Dominic,"],[2669,2761,"you have to stay strong"],[2806,2911,"for the sake of the pack."],[3253,3319,"Let's just go."],[4225,4346,"My darling daughter."],[4788,4854,"Alpha Justin,"],[4988,5142,"please, come with me."],[6498,6539,"Dad."],[6606,6852,"I'm just so glad you're okay."],[7027,7140,"What happened?"]],"33":[[33,137,"What happened?"],[600,671,"Don't blame me."],[738,850,"Blame Alpha Dominic"],[850,930,"for marrying you."],[2464,2506,"Evelyn."],[2569,2606,"Evelyn!"],[4137,4262,"Dominic thinks I'm dead."],[4379,4496,"He won't come after me now."],[4571,4733,"I'm just so glad you're alive."],[4884,5105,"Evelyn's not fully recovered yet."],[5146,5230,"She should stay here."],[5280,5422,"That way I could look after her,"],[5434,5601,"and it'll keep her away from Dominic."],[5747,5843,"It's for the best, Dad. - Yeah."],[5855,5951,"Okay."],[6322,6477,"I'll leave you two to it."],[6556,6610,"Okay."]],"34":[[125,258,"Are you out of your mind"],[266,346,"to bring her here,"],[350,496,"hiding behind my back?"],[517,650,"If Alpha Dominic finds out,"],[650,784,"he will eat us all alive."],[838,917,"Get her out,"],[959,1134,"or I'll tell her the truth."],[1167,1255,"Keep your voice down."],[1301,1372,"What truth?"],[1455,1555,"What are you talking about?"],[1764,1810,"Nothing."],[1856,1997,"Evelyn, you need to get some rest."],[2235,2344,"Have you got no shame?"],[2398,2577,"If Alpha Dominic finds out you're here,"],[2577,2744,"we're all dead because of you!"],[2761,2902,"Mom, what the hell are you doing?"],[3061,3319,"I'm trying to save your life, you moron."],[3428,3532,"I don't wish to be a burden."],[3953,4062,"Let her go."],[4208,4383,"You know what I'll do if she stays."]],"35":[[546,588,"Wait."],[675,754,"Is that me?"],[1830,1872,"Stop!"],[3874,3924,"Evelyn?"]],"36":[[33,75,"Evelyn?"],[308,379,"Is it really you?"],[550,688,"Don't tell me I'm just dreaming again."],[800,884,"You could kill me,"],[955,1084,"but don't hurt my pack."],[1159,1209,"No,"],[1263,1368,"I would never do that."],[1518,1760,"I'm just so goddamn happy you're alive."],[2923,2961,"Please,"],[3036,3249,"let's go back home and start over."],[3361,3482,"Your home was hell to me."],[3524,3607,"I would rather be dead"],[3607,3703,"than go back there with you."],[3974,4074,"You're not leaving me again."],[4921,4979,"Let me go,"],[5025,5121,"you asshole."],[5321,5392,"I can't"],[5480,5559,"and I won't."],[5747,5868,"I will never let you go"],[5868,5976,"out of my sight again."]],"37":[[100,237,"Let go of me."],[513,575,"Let me go."],[1059,1146,"I will let you go,"],[1197,1292,"if you promise me"],[1292,1422,"you will stay by my side."],[1518,1643,"I'll never promise that."],[1960,2056,"Then I have no choice."],[2218,2377,"I cannot lose you again, Evelyn."],[4270,4383,"If you hate me so much,"],[4508,4596,"why are you so wet?"],[4813,4863,"I'm not."],[6602,6719,"You can't hide it anymore."],[6831,6911,"You're my mate."],[7065,7119,"Tell me"],[7232,7323,"you burn for me"],[7340,7457,"as much as I burn for you."],[7782,7824,"What?"]],"38":[[70,233,"You want me to talk dirty too now?"],[437,629,"Why don't you just shut up and fuck me."],[725,855,"Isn't that all you've ever wanted?"],[975,1121,"To own me like I'm your property."],[1814,1914,"I love you, Evelyn."],[2022,2127,"Your love is nothing"],[2135,2239,"but twisted possession."],[2364,2581,"So just fuck me and get it over with."]],"39":[[3032,3115,"What do you want now?"],[3211,3315,"How about we make a deal?"],[3649,3716,"You are mine"],[3841,4008,"for 365 days."],[4070,4166,"And by the end of it,"],[4366,4487,"I'll make you fall in love with me."],[4692,4808,"What if I don't?"],[4967,5046,"Then I'll let you go"],[5217,5255,"for good."],[5334,5447,"You're really gonna let me go?"]],"40":[[16,112,"I'm a man of my word."],[329,362,"Fine."],[508,592,"But you can't touch me."],[725,829,"I won't sleep with you."],[1363,1476,"What if you change your mind?"],[1810,1926,"I'm a woman of my word."],[2181,2264,"Then I promise you,"],[2427,2502,"I won't touch you"],[3044,3136,"unless you beg me to."],[3465,3574,"That's never gonna happen."],[3720,3757,"Never."],[4183,4233,"We'll see."],[4992,5088,"Evelyn Walker?"],[5376,5497,"How could you be alive?"]],"41":[[45,254,"Why do you look so disappointed?"],[279,371,"No, no."],[450,529,"No, I'm, I'm just,"],[529,663,"I'm, I'm surprised."],[738,992,"No, I'm glad Ms. Walker is alive."],[1126,1355,"We should get her back to her pack."],[1447,1514,"Oh."],[1534,1697,"She stays here with me."],[1805,1876,"And soon enough,"],[1939,2039,"she will marry me"],[2110,2198,"and become my Luna."],[2268,2406,"How can she be our Luna"],[2444,2677,"when she is a wolf-less Omega."],[2702,2773,"I told you."],[2815,2990,"She doesn't need a wolf."],[3140,3224,"She's tougher"],[3253,3432,"than most women with wolves."],[3499,3595,"As a matter of fact,"],[3620,3795,"she'd been taking care of her pack,"],[3945,4062,"since her mother passed away."],[4212,4408,"If you will question my decision again,"],[4408,4454,"uncle,"],[4525,4746,"I will have to cast you out of Ironclaw."],[4975,5038,"Yes,"],[5259,5367,"Alpha Dominic."],[5626,5755,"It's nice to see you,"],[5860,5939,"Luna Evelyn."],[6168,6310,"Let's eat, shall we?"],[6861,6961,"Fucking hell."],[7023,7082,"I can't believe"],[7082,7257,"this bitch survived the accident."],[7374,7570,"But she won't be alive for long."]],"42":[[1589,1655,"Like what you see?"],[2002,2072,"I've seen better."],[3128,3240,"Just getting a fresh towel."],[3516,3645,"Unless you don't want me to cover up?"],[4921,4988,"What happened?"],[5084,5292,"He was all over me just hours ago."],[5359,5422,"All of a sudden"],[5422,5597,"he doesn't find me attractive anymore?"]],"43":[[346,542,"I think you're out of shower gel."],[554,692,"Can you get me a new bottle?"]],"44":[[713,784,"No sex,"],[850,900,"remember?"],[1030,1172,"You said you were a man of your word."],[1743,1885,"And you said you wouldn't beg me."],[2056,2160,"Who says I'm begging you?"],[2314,2456,"I just need shower gel is all."],[2565,2640,"You can go now."],[4183,4341,"Oh, but before you go,"],[4792,4888,"can you help me with this?"],[5138,5230,"If I touch her now,"],[5326,5422,"I won't be able to stop."],[5538,5630,"You're playing with fire."],[5801,5893,"You sure you want this?"],[5976,6122,"Oh, I'm not playing with fire."],[6431,6619,"I am the fire."],[7048,7086,"Ah."]],"45":[[529,596,"Are you going to break"],[596,684,"your promise now?"],[1001,1080,"You want me,"],[1159,1242,"I can smell it."],[1551,1664,"Beg me to fuck you."],[1968,2043,"I don't want you."],[2239,2406,"You're a bad liar, Evelyn."],[2590,2715,"Not only you'll beg me,"],[2827,2957,"you will scream my name"],[3061,3128,"with pleasure."]],"46":[[900,971,"Alpha Dominic,"],[996,1113,"Ms. Miller is here to see you."],[1718,1789,"To be continued,"],[1964,2018,"my mate."],[3528,3632,"Why do I feel so,"],[3770,3858,"so lost?"],[5046,5192,"Luke said you wanted to see me?"],[5451,5518,"Yes, I do."],[5659,5743,"This is Ms. Miller."],[5805,5947,"She's the most powerful witch"],[5947,6072,"in the Ironclaw Pack."],[6318,6527,"She can help you get your wolf back."]],"47":[[45,112,"Oh my God."],[196,287,"Is it really true?"],[433,538,"I'm a healer too."],[579,855,"And I've tried so many times, but-"],[855,980,"You can't find your wolf"],[988,1109,"because you've been poisoned"],[1109,1251,"by a witchcraft potion."],[1338,1372,"What?"],[1451,1551,"Who would do that to me?"],[1593,1768,"Someone you really trust."],[1789,1843,"Don't worry."],[1876,2002,"I know how to fix it."],[2039,2243,"I'll help you bring your wolf back."],[2339,2389,"But how?"],[2419,2535,"If you want your wolf back,"],[2535,2665,"your mate Alpha Dominic"],[2665,2865,"needs to pray during the full moon."],[2911,2977,"I'll help him"],[2982,3148,"connect with the Moon Goddess"],[3169,3399,"to guide you back to your wolf."],[3445,3490,"Really?"],[3649,3837,"I, I've heard that's really difficult."],[4124,4229,"You would do this for me?"]],"48":[[346,446,"Of course, Evelyn."],[638,734,"I'll do anything for you."],[913,1059,"Thank you, Dominic."],[1284,1434,"Tomorrow night is the full moon."],[1484,1618,"We need to prepare quickly."],[1710,1755,"Okay."],[1918,2035,"I'm gonna go tell my dad."],[2102,2202,"He'll be so happy."],[2619,2723,"Alpha Dominic,"],[2740,2819,"are you sure you want"],[2819,2940,"to go through with this?"],[2986,3073,"Once we begin,"],[3094,3236,"there's no turning back."],[3365,3507,"Did you see how happy she is?"],[3937,4141,"I'll do anything for that smile."]],"49":[[450,646,"Dominic's wolf, it's so strong,"],[684,763,"just like him."],[1080,1317,"It's time, Alpha Dominic."],[2035,2152,"What's the knife for?"],[2256,2360,"You're not gonna hurt yourself,"],[2360,2402,"are you?"],[2469,2531,"Block."],[2694,2823,"Ms. Miller, what's going on?"],[2848,2907,"Let me through."],[2944,3019,"I'm sorry,"],[3082,3174,"I can't."],[3232,3315,"Alpha Dominic,"],[3365,3445,"are you sure you want"],[3445,3553,"to go through with this?"],[3599,3695,"Once we begin,"],[3695,3832,"there's no turning back."],[3903,4033,"Did you see how happy she is?"],[4270,4362,"I will do anything"],[4491,4571,"for that smile."],[4717,4938,"To help Evelyn get her wolf back,"],[4946,5084,"you need to sacrifice"],[5084,5330,"using your blood and your wolf."],[5384,5522,"The process is painful"],[5522,5626,"and dangerous."],[5722,5818,"Once it's done,"],[5847,6022,"your wolf will grow weaker."],[6051,6135,"And if it fails,"],[6135,6335,"you could lose your wolf forever"],[6360,6435,"or even die."],[6485,6581,"Is it really worth"],[6589,6731,"risking it all for her?"],[6881,6986,"I've made my decision."],[7107,7273,"Go ahead and make preparations."]],"50":[[575,650,"Dominic, stop."],[867,984,"You can't do this for me."],[1063,1205,"You're the strongest Alpha,"],[1292,1447,"the leader of the Ironclaw Pack."],[1447,1584,"You can't lose your wolf."],[1639,1776,"I can't lose you either, Evelyn."],[2160,2206,"No!"],[2398,2569,"Dominic, stop, please."],[2606,2711,"Stop."],[2744,2915,"Don't do this, stop."],[3395,3586,"Ms. Miller, let me through."],[3649,3874,"Are you all right, Alpha Dominic?"],[3912,3970,"I'm fine."],[4241,4362,"Just bring her wolf back."]],"51":[[12,208,"Oh, Moon Goddess,"],[287,479,"please hear our plea,"],[517,738,"accept our sacrifice"],[792,1113,"and grant Evelyn Walker her wolf."],[3349,3395,"Mate."]],"52":[[0,41,"Mate."],[1034,1101,"Moon Goddess,"],[1188,1247,"please."],[1334,1459,"Please don't hurt him."],[2114,2189,"Dominic, I,"],[2298,2444,"I caused you so much pain."],[3053,3115,"Your wolf"],[3345,3474,"is as beautiful as you."],[3853,3966,"You're my mate, Dominic."],[4170,4266,"I can feel it now."],[4629,4738,"I'm so happy now."],[5017,5067,"Dominic?"],[5159,5292,"Dominic, please."],[5317,5442,"Dominic, don't leave me."]],"53":[[1055,1109,"Dominic."],[1226,1292,"You're awake."],[1401,1472,"How are you feeling?"],[1589,1643,"I'm fine."],[1747,1872,"My wolf helps me heal."],[2135,2243,"You risked your life and"],[2331,2414,"your wolf for me."],[2569,2656,"I can't even imagine"],[2665,2769,"how painful this must be."],[2952,3065,"Was it really worth it?"],[3211,3403,"This pain means nothing to me if"],[3557,3716,"it helped you get your wolf back."],[4020,4112,"You must be thirsty."],[4120,4216,"I'll go get you some water."],[4537,4713,"All I need right now is you."]],"54":[[1134,1322,"Oh, God, you're so wet."],[1918,2014,"Dominic, please."],[2364,2494,"No, I'm sorry."],[2740,2865,"I promised I wouldn't touch you."],[3132,3178,"Don't go."],[3486,3687,"Dominic, I'm begging you."],[3903,3949,"Take me."],[4045,4091,"Mark me."],[4233,4312,"I'm yours now."],[4579,4717,"I've always been yours"],[4846,4971,"from the moment I met you."]],"55":[[575,650,"That bitch."],[704,796,"She tricked Dominic"],[796,971,"into sacrificing his wolf blood,"],[1017,1163,"so she could get her wolf back."],[1163,1209,"Dominic's willing"],[1209,1322,"to risk his life for her?"],[1409,1509,"I totally underestimated"],[1509,1564,"that slut."],[1564,1659,"Oh, they're in love."],[1722,1860,"Can't keep their hands off each other."],[1926,2127,"It's disgusting that our Alpha"],[2156,2285,"has been lured by this"],[2285,2360,"worthless woman."],[2419,2452,"Now sure"],[2452,2573,"he's gonna marry her soon,"],[2615,2748,"and she's going to be our Luna."],[2790,2894,"That should have been me."],[2986,3103,"I won't let this happen."],[3219,3290,"What's our next move?"],[3361,3511,"Dominic's already suspicious of us"],[3520,3649,"having something to do with"],[3724,3816,"Evelyn's car accident,"],[3816,3962,"so we have to lay low for now."],[4091,4137,"So what?"],[4137,4354,"We just sit back and watch this whore"],[4354,4521,"become the Luna of Ironclaw Pack?"]],"56":[[8,45,"No."],[291,437,"We can't make a move,"],[538,700,"but I know someone else that can."],[804,975,"Well done, Beta Mateo."],[1101,1280,"Once I'm Luna of Ironclaw Pack,"],[1355,1480,"I'll make sure you're set for life."],[1764,1818,"Deal,"],[1910,2014,"Luna Jessica."],[2890,2965,"You're,"],[3203,3395,"Mateo from the Ironclaw Clan."],[3436,3490,"What do you want?"],[3712,3883,"I wanna help you get Evelyn back."]],"57":[[425,462,"Wow."],[608,713,"What a feast."],[917,1051,"Don't tell me you made all of this?"],[1071,1180,"Yes, I did."],[1242,1380,"We're having a guest tonight."],[1647,1701,"Dad."],[2147,2227,"Thank you for coming."],[2227,2285,"Oh yeah."],[2452,2527,"It's nice to see you,"],[2540,2606,"Alpha Justin."],[2865,2977,"I'll leave you two to chat."],[3011,3048,"Wait."],[3232,3399,"Evelyn has told me everything"],[3399,3511,"that you've done for her,"],[3541,3628,"taking care of her,"],[3649,3766,"risking your life"],[3816,3983,"to help her get her wolf back."],[4041,4241,"You are truly the only man"],[4254,4404,"worthy of marrying my daughter,"],[4475,4704,"and I am very grateful to you,"],[4704,4779,"Alpha Dominic."],[4817,4934,"And I do think it's time"],[4979,5125,"for us to let the past go."],[5196,5251,"And I know that"],[5259,5376,"her mom would want that too."],[5768,5830,"I'd like that."],[6160,6227,"Okay, you two,"],[6256,6339,"let's go celebrate."]],"58":[[183,229,"So Evelyn,"],[229,300,"how do you feel"],[300,458,"now that you've got your wolf back?"],[500,567,"It feels"],[671,817,"amazing, Dad."],[867,1084,"My wolf’s name is Anya,"],[1159,1347,"and we’re getting along so well."],[1376,1459,"Oh Evelyn,"],[1539,1630,"I want to undress you"],[1630,1856,"and taste every inch of your naked body."],[2027,2164,"I'm so glad to hear that."],[2181,2360,"You know that your mother's wolf"],[2360,2456,"was purple too."],[2506,2640,"You've inherited that from her."],[2744,2973,"Evelyn, I want to fuck you right now"],[2973,3136,"and go deep into places"],[3136,3332,"no man has ever been."],[3436,3628,"Dominic, what are you saying?"],[3628,3762,"My father's right here."],[3928,3987,"What do you mean?"],[4054,4141,"I haven't said a word."],[4220,4283,"Yes you did,"],[4283,4358,"I heard you."],[4400,4491,"You said you wanted to..."],[4567,4662,"Evelyn, are you okay?"],[4754,4925,"She's so cute when she blushes."],[5017,5113,"Just like last night"],[5113,5242,"when she begged me to stop."],[5330,5492,"Wait, no way."],[5576,5701,"Is she reading my mind?"],[5701,5759,"Yes,"],[5860,5980,"I'm reading your mind."],[6139,6235,"Well, that's incredible."],[6402,6598,"Your mother was a mind reader."],[6685,6844,"You've inherited her gift."],[6940,6994,"Cheers."]],"59":[[2198,2256,"Oh my God."],[2523,2606,"I'm pregnant."],[2773,2894,"Should I tell Dominic?"],[3078,3207,"What if he's not ready for this?"],[4758,4833,"Oh, you're here."],[4867,4996,"Dominic, what's going on?"],[5676,5830,"I had a dream of you leaving me."],[5943,6022,"And then I woke up"],[6106,6189,"and you weren't there."],[6331,6439,"I'm never gonna leave you."],[6610,6731,"Not even if you beg me to."]],"60":[[1326,1368,"Sir."],[1451,1539,"Yes, what is it?"],[1689,1793,"Ms. Walker is pregnant."],[2556,2615,"Fuck."],[2898,2940,"Well,"],[3115,3236,"we just need to be quicker."],[3624,3753,"Evelyn, there you are."],[3782,3841,"Harrison?"],[3887,4024,"What are you doing here?"],[4191,4275,"I'm here to rescue you."],[4304,4358,"Hey, come on,"],[4358,4429,"we need to leave now."]],"61":[[37,100,"Wait, wait, wait,"],[100,304,"but, but, but if Dominic finds out,"],[346,412,"he'll kill you."],[533,588,"Don't worry."],[621,704,"I have someone helping me"],[704,775,"get you out of here."],[867,934,"And once we do,"],[959,1130,"I will never let anyone"],[1130,1263,"take you away from me again."],[1576,1618,"But,"],[1735,1801,"I, I,"],[2152,2373,"I don't want to leave him."],[2690,2923,"I have my wolf back now and"],[3128,3349,"Dominic is my mate."],[3724,3853,"I can't leave my mate."],[4087,4241,"I thought I, I was your mate."],[4429,4558,"You, you chose me, come on."]],"62":[[663,713,"Dominic,"],[809,942,"our security has just informed me"],[942,1113,"that Harrison has snuck into the house"],[1130,1201,"and he and Evelyn"],[1201,1305,"are about to run away."],[1472,1543,"It's impossible."],[1647,1743,"She would never leave me."],[1822,1889,"She promised."],[1951,2077,"Then explain this to me."],[2469,2652,"She's just been stringing you along,"],[2690,2798,"lowering your guard."],[2827,3019,"Now, if you don't act now, Alpha,"],[3053,3278,"she will disappear with her old flame"],[3286,3374,"and you will never be able"],[3382,3470,"to find her again."],[4771,4921,"No one can take Evelyn"],[4921,4996,"away from me."]],"63":[[212,304,"I'm your chosen mate."],[304,425,