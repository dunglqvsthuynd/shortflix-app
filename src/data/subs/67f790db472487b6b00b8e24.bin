 talk to me"],[3287,3329,"like that!"],[3350,3450,"Is it so wrong for me to"],[3450,3600,"want you to come back"],[3600,3712,"and run the company?"],[3766,3866,"It's a hell of a lot safer"],[3866,4016,"than that dangerous racing"],[4016,4125,"you insist on!"],[4125,4275,"It’s fine to have dream,"],[4275,4337,"mom."],[4366,4508,"Ivy supports me,"],[4533,4783,"Ivy truly understands me."],[4837,4987,"I love her!"],[4987,5100,"And I will never"],[5108,5179,"divorce"],[5233,5325,"her!"],[5412,5512,"I'm pregnant!"],[5608,5675,"What?"],[5770,5858,"What?!"],[5900,5958,"Yes!"]],"54":[[29,116,"Yes."],[212,254,"I was going to"],[254,362,"wait for a better time"],[362,416,"to tell you"],[416,483,"but I think"],[483,637,"now is as good as ever."],[658,741,"Are you sure?"],[758,804,"Yes."],[804,891,"You're not just saying this"],[891,966,"to avoid a divorce."],[966,1075,"No."],[1308,1445,"Wonderful!"],[1508,1579,"The Carter family is"],[1579,1758,"getting a new heir."],[1812,1904,"I won't meddle"],[1908,2037,"in your affairs any longer"],[2037,2120,"as long as Ivy"],[2120,2266,"safely delivers the baby."],[2362,2575,"I'll prepare our grandchild"],[2654,2787,"to inherit the company."],[2812,2970,"You can do whatever you want."],[3079,3133,"Ivy,"],[3133,3283,"I’ll arrange a top-notch"],[3283,3383,"prenatal care package"],[3383,3550,"to look after you."],[3550,3616,"Nothing"],[3616,3845,"must happen to this baby."],[4350,4562,"Ivy, thank you."],[4612,4725,"You’ve given me"],[4725,5029,"the most incredible gift and"],[5120,5262,"I'm gonna spend my life"],[5262,5408,"protecting you"],[5450,5579,"and our child."],[5658,5741,"Me too."],[5808,6058,"I can't wait to meet our baby."],[6108,6175,"I wanna plan a"],[6175,6320,"special gender reveal party."],[6675,6762,"Baby I'm going to"],[6762,6850,"be a good mom."],[6904,7033,"I'll never abandon you"],[7033,7191,"like my mother did to me."]],"55":[[325,400,"Byron!"],[462,579,"The doctor just called!"],[579,675,"Dad woke up!"],[779,870,"Caref