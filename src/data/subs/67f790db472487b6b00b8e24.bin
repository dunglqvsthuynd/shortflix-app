0,"Who's there?"]],"29":[[666,720,"Ivy?"],[804,950,"What are you doing here?"],[979,1154,"This is my family's garage."],[1225,1412,"You're the genius mechanic"],[1412,1579,"I've been searching for."],[1975,2112,"I can hardly believe it."],[2362,2433,"Ivy,"],[2433,2583,"you never fail to amaze me."],[3262,3308,"So you're here"],[3308,3416,"to fix your car?"],[3416,3500,"Well, this"],[3525,3666,"isn't my race car."],[3683,3858,"Now it does need fixing,"],[3900,4091,"If the best mechanic around,"],[4091,4233,"would do it for me."],[4387,4558,"Do you have to race?"],[4783,4966,"Come on, it's my dream!"],[4970,5116,"And you'll support me, right?"],[5175,5366,"He loves racing so much."],[5391,5475,"I can't stand in"],[5475,5637,"the way of his dream."],[5716,5783,"Yeah."],[5808,5879,"Don't worry."],[5916,5979,"I'll make sure"],[5979,6129,"your car is in top shape."],[6141,6287,"It'll be the best on the track."],[6291,6454,"I knew I could count on you."],[6512,6625,"You're the best."],[7983,8108,"Sorry to break up the"],[8116,8254,"love fest between you two."],[8254,8391,"But Byron."],[8416,8470,"We've got a meeting"],[8470,8529,"with sponsors"],[8529,8666,"and we're already late."],[8666,8787,"Yeah."],[9058,9170,"See you tonight."]],"30":[[316,400,"Ivy."],[462,525,"How dare you"],[525,712,"deceive me and Byron?"],[775,887,"What are you talking about?"],[887,987,"I found out"],[987,1100,"that you are not the bride"],[1100,1170,"that was supposed to"],[1170,1250,"marry Byron."],[1333,1487,"Your sister, Beatrice"],[1487,1583,"should be."],[1691,1762,"I'm sorry,"],[1762,1845,"I can explain."],[1845,1937,"Enough."],[2025,2116,"I don't care"],[2133,2312,"why you took your sister's place."],[2325,2416,"Over these days,"],[2416,2570,"I've seen you have potential"],[2570,2720,"to be a good wife."],[2737,2858,"All you need to do,"],[2870,2966,"is convince Byron"],[2966,3083,"to quit racing,"],[3100,3158,"and return to"],[3158,3283,"the family business."],[3291,3391,"And I'll pretend like"],[3391,3458,"none of this"],[3458,3541,"ever happened."],[3575,3625,"You want me to"],[3625,3766,"keep deceiving Byron?"],[3845,3933,"Alongside you?"],[3933,4075,"Think about your father,"],[4075,4220,"in the ICU still."],[4262,4341,"You don't want him to be"],[4341,4454,"kicked out of hospital,"],[4454,4529,"do you?"],[4962,5000,"Byron,"],[5000,5204,"what am I supposed to do?"]],"31":[[366,462,"Come in."],[950,1029,"My mom gave you"],[1029,1150,"a hard time again?"],[1862,1962,"Is that your dad?"],[2050,2150,"Yeah, it's him."],[2233,2420,"He was a race car driver too."],[2533,2608,"Died"],[2608,2712,"in a big race."],[2712,2812,"And,"],[2920,3070,"that's why mom hates it."],[3262,3429,"She wants me to stop and"],[3429,3575,"take over the family business."],[3575,3662,"But I can't."],[3716,3850,"My dream and it's a dream"],[3850,3987,"that I shared with him."],[4025,4075,"I am going to"],[4075,4229,"do everything I can."],[4300,4483,"To make that dream come true."],[5900,5979,"Byron."],[6179,6283,"Do you trust me?"]],"32":[[187,300,"Are you talking crazy"],[300,416,"all of a sudden."],[429,475,"Byron,"],[475,562,"I'm not with you"],[562,620,"because I was"],[620,758,"planted there to"],[775,962,"spy on you for your mother."],[1016,1120,"I'm your wife."],[1287,1354,"If racing"],[1354,1462,"is what you wanna do,"],[1462,1595,"I'll support you."],[1875,1908,"You'll be"],[1908,2079,"on the highest podium."],[2116,2262,"I'm sure of that."],[3200,3233,"Byron,"],[3233,3333,"what are you doing?"],[3400,3520,"Ivy...I..."],[3729,3883,"I think I'm falling for you."],[6012,6095,"Remember"],[6095,6175,"how you said"],[6175,6245,"that you've"],[6245,6391,"never had sex before."],[6529,6654,"You're my first..."],[6945,7008,"Right."],[7008,7216,"And I'm gonna take it gentle"],[7216,7304,"and slow."],[7345,7550,"So you can really enjoy this."]],"33":[[462,562,"Where are we going?"],[566,600,"Look,"],[600,666,"I"],[700,858,"know my mom's been"],[858,958,"troubling you."],[1079,1166,"So I'm gonna do what any"],[1166,1316,"decent CEO should do."],[1387,1458,"To ensure that"],[1458,1500,"she doesn't"],[1500,1604,"trouble you anymore."],[2904,3066,"I'm heading out shortly,"],[3066,3275,"to discuss cooperations"],[3275,3616,"with the CEO of CMS."],[3716,3841,"You come with me."],[3945,4166,"Yes, I must come with you."],[4237,4429,"I need to keep a close eye on you."],[5016,5129,"Hello, this is Carter."],[5229,5329,"Ivy is indeed"],[5329,5483,"keeping a close watch on Byron,"],[5483,5666,"to make sure he focuses on work."],[5704,5916,"They just left to discuss a deal."],[6004,6104,"Don't worry."],[6141,6291,"I'll keep you updated."],[7154,7241,"Sir."],[7820,7900,"I thought you were just"],[7900,8058,"looking for an excuse to get out."],[8058,8091,"You..."],[8095,8295,"You really came to sign a contract."],[8295,8433,"And I'm so glad"],[8433,8641,"that you came to support me."],[8808,8937,"I've got something I want to show you."],[8937,9012,"Also,"],[9041,9137,"my mother."],[9241,9408,"She's not that easy to fool."],[9591,9716,"Come with me."]],"34":[[0,58,"Alright,"],[58,200,"why don't you"],[216,416,"Hope in and then..."],[541,691,"I'll take you for a little spin."],[754,845,"What about your hand?"],[987,1100,"You're still injured."],[1195,1387,"My hands are fine for a little"],[1433,1608,"once around the track."],[1725,1870,"You're not scared, are you?"],[1912,2037,"Scared?"],[2062,2200,"Why would I be scared?"],[2325,2466,"Perfect opportunity to see"],[2466,2550,"if there's any room for"],[2550,2687,"improvement with your car."],[2966,3079,"Yes m'am."],[4854,4958,"I think we can adjust"],[4958,5108,"your gear ratios a bit more."],[5287,5329,"And I will check"],[5329,5475,"your weight distribution as well."],[6037,6175,"Thank you for supporting me."],[6175,6275,"It..."],[6341,6437,"means a lot."],[6479,6575,"Make sure you rest that"],[6575,6687,"hands of yours."],[6779,6866,"I want to see you compete"],[6866,6983,"in your best form."],[7195,7262,"You sure know how to"],[7262,7362,"kill the mood."]],"35":[[262,329,"Byron."],[370,512,"Are you sure you're up for this?"],[570,708,"Your wrist..."],[762,850,"It's not healed."],[875,950,"He's right."],[950,1129,"My wrist is not okay."],[1129,1308,"I really need to see a doctor."],[1562,1712,"What are you guys talking about?"],[1720,1791,"Nothing."],[1891,1987,"Race stuff."],[2091,2195,"Let me see your wrist."],[2495,2583,"It's fine."],[2875,3033,"What are you doing here?"],[3112,3183,"Thought I'd drop by"],[3183,3241,"and see the guys"],[3241,3354,"that's about to lose to me."],[3475,3537,"Derek."],[3537,3591,"You've never"],[3591,3716,"beaten me in the past."],[3770,3900,"It's not gonna happen today,"],[3900,3995,"I think."],[4062,4154,"You gotta get used to"],[4154,4262,"second place."],[4279,4366,"You."],[4491,4545,"Byron."],[4562,4625,"Yeah."],[4675,4791,"Can we make a wager?"],[4900,4983,"I’m listening."],[5008,5100,"If I beat you."],[5179,5333,"I get to take Ivy"],[5350,5450,"out on a date."]],"36":[[16,150,"You are fucking insane."],[150,295,"You think I'm gonna use my wife"],[295,400,"as some kind of"],[441,487,"bet?"],[550,612,"What?"],[637,712,"Scared?"],[741,816,"Okay."],[891,1016,"I'm gonna make you a bet."],[1133,1295,"How about if you lose,"],[1379,1466,"you never"],[1479,1562,"speak to her"],[1600,1679,"again."],[1729,1800,"And let's see who comes"],[1800,1916,"in first place."],[2970,3183,"So after I win this race."],[3262,3475,"I got a little surprise for you."],[5891,5962,"What was that?"],[6033,6112,"Alright."],[6116,6216,"I need to be honest with you."],[6291,6425,"Byron's hand isn't fully healed,"],[6508,6541,"I tried to"],[6541,6625,"tell him to sit this one out"],[6625,6716,"but he won't listen."],[6725,6795,"What?"],[6979,7120,"Is he out of his mind?"]],"37":[[1850,1891,"Come on!"],[3304,3462,"I need to go to the hospital."],[3587,3662,"Ivy."],[4391,4491,"Ivy."],[4550,4625,"I guess dreams"],[4625,4729,"really do come true."],[4729,4866,"Congrats Byron."],[4929,5079,"You've proven yourself."],[5166,5362,"I'm so happy for you."],[5412,5550,"You know something, Ivy."],[5650,5812,"You're my lucky charm."]],"38":[[166,241,"Doctor,"],[287,429,"how’s my son’s wrist?"],[454,533,"Good thing you brought him"],[533,570,"when you did,"],[570,608,"otherwise,"],[608,650,"there was a risk of"],[650,762,"permanent damage."],[854,991,"The nurses are still bandaging him."],[1020,1158,"You can go in to see him shortly."],[1279,1391,"Okay, thank you doctor."],[1741,1866,"Thank you doctor."],[2187,2287,"Ivy!"],[2287,2450,"What did you promise me?"],[2450,2604,"Byron's wrist wasn't even healed"],[2604,2737,"and you let him race!"],[2762,2900,"Are you trying to get him killed?"],[2925,3020,"Please,"],[3095,3187,"let me explain."],[3187,3275,"Shut up!"],[3300,3354,"You better pray"],[3354,3445,"that byron's wrist"],[3445,3637,"doesn't have any lasting damage."],[3637,3762,"Or I won't let you forget it!"],[4687,4825,"You really scared me."],[5079,5237,"What happened to your face?"],[5537,5666,"Did somebody hit you?"]],"39":[[0,75,"No!"],[175,295,"I'm just going to the bathroom"],[295,400,"to wash my face."],[412,487,"Ivy."],[1287,1358,"Matt."],[1379,1483,"What happened today"],[1483,1658,"with Ivy at the hospital?"],[1775,1875,"What?"],[1875,2075,"Mom hit Ivy!"],[3500,3579,"Byron."],[3720,3845,"Just tell me that"],[3912,4016,"my mother hit you?"],[4200,4291,"It's nothing."],[4291,4416,"She's just worried about you."],[4437,4487,"Alright."],[4487,4608,"I am never"],[4608,4733,"going to let another person"],[4733,4862,"lay a finger on you"],[4862,5016,"even if it is my mother."],[5225,5329,"Thank you."],[5429,5604,"That's really good to be protective."],[5641,5745,"Byron,"],[5779,5929,"I didn't think you cared so much"],[5929,6029,"about your wife."],[6112,6279,"Now I know how to get to you."],[6625,6812,"Get me Ivy's auto repair shop."],[6812,6966,"Buy it out immediately!"],[7175,7312,"Byron, what sacrifices"],[7312,7370,"you're prepared to"],[7370,7525,"make for your wife."]],"40":[[262,345,"You know you could’ve stayed"],[345,512,"a few days for observation."],[512,729,"You don't need to rush out today."],[741,808,"No,"],[808,1079,"I hate the hospital smell plus,"],[1125,1262,"I miss our bedroom."],[2162,2250,"Give me a second."],[2425,2504,"Yeah!"],[2525,2579,"Boss,"],[2579,2741,"I find out what you wanted."],[2741,2895,"Ivy's father was severely injured"],[2895,3125,"and is in the ICU."],[3154,3300,"He needs a ton of money"],[3300,3437,"for medical bills."],[3466,3620,"Her sister Beatrice"],[3620,3737,"used those bills"],[3737,3925,"to force her into marrying you..."],[4362,4475,"Who was that?"],[4541,4662,"Ivy..."],[4866,5000,"You took your sister"],[5000,5262,"Beatrice's place and married me?"]],"41":[[233,370,"How do you know?"],[537,600,"I'm sorry."],[600,766,"I didn't mean to hide it from you."],[766,804,"I just..."],[804,937,"I didn't know what to do."],[966,1020,"Why..."],[1020,1091,"Why wouldn’t you"],[1091,1283,"confide in me? Or..."],[1379,1570,"Trust me enough"],[1587,1708,"to tell me I mean..."],[1750,2041,"Like...ever... You can..."],[2091,2312,"Really truly considered me"],[2370,2483,"as your husband?"],[2579,2666,"It's not that,"],[2666,2712,"Byron,"],[2712,2854,"I was just scared, I want..."],[2962,3004,"If you know"],[3004,3075,"I married you"],[3075,3150,"instead of Beatrice,"],[3150,3220,"what are you going to do?"],[3220,3275,"Ivy!"],[3275,3383,"I told you,"],[3383,3637,"you have me."],[3662,3750,"You don't have to go"],[3750,3908,"with this thing alone."],[3958,4033,"I mean..."],[4191,4337,"We're married, right?"],[4458,4541,"Yeah..."],[4620,4712,"Byron, I'm just"],[4712,4875,"so afraid of losing you."],[4929,5041,"Because I love you."],[5191,5308,"Sorry Byron..."],[5675,5837,"I think I need to be alone."],[7083,7145,"Hello."],[7145,7191,"Hey."],[7191,7329,"We're the demo team."],[7329,7525,"We're at your repair shop right now."],[7525,7708,"You better come clear out all this junk,"],[7712,7833,"or we're bulldozing it."],[7833,7887,"What?"],[7925,8041,"You can't do that!"],[8116,8229,"I'm coming now!"]],"42":[[300,375,"Hey!"],[587,795,"Move your junk out of here, pronto!"],[808,991,"Our boss already bought this place."],[991,1083,"What?"],[1083,1212,"No way!"],[1229,1362,"Read this."],[1620,1720,"Your dad"],[1720,1800,"took out a mortgage"],[1800,1962,"on this shop ages ago."],[2029,2179,"But he didn't pay it off."],[2204,2341,"So our boss bought it."],[2345,2458,"That's impossible!"],[2500,2645,"The shop meant everything to him"],[2645,2816,"and he never mortgaged!"],[2845,2983,"I'm done talking."],[3041,3191,"Move your junk!"],[3191,3320,"Or we'll do it for you."],[3479,3575,"Boys,"],[3595,3700,"tear it apart!"],[3729,3820,"No!"],[3970,4054,"No!"],[4354,4491,"That's my dad’s toolbox!"],[4491,4554,"Stop!"],[4679,4766,"Oh."],[4862,4929,"So this some thing"],[4929,5020,"means a lot to you,"],[5020,5116,"young lady?"],[5154,5229,"I wonder how upset"],[5229,5279,"you're gonna be"],[5279,5375,"when I break it?"],[5500,5579,"No!"]],"43":[[45,104,"Stop!"],[104,162,"No!"],[312,450,"No!"],[475,625,"The louder you scream,"],[662,800,"the more excited I get!"],[1737,1841,"Oh..."],[2029,2212,"Seeing you upset like that."],[2254,2370,"Just makes me want to mess"],[2370,2479,"with you more."],[2883,2975,"Here's the deal."],[3133,3291,"You spend the night with me,"],[3362,3433,"and I'll make sure"],[3433,3600,"they don't break too much."],[3629,3762,"Sounds fair, doesn't it?"],[3804,3962,"What you're doing is illegal!"],[3987,4112,"You have no right to vandalize"],[4112,4233,"my family's shop."],[4416,4516,"If you don't back off,"],[4516,4658,"I'm calling the police!"],[4729,4808,"Sweetheart."],[4875,4929,"The only way"],[4929,5050,"you're getting out of this,"],[5095,5270,"is by giving me what I want."],[6187,6229,"Take it."],[6229,6304,"Boss,"],[6320,6437,"Ivy's calling."],[6529,6679,"What you're doing is illegal!"],[6679,6795,"You have no right to vandalize"],[6795,6900,"my family's shop."],[6950,7000,"The only way"],[7000,7125,"you're getting out of this"],[7145,7354,"is by giving me what I want."],[7429,7516,"Ivy?"]],"44":[[41,66,"Wait!"],[66,150,"What's going on?"],[216,291,"Ivy's in trouble."],[362,425,"Let's go!"],[2254,2341,"You bitch!"],[2404,2512,"Don't try to run!"],[2879,2991,"Be a good girl."],[2991,3108,"Let her go!"]],"45":[[1262,1416,"I'm so sorry, I was late."],[1820,1945,"Who the fuck,"],[1991,2183,"gave you the audacity,"],[2216,2387,"to lay a hand on my wife?"],[2666,2854,"You guys sick of living or something?"],[3091,3179,"Answer it!"],[3354,3437,"Please!"],[3641,3729,"Spare us!"],[3783,3983,"We're just following orders."],[4008,4116,"Our boss,"],[4150,4358,"bought this land fair and square."],[4412,4545,"Without his say so,"],[4595,4791,"you’ll never get this dump back!"],[4816,5016,"Watch as your precious repair shop"],[5016,5133,"turns to rubble!"],[5575,5641,"Ivy,"],[5691,5750,"don't worry."],[5766,5954,"I'm not gonna let anything"],[5979,6154,"happen to your dad's repair shop."],[6225,6279,"First,"],[6283,6450,"let's get you home and"],[6500,6654,"tend to these injuries."],[6670,6770,"And Matt,"],[6862,6975,"after you teach these"],[6987,7100,"fuckers a lesson."],[7266,7479,"I want you to restore"],[7479,7666,"this place to its earlier state."],[7812,7937,"Yes boss!"],[8000,8150,"Let's get you out of here."]],"46":[[412,591,"I'm so glad you're okay."],[725,875,"So tell you what if you want,"],[887,1016,"I would get each and every"],[1016,1225,"one of those fucking bastards."],[1300,1362,"I thought you were"],[1362,1525,"still mad at me."],[1604,1658,"And you weren't"],[1658,1766,"going to come."],[1791,1875,"Listen, Ivy,"],[1875,1937,"what I..."],[2029,2237,"What I said in the hospital was stupid."],[2354,2508,"What I meant to say is that,"],[2545,2658,"is that..."],[2804,2958,"I've always really liked you."],[3137,3258,"Careful, Byron."],[3504,3620,"According to our agreement,"],[3620,3683,"we're supposed to"],[3683,3825,"get divorced in a year."],[3904,4058,"To hell with the agreement."],[4150,4262,"Ivy, I..."],[4612,4729,"I give up."],[4733,4883,"I'm not ending this relationship."],[4883,4987,"I want you."],[5058,5270,"I want to be with you forever."],[5279,5529,"I want you to be my true wife."],[5650,5750,"You mean..."],[5787,5925,"I love you, Ivy."],[6175,6254,"But..."],[6487,6562,"I don't know if you feel"],[6562,6695,"the same way about me."],[6937,7100,"I love you too, Byron."],[7362,7416,"I love you,"],[7416,7604,"like a wife loves her husband."]],"47":[[75,237,"What are you thinking about?"],[366,525,"Worried about the repair shop."],[712,775,"I never thought"],[775,875,"dad would mortgage it"],[875,987,"without telling me."],[1191,1333,"Yeah I guess,"],[1333,1491,"he didn't want to worry you."],[1550,1720,"He's going through a lot and"],[1900,2091,"he didn't want to put that on you."],[2300,2408,"I just feel like I haven't been"],[2408,2533,"a very good daughter."],[2650,2808,"Just working with him every day,"],[2816,2900,"and never noticed"],[2900,3016,"anything was wrong."],[3137,3220,"He must have been under"],[3220,3366,"so much pressure."],[3425,3562,"He'd never mortgaged it"],[3562,3641,"unless he felt like he"],[3641,3837,"really had no other choice."],[3954,4025,"Well."],[4041,4191,"Once Matt finds out"],[4212,4354,"who bought that land."],[4487,4625,"I'm gonna get it back for you."],[4716,4825,"I promise you that."],[5054,5175,"How'd I get so lucky?"],[5300,5375,"What do you mean?"],[5537,5654,"When I married you,"],[5654,5745,"I was prepared"],[5745,5912,"for a terrible marriage."],[6100,6162,"I never thought"],[6162,6233,"I'd have such a"],[6233,6395,"wonderful husband like you."],[6525,6612,"Ivy."],[6712,6812,"I'm the lucky one."],[6987,7162,"I have the most amazing,"],[7166,7295,"extraordinary,"],[7366,7479,"beautiful wife."]],"48":[[325,408,"I told you"],[408,504,"to pressure Ivy"],[504,654,"to move ou