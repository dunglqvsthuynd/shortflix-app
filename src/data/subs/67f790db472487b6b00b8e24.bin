n her an injection"],[1979,2087,"to reduce the fever."],[2225,2304,"Just be safe."],[2304,2354,"You should monitor"],[2354,2462,"her condition closely."],[2541,2687,"The fever doesn't subside."],[2708,2745,"You need to"],[2745,2850,"take her to the hospital,"],[2879,2975,"immediately."],[3066,3150,"Alright."],[3187,3283,"Thank you."],[3362,3475,"Dr. Smith."],[4337,4479,"Still feeling cold?"],[4516,4620,"Much better now."],[4745,4887,"Looks like I intervened at"],[4887,5033,"just the right time."],[5050,5175,"I'd be much more grateful,"],[5179,5283,"if you didn't force me"],[5283,5429,"under that cold water."],[5458,5720,"But you had a 104 degree fever."],[5837,6012,"What was I supposed to do."],[6095,6245,"You didn't have to."],[6266,6366,"To what?"],[6512,6600,"Kiss you?"],[6970,7179,"God, am I falling for Byron?"],[7212,7283,"No, Ivy."],[7283,7512,"This is only a contract marriage."]],"26":[[3212,3300,"Matt."],[3312,3400,"I want you to find out,"],[3404,3545,"what's going on with Ivy."],[3604,3808,"I want you to do it tonight."],[3937,4054,"Yeah."],[4337,4425,"Ivy."],[4441,4604,"How many more secrets"],[4604,4850,"are you hiding from me?"]],"27":[[712,854,"Did you stay up all night?"],[1887,1962,"What's wrong?"],[2087,2187,"Did something happen?"],[2212,2329,"Why?"],[2491,2650,"Did you hide all this from me?"],[2850,2883,"I don't know"],[2883,2991,"what you're talking about."],[3125,3312,"I paid your dad's medical bills."],[3500,3645,"If I hadn't had Matt"],[3695,3804,"go to investigate."],[4012,4100,"Were you planning on"],[4100,4241,"keeping this"],[4241,4366,"from me forever?"],[4712,4833,"I mean,"],[4854,4895,"why would you"],[4895,5041,"trust Beatrice over me?"],[5100,5225,"Husband."],[5266,5508,"You said this is all just an act."],[5537,5745,"We're getting divorced soon."],[5770,5954,"I had no choice."],[6500,6620,"To save my father."],[6620,6812,"I would do anything."],[7041,7116,"Hey."],[7666,7775,"You have me."],[7841,7920,"You don't have to go"],[7920,80