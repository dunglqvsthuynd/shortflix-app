f easy for"],[592,796,"impersonating the Davenport heiress."],[796,1001,"Mind your manners, or I'll have you"],[1001,1088,"thrown out!"],[1117,1226,"Not yet."],[1226,1343,"We're just getting started."],[1343,1426,"Did you forget?"],[1426,1676,"You have a newborn at home, Alyssa."],[1676,1801,"Have all the fun you want,"],[1801,1968,"but you have to actually at least"],[1968,2173,"net a man who can provide for you."],[2210,2402,"I've never seen Mr. No-Name here"],[2402,2573,"at any of my family's events."],[2573,2681,"Krystal"],[2681,2806,"Langley, right?"],[2806,2890,"You must be related to"],[2890,2952,"the Gordon Langley"],[2952,3111,"who oversees our developments."],[3111,3199,"That's right."],[3199,3274,"He's my uncle."],[3274,3440,"The Langleys are like royalty in the"],[3440,3574,"world of economics."],[3603,3766,"Krystal has a PhD from Oxford,"],[3766,3903,"and her uncle is one of the"],[3903,4120,"top experts in Davenport builds."],[4166,4316,"That's why Bennett Business"],[4316,4416,"is the obvious choice"],[4416,4529,"for this project."],[4529,4729,"Right, right."],[4729,4896,"Well, that's why I'd like to announce"],[4896,5034,"that from this day onward,"],[5034,5171,"Davenport Corp will be canceling"],[5171,5292,"all future projects with the"],[5292,5401,"Langley Estate."],[5526,5663,"Oh my God."],[5663,5893,"That is actually insane."],[5893,6043,"Who even are you?"],[6043,6193,"The CEO?"],[6193,6306,"The president?"],[6306,6398,"Oh, Alyssa,"],[6398,6589,"you better call the doctor."],[6589,6756,"Your postpartum delusion is"],[6756,6890,"contagious."],[7157,7269,"Hi, Uncle Gordon."]],"30":[[25,108,"Krystal!"],[108,200,"Who the hell did you"],[200,304,"just piss off?"],[304,400,"I was just"],[400,471,"fired from"],[471,550,"Davenport!"],[550,642,"They said Langley"],[642,700,"would never"],[700,738,"get another"],[738,817,"contract with them"],[817,880,"ever again!"],[909,992,"Who are you?"],[992,1134,"Does it matter?"],[1134,1280,"What does matter though,