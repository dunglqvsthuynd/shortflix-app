ng the victim."],[5163,5171,"Always playing the victim."],[5171,5267,"Only someone like Luke"],[5267,5351,"would fall for it"],[5351,5480,"over and over like this."],[5480,5613,"I'm sorry, Luke."],[5613,5743,"I figured Alyssa would know"],[5743,5860,"the Davenport heiress,"],[5860,5972,"you know, seeing how close"],[5972,6064,"she is to Alexei."],[6064,6147,"But..."],[6147,6331,"then she shoved me out of nowhere."],[6414,6715,"Alyssa, apologize to Krystal, now."]],"45":[[116,187,"Don't make me"],[187,258,"say it again!"],[258,358,"Tell Krystal"],[358,450,"you're sorry."],[450,517,"Why would I tell"],[517,604,"her I'm sorry"],[604,671,"when she tripped"],[671,846,"and fell by herself."],[846,880,"What do you"],[880,992,"mean by herself?"],[992,1076,"You expect us to"],[1076,1138,"believe that?"],[1138,1284,"Oh, I don't know."],[1284,1388,"She's always so"],[1388,1522,"weak and helpless."],[1572,1701,"Who knows?"],[1701,1805,"Maybe she was"],[1805,1914,"toppled over by"],[1914,2043,"a big gust of"],[2043,2202,"wind from the AC."],[2202,2344,"Let it go, Amy."],[2344,2448,"It wasn't Alyssa's"],[2448,2498,"fault."],[2498,2606,"I- I must have"],[2606,2673,"just tripped"],[2673,2786,"or something."],[2786,2936,"Ms. Langley,"],[2936,3015,"let me remind you"],[3015,3065,"that there are"],[3065,3148,"cameras"],[3148,3257,"everywhere."],[3257,3332,"Don't make us"],[3332,3449,"rewind the tapes."],[3449,3516,"Or you might find"],[3516,3636,"yourself in court"],[3636,3737,"for libel."],[3841,4029,"Alysa, I know you"],[4029,4141,"hate me, but"],[4283,4379,"you didn't have"],[4379,4483,"to break my"],[4483,4558,"grandmother's"],[4558,4612,"heirloom"],[4612,4725,"Patek Philippe"],[4725,4813,"watch."],[4867,4917,"You should be"],[4917,5000,"thanking me."],[5000,5080,"If this really was a"],[5080,5150,"family heirloom,"],[5213,5342,"it was fake."],[5417,5509,"What?!"],[5914,6031,"This is composite"],[6031,6122,"glass crystal,"],[6122,6222,"Ms. Langley."],[6356,6418,"You should be"],[6