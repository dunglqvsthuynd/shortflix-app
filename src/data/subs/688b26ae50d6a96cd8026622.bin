"],[1776,1868,"What's this?"],[1868,1926,"Middle school"],[1926,2027,"theater?"],[2027,2102,"Alyssa, I don't know"],[2102,2177,"where you found these"],[2177,2243,"D-listers,"],[2243,2293,"but we're not"],[2293,2385,"buying it."],[2552,2752,"Are you daft?"],[2752,2848,"I've never met"],[2848,2923,"someone who lacks"],[2923,3003,"such basic"],[3003,3136,"observational skills"],[3136,3203,"as you."],[3282,3386,"We are guests"],[3386,3499,"by Davenport's"],[3499,3636,"personal invite."],[3636,3716,"Back off, you"],[3716,3795,"dirty runt."],[3795,3933,"And stop oinking"],[3933,4091,"at Dr. Davenport."],[4091,4287,"No, no, wait."],[4287,4366,"We worked her like"],[4366,4433,"a slave for"],[4433,4500,"the past three years."],[4525,4583,"There's no way"],[4583,4625,"Alyssa's"],[4625,4696,"the one and only"],[4696,4804,"Dr. Davenport."],[4854,4938,"Alyssa,"],[4938,5063,"how could you"],[5063,5192,"lie to me like this"],[5192,5326,"for so many years"],[5326,5409,"over something"],[5409,5513,"so big?"],[5513,5659,"There's no point."]],"36":[[0,91,"Shit."],[91,254,"If Alyssa's Dr. Davenport"],[254,421,"we can't have her treat Lilly."],[446,654,"She'll kill her on the operating table."],[658,746,"We have to get to"],[746,863,"the Davenport project."],[863,1071,"Once we finish it, all the money and"],[1071,1242,"fame will be ours."],[1267,1393,"We'll have our pick of the best"],[1393,1576,"heart surgeons in the world."],[1710,1839,"Alyssa."],[1839,1997,"Dr. Davenport."],[1997,2102,"Seeing as how close"],[2102,2210,"you are to these three,"],[2231,2339,"could you possibly"],[2339,2419,"convince them to give"],[2419,2552,"Luke the big build project"],[2552,2686,"after all?"],[2686,2986,"I mean, just put in a good word for him."],[3086,3257,"For old time's sake."],[3257,3511,"I mean, you wouldn't be so selfish as to"],[3511,3687,"say no to that, would you?"],[3824,3974,"Of course not."],[3974,4149,"Seeing as you've asked so nicely,"],[4149,4350,"Miss Langley, I'll be happy to help"