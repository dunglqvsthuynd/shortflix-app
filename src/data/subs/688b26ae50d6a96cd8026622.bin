[3949,4033,"I'm warning you."],[4033,4195,"Back off!"],[4195,4337,"Or you will be eating your words"],[4337,4496,"when the truth comes out."],[5084,5221,"Don't be upset, Amy."],[5221,5376,"When the real Davenport heiress"],[5376,5513,"gets here,"],[5513,5672,"Alyssa the imposter,"],[5672,5855,"will get her just desserts."],[5855,6043,"You're right, Krystal."],[6043,6147,"The real Davenport heiress"],[6147,6339,"won't go easy on her."],[6339,6464,"Alyssa's dead, for sure."],[6623,6715,"Thank you, everyone,"],[6715,6931,"for coming tonight to my private show."],[6931,7115,"And thank you to Miss Davenport"],[7115,7349,"for gracing us with her presence."],[7349,7507,"Now, I would like to begin"],[7507,7736,"the evening with a duet"],[7736,7853,"and the most beautiful lady"],[7853,7899,"I know."]],"47":[[104,329,"That's the real Davenport heiress."],[329,400,"Alyssa,"],[400,563,"you've got a real storm coming."],[625,792,"Why does she look so familiar?"],[1514,1634,"Oh, my God, I didn't know"],[1634,1780,"Miss Davenport was such a good dancer,"],[1780,2035,"dancer, rich and pretty and talented."],[2035,2193,"They're a match made in heaven."],[2281,2423,"That woman on stage,"],[2515,2606,"why does she remind me"],[2606,2669,"of Alyssa?"],[2669,2744,"No shot."],[2744,2919,"Alyssa's a common whore."],[2919,3094,"She's nothing like Miss Davenport"],[3094,3182,"up there."],[3732,3887,"Alyssa?!"]],"48":[[788,850,"What do we do?"],[850,938,"If Alyssa's really"],[938,1001,"the Davenport"],[1001,1051,"heiress, we're"],[1051,1172,"screwed."],[2331,2414,"Could I ask you"],[2414,2502,"to keep my identity"],[2502,2652,"a secret for now?"],[2652,2806,"Of course."],[2806,2898,"But, why don't"],[2898,2952,"you just tell him"],[2952,3003,"you are the"],[3003,3153,"Davenport heiress,"],[3153,3232,"next in line to be"],[3232,3328,"CEO?"],[3328,3403,"No one will mess"],[3403,3490,"with you after that."],[3490,3557,"I like to play"],[3557,3699,"with my food."],[3883,3941,"Sorry."],[3941,4049,"It's just a bit drafty"],[4049,4162,"in here."],[4879,4938,"You're Jane"],[4938,5017,"Davenport,"],[5017,5121,"aren't you?"],[5121,5196,"Why did you"],[5196,5326,"lie to me?"],[5326,5351,"Luke,"],[5351,5405,"what are you doing?"],[5405,5484,"Let me go!"],[5484,5593,"Sir, you are"],[5593,5701,"mistaken."],[5701,5755,"She's my special"],[5755,5830,"guest."],[5830,5893,"She's not the"],[5893,5947,"heiress,"],[5947,6064,"Jane Davenport."],[6064,6214,"Right, of course."],[6214,6289,"How could a dirty"],[6289,6393,"skank like her be"],[6393,6514,"Jane Davenport?"]],"49":[[0,133,"She's not the heiress,"],[133,233,"Jane Davenport."],[325,404,"Well,"],[404,504,"if this is all"],[504,700,"a big misunderstanding."],[700,913,"Why don't you put this on,"],[913,1042,"and we'll go home?"],[1192,1351,"I'm sorry, Alexei."],[1351,1543,"It seems that I still have some personal"],[1543,1651,"business to attend to."],[1714,1822,"I'll be right out."],[2239,2456,"Luke, we're divorced."],[2456,2610,"And you have Krystal now."],[2882,2948,"Leave me alone."],[2948,3057,"You make me sick."],[3057,3244,"You're sleeping with him, aren't you?"],[3244,3328,"I'm a man."],[3328,3495,"I can see the way he's looking at you."],[3495,3707,"That creep, are you blind?"],[3707,3807,"Don't you see he"],[3807,3928,"has ulterior motives?"],[4116,4275,"You're the one who is blind here,"],[4275,4329,"Luke."],[4329,4450,"You still haven't realized what"],[4450,4575,"Krystal is up to."],[4633,4758,"And we are divorced."],[4758,4946,"So who I spend my time with is none"],[4946,5067,"of your business."]],"50":[[0,116,"Who I spend my time with"],[116,304,"is none of your business."],[567,621,"Fine."],[621,729,"I won't get into your"],[729,863,"business with other men."],[863,1042,"What I won't let you get away with is"],[1042,1205,"you messing with us."],[1205,1376,"Messing with you?"],[1376,1622,"I came here tonight to talk"],[1622,1751,"with Ms. Davenport."],[1751,1951,"We were hoping Alexei would"],[1951,2072,