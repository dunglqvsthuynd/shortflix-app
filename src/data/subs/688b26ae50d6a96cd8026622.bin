s Alexei Trudova's"],[2039,2127,"private show."],[2127,2293,"I don't care what mistress you are."],[2293,2481,"You can't waltz in here willy-nilly."],[2523,2606,"Ew!"],[2606,2715,"Get out!"],[2823,2886,"Are you deaf?"],[2886,2990,"Get out of the way!"],[3582,3787,"Oh my God, Alexei!"],[3787,3874,"Alexei!"],[4087,4154,"I'm sorry for the wait,"],[4154,4233,"Miss Davenport."],[4433,4554,"She doesn't have a ticket because"],[4554,4688,"she's on my invite list."],[4688,4813,"So if you have any questions,"],[4813,4988,"please direct them to me."]],"42":[[300,462,"Oh my God."],[462,671,"That woman's friends with Alexei."],[671,788,"Look how protective"],[788,875,"he is over her."],[875,955,"What if she's not"],[955,1092,"some guy's mistress?"],[1092,1167,"What if she's..."],[1180,1313,"Alexei's girlfriend?"],[1593,1735,"She just divorced Luke,"],[1735,1901,"and she's already got her hands"],[1901,1993,"on the Davenports"],[1993,2085,"and Alexei?"],[2131,2202,"Ugh!"],[2202,2427,"She doesn't deserve to have anything!"],[2427,2577,"See, I told you, Luke."],[2577,2686,"You should have known she's just a"],[2686,2761,"cheap whore."],[2761,2857,"Oh, don't say that, Amy."],[2857,3011,"I'm sure Alyssa and Alexei"],[3011,3115,"are just friends."],[3115,3253,"Alyssa's the penniless orphan"],[3253,3428,"without any money or fame."],[3428,3578,"Alexei, her friend?"],[3578,3749,"More like her customer."],[3749,3924,"Shut up."],[3924,4104,"Or get out."]],"43":[[12,87,"Thank you for your"],[87,216,"help, Alexei."],[216,266,"Don't worry about"],[266,312,"anything,"],[312,396,"Miss Davenport."],[396,454,"Just enjoy"],[454,563,"yourself tonight."],[671,804,"Mr. Alexei,"],[838,959,"I was told the"],[959,1080,"Davenport heiress"],[1080,1155,"would be in"],[1155,1297,"attendance tonight."],[1409,1468,"Could you,"],[1468,1559,"perhaps, make us"],[1559,1659,"an introduction?"],[1659,1751,"I can't possibly"],[1751,1847,"do that, sir."],[1847,1997,"I'm just a dancer."],[1997,2068,"If you really"],