perate to meet the"],[5797,5968,"famed Davenports, are we?"],[5997,6135,"Well, you're in luck,"],[6135,6243,"Nathaniel Davenport"],[6243,6352,"will be here soon."],[6352,6539,"Not just him."],[6539,6639,"The three biggest execs"],[6639,6769,"that we have on the project"],[6769,6969,"will all be in attendance."]],"32":[[8,179,"The three biggest business execs"],[179,275,"on the project?"],[275,375,"News flash!"],[375,550,"They're all in the Forbes Top 10."],[550,692,"None of them care about events"],[692,771,"like this."],[825,930,"No way they'd all"],[930,1021,"show up here together."],[1021,1192,"Alyssa,"],[1192,1322,"come on."],[1322,1505,"I haven't heard anything about this."],[1505,1776,"I'm involved in every single detail"],[1776,1868,"of this project."],[1868,2014,"Ten seconds and they'll be here."],[2047,2164,"All right, everybody."],[2164,2352,"We're all socialites here."],[2352,2485,"How about we just throw her"],[2485,2631,"and her little boy toy out of the gala"],[2631,2786,"before they ruin everything?"],[2786,2890,"Throw them out!"],[2915,3019,"Throw them out!"],[3040,3161,"Throw them out!"],[3178,3261,"Throw them out!"],[3290,3382,"Not a chance!"],[4170,4258,"At your service,"],[4258,4412,"Mr. Davenport."]],"33":[[154,279,"They didn't give you a hard time, Jane,"],[279,379,"did they?"],[429,633,"Great timing, brother of mine."],[633,709,"Isn't that the president"],[709,884,"of Saint Mary's Hospital?"],[884,988,"Why did the bodyguards"],[988,1113,"call him Mr. CEO?"],[1163,1242,"Nathaniel Davenport is the"],[1242,1376,"acting CEO,"],[1376,1564,"president, and the youngest ever"],[1564,1639,"chairman of the board"],[1639,1751,"at Davenport Corp."],[1751,1918,"How do you not know that?"],[1939,2035,"Everyone in these"],[2035,2231,"upper circles knows who he is."],[2231,2431,"Well, that explains it then."],[2477,2623,"She must have wormed her way into"],[2623,2740,"his inner circle."],[2740,2894,"That's certainly why he was so eager"],[2894,3036,"to help h