4,6502,"She's going to his private event"],[6502,6581,"tonight."],[6619,6756,"Maybe, we can meet her there."]],"38":[[4,133,"Alexei's private tickets are"],[133,279,"notoriously hard to get."],[279,400,"Even I know that."],[513,654,"We could spend our entire fortune,"],[654,759,"and we still might not get it."],[821,988,"Well, we're in luck."],[988,1180,"I happen to have a friend who's his PA."],[1226,1363,"He'll get us in."],[2039,2177,"Got a surprise for you, munchkin."],[2431,2506,"Your favorite celebrity's"],[2506,2581,"coming to town."],[2635,2727,"Want to go see him?"],[2777,2848,"Oh my God."],[2848,2936,"Alexei?"],[2936,2977,"Mmm hmm."],[3036,3261,"Only the best Latin dancer in the world."],[3340,3470,"Look, Uncle Nate, I would love to,"],[3470,3545,"but"],[3545,3632,"his private show tickets"],[3632,3737,"are all sold out."],[3737,3820,"Well, you see, Jane,"],[3820,4037,"we are sponsoring their venue."],[4037,4233,"So if my little buttercup"],[4233,4379,"wants to go see a show..."],[4517,4612,"all we need is a word"],[4612,4704,"with the organizers."],[4825,4979,"No need for tickets."],[5017,5205,"Are you serious? -I'm serious."],[5251,5359,"That's amazing!"],[5359,5463,"I would love to!"],[5463,5597,"Thought you'd say that."],[5701,5797,"Thank you."],[5797,5930,"You're welcome."],[5947,6106,"Look, I know you and Uncle Jason"],[6106,6285,"have been trying to cheer me up."],[6285,6431,"I really appreciate it."],[6431,6527,"This is the best thing that's"],[6527,6589,"happened to me"],[6589,6698,"since the divorce."],[6781,6877,"I know."],[7036,7219,"Look, if it'll make you happy,"],[7323,7494,"Jason and I will do anything for you."]],"39":[[900,1051,"Wait."],[1051,1172,"I saw him in my dad's"],[1172,1263,"finance newsletter."],[1263,1384,"That's Luke Bennett,"],[1384,1559,"the up and coming real estate guy."],[1559,1618,"-Wow!"],[1618,1818,"He looks like a supermodel."],[1818,1976,"Who's the woman next to him?"],[1976,2118,"I'd kill to be his date."],[2118,227