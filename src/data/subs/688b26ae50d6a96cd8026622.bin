eck the number"],[2327,2444,"and try again later."],[2811,3086,"So you hate me that much, huh, Alyssa?"],[3232,3399,"Whatever."],[3399,3624,"I'm bringing you and our baby home."],[4383,4525,"Luke, the guest list for the Davenport"],[4525,4646,"Annual Gala just came out,"],[4646,4746,"and we're not on it."],[4746,4875,"What? Are you sure?"],[4875,4963,"I'm certain."],[4963,5096,"Krystal checked too."],[5096,5221,"We're the only major company"],[5221,5309,"that didn't get an invite."],[5309,5467,"If the others find out, your business"],[5467,5555,"is done for."],[5555,5638,"Amy,"],[5638,5897,"prep an expensive gift for me."],[5897,6022,"I'll go talk to the Davenport"],[6022,6118,"CEO myself."]],"52":[[704,871,"Seat of power."],[1330,1551,"Small gift from Uncle Nate."],[1551,1814,"Soon, I promise."],[1814,1960,"Once I take over the business, you will"],[1960,2081,"have all the time in the world"],[2081,2264,"to spend your days traveling the globe."],[2423,2581,"Luke Bennett wanted to see me."],[2756,2911,"Him? What for?"],[2961,3065,"Who knows?"],[3261,3399,"I said no."],[3399,3478,"Look,"],[3532,3707,"he's none of your concern anymore,"],[3707,3774,"Jane."],[3774,3853,"Okay?"],[3887,4049,"You're only job is to focus on taking"],[4049,4245,"over Davenport Corporations, huh?"],[4358,4458,"Leave it to me,"],[4458,4550,"Uncle Nate."],[4621,4696,"I'll do you proud at"],[4696,4821,"the annual gala tomorrow."],[5021,5171,"I wish your mother could see you now."],[5255,5388,"She'd be so proud of the woman"],[5388,5476,"you've become."],[5613,5722,"No, Mr. Bennett,"],[5722,5793,"you cant go in without"],[5793,5885,"an appointment."],[6060,6231,"President Davenport?"]],"53":[[154,421,"Mr. Bennett, the CEO is very busy."],[421,504,"You can't just come in here"],[504,621,"without an appointment."],[621,754,"President Davenport."],[754,855,"It's Luke Bennett."],[855,1021,"I am so sorry about before."],[1021,1297,"I brought you a gift to apologize."],[1297,1413,"I'm busy at the moment,"],[1413,1505,"Mr. Bennett."],[1505,1676,"I won't be seeing you out."],[2085,2323,"Alyssa, what are you doing here?"],[2323,2565,"That's the CEO's chair, Isn't it?"],[2619,2944,"Why? Why are you sitting here?"],[2944,3174,"You're not the CEO, are you?"],[3174,3261,"Now, Mr. Bennett."],[3261,3549,"Mr. Bennett, may I remind you that,"],[3549,3753,"the two of you are no longer married."],[3828,4004,"You're divorced."],[4004,4304,"So whether or not she's CEO."],[4354,4571,"It's no longer any of your concern, is it?"],[4571,4733,"Yeah, that's right."],[4733,4825,"We know Alyssa's"],[4825,4975,"not Jane Davenport."],[4975,5096,"So it doesn't matter if she lies and"],[5096,5255,"says she's CEO now."],[5305,5413,"President Davenport?"],[5451,5651,"I wanted to apologize"],[5701,6010,"on behalf of the Bennett Business,"],[6010,6143,"and for my family,"],[6143,6314,"for the way that they acted."],[6456,6798,"And I'd like to ask you for a favor."],[6906,6965,"Go right ahead,"],[6965,7102,"Mr. Bennett."],[7207,7365,"But it's up to her to decide."],[7453,7540,"Um."]],"54":[[0,58,"But it's up to"],[58,129,"her to decide."],[233,321,"Um."],[454,542,"Alyssa."],[542,746,"The Davenport Annual Gala"],[746,842,"is coming up."],[863,946,"Most of the big"],[946,1051,"companies will be"],[1051,1192,"present, and I..."],[1301,1363,"I'm not on the"],[1363,1422,"invite list."],[1514,1576,"So?"],[1576,1730,"The Bennet Business already"],[1730,1847,"lost the construction deal"],[1847,1997,"and if we don't even come to the"],[1997,2177,"Davenport Gala, we're doomed."],[2243,2335,"None of the other"],[2335,2410,"businesses would"],[2410,2469,"work with us"],[2469,2544,"ever again."],[2944,3073,"Are you asking me"],[3073,3228,"for a favor?"],[3228,3424,"Please, Alyssa."],[3424,3636,"Do you know how many times"],[3636,3782,"I begged you?"],[3782,3891,"Pleaded with you"],[3891,4054,"to listen to me?"],[4054,4183,"You didn't listen."],[4250,4350,"Not a single time."],[4859,4934,"Fine."],[5005,5138