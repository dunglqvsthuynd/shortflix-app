{"1":[[1818,1889,"Don't just stand there."],[1889,2006,"Patient's in V-fib."],[2006,2227,"Defibrillator! Charge to 200, stat!"],[2510,2623,"Clear!"],[2836,2932,"Clear!"],[2994,3115,"He's coming back."],[3319,3415,"Clear."],[3720,3824,"Pulses back to normal,"],[3824,3987,"Dr. Davenport."],[3987,4166,"Another patient brought back"],[4166,4325,"from the jaws of death."],[4325,4454,"You've done it again!"],[4662,4842,"No,"],[4846,4967,"we've done it again."],[5155,5271,"I'm all good here."],[5271,5405,"Go ahead and close up."],[6260,6393,"Mr. Davenport."],[6393,6602,"Are you out of your damn mind?"],[6602,6744,"Jane is no condition"],[6744,6881,"to be working in the OR!"],[6881,7015,"What is wrong with you?!"],[7219,7415,"Jane!"],[7415,7645,"Oh, come on, come on."],[7645,7753,"Have a seat."],[8024,8220,"Jane, please."],[8220,8354,"You're in your third trimester."],[8354,8462,"You're Davenport's heiress,"],[8462,8562,"you shouldn't be pushing"],[8562,8675,"yourself this hard."],[8687,8796,"Jason and I as your uncles,"],[8796,8888,"if anything bad would happen"],[8888,9096,"to you or the baby,"],[9188,9384,"we just couldn't forgive ourselves."],[9446,9576,"Please."],[9576,9667,"And don't even get me started"],[9667,9805,"with that husband of yours."],[9805,9997,"Always vanishing for days."],[10093,10210,"Luke's busy,"],[10210,10318,"okay?"],[10318,10493,"His company just went public."],[10493,10656,"He's got a lot on his plate."],[10656,10744,"Please."],[10744,10848,"That Bennett Business thing"],[10848,10906,"wouldn't have made"],[10906,10965,"it past day one"],[10965,11031,"without your help"],[11031,11098,"behind the scenes."],[11119,11336,"Luke doesn't know that I'm a doctor"],[11336,11540,"or that I'm from money."],[11540,11624,"As far as he knows,"],[11624,11745,"I'm just Alyssa."],[11745,11861,"I'm some orphan"],[11861,11982,"who grew up with nothing."],[12074,12208,"But he's never treated me like"],[12208,12303,"I'm anything less."],[12303,12512,"I'm happy with him,"],[12512,12696,"Uncle Jason."],[12696,12800,"Alright, Jane."],[12825,12879,"Alright."],[12979,13083,"We'll let Bennett Business"],[13083,13154,"take the lead"],[13154,13392,"on our new real estate project."],[13430,13542,"Really?"],[13542,13697,"Yes, but"],[13697,13842,"we are doing this is for you"],[13842,13988,"and the baby."],[14084,14172,"Not for him."],[14247,14385,"Now that Luke has a successful"],[14385,14518,"business of his own,"],[14518,14622,"he won't feel inadequate"],[14622,14718,"anymore."],[14756,14860,"I can finally tell him"],[14860,14985,"my real identity."]],"2":[[308,504,"Congenital heart defect."],[625,829,"This is a complicated case."],[955,1117,"No wonder Luke pulled so many"],[1117,1238,"strings to get the famous"],[1238,1355,"Dr. Davenport."],[1480,1568,"Dr. Davenport?"],[1568,1710,"The patient's here."],[1751,1843,"Let them in."],[2239,2364,"Daddy, daddy!"],[2364,2477,"Hold my hand!"],[2923,3028,"Luke?"],[3065,3182,"Thank you, Luke."],[3182,3353,"Dr. Davenport is the leading"],[3353,3511,"heart surgeon in pediatric care."],[3566,3641,"We never would have"],[3641,3716,"gotten this appointment"],[3716,3824,"without your help."],[4049,4154,"Don't worry about it."],[4154,4275,"That's what I'm here for."],[5088,5334,"Oh, it's your wife, Alyssa."],[5334,5413,"Oh, maybe it's"],[5413,5522,"something important."],[6139,6327,"Whatever it is, it can wait."],[6506,6727,"Lilly's health comes first."],[6727,6785,"Come on."],[6785,6923,"Let's go see Dr. Davenport."]],"3":[[291,408,"Dr. Davenport!"],[408,504,"Are you okay?"],[542,613,"Are you okay?"],[613,729,"Dr. Davenport."],[817,875,"Daddy!"],[930,1051,"I'm scared!"],[1121,1209,"Wait,"],[1209,1292,"did she just"],[1292,1409,"call Luke daddy?"],[1518,1568,"Guess we'll have to"],[1568,1614,"find another"],[1614,1693,"doctor today."],[1714,1805,"Don't worry."],[1805,1935,"I'll take care of it."],[2081,2177,"All those times he"],[2177,2273,"said he was busy,"],[2273,2406,"he wasn't working."],[2406,2560,"He was with her."],[3211,3332,"Hey."],[3386,3528,"Nate, the baby."],[3528,3620,"Is the baby okay?"],[3620,3728,"Baby's okay, Jane."],[3728,3778,"She's okay,"],[3778,3841,"but you"],[3841,3887,"almost went"],[3887,4033,"into early labor."],[4070,4304,"Hey, no more work."],[4304,4450,"I'm serious."],[4450,4537,"You need to rest"],[4537,4612,"now."],[4612,4683,"No more pushing"],[4683,4821,"yourself."],[4821,4934,"I don't want them to"],[4934,4996,"worry about me"],[4996,5084,"anymore."],[5242,5413,"Okay."],[5413,5484,"I'll take some time"],[5484,5584,"off."],[6614,6748,"Yo, Amy, I think your"],[6748,6915,"sister-in-law is here."],[7415,7486,"Amy!"],[7549,7620,"How much have"],[7620,7761,"you had?"],[7761,7820,"You know drinking"],[7820,7870,"like this"],[7870,7924,"is really hard on"],[7924,7978,"your liver."],[7978,8099,"Oh my god, Alyssa,"],[8099,8170,"spare me the"],[8170,8216,"lecture."],[8216,8354,"You're not my mom."],[8596,8704,"Let's keep this party"],[8704,8750,"going!"],[8892,9029,"Be careful, Amy!"],[9029,9146,"Get outta my face,"],[9146,9263,"you pregnant cow!"],[9263,9351,"You're ruining the"],[9351,9421,"vibes."],[9563,9680,"Ignore her."],[9680,9822,"Let's keep going."],[11019,11119,"Yo Amy."],[11198,11344,"I made this for you."],[11469,11565,"Amy, don't drink"],[11565,11615,"that!"],[11749,11840,"Your friend over"],[11840,11895,"here just"],[11895,12007,"drugged your drink."],[12007,12087,"You lying bitch."],[12087,12153,"How dare you"],[12153,12237,"accuse me of that!"],[12295,12391,"You saw nothing,"],[12391,12449,"okay?"],[12449,12545,"Guys!"],[12566,12600,"Let's get out of"],[12600,12625,"here."],[12625,12750,"This party's dead."],[13263,13329,"Fuck you!"],[13329,13405,"This is my brother's"],[13405,13446,"house!"],[13446,13509,"You don't get a say"],[13509,13592,"in what I do in it!"],[13592,13697,"I'm trying to protect"],[13697,13772,"you!"],[13772,13863,"Please."],[13863,13963,"Luke only married"],[13963,14051,"you because he felt"],[14051,14114,"sorry for you."],[14114,14218,"Orphan girl gets a"],[14218,14310,"pity wedding."],[14310,14360,"Now that his"],[14360,14406,"childhood"],[14406,14506,"sweetheart's back,"],[14531,14639,"you're done."],[15211,15311,"Krystal, Lilly!"],[15311,15411,"You're here!"]],"4":[[241,379,"Daddy!"],[379,563,"Who's that lady?"],[563,750,"Lilly, what have I told you"],[750,967,"about calling Luke daddy in public?"],[1030,1172,"Lilly Bennett."],[1172,1247,"Luke Bennett."],[1247,1547,"Is she really his daughter?"],[1593,1826,"Luke, I want to hear it from you."],[1910,2010,"Who are they?"],[2010,2110,"This is Krystal,"],[2110,2277,"Luke's childhood sweetheart."],[2277,2414,"She just got back from Oxford"],[2414,2527,"with a PhD and her daughter."],[2527,2669,"So, I think it's time"],[2669,2773,"for a certain someone"],[2773,2882,"to pack her bags."],[2882,2977,"Amy."],[3023,3136,"That's enough."],[3169,3332,"Alyssa, right?"],[3332,3632,"Well, this, this isn't what this looks like."],[3661,3849,"I'm just a new hire at Luke's company,"],[3849,3962,"and, well,"],[3962,4066,"we haven't quite yet found"],[4066,4233,"a place to stay, so"],[4233,4362,"Luke's been helping us out,"],[4362,4533,"you know, until we settle in."],[4621,4779,"But we will be out of your hair"],[4779,4954,"before you know it, I promise."],[5100,5188,"You hired your ex to"],[5188,5330,"work at your company?"],[5401,5526,"I just spent a fortune"],[5526,5613,"helping your business"],[5613,5689,"go public."],[5689,5830,"But you're just using your status"],[5830,5980,"to get back with your ex?"],[5980,6160,"How stupid am I?"],[6160,6331,"Of course he hired her!"],[6331,6514,"Krystal has a PhD in economics."],[6514,6610,"She'll actually help"],[6610,6715,"get his business somewhere."],[6715,6906,"Unlike a certain stupid housewife"],[6906,7061,"who never even went to college!"],[7061,7144,"Amy!"],[7257,7357,"Cut it out."],[7378,7586,"That's my wife you're talking to."],[7586,7832,"Luke, don't be upset with her."],[7832,7957,"Well, she's just protecting"],[7957,8108,"her big brother."],[8108,8187,"Look,"],[8212,8366,"I picked this up for you"],[8366,8475,"while I was in Paris."],[8562,8654,"I thought of you"],[8654,8858,"the moment I laid eyes on it."],[8858,9038,"Oh my god! Givenchy!"],[9038,9154,"It looks so expensive!"],[9154,9296,"Thank you!"],[9296,9547,"It's glass and metal."],[9547,9722,"You're fawning over costume jewelry."],[9722,9876,"Shut up!"],[9876,10022,"Like you'd know the difference?"],[10043,10197,"You've probably never seen a real"],[10197,10339,"ruby in your life."],[10372,10414,"Amy!"],[10539,10773,"Luke, I deserve the truth."],[10773,10940,"Who is she to you?"],[10940,11061,"Really?"]],"5":[[16,162,"Who is she to you?"],[162,291,"Really?"],[291,396,"Daddy,"],[500,692,"does Auntie Alyssa hate me?"],[692,875,"Did I do something wrong?"],[896,1067,"It's not what it looks like."],[1067,1184,"Krystal and Lilly are just"],[1184,1251,"gonna stay with us"],[1251,1355,"for a little while."],[1384,1514,"Right."],[1514,1743,"Tell me, Luke, who's her father?"],[2160,2248,"Lilly, sweetie,"],[2248,2456,"can you go play for a minute?"],[3253,3470,"You didn't have to scare her like that."],[3470,3616,"She has a heart condition."],[3653,3762,"You have to be careful."],[3803,3966,"So that's what this is?"],[3966,4112,"Her heart."],[4112,4283,"That is why you kept begging me"],[4283,4466,"to put you in touch with Dr. Davenport."],[4517,4754,"Because you're her father."],[4754,4867,"Actually,"],[4867,5100,"she's never had a dad, Alyssa."],[5100,5171,"The other kids,"],[5171,5467,"they tease her, call her names."],[5467,5651,"But hey, if we're not welcome,"],[5651,5797,"we will just leave, it's -"],[5905,6018,"Alyssa."],[6018,6318,"Please, can you be the bigger person,"],[6318,6448,"just this once?"],[6519,6723,"They don't have anyone else."],[6723,6998,"You bring your ex into our house"],[6998,7186,"with a child who calls you daddy,"],[7186,7407,"and I'm supposed to smile?"],[7503,7661,"And then swallow it?"],[7716,7907,"Luke, do you take me as a fool?"],[7907,8024,"It's okay Luke, we will just"],[8024,8112,"stay at a motel."],[8112,8316,"No! You won't!"],[8316,8416,"Luke owns this house."],[8416,8591,"He decides who stays."],[8591,8733,"If anyone's leaving,"],[8733,8825,"it's you!"],[8900,9059,"That's-"],[9180,9309,"What?"],[9501,9622,"Fine."],[9659,9772,"Fine, I'll leave."],[9909,10097,"Enjoy playing house."],[10222,10347,"Let her go."],[10347,10481,"She's got nothing."],[10481,10710,"No family, no money, no one."],[10710,10839,"Once she's out of here,"],[10839,10973,"she's just nothing."],[11169,11290,"Auntie Alyssa?"],[11290,11398,"Don't take my daddy"],[11398,11553,"away from me."],[11553,11745,"Please, Auntie Alyssa!"],[11745,11982,"I won't take daddy away from you!"],[11982,12062,"Please!"],[12062,12228,"Don't hit me!"],[12458,12562,"Oh, Lilly!"]],"6":[[41,154,"Lilly!"],[154,229,"Oh!"],[229,325,"Lilly!"],[325,454,"Oh my god!"],[479,604,"Lilly, are you okay?"],[604,784,"Don't touch my daughter!"],[838,930,"Yell at me,"],[930,1121,"hit me, do whatever you want!"],[1121,1263,"But don't you dare lay a hand"],[1263,1363,"on my daughter!"],[1363,1472,"She's sick."],[1472,1634,"What the hell is wrong with you?"],[1659,1893,"She's five, Alyssa, she's a kid!"],[1893,2022,"I, I didn't touch her."],[2064,2164,"She, she fell."],[2164,2293,"She hit the wall herself."],[2293,2444,"So you want me to believe"],[2444,2686,"that a five year old faked her own injury"],[2686,2802,"just to frame you?"],[2831,3019,"Why would she do that?"],[3019,3345,"I just wanted to say goodbye"],[3345,3628,"to Auntie Alyssa,"],[3628,3832,"and then she called me names,"],[3949,4016,"and said..."],[4016,4133,"What did she say?"],[4133,4433,"She said she wished I was dead!"],[4529,4754,"I never said that!"],[4754,4904,"Krystal must have put her up to this."],[4904,5038,"It's all an act!"],[5038,5234,"She's five!"],[5234,5355,"You think a child with a"],[5355,5451,"heart condition"],[5451,5572,"would fake that?"],[5572,5722,"Just to mess with you?"],[5759,5935,"God, Alyssa, apologize to her"],[5935,6014,"right now!"],[6081,6318,"Luke. We've been married for years."],[6318,6406,"Do you really have"],[6406,6498,"that little faith in me?"]],"7":[[25,62,"Look."],[62,141,"She's faking."],[141,246,"Look. Are you blind?"],[475,533,"Watch your"],[533,592,"damn mouth!"],[592,654,"Don't talk to my"],[654,746,"brother like that!"],[746,809,"What the hell?!"],[809,955,"She's pregnant!"],[1935,2031,"Luke!"],[2031,2135,"Luke! Oh my God,"],[2135,2235,"she's fainted!"],[2235,2318,"She's fainted!"],[2318,2410,"No, I'm losing"],[2410,2535,"my baby!"],[2606,2706,"Take me instead!"],[2706,2798,"I don't want to be"],[2798,2915,"here without her!"],[2940,2986,"No!"],[2986,3090,"Take me!"],[3123,3199,"Lilly!"],[3303,3361,"We need to get to"],[3361,3411,"the hospital!"],[3411,3440,"We don't have a"],[3440,3561,"moment to waste."],[3561,3666,"Luke!"],[3666,3853,"Please, help it hurts!"],[3878,4029,"Luke! Lilly"],[4029,4120,"needs you."],[4158,4312,"She could die."],[4358,4450,"No!"],[4491,4629,"Alyssa, please,"],[4629,4721,"she's just a child!"],[4721,4796,"Don't take this"],[4796,4871,"out on her!"],[4871,5034,"Let us go!"],[5221,5309,"I don't have"],[5309,5388,"time for this!"],[5388,5430,"When you're"],[5430,5492,"done pretending"],[5492,5572,"to be sick,"],[5572,5672,"drive yourself"],[5672,5768,"to the hospital!"],[6068,6160,"They all said I was"],[6160,6256,"lucky to have him."],[6256,6373,"But no one saw"],[6373,6498,"what I saw."],[6498,6539,"The truth is,"],[6539,6619,"The truth is,"],[6619,6685,"he was never"],[6685,6765,"there for me."],[7215,7282,"Uncle Nate,"],[7282,7469,"I, I need your help."],[7570,7686,"I need you."]],"8":[[308,392,"She's crashing!"],[392,546,"We need consent to operate, right now!"],[546,642,"Who's her husband?"],[1197,1355,"The doctor said shes's stable."],[1355,1547,"She's going to be okay."],[1630,1730,"Good."],[2114,2173,"Ugh."],[2173,2260,"Her again?"],[2289,2435,"She's probably got a whole speech lined"],[2435,2577,"up about how she's the victim."],[2594,2719,"I'm not in the mood."],[2965,3107,"What, that asshole's not picking up?"],[3107,3278,"No! Son of a bitch hung up on her."],[3278,3415,"We need this waiver signed, now!"],[3415,3532,"Her life's on the line!"],[3636,3712,"Screw him!"],[3712,3832,"Her husbands dead to us."],[3832,3928,"I'm her next of kin."],[4108,4204,"Alright, deep breath."],[4204,4295,"Ready?"],[4295,4391,"Deep breath."],[4408,4504,"And push!"],[4587,4658,"Alright."],[4704,4763,"One!"],[4796,4838,"Two!"],[4838,4909,"And push!"],[5601,5709,"Alyssa,"],[5709,5860,"I promise to love you"],[5860,6051,"forever and always."],[6256,6322,"In!"],[6322,6439,"Out!"],[6477,6556,"Out!"],[6556,6702,"Big push, big push!"],[6886,7002,"Luke! The baby just kicked!"],[7094,7190,"Where?"],[7215,7378,"There?"],[8316,8458,"Don't take this out on her!"],[8458,8621,"Let us go!"],[8829,8992,"I don't have time for this!"],[8992,9096,"When you're done pretending"],[9096,9184,"to be sick,"],[9184,9376,"drive yourself to the hospital!"],[10001,10231,"Luke, if I could do this all over again,"],[10231,10443,"I'd never choose you."],[10652,10731,"She's here!"],[10744,10852,"She's here!"],[10860,10969,"She's here!"]],"9":[[183,500,"Please, Lilly, baby. Wake up."],[533,725,"Mommy's right here."],[725,855,"You're going to be okay."],[1088,1205,"We'll figure it out."],[1280,1384,"I don't know what happened to"],[1384,1484,"Dr. Davenport,"],[1484,1634,"but whatever it takes."],[1634,1793,"We'll get her to see Lilly."],[1793,1876,"You've already spent"],[1876,1964,"so much on her."],[1964,2143,"Your wife is going to hate me."],[2143,2356,"Alyssa pushed Lilly."],[2402,2540,"She doesn't get a say anymore."],[2577,2723,"Lilly needs help now."],[2723,2861,"Davenport's her only shot."],[2877,2973,"Thank you."],[2994,3086,"I mean it."],[3107,3182,"I..."],[3249,3395,"I don't know what I would do"],[3395,3520,"without you."],[3641,3766,"Luke."],[3766,3983,"Luke, please help. This hurts."],[4308,4441,"Amy, can you stay with them for a bit?"],[4462,4592,"I need to check on Alyssa."],[4637,4729,"Please don't go."],[4771,4921,"Luke. I'm scared."],[4963,5100,"What if she has another attack"],[5100,5242,"and I..."],[5242,5305,"Please don't go."],[5305,5551,"Just stay for a few moments longer?"],[5551,5659,"I need to check on Alyssa."],[5780,6081,"Daddy, are you leaving?"],[6097,6243,"Hey! Hey, you're awake."],[6243,6348,"How are you feeling?"],[6348,6544,"I dreamed that I died."],[6573,6744,"I don't want to die."],[6781,6898,"Can you stay with me"],[6898,7002,"until I get better?"],[7032,7148,"Yeah, Luke."],[7148,7269,"It's Alyssa's fault Lily's"],[7269,7378,"here in the first place."],[7378,7515,"How could you just abandon her"],[7515,7678,"for that disgusting woman?"],[7757,7937,"All right, all right."],[7978,8062,"I'm here,"],[8062,8133,"Daddy's here,"],[8133,8254,"Daddy's not going anywhere."],[8254,8320,"Okay?"],[8320,8458,"Try to rest."],[8458,8600,"You're a good dad, Mr. Bennett."],[8600,8783,"We had a woman come in last night,"],[8783,9054,"early labor, heavy internal bleeding."],[9054,9230,"Poor thing almost died giving birth."],[9230,9330,"No sign of the husband."],[9330,9417,"Preterm labor?"],[9471,9547,"What's her name?"],[9580,9659,"Alyssa."],[9659,9726,"Where is she?"],[9747,9818,"Room 8."],[10418,10643,"Luke, we have been married for years."],[10643,10719,"Do you really have"],[10719,10835,"that little faith in me?"],[11040,11165,"Luke."],[11165,11327,"Luke, please help this hurts."],[11845,11945,"No."],[11945,12057,"Alyssa!"]],"10":[[41,246,"No, Alyssa!"],[462,546,"What the hell, man?"],[546,709,"Leave my mom alone!"],[846,1076,"There was a woman here,"],[1076,1172,"pregnant, went into labor early."],[1172,1267,"Where is she?"],[1267,1347,"She's not here."],[1347,1459,"Her family had her moved"],[1459,1593,"to the VIP floor."],[1593,1685,"Family?"],[1685,1893,"I thought Alyssa was an orphan?"],[2381,2485,"She's beautiful."],[2527,2660,"She looks just like you."],[2736,2852,"Where's Uncle Nate?"],[2961,3028,"He's just finishing up"],[3028,3148,"a surgery."],[3148,3274,"He'll be right over."],[3274,3390,"You should get some rest."],[3440,3574,"As for your husband,"],[3574,3741,"leave that jerk to me and Nate."],[3787,3928,"We'll deal with him."],[4083,4241,"I was killing myself."],[4316,4517,"Picking up extra shifts to take care"],[4517,4804,"of a patient who turned out to be the"],[4804,5000,"kid that he had with his ex."],[5109,5213,"You don't have to do any of that"],[5213,5292,"anymore."],[5292,5372,"Okay?"],[5409,5526,"You've got us."],[5572,5764,"And our little heiress is safe now."],[5860,5997,"I'll get you something to eat."],[6110,6247,"No more tears, okay?"],[6306,6414,"Just rest."],[6973,7040,"Alyssa!"],[7040,7119,"Oh my God."],[7119,7228,"Thank god you're okay!"],[7253,7478,"Are you okay? How's the baby?"],[7520,7632,"Don't touch me."]],"11":[[200,262,"Alyssa."],[262,433,"Please. I'm worried about you."],[433,546,"Oh, that's rich."],[658,746,"Now you're worried."],[746,838,"Thank you, Mr. Bennett,"],[838,905,"for taking a break"],[905,1042,"from your little affair to come"],[1042,1205,"check on your wife and newborn!"],[1272,1480,"What, would you like a trophy?"],[1480,1622,"A round of applause?"],[1826,1956,"Alyssa."],[1956,2160,"Lilly was also in critical condition"],[2160,2256,"last night."],[2427,2544,"Lilly is in danger."],[2544,2627,"Lilly needs me."],[2627,2806,"It's always Lilly with you, isn't it?"],[2873,2994,"What about Vivian?"],[3053,3211,"Is she not your daughter too?"],[3582,3778,"Oh, Vivian."],[3899,4058,"My beautiful little girl."],[4108,4270,"Vivian Davenport."],[4350,4479,"She's the best thing that's ever"],[4479,4608,"happened to me."],[4721,4875,"I just hope that she can live up"],[4875,5038,"to all that name can give her."],[5163,5359,"You gave her your last name?"],[5405,5622,"Davenport? Alyssa, she's a Bennett!"],[5655,5759,"She's my daughter!"],[5759,5935,"You don't get to just make that decision"],[5935,6018,"on your own."],[6047,6151,"Oh, Jesus."],[6151,6318,"You're impossible!"],[6318,6431,"Mr. Bennett!"],[6510,6731,"I think that it's time that you leave."],[6731,6890,"You are interfering with me"],[6890,7032,"and my daughter's rest."],[7040,7340,"Leave? What? I don't understand."],[7349,7507,"I want you out!"],[7561,7695,"From this moment on,"],[7695,7795,"me and my daughter"],[7795,7907,"want nothing to do with you."],[7907,8070,"I want you gone."],[8425,8612,"Stop! Ow! Luke, you're hurting me!"],[8612,8692,"Come on babe! I know you didn't"],[8692,8754,"mean that."],[8754,8854,"You're just hormonal."],[8854,8950,"But it's time"],[8950,9134,"for you and Vivian to come home"],[9134,9225,"with me!"],[9225,9271,"Stop, Luke!"],[9271,9351,"Come on!"],[9351,9480,"Luke, you're hurting me!"],[9480,9605,"Please! Stop!"],[9605,9713,"Ow! Ow!"]],"12":[[4,400,"Take your goddamn hands off my wife!"],[400,588,"Alyssa, who the hell is he?"],[633,763,"You don't deserve to know."],[763,917,"I have every right to know."],[917,1021,"I'm her husband."],[1051,1113,"Oh, yeah?"],[1113,1197,"Then where the hell"],[1197,1292,"were you yesterday?"],[1292,1493,"She almost died on that operating table"],[1493,1643,"while you were off screwing around"],[1643,1701,"with that other woman!"],[1701,1897,"You told him about Krystal?"],[1897,1926,"Wait, wait, wait."],[2022,2206,"What, are you sleeping with him?"],[2206,2331,"Is this why you won't come home?"],[2394,2577,"Excuse me?"],[2577,2727,"VIP suite."],[2727,2844,"In a place like this."],[2844,3048,"What is this? 400 grand a day?"],[3048,3465,"You have no family, no savings, no job."],[3465,3632,"So tell me, Alyssa,"],[3632,3799,"where is all this coming from?"],[3937,4170,"You're screwing him, aren't you?"],[4170,4300,"Behind my back."],[4300,4433,"And you're out here calling me"],[4433,4575,"a cheater?"],[4575,4708,