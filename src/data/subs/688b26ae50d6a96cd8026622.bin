t of here!"]],"59":[[684,821,"President Davenport!"],[821,975,"Thank God you're here."],[975,1067,"This skank has been"],[1067,1126,"going around"],[1126,1255,"saying she's the CEO."],[1255,1343,"You should throw her out"],[1343,1455,"of the building."],[1455,1534,"Oh, and it looks like"],[1534,1705,"boy toy's here, too."],[1705,1772,"Good on you,"],[1772,1864,"President Davenport."],[1864,1960,"You found Alyssa's"],[1960,2039,"other lover."],[2039,2193,"Shut up, you two."],[2193,2289,"You really don't have much"],[2289,2406,"for brains, huh?"],[2406,2540,"Never thought I'd live to see the day"],[2540,2619,"someone would call me"],[2619,2706,"a boy toy."],[2802,2965,"I'm Jason Davenport."],[3132,3353,"You're Jason Davenport?"],[3353,3428,"The VP of"],[3428,3536,"Davenport Corp?"],[3661,3749,"Jane,"],[3749,3874,"a moment, please."],[4041,4154,"Uncle Nate."],[4154,4241,"Uncle Jason."],[4241,4300,"Jane?"],[4379,4475,"Why did he call you"],[4475,4537,"Jane?"],[4579,4696,"What's all this about?"],[4758,4859,"Everyone..."],[4938,5105,"I would like to formally introduce"],[5105,5221,"my niece,"],[5221,5438,"and the only heiress"],[5438,5588,"to the Davenport Corporation,"],[5588,5734,"Jane Davenport."],[5864,5960,"No!"],[5985,6106,"Alyssa is-"],[6106,6281,"Alyssa is a skank!"],[6281,6423,"A whore!"],[6423,6556,"She could never be"],[6556,6694,"the one and only"],[6694,6869,"Jane Davenport!"],[6869,7023,"If she's really the heiress,"],[7023,7161,"we're screwed."],[7165,7278,"You're telling me my wife,"],[7303,7399,"the woman that"],[7403,7557,"took care of all of us."],[7557,7711,"The one we worked like a slave."],[7711,7786,"Was the heiress to"],[7786,7882,"one of the biggest companies"],[7882,8020,"in the world?"],[8033,8208,"No, Alyssa,"],[8208,8350,"I failed you,"],[8350,8404,"and you never even"],[8404,8500,"did anything wrong."],[8521,8591,"Alyssa,"],[8696,8829,"please."],[8829,8921,"We were married"],[8921,9042,"for so long."],[9042,9163,"How come you never told me"],[9163,9271,"who you really are?"]],"60":[[75,279,"I hid my identity from you because"],[279,508,"your ego was too weak to handle"],[508,571,"the truth."],[688,838,"I was helping Bennet Business"],[838,975,"behind the scenes, but now,"],[1001,1192,"I see you for who you really are."],[1338,1451,"So what"],[1451,1643,"if you are the Davenport heiress?"],[1685,1910,"You still hit my daughter, Lilly."],[1910,2210,"And your husband dumped you for me."],[2264,2460,"I really didn't want to do this, Krystal,"],[2460,2681,"but you have left me no other choice."],[2681,2873,"It's time to settle things."],[2873,3044,"Remember, Henry Clayton?"],[3228,3324,"What's with the face?"],[3324,3482,"Did I hit a nerve?"],[3561,3745,"You two must be close from the way"],[3745,3849,"that you're reacting."],[4054,4304,"I don't know anyone by that name."],[4304,4450,"Stop trying to lie to Luke"],[4450,4612,"to make me look bad."],[4913,5150,"I think you're the one lying to him."],[5271,5392,"Isn't that right?"],[5868,5976,"Good Lord!"],[5976,6101,"What is this?"],[6101,6185,"Wait!"],[6185,6343,"The woman in the photo looks"],[6343,6485,"just like Ms. Langey."]],"61":[[158,287,"Miss Langley."],[287,467,"You sure get up to a lot when you think"],[467,588,"we're not looking."],[725,784,"Who is it?!"],[784,880,"Tell me right now."],[880,1017,"Who is that guy in the photo?!"],[1017,1192,"How dare you cheat on my brother!"],[1192,1334,"Turn it off! Turn it off!"],[1334,1409,"Someone must have"],[1409,1501,"photoshopped it!"],[1559,1780,"I am going to sue you for libel."],[1780,1968,"Keep it on the screen!"],[2248,2310,"Krystal,"],[2339,2423,"I thought you said you loved"],[2423,2527,"doing it with me."],[2552,2673,"But, you were just stringing me along,"],[2673,2731,"huh?"],[2815,2923,"All this time you were out"],[2923,2994,"being a home wrecker"],[2994,3069,"in Luke Bennett's house,"],[3069,3123,"trying to get him to"],[3123,3203,"wife you up."],[3395,3666,"You're just a fake, backstabbing bitch."],[4312,4391,"Krystal!"],[4562,4846,"Tell me it isn't true."],[4996,5067,"Henry!"],[5067,5221,"You asshole!"],[5221,5392,"You ratted me out!"],[5722,5814,"Too bad, sugar."],[5910,6035,"Davenport paid me more."],[6143,6314,"And I mean, really, Krystal?"],[6314,6527,"Did you really think you could win"],[6527,6685,"against Jane Davenport?"],[7073,7152,"Krystal,"],[7253,7415,"You better tell me"],[7415,7695,"what the hell is going on."],[7695,7820,"Luke, you have to believe me."],[7820,7982,"I have never seen this man before"],[7982,8120,"in my life."],[8120,8312,"Scram, you hobo!"],[8312,8445,"You can't play your dirty little"],[8445,8562,"tricks on me."],[8562,8725,"Don't you know who I am?"],[8725,8879,"I am the sole heir"],[8879,9025,"of the Langley fortune!"],[9188,9246,"Langley?"],[9300,9413,"You mean like the Langley that went"],[9413,9534,"bankrupt ages ago?"],[9638,9784,"That's why you tried so hard to net you a"],[9784,10039,"rich husband to leech off of, right?"],[10039,10251,"Help! Help, Luke!"]],"62":[[0,83,"It's Alyssa!"],[83,212,"This must be Alyssa."],[212,383,"She hired this hobo to try to"],[383,513,"ruin my reputation!"],[575,692,"I'm innocent!"],[729,867,"Oh, innocent?"],[867,959,"Oh, you weren't so innocent"],[959,1101,"when you were in my bed, sugar."],[1201,1330,"Want me to count how many times we"],[1330,1397,"slept together?"],[1397,1568,"Shut up, shut up!"],[1626,1726,"I'm going to sue you!"],[1726,1793,"Do you hear me?!"],[1793,1931,"I will have you arrested"],[1931,2018,"and thrown in jail"],[2018,2110,"right this second!"],[2510,2635,"This bitch has been lying to you."],[2698,2831,"You know your mentor, who died?"],[2861,2873,"She's the one who killed him for the"],[2873,2961,"She's the one who killed him for the"],[2961,3048,"insurance payout."],[3123,3203,"Oh, and..."],[3261,3461,"bad news, buddy, but..."],[3461,3557,"your daughter Lilly?"],[3837,3920,"She's mine."],[3962,4112,"Luke, you, please,"],[4112,4254,"you have to believe me."],[4254,4391,"I.. I..."],[4391,4575,"You fucking snake!"],[4575,4763,"You fucking rat!"],[4884,5075,"It was you all along, wasn't it?"],[5075,5276,"You made me leave my wife."],[5276,5438,"Used me for your schemes."],[5568,5726,"I was a fool."],[5885,6018,"I let her down,"],[6110,6214,"and now she left me."],[6619,6740,"What are you doing here?"],[6781,6886,"Krystal Langley,"],[6886,6965,"Henry Clayton,"],[6965,7069,"you are hereby under arrest"],[7069,7240,"for suspicion of first degree murder"],[7240,7319,"via contract killing."],[7390,7494,"You have the right to remain silent."],[7494,7632,"Anything you say can and will be held against"],[7632,7707,"you in the court of law."],[7707,7845,"Contract killing?"],[7941,8099,"Who did you try to kill?"],[8099,8258,"I didn't..."],[8537,8708,"You hired a hitman on her? - No."],[8829,8975,"You're disgusting."],[9100,9217,"Get her out of my sight!"],[9217,9325,"No, no, no, no!"],[9388,9505,"I can't go to jail."],[9667,9747,"Luke, this is just a"],[9747,9855,"big misunderstanding!"],[9855,9964,"What about our daughter,"],[9964,10130,"you son of a bitch!"],[10130,10181,"No!"],[10231,10335,"No!"],[10335,10410,"NO!"]],"63":[[283,346,"Everyone."],[375,437,"Everyone."],[437,558,"May I have your attention, please?"],[558,629,"I have an important"],[629,721,"announcement to make."],[721,825,"Starting today,"],[825,900,"my niece,"],[900,1051,"Miss Jane Davenport,"],[1126,1213,"will be the new"],[1213,1426,"President and CEO"],[1484,1685,"of Davenport Corporations."],[2027,2106,"With you at the helm,"],[2106,2168,"Nate and I"],[2168,2302,"can finally rest easy."],[2381,2565,"We trust you, Jane,"],[2565,2656,"and,"],[2656,2752,"that's why we're leaving"],[2752,2861,"Davenport Corporation"],[2861,2973,"in your capable hands."],[3257,3361,"I will make sure to"],[3361,3424,"take care of the"],[3424,3599,"empire that you've built."],[3691,3849,"Davenport Corporations"],[3849,3920,"will be safe"],[3920,3987,"with me."],[6418,6531,"I stopped needing you"],[6531,6610,"to keep me warm"],[6610,6731,"a long time ago"],[6731,6827,"Mr. Bennett."],[6865,6936,"If I'd known"],[6936,6998,"you were the"],[6998,7111,"Davenport heiress earlier,"],[7111,7215,"maybe we could've..."],[7215,7344,"Could've what?"],[7453,7549,"Are you regretting"],[7549,7624,"divorcing me"],[7624,7732,"now that you know who I am,"],[7732,7841,"Mr. Bennet?"],[7841,7953,"No!"],[7953,8074,"I don't care"],[8074,8174,"about you being"],[8174,8308,"Jane Davenport."],[8308,8450,"I'd rather"],[8450,8541,"you be"],[8541,8621,"my Alyssa."],[8800,8996,"If you could just be mine."]],"64":[[367,525,"Jane, Jane,"],[583,625,"let's put this"],[625,750,"all behind us."],[750,846,"Start fresh"],[846,934,"with a clean slate."],[1017,1101,"I'll still be the"],[1101,1209,"Luke Bennett"],[1209,1309,"who loves you"],[1309,1413,"with his entire"],[1413,1509,"heart."],[1509,1559,"And, you'll be"],[1559,1659,"Alyssa again."],[1755,1801,"And we'll be"],[1801,1914,"together,"],[1914,2002,"forever."],[2335,2427,"You can't tell me"],[2427,2498,"to just"],[2498,2635,"forget the past,"],[2635,2690,"Luke."],[2786,2902,"Some things are too"],[2902,2982,"damaged to be"],[2982,3044,"fixed."],[3157,3286,"Alyssa,"],[3286,3440,"I'm sorry"],[3440,3578,"for how badly"],[3578,3728,"I treated you."],[3728,3837,"I didn't know how"],[3837,3945,"bad until today."],[3945,3995,"I-"],[4037,4087,"I was-"],[4087,4208,"I was too naive."],[4208,4371,"Too trusting."],[4371,4425,"I should have"],[4425,4466,"listened"],[4466,4567,"to you more."],[4567,4621,"Alyssa..."],[4621,4746,"You still don't get it,"],[4746,4850,"do you?"],[4950,5084,"I left you because"],[5084,5142,"you never"],[5142,5276,"took me seriously."],[5276,5388,"You never saw me"],[5388,5455,"as an equal."],[5455,5568,"In your eyes, I was"],[5568,5638,"worthless!"],[5747,5834,"We're on the same"],[5834,5968,"level now, Luke."],[6064,6131,"But I don't have"],[6131,6243,"to be yours."],[6393,6456,"Please,"],[6456,6589,"I'm begging you,"],[6589,6627,"Alyssa."],[6627,6756,"Just give me one"],[6756,6848,"more chance."],[6848,6965,"I love you."],[7036,7148,"I can't live"],[7148,7232,"without you."],[9109,9221,"It's over, Luke."],[9371,9492,"We're done."]]}