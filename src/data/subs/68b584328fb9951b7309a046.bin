{"1":[[1930,2083,"Stop! You're hurting me!"],[2256,2370,"You monster."],[3023,3149,"I don't want your money."],[3149,3383,"Please, just let me go!"],[3453,3670,"Shut your mouth."],[4640,4760,"So, Emily..."],[4873,5070,"Here, take a look!"],[5146,5450,"I'm offering you $2 million."],[5586,5900,"That will help cover your father's medical expense."],[5920,6286,"And you can certainly buy yourself something nice."],[6293,6420,"Anything you want."],[6673,6756,"You know what?"],[6756,7180,"I can even write you another check for 2 million."],[7246,7387,"Just promise me."],[7387,7670,"Just go through this whole wedding."],[8376,8476,"I'll do it."],[8536,8616,"Great."]],"2":[[756,796,"Hello?"],[870,1040,"We have his results in."],[1046,1250,"The situation is very bad."],[1280,1483,"This is a new genetic disease."],[1710,1930,"Thanks for letting us know."],[2793,2876,"Dad."],[4280,4376,"Hi, excuse me."],[4376,4570,"You're here for the cleaner job, right?"],[4616,4776,"Please fill out this form first."],[5333,5420,"Thanks, Miss."]],"3":[[646,920,"Edward, please don't do this to me…"],[3310,3560,"Edward, is my touch so intolerable to you?"],[3603,3863,"Isabella, my tolerance for you is limited."],[3896,3946,"And if you..."],[3960,4080,"Hey!"],[4123,4300,"You shouldn't treat a lady like that."]],"4":[[606,803,"Edward, what the hell?"],[923,1014,"I thought you had a problem"],[1014,1146,"with physical touch?"],[1146,1326,"Miss, are you okay?"],[1340,1500,"Do you want me to call someone?"],[1500,1636,"Are you the new janitor?"],[1636,1780,"Don't you know it's rude"],[1780,2050,"to interrupt a couple while they're flirting?"],[2233,2386,"Oh, I'm sorry!"],[2480,2640,"I thought you needed help."],[2900,3040,"Well, you can go now."],[3853,4070,"Yes? What is it?"],[4270,4356,"Nothing."],[4426,4506,"You can go?"],[5133,5216,"Bitch."],[5296,5443,"I'll take care of you later."]],"5":[[2216,2333,"What are you doing?"],[2596,2698,"You're still working!?"],[2744,3003,"I think I messed up your table."],[3100,3293,"And my drawers need cleaning, too?"],[3803,3963,"There's nothing here that you're looking for."],[4023,4138,"What do I do?"],[4170,4283,"What can I do!?"],[4406,4486,"Get out."],[4613,4693,"Now!"]],"6":[[4363,4530,"Ouch… gentle… It hurts…"],[4720,4800,"Oh…"],[4873,4953,"Oh…"]],"7":[[1010,1130,"Did you hear what I just said?"],[1233,1313,"Hmm?"],[1353,1443,"Sorry?"],[1540,1763,"I'm going out for a while."],[1796,2023,"Clean up my office before I get back."],[2743,2917,"Oh, sir."],[2917,3070,"Excuse me, may I ask you a…"],[3070,3180,"No."],[3346,3490,"All right…"],[4973,5096,"Hey, the new cleaner..."],[5190,5323,"Find out what you can about her."],[5390,5650,"Let me know if you find anything strange."]],"8":[[3483,3646,"Who the hell are you?"],[3720,3846,"Who the hell are you!?"]],"9":[[826,990,"Oh, good morning, Emily."],[1073,1260,"You're just in time for breakfast."],[1320,1420,"Have a seat."],[1810,1920,"How are you doing these days?"],[1940,2180,"Do I have to wait until the wedding"],[2240,2413,"to receive another payment?"],[2583,2663,"Um, yes."],[2730,2783,"Why?"],[2803,3056,"Everything just feels so..."],[3223,3343,"unpredictable."],[3390,3583,"I'm so sorry, dear."],[3586,3883,"I can't really tell you anything right now."],[3986,4243,"But, you'll find out later."],[4423,4576,"I'm a little scared."],[4753,4810,"Emily,"],[4860,4990,"he's not a bad guy."]],"10":[[60,186,"Oh my God."],[220,426,"The coffee's just so hot."],[426,630,"I can't seem to hold it right."],[646,850,"Could you clean it up for me?"],[1550,1656,"Oh my goodness."],[1656,1803,"It's so hot."],[1803,1953,"I can't hold it upright."],[1953,2360,"I am such a klutz."],[2813,2970,"If you can't hold it steady,"],[2970,3100,"get ice next time."]],"11":[[220,300,"Hi."],[363,476,"I'm Emily."],[590,680,"You can call me Lily."],[680,880,"I work in the personnel department."],[1020,1160,"The personnel department?"],[1253,1543,"Is that where you manage all the information"],[1543,1763,"of all the people that work in the company?"],[1773,1953,"Yes, you can think of it that way."],[1953,2143,"But there's more to the job than that."],[2230,2493,"Can I see the personnel list?"],[2590,2660,"Why?"],[2660,2843,"I just, I..."],[2863,3060,"I just wanna know more about the company."],[3103,3360,"Only the personal manager and the CEO can have"],[3360,3483,"the list of the company."],[3726,3856,"CEO?"],[4033,4130,"Thank you."],[4346,4500,"Boss, I think-"],[4500,4600,"It's work time."],[4646,4810,"Don't do anything unrelated to work."],[5810,5950,"Who are you looking for?"]],"12":[[240,382,"Spirit of water."],[382,563,"Heed my call"],[683,833,"with your power."],[833,1300,"Cast a curse of debauchery upon Emily."],[1433,1840,"So that she shows her ugly face to Edward."]],"13":[[390,470,"Emily?"],[1483,1590,"Hey, boss."],[1696,2103,"You look so handsome."],[2220,2483,"Emily, what has got into you?"],[2736,2863,"Did Isabella get to you?"],[2903,3113,"No, I haven't seen her."],[3290,3390,"Isabella..."],[3816,3960,"Isabella, you're in trouble."]],"14":[[650,736,"Edward."],[736,936,"What brings you here, darling?"],[996,1113,"Are you here to share my bed?"],[1113,1226,"Isabella."],[1226,1436,"It seems I let you off too easily."],[1530,1686,"You shouldn't involve innocent people"],[1686,1870,"in what's going on between us."],[1870,2156,"Release Emily from the spell, now."],[2266,2433,"I don't know what you're talking about."],[2470,2670,"Don't toy with me."],[2743,2870,"End the witch magic."],[2870,2990,"I know it was you."],[2990,3100,"Edward."],[3140,3353,"Do you really like that stupid human"],[3356,3573,"with her face as dull as her fucking head?"],[3823,3903,"Edward."],[4240,4470,"Please understand"],[4500,4759,"how important the covenant is"],[4759,4900,"between the two of us."],[4996,5320,"It's not only about the survival of our clans, but-"],[5550,5630,"Edward."],[5690,5790,"It's about your..."],[5883,6040,"It's about your destiny."],[6140,6280,"A human woman is just"],[6280,6470,"simply not worth that risk."],[6470,6573,"Isabella!"],[6573,6813,"You and I are no longer in a relationship."],[6840,7066,"So, it is no longer your business."],[7176,7333,"Stop playing your dirty tricks."],[7403,7570,"And don't be a smartass."],[7596,7680,"And so?"],[7856,7980,"Do you want to try it?"]],"15":[[506,716,"Oh my God."],[783,880,"What happened?"],[3040,3263,"Why do I feel like I've cheated on him?"],[3856,4046,"Damn it..."],[4050,4196,"Damn it..."],[4326,4540,"Edward... Damn it..."],[6646,6803,"What are you doing here?"],[6870,7116,"I can make things between you and Edward work."],[7116,7423,"Only if you're willing to work with me."]],"16":[[1966,2083,"I'm sorry!"],[2353,2566,"I think I made a mistake today."],[2806,2913,"I don't know..."],[2913,3286,"I just feel like I betrayed you."]],"17":[[233,323,"Work?"],[473,583,"With you?"],[650,1020,"Why should I trust a traitor to the Temple Church?"],[1230,1383,"You need my help"],[1463,1730,"if you want to revive the Witch & Wizard Clan."],[1920,2000,"How?"],[2090,2266,"We can talk about that later."],[2290,2410,"Well, what about you?"],[2470,2603,"What do you want?"],[2603,2730,"Nothing."],[2756,2846,"I don't want anything."],[2846,3043,"Don't give me that bullshit."],[3113,3546,"Operation is based on the interests of both parties."],[3583,3830,"Now, let's get things straight."],[4113,4306,"What do you want?"],[4370,4466,"You want money?"],[4616,4703,"Power?"],[4810,5033,"I was just trying to help an old friend."],[5043,5213,"Maybe you don't remember me."],[5270,5440,"But I remember you."],[5653,5746,"You're weird."],[6496,6740,"Just leave Emily to me."]],"18":[[1513,1593,"Oh!"],[1716,1823,"Oh my gosh."],[1823,1896,"I'm so sorry!"],[1896,2070,"Are you okay?"],[2070,2210,"I'm so clumsy."],[2210,2323,"I just..."],[2350,2426,"—No need. —Are you okay?"],[2426,2506,"No need."],[2570,2650,"No need."]],"19":[[313,453,"Well, you've seen enough."],[590,670,"Get out."],[1416,1486,"Emily."],[1486,1740,"I just saw a man in the garage named Harry."],[1756,1920,"Seem to be the one you were looking for."],[1920,2093,"Thanks so much."],[2976,3060,"Dad?"],[3673,3753,"Dad?"],[4270,4393,"Emily, I'm here."],[4450,4560,"Get over here."],[4560,4631,"Dad?"]],"20":[[263,346,"Dad?"],[1210,1340,"Are you here?"],[1576,1693,"It's me."],[1993,2073,"Emily."],[4026,4153,"Emily, I'm here."],[4276,4383,"Get over here."]],"21":[[1273,1353,"Edward."],[1640,1720,"Emily?"],[1826,1923,"Are you still here?"],[2523,2626,"Edward!"],[3620,3693,"Where is she?"],[3746,3843,"You don't know?"],[3910,3996,"Fuck!"],[4417,4506,"Ughhh!"],[4606,5023,"Aghh! Ughhh! Aghh!"],[5386,5593,"Emily, come to me."],[5670,5766,"Quickly."]],"22":[[486,550,"Come."],[1556,1636,"Emily..."],[1770,1833,"Come."],[3113,3176,"Emily!"],[3176,3363,"Stop! Don't go any further!"],[3706,3770,"Emily!"]],"23":[[80,160,"Emily!"],[2200,2326,"Don't worry, Emily."],[3613,3783,"So much for my tolerance of you!"],[3826,3971,"When the Witch & Wizard Clan"],[3971,4103,"patriarch arrives,"],[4116,4346,"I'll speak to him about how to punish you."],[4406,4584,"You have broken the rules of peace"],[4584,4756,"between our clans."],[4776,4846,"You must"],[4856,4960,"stand trial."],[5040,5176,"And you will be punished."],[5176,5493,"But it was you who broke the rules first,"],[5493,5603,"Edward."],[5610,5723,"It's you"],[5723,5843,"who betrayed the covenant"],[5843,6003,"between our clan."],[6020,6178,"If it's anyone"],[6178,6313,"my patriarch would punish,"],[6313,6516,"it would be you!"]],"24":[[356,446,"Don't be afraid."],[536,663,"I'll hold you tight."],[766,1040,"Then I'll never let you go."],[1840,2020,"No, don't be afraid."],[2156,2250,"It's okay."],[2386,2600,"Someone's been protecting you."],[2756,2886,"Protecting me?"],[3313,3456,"My husband..."],[3586,3730,"is Edward, right?"],[4350,4520,"Just follow your heart."]],"25":[[4220,4300,"So..."],[4390,4566,"Is this your secret?"],[4750,4890,"What happened to you?"],[4953,5043,"Is that..."],[5130,5250,"Is that blood?"],[5570,5766,"This is what the moonlight does to me."],[5850,6023,"If I can't be intimate with you,"],[6170,6280,"my body will suffer"],[6343,6650,"You keep too many from me."],[6813,6980,"I'll explain everything later."]],"26":[[30,226,"I'm Edward's grandmother."],[260,356,"As you can see,"],[406,610,"we're all part of the Wolf Clan."],[756,1056,"We've been around for hundreds of years.."],[1193,1290,"And Edward,"],[1350,1523,"he's the head of the Wolf Clan"],[1523,1686,"for this generation."],[1853,1983,"Unfortunately,"],[2076,2370,"he was cursed a long, long time ago."],[2373,2530,"He must find a woman"],[2563,2763,"from the Witch & Wizard Clan."],[2896,3003,"It's the only way"],[3046,3306,"he can survive the transformation"],[3310,3480,"when the blood moon comes."],[3573,3656,"If Edward"],[3703,3850,"doesn't marry you,"],[3890,4243,"the curse inside of him will run out of control."],[4253,4333,"His life"],[4406,4636,"could be in danger at any moment."],[4736,4846,"Well, this is..."],[4913,5316,"Way too much information for me."],[5473,5596,"And that is why..."],[5666,5860,"I couldn't tell you before."],[5920,5976,"But..."],[6080,6200,"Why me?"],[6250,6326,"Emily,"],[6383,6603,"don't underestimate yourself."],[6640,6876,"Can't just see who you really are?"],[6926,7006,"What.. an.."],[7060,7310,"ordinary girl from the countryside?"],[7373,7603,"It doesn't matter where you came from."],[7686,7920,"I see witch in your blood."],[7993,8060,"What?"],[8173,8283,"A witch?"]],"27":[[30,96,"Then..."],[213,426,"Why didn't you choose Isabella?"],[483,580,"I mean,"],[646,860,"she's a witch, too, right?"],[956,1010,"And..."],[1123,1363,"she obviously loves Edward."],[1426,1643,"She'd probably do anything"],[1703,1836,"to be with him."],[1970,2130,"Isabella is indeed"],[2130,2356,"from the Witch & Wizard Clan."],[2363,2543,"But I think it would be best"],[2543,2753,"for Edward to tell you"],[2753,2946,"why he didn't marry Isabella."],[3133,3273,"I won't marry Isabella."],[3413,3546,"I can't be with her."],[3643,3726,"So..."],[3726,3973,"—You... —I want..."],[4033,4080,"You."],[4190,4343,"There's something about you that"],[4553,4660,"intrigues me."],[4670,4733,"And..."],[4843,5046,"I think I'm falling in love with you."],[5210,5343,"And I'd like to marry you."],[5393,5580,"Edward's been protecting you,"],[5586,5666,"Emily."],[5713,5820,"All this time."],[5933,6170,"I've never seen him care so much"],[6170,6290,"about anyone"],[6290,6436,"in a very little time."],[7006,7130,"Ruth! Open the door."]],"28":[[1660,1933,"There's no chance between Edward and I."],[2073,2320,"You are too impulsive, Isabella."],[2393,2636,"If you still want to get rid of Emily"],[2676,2940,"and have Edward all for yourself,"],[3006,3316,"you must listen to me."],[3393,3533,"Oh, what can you do?"],[3720,3973,"There are many things I can do"],[3973,4370,"as long as you promise to follow my lead"],[4410,4633,"and stop acting on impulse anymore."],[4776,5066,"I'm willing to do anything it takes,"],[5113,5326,"just to get Edward back."],[5376,5713,"This makes things easier."],[5830,6090,"I have a great,"],[6090,6233,"great plan."]],"29":[[310,370,"Ruth."],[406,523,"I want Edward."],[633,763,"Potter, what are you doing here?"],[833,1016,"You'll have to ask Edward."],[1016,1243,"Why did he break off his engagement with Isabella"],[1243,1356,"for no reason?"],[1423,1546,"Is this how we treat"],[1546,1793,"the centuries-old covenant between our clans?"],[1793,2073,"Isabella broke the rules of peace between us,"],[2090,2393,"which she used witchcraft on a human recklessly."],[2456,2793,"Such a woman is unfit to be my queen."],[2873,3110,"Isabella is the queen that we"],[3110,3296,"from the Witch & Wizard Clan selected."],[3296,3596,"You have no right to say she's not qualified."],[3596,3850,"Potter, I'm telling you,"],[3876,4033,"if you heard Edward,"],[4093,4339,"the relationship between our clans"],[4339,4580,"will fall apart completely."],[4583,4860,"The moment Edward broke the engagement,"],[4860,5116,"the relationship between our clans was broken."],[5116,5216,"Ruth,"],[5250,5483,"I'm sure you're not as good as you used to be."],[5533,5883,"And I'd love to give you some exercise."]],"30":[[143,255,"It's all because of you"],[255,486,"that our contract was broken, right?"],[500,730,"A charming girl you are indeed."],[826,1100,"Even the Wolf Clan is willing to fight"],[1130,1420,"the Witch & Wizard Clan"],[1420,1540,"just for you."],[1580,1644,"Look,"],[1644,2083,"I don't know what kind of contract you have."],[2083,2200,"But I'm just..."],[2263,2746,"I'm just normal girl with basic ability."],[2806,2990,"Come on. Save it!"],[3100,3513,"Emily is of the Witch & Wizard Clan as well."],[3566,3786,"And you, Patriarch,"],[3786,3895,"need to think about the consequences"],[3895,4070,"of hurting your own people."],[4126,4270,"Are you kidding me?"],[4313,4510,"Don't try to trick your way out."],[4540,4736,"I've got this place locked down."],[4990,5226,"Thought you said the smell of blood could prove it."],[5330,5423,"Well..."],[5526,5626,"There you go."]],"31":[[260,370,"What are you trying to do?"],[756,960,"It is indeed the smell of witches."],[1433,1520,"But how do we know"],[1520,1803,"she would stop pretending to be one and lying to you?"],[1873,2043,"We've already proven it."],[2210,2353,"You should probably go."],[2640,2743,"Edward."],[2836,2900,"Ruth."],[3076,3263,"You're gonna regret what you did today."]],"32":[[56,163,"Emily."],[246,363,"Dad."],[956,1216,"You look... you look tired."],[1530,1766,"Where have you been?"],[1766,2050,"You disappeared so suddenly."],[2050,2326,"I've been looking for you everywhere."],[2326,2423,"I'm sorry!"],[2473,2773,"It was a sudden decision to leave."],[2773,3050,"That were a few things that needed to be taken care of."],[3146,3290,"Dad."],[3290,3470,"How did you find me?"],[3626,3713,"Here."],[3806,3960,"Are you not going to"],[3960,4123,"introduce your friends to me?"],[4123,4396,"Dad, this is Ruth."],[4450,4668,"She's Edward's grandmother."],[4668,4807,"This is Edward."],[4966,5090,"He is my..."],[5200,5393,"My..."]],"33":[[120,256,"He is my..."],[346,460,"My..."],[610,770,"I'm her husband."],[1153,1316,"My Emily"],[1500,1706,"is no longer a little girl."],[1706,1996,"And I'm so happy to hear that."],[2200,2306,"Come here, Edward."],[2813,3040,"Edward, what's the problem?"],[3110,3276,"Something's wrong."],[3510,3706,"Dad, you..."],[3780,3953,"You should get some rest."],[3953,4110,"You look tired."],[4420,4726,"Is there a secret you're hiding from us?"]],"34":[[36,303,"You're not Emily's real father, are you?"],[516,759,"Yes, you're right, Ma'am."],[780,858,"Dad..."],[858,1080,"What are you talking about?"],[1150,1503,"Emily, I'm sorry."],[1503,1776,"I should have told you this earlier, but..."],[1856,1990,"I never did."],[2140,2249,"It was a long time ago"],[2249,2446,"I adopted you from an orphanage."],[2543,2804,"But it doesn't make me love you any less."],[2877,2966,"Um..."],[3046,3430,"I think I just need some time to process."],[3430,3484,"I know."],[3484,3646,"I know I made a mistake."],[3780,3926,"But I'm a dying man."],[4243,4523,"I came after all these years"],[4523,4836,"because I wanted to see you one last time."],[4953,5190,"Dad, what are you talking about?"],[5226,5496,"The truth is... I got sick."],[5686,5906,"And it cannot be cured."],[5906,6113,"I only got a month to live."],[6270,6429,"My last wish is..."],[6509,6890,"I want to live to know that my Emily,"],[6890,7066,"my daughter is happy now."]],"35":[[16,390,"My father wants me to see the place where I was born."],[410,531,"It's his last wish"],[531,757,"for me to accompany him"],[792,1223,"to a place called Sunset Hill."],[1426,1550,"Sunset Hill?"],[1574,1750,"The secret land?"],[1850,1973,"Emily, that's too dangerous."],[1973,2073,"You can't go with him!"],[2146,2583,"This is my last chance to be with my dad."],[2856,3010,"I have to go."],[3983,4093,"Emily."],[4173,4373,"Am I causing you a trouble?"],[4373,4524,"It's okay, Dad."],[4530,4713,"As long as we're together, right?"],[4756,4920,"Everything will be fine."],[5926,6016,"Let's go."],[6843,7056,"I smell Isabella in him."],[7140,7213,"Go."],[7346,7560,"Go and protect the one you care about."],[7613,7926,"And please, take care of yourself."]],"36":[[240,363,"Dad! Dad!"],[540,670,"Are you okay?"],[790,950,"Don't worry about me, Emily."],[990,1126,"I'm fine."],[1226,1456,"This has happened a lot in the past."],[1496,1790,"Anyways, we're almost there."],[1840,1949,"Let's get going."],[3466,3663,"Here they come."],[3800,4110,"I won't let them get away this time."],[4240,4375,"Zephyrus."],[4420,4724,"Clear the dust off this earth."],[4761,4956,"Lend me your power!"]],"37":[[140,220,"Emily?"],[470,550,"Emily..."],[2503,2603,"Hey, Emily."],[2660,2806,"Long time no see."],[3353,3640,"I told you to trust and follow my plan."],[3690,3816,"Are you bringing her over?"],[3816,3880,"No!"],[3900,4120,"The main character hasn't appeared yet."],[4213,4526,"Oh, I am so looking forward to this."],[4813,4966,"I'll leave the rest to you."],[5113,5243,"He should be here soon."]],"38":[[1096,1220,"Isabella!"],[1310,1390,"Edward."],[1476,1671,"I hate you!"],[1671,2022,"I became like this all because of you."],[2073,2226,"What did you do to Emily?"],[2236,2346,"She's dead."],[2543,2642,"If she dies,"],[2642,2846,"I'll kill your entire clan!"],[2946,3043,"Oh, yeah!"],[3050,3303,"I'm totally over you now."],[3383,3486,"I lied."],[3543,3636,"She's not dead."],[3763,3951,"but she will be—"],[3951,4110,"one day,"],[4110,4406,"when I kill her."]],"39":[[70,163,"Where's-"],[320,453,"Where's my dad?"],[636,763,"Stop looking for him."],[830,966,"Just come back with me, Emily."],[1043,1186,"I need to find him."],[1186,1290,"We were..."],[1360,1510,"We were looking for somewhere."],[1510,1610,"Umm..."],[1650,1836,"The secret land?"],[1836,1973,"Emily."],[1973,2126,"Emily, please. C'mon."],[2333,2510,"I don't think it's a good idea to keep looking for him."],[2510,2633,"I think he wants to hurt you."],[2633,2743,"What?"],[2956,3200,"If you're not willing to help me look for him,"],[3290,3425,"I'll do it myself!"],[3460,3579,"You need to stop!"],[3579,3766,"And think about this..."],[3840,4016,"There's something off about Harry."],[4016,4095,"He shows up"],[4095,4306,"and immediately puts you in danger?"],[4330,4463,"I just don't trust the guy."],[4536,4666,"Okay, enough!"]],"40":[[0,460,"(Potter chanting)"],[750,900,"The curse will bite back"],[940,1130,"and make your life a living hell."],[1130,1316,"It's not enough!"],[1970,2393,"Oh, great ancestors of the Witch & Wizard Clan."],[2613,2736,"With my blood..."],[2746,2866,"(Potter chanting)"],[2890,3140,"Give me your strength!"],[3621,3723,"Ahhh!"],[4496,4593,"I'm sorry."],[4806,4943,"I never should've said that."],[5066,5273,"You know I would do anything for you."]],"41":[[90,340,"The blood moon will come soon."],[956,1260,"Maybe your seal will be broken tonight."],[1290,1376,"How?"],[1826,2130,"But you will die when the blood moon ends,"],[2233,2706,"unless you and Emily can break that curse tonight."],[2760,2868,"So, go."],[2905,3160,"Bring her back home safe, kid."],[3446,3660,"It may not be a peaceful night."],[3866,4028,"But if anything or anyone"],[4028,4243,"interferes with the blood moon,"],[4286,4450,"I will help you stop it."],[4886,4996,"Thank you, Ruth."],[7133,7243,"What is it?"],[7376,7456,"Nothing."],[7616,7703,"Let's go."]],"42":[[780,860,"Dad?"],[860,960,"Dad!"],[980,1033,"Edward!"],[1033,1080,"Edward!"],[1103,1173,"Help him!"],[1206,1300,"Don't believe him. He's lying"],[1300,1346,"He's lying!"],[1346,1410,"What?"],[1410,1562,"What? Oh..."],[2580,2672,"Are you hurt?"],[2711,2834,"—Are you hurt? —Emily..."],[3306,3436,"I'm so scared."],[3460,3652,"This thing came out of nowhere and..."],[3652,3793,"it knocked you out."],[3913,4043,"I was just trying to help you."],[4043,4170,"So I lured it away."],[4230,4380,"Hey. It's okay. You're okay."],[4640,4720,"Here."],[4910,5063,"This is where I found you"],[5063,5236,"when you were just a little girl."],[6593,6683,"Emily...?"]],"43":[[450,650,"That Mark took a lot out of you."],[1430,1753,"Well, I think it'll all be worth it."],[1970,2133,"God of illusion."],[2203,2380,"Heed my call."],[3910,3999,"Emily...?"],[4476,4670,"That was a good show, right?"],[4670,4776,"Wolf King."],[4870,4980,"What did you do to her?"],[4996,5130,"Let's just say"],[5130,5340,"I got her away from this place"],[5340,5486,"just for a while."]],"44":[[1330,1496,"You can't beat me!"],[1563,1776,"I wouldn't know without trying it."],[3873,4016,"I love you, Emily."],[4683,4716,"—Wait! —Dad!"],[4750,4945,"Dad! Dad!"],[5003,5108,"Dad! Oh my god..."],[5108,5216,"Oh my god. Dad!"]],"45":[[36,116,"Dad..."],[226,320,"Dad?"],[320,444,"Dad!"],[640,768,"Oh my god..."],[906,1002,"Dad..."],[1093,1163,"Dad..."],[1190,1315,"Dad!"],[1523,1590,"Emily..."],[1590,1776,"Emily, please. Let me explain."],[1890,2000,"How could you...?"],[2186,2303,"What did you do?"],[2370,2646,"What did he do to make you want to kill him?"],[3176,3396,"I was just trying to keep you safe."],[3660,3823,"But he didn't do anything"],[3943,4110,"to hurt me!"],[4640,4750,"You murderer!"]],"46":[[5386,5480,"Edward..."],[6933,7056,"Only you"],[7130,7236,"are worthy"],[7236,7550,"of the most dazzling diamond in the world."]],"47":[[53,200,"I swear"],[200,543,"in the name of the Witch & Wizard Clan"],[643,803,"that once married,"],[803,1046,"I will never betray my husband,"],[1076,1326,"the eternal king of the Wolf Clan."],[1760,1840,"My head."],[2053,2150,"Isabella."],[2223,2323,"I'm sorry."],[2516,2636,"But I'm in love with a human."],[3006,3116,"Hate me!"],[3203,3370,"In the name of the sun,"],[3393,3746,"I curse all the men of the Wolf Clan."],[3785,3943,"If you do not mate"],[3943,4217,"with the women of the Witch & Wizard Clan,"],[4217,4426,"then on a night of transformation,"],[4426,4736,"shall you all face death!"],[4736,4874,"Witch of Soleil."],[4874,5036,"This started because of me."],[5060,5260,"so it will end with me."],[5274,5496,"Almighty gods of the universe,"],[5516,5711,"I swear by the blood diamond"],[5756,5870,"that the Wolf Clan"],[5896,6150,"will be able to overcome this curse,"],[6263,6603,"with the help of my reincarnated descendants."],[7715,7943,"No, no, no. No!"],[8356,8463,"Argh!"]],"48":[[86,193,"Are you all right?"],[283,626,"Couldn't be any better, Elder Potter."],[710,984,"Congratulations, your Highness."],[984,1116,"Queen of Soleil."],[1536,1680,"I need"],[1810,2165,"the Wolf Clan's blood diamond"],[2165,2376,"to restore my power."],[2683,2890,"And now that it's appeared again,"],[3063,3326,"I must get it."],[4790,4990,"Who- who are you?"],[5106,5276,"I'm an old friend."],[5366,5566,"Don't you remember me?"],[7343,7423,"Emily!"]],"49":[[1346,1536,"Wolf King!"],[1763,1926,"Where are you going?"],[2180,2406,"I don't have time to play right now."],[2723,3106,"I love seeing you in pain right now."],[3846,4133,"Is that all you got?"],[5266,5360,"Ruth..."]],"50":[[453,678,"What a beautiful face!"],[698,916,"Oh, I envy..."],[1080,1356,"No wonder the Wolf King fell for you."],[1576,1743,"It's not about looks."],[1820,2176,"Your soul is filthy!"],[2240,2353,"Oh, yeah?"],[2403,2639,"Well, let's clean my soul"],[2639,2770,"with your looks!"]],"51":[[130,265,"—Oh... —Very nice."],[413,566,"What's this?"],[710,800,"Energy."],[870,1066,"Did Edward leave this behind?"],[3706,3846,"Wolf King!"],[3936,4180,"Where's your usual swagger?"],[4790,4953,"Queen of fire."],[5016,5376,"I offer you energy as witch of Soleil."],[5500,5830,"Burn everything off the face of this earth."],[5846,6256,"But most especially this vile woman."]],"52":[[80,160,"Emily!"],[840,960,"What did you do?"],[1160,1386,"Just some spells."],[1626,2066,"The only way to break the curse is to fetch me"],[2113,2240,"the blood diamond."],[2376,2660,"Only then will she wake up."],[3073,3163,"Oh!"],[3390,4006,"I don't see any point in wasting time with them!"],[4126,4243,"Let's just kill him,"],[4506,4626,"and look for it later."],[4973,5080,"Farewell!"],[5260,5470,"Say hello to God for me!"]],"53":[[40,168,"Edward..."],[336,416,"Are you afraid?"],[503,613,"No..."],[693,866,"as long as I'm with you."],[2406,2650,"No, no, no. No!"],[5700,6056,"The blood diamond was inside Emily's body?"]],"54":[[900,988,"Edward..."],[1047,1156,"Edward!"],[2733,3070,"This is my usual swagger."],[4973,5203,"Your clan ends tonight."],[5230,5511,"I think not!"]],"55":[[780,1040,"A bunch of lowly aliens."],[1266,1736,"I shall be the master of the blood diamond."],[4980,5275,"Seems that you're all... All awakened!"],[5413,5530,"You're still alive."],[5653,5823,"My baby girl..."],[5846,6006,"You really want me dead?"],[6130,6277,"After all, I've been around"],[6277,6440,"over 200 years!"],[6526,6748,"You shouldn't be surprising that I'm still alive."],[6856,7026,"Let go of my wife!"],[7076,7193,"I will."],[7253,7560,"But you got to give me the blood diamond first."]],"56":[[2770,2993,"Let go of Emily!"],[3156,3560,"You're in no place to make any deals with me."],[3640,3781,"You bastard."],[3789,3933,"Let her go!"],[3973,4333,"What's so special about this bitch anyway, huh?"],[4333,4430,"Edward."],[4486,4906,"Why are you so addicted to her?"]],"57":[[500,740,"I can't seem to find it."],[926,1210,"She no longer has any value to us."],[1450,1653,"But didn't you need her blood？"],[1653,2110,"Now that she's awake, the deal is done."],[2400,2496,"No..."],[3193,3620,"This belongs to you, Your Highness."],[3666,3913,"Put it on my finger, Harry."],[3940,4093,"My Knight."],[4176,4396,"Yes, Your Highness."],[4396,4686,"It will be my pleasure."]],"58":[[56,713,"So this is the true power of the blood diamond."],[713,966,"Have you gained your strength yet?"],[1026,1142,"Yeah."],[1142,1350,"Just about back to my peak again."],[1493,1613,"You're right."],[1716,2230,"This is the real power of the blood diamond."],[3170,3487,"Thank you for everything you've done for me."],[3650,4106,"With the blood diamond and the witches' blood,"],[4126,4416,"my goal will be achieved."],[4420,4693,"But you know what?"],[4733,5353,"It's not going to work if you just put it on your hand."],[6510,7060,"The blood diamond will be mine forever!"]],"59":[[1576,1906,"Now, you can be together forever."],[1970,2281,"It's like a sad prince and princess's love story"],[2281,2512,"from a fairy tale."],[2560,2690,"Well then,"],[2810,3093,"I shall play the villain."],[3096,3240,"200 years ago,"],[3240,3380,"the Temple Church was dying."],[3480,3970,"And now, I am the only one who survived."],[3970,4229,"They strangled those from other races,"],[4316,4620,"but neglected their own treasures."],[4716,4936,"I was the only one."],[4936,5210,"Only one who knew what was needed."],[5306,5730,"And so, I am the only one who survived."]],"60":[[3598,3813,"You have to believe in yourself."],[3950,4284,"You can create infinite possibilities."],[4656,4765,"I'm sorry..."],[4886,5124,"I will always trust you."],[5216,5549,"You can bring Emily back safe and sound."],[6013,6350,"I will always protect you, my child."]],"61":[[390,500,"No way."],[545,617,"It's..."],[631,910,"It's impossible!"],[2456,2600,"Blood diamond..."],[4100,4171,"Emily..."],[4404,4588,"Oh... Emily."],[4988,5230,"Ahhh!"]],"62":[[2076,2296,"No, no, no. No!"],[2477,2550,"Hey..."]]}