{"1":[[229,392,"A catastrophic multi-vehicle"],[392,550,"collision rocked the city,"],[550,700,"sending a surge of critically"],[700,775,"injured patients"],[775,913,"flooding into Vale hospital's"],[913,1088,"emergency department."],[1088,1276,"The fate of these accident victims"],[1276,1430,"now rests in the hands of Vale's"],[1430,1555,"surgical team,"],[1555,1810,"their last hope for survival in the face"],[1810,1985,"of devastating trauma."],[1985,2081,"Patient's crashing."],[2081,2302,"We need an attending surgeon now."],[2302,2385,"All the OR’s are full."],[2385,2598,"We got three more criticals incoming."],[2648,2715,"Sir."],[2715,2886,"The patient in trauma three is coding."],[2886,2977,"I can't leave this one,"],[2977,3090,"where’s Doctor Stevens?"],[3090,3232,"We need another attending surgeon."],[3232,3407,"Everyone else is in the ER."],[5084,5230,"Need a hand?"],[5230,5409,"The new hire."],[5409,5584,"You just started this month."],[5584,5709,"Some junior surgeon fresh"],[5709,5839,"out of residency isn't ready for"],[5839,5980,"a level one trauma like this."],[5980,6139,"Patient's pressure is dropping."],[6139,6360,"Time to prove yourself, Doctor Marksman."],[6360,6485,"Patient's yours."],[7023,7082,"Okay."],[7082,7203,"We are going to perform"],[7203,7357,"a modified Whipple."],[7357,7607,"Whipple for trauma?"],[7607,7691,"That's insane."],[7691,7870,"Trust me."],[7870,7999,"Metzenbaum scissors."],[8170,8241,"Doctor Rhodes,"],[8241,8483,"I need you to retract here."],[8621,8792,"That procedure will take hours."],[8792,8967,"The patient won't survive."],[8967,9113,"Bovie cautery."],[9338,9455,"Watch."],[9976,10193,"He's doing it in half the normal time."],[10251,10352,"The bleeding..."],[10352,10493,"it's under control."],[10493,10631,"But how did he..."],[10810,10923,"Silk suture."],[11403,11557,"Parker, I want you to clamp"],[11557,11774,"exactly where I show you."],[12191,12424,"I've never seen anything like this."],[12458,12579,"Almost done."],[13405,13638,"This patient's going to make a full recovery."]],"2":[[216,312,"Jesus, Adrian."],[312,588,"What you just pulled off is impossible."],[588,671,"I thought you were just some"],[671,955,"rookie surgeon, but that..."],[955,1105,"that was the most incredible technique"],[1105,1234,"I've ever witnessed."],[1234,1384,"Where did you learn to operate like that?"],[1384,1488,"What you just did"],[1488,1689,"will go down in the history books."],[1689,1772,"Wait."],[1772,1960,"I heard President Vale personally recruited"],[1960,2068,"a medical prodigy"],[2068,2285,"who revolutionized surgical"],[2285,2469,"procedures at Mass General."],[2469,2619,"Was that you?"],[3224,3411,"Final suture."],[3432,3682,"Mrs. Vale’s new pancreatic duct is"],[3682,3812,"anastomosed."],[4079,4279,"Doctor."],[4362,4504,"The nurses."],[4504,4692,"They said you did it."],[4692,4804,"And you..."],[4804,4996,"you actually did."],[5238,5367,"Sir, you shouldn't be in here"],[5367,5497,"during an operation."],[5501,5689,"Every surgeon on the West Coast said"],[5689,5768,"it was inoperable,"],[5768,5889,"that she only had weeks to live."],[5889,5972,"But..."],[6031,6114,"you..."],[6214,6331,"you saved my Katherine."],[6360,6485,"She'll make a full recovery,"],[6485,6589,"President Vale."],[6619,6690,"Name your price."],[6690,6940,"Whatever it is, we need you at Vale."],[6940,7048,"My hospital."],[7323,7415,"Look, I'll explain later."],[7415,7578,"Right now, we have three critical patients"],[7578,7786,"that need specialized procedures."],[7803,7966,"It's going to take hours."],[7995,8216,"Y'all should go home, get some rest."],[8270,8441,"I'll take over from here."],[8441,8641,"Okay."],[8654,8900,"Good work everyone."]],"3":[[258,421,"They’re all stable."],[421,700,"Every single one of them stabilized."],[1105,1188,"Oh."],[1188,1401,"Sun's coming up."],[1401,1580,"I must have operated all night."],[1580,1701,"You're a machine."],[1735,1918,"Well that's why they pay me the big bucks."],[2039,2152,"All right."],[2152,2452,"It's time for some much needed shuteye."],[3891,4070,"Hey, you."],[4316,4500,"Hey, yourself."],[4562,4792,"You've been operating all night."],[4792,5121,"Saved every single patient from that pile-up."],[5121,5334,"What you did was extraordinary."],[5376,5643,"How do you always know exactly"],[5643,5755,"what I needed?"],[5755,5993,"Because I know you"],[6018,6239,"better than anyone."],[6656,6802,"Blueberry."],[6802,6944,"Your favorite."],[6965,7111,"You remembered."],[7140,7261,"Of course I did."],[7303,7478,"You know, I've been thinking lately"],[7478,7674,"about us."]],"4":[[70,367,"I know it's only been a month, but"],[400,604,"it just feels different."],[1309,1443,"That’s the third time this week."],[1488,1601,"Hospital food's better when it's"],[1601,1772,"someone else's."],[1885,2060,"So who's this Marksman guy?"],[2060,2210,"His surgical skills are unreal."],[2223,2377,"Not sure, I thought he was just another"],[2377,2452,"new hire."],[2452,2585,"I had no idea he could handle"],[2585,2806,"complex traumas like that."],[2806,2890,"With talent like this"],[2890,3003,"you think that he'd be running his own"],[3003,3119,"department by now."],[3866,4129,"What is this, a hospital or a nail salon?"],[4129,4275,"Last I checked,"],[4275,4437,"I’m not paying you doctors to sit around"],[4437,4542,"and gossip."],[4729,4829,"Who is this guy?"],[4984,5188,"Preston Vale, President Vale’s son."],[5188,5326,"Harvard MBA."],[5326,5518,"He's taking over as hospital administrator"],[5518,5659,"while his father takes care of his wife,"],[5659,5843,"who just recovered from an experimental"],[5843,6064,"pancreatico- duodenectomy."],[6151,6214,"I'm sorry."],[6214,6289,"Am I looking at two"],[6289,6493,"board certified surgeons,"],[6493,6669,"or med school dropouts?"],[6802,6977,"Hard to tell based on your behavior."],[6994,7048,"Sir,"],[7048,7098,"about last night--"],[7102,7173,"Save it."],[7336,7465,"Parker."],[7465,7557,"You couldn't even manage"],[7557,7741,"a simple trauma rotation."],[7849,7957,"You're fired."],[7957,8116,"Clear out your office."],[8116,8408,"New management means new standards."],[8408,8533,"It’s time to separate the real surgeons"],[8533,8704,"from the posers."]],"5":[[175,333,"Attention."],[333,521,"Everybody's attention now."],[521,763,"If you expect to keep your obscenely"],[763,892,"overpaid jobs,"],[892,1155,"every surgery must be perfect."],[1155,1426,"No complications, no deaths."],[1426,1593,"This second rate medicine stops"],[1593,1739,"right now."],[1889,1976,"Who does he think he is,"],[1976,2060,"Doctor House?"],[2248,2327,"What is this?"],[2427,2719,"Excellence in emergency medicine?"],[2719,2865,"Save your ego stroking"],[2865,3023,"for your own time."],[3140,3349,"This is a hospital."],[3349,3657,"We need surgeons, not trophy collectors."],[3774,3928,"That was from my residency director."],[3928,4162,"Oh, cry me a river."],[4162,4308,"Maybe if you spent a little bit more time"],[4308,4404,"on your patients"],[4404,4491,"and a little less time"],[4491,4621,"collecting gold stars,"],[4621,4825,"you'd be a real doctor."],[4825,4909,"You're fired."],[4913,5017,"Excuse me?"],[5017,5155,"Make sure she gets a souvenir"],[5155,5242,"from the gift shop."],[5242,5384,"Just to show her how grateful we are"],[5384,5526,"for her time here."],[5526,5651,"Yes, sir."],[5651,5818,"Would you prefer a fountain pen"],[5818,5922,"or a snow globe?"],[6072,6181,"That was good."],[6181,6352,"Let's go."],[6685,6852,"Well, well, well."],[6852,7057,"What do we have here?"],[7057,7344,"Sleeping after a shift."],[7344,7528,"Rise and shine, superstar."],[7982,8145,"Did I order a wake up call?"],[8145,8320,"No you didn't."],[8320,8462,"But here's one anyway."],[8462,8525,"You"],[8525,8587,"Are"],[8587,8650,"Fired!"]],"6":[[29,137,"Are you serious?"],[137,300,"You're firing me?"],[383,525,"Do you need me to draw your diagram,"],[525,629,"doctor?"],[633,684,"Well, no,"],[684,925,"but there's must be some sort of mistake."],[925,1155,"Fiona, what's his position here?"],[1155,1301,"He's..."],[1426,1593,"a new surgical resident,"],[1593,1710,"Mr. Vale."],[1710,1839,"What's he make?"],[1839,2031,"$700,000."],[2031,2227,"That's standard for a trauma surgeon."],[2227,2406,"700?"],[2406,2527,"Are you insane?"],[2527,2719,"You're giving resident money to a first year"],[2719,2861,"who sleeps on the job?"],[2861,3115,"This hospital is being scammed."],[3119,3282,"I just worked all night."],[3282,3399,"Okay, I'm just taking a nap."],[3399,3516,"Oh, so now you're expecting"],[3516,3657,"overtime pay?"],[3728,3849,"I’ve seen lazy doctors"],[3849,4112,"but this is criminal negligence."],[4112,4195,"What were you thinking,"],[4195,4354,"hiring this fraud?"],[4354,4487,"Either you’re as dumb as these"],[4487,4571,"hack surgeons,"],[4571,4817,"or this is some sort of insurance scam?"],[4875,5146,"Adrian and I might be sleeping together,"],[5146,5309,"but I can't let him drag me down."],[5309,5509,"My career comes first."],[5509,5651,"Boy bye."],[5718,5947,"There must be some clerical error."],[5947,6135,"His credentials,"],[6135,6285,"Other residents make a fraction"],[6285,6431,"of that salary."],[6431,6585,"Fionna?"],[6677,6794,"Doctor"],[6794,6931,"Marksman."],[6965,7349,"You are F I R E D fired."],[7465,7620,"Clear out your office."],[7620,7807,"Clear out your locker."],[7807,8091,"Get the hell out of my hospital."],[8091,8195,"This is a mistake."],[8195,8270,"Okay, you need to check the"],[8270,8345,"surgical logs--"],[8345,8487,"You don’t get to wear that anymore."]],"7":[[45,216,"I see."],[316,600,"Sir. Doctor Marksman is an amazing surgeon."],[600,809,"You don't understand. He's the one who-"],[809,1030,"Didn’t I fire you two already?"],[1030,1142,"Beat it!"],[1142,1384,"Vale is still the number one hospital in the nation."],[1384,1626,"Don't make this worse for yourselves."],[3395,3561,"I understand."],[3561,3782,"Hospital politics."],[3782,3908,"I know it's only been a month,"],[3908,4200,"but there is something real between us."],[4200,4441,"Meet me in the lobby after your shift."],[4441,4587,"I'll be waiting."],[5367,5668,"You care to explain that little exchange?"],[6122,6272,"The board won’t like this."],[6272,6485,"Four attendings dismissed in one day."],[6485,6652,"Patient care will suffer."],[6681,6906,"Fear is a weapon, Fionna."],[6906,7115,"I intend to wield it."],[7115,7257,"But perhaps you're more concerned"],[7257,7494,"with one surgeon in particular."],[7494,7766,"Your little scam artist “situationship”."],[7766,7891,"No, Preston."],[7891,8045,"He means nothing to me."],[8045,8158,"Really."],[8158,8337,"I have no personal stake in your staffing decisions."],[8337,8571,"Let's be clear about your future here."],[8679,8879,"Do you want to be with the nobody"],[8879,9100,"collecting unemployment checks?"],[9100,9246,"Or the man"],[9246,9463,"who signs everyone's paychecks,"],[9463,9567,"including yours?"],[9693,9993,"The man who signs everyone's paychecks."],[10105,10272,"Even the most attractive administrators"],[10272,10439,"need to be reminded."],[10439,10706,"Who's in charge around here."]],"8":[[671,738,"Hey, Dad."],[759,817,"What's wrong?"],[817,955,"Your mother's having a rough week"],[955,1055,"of recovery."],[1055,1172,"She’ll be ok,"],[1172,1326,"but I need you to take"],[1326,1497,"full control of the hospital."],[1497,1584,"And Preston,"],[1584,1693,"there’s something critical"],[1693,1780,"you need to know."],[1780,1889,"Of course, what is it?"],[1972,2081,"That new surgeon,"],[2081,2218,"Doctor Marksman,"],[2218,2352,"whatever happens,"],[2352,2540,"make sure you take care of him."],[2548,2673,"Doctor Marksman?"],[2673,2777,"Doctor Marksman,"],[2777,2961,"You're fucking fired!"],[2961,3148,"Get out of my hospital."],[3161,3461,"Christ, the resident I just fired."],[3495,3791,"Preston, are you there?"],[3837,4041,"Check the staff roster."],[4041,4187,"See if we have another Marksman"],[4187,4341,"working for us here."],[4483,4667,"I had to back up the Brinks truck"],[4667,4804,"to get him here."],[4804,4904,"He’s the surgeon who saved"],[4904,5009,"your mother's life."],[5009,5201,"And he’s pioneering our"],[5201,5442,"experimental surgery program."],[5442,5630,"The hospital's reputation"],[5630,5880,"rests on his work."],[6389,6498,"Yes, I see now."],[6498,6623,"There's another surgeon"],[6623,6740,"attending with that name."]],"9":[[37,162,"Doctor Marksman."],[162,417,"Pioneer in experimental trauma surgery."],[417,608,"Two time Florence Nightingale"],[608,821,"Medal recipient for medical excellence."],[821,959,"Three times Apex Award winner"],[959,1080,"for clinical research."],[1080,1197,"Is this who you mean Dad?"],[1197,1317,"That’s our man!"],[1317,1514,"There’s another surgeon with the same last name"],[1514,1747,"who’s been a disaster for us."],[1747,1968,"Negligent, lazy, you name it."],[1968,2089,"Do me a favor,"],[2089,2210,"fire him."],[2260,2427,"Already done, Dad."],[2427,2623,"I fired his slacker ass this morning."],[2640,2769,"Thank God."],[2769,3032,"I almost thought I fired our star surgeon."],[3032,3240,"Good work, son."],[3240,3503,"I'll visit when your mother's stronger."],[3595,3762,"Just, just take care of Mom,"],[3762,3795,"all right?"],[3795,3995,"I got everything else under control."],[4625,4767,"See, I told you"],[4767,5084,"that slacker resident I fired was worthless."],[5084,5413,"Now, about your career trajectory,"],[5467,5622,"Mr. Vale, sir."],[5622,5789,"Can't you see I'm busy?"],[5789,5914,"Multiple traumas. Incoming!"],[5914,6018,"The six car pileup."],[6018,6168,"You're fired half our surgery, team!"],[6168,6268,"What's your point?"],[6268,6431,"The ER is crashing."],[6431,6627,"We've no one left who can handle it."],[7223,7478,"Give me the situation now."],[7478,7632,"Six critical traumas."],[7632,7753,"Three more incoming."],[7753,7920,"Multiple crush injuries."],[7920,8103,"Arterial bleed. Sir,"],[8103,8258,"We're losing patients."],[8258,8395,"What are our options?"],[8420,8541,"There might be one solution."],[8546,8737,"Well, spit it out."],[8737,8863,"Doctor Marksman."],[8871,9117,"He handled four critical traumas alone last night."],[9117,9300,"If we can get him back here."],[9300,9396,"Marksman, right."],[9396,9605,"That's the method we need. Fionna, call him."],[9605,9843,"Which doctor Marksman should I...?"],[9843,9976,"The genius surgeon."],[9976,10193,"The one I didn't fire. Keep up."]],"10":[[237,421,"What the hell?"],[421,600,"Where’d all his stuff go?"],[2064,2277,"Idiot left his research notes."],[2464,2740,"Modified trauma protocol."],[2740,2936,"Wait,"],[2936,3236,"these are his revolutionary procedures."],[3357,3574,"Oh, this is brilliant work."],[3937,4029,"Hello?"],[4029,4371,"Doctor Marksman? Multiple critical traumas in the ER."],[4371,4567,"Preston Vale says if you can handle this crisis,"],[4567,4804,"there's a monster promotion waiting."],[4871,4992,"I’m on my way."],[5296,5438,"With Adrian's techniques."],[5438,5672,"I'll look like a genius."],[5672,5901,"They'll make me department head,"],[5901,6202,"and I can finally make seven figures."],[6715,6840,"Well?"],[6840,6994,"Doctor Marksman’s on his way."],[7015,7161,"Thank God."],[8045,8345,"Now, about your loyalty."],[8404,8604,"Adrian meant nothing."],[8604,8854,"I was using him to advance my career."],[8854,9042,"You're my future."],[9042,9296,"That's my girl."],[9889,10110,"Fionna’s shift ended an hour ago."],[10110,10410,"The boss's son is up to something."],[10481,10648,"To hell with this. I'm going up."],[12162,12258,"Piece of shit!"]],"11":[[291,483,"Get your hands off my girl!"],[658,884,"Oh! Just knock it off, Adrian."],[884,959,"You mean to tell me"],[959,1088,"that the brilliant surgeon"],[1088,1184,"can't see what's been happening"],[1184,1401,"under his own nose?"],[1409,1501,"You mean to tell me that you've been"],[1501,1584,"messing around"],[1584,1772,"with this incompetent nepo baby?"],[1772,1918,"I can choose who I want,"],[1918,2068,"and I don't want a disgraced surgeon"],[2068,2177,"with no future."],[2177,2373,"You pathetic loser."],[3903,4054,"We're done, Adrian."],[4108,4300,"Ancient history."],[4300,4433,"Are you serious?"],[4537,4688,"Just like that."],[4688,4888,"Sorry that this bum wrinkled your jacket,"],[4888,4988,"sir."],[5234,5417,"Why are you doing this, Fionna?"],[5417,5588,"Am I just a stepping stone to you?"],[5588,5772,"I need someone with a future."],[5772,5910,"Not someone who sleeps"],[5910,6160,"while patients are dying!"],[6477,6727,"Keep it for when you get lonely and horny."],[6727,6881,"It's the closest you'll ever come"],[6881,6990,"to the real thing again."],[7461,7595,"Look at us, Adrian."],[7640,7841,"I'm the future of Vale Hospital."],[7841,7945,"And you?"],[8224,8362,"You’re just a slacker."],[8362,8516,"In scrubs."],[8516,8704,"You're washed up Marksman."],[8704,8837,"Perhaps try nursing."],[8888,9042,"I hear they're always hiring."],[9129,9246,"Fionna, I met you here and it"],[9246,9392,"made me want to stay."],[9517,9801,"I thought we could build a family together."],[9834,9989,"Get over yourself."],[9989,10130,"You think I'm going to stay with someone"],[10130,10393,"who lied about their credentials?"],[10393,10564,"President Vale would never have"],[10564,10673,"hired someone"],[10673,10848,"who sleeps during shifts."],[11061,11211,"We're done."],[11240,11398,"I'm not done."],[11398,11549,"But when I am,"],[11549,11757,"there won't be a Vale Hospital left standing."],[11941,12149,"You can count on that."],[12333,12383,"No, no, no."],[12383,12541,"Don't you move an inch right there,"],[12541,12604,"Adrian."],[12604,12804,"Your troubles are just getting started."]],"12":[[58,237,"Who authorized you to be here?"],[237,387,"Mr. Vale, I'm pleased to announce"],[387,567,"that under my supervision,"],[567,742,"we've stabilized all the patients from"],[742,909,"the multi-car accident"],[909,1184,"and the situation is completely under control."],[1184,1363,"You’re Doctor Marksman."],[1372,1543,"Yes, the very same."],[1551,1689,"My father mentioned your"],[1689,1914,"exceptional credentials."],[1914,2031,"Harvard Medical, was it?"],[2181,2394,"These morons have no idea"],[2394,2615,"I'm taking credit for Adrian's revolutionary"],[2615,2723,"techniques."],[2723,2948,"As long as the boss's son is impressed,"],[2948,3174,"I'll be chief of surgery by next month."],[3174,3420,"Mr. Vale, I've identified who's responsible"],[3420,3724,"for all the issues in OR three today."],[3749,3887,"He was sleeping"],[3887,4116,"while a patient almost died on the table."],[4116,4316,"Clear cut medical malfeasance."],[5130,5263,"Doctor Hart."],[5330,5501,"Incredible news."],[5501,5643,"Doctor Adrian Marksman,"],[5643,5768,"that surgical pioneer that you've"],[5768,5872,"been tracking."],[5910,6010,"He's just been terminated"],[6010,6210,"from Vale Hospital."],[6289,6356,"When?"],[6356,6485,"Less than an hour ago."],[6485,6694,"Dismissed by President Vale's son."],[7007,7148,"Amazing."],[7148,7357,"I'd pay to see Nelson Vale's face"],[7357,7478,"when he discovers"],[7478,7728,"that his prize surgeon was fired"],[7728,7907,"by his sub-mental son."],[7907,8099,"With, respect, we're still"],[8099,8291,"establishing our reputation."],[8391,8575,"Would someone of Marksman’s caliber"],[8575,8754,"even consider joining us?"],[8754,9038,"We’ll offer him whatever it takes."],[9038,9246,"Full department autonomy,"],[9246,9455,"research funding,"],[9455,9738,"state of the art facilities,"],[9738,9955,"and, if necessary,"],[9955,10114,"my personal involvement."],[10231,10406,"His techniques could revolutionize"],[10406,10531,"surgical care."],[10602,10798,"Have my car brought round."],[10798,11090,"I'm going to Vale Hospital personally."],[11090,11294,"And Adrian Marksman."],[11294,11490,"He's leaving with me."]],"13":[[33,145,"Malfeasance?"],[145,333,"What kind of delusional accusation"],[333,383,"is that?"],[383,571,"No, don't insult our intelligence."],[571,763,"A patient coded while you were off taking"],[763,817,"a nap."],[817,942,"The timing couldn't possibly be"],[942,1038,"coincidental."],[1038,1201,"Yet you stand there denying it."],[1201,1351,"This is crazy."],[1351,1484,"You've all passed me off as some"],[1484,1618,"second rate surgeon."],[1618,1768,"And when a complication occurs,"],[1768,1964,"which happened in this hospital"],[1964,2081,"under your incompetent"],[2081,2218,"leadership,"],[2268,2506,"you blame me?"],[2590,2761,"The collective medical knowledge in this room"],[2761,2969,"isn't enough to fill a prescription pad."],[3098,3261,"If you were even half the surgeon"],[3261,3345,"that you claim to be,"],[3345,3532,"you would still have a job."],[3661,3807,"I'm not going to stand here and debate"],[3807,3962,"medicine with you in front of Mr. Vale."],[3962,4033,"Security."],[4033,4233,"Please detain him."],[4767,4950,"What exactly are you accusing me of?"],[4950,5226,"Either confess to medical malfeasance,"],[5226,5305,"or"],[5305,5459,"they'll escort you to the police"],[5459,5622,"for criminal negligence."],[5680,5885,"Adrian, I never realized"],[5885,6135,"you were capable of endangering patients."],[6135,6260,"What other medical atrocities"],[6260,6377,"have you committed?"],[6377,6523,"You better confess now,"],[6523,6635,"or we'll do everything in our power"],[6635,6756,"to make sure you lose your medical"],[6756,6848,"license."],[7007,7144,"Fine."],[7144,7253,"Go ahead."],[7253,7428,"Do your worst."],[7428,7586,"Let's see if a single piece of evidence"],[7586,7807,"holds up in front of the medical board."]],"14":[[129,266,"You really"],[266,421,"underestimate my family's influence,"],[421,521,"don't you?"],[617,771,"Don't you realize that Mr. Vale here"],[771,946,"could end your entire career with one"],[946,1059,"phone call?"],[1059,1230,"Sir, I strongly recommend that"],[1230,1409,"we make an example out of him."],[1409,1539,"After all, he'll be a danger to his patients"],[1539,1701,"wherever he goes."],[1701,1876,"Preston, you can't let him walk"],[1876,2047,"away after this."],[2047,2327,"Not after what he did to our patients."],[2389,2502,"I'm contacting the medical board"],[2502,2652,"right now."],[2652,2781,"As of this moment,"],[2781,2894,"Doctor Adrian Marksman"],[2894,3086,"is blacklisted from Vale Hospital"],[3086,3370,"and every medical institute in the country."],[3370,3557,"Plans in motion, Adrian."],[3557,3732,"Do you know what that means?"],[3732,3895,"It means that you will never practice"],[3895,3991,"medicine"],[3991,4183,"in this country again."],[4362,4608,"I have one question before I go."],[4608,4800,"Does your father know you fired me?"],[4884,5021,"My father's the one who asked me to fire"],[5021,5163,"you, you dipshit."],[5417,5609,"You thought you were some brilliant surgical"],[5609,5714,"god,"],[5714,5801,"didn't you?"],[5851,5922,"Security,"],[5922,5993,"Remove this criminal"],[5993,6172,"from hospital property immediately."],[6172,6318,"Immediately!"],[6318,6402,"Yes, doctor."],[6402,6485,"Right away, sir."],[6773,6877,"That's quite enough."],[8087,8187,"Let him go."],[8295,8516,"Doctor Marksman is about to accept"],[8516,8637,"the position"],[8637,8913,"as Chief of Surgical Innovation"],[8913,9175,"at Hart Medical Centre."]],"15":[[54,216,"I know you."],[216,350,"You're Vivian Hart,"],[350,458,"the surgical upstart from that"],[458,663,"medical clinic across town."],[663,1071,"That's Doctor Vivian Hart to you, Mr. Vale."],[1113,1184,"Vivian,"],[1184,1301,"I haven't seen you since the"],[1301,1426,"John Hopkins Symposium,"],[1426,1618,"like, 4 or 5 years ago."],[1618,1755,"What are you doing here?"],[1755,1935,"Well, I'm here for the most innovative"],[1935,2085,"surgeon in the country of course."],[2256,2339,"Wait."],[2339,2515,"Are you seriously suggesting"],[2515,2665,"this negligent doctor has value?"],[2748,2961,"He was sleeping during rounds."],[2961,3090,"Is this how Vale Hospital"],[3090,3261,"discards its exceptional talent?"],[3386,3657,"Your father built this institution's reputation"],[3657,3849,"off medical excellence,"],[3849,4008,"not petty politics."],[4137,4262,"Droctor Hart,"],[4262,4416,"with all due respect."],[4416,4571,"This is a conversation between medical"],[4571,4650,"directors."],[4650,4767,"Someone in your position should"],[4767,4934,"recognize when to maintain silence."],[5021,5205,"Doctor Hart, I must inform you"],[5205,5413,"that Doctor Marksman represents a serious"],[5413,5538,"liability."],[5538,5809,"He compromised patient safety. And-"],[5809,5930,"I don't believe I requested your"],[5930,6114,"medical opinion, Doctor..?"],[6114,6231,"Marksman."],[6231,6339,"David Marksman."],[6339,6506,"I have neither time nor interest"],[6506,6694,"in your assessment."],[6831,6973,"After he"],[6973,7111,"decided to go to sleep,"],[7111,7374,"we had a critical surgical complication."],[7374,7611,"His negligence led to the problem."],[7611,7832,"His actions not only endangered patients,"],[7832,8078,"it compromised my hospital's reputation."],[8208,8445,"Are you really willing to defend someone"],[8445,8654,"who violates the Hippocratic Oath?"],[8654,8796,"Did you actually consult with your"],[8796,8850,"father"],[8850,9075,"before dismissing Doctor Marksman?"]],"16":[[54,262,"Of course I consulted my father."],[421,563,"He's the one who specifically mentioned"],[563,775,"his dangerous surgical shortcuts"],[775,963,"and inflated reputation."],[963,1142,"Dangerous shortcuts?"],[1222,1413,"Is that what President Vale really said?"],[1413,1539,"His exact words were"],[1539,1797,"remove him at first opportunity."],[1797,1956,"President Vale was the one that recruited me,"],[1956,2118,"this makes absolutely no sense."],[2118,2268,"Please, Adrian."],[2268,2456,"The president wouldn’t personally recruit"],[2456,2686,"a mid-level surgeon like you."],[2686,2873,"Those gala invitations?"],[2873,3061,"Were a professional courtesy,"],[3061,3261,"not genuine respect."],[3261,3420,"Well, if that's the way things work at Vale,"],[3420,3616,"I have nothing more to contribute,"],[3616,3712,"to any of you."],[3766,3899,"Doctor Marksman."],[3899,4091,"Would you consider joining Hart Medical"],[4091,4245,"Center as our Chief of Surgery?"],[4437,4512,"Well, I--"],[4512,4733,"Full department autonomy,"],[4733,4909,"protected research time,"],[4909,5125,"a surgical fellowship in your name,"],[5125,5213,"and"],[5213,5455,"a seven figure salary package."],[8500,8650,"In cash."],[8650,8775,"Doctor Marksman."],[8775,9034,"I want you to revolutionize our surgery program."],[9150,9376,"Hopefully, this shows you,"],[9376,9526,"I mean what I say."]],"17":[[79,291,"Chief of Surgery?"],[433,583,"You're offering all this to"],[583,750,"a surgeon who can't even keep his eyes"],[750,913,"open on the job?"],[913,1034,"Doctor Hart,"],[1034,1134,"have you completely lost your"],[1134,1217,"medical judgment,"],[1217,1397,"or are you on drugs?"],[1397,1555,"This is absurd."],[1555,1830,"He was a mediocre surgeon here at Vale,"],[1830,2010,"and now you're positioning him to lead"],[2010,2235,"your entire surgical department?"],[2406,2519,"The medical board should review your"],[2519,2711,"hiring practices."],[2861,3023,"Vivian,"],[3023,3307,"I appreciate your confidence."],[3307,3545,"This isn't about money."],[3545,3695,"Maybe there is something beyond"],[3695,3874,"professional opportunity"],[3874,4045,"that might interest you."],[4045,4229,"She's offering herself up to him."],[4229,4387,"She can't do that."],[4387,4637,"Are you a doctor or a call girl?"],[4637,4788,"At Hart Medical Center,"],[4788,4950,"you'll be given everything a surgeon"],[4950,5184,"of your caliber deserves,"],[5184,5434,"including a boss that would do"],[5434,5601,"absolutely anything to recognize your"],[5601,5734,"value."],[5734,5830,"And I do mean anything,"],[5830,5976,"Doctor Marksman."]],"18":[[100,250,"Doctor Hart."],[250,454,"For the sake of your own reputation."],[454,633,"You need to know that this hack"],[633,763,"you're so eagerly pursuing"],[763,1067,"has a documented history of negligence."],[1067,1288,"My father confirmed it himself."],[1288,1589,"Is that precisely what Nelson Vale told you?"],[1597,1735,"His exact words."],[1864,2043,"Negligent surgeon?"],[2043,2181,"What are those?"],[2385,2627,"Personal gifts from your father."],[2861,2982,"My fellowship offer."],[3119,3290,"My personal research lab."],[3290,3436,"My surgical team."],[3436,3570,"I'm leaving it all behind."],[3807,3941,"You can tell President Vale that"],[3941,4037,"as of this moment,"],[4037,4216,"Doctor Marksman has permanently"],[4216,4341,"withdrawn"],[4341,4487,"from Vale Hospital"],[4487,4704,"and all of its affiliated institutions."],[4733,4796,"You know what?"],[4796,5005,"Spare us the theatrics, Adrian."],[5005,5201,"You never deserved those privileges in the"],[5201,5259,"first place."],[5355,5522,"The medical board is going to see that"],[5522,5647,"justice is done."],[5647,5935,"Oh, your stupidity,"],[5935,6097,"it's just,"],[6097,6172,"astonishing."],[6172,6368,"You treat pioneering surgeons"],[6368,6589,"like disposable scalpels."],[6589,6752,"This man"],[6752,6919,"is a life saving artist."],[7257,7382,"Doctor Hart."],[7382,7553,"I understand there's some competition"],[7553,7761,"between your center and Vale Hospital."],[7761,7982,"Yeah. Look, I’ll be real."],[8033,8179,"We’re struggling to get out from under their"],[8179,8241,"shadow."],[8241,8454,"I'd be happy to help you out with that."],[8454,8575,"Take me on,"],[8575,8775,"and I'll transform Hart to the number one"],[8775,9000,"surgical institution in the country."]],"19":[[33,221,"Look at yourself, Adrian."],[221,337,"Offering your skills"],[337,496,"to a struggling clinic."],[496,725,"How pathetically desperate."],[859,1080,"A backstabbing bottom feeder like you"],[1080,1234,"has absolutely no right"],[1234,1413,"to judge a surgeon of his caliber."],[1413,1697,"How dare you talk to me like that!"],[1697,1860,"Your malpractice has caused"],[1860,2064,"catastrophic damage"],[2064,2285,"to my hospital's reputation."],[2285,2435,"As the responsible party,"],[2435,2577,"I demand that you"],[2577,2727,"issue a formal apology"],[2727,2940,"to one of the major medical journals,"],[2940,3090,"and with an explanation"],[3090,3365,"to every affected Vale hospital patient."],[3478,3624,"Refuse me"],[3624,3795,"and I will ensure that the medical board"],[3795,4020,"revokes your license permanently."],[4020,4275,"That accusation isn't just baseless."],[4275,4387,"It's absurd."],[4387,4458,"What exactly"],[4458,4587,"do you think you're going to do about it?"],[4675,4892,"You've got no choice but to sign this confession."],[4892,5159,"Oh, stop threatening my Chief Surgeon."],[5159,5405,"If you insist on pursuing this vendetta,"],[5405,5480,"have your attorney"],[5480,5588,"send a formal complaint"],[5588,5764,"to Hart Medical Center."],[5764,5955,"We'll consider it nothing less"],[5955,6247,"than a declaration of total war."],[6247,6489,"If it's war you want,"],[6489,6748,"I will obliterate your dime store clinic"],[6748,6952,"with everything that I've got."],[7019,7157,"Let's go."],[7157,7232,"One more second"],[7232,7444,"this cesspool is going to make me physically ill."],[8362,8495,"Mr. Vale,"],[8495,8671,"don’t you waste another precious moment"],[8671,8854,"on those second rate practitioners."],[8996,9238,"David, you've proven your loyalty."],[9238,9463,"The Chief of Surgery position is yours"],[9463,9688,"effective immediately."],[9688,9784,"This is..."],[9784,9976,"This is extraordinary."],[9976,10206,"Thank you. I,"],[10301,10523,"I am honored beyond words."],[10523,10710,"Don't forget about me, Preston."],[10831,10952,"Don't worry, babe."],[10952,11098,"You will be"],[11098,11353,"thoroughly compensated for your loyalty."],[11419,11536,"How exciting."],[11632,11736,"Mr. Vale,"],[11736,11928,"I swear on my medical oath"],[11928,12137,"that I will not disappoint you."],[12237,12303,"Mr. Vale,"],[12303,12441,"a commuter train derailed"],[12441,12616,"six critical patients incoming."],[12616,12841,"Doctor Marksman, OR one, now."],[12841,13008,"Now's your time to shine Doctor Marksman."],[13008,13138,"Shit. I’m screwed."],[13138,13250,"Adrian's surgical journal"],[13250,13425,"with all his proprietary techniques"],[13425,13592,"is still in my office."],[13592,13763,"If Preston finds out I stole it"],[13763,14018,"and then couldn't even use it properly..."]],"20":[[25,225,"I implemented a"],[225,437,"groundbreaking surgical protocol"],[437,583,"that I invented myself."],[583,834,"These techniques are revolutionary."],[834,984,"I'll walk you through it in detail"],[984,1155,"after the emergency."],[1163,1330,"That’s impressive, Doctor Marksman."],[1330,1605,"You've obviously got your own methodology."],[1605,1747,"No need to bore me with the specifics,"],[1747,1906,"I trust your brilliance."],[1906,2093,"Keep up the good work, Doctor Marksman."],[2093,2310,"With you leading my surgical team,"],[2310,2527,"I can focus on what really matters."],[2527,2773,"Hospital expansion."],[2831,2936,"Again, sir."],[2936,3086,"I'm deeply honored."],[3645,4016,"Behold, Vale Hospital's new Chief of Surgery."],[4016,4179,"Let's see how all these condescending"],[4179,4350,"clowns treat me now!"],[4696,4846,"I’m glad you're feeling better, honey."],[4846,5005,"Thank you."],[5005,5159,"Oh, sorry."],[5159,5338,"Who's this?"],[5609,5730,"Nelson Vale speaking."],[5730,5843,"President Vale."],[5843,6076,"Doctor Vivian Hart here."],[6076,6352,"I'm calling to let you know that as of this morning,"],[6352,6468,"Hart Medical Center"],[6468,6769,"has officially entered the experimental surgery arena."],[6769,7007,"Revolutionary surgical procedures"],[7007,7278,"are Vale Hospital's domain."],[7278,7403,"Are you absolutely certain"],[7403,7624,"you want to pick this fight?"],[7624,7853,"This is merely a professional courtesy call,"],[7853,8028,"not an invitation for debate."],[8028,8103,"Now, just--"],[8683,8938,"What is that conniving bitch plotting?"],[8938,9321,"She knows Adrian is our surgical secret weapon."],[9321,9630,"Why would she deliberately provoke a medical war"],[9630,9884,"she has absolutely no chance of winning?"],[10018,10264,"Unless..."],[10823,10977,"Dad, we've got multiple traumas coming in."],[10977,11302,"Just tell me you didn't fire Doctor Marksman."]],"21":[[0,154,"Dad, relax."],[154,275,"I fired the other one."],[275,417,"That incompetent slacker"],[417,542,"resident that you mentioned."],[542,692,"Then explain to me"],[692,900,"why Hart Medical Center"],[900,1096,"believes they can suddenly challenge"],[1096,1242,"our surgical supremacy."],[1326,1501,"Because I"],[1501,1659,"masterfully lead Vivian Hart"],[1659,1876,"into a false sense of reality."],[1876,2018,"There’s no way a mediocre doctor"],[2018,2277,"can revolutionize surgical procedures."],[2277,2435,"I convinced Vivian,"],[2435,2648,"that she's acquired surgical brilliance,"],[2648,2748,"when in reality,"],[2748,3044,"she's hired our disgraced, discarded loser."],[3044,3328,"So you deliberately manipulated Vivian?"],[3328,3486,"She thinks she's hired"],[3486,3616,"the genius"],[3616,3774,"behind Vale Hospital's groundbreaking"],[3774,3870,"procedures."],[3870,3991,"That's why she had the audacity"],[3991,4108,"to declare war on you."],[4108,4266,"Impressive, son."],[4266,4375,"You're finally showing"],[4375,4529,"some of the leadership qualities"],[4529,4733,"that I've been waiting to see out of you."],[4733,4963,"I think you're ready to take complete control"],[4963,5230,"of our experiment surgical division."],[5397,5451,"Dad,"],[5451,5526,"This--"],[5526,5672,"This is everything I've worked for."],[5672,5768,"Thank you."],[5768,5939,"We'll get to work immediately."],[5939,6126,"We're going to expose"],[6126,6343,"Hart Medical Center"],[6343,6552,"for the low grade institution"],[6552,6694,"it truly is."],[6694,6819,"Their humiliation"],[6819,7027,"will be quick and absolute."],[7027,7215,"I won't let you down."],[7349,7444,"Darling,"],[7444,7595,"surgical innovation"],[7595,7749,"is the future of Vale."],[7749,8020,"Preston only got his MBA last year."],[8020,8153,"Do you really think it’s wise"],[8153,8437,"to entrust him with our most prestigious program?"],[8437,8696,"I would never take a risk like this"],[8696,8942,"if Preston was our only asset."],[8942,9059,"Remember,"],[9059,9234,"we have the ultimate"],[9234,9442,"surgical secret weapon."],[9442,9680,"You mean the surgeon that saved my life?"],[9680,9880,"Doctor Adrian Marksman."],[9880,9997,"Exactly."],[9997,10201,"And all I need to do"],[10201,10472,"is stay hands off"],[10472,10723,"and let him exercise his"],[10723,10935,"extraordinary talents."],[10935,11269,"As long as Adrian is with Vale Hospital,"],[11269,11382,"Hart Medical Center"],[11382,11649,"has no chance of competing."],[11649,11878,"Not only that, Vivian fell"],[11878,12037,"for Preston's manipulation"],[12037,12299,"and hired that medical disaster"],[12299,12550,"Doctor David Marksman."],[12587,12929,"All we have to do now is sit back"],[12929,13417,"and watch her would-be empire crumble."]],"22":[[446,779,"So now that you've seen the surgical department."],[980,1080,"What do you think?"],[1080,1222,"It's not bad."],[1222,1480,"It's a small team, but they're talented."],[1480,1668,"What you've built here,"],[1668,1780,"it's impressive, Viv."],[2018,2114,"It's good to see you again"],[2114,2298,"after all these years. Adrian."],[2381,2477,"You too."],[2548,2727,"We need to expand."],[2727,3007,"It's too small for what I'm planning."],[3007,3115,"So,"],[3215,3370,"I heard you weren't the only"],[3370,3591,"surgeon Preston Vale fired."],[3999,4241,"Well you have all the angles figured out, don’t you?"],[4241,4404,"And I always find the best one."],[5276,5480,"I'm going to start recruiting."],[5559,5651,"Good."],[5755,5960,"The faster we rise,"],[5960,6143,"the more rewarding"],[6143,6318,"this partnership becomes."]],"23":[[296,412,"This better be good."],[475,596,"Mr. Vale,"],[696,821,"you wanted to see me?"],[1176,1368,"My father has granted me"],[1368,1505,"complete authority over our"],[1505,1664,"experimental surgical department."],[1722,1843,"Given your new position"],[1843,2064,"as Chief of Surgery,"],[2064,2256,"I’m appointing you Head of Innovation."],[2256,2439,"Mr Vale, I--"],[2439,2598,"Is there an issue with that?"],[2598,2840,"No, no. Absolutely not."],[2840,2948,"The budget for innovation"],[2948,3082,"is astronomical,"],[3082,3186,"and President Vale"],[3186,3490,"has already handed control to his son."],[3490,3645,"If I oversee these procedures,"],[3645,3774,"I could divert significant"],[3774,4045,"resources to my personal research."],[4087,4216,"Mr. Vale,"],[4216,4391,"you can trust me completely."],[4391,4637,"I am precisely the right man for the job."],[4892,4946,"Preston,"],[4946,5080,"we have a catastrophe on our hands."],[5080,5184,"Two attending surgeons"],[5184,5305,"just admitted their resignations"],[5305,5384,"simultaneously."],[5384,5522,"The department can't possibly maintain"],[5522,5597,"its caseload."],[5597,5693,"What?"],[5693,5793,"They both resigned at once?"],[5793,5930,"What was their explanation?"],[5930,6093,"They refused to disclose the reasons."],[6093,6202,"But there's talk they were recruited"],[6202,6348,"by a former Vale physician."],[6393,6639,"Along with the three other surgeons you fired before."],[6639,6810,"Former physician, Adrian Marksman."],[6810,7123,"This has his saboteur signature all over it."],[7173,7323,"What is our contingency plan?"],[7323,7411,"The surgical department"],[7411,7570,"is severely understaffed."],[7570,7699,"If any more surgeons leave,"],[7699,7828,"patients will suffer."],[7828,8103,"Okay, everybody needs to remain calm."],[8266,8445,"You still have me."],[8445,8616,"I can rebuild this department."],[8679,8787,"Yes."],[8787,8917,"With your stellar reputation,"],[8917,9100,"we should be able to get the best of the best."],[9100,9246,"Exactly."],[9246,9496,"So we lost some second rate talent."],[9496,9626,"Let them go."],[9730,10026,"I'll make some calls to Cedars-Sinai"],[10026,10193,"and UCLA."],[10268,10372,"Good work Marksman."],[10735,10902,"This is working out perfectly."],[10902,11215,"Now I can install my own allies in key positions."],[11215,11277,"Soon,"],[11277,11661,"I'll control the entire hospital's medical direction!"]],"24":[[2198,2402,"It's an honor to meet you Doctor Hart."],[2769,2940,"This is Doctor Parker here."],[2940,3132,"He's a triple board certified surgeon."],[3132,3399,"And soon he'll be the head of trauma surgery."],[3399,3561,"This is Doctor Rhodes,"],[3561,3653,"Chen,"],[3653,3762,"Rose,"],[3762,3878,"and Thomas."],[3878,4074,"All consummate professionals."],[4074,4295,"My most trusted colleagues back at Vale."],[4604,4767,"With this surgical team."],[4767,4934,"Hart Medical can revolutionize"],[4934,5171,"surgical care all across the country."],[5280,5463,"Actually, the whole world."],[5463,5655,"We’re eager to begin, Doctor Hart!"],[5655,5797,"Well,"],[5797,5955,"welcome to Hart Medical Center."],[6076,6231,"I am thrilled to have surgeons"],[6231,6377,"of your caliber joining us,"],[6377,6539,"but,"],[6539,6744,"I do need to be transparent."],[6744,6940,"We've got considerable ground to cover"],[6940,7098,"before we can truly challenge"],[7098,7257,"Vale Hospital's dominance."],[7257,7449,"Have no fear, Doctor Hart."],[7449,7582,"With Adrian leading our team"],[7582,7736,"we’ll be three steps ahead of"],[7736,7916,"anything Vale attempts."],[7916,8174,"Yes, but Vale has already implemented"],[8174,8316,"Adrian's breakthrough"],[8316,8537,"surgical procedure protocols."],[8537,8717,"Yeah, about that."],[8717,8846,"It's a preliminary version."],[8846,9029,"If they continue to develop this approach"],[9029,9138,"without modification..."],[9138,9230,"Then what?"],[9230,9359,"A lot of deaths."],[9421,9576,"A lot of lawsuits."],[9576,9659,"A lot of patients"],[9659,9822,"could be harmed or worse."],[9822,9922,"These procedures weren't"],[9922,10110,"ready for widespread implementation"],[10110,10276,"without proper refinement."],[10322,10439,"Those techniques require"],[10439,10552,"precise calibration"],[10552,10760,"and specialized training."],[10760,10902,"Without that foundation..."],[10902,11190,"We’re talking about serious complications."],[11190,11298,"Preventable harm."],[11298,11582,"Our first priority has to be patient safety."],[11582,11799,"We need to perfect these procedures,"],[11799,11936,"and then we can find a way"],[11936,12128,"to prevent Vale from continuing"],[12128,12320,"with the flawed protocols."],[12320,12374,"Exactly."],[12374,12608,"It's not about competition or pride."],[12608,12758,"It's about saving lives."]],"25":[[104,233,"We're using our experience"],[233,450,"with the trial procedures I did at Vale"],[450,754,"to develop next generation surgical techniques"],[754,913,"eliminating all the previous"],[913,1142,"complications and inefficiencies."],[1222,1393,"Even if Vale Hospital analyzes"],[1393,1526,"our fundamental approach,"],[1526,1751,"and attempts to create something new,"],[1751,2018,"we’ll maintain our significant advantage."],[2093,2248,"And if they stubbornly continue"],[2248,2427,"with their flawed protocols,"],[2427,2548,"rest assured."],[2548,2765,"Their outcomes will deteriorate."],[2773,3053,"I don't wish it upon their patients, that's for sure."],[3103,3257,"Remember this moment."],[3257,3478,"In this battle for medical supremacy,"],[3478,3599,"Hart Medical Center"],[3599,3866,"will emerge victorious."],[4437,4612,"It’s three AM?"],[4692,4892,"I lost track of time again."],[5405,5555,"Viv, you surprised me."],[5718,5960,"Looks like you could use a nice rub."],[6035,6193,"Do you mind?"],[6193,6293,"No,"],[6431,6664,"I mean, yeah."],[6664,6977,"You give all your surgeons massages?"],[7007,7190,"Only the ones I really, really like."],[7770,7962,"You really, really like me?"],[7987,8133,"Adrian, I've really, really liked you"],[8133,8366,"since residency."],[8366,8566,"Nothing's changed."]],"26":[[33,125,"You are our most brilliant"],[125,271,"resident in the program."],[321,400,"I never imagined"],[400,542,"someone like you would like me."],[542,654,"There was never anyone else"],[654,796,"that caught my attention."],[917,1121,"Only you."],[1209,1434,"But you were completely oblivious."],[1434,1572,"And then you just"],[1572,1797,"vanished from the program."],[1805,1901,"Well, I left to join"],[1901,2081,"the experimental surgical fellowship"],[2081,2214,"in Switzerland."],[2264,2364,"I know."],[2548,2781,"Your talent was extraordinary even then."],[2894,3098,"Back then, I made a promise to myself"],[3098,3328,"that we would work together again someday."],[3365,3520,"You know, when I established"],[3520,3703,"Hart Medical Center,"],[3703,3916,"my first priority was recruiting you."],[3962,4262,"But that manipulative tyrant,"],[4262,4391,"Nelson Vale"],[4391,4600,"had already secured your contracts"],[4600,4829,"with ridiculous incentives."],[4900,5100,"I understand now."],[5730,5910,"So,"],[5910,6031,"should we"],[6031,6268,"pick up where we left off in residency?"],[6302,6452,"You’re the boss."],[6452,6602,"That's right."],[6602,6861,"And as your boss, I say,"],[6861,7023,"come home with me."],[7040,7127,"Tonight?"],[7136,7248,"You lost everything"],[7248,7415,"when Preston fired you."],[7415,7782,"Hospital privileges, research funding."],[7891,8262,"Even your hospital subsidized apartment."],[8400,8546,"You have literally nowhere else"],[8546,8783,"to go tonight."],[8783,8888,"Come with me."],[9104,9209,"Where?"],[9275,9505,"My place."]],"27":[[646,754,"All right."],[754,950,"I'll admit it."],[950,1030,"That was the best meal"],[1030,1167,"I've had in months."],[1167,1384,"Careful, Doctor Marksman."],[1384,1480,"I might start thinking"],[1480,1655,"you're easy to please."],[1655,1885,"That just depends on the company."],[1885,2093,"Well, starting tonight,"],[2093,2310,"this is your new home."],[2310,2498,"Until the program's fully established,"],[2498,2719,"it just makes sense."],[2719,2865,"Are you sure about that?"],[2865,3119,"We already work late hours."],[3119,3332,"Living together"],[3332,3457,"could get complicated."],[3532,3778,"Well, I like complicated."],[3778,3991,"Keeps things interesting."],[3991,4145,"And"],[4145,4325,"where exactly will I be sleeping?"],[4325,4621,"Well,"],[4675,4942,"my master suite"],[4942,5242,"has a California king."],[5472,5684,"Plenty of room"],[5684,6006,"if things ever need to get more"],[6006,6243,"collaborative."],[6243,6452,"Really?"],[6452,6569,"Relax."],[6569,6785,"I'm only teasing."],[6785,6856,"Tonight,"],[6856,7052,"at least."],[7052,7286,"Come on."],[7382,7557,"I'll show you your room."],[7711,7974,"Unless you'd rather have a nightcap,"],[7974,8091,"in mine."],[8679,8871,"Things could get dangerous."]],"28":[[112,212,"Is this pathetic attempt"],[212,392,"really the best that you can do?"],[800,1063,"You are completely worthless as surgeons."],[1063,1226,"Doctor Marksman."],[1226,1372,"The experimental procedures"],[1372,1459,"we're trying to replicate here"],[1459,1672,"are extraordinarily intricate."],[1672,1835,"We need at least six months"],[1835,2031,"to properly master--"],[2031,2147,"Six months?"],[2147,2318,"You have 72 hours,"],[2318,2590,"and I expect hourly updates on my desk."],[2590,2919,"Sir, rushing these delicate procedures"],[2919,3082,"dramatically increases the possibility"],[3082,3249,"of potentially fatal complication."],[3249,3353,"Three days"],[3353,3628,"and you don't get one hour or more."],[3628,3766,"Go, go."],[4129,4283,"Report Doctor Marksman."],[4283,4412,"What's our status?"],[4421,4575,"Excellent progress, Mr. Vale."],[4575,4783,"We will be advancing to phase two"],[4783,5030,"implementation within three days."],[5038,5246,"It's exactly what I wanted to hear."],[5246,5580,"I knew my judgement appointing you is flawless."],[6010,6126,"Preston, I need an update"],[6126,6414,"on the experimental surgery program."],[6414,6573,"Everything's proceeding perfectly, father."],[6573,6719,"Outstanding!"],[6719,6806,"When this is done,"],[6806,7132,"I’ll throw you a huge party to celebrate the launch."],[7169,7386,"Your father must be so proud of you."],[7386,7582,"Keep up the good work, Doctor Marksman."],[7653,7741,"I’ll make sure my father"],[7741,7949,"understand your invaluable contribution."],[8049,8166,"This is my shot."],[8166,8324,"Why settle for Chief of Surgery?"],[8324,8425,"With the right maneuvering,"],[8425,8516,"I could become the next"],[8516,8771,"Chief Medical Officer of Vale Hospital."],[8812,8942,"Mr. Vale,"],[8942,9230,"my purpose is to execute the visionary"],[9230,9384,"medical strategies"],[9384,9572,"of brilliant administrators"],[9572,9705,"such as yourself."],[9722,9872,"I believe that in the position"],[9872,10055,"of Chief Medical Officer,"],[10055,10139,"I could implement"],[10139,10289,"your ideas more effectively"],[10289,10418,"throughout the entire hospital."],[10489,10664,"If these procedures prove successful,"],[10664,10781,"I will personally discuss"],[10781,10902,"your advancement with the board."],[10910,11065,"Truly, that's."],[11223,11457,"I am profoundly grateful, sir."],[11498,11553,"Thank you."]],"29":[[1284,1438,"You're finally awake."],[1906,2056,"You can keep appreciating the view"],[2056,2214,"while you eat."],[2223,2323,"All right."],[2323,2565,"Oh, breakfast, looks good."],[2565,2681,"Thank you."],[2911,3019,"When you're finished eating,"],[3019,3219,"we'll head directly to the surgical wing."],[3219,3315,"Sound good?"],[3315,3586,"Yes, absolutely."],[3586,3753,"Good."],[3753,3883,"Get it up and running"],[3883,4062,"and there may be a"],[4095,4291,"special bonus waiting for you."],[4583,4738,"Extra special."],[5526,5630,"Okay, team."],[5630,5776,"We're approaching a critical phase"],[5776,5918,"of our program development."],[5918,6110,"We have groundbreaking procedures"],[6110,6247,"that we need to perfect"],[6247,6348,"in very little time."],[6348,6539,"So, let's get to it."],[6539,6756,"Let's start revolutionizing medicine."],[6765,6973,"I have excellent news for all of you."],[6973,7144,"I've just finalized arrangements"],[7144,7265,"with the board,"],[7265,7490,"and upon successful implementation"],[7490,7724,"of our surgical innovations,"],[7724,7836,"each of you will receive"],[7836,8045,"a fully funded medical mission trip"],[8045,8212,"anywhere in the world that you choose"],[8212,8387,"to share your expertise."],[8387,8604,"And, when the time comes"],[8604,8733,"that our procedures receive"],[8733,8967,"national certification,"],[8967,9138,"Every surgeon on this team"],[9138,9288,"will be gifted a percentage"],[9288,9392,"of the royalties from"],[9392,9526,"any techniques we patent."],[9776,9984,"At Hart Medical Center,"],[9984,10201,"our surgeons are the lifeblood"],[10201,10385,"of our institution,"],[10385,10623,"and you will be compensated accordingly."]],"30":[[12,75,"Doctor Hart,"],[75,216,"we are fully committed"],[216,358,"to making this surgical program"],[358,454,"a success."],[454,550,"Absolutely."],[550,779,"You'll be seeing progress ASAP."],[779,959,"Vale Hospital won't know what hit them."],[959,1067,"With Adrian leading us,"],[1067,1213,"victories guaranteed."],[1230,1789,"Hart is best!"],[1964,2256,"We're running wild hearts on fire."],[2327,2540,"Whoa!"],[2619,2919,"We're chasing dreams and climbing higher."],[2948,3161,"Whoa!"],[3190,3353,"Can’t hold us back."],[3353,3520,"We’re gonna stay."],[3520,3657,"Can’t hold us back."],[3657,3874,"We're going all the way."],[4938,5226,"You always this disciplined?"],[5226,5426,"Or are you just trying to impress me?"],[5547,5776,"If I was trying to impress you, you would know."],[5843,6114,"Midnight meetings,"],[6114,6364,"long hours."],[6364,6669,"This work ethic of yours."],[6669,6865,"It's a little dangerous."],[7090,7369,"That’s what Vale used to say about me."],[7407,7607,"Then they fired me."],[7799,7953,"Then they were fools."],[8133,8216,"You've earned"],[8216,8525,"more than just respect here, Adrian."],[8525,8750,"You know that, right?"],[9113,9321,"You trying to motivate me again?"],[9321,9534,"I don't try."],[9797,9901,"I do."],[10147,10251,"Well,"],[10251,10402,"don’t work too late."],[10727,10944,"You're no good to me burnt out."],[11699,11861,"The incompetence"],[11861,11986,"is..."],[11986,12095,"is staggering."],[12170,12420,"Yeah. You two are in way over your heads."]],"31":[[25,108,"Do you really think"],[108,283,"that this is acceptable?"],[283,429,"I give you one simple task"],[429,654,"and you screw it up."],[654,759,"How the hell did either of you"],[759,992,"even finish residency?"],[992,1184,"Vale General Hospital,"],[1184,1380,"is the gold standard."],[1380,1526,"And you two are just standing around"],[1526,1722,"like clueless little interns."],[1722,1835,"If these surgical models"],[1835,1976,"aren't flawless by tomorrow."],[1976,2131,"You're both gone."],[2131,2298,"Is that clear?"],[2298,2398,"Yes, sir."],[2406,2556,"This is the man I trusted"],[2556,2857,"to lead my surgical team?"],[2977,3086,"Go!"],[3607,3728,"Oh, Mr. Vale."],[3728,3924,"What a, what a, what a surprise."],[3924,4058,"Cut the bullshit, Marksmen."],[4208,4362,"Are we on schedule or not?"],[4362,4504,"Of course."],[4612,4900,"We're just refining the final stages."],[4900,5021,"Yeah."],[5021,5150,"Everything's under control."],[5150,5271,"Good."],[5271,5338,"If there's a problem."],[5338,5455,"I expect to hear it from you."],[5455,5572,"No cover ups."],[5572,5705,"Of course, sir."],[5939,6010,"Mr. Vale--"],[6010,6126,"Not now."],[6126,6306,"Go get me the latest performance reports."],[6681,6881,"It--"],[6881,6977,"looks like Preston's"],[6977,7082,"growing a little cold"],[7082,7323,"on our lovely administrator here."],[7323,7428,"Don't worry."],[7428,7678,"When Preston makes me Chief Medical Officer,"],[7678,7870,"I'm gonna need someone"],[7870,8078,"flexible in my corner."],[8078,8341,"I always back the winning team Doctor Marksman."]],"32":[[216,400,"Today, Vale Hospital officially launched"],[400,550,"its highly anticipated"],[550,825,"next generation surgical program."],[825,934,"This cutting edge approach"],[934,1034,"to surgical care"],[1034,1176,"is being closely watched"],[1176,1355,"by the medical industry,"],[1355,1509,"especially as Hart Medical's"],[1509,1618,"competing program"],[1618,1835,"was released on the same day."],[1843,1976,"The question now is,"],[1976,2223,"who will define the future of surgery?"],[2331,2506,"Relax, Mr. Vale."],[2506,2673,"Hart Medical doesn't stand a chance."],[2848,2990,"I hope you're right,"],[3061,3240,"for your sake."],[3428,3591,"Didn't you say that,"],[3591,3724,"if the rollout went well,"],[3724,3891,"that you'd make me"],[3891,4054,"Chief Medical Officer?"],[4054,4229,"It's not a success."],[4229,4316,"Yet."],[4487,4704,"Enjoy tonight's launch party."],[4704,4946,"Because if our results don't outshine Hart Medical,"],[4946,5134,"it'll be the last thing you have to celebrate"],[5134,5280,"for a long time."],[6381,6527,"Doctor Hart, we"],[6527,6690,"have a problem."],[6765,6973,"Vale Hospital's new surgical program"],[6973,7094,"launches today."],[7094,7215,"That soon?"],[7215,7344,"They're hosting a big"],[7344,7540,"celebration party tonight."],[7761,7920,"It’s a good thing we're ahead of them."],[8095,8266,"You’re saying we're ready?"],[8266,8420,"Why would I lie?"],[8420,8625,"We've been tracking Vale’s every move."],[8704,8821,"Let them celebrate."],[8821,8950,"It's just going to backfire."],[8950,9205,"How exactly does that work in our favor?"],[9321,9501,"Viv, do you remember what I told you"],[9501,9642,"when you first brought me here?"],[9809,9976,"Preston Vale is rushing this."],[9976,10155,"He's desperate to beat us to the market."],[10155,10247,"And?"],[10247,10431,"Their model's flawed."],[10431,10548,"If they keep moving forward"],[10548,10627,"without realizing"],[10627,10723,"their structural failure"],[10723,10990,"in their approach,"],[10990,11173,"we won't have to lift a damn finger."],[11173,11332,"And what about when it falls apart?"],[11332,11482,"Then Hart Medical takes over"],[11482,11753,"as the future of modern surgery."]],"33":[[12,204,"So you're saying that Vale Hospital"],[204,337,"has been refining the prototype"],[337,538,"surgical method that you designed?"],[538,663,"It's the only way they could have gotten"],[663,838,"this far this fast."],[838,1013,"They're using an early draft"],[1013,1313,"full of mistakes that I won't make again."],[1330,1438,"They don't even realize the"],[1438,1593,"cracks in their foundation."],[1630,1931,"That actually makes perfect sense."],[2006,2306,"Which means we've already won."],[2331,2506,"Well, this is a big day for us."],[2506,2623,"We should celebrate."],[2631,2765,"What do you have in mind?"],[2765,2844,"Drinks?"],[2844,2982,"Not quite."],[2990,3224,"You and I are crashing the Vale launch party,"],[3224,3319,"tonight."],[3319,3465,"What?"],[3465,3574,"Why?"],[3574,3753,"Let me worry about that."],[3753,3945,"In the meantime, ensure a smooth rollout."],[3945,4175,"Finish whatever procedures you need to"],[4241,4446,"and meet me in the lobby at 8 PM sharp."]],"34":[[300,396,"Preston,"],[396,638,"we’ve been through so much together."],[638,792,"I know where I'm headed in life,"],[792,1076,"and I know who I want by my side."],[1096,1368,"Tonight at this launch party"],[1368,1509,"celebrating our groundbreaking"],[1509,1739,"surgical program,"],[1739,2039,"feels like the perfect moment to ask."],[2085,2264,"Will you marry me?"],[2911,3028,"This should be fun."],[3028,3215,"Absolutely."],[3215,3328,"You really know how to take care"],[3328,3478,"of your staff, Mr. Vale."],[3520,3599,"Stop it."],[3599,3749,"Too bad you're taken."],[3749,3953,"Yeah. Yeah. What a shame."],[3953,4095,"Where the fuck is Fionna?"],[4095,4191,"Told her to meet me out here"],[4191,4391,"so we can go to this party together."],[4391,4529,"Forget about her."],[4529,4792,"She's just social climbing trash anyways."],[4792,4954,"We'll show you a better time."],[5284,5409,"Now that's an offer I can't refuse."],[5409,5459,"Let's go."],[5459,5655,"Fionna who?"],[5889,6118,"Oh, you ladies are crazy."],[6118,6210,"Let me get the door."],[8312,8529,"The number you have dialed is unavailable."],[8529,8658,"Please try again later."],[8658,8804,"Adrian."]],"35":[[500,725,"That’s 20 in one day."],[725,821,"All clean."],[821,938,"All stable."],[938,1076,"The experimental procedures are all"],[1076,1217,"working Doctor Marksman."],[1267,1355,"You did it."],[1422,1543,"No."],[1543,1726,"We did it."],[1893,2002,"Doctor Marksman."],[2002,2206,"You have to get to Vale's launch party, pronto."],[2206,2318,"You're already late."],[2318,2435,"I need to change then."],[2435,2552,"You don't have time."],[2552,2781,"Where's Vivian?"],[2781,2969,"Taking care of something."],[2969,3153,"She said it's really important that you be there"],[3153,3407,"and she'll meet you as soon as she can."],[3503,3657,"Tonight, we celebrate the launch"],[3657,3749,"of Vale Hospital's"],[3749,3987,"revolutionary surgical program."],[5472,5568,"What the fuck?"],[5568,5797,"You're my date, and you're wasted."],[5797,5955,"I'm sure you have plenty of other dates"],[5955,6076,"to accompany you."],[6076,6135,"Yeah."],[6135,6360,"God knows why I chose you, but I did."],[6360,6510,"So if you want to keep your job"],[6510,6664,"and your status, sober up"],[6664,6756,"for God's sakes."]],"36":[[212,291,"Did he just wander in"],[291,437,"from the janitors' lounge?"],[437,579,"It's giving"],[579,700,"“orderly chic.”"],[975,1192,"Maybe he's here to buss tables."],[1338,1484,"What are you doing at our launch party?"],[1484,1609,"You weren't invited."],[1609,1718,"You so sure about that?"],[1718,1830,"I mean, look at you."],[1830,1972,"This is a black tie."],[1972,2106,"I mean, not that I'd expect you to know"],[2106,2268,"what that actually is."],[2414,2748,"Oh, look who crawled in from the gutter."],[2748,3073,"The failed surgeon, the fraud."],[3073,3274,"The nobody."],[3274,3591,"You show up to my party in dirty scrubs, Marksman?"],[3591,3699,"Thought I told the security"],[3699,3799,"to keep out the criminals"],[3799,3916,"and the lowlifes."],[3916,4074,"Guess I need to fire them, too."],[4074,4137,"Pardon me,"],[4137,4341,"I just came straight from surgery."],[4341,4450,"Because some of us here"],[4450,4612,"are real surgeons."],[4612,4742,"What are you trying to say?"],[4742,4959,"I'm saying that the failed surgeon,"],[4959,5221,"the fraud, the nobody."],[5288,5405,"Isn’t me."]],"37":[[33,162,"I can't have him expose me"],[162,333,"in front of all these people."],[462,617,"You’ve got some nerve talking to my man"],[617,763,"Marksman like that."],[796,1071,"With a genius like him leading our surgical team,"],[1071,1176,"you won't be able to get anywhere"],[1176,1305,"near our next party."],[1305,1514,"Yeah, because it'll happen in prison"],[1514,1668,"when you're all arrested"],[1668,1822,"for medical malpractice,"],[1822,2031,"criminal negligence"],[2031,2152,"and identity theft."],[2268,2448,"What are you talking about?"],[2448,2656,"Identity theft?"],[2656,2740,"Whose identity"],[2740,2877,"would we possibly be stealing?"],[2877,3040,"Yours?"],[3040,3190,"Let me give you a little bit of advice,"],[3190,3311,"Marksman."],[3311,3453,"If you don't got it,"],[3453,3624,"at least act like you do."],[3624,3778,"Speaking from experience?"],[3949,4137,"Look around you."],[4137,4362,"This is the elite among the elite."],[4362,4500,"The best of the best"],[4500,4612,"in the medical field."],[4621,4746,"Just because you waltz in here"],[4746,4896,"and your dirty, cheap scrubs"],[4896,5050,"doesn't make you one of us."],[5050,5234,"Good, I’m glad."],[5234,5367,"Because you're all beneath me."],[5463,5605,"Isn't that right?"],[5605,5751,"Doctor “Marksman”?"],[5751,5818,"That's enough."],[5818,5901,"Guards!"],[6026,6264,"This former employee is threatening us."],[6264,6427,"Kick him out!"],[6456,6690,"Touch me and you'll regret it."],[6848,7044,"I'm here tonight with a very"],[7044,7173,"important guest."],[7173,7336,"What are you dumb asses doing?"],[7336,7465,"Grab him!"]],"38":[[87,145,"Preston!"],[296,467,"What the hell is this?"],[467,600,"Dad."],[600,646,"Relax."],[646,721,"I--"],[721,829,"Relax?"],[900,1071,"This twat came in uninvited."],[1071,1230,"I was just kicking him out. Guards!"],[1230,1351,"Remove him immediately."],[1351,1422,"President Vale,"],[1422,1639,"it truly is an honor to finally meet you."],[1639,1810,"You get out of my way!"],[1864,1951,"Dad, what are you doing?"],[1951,2006,"This is. This is."],[2006,2139,"This is Doctor Marksman,"],[2139,2231,"the genius surgeon"],[2231,2398,"that is leading our surgical--"],[2398,2627,"You are such a fool!"],[2719,2773,"Dad."],[2890,3028,"What are you doing?"],[3028,3249,"Open your eyes, Preston."],[3249,3361,"This man that you tried"],[3361,3541,"so hard to kick out,"],[3541,3607,"he is--"],[3678,3895,"You are a"],[3895,4004,"disgrace!"],[4029,4099,"Dad!"],[4216,4466,"My hospital meant something and"],[4466,4617,"you turned it into out a"],[4679,4796,"into a j--"],[4796,4879,"--joke"],[4950,5034,"Dad!"]],"39":[[4,83,"Dad!"],[266,417,"President Vale."],[417,567,"Fuck away from my dad."],[596,709,"Are you out of your mind?"],[709,871,"He is the best surgeon in this room."],[880,917,"Oh, yeah."],[917,1109,"Like you give a shit about saving my dad."],[1109,1309,"I'll die before I trust you two."],[1309,1459,"Somebody get me a real doctor."],[1459,1647,"David."],[1672,1872,"Do something, he’s coding."],[2260,2473,"Can't think of what to do next?"],[2473,2573,"Blanking?"],[2573,2706,"Can't think of a diagnosis?"],[2706,2844,"Shut up!"],[2844,3069,"Why isn't Doctor Marksman doing anything?"],[3069,3199,"This is ridiculous."],[3199,3415,"I thought this David guy was a genius."],[3528,3616,"Why are you just standing there?"],[3616,3712,"Do something!"],[3883,4033,"What's the matter, David?"],[4033,4279,"If you need help, just ask."],[4279,4500,"All you have to do is admit what you did."],[4500,4700,"Right here, right now."],[4783,5063,"I can't blow my cover but,"],[5063,5242,"what if I kill him?"],[5242,5476,"I don't know anything about surgeries."],[5476,5676,"I don't even know what's wrong with him."],[5676,5922,"I did medical school on zoom."],[5930,6026,"David,"],[6026,6318,"this is a matter of life and death."],[6318,6431,"Let it go."],[6560,6635,"I--"],[6685,6760,"I--"],[6948,7073,"I can't!"],[7073,7211,"I can't do this."]],"40":[[12,141,"Okay, I can't--"],[141,283,"I can't do this."],[283,446,"I can't do this,"],[446,567,"without,"],[567,729,"my notebook!"],[963,1142,"That's my surgical notebook!"],[1142,1251,"He stole it from me."],[1985,2177,"Okay, okay."],[2177,2293,"I'm going to need"],[2293,2523,"a fork and a glass of water."],[2907,3044,"Okay, I got it, I got it."],[3161,3299,"Take it."],[3299,3395,"Okay."],[3395,3490,"Hold his head."],[3490,3824,"Good. Tilt it back and apply pressure"],[3824,3953,"here."],[3974,4054,"Okay."],[5071,5171,"Okay."],[5384,5459,"Three."],[5522,5580,"Four."],[5630,5689,"Five."],[6106,6256,"Oh, thank God."],[6306,6410,"What happened?"],[6685,6777,"Thank you."],[6936,7090,"That's my guy."],[7090,7261,"Surgical genius."],[7328,7499,"That's how Vale makes history."],[7499,7716,"Somebody get this man a medal,"],[7716,7895,"or at least a new department."],[7895,7987,"If you still want that"],[7987,8191,"Chief Medical Officer position,"],[8191,8295,"say the word."],[8320,8387,"Now,"],[8429,8637,"do I have to have somebody escort you out?"]],"41":[[8,187,"That maneuver."],[187,283,"That notebook."],[283,387,"It's mine."],[387,513,"Then tell them."],[892,1017,"Where is he going?"],[1017,1138,"Maybe he's headed to develop"],[1138,1292,"another fake surgery program"],[1292,1472,"at another fake hospital."],[1497,1718,"Leaving so soon, doctor PJs?"],[1776,1872,"Say, why don't you come back"],[1872,2114,"when you've actually saved a life?"],[2477,2715,"That procedure David used,"],[2715,2823,"I invented it."],[2911,3078,"What kind of crack are you smoking?"],[3078,3215,"He's delusional."],[3311,3415,"Somebody, seriously"],[3415,3578,"check this guy's medical license."],[3578,3887,"The notebook he used to save your father."],[3887,4029,"That's mine."],[4029,4208,"My handwriting."],[4208,4333,"My theories."],[4387,4592,"You’re just pissed because he did"],[4592,4721,"what you couldn't."],[4721,4867,"I'm pissed because you used"],[4867,4975,"rudimentary theories"],[4975,5142,"as innovation."],[5142,5305,"And when it fails,"],[5434,5568,"and it will."],[5663,5860,"You're not the ones that will pay for it."],[5860,5976,"The patients will."],[5976,6126,"You can't prove that."],[6126,6268,"Not yet."],[6348,6644,"But you can't fake medicine."],[6644,7102,"Medicine and science always tell the truth."]],"42":[[158,271,"OR three’s vitals just dropped."],[271,400,"We've got uncontrolled bleeding."],[400,533,"Second patient today."],[533,621,"Same issue."],[621,896,"Vessel ligation failed mid operation."],[896,1038,"These techniques aren't viable."],[1038,1151,"The Vale method doesn't"],[1151,1309,"hold under stress."],[1384,1488,"I mean, come on."],[1488,1639,"Tonight proves it."],[1639,1793,"We’re ahead of every surgical institute"],[1793,1931,"in the country."],[2656,2865,"I'll be right back."],[2865,2982,"Just coordinating with the team."],[3307,3395,"Talk to me."],[3428,3616,"The vascular bundle clamp maneuver failed again."],[3678,3887,"This is the second patient bleeding out tonight."],[4141,4333,"Use the compression step."],[4333,4525,"That only works in controlled scenarios."],[4583,4725,"We told you these procedures"],[4725,4825,"weren’t fully tested."],[4925,5130,"Look, just follow the notes."],[5459,5584,"I designed those techniques"],[5584,5726,"for one-on-one guidance."],[5726,5980,"Not mass implementation."],[5980,6164,"Without calibration,"],[6164,6293,"it's unstable."],[6293,6373,"It's dangerous."],[6373,6698,"They tried to commercialize your success without you."],[6698,6961,"Now people are paying for it."]],"43":[[41,158,"All good?"],[158,325,"Of course."],[325,525,"Just routine coordination."],[525,633,"Routine coordination"],[633,871,"doesn't usually include blood loss."],[871,1063,"Your surgical program is failing"],[1063,1259,"and patients are suffering."],[1259,1426,"You've been out of the field for months."],[1426,1518,"You wouldn't know."],[1518,1664,"Yeah, I would know"],[1664,1764,"because the procedures"],[1764,1893,"that you're butchering,"],[1893,2018,"I invented."],[2018,2156,"And I’m the only one in this room"],[2156,2285,"who can fix the mess that you made"],[2285,2406,"in your surgical wing."],[2481,2606,"Bull shit."],[3153,3307,"Hello, yes, this is Doctor Marksman."],[3399,3591,"Connect me with the surgical coordinator"],[3591,3678,"immediately."],[3812,4049,"Okay, listen very carefully."],[4049,4254,"Your patient in OR three is experiencing"],[4254,4454,"a catastrophic hemorrhaging"],[4454,4554,"because the vascular"],[4554,4696,"bundle clamp technique"],[4696,4888,"was improperly executed."],[4888,4942,"No."],[4942,5138,"You need to perform a Marksman modified"],[5138,5376,"Pringle maneuver with selective hepatic"],[5376,5513,"arterial ligation,"],[5513,5684,"followed by a rapid sequence"],[5684,5839,"vascular anastomosis"],[5839,6185,"using interrupted 6-0 proline sutures."],[6322,6431,"Yes."],[6564,6698,"Yes."],[6869,7107,"How do we even know he made a phone call?"],[7107,7257,"This whole thing is performance,"],[7257,7369,"a charade."],[7369,7561,"You stole his methods."],[7561,7799,"This entire launch party"],[7799,8087,"is built upon stolen work and guesswork."],[8124,8224,"That's a lie."],[8224,8375,"Then prove me wrong."],[8375,8504,"Show them all a technique"],[8504,8604,"that I didn't create."]],"44":[[37,262,"Why would we believe anything he says?"],[262,433,"He was fired. Humiliated."],[462,638,"You're right, I was fired."],[638,750,"And the same procedures"],[750,900,"I pioneered were renamed"],[900,1042,"and sold back to the board"],[1042,1205,"as “revolutionary.”"],[1205,1301,"No, you know what?"],[1301,1422,"This is pathetic."],[1422,1551,"He's just jealous."],[1551,1689,"He missed his shot."],[1689,1881,"Is that what you told yourself?"],[1881,2039,"When you snuck back into my office"],[2039,2248,"and stole my surgical journal?"],[2248,2419,"Even if that were true,"],[2419,2644,"this isn't the time or the place."],[2644,2944,"I think it's exactly the time and place."],[4041,4141,"I just got off the phone"],[4141,4375,"with our surgical coordinator,"],[4375,4608,"and thanks to Adrian's guidance,"],[4608,4863,"our surgeons were able to stabilize"],[4863,5038,"the coding patients."],[5038,5338,"Adrian just cleaned up your mess."],[5363,5559,"You took this good man's techniques"],[5559,5860,"that weren't ready, and you fired him."],[5897,6156,"The one person who could make them safe."],[6306,6610,"Dad, you don't see the full picture here."],[6610,6861,"Oh, I'm seeing it perfectly well."],[6861,7094,"This hospital was built on trust"],[7094,7223,"and integrity."],[7223,7465,"And you've disgraced them both."],[7465,7649,"Your father nearly died"],[7649,7870,"because of your ego."],[7870,8095,"Because of his lies."],[8191,8362,"You saved me."],[8362,8529,"You saved Nelson."],[8529,8829,"And now you can save Vale."],[8829,9025,"I tried to warn you all."],[9025,9138,"No one listened."],[9138,9321,"They're listening now."],[9321,9605,"You deserve to be at Vale"],[9605,9855,"more than either of those two."],[9855,10093,"And probably even more than me."],[10093,10272,"It was a mistake to let you go."]],"45":[[0,258,"Months ago, I was fired from Vale Hospital."],[258,529,"With procedures still in development."],[529,658,"They weren't ready."],[658,880,"They needed supervision."],[880,1021,"Precision."],[1021,1146,"Development."],[1146,1280,"Instead, someone took my notes"],[1280,1514,"and tried to fast track them for glory."],[1580,1726,"You can't prove that."],[1805,2031,"Security footage."],[2235,2385,"Of you stealing Adrian's"],[2385,2548,"notebook from the hospital."],[2681,2873,"Already submitted to the board."],[2923,3219,"I built on what he started."],[3219,3315,"Okay."],[3315,3445,"I didn't steal."],[3445,3657,"I enhanced it."],[3657,3849,"Then why were patients about to die?"],[4004,4229,"You falsified rollout readiness?"],[4229,4404,"He did more than that."],[4404,4604,"He put lives at risk"],[4604,4783,"to prove that he was smarter than the guy"],[4783,4984,"that actually created the program."],[4984,5100,"We're going to need to open"],[5100,5288,"a formal investigation on this."],[5330,5509,"This is absurd."],[5509,5680,"This was supposed to be our night."],[5680,5926,"Oh, it's your night."],[5926,6114,"Just not the way you thought it'd be."]],"46":[[16,141,"You lied to me."],[141,250,"I didn't lie."],[250,433,"I simplified the truth."],[433,575,"Simplify?"],[575,775,"You could have caused serious harm"],[775,1038,"to countless innocent people."],[1038,1109,"You nearly killed"],[1109,1297,"the president of the hospital."],[1297,1493,"You passed off experimental procedures"],[1493,1630,"as launch ready?"],[1630,1785,"That’s malpractice."],[1785,1910,"They worked!"],[1910,2022,"Nelson's alive!"],[2022,2231,"Look! The patients. They're alive."],[2231,2352,"Yeah, because of me."],[2377,2494,"Those methods require"],[2494,2773,"sequential tensioning. Breath control."],[2773,2894,"Special clamp techniques."],[2894,3044,"Getting one beat wrong is the difference"],[3044,3174,"between life and death."],[3174,3399,"Wait, these really are your techniques?"],[3432,3603,"I tested them for years."],[3720,3962,"It was never meant for mass rollout."],[3962,4104,"Not without training."],[4104,4304,"You're rewriting history?"],[4304,4354,"No."],[4354,4579,"You tried to erase him from it."],[4579,4704,"Adrian Marksman"],[4704,4792,"was the reason"],[4792,5038,"that Vale's program had a future."],[5038,5271,"And without him, it won't."],[5271,5442,"This is absurd."],[5442,5538,"You're siding with this"],[5538,5751,"disgraced former resident."],[5751,5951,"He's not disgraced, son."],[5951,6022,"You are."]],"47":[[4,145,"You hijacked a program"],[145,271,"you didn't understand."],[271,617,"And then when your ego wasn't enough,"],[617,909,"you propped up this fraud."],[1017,1180,"You’re taking his side, dad?"],[1234,1322,"I'm your son!"],[1322,1551,"I'm taking the side of truth."],[1618,1735,"And so will the board."],[1735,1822,"We will be convening"],[1822,2064,"an emergency session tomorrow morning."],[2064,2131,"Until then,"],[2131,2252,"both of you are suspended"],[2252,2364,"from all surgical"],[2364,2552,"and administrative duties."],[2552,2656,"Suspended?"],[2656,2761,"Oh, no. No, you can't do that."],[2761,2898,"You don't understand the politics"],[2898,3040,"of running a hospital."],[3040,3186,"We understand the liability."],[3186,3311,"That's enough."],[3490,3645,"Mr. Preston Vale."],[3645,3841,"Doctor David Marsden."],[3841,3949,"Come with us."],[4049,4149,"Dad."],[4149,4295,"You're not gonna let them drag me out like this,"],[4295,4375,"I’m your son!"],[4375,4542,"No! Don't you touch me!"],[4542,4683,"You’re not a child."],[4683,4788,"Hey, dad."],[4813,4917,"I built this!"],[5013,5109,"Son of a--"],[5167,5276,"Do something!"],[5276,5405,"I’m your son!"],[5405,5538,"You’re not a child!"],[5538,5722,"You're not my responsibility."]],"48":[[304,467,"Adrian, please."],[467,675,"I made a mistake. I see that now."],[675,842,"I should have believed in you."],[842,1080,"I should have stood by you."],[1080,1380,"You were right about everything."],[1551,1789,"Just give me a second chance."],[1789,1956,"Please."],[1956,2231,"I still love you."],[2231,2339,"Love?"],[2339,2456,"You traded him the second"],[2456,2648,"someone flashier walked by."],[2686,2902,"You don't understand."],[2902,3169,"I thought he was finished."],[3169,3299,"I thought he had nothing left."],[3299,3486,"So you sold him out?"],[3486,3632,"Mocked him,"],[3632,3803,"over and over again."],[3891,4074,"I was scared."],[4074,4208,"I didn't know what to do."],[4208,4312,"Oh, you knew."],[4312,4525,"You just didn't care."],[4525,4633,"Not until you realized"],[4633,4738,"that the horse you bet on"],[4738,4896,"turned out to be a loser."],[4917,5030,"Please,"],[5117,5288,"say something."],[5376,5484,"Anything."],[5484,5709,"You had your chance, Fionna,"],[5709,5901,"and you spent it holding Preston's arm"],[5901,6089,"while they tried to bury me alive."]],"49":[[162,379,"You always belonged in my operating room."],[442,538,"And I should have fought"],[538,700,"harder to keep you."],[700,809,"If I had only known"],[809,1067,"what was going on behind the scenes."],[1088,1372,"The board will vote that Preston"],[1372,1522,"is removed from the board,"],[1522,1718,"and David will never go near"],[1718,1926,"another patient again."],[1926,2081,"We're rebuilding,"],[2081,2277,"and I want you back."],[2277,2464,"As Vale’s Chief"],[2464,2715,"of Experimental Surgery."],[2836,3065,"I'm sorry, Doctor Vale."],[3065,3282,"You had your chance too."],[3282,3499,"I'm not the same man that you fired."],[3628,3862,"All the more reason we need you back at Vale."],[3924,4112,"Adrian 2.0."],[4112,4279,"I'm not coming back."],[4475,4629,"You're choosing her?"],[4629,4775,"Our rival?"],[4775,5013,"You arrogant little ingrate."],[5013,5142,"I open the door for you,"],[5142,5430,"and you slam it in my face."],[5447,5580,"Just typical."],[5668,5839,"Just when you had your moment,"],[5839,5985,"you turn your back on it."],[5985,6177,"For, for what? Her?"],[6177,6310,"She's just going to use you up"],[6310,6585,"and toss you aside like everyone else."],[6585,6831,"Oh. Projecting much Nelson."],[6931,7111,"Get me out of here."],[7111,7232,"Now!"]],"50":[[54,304,"Karma has good timing."],[467,633,"Speaking of timing,"],[633,825,"we should get back to work."],[825,967,"We have lives to save."],[967,1063,"Hey,"],[1163,1338,"not so fast, Mr."],[1338,1609,"Hotshot genius surgeon."],[1609,1843,"I still owe you that"],[1843,2002,"extra special bonus."],[2152,2235,"Now?"],[2235,2423,"Well there’s no time like the present."],[3215,3457,"This is what victory tastes like."],[3457,3641,"It's not bad."],[3641,3795,"I need a second opinion."],[4045,4216,"Well I’ve got all night."],[4216,4362,"And you're not leaving this room"],[4362,4617,"until I've properly celebrated"],[4617,4771,"my genius surgeon."],[4771,4846,"Should I be afraid"],[4846,5092,"of a performance review?"],[5092,5409,"You're already exceeding expectations."],[5409,5613,"But I am very thorough."],[6277,6439,"Getting fired was the best thing"],[6439,6598,"that ever happened to me."],[6756,6952,"Besides meeting you, of course."]]}