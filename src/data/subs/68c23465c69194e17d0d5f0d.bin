{"1":[[0,241,"Three... Two... One..."],[241,320,"Push!"],[320,450,"Good Job!"],[670,816,"Deep breath!"],[816,1066,"Three... Two... One..."],[1066,1208,"Push!"],[1975,2145,"Congratulations!"],[2145,2325,"It's a baby girl."],[3183,3379,"Hey, my sweet girl..."],[3404,3604,"You’re all I’ve got now."],[3604,3816,"My little hope..."],[4204,4358,"Edith,"],[4454,4679,"you’re my best friend."],[4712,4958,"Now our girls have birthday twins,"],[4958,5033,"like"],[5033,5250,"the universe is giving me a do over."],[5250,5479,"A chance to make things right."],[5512,5754,"Your husband died driving for us."],[5754,5891,"For me."],[5891,6145,"I think about it everyday, Edith."],[6145,6358,"I'll never stop blaming myself."],[6358,6458,"I owe you"],[6458,6708,"and your baby everything."],[6883,7012,"Babe."],[7083,7191,"Let’s buy the house next door"],[7191,7350,"and give it to Edith."],[7387,7500,"We'll be neighbors."],[7500,7595,"Raise our girls"],[7595,7762,"side by side,"],[7837,7983,"like sisters."],[8129,8354,"Thank you, Claire..."],[8862,9108,"Edith?"],[9108,9229,"Oh God!"],[9295,9508,"Oh my baby!"],[9995,10170,"Wait, wait, wait..."],[10262,10408,"Are you sure about this, Edith?"],[10441,10562,"What if Claire finds out?"],[10562,10662,"She won't."],[10662,10808,"She's out cold!"],[10837,11004,"That smug bitch."],[11004,11083,"I mean what she got"],[11083,11204,"that I haven't got."],[11204,11333,"She’s not smarter."],[11333,11437,"She’s not hotter."],[11454,11558,"She‘s just"],[11558,11654,"lucky-born"],[11654,11816,"with a big old silver spoon"],[11816,11929,"up her ass."],[11950,12070,"CEO?"],[12083,12300,"CEO my ass!"],[12300,12395,"And then,"],[12416,12495,"she has the nerve"],[12495,12608,"to make me"],[12608,12729,"her secretary,"],[12750,12941,"like that was a charity."],[12941,13137,"My brilliant husband,"],[13137,13225,"all he had to do"],[13225,13358,"was play the driver,"],[13358,13537,"get close to Claire and"],[13537,13658,"take her out."],[13725,13825,"The idiot"],[13825,13970,"goes and gets himself killed"],[13970,14137,"before he even tries!"],[14216,14387,"If I can't beat her head on,"],[14387,14500,"I am going to make her"],[14500,14737,"raise my baby like a princess."],[14762,15016,"And I'm going to raise hers in hell."],[15195,15454,"I'm gonna make her darling angel"],[15454,15550,"pay"],[15550,15679,"for everything"],[15679,15908,"that I have been through."]],"2":[[862,1037,"It’s okay, my baby..."],[1037,1300,"I won't let anyone hurt you."],[3162,3283,"I'd like to see you try"],[3283,3504,"and hurt my daughter."],[4112,4220,"Mom, dad!"],[4220,4358,"How do I look?"],[4370,4562,"Absolutely stunning."],[4562,4704,"My girl could wear a trash bag"],[4704,4887,"and still steal the show."],[4887,4979,"Phoebe,"],[4979,5237,"you look amazing!"],[5258,5362,"Do you like the birthday gift"],[5362,5454,"I got you?"],[5454,5583,"Of course, Aunt Edith."],[5583,5750,"I love everything you give me."],[5750,5870,"Such a sweet-talking"],[5870,6037,"little angel."],[6037,6216,"Beautiful and polite."],[6216,6341,"Unlike this one."],[6379,6475,"Dumb as a rock!"],[6475,6666,"God knows who she got it."],[6679,6904,"Edith, did you hit Lucy again?"],[6966,7104,"You can't raise a child like that!"],[7104,7275,"There's got to be a better way."],[7287,7450,"She deserves it!"],[7450,7662,"Which is always moping around"],[7662,7812,"like the world owes her."],[7812,8000,"Always with a damn attitude."],[8000,8066,"Just looking at her"],[8066,8191,"makes my skin crawl!"],[8316,8345,"What,"],[8345,8512,"do you need a written invitation"],[8537,8725,"to say hi to Phoebe?"],[9266,9350,"I’m sorry, Mom."],[9350,9466,"I didn’t mean to..."],[9691,9800,"Jesus, Edith!"],[9800,9879,"That's your daughter,"],[9879,9991,"not a punching bag!"],[9991,10054,"You're treating her"],[10054,10175,"like she’s your enemy's daughter"],[10175,10262,"or something."],[10262,10500,"Oh! She's a damn curse."],[10500,10587,"She's lucky that"],[10587,10737,"I haven't buried her yet!"],[10737,10837,"Enough!"],[10837,10987,"Their birthday party is coming up soon."],[10987,11045,"And now you expect"],[11045,11212,"to show her face like this?"],[11316,11425,"Pheebs,"],[11425,11504,"honey,"],[11504,11641,"take Lucy upstairs."],[11666,11816,"Help her with her wounds."],[12391,12512,"So..."],[12512,12641,"Rumour has it,"],[12641,12808,"that you're handing over the company"],[12808,12950,"to Phoebe at the party."],[12987,13100,"Is it true?"],[13137,13212,"Yeah."],[13212,13362,"That's the plan. Why?"],[13362,13475,"Just curious."],[13475,13737,"Pheebs is a star!"],[13737,13962,"She is just born to lead."],[13962,14079,"Perfect!"],[14079,14237,"Phoebe's my blood."],[14237,14462,"The second you sign those papers."],[14462,14587,"I'm taking her back"],[14587,14750,"and kicking your smug ass"],[14750,14845,"to the curb."],[14854,14991,"You really think"],[14991,15137,"the girl you’ve been abusing"],[15137,15350,"for 18 years is mine?"],[15375,15616,"Can't wait to watch your world collapse"],[15616,15829,"when you find out the truth."]],"3":[[233,300,"I..."],[300,458,"I don't want to mess your rug up."],[458,600,"It's a rug,"],[600,758,"not a museum piece."],[766,925,"Because if it gets dirty, we'll clean it."],[925,1079,"Come on."],[1266,1508,"Your room is gorgeous."],[1558,1737,"It's just like you."],[1866,2087,"Your mom gave me this."],[2133,2183,"But..."],[2183,2366,"I want you to have it."],[2366,2516,"You’ll rock it way harder than me."],[2516,2679,"No, no, I can't!"],[2725,2833,"It's yours."],[2833,2887,"And..."],[2887,3037,"If my mom sees me wearing your stuff,"],[3037,3141,"she'll kill me."],[3158,3383,"Lucy, I've got your back."],[3429,3541,"Besides,"],[3541,3741,"your birthday is coming up too."],[3766,3987,"Call it an early present."],[4079,4295,"Thank you... Pheebs."],[4341,4566,"Girl, you look incredible!"],[4566,4675,"Mom, isn’t she killing it"],[4675,4841,"in that dress?"],[4895,4979,"She's stunning."],[4979,5216,"Just missing the right pair of shoes."],[5308,5541,"These are my birthday gifts to you."],[5541,5804,"Go on, try them on! I want to see."],[5804,5870,"Oh!"],[5870,6012,"Aunt Claire,"],[6012,6154,"thank you!"],[6254,6341,"You two are the only ones"],[6341,6512,"nice to me."],[7100,7266,"You little thief!"],[7437,7683,"You stealing Phoebe’s dress now?"],[7683,7816,"Aunt Edith, stop!"],[7816,7950,"I gave it to her!"],[7958,8020,"Oh,"],[8020,8166,"you gave it away?"],[8166,8204,"You..."],[8204,8329,"You didn't like it?"],[8329,8391,"That's okay."],[8391,8545,"Look, I’m going to take you out,"],[8545,8733,"and I'm gonna buy you ten more!"],[8750,8833,"You can pick."],[8833,9016,"It's not about that."],[9016,9191,"The party is in two days."],[9191,9341,"We're turning 18."],[9341,9520,"I've got closets full of gowns,"],[9520,9658,"but Lucy doesn't even own"],[9658,9758,"a proper dress."],[9779,9858,"She hasn't worn"],[9858,9991,"anything new in years."],[9991,10137,"Oh, sweetie."],[10183,10354,"You are just too kind"],[10354,10479,"for your own good."],[10491,10666,"Plus, giving designer clothes"],[10666,10779,"to trash like that?"],[10779,10929,"It’s a waste of fabric!"],[10929,11108,"Please don't talk about her like that."],[11108,11245,"It's cruel!"],[11245,11379,"The thick skin like that."],[11379,11541,"I don't think she felt it."],[11675,11816,"Take it off!"],[11816,11883,"The shoes,"],[11883,12033,"the dress, everything!"],[12033,12245,"You don't get to play princess."],[12245,12545,"Those shoes are my gift to Lucy."],[12566,12658,"You really want her"],[12658,12845,"turning up to her 18th birthday party"],[12845,13041,"with nothing decent to wear?"],[13045,13166,"Why not?"],[13166,13358,"I mean, that is what she deserves."],[13358,13454,"Girls like that"],[13454,13629,"don't get to play dress-up!"]],"4":[[0,137,"Edith, she's your daughter."],[137,275,"How could you say that?"],[275,325,"Come on."],[325,525,"She's not some porcelain doll."],[525,662,"Plus, a little tough love"],[662,787,"never hurt anyone."],[950,1200,"What the hell are you looking at?"],[1200,1383,"I said take it off!"],[1412,1520,"Now!"],[1612,1800,"Still not moving?"],[1800,1891,"Okay,"],[1941,2100,"I'll help you."],[2100,2179,"No!"],[2179,2262,"No! Mom, please!"],[2262,2379,"No! Stop!"],[2379,2466,"Sorry!"],[2466,2650,"Mom! I'm sorry!"],[3325,3362,"Oh..."],[3362,3450,"Oh my God!"],[3450,3537,"Lucy you're bleeding."],[3537,3637,"Don’t touch her, Pheebs."],[3637,3775,"She’s filthy!"],[3837,4025,"You pathetic wreck!"],[4025,4262,"Look, you ruined Phoebe's dress."],[4262,4525,"Why don't you just drop dead already!"],[4525,4687,"Mom, I'm sorry."],[4687,4954,"Don't call me that!"],[5220,5400,"Stop with the crying."],[5400,5550,"Get up!"],[5550,5700,"Apologise to Phoebe!"],[5712,5837,"That's enough!"],[5895,5987,"Look at her."],[5987,6183,"She's terrified."],[6262,6379,"Oh, Phoebe."],[6379,6500,"Did she frighten you?"],[7095,7237,"This is all your fault!"],[7237,7425,"You worthless little brat!"],[7425,7775,"Get your filthy ass outta here!"],[7775,8020,"I do not want your disgusting blood"],[8020,8200,"all over Phoebe's rug."],[8212,8433,"Oh Mom, I'm sorry!"],[8433,8525,"Mom!"],[8637,8887,"Mom, isn't Lucy Edith's daughter?"],[8887,9125,"Why is she so cruel to her?"],[9125,9337,"I wish I knew, baby."],[9387,9550,"Maybe losing Lucy's father so young"],[9550,9700,"broke something inside her."],[9700,9850,"Maybe it twisted her in ways"],[9850,10037,"we never saw coming..."],[10429,10612,"Mom... should we do something?"],[10641,10775,"That sounded awful."],[10775,10975,"It's not our place, honey."],[11087,11166,"Edith,"],[11166,11375,"when you finally realise the girl"],[11375,11587,"you’ve tortured all these years"],[11587,11816,"is your own flesh and blood."],[11825,12162,"I hope the guilt eats you alive."]],"5":[[50,120,"Hi!"],[120,258,"Thank you."],[425,725,"Aunt Edith!"],[1091,1195,"Jesus, Edith."],[1195,1337,"What happened to Lucy's leg?"],[1337,1475,"Oh, she ruined Phoebe's dress,"],[1475,1570,"so she got the punishment"],[1570,1700,"she deserves."],[2020,2083,"Oh, come on!"],[2083,2212,"Don't make a scene."],[2212,2400,"Kids bounce back. She's fine."],[2400,2508,"Edith,"],[2508,2725,"today is Lucy’s 18th birthday, too."],[2775,2916,"Whatever happens,"],[2916,3054,"you don't lay a hand on her,"],[3054,3250,"especially not today."],[3316,3391,"Relax."],[3391,3491,"If she causes any trouble,"],[3491,3654,"we’ll just throw her in the basement."],[3662,3775,"We're not going to let her ruin"],[3775,3908,"Phoebe's big day."],[3908,4087,"Not with her bad energy."],[4087,4200,"Exactly!"],[4200,4320,"Today,"],[4320,4529,"is all about Phoebe."],[4550,4612,"Lucy?"],[4612,4725,"She's just here to help you"],[4725,4837,"with your dress and"],[4837,4954,"keep her mouth shut."],[4995,5166,"She's your daughter, Edith."],[5195,5375,"Not Phoebe’s maid!"]],"6":[[79,166,"Oh, Claire."],[166,270,"I'm just your secretary,"],[270,345,"remember?"],[345,450,"So clearly that"],[450,666,"Lucy’s not on the same level as Phoebe."],[666,737,"Besides,"],[737,858,"helping you with the dress,"],[858,1054,"that's a privilege for Lucy."],[1312,1358,"Phoebe,"],[1358,1500,"what's happened to your hand?"],[1595,1745,"Why is there a bandage?"],[1745,1854,"Claire."],[1854,2033,"How did you let her hurt her hand?"],[2045,2183,"It's just a scratch, Edith."],[2183,2270,"She's fine."],[2270,2337,"A couple of days"],[2337,2454,"and she'll bounce back."],[2454,2554,"You know how kids are."],[2579,2687,"How can you say that?"],[2687,2808,"This hand is worth millions!"],[2850,2941,"Don't you get that?"],[2941,3037,"That's enough."],[3108,3145,"You're the reason"],[3145,3287,"she got hurt in the first place."],[3287,3408,"You trashed her room"],[3408,3541,"going off on Lucy."],[3541,3662,"Shattered the glass."],[3662,3787,"She was picking up your mess"],[3787,3908,"when she cut herself."],[3908,4079,"Why wasn't the maid doing it?"],[4079,4195,"What kind of parents"],[4195,4400,"let their child handle broken glass."],[4400,4508,"Phoebe's mature."],[4508,4733,"She takes care of her own space."],[4733,4904,"It's just a small scratch, Edith."],[4904,5054,"But Lucy's hand"],[5054,5158,"is still slashed up"],[5158,5300,"and covered in gauze."],[5300,5475,"That's not the same."],[5475,5575,"Lucy’s tough,"],[5575,5687,"she's built for this."],[5687,5912,"Don't ever try to compare the two."],[5912,6079,"All right, all right."],[6079,6200,"Let's just all"],[6200,6291,"take a breath."],[6291,6400,"Mrs. Watts,"],[6400,6504,"don't take it personally."],[6504,6587,"My sister"],[6587,6745,"just get a little over the top"],[6745,6933,"when it comes to Phoebe. Okay?"],[6966,7029,"Yeah!"],[7029,7095,"I mean,"],[7095,7270,"she’s going to inherit millions, right?"],[7270,7362,"They're going to be signing"],[7362,7562,"seven figure deals one day."],[7591,7808,"Where Lucy's built to scrub floors."],[7808,7916,"If she wrecks her hands."],[7916,8008,"Who cares?"],[8008,8150,"That's what they're here for."],[8150,8237,"So,"],[8237,8375,"let me get this straight."],[8375,8500,"You don't even blink"],[8500,8666,"while your daughter is bleeding."],[8666,8820,"But my kid gets a small cut"],[8820,9000,"and you lose your mind?"],[9000,9158,"If I didn't know any better,"],[9208,9454,"I'd think Phoebe was your daughter."]],"7":[[33,150,"Oh! Claire."],[150,216,"I mean,"],[216,391,"we've been best friends"],[391,504,"since forever."],[512,654,"I've always treated your girl"],[654,737,"as my own."],[737,870,"And what's not to love?"],[870,1070,"Phoebe has been a sweet heart angel"],[1070,1183,"since day one."],[1212,1304,"Yeah. I mean,"],[1304,1391,"Lucy could never"],[1391,1512,"compare to Phoebe."],[1541,1625,"Pheebs,"],[1625,1720,"honey,"],[1720,1908,"you have one job in life."],[1908,2025,"You just enjoy it."],[2025,2125,"I mean, your parents"],[2125,2258,"they're loaded."],[2258,2404,"Get them to buy your shoes"],[2404,2516,"and handbags,"],[2516,2654,"whatever sparkles!"],[2654,2791,"Leave all that boring stuff,"],[2791,2954,"carrying thing, cleaning,"],[2954,3062,"leave it to Lucy."],[3062,3237,"Because that's what she's here for."],[3237,3404,"You treat your own daughter"],[3404,3512,"like a servant."],[3512,3591,"Let's see if that"],[3591,3812,"smug grin survives the truth."],[3841,4000,"Oh! Claire,"],[4000,4154,"did you get that paperwork ready"],[4154,4279,"for the shares?"],[4400,4566,"Yes, I did."],[4620,4737,"There you go again."],[4737,4962,"Ruining my daughter's big surprise."],[4962,5020,"Wait,"],[5020,5141,"seriously?"],[5141,5329,"Mom, I'm only 18."],[5329,5441,"You're already giving me"],[5441,5558,"shares in the company?"],[5558,5779,"Of course she is, Pheebs!"],[5779,5895,"You’re brilliant,"],[5895,6016,"you’re beautiful,"],[6016,6137,"you’re born to lead."],[6137,6370,"And I am so proud of you, honey."],[6370,6458,"Well,"],[6458,6662,"she is my pride and joy."],[6662,6820,"No one compares."],[6820,6895,"And I mean,"],[6895,6979,"no one"],[6979,7158,"compares to my girl."],[7166,7316,"Keep gloating, Claire."],[7316,7508,"Once Phoebe gets those shares,"],[7508,7625,"I'll drop the bomb."],[7625,7850,"Your company will be mine."],[8033,8162,"Hello?"],[8162,8400,"The results are in."],[8400,8500,"I'll get my brother to come"],[8500,8650,"and pick them up."],[8733,8841,"Aunt Edith,"],[8841,8925,"what results?"],[8925,9012,"Just a surprise"],[9012,9133,"I'm cooking up."],[9187,9312,"One you’ll never forget."],[9329,9445,"Another one?"],[9445,9504,"You've already"],[9504,9637,"spoiled me like crazy!"],[9637,9779,"Oh, trust me, honey."],[9779,9904,"You’ll understand everything"],[9904,9987,"soon enough."],[9987,10062,"Alright,"],[10062,10237,"looks like everyone’s here."],[10237,10354,"Let’s go in."],[10391,10495,"Save your big reveal"],[10495,10662,"for the crowd, okay, Edith?"],[10983,11133,"Keep smiling, Claire."],[11133,11304,"Because your public meltdown"],[11304,11579,"is everything I’ve dreamed of."],[11645,11725,"Move it!"]],"8":[[1191,1345,"Who's that next to Phoebe?"],[1370,1529,"Why is she dressed like that?"],[1529,1675,"Is she Phoebe's maid?"],[1675,1920,"She won't even lift her head."],[1920,2204,"Is this some kind of punishment?"],[2204,2395,"She's standing next to Phoebe."],[2395,2525,"It's like the swan"],[2525,2695,"and the Ugly Duckling."],[2712,2916,"Claire, you say we’re friends,"],[2916,3083,"but that self-righteous"],[3083,3279,"little queen act of yours,"],[3279,3441,"makes me want to gag."],[3441,3562,"Guess what?"],[3562,3645,"I’ve been grinding"],[3645,3800,"your precious little princess"],[3800,3887,"into the dirt"],[3887,4104,"for eighteen years."],[4104,4341,"Time you get a taste of that."],[4341,4412,"Thank you all"],[4412,4608,"for coming to celebrate my daughter,"],[4608,4683,"Phoebe Watts,"],[4683,4891,"on her eighteenth birthday."],[4891,5075,"Bravo!"],[5579,5733,"We're also here today"],[5733,5954,"to celebrate another special 18th,"],[5954,6254,"my best friend's daughter, Lucy."],[6308,6479,"Wait...She's not the help."],[6479,6683,"Who sends her kid out like that?"],[6683,6783,"Ugh."],[6804,7095,"No class at all."],[7125,7379,"Where's her mother?"],[7379,7616,"Most of you know Phoebe's story."],[7616,7704,"Accepted into"],[7704,7916,"Harvard Business School at 15."],[7916,8075,"Graduated at 17"],[8075,8220,"and already making waves"],[8220,8383,"inside Watts group."],[8387,8520,"That's my girl."],[8520,8700,"Brains, beauty."],[8700,8966,"She obviously got that from me."],[8966,9062,"So,"],[9062,9150,"today,"],[9150,9304,"I'm making it official."],[9875,10016,"Today I’m transferring"],[10016,10245,"all my shares of Watts Group"],[10312,10512,"to Phoebe."],[11083,11225,"Happy birthday, sweetheart."],[11225,11279,"You're now"],[11279,11404,"the majority shareholder"],[11404,11525,"of Watts Group."],[11550,11775,"This is my birthday gift to you."],[11775,12004,"Your first step into adulthood"],[12004,12216,"and your first real challenge."],[12300,12416,"Finally."],[12416,12670,"Now, let the real show begin."]],"9":[[4,100,"Mom..."],[100,241,"what if I screw this up?"],[241,320,"Hey,"],[320,433,"look at me."],[433,537,"You're my daughter."],[537,825,"I never bet on the wrong horse, baby."],[887,1012,"Remember that ski trip"],[1012,1116,"when you were eight?"],[1116,1283,"Top of the slope,"],[1283,1404,"knees shaking."],[1404,1512,"Look at you now."],[1512,1629,"Advanced, certified."],[1629,1758,"Tearing through competitions"],[1758,1925,"like it's nothing."],[1925,2212,"You're stronger than you think."],[2316,2495,"That's right, baby girl."],[2495,2637,"You're a star,"],[2637,2766,"just like your mama."],[2766,3025,"Born to take the crown."],[3041,3200,"You got this Phoebe."],[3200,3370,"We're all rooting for you."],[4000,4133,"Thanks, Mom."],[4133,4304,"I won't let you down."],[4304,4529,"I’m gonna run Watts Group like a boss."],[4529,4791,"Take it higher than it's ever been."],[4962,5195,"That's my girl! Pheebs."],[5250,5487,"That's what I'm talking about."],[5612,5754,"Why are you behaving that way?"],[5754,5908,"It's not even your daughter."],[5950,6116,"But she is."],[6237,6316,"Phoebe,"],[6362,6591,"the new queen of Watts Group"],[6641,6804,"is my daughter."]],"10":[[683,779,"Aunt Edith..."],[779,929,"What are you talking about?"],[929,1158,"Stop calling me Aunt Edith."],[1191,1400,"The word you’re looking for..."],[1400,1541,"is mom."],[1708,1891,"Mom...I..."],[2087,2191,"Here we go."],[2191,2370,"It's showtime."],[2370,2425,"Edith,"],[2425,2566,"have you lost your damn mind?!"],[2566,2716,"This isn't The Real Housewives."],[2750,2816,"You don't get to talk"],[2816,2987,"crap like this around for laughs."],[2987,3104,"The other day,"],[3104,3287,"I took Lucy to the hospital."],[3329,3454,"One of the doctors there"],[3454,3600,"he recognized me."],[3600,3775,"He broke down in tears,"],[3775,3837,"and..."],[3837,3975,"He said he was the one"],[3975,4275,"that switched our babies at birth."],[4291,4404,"The guilt it finally"],[4404,4516,"caught up with him,"],[4516,4600,"and he just wanted"],[4600,4770,"to put everything right."],[4800,4866,"Edith,"],[4866,4995,"please tell me you're joking."],[4995,5195,"This really isn't the time or place"],[5195,5400,"for one of your soap opera moments."],[5408,5470,"Yeah."],[5487,5537,"Nice try."],[5537,5662,"We raised Phoebe."],[5662,5820,"There's no way she's yours."],[5820,5900,"Edith,"],[5900,6050,"I know how much you care"],[6050,6158,"about Phoebe."],[6158,6287,"But did you ever think about"],[6287,6475,"what this would do to Lucy?"],[6525,6637,"Mom..."],[7416,7537,"Her? I..."],[7558,7675,"I fed her,"],[7687,7800,"clothed her,"],[7800,8079,"I even paid for 18 years of schooling."],[8079,8279,"That's more than she ever deserved."],[8279,8504,"Now, I just want what's mine."],[8504,8658,"My real daughter,"],[8695,8804,"Phoebe."],[8804,8945,"Look at her, Edith."],[8945,9104,"You beat the soul outta that girl"],[9104,9212,"and now you gonna stand here"],[9212,9366,"and call yourself a good mom?!"],[9366,9512,"That's called discipline."],[9745,9912,"I did you two a favour,"],[9912,10033,"I stopped her from becoming"],[10033,10208,"some soft princess."],[10208,10254,"Look,"],[10254,10408,"thank you so much"],[10408,10600,"for raising Phoebe so well."],[10620,10695,"But,"],[10770,10941,"I'll take it from here."],[10966,11062,"So, Edith,"],[11062,11216,"you're absolutely sure"],[11216,11375,"that Phoebe is yours?"],[11441,11579,"I'm not stupid."],[11579,11779,"I knew there would be questions."],[11779,11979,"And that is why I"],[11979,12170,"did a DNA test."],[12408,12516,"Josh will be back"],[12516,12737,"with the results very soon."],[13212,13341,"No, no..."],[13375,13512,"This can't be right."],[13562,13712,"Oh, what the hell!"]],"11":[[8,229,"You actually did a DNA test?"],[229,341,"Of course I did."],[366,487,"And science"],[487,637,"doesn't lie."],[704,804,"Pheebs,"],[804,1033,"this is mommy's big surprise."],[1033,1158,"Do you love it?"],[1220,1320,"Mom..."],[1370,1462,"No."],[1462,1583,"That's not your mom."],[1583,1666,"I am."],[1704,1941,"I'm your real mother now."],[1941,2029,"Jesus, Edith."],[2029,2112,"Enough!"],[2112,2241,"The results aren't even here yet."],[2241,2412,"You don't get to just claim her."],[2412,2604,"They'll be here any second."],[2604,2904,"I have lost 18 years with my girl."],[2904,3137,"And I’m not losing another second!"],[3150,3316,"Tell me, Edith."],[3316,3441,"Are you really sure that"],[3441,3620,"Phoebe's yours?"]],"12":[[0,150,"Of course, I'm sure."],[150,329,"I was the one that swapped them."],[329,404,"I don't need some"],[404,579,"stupid piece of paper"],[579,762,"to tell me what I already know."],[779,941,"You all keep acting like"],[941,1075,"Phoebe's not mine."],[1137,1208,"Why?"],[1208,1316,"Because Lucy's not"],[1316,1458,"good enough for you?"],[1479,1604,"She's no Phoebe,"],[1604,1766,"but she's a pretty good maid."],[1766,1870,"If you don't want her"],[1870,1970,"as your daughter,"],[1970,2141,"you could just keep her around to clean."],[2141,2245,"If you get tired,"],[2245,2304,"pissed off,"],[2304,2412,"just"],[2412,2570,"give her a few slaps, kicks."],[2570,2666,"She can take it."],[2666,2850,"She knows how to take a beating."],[5445,5608,"Does that sound good to you?"],[5645,5845,"You pathetic little reject,"],[5845,6145,"even your real parents don't want you."],[6229,6379,"Enough!"],[6445,6645,"I never look down on Lucy"],[6645,6791,"and I never will."],[6812,6945,"Jumping to conclusions"],[6945,7112,"won't fix anything."],[7187,7433,"It'll only rip them both apart."],[7433,7733,"Still clinging to your little fairy tale."],[7733,7879,"The report is coming."],[7879,8000,"And when it does,"],[8000,8129,"I'll be right here."],[8129,8325,"Watching you fall apart."],[9016,9116,"Claire, I get it."],[9116,9254,"Letting go hurts."],[9254,9383,"You look at Lucy,"],[9383,9454,"and you don't see"],[9454,9600,"the daughter you dreamed of."],[9600,9883,"But I'm Phoebe's mother."],[9883,10000,"I'm only taking back"],[10000,10145,"what's rightfully mine."],[10145,10333,"Don't listen to her, Claire."],[10333,10425,"We raised Phoebe."],[10425,10483,"We are there for"],[10483,10670,"every step, every skinned knee."],[10670,10800,"That doesn’t just disappear because of"],[10800,10983,"a few words and a piece of paper."],[11050,11120,"Claire,"],[11137,11312,"you gave that girl your life."],[11312,11483,"I mean, we all saw it your time,"],[11483,11604,"your heart,"],[11604,11700,"all of it."],[11700,11866,"Everything Phoebe is,"],[11866,12050,"That's because of you."],[12050,12229,"You don't just throw that away"],[12229,12420,"and give it to someone like her."],[12662,12770,"Edith!"],[12908,12987,"That's the report."],[12987,13150,"Give it to me."],[13312,13433,"Edith,"],[13483,13558,"what if that doesn't say"],[13558,13725,"what you think it does?"],[13725,13845,"What if you're wrong?"],[13862,13979,"Phoebe's mine."],[13979,14087,"You don't believe me?"],[14087,14233,"Let the test shut you up."]],"13":[[200,312,"Phoebe."],[408,633,"You’re my daughter!"],[704,833,"You’ve always been mine!"],[833,945,"No! No,"],[945,1150,"that's not possible!"],[1191,1383,"This can't be right."],[2308,2408,"What the hell?!"],[2454,2683,"Phoebe's not Edith’s daughter?!"],[2683,2725,"That means"],[2725,2912,"we never switched them!"],[3020,3183,"Our whole plan is backfired!"],[3183,3412,"Phoebe already has WG shares."],[3412,3720,"Edith and I busted our asses for this."],[3791,4041,"Phoebe has to be Edith's daughter!"],[4120,4308,"She has to be!"],[4583,4754,"Back then... I swear..."],[4754,5004,"You can see it with your own eyes."],[5025,5175,"Phoebe's mine."],[5250,5437,"Now do what's right."],[5437,5608,"Give me back my daughter."]],"14":[[4,229,"Are you out of your damn mind?"],[229,362,"That's not how this works."],[362,475,"Why not?"],[529,629,"I get it that"],[629,770,"you've gotten close to Phoebe,"],[770,833,"But..."],[833,1008,"she's my biological daughter."],[1020,1316,"I've already lost 18 years with her,"],[1316,1416,"and I just..."],[1416,1633,"I just want to make it up to you."],[1633,1925,"No, no...Mom..."],[1925,2129,"Please... don't leave me..."],[2129,2254,"Please..."],[2741,2845,"Mrs. Watts,"],[2870,3029,"my brother-in-law died"],[3029,3191,"working for you."],[3191,3366,"You promised you'd look after my sister"],[3366,3479,"and her daughter."],[3479,3570,"Now,"],[3570,3741,"she wants her kid back."],[3741,3879,"What's so wrong with that?"],[3933,4125,"Claire, you're a mom too."],[4125,4270,"You know how deep"],[4270,4425,"a mother's love can run?"],[4475,4637,"Exactly."],[4637,4879,"That's why I never hand my daughter"],[4879,5083,"over to someone like you."],[5254,5425,"Because this test is a fake!"],[5425,5512,"Oh my god!"]],"15":[[20,112,"Fake?"],[112,266,"What are you talking about?"],[266,329,"That's right."],[329,433,"You seriously thought"],[433,529,"you could take her from us"],[529,645,"with a fake report?"],[662,895,"How the hell did that bitch find out?"],[895,979,"Doesn't matter."],[979,1250,"Fake or not, it has to be real now."],[1250,1366,"This is ridiculous."],[1366,1570,"What proof do you have that it's fake?"],[1570,1645,"Claire,"],[1645,1837,"I know this is hard for you,"],[1837,1945,"but you can't just accuse"],[1945,2104,"my brother of fraud."],[2104,2308,"There's no way he would risk jail"],[2308,2454,"with a fake DNA test."],[2454,2533,"Exactly."],[2533,2666,"Everyone wants Phoebe now."],[2666,2762,"But Lucy,"],[2762,2887,"she's the one my sister raised"],[2887,2975,"for 18 years!"],[2975,3137,"You think we just tossed her away?"],[3137,3295,"Unless we were absolutely sure"],[3295,3437,"that she wasn't ours."],[3441,3566,"Raised her?"],[3566,3770,"You call that raising your child?"],[3770,3870,"As long as I've known you,"],[3870,4041,"you've hit her like a hundred times"],[4041,4141,"right in front of us."],[4141,4262,"And that's not even counting the nights"],[4262,4408,"you've locked her up,"],[4408,4479,"starved her,"],[4479,4537,"and treated her like"],[4537,4695,"she wasn’t even human!"],[4887,5062,"Eat, you little mutt!"],[5608,5800,"What are you waiting for?"],[6054,6137,"Mom..."],[6137,6341,"Can I please have a real room?"],[6341,6512,"Like Phoebe's?"],[6875,7025,"Phoebe's everything that"],[7025,7166,"you'll never be."],[7166,7445,"You’re not worth the floor she walks on."],[7445,7600,"So it's either this,"],[7633,7779,"or the street."],[8216,8441,"You lazy bitch!"],[8579,8779,"I told you to clean Phoebe's room."],[8841,9087,"How dare you slack off!"],[9529,9654,"Be honest with yourself."],[9654,9791,"Have you ever treated Lucy"],[9791,9900,"like your daughter?"],[9900,10158,"I was strict because I cared."],[10158,10325,"It was for her own good."],[10325,10466,"That's enough!"],[10529,10704,"If the test is real,"],[10704,10900,"a second one will confirm it."],[10941,11141,"But yours was done in private."],[11162,11237,"So,"],[11237,11387,"why don't we do another one,"],[11387,11516,"right here, right now,"],[11516,11720,"in front of everyone?"],[11720,11791,"That way,"],[11791,12012,"no one will question it again."],[12095,12250,"What do you say, Edith?"],[12250,12320,"You in?"],[12362,12466,"Sure,"],[12466,12633,"why not?"],[12633,12791,"Do the test 100 times."],[12791,12962,"Phoebe's still mine."],[12962,13037,"Perfect."],[13037,13245,"Let's go to the hospital right now."],[13283,13375,"No!"]],"16":[[0,125,"What's wrong? Josh?"],[125,300,"You look guilty as hell right now."],[300,408,"No,"],[408,550,"I'm just thinking about the girls."],[550,675,"Another test?"],[675,812,"It might be too much for them."],[812,925,"You know, emotionally."],[925,1204,"That's unexpectedly thoughtful of you."],[1204,1400,"I didn't know you had a heart."],[1400,1483,"Claire,"],[1483,1583,"he's right."],[1583,1695,"If you want to"],[1695,1908,"drag Lucy through this again."],[1908,1991,"Fine."],[1991,2091,"But think of Phoebe."],[2091,2154,"I mean,"],[2154,2350,"she's been through enough."],[2350,2450,"Look, I get it."],[2450,2662,"Even if the truth is a little messy,"],[2662,2825,"the girls can still stay with you."],[2825,2937,"They’d still be living with you"],[2937,3033,"in the same house."],[3033,3095,"Oh,"],[3095,3200,"and we'll just pretend like"],[3200,3358,"none of this has ever happened."],[3370,3583,"How is that even possible Josh?"],[3629,3791,"I get it."],[3870,4058,"You're embarrassed."],[4058,4241,"That Lucy might actually"],[4241,4420,"be your daughter."],[4562,4754,"Aunt Claire, is that true?"],[4754,4920,"You don't want me?"]],"17":[[25,216,"Why shouldn't we be disappointed?"],[216,320,"Embarrassed too."],[320,445,"I don't care if Phoebe's"],[445,583,"biologically ours or not."],[583,708,"She's the one we raised."],[708,904,"The one we poured everything into."],[904,1100,"She's sharp, driven, going places."],[1100,1208,"And, Lucy?"],[1208,1295,"Look at her."],[1295,1458,"Look what you turned her into."],[1458,1725,"Maybe I wasn't the perfect mother,"],[1725,1895,"but all I really want"],[1895,2079,"is to hear my real daughter"],[2079,2195,"call me mom."],[2250,2416,"Is that too much to ask?"],[2416,2604,"Oh, please cut the act."],[2604,2825,"If this was really about reuniting"],[2825,2929,"with your daughter."],[2929,3079,"Why not do it in private?"],[3079,3187,"Why today?"],[3187,3362,"Why Phoebe's birthday?"],[3416,3595,"You walked in here"],[3595,3745,"waving that DNA test"],[3745,3950,"like it was some kind of prize."],[4037,4154,"Seems like she just wants"],[4154,4312,"a piece of Phoebe's success."],[4312,4470,"That's why she's so eager"],[4470,4604,"to throw Lucy away."],[4604,4708,"Seriously,"],[4708,4887,"who celebrates a baby switch"],[4887,5041,"like they just hit the lottery?"],[5041,5191,"That's just messed up."],[5191,5345,"So tell me, Edith."],[5345,5537,"Was it really about being a mother,"],[5537,5733,"or is it just a shortcut to the top?"],[5733,5912,"I don't know what you're talking about."],[5912,5941,"Yeah,"],[5941,6125,"what the hell are you trying to say?"],[6125,6216,"Claire,"],[6216,6366,"I know I didn't give Lucy"],[6366,6562,"the life that she deserved,"],[6570,6733,"but that doesn't change the fact"],[6733,6975,"she's your biological daughter."],[7004,7229,"If you could just accept her,"],[7258,7350,"maybe"],[7350,7512,"things could get better for Lucy."],[7512,7654,"Oh, give me a break!"],[7654,7787,"Is that what this is really about,"],[7787,7883,"helping Lucy?"],[7883,8045,"Or you just trying to steal our daughter"],[8045,8183,"and take over Claire's company"],[8183,8270,"while you're at it?"]],"18":[[4,108,"Watch it!"],[108,241,"Throwing out false accusations"],[241,320,"like that?"],[320,437,"That is..."],[437,470,"Oh!"],[470,529,"Felony!"],[529,787,"None of us wanted this baby swapped."],[800,900,"Nobody."],[908,995,"Claire,"],[995,1175,"I thought we were best friends."],[1175,1483,"My husband died driving for you."],[1483,1562,"Lucy and I,"],[1562,1691,"we have worked for your family"],[1691,1808,"for 18 years"],[1808,1950,"without a single complaint."],[1950,2070,"How could you think that"],[2070,2270,"I would plot against you?"],[2279,2329,"Yeah."],[2329,2512,"After my brother-in-law died,"],[2512,2633,"I stepped in."],[2633,2808,"I drove for your family"],[2808,3016,"every single day"],[3016,3112,"for years!"],[3112,3270,"Doesn't that count for something?"],[3270,3462,"You raised Phoebe."],[3462,3591,"You’ve made her the company's"],[3591,3733,"biggest shareholder."],[3733,4008,"Even if she's my biological daughter,"],[4008,4170,"I will never let her forget"],[4170,4308,"what you've done for her."],[4395,4512,"She’ll never forget?"],[4512,4595,"Please."],[4595,4729,"First thing I'm doing is"],[4729,4916,"kicking your ass out of that company."],[4941,5037,"Claire,"],[5037,5154,"you're done."],[5183,5300,"So,"],[5300,5433,"all of this is just about"],[5433,5633,"switching the kids back?"],[5633,5750,"Claire,"],[5750,5904,"Lucy may not be perfect,"],[5904,6095,"but I've raised her."],[6095,6266,"This is hard on me, too."],[6266,6491,"But what choice do we have?"],[6491,6791,"I already lost 18 years with Phoebe."],[6808,7025,"I don't want to lose another second."],[7025,7129,"Claire,"],[7129,7304,"you're my best friend."],[7304,7437,"My husband's gone."],[7437,7604,"All I want is to spend"],[7604,7720,"the rest of my life"],[7720,7887,"with my real daughter."],[7887,8100,"Just one simple,"],[8100,8233,"humble wish."],[8233,8425,"Please don't take that from me."],[8437,8516,"Please,"],[8516,8591,"Mrs. Watts."],[8591,8775,"Let my sister have Phoebe."],[8837,8954,"It's only fair."],[8954,9125,"You want to put on a show?"],[9150,9229,"Fine."],[9229,9358,"I'll play along."],[9358,9520,"Let's see how long that mask"],[9520,9704,"stays on before it cracks."],[9750,9854,"Okay."],[9887,9979,"Let's switch."]],"19":[[229,408,"What? Have you lost your mind?"],[408,491,"Mom,"],[491,650,"what are you talking about?"],[770,933,"Maybe they've got a point."],[933,1058,"If the kids were really"],[1058,1175,"switched at birth."],[1175,1283,"Maybe they should go back"],[1283,1445,"to where they belong."],[1554,1641,"You're kidding me, right?"],[1641,1737,"You're going to hand our daughter"],[1737,1879,"over to a manipulative"],[1879,2129,"lunatic over some shady DNA test?!"],[2129,2283,"Of course not! I meant..."],[2283,2491,"Claire, I knew you'd come around."],[2491,2554,"Don't worry."],[2554,2704,"I will raise Phoebe right."],[2704,2829,"No, I'm her father."],[2829,2966,"You don't just toss your kid away"],[2966,3091,"because of a lab result."],[3091,3166,"Mr. Lyons,"],[3166,3333,"your wife already agreed."],[3333,3487,"And the DNA test doesn't lie."],[3487,3537,"So,"],[3537,3641,"like it or not,"],[3641,3795,"this is happening."],[3908,4016,"Mrs. Watts,"],[4016,4083,"you've already transferred"],[4083,4204,"your shares to Phoebe."],[4204,4291,"You're not planning on"],[4291,4408,"pulling that back, right?"],[4408,4516,"Of course not."],[4516,4654,"The paperwork's all done."],[4654,4833,"Phoebe's the largest shareholder"],[4833,4979,"of Watts Group."],[5254,5329,"I knew it."],[5329,5491,"This was never about the kids."],[5491,5616,"It's about the company."],[5616,5791,"Finally showing your hand."],[5791,5983,"Took you long enough."],[5983,6120,"And what are you gonna do about it?"],[6120,6279,"Phoebe runs the company now."],[6279,6370,"And lucky us,"],[6370,6691,"she just so happens to be family."],[6816,6916,"Mr. Lyons."],[6916,7079,"Oh, my bad,"],[7079,7204,"I mean Eric."],[7233,7379,"Have you got a problem with that?"],[7379,7441,"Claire,"],[7441,7529,"for God sakes,"],[7529,7595,"say something!"],[7595,7683,"Are you really just going to"],[7683,7825,"hand over Phoebe and the company"],[7825,7925,"to these snakes?"],[7925,8054,"Oh, Eric."],[8054,8129,"Come on."],[8129,8291,"I mean, Claire's not even upset."],[8291,8433,"Why are you throwing a fit?"],[8433,8600,"She's the one that built Watts Group"],[8600,8679,"from scratch."],[8679,8854,"She raised Phoebe on her own."],[8854,9016,"Now it all belongs to me."],[9091,9195,"So,"],[9195,9433,"are you after my company?"],[9433,9670,"What did you just say?"],[9670,9770,"Oops."],[9770,9970,"Did I say that out loud?"],[9979,10145,"Sorry, darling."],[10145,10283,"Watts Group,"],[10283,10420,"your legacy,"],[10420,10541,"it's mine now."]],"20":[[0,183,"You two are unbelievable."],[183,320,"Treating these girls' lives"],[320,466,"like they're poker chips?"],[466,566,"Are they your daughters,"],[566,695,"or your next investment?"],[695,820,"Oh, Mrs. Watts,"],[820,966,"don't take it so personally."],[966,1087,"We're just trying to reclaim"],[1087,1245,"what's rightfully ours."],[1458,1675,"Claire, you've raised my girl"],[1675,1833,"for 18 years."],[1833,1912,"It's only fair"],[1912,2133,"I give you something in return."],[2400,2591,"Look how well I've trained her."],[2591,2829,"As obedient as a little puppy."],[2829,2950,"It took years."],[2950,3095,"She knows her place."],[3595,3704,"Come on, look at her."],[3704,3845,"Look at your real daughter."],[3845,3937,"Not exactly"],[3937,4125,"Ivy League material, huh?"],[4166,4275,"What's wrong?"],[4275,4391,"You don't want to touch her?"],[4391,4529,"Not so excited now."],[4529,4637,"She’s standing there"],[4637,4779,"in rags and tears."],[4808,4891,"Go on!"],[4891,5008,"Beg your mommy"],[5008,5204,"to take you back."],[5375,5537,"What are you waiting for?"],[5537,5625,"Say it!"]],"21":[[66,100,"Please..."],[100,275,"Please don't hit me."],[316,475,"Pathetic."],[475,550,"Claire Watts,"],[550,704,"that's your daughter now."],[704,895,"A broken little puppet."],[895,1079,"You'll spend the rest of your life"],[1079,1270,"wishing you never took her back."],[1350,1479,"What is wrong with you?"],[1479,1587,"She's just a kid."],[1587,1766,"Even if she's not related to you"],[1766,1870,"by blood,"],[1870,1933,"you do not"],[1933,2100,"treat a child like that."],[2125,2233,"Oh, please."],[2233,2375,"Her real parents don't want her."],[2375,2483,"Why the hell would I?"],[2483,2741,"You raised Lucy for 18 years!"],[2741,2866,"Don't you feel guilty"],[2866,3008,"treating her like this?"],[3008,3183,"If you care so much."],[3183,3362,"Why don't you take her back?"],[3362,3433,"Oh, wait."],[3433,3520,"I know why."],[3520,3695,"Because deep down,"],[3745,3875,"you see it too."],[3875,4012,"She’s just like you."],[4050,4158,"Trash,"],[4158,4295,"unwanted,"],[4295,4370,"worthless."],[4370,4433,"That's it!"],[4433,4608,"You people are monsters!"],[4608,4666,"Claire,"],[4666,4708,"are you really"],[4708,4800,"just going to stand there"],[4800,4925,"and let them tear our family"],[4925,5025,"and company apart?"],[5129,5204,"Claire,"],[5204,5316,"you're smarter than this."],[5316,5395,"How could you let them"],[5395,5483,"play you like that?"],[5483,5575,"Whatever happens,"],[5575,5783,"don't hand Phoebe over to them."],[5875,6029,"Everyone calm down!"],[6029,6254,"Edith and Josh aren't lying."],[6254,6379,"Phoebe and Lucy"],[6379,6554,"were switched at birth."],[6729,6850,"I know this because"],[6850,7012,"I saw it happen."]],"22":[[83,204,"You saw it?"],[204,341,"Are you sure you weren't just"],[341,562,"heartbroken and seeing things?"],[562,704,"Oh, I was heartbroken,"],[704,833,"but I was not blind."],[833,1108,"I saw you and Josh switch my daughter"],[1108,1237,"with my own eyes."],[1254,1441,"Knowingly swapping babies"],[1441,1562,"is a felony."],[1562,1737,"So tell me, Edith."],[1737,1862,"If I turn you both in,"],[1862,1995,"what do you think is going to happen"],[1995,2170,"to this little scheme of yours?"],[2200,2316,"You're bluffing!"],[2316,2504,"Why would I switch my own daughter"],[2504,2675,"with yours on purpose?"],[2675,2816,"That's insane!"],[2816,2908,"No."],[2908,3095,"What's insane is the hatred"],[3095,3300,"that you've had for me for years."],[3300,3504,"You hated me for making it."],[3504,3583,"CEO,"],[3583,3700,"respected."],[3700,3925,"While you stayed the secretary."],[3925,4216,"You hated watching me succeed."],[4216,4279,"So,"],[4279,4400,"you thought you'd hit me"],[4400,4525,"where it hurt most."],[4525,4654,"Torturing the girl"],[4654,4825,"that you thought was mine."],[4825,4945,"Every bruise,"],[4945,5050,"every slap."],[5050,5295,"Every time you made her beg..."],[5295,5541,"You made sure that I watched."],[5541,5691,"Tell me I'm wrong!"],[5920,6062,"You saw all that?"],[6062,6104,"Claire,"],[6104,6250,"are you out of your mind?"],[6250,6358,"You knew for years"],[6358,6466,"and you just stood there,"],[6466,6650,"and let that bitch torture our daughter"],[6650,6783,"for 18 years?"],[6858,7033,"I thought she was a good mom."],[7033,7245,"Turns out she's a sociopath."],[7325,7579,"You saw us switch the babies."],[7579,7712,"And did nothing?"],[7712,7866,"You just let it happen."],[7866,8058,"Maybe you wanted Lucy gone."],[8058,8229,"Maybe you were ashamed of her."],[8229,8400,"You made this happen"],[8400,8529,"on purpose."],[8529,8670,"And there it is."],[8670,8808,"The truth slipping"],[8808,8970,"right out of your mouth."],[8970,9058,"No,"],[9095,9191,"I wanted to see"],[9191,9350,"how far you would go."],[9379,9450,"I wanted to see"],[9450,9708,"what kind of monster you really were."],[9712,9883,"So what, are you just saying this"],[9883,10087,"was some kind of social experiment?"],[10087,10287,"You let her abuse our daughter"],[10287,10491,"for 18 years just to prove a point."],[10537,10695,"Is that true?"],[10750,10900,"Aunt Claire..."],[11012,11120,"Mom?"]],"23":[[12,220,"Just breathe, okay?"],[220,366,"It's not what you think."],[366,466,"Stop!"],[529,675,"Just stop!"],[675,758,"Why?"],[758,970,"Why did I have to suffer?"],[987,1204,"Just for your stupid grudge?"],[1208,1312,"Lucy, I..."],[1312,1466,"No! You knew!"],[1466,1716,"And you let that evil woman"],[1716,1829,"beat me,"],[1829,1920,"starve me,"],[1920,2020,"humiliate me."],[2020,2095,"What? Just because"],[2095,2266,"You were curious?"],[2266,2491,"You made me call her mom"],[2491,2716,"when you knew she wasn't."],[2716,2854,"Unbelievable."],[2854,3004,"I never knew you could be"],[3004,3158,"so heartless, Claire."],[3158,3308,"You let your own daughter"],[3308,3570,"get tortured for 18 years."],[3570,3650,"Honestly, Lucy."],[3650,3800,"I feel bad for you now."],[3800,3970,"You've been hating the wrong person"],[3970,4108,"this whole time."],[4108,4312,"No, I hate you too!"],[4312,4466,"You broke me"],[4466,4629,"for your own sick,"],[4629,4775,"twisted revenge."],[4775,5000,"Oh, don't flatter yourself."],[5000,5162,"You're Claire's daughter."],[5162,5333,"Just looking at you makes me sick."],[5333,5437,"You should be grateful that"],[5437,5633,"I didn't throw you on the streets."],[5633,5854,"You hated me that much."],[5854,6054,"Enough to steal my daughter"],[6104,6208,"and torture her?"],[6229,6287,"Yes!"],[6287,6458,"Because you got everything!"],[6458,6583,"Everything handed to you,"],[6612,6679,"money,"],[6679,6750,"power,"],[6750,6829,"success."],[6829,7058,"And I had to stand in your shadow."],[7058,7379,"I wanted your daughter to suffer!"],[7379,7550,"I wanted her to feel"],[7550,7775,"every bit of pain"],[7775,7908,"that I felt!"],[7925,8137,"Then I would look my Phoebe..."],[8137,8333,"And she was smart,"],[8333,8450,"and strong,"],[8450,8537,"and beautiful."],[8537,8658,"While your daughter was"],[8658,8854,"flinching at all the sounds."],[8854,9012,"That was the best part."],[9029,9108,"You..."],[9108,9329,"I used to think that you had no clue,"],[9329,9625,"that torturing Lucy was pointless."],[9625,9816,"Now, I know that you’ve been"],[9816,10058,"watching this whole time."],[10154,10325,"Did you hear that, sweetheart?"],[10325,10550,"The woman you were crying for"],[10550,10754,"was worse than me the whole time."],[10787,10900,"Claire Watts,"],[10900,11008,"you watched your daughter"],[11008,11200,"get crushed and said nothing."],[11200,11312,"What kind of a mother"],[11312,11425,"does that make you?"],[11425,11558,"If you hate Edith,"],[11558,11729,"why didn't you go after her?"],[11737,11816,"Why me?"],[11816,12000,"What did I do wrong?"],[12120,12237,"You are sick!"],[12237,12362,"Kids are innocent."],[12362,12575,"You don't do things like that!"],[12575,12833,"You broke my heart..."],[12833,12925,"Mom..."],[12925,13037,"No..."],[13120,13291,"Claire."]],"24":[[0,108,"Oh, Pheebs."],[108,179,"No!"],[220,304,"Why?"],[304,554,"Why did she get everything?"],[554,708,"Every year she gets"],[708,891,"every new Chanel collection"],[891,1000,"the moment it drops."],[1000,1079,"And me?"],[1079,1258,"I get hand-me-downs for"],[1258,1520,"five bucks from the flea market!"],[1520,1700,"Every birthday, she gets presents,"],[1700,1883,"parties and cakes"],[1883,2058,"bigger than a person."],[2058,2220,"I got locked in a room,"],[2258,2408,"beaten bloody!"],[2408,2641,"We were born on the same day."],[2641,2925,"What did I do to deserve this?!"],[2925,3000,"You?"],[3000,3125,"What makes you think you can"],[3125,3304,"compare yourself to my daughter?"],[3304,3487,"I prayed for the day"],[3487,3679,"you and your “mother”"],[3679,3887,"could rot in hell together."],[3904,4204,"You really outdid yourself, Edith."],[4220,4362,"What a good best friend"],[4362,4500,"you turned out to be."],[4500,4620,"Oh! Come on,"],[4620,4683,"Claire."],[4683,4850,"You should be thanking me."],[4850,5066,"You got to raise my perfect girl."],[5066,5279,"I saved you a decade of stress."],[5295,5483,"You think I would let my own daughter"],[5483,5745,"call a phoney like you, “mom”?"],[5745,5862,"For 18 years,"],[5862,5937,"if it wasn't for"],[5937,6079,"your precious little company?"],[6079,6237,"Stop it!"]],"25":[[4,216,"Lucy and I aren't your toys."],[216,375,"Have any of you ever thought"],[375,504,"about how we feel?"],[504,712,"Everything I did was for you."],[712,837,"You've got everything."],[837,1025,"Power, success, me."],[1025,1212,"You should be grateful."],[1212,1512,"I don't have a real mom."],[1675,1862,"Not if she's messed up like you."],[1862,2062,"You did this for yourself."],[2062,2154,"For your ego!"],[2154,2287,"For revenge!"],[2287,2437,"If you hadn't switched us,"],[2437,2650,"none of this would have happened."],[2650,2875,"We clawed our way"],[2929,3154,"to get you into the Watts family."],[3200,3491,"So you could live the life you deserve."],[3491,3625,"You lived like royalty"],[3625,3750,"because of me."],[3750,4041,"You should be thanking us."],[4041,4262,"But you know who's worse than me?"],[4354,4654,"Claire Watts."],[4900,4987,"She's right."],[4987,5200,"She watched it all happen for 18 years"],[5200,5300,"and did nothing."],[5300,5400,"She's heartless."],[5400,5487,"She doesn't deserve"],[5487,5604,"to be called a mother."],[5604,5766,"Satisfied now, Claire?"],[5766,5962,"Your biological daughter's broken."],[5962,6150,"The one we raised is gone."],[6150,6300,"They both hate you now."],[6300,6441,"So tell me, was it worth it?"],[6441,6654,"Was your curiosity really"],[6654,6850,"worth destroying everything?"],[6916,7087,"If none of you wanted me,"],[7200,7400,"why was I even born?"]],"26":[[0,120,"I hate Edith"],[120,325,"for turning me into nothing."],[354,545,"But I hate you more!"],[545,704,"I used to pray"],[704,879,"that you were my mom,"],[920,1020,"and you were."],[1020,1166,"And you stood by"],[1166,1416,"and watched me suffer."],[1416,1475,"Why?"],[1475,1775,"Why would you let that happen to me?"],[3945,3995,"Pheebs,"],[4029,4075,"get back!"],[4075,4329,"Don't go near that dirty little psycho."],[4625,4820,"Don't come any closer."],[4970,5100,"Lucy."],[5100,5241,"It's okay."],[5441,5675,"You're safe."],[5675,5891,"Just breathe."],[5891,6191,"I'm not here to hurt you."],[6241,6379,"Pheebs! No!"],[7191,7429,"You little bitch!"],[7429,7670,"You think you can hurt my daughter?"],[7670,7962,"I will send you to hell myself!"]],"27":[[37,170,"Mom..."],[470,579,"No!"],[1012,1175,"You regret it now?"],[1175,1291,"Too bad."],[1291,1454,"A daughter like that is"],[1454,1650,"going to haunt your legacy."],[1650,1879,"I was doing you a favour, Claire."],[1879,2087,"You should be thanking me!"],[2087,2241,"You'll regret this, Edith."],[2295,2437,"You don't know what you've done!"],[2437,2533,"Regret?"],[2533,2670,"I just made you watch"],[2670,2900,"your daughter bled out in your arms."],[2920,3029,"This,"],[3029,3112,"this is the most"],[3112,3366,"satisfying thing I've ever done."],[3366,3462,"Lucy,"],[3462,3575,"look at me, baby."],[3575,3658,"Okay, stay with me."],[3658,3895,"Don't go to sleep, okay?"],[3895,4066,"I hate..."],[4066,4258,"you all..."],[4479,4562,"Hello!"],[4616,4704,"We need an ambulance!"],[4704,4812,"Someone’s been stabbed!"],[4850,4945,"No!"],[5079,5233,"She came at my daughter"],[5250,5350,"with a knife!"],[5350,5500,"This is justice!"],[5500,5695,"Are you crazy? She is dying!"],[5758,6054,"Today is my last day"],[6054,6320,"as her so-called mother."],[6320,6550,"This is her final lesson."],[6566,6762,"You come at my daughter,"],[6762,7037,"you pay with your life!"],[7037,7104,"I hope"],[7104,7362,"you remember this moment..."],[7362,7475,"When you find out"],[7475,7700,"who really hurt your daughter."],[7716,7783,"Enough!"],[7783,7887,"She's not breathing."],[7887,7995,"We don't have time for this."],[7995,8187,"We need to get her to a hospital now!"]],"28":[[425,608,"Doctor, how is Lucy?"],[608,729,"Is she going to be okay?"],[729,879,"She lost a lot of blood."],[879,958,"And after everything,"],[958,1066,"her body's been through..."],[1091,1229,"years of malnourishment,"],[1229,1375,"untreated injuries."],[1375,1504,"We don't know if"],[1504,1633,"she'll ever wake up."],[1633,1733,"No..."],[1733,1945,"No... This can't be real..."],[1945,2120,"Well, I guess that's that."],[2120,2341,"No more competition for Phoebe."],[2341,2466,"Watts Group’s future"],[2466,2579,"is safe and sound."],[2579,2741,"You stabbed her!"],[2741,2954,"You put her in that bed,"],[2954,3087,"and all you can care about"],[3087,3170,"is the company?!"],[3170,3325,"Like you get to talk."],[3325,3429,"You watched me"],[3429,3608,"torture her for 18 years."],[3608,3750,"You don't get to play the hero."],[3750,3983,"Oh, I didn't stab her."],[4041,4254,"What are you trying to say?"],[4254,4475,"The girl you stabbed tonight."],[4475,4658,"The one you tried to kill."],[4658,4816,"She's not my daughter,"],[4816,4920,"Edith."],[5058,5229,"She's yours."]],"29":[[12,100,"Claire...."],[100,229,"What are you talking about?"],[229,362,"So who's our daughter?"],[362,583,"You finally lost it, huh?"],[616,791,"That comatose little brat."],[791,887,"That's yours."],[887,1062,"When you swap the babies."],[1062,1250,"You didn't even look closely."],[1250,1370,"You didn't even really notice"],[1370,1516,"how different they were."],[1516,1629,"How do you mean?"],[1629,1733,"Come on."],[1733,1937,"All newborns look the same."],[1937,2100,"Nobody can tell them apart."],[2129,2312,"Why so nervous, Josh?"],[2354,2466,"I'm not."],[2466,2725,"I just can't stand hearing your lies!"],[2870,3054,"She was born"],[3054,3175,"with this."],[3216,3366,"I saw this the moment"],[3366,3533,"she came into the world."],[3533,3712,"But before I had a chance"],[3712,3841,"to tell anyone."],[3841,4083,"You'd already taken her from me."],[4333,4466,"A birthmark?"],[4466,4587,"No, that's..."],[4587,4637,"That's not..."],[4637,4804,"That's not real... That’s..."],[4804,4954,"That's not right."],[4954,5100,"Just a birthmark,"],[5137,5250,"doesn't prove anything."],[5250,5337,"Exactly."],[5337,5504,"That's why I had the hospital"],[5504,5666,"redo the DNA test"],[5666,5816,"while Lucy was in surgery."],[5816,5908,"Mrs. Watts,"],[5908,6083,"here's the DNA results you requested."],[6370,6462,"You always said"],[6462,6770,"DNA tests don't lie, right?"]],"30":[[158,254,"Claire..."],[254,333,"is this real?"],[333,495,"What the hell is going on?"],[512,629,"You're really..."],[629,737,"my mom?"],[841,1050,"Of course, sweetheart."],[1050,1229,"You've always been mine."],[1229,1383,"I would never give you up."],[1383,1458,"No!"],[1458,1587,"You're bluffing!"],[1587,1725,"This is just a stunt"],[1725,1862,"to take my daughter"],[1862,1987,"and my company."],[2012,2150,"You'll say anything to win,"],[2150,2241,"won't you, Claire?"],[2245,2379,"No one's buying it."],[2425,2562,"Then prove me wrong."],[2562,2741,"Go on, read it."],[2741,2866,"Unless you're scared."],[2895,3008,"Scared?"],[3008,3212,"Are you kidding me?"],[3545,3641,"So..."],[3745,4000,"Phoebe really is your daughter?"],[4075,4208,"That means..."],[4375,4466,"So,"],[4466,4675,"do you believe me now, Edith?"],[4754,4841,"No,"],[4841,5020,"I don't believe this."],[5020,5166,"This is a fake."]],"31":[[12,145,"I am smart!"],[145,204,"I’m pretty."],[204,279,"There's no way"],[279,383,"that I gave birth to"],[383,545,"that whimpering gutter rat!"],[575,650,"You!"],[650,845,"You have rigged this test."],[845,962,"You're just trying to"],[962,1100,"get my company back."],[1100,1275,"You're still lying to yourself,"],[1275,1400,"even now."],[1416,1520,"Let me guess."],[1520,1654,"The fake test that you got"],[1654,1783,"that must have cost a fortune,"],[1783,1883,"didn’t it?"],[1920,2116,"I don't know what you're talking about."],[2116,2387,"You better not be lying to me."],[2387,2587,"Look me in the eye, Josh."],[2633,2712,"Tell me!"],[2783,2845,"Edith, come on..."],[2845,2970,"I'm your brother."],[3008,3145,"You know I would never..."],[3145,3291,"Oh, spare us!"],[3291,3525,"You only ever wanted Watts Group,"],[3525,3775,"so you needed Phoebe to be yours."],[3775,3854,"So,"],[3854,4041,"you forged a fake DNA test,"],[4041,4170,"and you shoved it to the world"],[4170,4366,"like it was gospel."],[4600,4870,"Tell me the truth."],[4870,5070,"Was the DNA test real or not?"]],"32":[[150,325,"Did you really think"],[325,412,"that as a mother,"],[412,500,"I'd stand by"],[500,654,"and let you steal my daughter,"],[654,787,"and do nothing?"],[825,950,"You..."],[950,1079,"You switched them back."],[1079,1266,"So Lucy really is mine."],[1266,1462,"I abused my own flesh and blood"],[1475,1637,"for 18 years."],[1737,1870,"What have I done?!"],[2362,2475,"Lucy..."],[2475,2570,"Lucy..."],[2641,2750,"My baby girl..."],[2766,2879,"I'm sorry."],[2879,3079,"I didn't know that it was you!"],[3079,3237,"Please come back."],[3237,3487,"Let me make it right."],[3487,3591,"Lucy,"],[3591,3687,"please,"],[3687,3804,"come back."],[3804,4008,"I will fix everything."],[4037,4116,"I'll make sure"],[4116,4266,"that the rest of your life"],[4266,4450,"is free from that monster"],[4450,4641,"who calls herself your mother."],[4754,4950,"Are you the patient's guardian?"],[4950,5016,"Yeah,"],[5054,5158,"I'm her mother."],[5200,5375,"Her body is covered in wounds."],[5400,5537,"Some fresh, some old,"],[5562,5700,"multiple infections."],[5700,5787,"Thanks to the trauma,"],[5787,5941,"she may never fully recover."],[6741,6816,"This"],[6875,7079,"is all your fault!"]],"33":[[0,150,"You set this up!"],[150,262,"If it wasn't for you,"],[262,375,"I never would’ve"],[375,562,"hurt my daughter like that!"],[662,787,"You're insane!"],[787,925,"Did I put those bruises"],[925,1012,"on your daughter?"],[1012,1137,"Did I lock her up?"],[1137,1287,"Did I starve her?"],[1287,1404,"You did that to her,"],[1404,1466,"not me!"],[1487,1558,"If you hadn't"],[1558,1687,"switched them back,"],[1687,1850,"if you’ve just let things be..."],[1850,2025,"Lucy wouldn't be in a coma!"],[2187,2283,"Wake up!"],[2291,2479,"This is about you and me!"],[2479,2625,"It was not about the kids."],[2654,2716,"You have ruined your"],[2716,2850,"own daughter’s life"],[2866,3000,"with your hatred!"],[3025,3225,"You called me hateful?"],[3254,3433,"It was never fair!"],[3450,3620,"I was smarter than you,"],[3650,3762,"prettier than you!"],[3791,4062,"Everybody loves you!"],[4062,4250,"Because you have rich parents."],[4250,4404,"You've got everything"],[4404,4537,"handed to you."],[4562,4625,"Everything!"],[4625,4812,"And I just slave away."],[4850,5012,"You inherit company,"],[5012,5225,"and then you make me your secretary,"],[5225,5437,"like I'm some charity case."],[5466,5566,"No, Edith."],[5566,5650,"I gave you the job"],[5650,5787,"because I trusted you."],[5804,5891,"Because I thought"],[5891,6041,"that you were my best friend."],[6054,6125,"But instead,"],[6125,6412,"all you saw was someone to envy,"],[6412,6512,"someone to blame!"],[6512,6591,"I don't care!"],[6591,6800,"Because I wanted your daughter"],[6800,6900,"to suffer!"],[6900,7112,"I wanted her to feel this hell"],[7112,7275,"that I have been living in!"]],"34":[[33,108,"Why"],[137,350,"isn’t it you in that bed?"],[362,491,"I loved you"],[491,650,"for 18 years"],[675,787,"like my own!"],[800,929,"How could you be hers?"],[954,1004,"You..."],[1029,1204,"Carry her filthy blood!"],[1237,1429,"It should be you in the coma!"],[1966,2100,"You want to lay your hand"],[2100,2216,"on my daughter?"],[2250,2412,"You have to get through me first!"],[2412,2591,"And I promise you won't win."],[2650,2700,"So..."],[2700,2825,"Aunt Edith..."],[2825,2987,"All of your kindness..."],[3012,3212,"It was all just an act?"],[3229,3350,"You sick woman!"],[3362,3525,"Claire gave you a life,"],[3525,3600,"stood by you"],[3600,3675,"when no one else would,"],[3675,3804,"and you plotted against her"],[3804,3920,"like a damn snake!"],[4087,4154,"Edith,"],[4154,4229,"get a grip!"],[4275,4450,"Why the fuck did you lie to me?"],[4462,4575,"You stood there"],[4575,4679,"and watched me"],[4679,4812,"stab my own daughter."],[4862,4987,"Your niece!"],[5041,5175,"I did it for you."],[5200,5350,"She can’t wake up."],[5350,5441,"But the company,"],[5450,5616,"the company is worth something."],[5650,5850,"We can't resurrect Lucy,"],[5870,6075,"but we can rebuild from this!"],[6129,6375,"You ruined my daughter."],[6391,6537,"So you owe me."],[6575,6733,"Handover Watts Group"],[6762,6875,"as compensation!"]],"35":[[0,104,"You've lost your"],[104,237,"fucking mind, Edith."],[237,412,"You stabbed your own daughter,"],[412,512,"put her into a coma,"],[512,579,"and now you think"],[579,675,"we should pay you?"],[704,866,"Claire knew the kids were swapped,"],[875,1025,"and she kept quiet"],[1041,1345,"for 18 years."],[1362,1516,"That's malicious intent!"],[1525,1675,"Lucy's brain dead now,"],[1737,1812,"you’re"],[1850,1904,"all"],[1950,2066,"accomplices."],[2087,2150,"That's right."],[2150,2375,"Every time I hit Lucy,"],[2412,2512,"you were there..."],[2512,2587,"Watching!"],[2612,2750,"You didn't stop me."],[2775,2962,"You wanted this to happen."],[2962,3150,"You wanted her dead."],[3154,3312,"Oh... Please!"],[3312,3525,"Every time we begged you to stop,"],[3525,3625,"you barked at us!"],[3641,3762,"“You're not her parents.”"],[3762,3900,"You said it wasn't our business."],[3900,3979,"You hit her"],[3979,4075,"even harder"],[4075,4250,"after we tried to intervene."],[4250,4429,"And now she's in a coma,"],[4429,4587,"and all you can think about"],[4625,4837,"is using her tragedy"],[4850,4975,"to get a payout."],[4979,5175,"Do you even have a soul?"],[5187,5337,"She's my daughter."],[5362,5516,"I brought her into this world."],[5525,5687,"She was born"],[5704,5837,"to get me what I want."],[5837,6025,"If she wins me the Watts Group,"],[6025,6287,"I'll say she finally did something right."],[6300,6462,"I can't believe"],[6462,6600,"I used to look up to you."],[6612,6762,"You're not just cruel."],[6762,6950,"You are rotten to the core."],[6962,7162,"You are the disappointment!"],[7162,7354,"I had high hopes for you."],[7391,7512,"You lived the life"],[7512,7712,"that my daughter was meant to."],[7712,7825,"Now you've got the nerve"],[7825,7937,"to stand there"],[7937,8050,"and judge me!"],[8075,8166,"Claire Watts,"],[8175,8325,"hand over Watts Group."],[8329,8487,"Right now."],[8487,8629,"Or I’ll expose you."],[8650,8825,"I will tell the world"],[8825,9125,"how you destroyed my daughter's life."],[9129,9325,"You'll go down as a monster."],[9325,9450,"Expose me?"],[9462,9704,"After all the sick twisted shit"],[9729,9862,"that you've pulled,"],[9862,9950,"you still think that"],[9950,10108,"you've got cards to play?"]],"36":[[487,566,"Let go of me!"],[566,608,"I..."],[608,762,"I haven't done anything!"],[762,912,"You can't just arrest us."],[912,1062,"You've got no proof."],[1062,1175,"No grounds!"],[1187,1254,"Proof?"],[1312,1400,"Evidence?"],[1650,1712,"Here,"],[1766,1933,"watch yourself burn."],[2837,2904,"You..."],[2937,3029,"You set me up!"],[3029,3070,"You..."],[3070,3270,"You planned all of this..."],[3304,3475,"Just to make me confess?"],[3541,3687,"Congratulations, Edith."],[3704,3862,"You finally figured it out."],[3862,3954,"So,"],[3954,4112,"still think you're smarter than me?"],[4141,4262,"You're both under arrest,"],[4312,4400,"for charges including"],[4400,4554,"infant abduction, child abuse,"],[4554,4654,"and attempted murder."],[4675,4745,"No!"],[4895,4987,"Stop it!"],[5050,5112,"Edith,"],[5137,5300,"you destroyed your own daughter"],[5300,5425,"with your own hands."],[5429,5504,"So,"],[5504,5625,"spend the rest of your life"],[5625,5725,"behind bars."],[5775,5904,"Making it up to her."]],"37":[[125,195,"Lucy..."],[229,300,"They're gone."],[312,462,"Your mom, your uncle,"],[462,637,"everyone who used you."],[637,770,"They got what they deserved."],[862,958,"Wake up,"],[1087,1220,"and see for yourself."],[1333,1400,"Lucy,"],[1437,1591,"I should have protected you."],[1662,1787,"I'm so sorry."],[1858,2020,"Please don't hate me baby."],[2070,2241,"You've never had a real dress."],[2266,2412,"Never had a real moment"],[2412,2570,"to just be a girl."],[2625,2745,"This is from me."],[3095,3208,"Aunt Claire's gift,"],[3262,3358,"just for you."],[3412,3495,"So wake up."],[3541,3770,"Try it on and show us that smile again."],[4037,4162,"Come on, ladies."],[4187,4312,"It's been a month."],[4350,4487,"Lucy is a kind soul."],[4487,4587,"She'll wake up."],[4587,4783,"You can't live in this hospital forever."],[4791,4895,"That's right, Mom."],[4912,5037,"You've been here for days."],[5037,5154,"You haven't slept."],[5212,5370,"Why don't you take a few days off?"],[5437,5570,"I've got things covered here."],[5612,5850,"You both need some rest."],[5866,5950,"Claire, babe,"],[5950,6125,"you've been grinding for years."],[6125,6229,"For this family,"],[6229,6316,"for the company."],[6337,6504,"Never once really stopping,"],[6504,6600,"just to breathe."],[6658,6804,"Why not take this chance, huh?"],[6829,6945,"Grab Pheebs,"],[6950,7104,"go on a little getaway."],[7116,7233,"Recharge for real."],[7270,7329,"If Phoebe and I"],[7329,7475,"go on a vacation..."],[7475,7620,"Who's gonna run the company?"],[7662,7725,"Babe,"],[7766,7820,"don't forget"],[7820,7900,"you've got a husband."],[7900,8020,"I've been right here"],[8020,8137,"all these years."],[8137,8295,"Learned a thing or two, haven't I?"],[8329,8437,"And even if you won't to"],[8437,8512,"free yourself,"],[8512,8645,"think about Pheebs."],[8675,8866,"She's been glued to this room for weeks,"],[8866,9004,"running on fumes."],[9012,9104,"Look at her."],[9162,9275,"She's wiped out."],[9350,9416,"Okay."],[9504,9600,"I'll take Phoebe away"],[9600,9708,"for a little break."],[9750,9904,"Your amazing husband"],[9950,10091,"and your awesome dad"],[10100,10204,"has already booked you"],[10204,10333,"a luxury cruise."],[10354,10491,"All you two need to do is"],[10491,10591,"pack your bags"],[10591,10762,"and sail off into the sunset."],[10800,11050,"How thoughtful of my dear husband."],[11050,11141,"Of course,"],[11166,11287,"I am the husband"],[11287,11462,"of the one and only Claire Watts"],[11462,11650,"boss lady of the century!"],[11812,11954,"Enjoy yourselves."],[11954,12083,"You've earned it."]],"38":[[187,250,"Mom,"],[250,325,"can you believe"],[325,483,"this is our first trip together?"],[483,604,"Just the two of us!"],[700,804,"I know, baby."],[912,1066,"I've spent too many years"],[1066,1208,"buried in work."],[1241,1395,"I should've spent more time with you."],[1466,1533,"I'm sorry."],[1604,1687,"Don't be."],[1754,1875,"Everything you built,"],[1875,2004,"you built for me."],[2108,2250,"When we get back from this trip,"],[2258,2387,"I'm going to give you the company."],[2404,2529,"For real this time."],[2616,2691,"Are you ready?"],[2937,3037,"Mom! Watch out!"],[3404,3475,"Breaking news,"],[3475,3554,"Watts Group CEO"],[3554,3675,"Claire Watts and her daughter"],[3675,3783,"Phoebe Watts"],[3800,3858,"have gone missing"],[3858,3983,"after a tragic car crash"],[3983,4062,"along the coast."],[4100,4233,"Authorities believe their vehicle"],[4233,4375,"may have plunged into the ocean."],[4404,4520,"Search teams continue,"],[4541,4704,"but both remain unaccounted for."],[5150,5258,"The job's done."],[5283,5400,"Your wife and daughter"],[5416,5504,"took a dive."],[5520,5579,"Now,"],[5587,5741,"about the rest of my payment?"],[5754,5866,"It's been wired."],[5908,6000,"Check your account."],[6412,6483,"Claire."],[6550,6725,"You left me no choice."],[6812,6925,"18 years"],[6925,7058,"you trained our daughter"],[7058,7145,"for the throne,"],[7145,7316,"and never once thought of me."],[7383,7541,"Not even a slice."],[7645,7725,"Phoebe..."],[7820,8025,"You had a good run, kid."],[8112,8304,"Enjoy the afterlife, girls."],[8433,8604,"The company is mine now."]],"39":[[895,954,"God,"],[975,1125,"weren't they find a few weeks ago?"],[1154,1216,"How does something"],[1216,1308,"like this happen?"],[1350,1504,"I ask myself that every day."],[1512,1662,"They finally take a break and then..."],[1700,1741,"This..."],[1804,1875,"You never know"],[1875,1975,"what's going to happen."],[2050,2129,"Tomorrow,"],[2129,2304,"or a great tragedy."],[2362,2550,"They were such good people."],[2625,2679,"No, no."],[2679,2825,"I refuse to believe they're gone."],[2825,2912,"They're missing."],[2912,2979,"That's all."],[3091,3216,"They'll come back, I know it."],[3275,3391,"If there's any consolation,"],[3412,3566,"they have a loving husband and father."],[3600,3725,"They'll be at peace knowing that."],[3829,3958,"Claire... Phoebe..."],[4012,4179,"I can't do this without you."],[4200,4354,"Claire founded Watts Group,"],[4400,4479,"and Phoebe was the biggest"],[4479,4566,"shareholder."],[4591,4675,"Now that they're both gone,"],[4675,4783,"who inherits everything?"],[4812,4916,"The company's worth what,"],[4945,5029,"a billion?"],[5112,5208,"I've already contacted"],[5208,5279,"our lawyers."],[5279,5325,"Everything will be"],[5325,5429,"handled by the book."],[5475,5587,"Mr. Lyon..."],[5887,5962,"You're here!"],[5979,6054,"Finally!"],[6437,6500,"Mr. Lyon..."],[6500,6637,"Why are you so damn excited?"]],"40":[[0,29,"I..."],[41,137,"I... I just thought"],[154,325,"maybe they brought me good news"],[325,412,"about my wife..."],[454,537,"my daughter..."],[608,750,"Mr. Lyon, I'm your legal counsel."],[750,804,"We've met"],[900,987,"more than once."],[1050,1237,"And I handle the insurance policy"],[1237,1300,"you took out."],[1325,1487,"We spoke a month ago."],[1841,1954,"I’m... I'm sorry."],[1975,2175,"I've just been so devastated."],[2175,2283,"I didn't recognise you."],[2304,2404,"Due to the sudden passing"],[2404,2512,"of Mrs. Claire Watts"],[2512,2616,"and Ms. Phoebe Watts,"],[2641,2787,"and in the absence of a will,"],[2804,2987,"ownership of their assets and estate"],[2987,3116,"will be transferred"],[3200,3262,"to you."],[3275,3387,"Here's the full inventory."],[3387,3487,"Please carefully review"],[3487,3575,"before signing."],[3579,3816,"And per the life insurance policy,"],[3850,4112,"You're entitled to a 6 million payout"],[4112,4262,"as the sole beneficiary."],[4312,4379,"This"],[4400,4541,"is the disbursement form."],[4566,4629,"Sign here."],[5112,5250,"What good is all this money"],[5250,5362,"when I've lost the only people"],[5362,5454,"I've ever loved?"],[5462,5520,"Eric,"],[5550,5641,"Claire spent her life"],[5675,5750,"building that company."],[5750,5908,"Make sure you honor that legacy."],[5954,6116,"I can't think about this right now."],[6116,6258,"I just want my girls back."],[6300,6362,"Come on, man,"],[6362,6412,"Phoebe and Claire"],[6412,6487,"wouldn't want to see you"],[6487,6604,"falling apart like this."],[6662,6704,"Of course,"],[6704,6800,"you always have the right"],[6800,6970,"to decline inheritance."],[6987,7100,"In that case, by law,"],[7100,7245,"everything will be donated"],[7266,7354,"to welfare foundation..."],[7354,7391,"No..."],[7404,7454,"No..."],[7475,7620,"No... This is the last thing"],[7637,7729,"Claire left me."],[7825,7912,"I'll take it."],[8629,8812,"The company is mine now."],[8858,8966,"Eric Lyon,"],[9029,9241,"you just couldn't wait, huh?"]],"41":[[820,941,"She's alive!"],[958,1075,"And Phoebe too!"],[1112,1179,"Claire..."],[1212,1262,"Phoebe..."],[1262,1387,"How... How are you back?"],[1425,1591,"You sound disappointed."],[1600,1679,"No, no!"],[1679,1729,"Claire."],[1741,1775,"Come on,"],[1775,1900,"how could you think that?"],[1950,2016,"Thank God!"],[2016,2191,"I was losing my mind."],[2225,2375,"When the news said you were gone,"],[2375,2483,"I... I thought I'd die."],[2491,2737,"6 million accident payout"],[2737,2920,"for me and Phoebe..."],[2954,3012,"Funny."],[3037,3254,"I don't recall signing anything like this."],[3275,3400,"You were just so busy."],[3400,3525,"You probably just forgot."],[3554,3700,"We bought those policies together,"],[3700,3779,"remember?"],[3804,3900,"I even took one out"],[3900,3966,"for myself."],[4012,4062,"Yes,"],[4062,4200,"Mr. Lyon did purchase"],[4200,4379,"an identical policy for himself."],[4462,4533,"Of course I did!"],[4562,4687,"Cover all my bases"],[4687,4820,"with a wife like Claire"],[4841,5016,"you can’t leave a single loose end."],[5100,5208,"Is that so?"],[5400,5454,"Claire,"],[5504,5583,"I know you're upset."],[5583,5762,"And you think this trip was my fault,"],[5762,5900,"but I just wanted to give you"],[5900,6000,"and Phoebe a break."],[6054,6195,"I'm so sorry, baby..."],[6250,6337,"Let's just move on"],[6337,6425,"and forget it happened."],[6425,6495,"You, me,"],[6541,6620,"our daughter..."],[6662,6762,"We're still a family."],[6879,7041,"Still going with the act?"]],"42":[[37,87,"Claire,"],[87,200,"are you out of your mind?"],[304,341,"Claire,"],[341,462,"you're clearly still"],[462,587,"shaken up by the accident."],[612,737,"But don't take it out on Eric."],[737,862,"He didn't do anything wrong."],[887,1025,"Eric has been a wreck"],[1025,1137,"these past few days."],[1137,1300,"I mean, he has barely slept."],[1304,1412,"You could tell how much"],[1412,1575,"he cares about you and Phoebe."],[1612,1675,"Claire..."],[1700,1804,"I saw the crash site."],[1804,1875,"It was bad."],[1875,1962,"Really bad."],[1987,2150,"Everyone told me to stop looking"],[2150,2287,"to let go that you were gone."],[2287,2454,"But I didn't believe them."],[2454,2575,"Not for a second."],[2587,2700,"Every moment I prayed"],[2700,2787,"you'd both come back"],[2787,2895,"safe and sound."],[2895,2962,"And thank God."],[3087,3179,"Here you are."],[3475,3600,"Are you still shaken up?"],[3650,3737,"Is that what this is?"],[3791,3875,"Claire,"],[3875,4025,"I swear I'll never let danger"],[4025,4125,"come near you again."],[4150,4250,"He's right, Claire."],[4275,4391,"You're all together again."],[4391,4466,"Shouldn’t that be something"],[4466,4541,"to celebrate?"],[4562,4625,"You said you'd never"],[4625,4762,"let danger near us again."],[4800,4862,"That's right!"],[4875,4937,"I promiss!"],[5037,5212,"So tell me, Eric Lyon..."],[5262,5404,"What if the danger"],[5450,5566,"is you?"]],"43":[[0,137,"What the hell are you talking about?"],[137,241,"After you and Phoebe"],[241,287,"disappeared,"],[287,425,"I sent teams out to find you."],[425,562,"Nobody could locate you."],[579,775,"Those people you sent out?"],[800,862,"Yeah,"],[904,1037,"Phoebe and I met them."],[1050,1141,"You...you what?"],[1162,1225,"Dad."],[1250,1300,"No,"],[1325,1429,"Mr. Lyon,"],[1500,1600,"for those men you sent,"],[1600,1716,"really"],[1741,1854,"supposed to find us?"],[1866,1941,"Phoebe,"],[1950,2037,"is that any way to speak"],[2037,2137,"to your father?"],[2137,2237,"You clearly haven't"],[2237,2354,"recovered from the trauma."],[2354,2462,"Maybe I should book you a room"],[2462,2562,"at the psych ward."],[2612,2700,"So now you're going to"],[2700,2804,"call me crazy,"],[2825,2962,"just to cover your own ass?"],[2975,3025,"Phoebe!"],[3025,3125,"You wanna talk crazy?"],[3162,3337,"The second your guys saw us,"],[3337,3475,"they sent out guns."],[3500,3612,"Not first aid kits,"],[3612,3687,"guns!"],[3716,3850,"What?! That's insane."],[3850,4004,"There's got to be some kind of mix up!"],[4004,4100,"Claire, come on."],[4125,4300,"Watts Group is blowing up right now."],[4300,4412,"You've got enemies"],[4412,4500,"and competitors"],[4500,4625,"who'd kill to see you gone."],[4666,4700,"Maybe..."],[4700,4762,"Maybe someone else"],[4762,4866,"was trying to take you out."],[4887,4950,"Huh..."],[4991,5062,"Claire,"],[5062,5175,"how can you not believe me?"],[5175,5254,"I'm your husband."],[5275,5375,"Phoebe is my daughter."],[5425,5487,"You really think"],[5487,5625,"I'd try to hurt the two of you?"],[5625,5700,"Oh, Come on!"],[5700,5800,"You'd sell your own soul"],[5800,5862,"for a paycheck."],[5875,6000,"Don't act all innocent!"],[6000,6041,"Claire!"],[6062,6191,"You're not even curious"],[6212,6312,"how Phoebe and I managed"],[6312,6466,"to survive that accident?"],[6912,7016,"Coastal Highway."],[7016,7175,"Tomorrow, 3 p.m."],[7175,7291,"My wife Claire Watts."],[7291,7462,"My daughter Phoebe Watts."],[7466,7554,"They'll be there."],[7554,7637,"You know what to do."],[7666,7750,"Take them out,"],[7750,7812,"quick and clean."]],"44":[[62,137,"You bugged me."],[150,250,"You never trusted me."],[250,337,"Not for a second,"],[337,412,"did you?"],[412,575,"That wasn't me bugging you."],[591,725,"The guy you hired"],[750,875,"figured I could pay him more."],[887,966,"So,"],[966,1050,"he came to me."],[1066,1216,"I just offered him a better deal"],[1262,1462,"and got the receipts to your sins."],[1512,1687,"I didn't keep the company from you"],[1687,1812,"because I didn't trust you."],[1841,1975,"I kept it from you because"],[2050,2179,"you're useless."],[2225,2325,"Well, yeah."],[2325,2425,"Now the cat's out of the bag."],[2425,2550,"Yeah. It was all me."],[2562,2691,"Every damn bit of it!"],[2887,3012,"You ever think about Phoebe"],[3012,3141,"when you were planning all this?"],[3179,3291,"Your own daughter!"],[3291,3429,"She never listen to me anyway."],[3437,3587,"She only ever trusted you."],[3587,3775,"Even the most savage animal"],[3775,3887,"won't kill its own young."],[3887,4062,"You're worse than a beast."],[4112,4287,"I thought Eric was a stand-up guy."],[4304,4416,"This is sickening!"],[4466,4550,"To put a hit"],[4550,4687,"on your own kid?"],[4700,4850,"You don't deserve to be called a man."],[4850,4950,"Oh, cut the crap."],[4950,5187,"You'd all do the same if $10 billion"],[5187,5325,"were on the table."],[5354,5437,"But you know what,"],[5437,5516,"Claire Watts."],[5562,5641,"Even if you did"],[5641,5729,"crawl out of that wreck,"],[5729,5829,"you're legally dead."],[5866,5937,"Your assets,"],[5937,6041,"they're all mine now."],[6100,6212,"You mean this?"],[6462,6625,"You might want to read the fine print"],[6625,6812,"before you pop the champagne."],[6825,6941,"No...No...No..."],[6979,7075,"This can't be real."],[7125,7262,"That's not your paycheck."],[7262,7412,"It's your eviction notice."],[7412,7525,"The divorce agreement."],[7525,7675,"You just signed your ass"],[7675,7850,"out of everything."]],"45":[[29,141,"No, no, no."],[162,250,"You lied to me."],[287,354,"You were bought off"],[354,487,"by this vicious woman."],[512,604,"Mr. Lyon,"],[604,775,"I warned you to read it carefully."],[800,862,"You were the one"],[862,975,"that was in a hurry to sign."],[1016,1079,"Your mistake."],[1079,1175,"No, no, no,"],[1175,1262,"this can't be happening."],[1262,1350,"I paid you."],[1350,1504,"Why the hell would you turn on me?"],[1537,1762,"You finally had a moment of clarity."],[1800,1954,"You want to know why?"],[2016,2200,"Because I told him to."],[2275,2400,"I've been Mrs. Watts' exclusive"],[2400,2575,"legal counsel since day one."],[2779,2891,"Mrs. Watts, you called?"],[2962,3012,"Saul,"],[3062,3187,"my dear husband secretly"],[3187,3437,"took out massive life insurance policies"],[3437,3587,"on me and my daughter."],[3641,3750,"I smell blood."],[3800,3862,"So,"],[3887,4012,"I want to divorce."],[4100,4150,"And,"],[4191,4241,"I want him"],[4241,4387,"walking out penniless."],[4437,4529,"Understood."],[4562,4725,"You are in excellent hands."],[4812,4854,"So..."],[4891,5037,"So you've been on to me all along."],[5075,5204,"Since the day you bought those"],[5204,5400,"shady insurance policies."],[5529,5600,"Even her?"],[5737,5837,"the insurance agent?"],[5837,5950,"She's one of yours too?"]],"46":[[37,212,"I'm sorry, Mr. Lyon."],[250,387,"All Watts Group employees,"],[387,625,"including the CEO and her family,"],[654,812,"have their insurance policies"],[812,900,"through our firm."],[937,1175,"And I happen to be Mrs. Watts'"],[1175,1362,"personal insurance agent."],[1466,1562,"Mrs. Watts,"],[1562,1675,"your husband just"],[1675,1875,"signed out for a multi-million-dollar"],[1875,2075,"accident insurance policy for you"],[2075,2175,"and your daughter."],[2237,2354,"Were you aware of this?"],[2412,2550,"Multi-million accident"],[2550,2675,"insurance policy?"],[2691,2816,"No, I wasn’t."],[2937,3037,"Thank you, Mrs. White."],[3054,3175,"I'll handle it from here."],[3400,3500,"Eric,"],[3500,3666,"you really are dumb as hell."],[3725,3900,"So this whole thing was a setup?"],[3900,3991,"Oh please!"],[3991,4162,"You think I'd waste my time"],[4162,4250,"setting a trap"],[4250,4400,"for a loser like you?"],[4441,4550,"All I had to do"],[4550,4725,"was see right through yours."],[4750,4937,"You're even dumber than I thought."],[4987,5104,"You didn't even bother"],[5104,5237,"doing a background check"],[5237,5375,"before pulling the trigger?"],[5454,5587,"You always said"],[5587,5712,"you were smarter than me."],[5737,5850,"But look at you now."],[5879,6037,"Every move you made"],[6037,6137,"is crumbling"],[6175,6275,"in my palm."],[6287,6412,"Every step you took"],[6437,6708,"was exactly where I wanted you."]],"47":[[25,125,"Why?"],[125,237,"I just wanted what was mine."],[237,437,"Why do you have to go this far, Claire?"],[475,550,"Yours?"],[550,704,"You really are delusional!"],[729,825,"Watts Group was built with"],[825,929,"my bare hands!"],[962,1037,"Since when did it become"],[1037,1125,"your birthright?"],[1162,1275,"You promised!"],[1275,1437,"You said after we got married,"],[1437,1554,"you'd hand over the company."],[1587,1662,"You'd step back,"],[1662,1775,"focus on family."],[1775,1937,"We've been married for 20 years."],[1937,2050,"Phoebe's 18."],[2050,2116,"And you?"],[2137,2262,"You're this award-winning,"],[2262,2375,"high-flying CEO."],[2375,2437,"And me?"],[2454,2550,"I'm a nobody."],[2575,2662,"Just your shadow."],[2662,2812,"A damn househusband."],[2887,2975,"You want to know"],[2975,3125,"why I never gave you the company?"],[3150,3362,"Because you never saw me as family."],[3387,3512,"I was just the outsider."],[3512,3675,"You trusted our daughter"],[3675,3800,"more than your own husband."],[3816,3925,"Oh, give me a break!"],[3937,4037,"You think I didn't try?"],[4050,4150,"I gave you chance"],[4150,4262,"after chance."],[4287,4416,"You couldn't even close one deal."],[4454,4562,"Not one."],[4625,4779,"You sabotaged partnerships."],[4787,4900,"You double crossed clients."],[4904,5075,"You trashed your own reputation."],[5091,5275,"I was trying to do that for us."],[5312,5412,"For the company."],[5437,5525,"You use that as an"],[5525,5650,"excuse to shut me out!"],[5650,5737,"No, Eric."],[5737,5854,"You shut yourself out."],[5875,6129,"You're no different than Edith or Josh."],[6200,6275,"You just wanted to"],[6275,6412,"reap what you never sowed!"],[6412,6491,"Shut up!"],[6512,6675,"Oh, you want to talk about power?"],[6675,6837,"If you're so talented,"],[6837,6962,"why don't you start your own business?"],[6979,7112,"Why did you have to scheme,"],[7112,7175,"and plot,"],[7175,7287,"to try and kill Phoebe and me"],[7287,7450,"to take what we built?"],[7512,7691,"You never wanted success."],[7729,7854,"You wanted a shortcut."],[7904,8100,"You didn't want a company."],[8129,8279,"You wanted the crown without"],[8279,8462,"having to ever earn the throne."],[8500,8637,"Pathetic."]],"48":[[37,125,"Why?"],[150,325,"Why did it all fall apart?"],[891,1091,"Claire Watts go to hell!"],[1225,1291,"Mom!"],[1675,1837,"Mrs. Watts, you okay?"],[2029,2137,"You think you're worthy"],[2137,2300,"to lay a finger on her?"],[2341,2550,"She's my number one client,"],[2662,2804,"asshole!"],[2804,2891,"It's fine."],[2891,3062,"He didn't touch me."],[3062,3229,"You damn monster!"],[3241,3350,"Rot in hell!"],[3350,3500,"Claire helped my company"],[3500,3687,"when nobody else would."],[3687,3850,"If you try to hurt her,"],[3850,4054,"I'll bury you myself."],[4087,4141,"Mrs. Watts,"],[4179,4237,"how do you want"],[4237,4433,"this garbage disposed of?"]],"49":[[29,66,"How do you want"],[66,229,"this garbage disposed of?"],[562,737,"Don't bite off more than you can chew."],[766,891,"I lost,"],[962,1212,"completely, utterly lost."],[1212,1325,"Claire,"],[1325,1516,"my beloved wife."],[1541,1687,"You're colder than ice."],[1700,1937,"I was going to let you walk away,"],[1937,2029,"but then,"],[2029,2187,"you touched Phoebe,"],[2187,2325,"and that"],[2325,2512,"was your last mistake."],[2525,2591,"Mr. Hamlin,"],[2591,2679,"be a dear and hand him over"],[2679,2829,"to the cops, would you?"],[2862,2950,"Scum like this"],[2950,3104,"should never see daylight again."],[3129,3312,"It would be my absolute pleasure."],[3312,3400,"This guy's going down"],[3400,3500,"with so many charges."],[3500,3575,"His grandkids will"],[3575,3737,"be visiting him behind bars."],[3737,3816,"No, no, no..."],[3816,3912,"you can't lock me up."],[3912,4075,"I won't survive in prison."],[5333,5433,"No vitals."],[5554,5625,"He is dead."],[5775,5908,"Karma doesn't miss."]],"50":[[212,391,"Mrs. Watts."],[412,591,"He took out a $6 million"],[591,775,"life insurance policy on himself."],[837,975,"As his legal spouse,"],[975,1162,"the pay out now belongs to you."],[1237,1362,"Donate it all"],[1375,1487,"to charity."],[1541,1662,"Understood."],[2141,2275,"It's over..."],[2437,2604,"All of it..."],[3475,3604,"Lucy,"],[3650,3837,"it's our birthday today."],[3837,4150,"My mom got us tons of presents."],[4262,4341,"You have to wake up"],[4341,4562,"so we can open them together."],[4612,4754,"It's been a year."],[4754,5041,"All the monsters are gone, Lucy."],[5041,5225,"You're safe now."],[5237,5416,"You've always been a fighter."],[5429,5629,"Don't give up, okay?"],[6050,6129,"Lucy?"],[6775,6866,"Lucy!"],[6904,7054,"You are awake!"]],"51":[[29,112,"Pheebs..."],[225,345,"Happy birthday."],[612,804,"You're finally awake, sweetheart."],[887,975,"How do you feel?"],[1112,1195,"Aunt Claire,"],[1258,1337,"this whole year,"],[1337,1525,"even though I couldn't move."],[1583,1741,"I heard everything you said."],[1770,2066,"And I'm so sorry"],[2095,2208,"for misunderstanding"],[2208,2262,"you."],[2341,2404,"Oh, honey..."],[2450,2625,"I'm the one who failed"],[2625,2741,"to protect you."],[2854,3058,"I should be asking for forgiveness."],[3112,3187,"You and Phoebe,"],[3187,3350,"born on the same day."],[3416,3495,"And in my heart,"],[3529,3604,"you've always"],[3604,3787,"both been my daughters."],[3904,4162,"Can Phoebe really be my sister?"],[4329,4412,"Lucy..."],[4475,4687,"You have always been my sister."],[4837,4983,"Then... can I call you mom?"],[5100,5191,"Of course,"],[5225,5295,"sweetheart."],[5400,5525,"If that's what you want."],[5525,5654,"Then I'm your mom."],[5737,5779,"Mom..."],[5887,5941,"Yes,"],[6037,6112,"sweetheart!"],[6258,6404,"We are family now."],[6850,7166,"And nothing and no one will ever"],[7237,7345,"hurt you again."]]}