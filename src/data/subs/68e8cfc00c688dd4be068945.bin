{"1":[[164,340,"Eric, stop."],[340,480,"I have to go back to work."],[480,640,"It's a big day today."],[640,792,"The new CEO is in town."],[810,885,"Damn."],[936,1132,"No one's gonna even notice you slipped off."],[1132,1200,"Coffee girl."],[1200,1328,"No, Eric."],[1412,1484,"Honey, please."],[1484,1616,"I actually have to go."],[1616,1760,"Please, stop."],[1952,2036,"Wait, What are you doing?"],[2068,2188,"What are you doing? Stop."],[2188,2308,"Workspace role-play."],[2332,2396,"Don't you like it?"],[2396,2452,"No."],[2640,2724,"Stop."],[2856,2912,"Oh my god."],[2912,3064,"No, I'm so sorry."],[3088,3168,"I've had enough."],[3240,3324,"Let's break up."],[3352,3520,"Fucking you is like fucking a corpse."],[3520,3624,"Are you seriously"],[3624,3770,"breaking up with me right now?"],[3770,3848,"I am."],[3936,4084,"Go find somebody else who can endure you"],[4084,4272,"three years of missionary and doggy."],[4484,4556,"C'mon, kitty."],[5020,5096,"What?"],[5472,5668,"You're fucking sick."],[7916,7988,"Perfect."],[8080,8228,"Absolutely perfect."],[8272,8448,"So this is your idea of a quiet welcome?"],[8660,8712,"Sir."],[8712,8776,"How do you feel about"],[8776,8928,"taking over the Graves Club?"],[9044,9236,"As the heir to the Graves Family,"],[9236,9412,"did you join secretly?"],[9532,9692,"In order to keep track of the family?"],[9692,9768,"What do you think?"]],"2":[[1208,1348,"Get these reporters out of here."],[1348,1452,"Okay."],[1452,1668,"Out, out, out, out."],[1668,1760,"Thank you."],[2036,2124,"Oh my God."],[2124,2236,"Are you insane?"],[2272,2432,"Why are your hands bound?"],[2564,2672,"This is a tennis court,"],[2684,2916,"not a stage for your role-play games, Miss..."],[2996,3096,"Isla Moore."],[4412,4516,"Thank you."],[5148,5388,"I am so screwed."],[5688,5808,"Oh, God."],[5840,5896,"Another..."],[5896,5988,"Enough."],[6044,6224,"That's 12 shots, Isla."],[6224,6436,"You always lose it when you drink this much."],[6548,6652,"Is it true?"],[6660,6948,"Am I really a bore with no sex appeal?"],[6948,7064,"Of course not."],[7064,7264,"Don't let that asshole get to your head."],[7420,7560,"Tell me about the scene."],[7668,7752,"What scene?"],[7900,8096,"Dom. Sub."],[8096,8264,"That's what they call it here, right?"],[8292,8440,"You know it, Tracy."],[8540,8652,"You sure about this?"],[8956,9040,"All right."],[9204,9388,"Most people consider it a kink."],[9388,9564,"But it's more than that."],[9596,9776,"It's about trust, control,"],[9776,9996,"and mutual respect."],[10208,10364,"For some people,"],[10364,10620,"it's a way to explore parts of themselves,"],[10736,11008,"buried deep even to their own knowledge."],[11780,11880,"Excuse me."],[12528,12836,"There's this famous Dom, goes by CG."],[13012,13156,"He's looking for a sub."],[13232,13408,"Picky as hell."],[13532,13696,"Never satisfied."],[13812,14004,"None of the people I knew made the cut."],[14088,14216,"Maybe you might."],[14268,14600,"If you want to try something new."],[15300,15404,"CG?"]],"3":[[748,860,"Take your clothes off."],[2056,2112,"I'm sorry."],[2112,2308,"I'm just not ready for this."],[2908,3004,"Holy shit."],[3036,3208,"Are those even human muscles?"],[3276,3552,"What kind of face comes with a body like this?"],[3636,3716,"If you're looking to leave,"],[3716,3844,"you're going the wrong way."],[3936,4100,"Seems a little unfair."],[4144,4240,"If you're going to be my dom,"],[4240,4396,"I should at least see your face."],[4640,4732,"Rule number one,"],[4768,4960,"my sub never sees my face."],[4960,5148,"If you're not ready, then leave."],[5168,5268,"If you are,"],[5320,5484,"then put the blindfold back on."],[5668,5812,"You have three seconds."],[5884,5952,"Three."],[6044,6240,"Fucking you is like fucking a corpse."],[6448,6516,"Two."],[6564,6732,"Go find somebody else who can endure you"],[6732,6960,"three years of missionary and doggy."],[7064,7124,"One."],[7700,7784,"I'm in."]],"4":[[60,144,"I'm in."],[1412,1604,"Should I kneel, sir?"],[1864,1964,"Call me Master."],[2292,2524,"Should I kneel, Master?"],[3208,3308,"What's your name?"],[3364,3424,"Isl..."],[3604,3708,"It's Grace."],[4256,4436,"Why kneel, Grace?"],[4604,4804,"Because I feel like I have to."],[10324,10404,"Are you ready?"],[10648,10760,"I think so."]],"5":[[1588,1684,"It's her!"],[2296,2428,"Wait, why are we stopping?"],[2672,2840,"I cannot accept you as my sub, Grace."],[2940,3016,"What?"],[3084,3208,"What are you talking about?"],[3208,3448,"Is it because I'm not sexy enough?"],[3544,3616,"No."],[3616,3724,"Rule number two,"],[3724,3936,"I don't play with people I know in real life."],[6896,6956,"Hello?"],[6956,7056,"I just got here to"],[7056,7228,"Mr. Grave's welcoming party."],[7228,7368,"Where are you, Isla?"],[7368,7448,"Shoot."],[7508,7676,"I'm sorry, I'm on my way."],[8240,8356,"Where are my clothes?"]],"6":[[1476,1836,"Oh, you are such a loser, Isla."],[1948,2100,"I couldn't agree more."],[2164,2400,"And as your supervisor,"],[2400,2580,"it's my obligation to remind you about"],[2580,2756,"dressing properly."],[2808,3184,"It is off hours, Stephanie."],[3184,3400,"What I wear is my business."],[3412,3684,"You don't really think some rented rag"],[3684,3956,"that barely covers anything is going to"],[3956,4184,"get you the attention of anyone?"],[4184,4436,"I've seen so many girls like you."],[4436,4704,"Pathetic, little gold-diggers."],[4716,4956,"At least I know how to treat people with respect."],[4988,5140,"Which is more than I could say for you."],[5140,5364,"You bitch, you can't talk to me like that."],[5364,5620,"Why are you always like this to me?"],[5964,6216,"I am your Intern, not your servant!"],[6268,6352,"God."],[6736,6852,"What is wrong with you?"],[6852,6972,"Are you crazy?"],[7068,7176,"Watch out!"]],"7":[[496,744,"Somebody help her. Isla can't swim."],[3352,3476,"Mr. Graves."],[3744,3932,"Oh my god, look at what she's wearing."],[3932,4000,"Whoa."],[4000,4156,"I didn't think the little sweet intern"],[4156,4252,"got down like that."],[4396,4496,"With all due respect,"],[4600,4768,"this is not what tonight was meant to be about."],[4804,4976,"This is your welcome party,"],[4976,5192,"I highly recommend against leaving."],[5328,5436,"If I ever catch you"],[5436,5580,"mistreating a coworker again,"],[5632,5784,"it'll be your last day at my club."],[11020,11160,"Master?"]],"8":[[502,615,"Master..."],[2040,2140,"What did you say?"],[2548,2744,"I can't believe she is still wasted."],[4108,4332,"I need to take a shower so just make yourself..."],[4888,4964,"At home."],[6228,6376,"Where am I?"],[6452,6596,"Is this heaven?"],[6904,7032,"Water."],[8368,8468,"What are you doing?"]],"9":[[116,264,"Got yourself all wet again."],[548,660,"Master?"],[880,968,"It's you."],[1072,1184,"You're CG."],[1408,1572,"I'm your boss, Grace."],[1596,1712,"You're too drunk."],[2140,2508,"My boss does not call me Grace."],[2700,2752,"Wait."],[2752,2992,"Why won't you accept me as your sub?"],[3012,3232,"Look, I know I'm a loser."],[3260,3384,"And unworthy."],[3384,3560,"And that's probably why my boyfriend"],[3560,3784,"cheated on me with a \"Cat\"."],[3784,3888,"Go put your clothes on."],[4668,4736,"Come on."],[6404,6588,"I want you to spank me."],[7124,7320,"Are you sure that's what you want?"],[7532,7620,"Yes."],[8172,8264,"Fuck the rules."]],"10":[[172,284,"Oh..."],[284,412,"My head."],[564,796,"I can't drink so much."],[2336,2552,"What exactly happened last night?"],[2736,2864,"Oh my God."],[2896,3104,"I'm in my boss's room."],[3292,3384,"On his first day,"],[3384,3526,"the new president of the renowned"],[3526,3648,"Graves Tennis Club"],[3648,3832,"encountered a distressing incident."],[3832,4052,"Famed tennis player, Harry Hayes,"],[4052,4248,"was injured gravely during training."],[4352,4538,"The 25-year-old rising tennis star"],[4538,4675,"is preparing for a lawsuit"],[4675,4948,"citing equipment failure and safety concerns."],[5252,5368,"Prepare my flight."],[5412,5640,"I'm going to visit Harry in D.C. right away."],[5660,5796,"Christian, I'll go with you."],[5840,6008,"Stephanie, I need you here."],[6008,6136,"You're head of PR."],[6164,6324,"Okay? What if press barges in?"],[6324,6600,"Okay, but we're in a PR crisis."],[6628,6840,"Who can handle it better than me?"],[6872,7112,"Oh my God, you imbecile."]],"11":[[28,264,"Oh my God, you imbecile."],[264,520,"Now is not the time to barge in, OK?"],[520,800,"You told me to deliver these in 5 minutes."],[800,920,"-Or you would... -OK, you..."],[920,1014,"You."],[1144,1292,"You're coming with me to D.C.."],[1600,1692,"Christian."],[1692,1818,"She can't even handle coffee."],[1818,1992,"My decision has been made."],[2168,2304,"I might need a sub..."],[2496,2616,"substitute plan."],[2820,3036,"Prepare a crisis presentation plan."],[3180,3380,"Meet me at my private jet lounge in 3 hours."],[4404,4532,"Mr. Graves,"],[4608,4989,"this is the crisis resolution proposal I put together."],[5632,5764,"Christian took me home."],[5764,6092,"But I swear I saw Master."],[6276,6540,"And my body, it's aching."],[6636,6745,"Did something happen"],[6745,6900,"between Christian and me?"]],"12":[[72,174,"Did something happen"],[174,328,"between Christian and me?"],[664,899,"So, first I thought we'll start with..."],[899,1066,"Start with the... um..."],[1264,1420,"You're breathing hard."],[1600,1688,"Are you nervous"],[1688,1836,"or are you expecting something?"],[2036,2412,"I just want to try my best for the proposal."],[2532,2600,"Try?"],[2864,3052,"I demand relentless perfection."],[3124,3308,"Absolute control over every single detail."],[3308,3444,"Do you understand?"],[3604,3852,"The tiniest flaw could lead to total collapse."],[4028,4140,"I'll make changes."],[4684,4780,"Anything else?"],[4884,5044,"I just want to say thank you"],[5044,5344,"for taking care of me last night."],[5476,5582,"I tend to black out"],[5582,5848,"and sometimes get a little crazy."],[6028,6328,"I hope I didn't do anything out of line."],[6384,6468,"Not at all."],[6660,6728,"Good."],[6796,6844,"Great."],[6928,7032,"Does it still hurt?"],[7228,7388,"What did you just say?"]],"13":[[80,296,"You fell by the street last night."],[356,465,"Does it still hurt?"],[478,565,"Oh."],[668,752,"Oh, no."],[904,1136,"No wonder I have wounds on me."],[1172,1380,"I guess I fell really hard."],[1436,1528,"You've got the potential"],[1528,1764,"to become a professional publicity manager."],[1852,1964,"You're attractive."],[2004,2188,"But you need to start believing it first."],[2268,2424,"Never underestimate yourself."],[2720,2900,"Would you believe in me,"],[3032,3148,"Mr. Graves?"],[3272,3388,"I do believe in you."],[5216,5400,"Have some water, Mr. Graves."],[5460,5556,"You look hot."],[6128,6280,"Apologies, Mr. Graves."],[6280,6524,"But Harry isn't feeling well, and he"],[6524,6788,"asked that you contact his attorney instead."],[6944,7012,"With sincerity,"],[7012,7196,"I was hoping to speak with him alone."],[7260,7404,"I understand, sir,"],[7456,7704,"but he truly is not feeling well."],[8116,8288,"Excuse me, sir."],[8404,8640,"Harry will have to meet with me today."]],"14":[[68,152,"Letters"],[188,436,"from the orphanage that Harry sponsors in L.A.."],[512,632,"The children were hoping that"],[632,808,"Harry might write back to them."],[1200,1376,"Please wait here."],[1728,1828,"What was that?"],[1900,2132,"Well, I did my homework, Mr. Graves."],[2168,2364,"I went to the orphanage myself,"],[2364,2524,"asked the kids to make them just in case"],[2524,2628,"we needed them."],[2776,2888,"Well done, Isla."],[2988,3124,"Good girl, Grace."],[3236,3332,"Oh, God."],[3370,3540,"What am I even thinking?"],[3692,3776,"You alright?"],[3852,4136,"Who brought me the gift from the orphanage?"],[4392,4536,"I did, sir."],[4588,4664,"Wait."],[4720,4956,"Do we know each other?"]],"15":[[108,324,"Well, I certainly know you,"],[324,656,"but I have no idea how you would know me."],[740,933,"You remind me of someone, uh,"],[984,1080,"friend."],[1177,1316,"It's a long time ago."],[1364,1500,"Perhaps I'm mistaken."],[1840,2004,"Thank you so much for this."],[2308,2580,"Is there anything I can do for you?"],[3064,3324,"Your compensation proposal"],[3324,3552,"is generous and sincere."],[3604,3900,"As for becoming the face of the Graves Club,"],[4140,4368,"I'll give it some strong consideration."],[4428,4628,"Oh, wonderful."],[4659,4836,"We wish you a smooth recovery."],[4928,5044,"Oh, and Isla..."],[5344,5532,"You mind if I ask for your number?"]],"16":[[176,332,"For the proposal,"],[332,476,"I have some questions."],[556,668,"Of course. Ye—"],[736,804,"Here."],[836,992,"I'll give you my personal line."],[2004,2084,"Thank you."],[2212,2300,"Come on."],[3404,3572,"Impressive work today, Isla."],[3748,3988,"Thank you, Mr. Graves."],[4040,4160,"You can call me Christian."],[4372,4524,"Thank you, Christian."],[4640,4776,"For giving me first approval"],[4776,4928,"on this internship."],[4984,5200,"How did you know about Harry's orphanage?"],[5296,5468,"I don't believe it's public knowledge."],[5680,5844,"Because I grew up there."]],"17":[[588,796,"Congratulations, Isla."],[796,1008,"Oh, you scored us a major win."],[1024,1140,"What win?"],[1192,1352,"Harry agreed to be the face of the company."],[1352,1592,"And it's all because you convinced him."],[1592,1710,"Mr. Graves said so before"],[1710,1876,"making you full-time this morning."],[1968,2104,"I'm not dreaming, am I?"],[2104,2172,"No."],[2324,2464,"Oh, my God."],[2580,2628,"Oh, my God."],[2628,2776,"I can't believe it."],[2904,3004,"Congratulations."],[3004,3064,"Thank you."],[4024,4257,"Hey, Stephanie, I put together a list with"],[4257,4495,"a couple of options of Harry's best angles."],[4495,4578,"If you want it to—"],[4592,4684,"No need."],[4684,4888,"Just because you're full-time now,"],[4888,5124,"doesn't mean you can tell me how to do my job."],[5228,5300,"Here."],[5328,5640,"You can help Harry put on the sponsor's watch."],[5676,5968,"It's limited edition, so handle it with care."],[6364,6444,"Oh!"],[6684,6788,"Oh, my God."],[6788,6960,"Look at what you did."]],"18":[[212,448,"Can you even afford to pay that back?"],[448,760,"That watch costs tens of thousands of dollars."],[788,980,"It's okay. I'll talk to the sponsors."],[1008,1180,"If I ask for a favor, it'll be fine."],[1180,1444,"That is one of only two in the whole world,"],[1444,1621,"so I don't even know how we're supposed to"],[1621,1756,"finish the shoot now."],[1904,1972,"Here."],[2100,2196,"Take mine."],[2248,2387,"I happen to have the only other one."],[2532,2672,"I'll pay for the broken one."],[2768,3084,"If all you do is endure your unbearable boss,"],[3340,3496,"why don't you work somewhere else?"],[3552,3668,"Maybe for me."],[3724,3920,"Are you seriously trying to poach my staff"],[3920,4040,"first day on your job?"],[4056,4324,"Well, she could make her own decisions, can't she?"],[4452,4600,"What's the matter, Christian?"],[4644,4756,"Threatened?"],[4892,4980,"Not at all."],[5036,5196,"Why don't we have a tennis match?"],[5216,5480,"That is actually a great idea."],[5504,5668,"We can even make it marketable."],[5676,5872,"Our new brand ambassador,"],[5872,6232,"versus our new president of the club."],[6248,6396,"Why don't we make it doubles?"],[6504,6616,"Bring in some staff?"],[6616,6924,"Well, I play tennis, so I can double Christian."],[6948,7132,"And Isla will be with me."],[7244,7324,"What?"]],"19":[[2640,2812,"What took you so long?"],[2812,2996,"Sorry, there's traffic."],[3036,3332,"Alright, we're all here, so let's play."],[3444,3552,"Ready, Christian?"],[4756,4844,"Hey, time out."],[5082,5228,"Hey, are you alright?"],[5228,5464,"I think I'm just not made for tennis."],[5516,5652,"Here, let me show you."],[5684,6040,"Okay, so, racket up, face up,"],[6040,6216,"and drive."],[6770,6858,"Oh."],[6876,7028,"Hey, are you okay?"],[7112,7192,"Yeah."],[7812,7940,"Excuse me."],[7940,8052,"What are you doing?"],[8052,8224,"Are you playing tennis or"],[8248,8448,"making love to something?"],[8548,8760,"If you can't handle the pressure,"],[8788,8932,"maybe you should just quit."],[9356,9420,"No."],[9524,9668,"No, I'm not quitting."],[10152,10240,"Game's on."],[10252,10340,"Keep going."],[11440,11596,"-Yeah! -Yeah!"],[11718,11905,"That's awesome. Oh my—"],[11984,12184,"Whoa... Hey, Isla, are you okay?"]],"20":[[24,240,"Whoa... Hey, Isla, are you okay?"],[256,364,"Are you hurting?"],[364,504,"I need a moment."],[2124,2216,"Who's there?"],[2260,2348,"It's me."],[2348,2472,"Do you need an ice pack?"],[2564,2720,"No, no, I'm..."],[3304,3400,"You okay?"],[4420,4496,"Thank you."],[5040,5252,"I want her, right here."],[5312,5420,"Mr. Graves."],[6088,6192,"What's that?"]],"21":[[80,156,"What's that?"],[524,596,"Isla?"],[620,692,"You okay?"],[740,813,"Yeah."],[876,984,"She's not feeling well."],[1052,1160,"Did you warm up?"],[1192,1308,"You know you have to warm up"],[1308,1436,"before playing tennis."],[1640,1724,"What's this?"],[1852,2012,"It's just a birthmark."],[2096,2196,"Birthmark..."],[2284,2516,"Harry, I think you should let a doctor tend to that."],[2544,2700,"No, I'm really okay."],[2700,2856,"I just need to rest."],[3764,3920,"After all these years,"],[3976,4124,"I've finally found her."]],"22":[[1148,1364,"If they ever lay a hand on you again,"],[1364,1520,"I'll punch their asses."],[1728,1916,"We'll stay together forever."],[1916,2016,"Right, Grace?"],[2092,2192,"Forever."],[2448,2584,"After I got adopted,"],[2628,2740,"they took me out of the city"],[2740,2852,"and changed my name."],[2960,3128,"You changed your name too."],[3216,3300,"Grace."],[3680,3796,"To Isla?"],[3868,4016,"Right in time, Isla."],[4016,4200,"You've got a secret admirer!"],[4228,4468,"Someone is trying hard to win your heart!"],[4796,4912,"They're for me?"],[5000,5160,"Who is the lucky boy?"],[5776,5932,"How do you like my roses?"]],"23":[[80,208,"They're from you?"],[228,512,"I did. And it's meant to come with a question."],[540,704,"If I win this match overseas"],[704,888,"which I'm about to fly out for,"],[932,1080,"will you celebrate with me?"],[1276,1404,"Oh, um..."],[1524,1632,"Maybe...?"],[1776,1960,"I'll take that as a yes then!"],[2060,2228,"Was that Harry's voice?"],[2248,2504,"Are you dating the world's sexist tennis star?"],[2636,2740,"Isla?!"],[2948,3116,"Isla, there is an even bigger"],[3116,3276,"bouquet of flowers for you."],[3276,3364,"Man, Isla?!"],[3364,3604,"How many secret admirers do you have?"],[3604,3896,"Well, this one doesn't have a note, so..."],[3956,4152,"Game! Christian."]],"24":[[1624,1676,"Hi."],[1676,1740,"Hi."],[1792,1896,"No luggage?"],[1976,2072,"Luggage?"],[2072,2304,"Yes, ma'am. The meeting spot is in Las Vegas."],[2420,2492,"What?"],[2544,2740,"No, I only have one day."],[2764,2932,"That would be like 10 hours there and back."],[2932,3084,"I'd miss my meeting then."],[3148,3260,"We're not driving."],[3372,3528,"We're taking his private jet."]],"25":[[5016,5108,"Relax."],[5348,5444,"If you can't,"],[5572,5752,"just use your safe word, and I'll stop."]],"26":[[996,1132,"I was dominated."],[1208,1520,"And yet, this strange feeling is growing on me."],[1628,1828,"Am I taking this too far?"],[2540,2664,"Mr. Graves."],[2816,3040,"Here's the proposal for Vantage Holdings."],[3116,3240,"Just leave it on the desk."],[4160,4324,"What happened to your wrist?"],[4788,4916,"I was playing with a kitten."],[5128,5308,"Were you here yesterday?"]],"27":[[132,332,"Were you here yesterday?"],[412,504,"Of course."],[720,940,"He doesn't sound like he's lying."],[1016,1172,"Maybe I'm overthinking."],[1516,1608,"Anything else?"],[1730,1831,"No."],[1840,1936,"No."],[2792,2932,"Come on, God."],[2984,3188,"Oh God."],[3252,3488,"You! The projector is down,"],[3488,3604,"and the sponsors are going to be here"],[3604,3668,"any minute."],[3668,3924,"So, could you just run to the supply room"],[3924,4028,"and get a spare?"],[4116,4184,"Yeah."],[4184,4308,"Okay. Go."],[6404,6608,"Enjoy your alone time."],[7320,7404,"Hey!"],[7428,7576,"Hey! Somebody out there?"],[7776,7976,"Hey, please! Help!"],[8040,8160,"Help me please!"]],"28":[[240,320,"Where's Isla?"],[396,512,"Who knows?"],[568,756,"She's supposed to lead this presentation today."],[856,920,"Come on."],[920,1088,"She can't even be bothered to show up"],[1088,1280,"on time for her presentation."],[1280,1484,"I guess I'll just have to find someone else"],[1484,1620,"to step in."],[2184,2256,"Christian?"],[2284,2416,"Christian, where are you going?"],[2416,2552,"They will be here any minute!"],[4208,4368,"No! Don't come near me..."],[4384,4532,"Stay away from me."]],"29":[[368,424,"Hey."],[500,572,"It's okay."],[604,700,"Just breathe."],[788,880,"Deep breaths."],[1076,1192,"You got this, Isla."],[1248,1352,"Hey, look at me."],[1484,1596,"You're safe now."],[1596,1700,"You're with me, okay?"],[2096,2244,"Thank you, Christian."],[2644,2780,"Wait! No, the meeting!"],[2908,2988,"It's all right."],[3006,3144,"It's alright. Just go rest."],[3164,3420,"No, Christian, this is my presentation."],[3568,3752,"I can't back down from this."],[4016,4080,"Alright."],[4176,4308,"Show them what you're made of."],[5368,5508,"Incredible proposal."],[5652,5736,"All the credit goes to"],[5736,5896,"Ms. Moore from our PR team."],[6016,6168,"I'm very happy, Ms. Moore."],[6244,6340,"In fact,"],[6424,6572,"I'd like you to take the lead"],[6572,6708,"on this collaboration,"],[6736,6924,"if that's okay with your boss?"],[7160,7328,"Thank you, sir."],[7328,7472,"I'll do my best."],[7472,7584,"Excellent."],[7600,7696,"And Stephanie,"],[7744,7920,"you'll be her assistant on this case."],[8076,8108,"But..."],[8108,8276,"You and I both know what you've done."],[9168,9272,"Excuse me."],[9648,9764,"Hey, Harry."]],"30":[[92,240,"I won the match!"],[240,424,"It's time to keep your promise."],[1000,1256,"I can't believe this place is still here."],[1256,1404,"You've been here before?"],[1420,1508,"I haven't."],[1556,1864,"But when I was a kid, my best friend"],[1864,2140,"Jimmy and I saw it in a magazine,"],[2140,2336,"and swore that one day"],[2336,2544,"when we had money, we'd come back."],[2544,2728,"Well, now you're here."],[2752,2960,"So, what flavor are you going to get?"],[2972,3052,"Well,"],[3256,3392,"I seem to remember that"],[3392,3684,"your favorite flavor was strawberry?"],[3788,3864,"Grace?"],[3996,4152,"What did you just call me?"],[4244,4408,"Griffith Orphanage."],[4452,4592,"1997"],[4660,4864,"You snuck out some strawberry jam."],[4932,5044,"Shared it with me."],[5084,5340,"Aunt Katherine got super upset of us."],[5468,5552,"Grace."],[5616,5724,"I'm Jimmy."]],"31":[[192,340,"I knew you're gonna pick that flavor."],[340,504,"Well, it's the best one."],[560,700,"No, it's strawberry."],[700,832,"Are you kidding me?"],[1004,1100,"Sorry."],[1568,1700,"Harry, I'm so glad that"],[1700,1952,"you found such an amazing adoptive family."],[2060,2132,"What about you?"],[2132,2384,"How was your life been all this time?"],[2556,2684,"I've been..."],[2980,3132,"You make a noise,"],[3156,3372,"and I'll cut out your tongue."],[3456,3676,"You're so ugly! You don't deserve nice things."],[3676,3832,"That was a gift from Aunt Katherine!"],[3832,3924,"Keep crying!"],[3924,4204,"Jimmy's gone and no one will come for you."],[4492,4620,"I've been okay."],[4756,5104,"Grace, I've been looking for you all these years."],[5216,5412,"I'm never gonna let anyone hurt you"],[5412,5508,"ever again."]],"32":[[1108,1220,"Sorry."],[2444,2628,"Grace, you okay?"],[2772,2832,"Yeah."],[2832,2996,"Yeah, I'm okay."],[4412,4600,"Master, are you upset?"],[4700,4832,"Is it because I was late,"],[4832,5024,"or because I was with a friend?"],[5608,5724,"You've hit your limit."],[5724,5836,"I'm okay."],[5836,5976,"Say your safe word."],[5976,6160,"Just keep going. I'm okay."],[6160,6252,"Keep going!"],[6252,6340,"Say it!"],[6340,6536,"No! Just keep going!"],[6536,6708,"I want to make you happy."]],"33":[[84,288,"My personal doctor will be here."],[336,556,"Grace, we're over."],[608,696,"Jesus! What happened?"],[696,812,"Are you okay?"],[896,968,"Sorry."],[1172,1264,"Holy shit."],[1264,1440,"Why didn't you use the safe word?"],[1572,1740,"I thought I could take it."],[1740,1844,"Girl, no!"],[1844,2052,"BDSM is all about trust and pleasure,"],[2052,2268,"not pushing yourself till you break."],[2448,2672,"Tracy, he ended things with me."],[2988,3088,"Sweetheart."],[3120,3404,"Not using the safe word is a huge red flag."],[3424,3560,"Just two weeks ago,"],[3560,3716,"a sub pushed too far and"],[3852,3972,"didn't make it."],[4428,4564,"I knew he was upset."],[4564,4808,"I just wanted to make him happy."],[4844,4988,"A real Dom"],[5016,5384,"puts a sub's safety way above their own pleasure."],[5432,5532,"If CG walked away,"],[5532,5756,"that tells me he's a responsible person."],[6060,6300,"You didn't fall in love with your Dom, did you?"],[7324,7508,"I should've walked away the second"],[7508,7696,"I started waiting for her texts..."],[7788,7992,"The second I felt jealous."]],"34":[[776,1084,"CG hasn't replied to me for a whole week..."],[1116,1320,"I guess it's really over between us."],[1380,1648,"Isla, the sponsors are looking for you."],[1648,1744,"Oh, okay."],[1744,1836,"Let's go."],[2336,2464,"You like her, right?"],[2628,2764,"Well, I like her, too."],[3076,3164,"A lot."],[3280,3512,"I hear you go through girlfriends like shirts."],[3616,3852,"You should stay away from a girl like Isla."],[3908,4108,"Grace is special."],[4216,4348,"She's different from everyone else."],[4348,4456,"At least for me."],[4520,4612,"Grace?"],[4696,4868,"We actually grew up together."],[4868,5092,"That's the name she used in the orphanage."],[5340,5516,"Funny, she didn't tell you that."],[5608,5688,"Maybe it's you"],[5704,5812,"who should back off."]],"35":[[244,424,"Oh, damn it."],[424,668,"I'm drunk again."],[1008,1092,"Hey."],[1408,1524,"Master?"],[1584,1716,"Is that you?"],[1800,1964,"Why did you drink so much?"],[3336,3648,"Christian took me back to his place again last night?"],[4212,4436,"You threw up on yourself last night."],[4504,4672,"Your clothes are at the cleaners."],[4744,4848,"Feel free to borrow something"],[4848,4960,"from my closet."],[5140,5236,"Christian."]],"36":[[228,364,"Oh, my God."],[388,680,"You are late again."],[872,1148,"Did you even make it home at all last night?"],[1272,1440,"You ended up in some random guy's bed,"],[1440,1536,"didn't you?"],[1664,1792,"You know, that cheap shirt"],[1792,1956,"actually kind of suit you."],[2324,2428,"What's going on?"],[2448,2656,"Someone was late."],[2716,2888,"In fact, I'm willing to bet"],[2888,3072,"they didn't make it home last night,"],[3168,3420,"or managed to hang on to their clothes."],[3488,3612,"I like that shirt on you."],[3792,3904,"You should keep it."],[4064,4172,"Thank you."],[4340,4388,"I'm sorry."],[4388,4588,"What does that even mean?"],[4756,4824,"Wait."],[4872,5040,"Are you two like..."],[5040,5224,"Stephanie, this is a workplace,"],[5224,5360,"not a tabloid."],[5672,5768,"Okay."],[6288,6376,"Christian."],[6444,6596,"About last night."],[6676,6996,"Sometimes I black out when I get too drunk."],[7064,7368,"I hope I didn't do anything I shouldn't have."],[7684,7772,"You did."],[7884,7976,"What?"]],"37":[[172,216,"Oh, my God."],[216,312,"I am so sorry."],[312,532,"Did I cross a line? Or..."],[600,748,"What line do you think you crossed?"],[944,1120,"I... um..."],[1784,1868,"It's okay."],[1928,2060,"You're fun when you're drunk."],[3204,3300,"Tracy?"],[3332,3412,"Isla?"],[3468,3620,"Help me! I met a new Dom."],[3620,3732,"Code name M."],[3768,3872,"I'm at the Queen's Hotel."],[3872,4004,"Something feels wrong."],[4004,4228,"Tracy, stop drinking and stay right there."],[4228,4269,"Okay?"],[4269,4440,"I'm coming to get you right now."],[4652,4764,"Tracy?"],[4856,4932,"Fuck."],[5176,5320,"This is my friend."],[5320,5468,"A man brought her to this hotel."],[5468,5560,"She could be in danger."],[5560,5760,"Can you please tell me what room she's in?"],[5784,5872,"Sorry, ma'am."],[5872,6016,"We can't give out room information"],[6016,6184,"without the guest's permission."]],"38":[[48,96,"No, ma'am."],[96,196,"You don't understand."],[196,340,"She's in danger, okay?"],[340,396,"I'm begging you."],[396,572,"She's drunk and she could be assaulted"],[572,732,"or worse! Please!"],[732,852,"What's her name?"],[852,988,"It's Tracy White."],[1160,1252,"I'm sorry."],[1336,1556,"There is no record under that name. Um..."],[1596,1828,"Do you know who brought her here?"],[1828,1952,"I don't know his name."],[1952,2152,"I only know his alias."],[2176,2320,"His alias?"],[2424,2608,"CG must know him!"],[2984,3072,"Grace?"],[3104,3272,"Please! Please help me!"],[3304,3468,"My friend was brought to the Queen's Hotel,"],[3468,3616,"And she's in danger."],[3616,3784,"She was brought here by some man"],[3784,3892,"that goes by the name M."],[3892,4028,"Do you know him?"],[4028,4156,"Wait for me there."],[4468,4564,"Isla!"],[4652,4748,"Christian?!"],[4748,4924,"Christian, what are you doing here?"]],"39":[[272,384,"Room 302."],[384,468,"Come on."],[1136,1236,"Oh, my God!"],[1284,1376,"Oh, my God!"],[1768,1896,"You gonna be okay."],[1896,1980,"Please, you're gonna be okay."],[1980,2100,"Help me!"],[2100,2260,"Let's get her out of here."],[3224,3383,"I've arranged for Tracy to be transferred to"],[3383,3552,"the best hospital in town."],[3636,3748,"She'll be okay."],[3976,4136,"You are CG."],[4364,4480,"Aren't you?"]],"40":[[204,304,"Yeah."],[492,692,"So you knew I was Grace"],[692,884,"this whole time?"],[960,1032,"Isla..."],[1032,1148,"I need some space."],[2244,2336,"Isla!"],[2348,2588,"Where have you been the past few days?"],[2624,2804,"#Boss wants you# #to be in his office.#"],[3680,3840,"I'd rather stand."],[4048,4292,"What is it you need, Mr. Graves?"],[4348,4588,"Isla, you know I'm not just your boss."],[4644,4704,"Yeah."],[4784,4972,"Yeah, you're CG."],[5088,5272,"My former Dom, right?"],[5556,5768,"There's something you need to understand."],[6012,6068,"At first,"],[6068,6184,"when I found out it was you,"],[6184,6296,"I thought about ending it."],[6296,6420,"Then why didn't you?"]],"41":[[96,404,"Why didn't you stop, Christian?"],[744,820,"Do you remember that night"],[820,944,"that I drove you home?"],[1092,1208,"You were drunk."],[2096,2172,"Yeah."],[2196,2392,"I threw myself at you."],[2448,2684,"Look, I won't pretend like you didn't tempt me,"],[2684,2752,"but I..."],[2752,2840,"Don't!"],[3016,3172,"Don't make it worse."],[3252,3552,"Okay, you had every chance to tell me."],[3604,3800,"But instead, you let me spin around"],[3800,3924,"like a puppet on a string."],[3924,4028,"No, it wasn't like that."],[4028,4192,"Then what was it like?"],[4368,4560,"I am done, Christian."],[4768,4840,"For what it's worth,"],[4840,5024,"I did come in here to talk to you."],[5092,5324,"Harry's going to Spain for a month."],[5324,5448,"He needs a PR manager."],[5448,5680,"And I volunteered."],[5700,5864,"That's six thousand miles away."],[5880,6144,"That is exactly what I need."]],"42":[[272,536,"And that wraps up our collaboration plan."],[580,748,"The press conference in Los Angeles"],[748,916,"will proceed as scheduled."],[936,1052,"Excellent! Miss Moore,"],[1052,1200,"thank you so much, you and your team,"],[1200,1416,"for the past months of really hard work."],[1416,1568,"Partnering with Harry and Graves Club"],[1568,1668,"will be a success."],[1668,1746,"We're sure."],[1924,2060,"You've been working non-stop."],[2060,2168,"Take a break."],[2168,2364,"Barcelona has the most beautiful coast"],[2364,2432,"in the world."],[2432,2504,"Go see it."],[2504,2748,"You will feel better and look better."],[2788,2912,"Thank you."],[4212,4420,"You have sharp taste."],[4500,4716,"These belonged to my grandfather."],[4820,5016,"Before he left for war,"],[5068,5244,"my grandmother had his initials"],[5244,5372,"carved into them."],[5424,5684,"He returned in one piece."],[5696,5800,"They say"],[5856,6156,"when two people truly love each other,"],[6184,6364,"they find their way back."],[6452,6628,"It's very romantic, you know?"],[6672,6812,"It's beautiful."],[7004,7248,"It's been a month since I last heard from him."],[7840,8036,"Grace. it's your birthday today,"],[8036,8140,"Let's go celebrate!"]],"43":[[268,488,"Monsieur, Madame, here is your table."],[488,720,"Is that Harry?"],[720,884,"The tennis star?"],[904,1164,"He is even more gorgeous in person."],[1164,1280,"Who's the girl?"],[1516,1808,"Harry, I know we're in Spain, but"],[1848,2144,"isn't it a little bold for us to be together like this?"],[2364,2584,"I don't mind being seen with you."],[2616,2760,"Happy birthday, miss."],[2772,2924,"-Oh! -Thank you."],[3100,3264,"You remembered my birthday."],[3344,3620,"I remember everything about you, Grace."],[3696,3916,"Harry, I wasn't expecting any of this."],[3916,4032,"It's so beautiful."],[4096,4364,"Hey, I just wanted to say thank you"],[4420,4608,"for this past month, you know?"],[4624,4756,"Working with you."],[4792,4912,"Being with you."],[5032,5200,"It's meant more than you know."],[5468,5708,"Call me old-fashioned, but..."]],"44":[[68,228,"Would you give me a chance?"],[432,868,"Say yes..."],[1196,1396,"Harry, I'm sorry, I..."],[1528,1748,"I can't lie to you."],[1972,2052,"Yeah."],[2200,2348,"Okay. Okay. Um..."],[2384,2544,"I'm so sorry."],[2552,2652,"It's fine."],[2652,2896,"I mean, I think I always knew"],[2976,3136,"that your heart wasn't mine."],[3404,3728,"Maybe we can still be best friends forever."],[3744,3892,"Like when we were kids."],[4220,4448,"Thank you, Jimmy."],[5540,5712,"Who sent these?"]],"45":[[944,1092,"Hi. Um..."],[1124,1376,"There was a jewelry box left in my room."],[1404,1568,"I was wondering if somebody left it here"],[1568,1692,"by mistake or..."],[1692,1960,"Oh, a gentleman asked me to pass it to you."],[1960,2136,"He said, happy birthday, Miss Moore."],[2292,2416,"Where is he?"],[2416,2536,"He just left."],[3764,3856,"Christian!"],[4704,4820,"Christian!"],[4868,4924,"No!"],[4952,5048,"Oh, my God."],[5120,5248,"Somebody help!"],[5284,5408,"Please!"],[5476,5596,"Oh, my God."]],"46":[[3664,3760,"How is he?"],[4032,4104,"Chris..."],[4104,4256,"Oh, my God!"]],"47":[[364,444,"Isla."],[540,628,"Hey."],[1328,1385,"Wait."],[1452,1700,"Who's the family member for Christy Walker?"],[3128,3344,"Your look beautiful with those earrings."],[3408,3632,"Thank you for the birthday present."],[3768,3932,"I said I wasn't going to reach out to you,"],[3932,4068,"and I broke that promise."],[4232,4560,"Christian, after everything I said to you,"],[4700,4892,"why would you show up?"],[5168,5348,"I just couldn't bear to lose you."]],"48":[[116,284,"I got into the kink world"],[428,576,"because of my first love."],[808,968,"She showed me control,"],[1076,1272,"and then she slept with my best friend."],[1428,1620,"When I confronted her about it,"],[1652,1780,"she blamed me."],[2012,2184,"She said that it was boring."],[2456,2580,"She said, Christian,"],[2728,2880,"no one could ever love you."],[3196,3412,"I think she broke something in me that day."],[3692,3860,"I didn't believe in love."],[4204,4300,"Until you."],[4664,4808,"I had every chance"],[4920,5068,"to tell you the truth."],[5292,5496,"But the old mighty Christian Graves,"],[5496,5696,"the one you once called Master,"],[5944,6080,"just lied to you."],[6252,6472,"You know I was afraid."],[6560,6724,"Afraid to be alone."],[6852,7044,"Don't say that, Christian."],[7256,7340,"Look at me."],[7836,8060,"Of course I wanted you physically,"],[8116,8268,"but I stayed."],[8288,8508,"Because of your courage,"],[8548,8768,"intelligence and honesty."],[8952,9240,"And the way you fight for your life."],[9396,9576,"Christian, do you like me?"]],"49":[[532,844,"I can't believe Isla and our boss got engaged."],[896,1092,"By the way, this cake tastes amazing."],[1092,1304,"I always knew they had chemistry."],[1892,1992,"Hey!"],[2188,2400,"Let's hear it for our future newlyweds."],[2976,3148,"Congratulations, Isla."],[3316,3416,"What's this?"],[3620,3756,"I bought you an island."],[3848,3984,"Just in case you two fight,"],[3984,4204,"and you need someplace to escape to."],[4316,4380,"Harry."],[4380,4556,"That's very thoughtful, Harry."],[4616,4768,"But she won't be needing it."],[5224,5368,"Nice cufflinks."],[5412,5536,"Isla got them for me."],[5860,6136,"Alright, let's get this party started, shall we?"],[6748,6836,"So..."],[6884,7096,"This party's a little dull."],[7140,7248,"You wanna get out of here?"],[7304,7440,"Where are we gonna go?"],[7532,7668,"I've got an idea."]],"50":[[1168,1244,"Come here."],[1752,1892,"Are you being disobedient?"],[2068,2188,"I don't know."],[2280,2388,"Maybe."],[2440,2600,"Let's get started for your punishment."],[2600,2672,"Oh, really?"],[2672,2732,"Yeah."],[2888,3072,"What are you doing?"],[3728,3848,"What do you say, Grace?"],[4592,4700,"Master."]],"51":[[2712,2948,"You're the worst, Christian."],[3024,3136,"You didn't like it?"],[3228,3352,"I didn't say that,"],[3480,3732,"but I am tired."],[3832,3952,"Let's go home."],[4048,4124,"Home?"],[4184,4304,"We are at home."],[4524,4708,"What are you talking about?"],[4788,4960,"It's part of the Graves estate."],[5044,5148,"From the moment we parked,"],[5148,5336,"you've been standing in your own backyard."],[5424,5528,"What?"],[5620,5724,"From now on,"],[5780,6060,"you'll be known as the madam of Graves Manor."]]}