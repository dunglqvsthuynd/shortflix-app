{"1":[[321,621,"Chris is my boss and my boyfriend."],[658,842,"Three years of sneaking around,"],[875,1013,"three years of promises."],[1034,1209,"He swore once the company's funding"],[1209,1272,"came through,"],[1272,1443,"he'd finally go public about us"],[1472,1555,"and propose."],[1609,1693,"Today's the day."],[1714,1922,"If it wasn't for a very special person,"],[2010,2210,"she's been with me since day one."],[2277,2406,"And now that I'm finally launching"],[2406,2473,"my company,"],[2519,2615,"I think it's time"],[2615,2715,"that I make it official."],[2761,2873,"This is it."],[2898,2977,"Finally."],[3616,3707,"Will you marry me,"],[3928,4087,"Eva Larsen?"],[4441,4500,"Yes!"],[4500,4612,"Oh my God, yes!"],[5000,5130,"Three years,"],[5176,5317,"and it was all just a lie."],[5363,5438,"What a joke."],[6589,6677,"Nola!"],[6815,6927,"You made me hide"],[6944,7032,"behind your stupid"],[7032,7161,"no office dating rule."],[7207,7282,"You wouldn't even admit"],[7282,7353,"that we were together,"],[7353,7461,"and now you're proposing"],[7478,7574,"to somebody else?"],[7586,7653,"Screw you!"],[7653,7720,"Don't you get it?"],[7820,7878,"I mean, you,"],[7937,7999,"you're nothing."],[8049,8095,"My parents,"],[8095,8208,"they would never accept you."],[8233,8345,"Eva, on the other hand, though,"],[8412,8600,"her dad is Ryan Larsen."],[8629,8754,"He's the richest man in the country."],[8771,8917,"Once I marry her, well,"],[8946,9092,"he's going to invest in my company,"],[9109,9192,"and then we'll go public."],[9192,9225,"I mean,"],[9225,9346,"that's just how the game is played."],[9496,9547,"Look,"],[9659,9759,"I can't marry you,"],[9830,9922,"but I still love you."],[10764,10919,"Uh, Mr. Larsen, your daughter"],[10923,11077,"and her fiancé, Chris Wilton,"],[11077,11140,"are in the ballroom."],[11140,11294,"They'd like you to join them for dinner."],[11340,11419,"The kid who dropped"],[11419,11478,"to one knee"],[11478,11574,"the second he met her?"],[11690,11761,"I'll pass."],[11815,11874,"Understood."],[12441,12583,"At least try to cover up the hickey"],[12583,12662,"before you lie."],[12666,12729,"Wake up."],[12775,12854,"You think you're just"],[12854,12987,"some precious virgin"],[12987,13058,"that's worth it?"],[13104,13146,"Honestly,"],[13146,13254,"I'm the only man who's ever"],[13254,13355,"gonna want to touch you."],[13500,13634,"We're done, Chris Wilton."],[15402,15494,"You're wet."]],"2":[[0,83,"You're wet."],[296,371,"Excuse me?"],[642,700,"Your clothes."],[750,804,"They're wet."],[888,988,"Oh, I'm, I'm sorry."],[988,1101,"I didn't realize."],[1497,1564,"Take them off."],[1668,1718,"What?"],[1918,2010,"I was just kidding."],[2131,2273,"But you know, in all seriousness,"],[2273,2369,"a pretty girl like you"],[2369,2544,"walking around in a city like that"],[2544,2619,"isn't safe."],[2669,2769,"So how about you come up"],[2769,2977,"into my suite and get changed?"],[3378,3524,"Just to change, nothing else."],[3574,3645,"You got my word."],[4763,4825,"Here."],[4963,5071,"The bathroom is through there."],[5196,5355,"Oh, there's a deadbolt on there"],[5355,5438,"if you don't trust me."],[5755,5851,"Thanks."],[6222,6377,"God, I'm a mess."],[6435,6498,"And for what?"],[6498,6589,"That piece of shit?"],[6623,6790,"Telling me to wake up?"],[6802,6973,"He's delusional if he thinks,"],[7023,7123,"I can't marry you,"],[7136,7290,"but you're the only person I love,"],[7290,7415,"is gonna keep me hanging."],[7461,7599,"I mean, he doesn't love that girl."],[7640,7795,"He just loves her daddy's money."],[7832,7924,"If he's so obsessed,"],[7924,7999,"maybe he should just"],[7999,8141,"marry Ryan Larsen himself."],[8316,8375,"Rough night?"],[8666,8750,"Don't waste your tears"],[8750,8833,"on some loser."],[8833,8933,"He's not worth it."],[9121,9255,"You know, cutting your losses early"],[9255,9388,"is something to be celebrated."],[9505,9555,"Trust me,"],[9559,9617,"I'm an expert"],[9622,9751,"in investment and returns."],[10160,10226,"Thanks."],[10268,10410,"I just needed to let it out."],[10456,10631,"You mentioned Ryan Larsen earlier."],[10760,10827,"Do you know him?"]],"3":[[37,100,"Do you know him?"],[175,308,"The world famous billionaire?"],[346,508,"Sure, I've heard of him."],[538,633,"Just rumors, though."],[684,775,"What kind of rumors?"],[825,938,"That he's ruthless,"],[1005,1101,"vicious,"],[1176,1267,"not just in business,"],[1267,1359,"but with women, too."],[1484,1576,"Ruthless with women?"],[1935,1976,"Yeah,"],[2039,2143,"that he burns through them,"],[2152,2298,"doesn't sleep with the same one twice."],[3453,3549,"Those eyes,"],[3653,3749,"I could drown in them."],[3832,3995,"If I was to kiss you right now,"],[4212,4337,"would it be crossing the line?"],[4808,4879,"I should go."],[5296,5355,"Do you really think"],[5355,5513,"that being some precious little virgin"],[5513,5593,"makes you worth it?"],[5689,5730,"Wake up."],[6139,6197,"I think-"],[8646,8767,"Are you sure about this?"],[8800,8871,"Yeah, I'm sure."]],"4":[[79,212,"It's Chris Wilton."],[237,296,"Chris?"],[312,425,"Why the hell is he here?"],[1534,1626,"No, uh,"],[1626,1776,"sorry to interrupt, Mr. Larsen."],[1805,1943,"Mr. Larsen?"],[1943,2068,"I'll come back later."],[2635,2836,"Mr. Larsen, like Ryan-"],[2836,2957,"Larsen, that's right."],[3015,3345,"Oh my God, Ryan Larsen, Eva's dad,"],[3365,3520,"my ex's future father-in-law?"],[3653,3866,"Mr. Larsen, I think we should stop."],[3878,3941,"Why?"],[4033,4154,"I know what you think of me."],[4300,4346,"Or do you think"],[4346,4462,"I'm gonna use it against you?"],[4550,4654,"That's not the reason."],[4688,4796,"The real reason is"],[4838,5042,"you're my ex's future father-in-law,"],[5059,5238,"and I just can't take this any further."],[5284,5355,"Then what is it?"],[5463,5563,"You think I'm gonna make it"],[5563,5684,"just a one-night thing?"],[5876,5939,"Well."],[6122,6218,"I have to admit,"],[6218,6285,"you're not just a"],[6285,6435,"one-night kind of gal."]],"5":[[74