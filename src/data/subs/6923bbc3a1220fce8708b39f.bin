the second"],[1976,2110,"you found out he was in trouble."],[2256,2419,"One insult and it crushed you."],[2569,2644,"Don't you see?"],[2773,2865,"That's love."],[3028,3090,"I see it."],[3294,3395,"And for what it's worth,"],[3591,3699,"I think you're the best."]],"50":[[145,237,"You know, that's funny."],[291,408,"I could swear just a week ago,"],[408,471,"you were telling me"],[471,525,"that I'm this"],[525,688,"cold-blooded bastard."],[775,930,"That's just what the magazines say."],[1017,1109,"I guess it's not true."],[1109,1234,"Maybe you should sue them."],[1330,1501,"What else did these magazines say?"],[1601,1726,"That you're ruthless,"],[1818,1964,"a business prodigy,"],[2014,2152,"and a heartless robot."],[2327,2406,"Really?"],[2410,2569,"What a defamation."],[2615,2802,"If you were to sue those magazines,"],[2802,2915,"you'd never leave court."],[2919,3053,"I mean, some of them even say that"],[3073,3123,"you never sleep"],[3123,3232,"with the same woman twice."],[3424,3478,"Really?"],[3607,3699,"I was just joking."],[3699,3841,"Don't take it so serious."],[4291,4375,"Yet you care."],[4567,4679,"Do you wanna know the truth?"],[4975,5055,"Is, is it true?"],[5518,5676,"There's only one way to find out."],[5818,5864,"How?"],[6056,6143,"I'll show you."],[6243,6402,"Then you can decide for yourself."]],"51":[[4,95,"I'll show you."],[183,358,"Then you can decide for yourself."],[563,658,"Say it, Nola."],[804,905,"Say you want me."],[1055,1272,"I want you, Mr. Larsen."],[1943,2014,"Nervous?"],[2097,2185,"First time, huh?"],[2264,2364,"What do you think?"],[2736,2890,"All this boldness around me,"],[3036,3178,"and underneath all this,"],[3294,3449,"you're just a tiny little rabbit"],[3449,3574,"wanting to be caught."],[3732,3895,"I've never been with anyone else."],[4054,4241,"I want you to be my first time."],[6068,6202,"I'll teach you how to beg,"],[6297,6402,"but not right now."],[7982,8091,"Nola."],[8191,8354,"Relax for me, Nola."]],"52":[[404,475,"Are you sure