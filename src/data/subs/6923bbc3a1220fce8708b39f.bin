Is flaunting yourself the only way"],[3115,3278,"you know how to make money?"],[3328,3365,"What?"],[3390,3495,"You're not gonna serve us?"],[3753,3845,"Sorry, sir."],[3845,3945,"I'm off the clock."],[4412,4529,"What's the kid doing here?"],[4558,4708,"How do you expect to make that million,"],[4746,4913,"if you don't get any overtime, right?"],[5000,5155,"Blake, tell me how this new caddy"],[5155,5226,"is treating you."],[5242,5338,"Pretty good so far."],[5376,5480,"She's already a favorite."],[5505,5613,"Lots of tips."],[5659,5797,"But if she's gonna get that million,"],[5843,5897,"she's gonna have to"],[5897,6076,"put in a little extra effort."],[6089,6314,"Guess you better start earning, babe."],[6448,6564,"Show some respect, okay?"],[6564,6623,"Back off."],[6623,6731,"Nice outfit."],[6756,6915,"White is a good color on you"],[6948,7036,"and those legs."],[7090,7157,"Come on, honey."],[7186,7278,"Skip the golf."],[7303,7586,"How about a little 19th hole action?"],[7603,7707,"It'll be the biggest tip"],[7707,7803,"you'll ever get."],[7832,7907,"Don't touch me."],[7907,8016,"How's life without me?"],[8066,8153,"No safety net."],[8199,8283,"No power."],[8316,8383,"And"],[8483,8587,"no one to get your mom"],[8587,8658,"out of jail."],[8908,9075,"I didn't think you could stoop this low."],[9079,9142,"Low?"],[9154,9259,"This is reality."],[9292,9392,"Beg me to take you back."],[9446,9513,"I'll give you everything"],[9513,9576,"you want,"],[9580,9805,"wealth, status, stability,"],[9843,9943,"and a cushy life"],[10060,10168,"as my mistress."]],"10":[[513,567,"Fuck!"],[759,821,"Get her!"],[1380,1568,"You roaming around,"],[1589,1659,"wearing that,"],[1659,1805,"shaking your ass for tips,"],[1826,1981,"but I'm the line that you won't cross?"],[1997,2173,"What, half the room is fine,"],[2189,2285,"but one man isn't?"],[2306,2389,"Just let me go."],[2389,2498,"You're such a creep."],[2669,2731,"Creep?"],[2761,2882,"You know I'll fucking end you."],[2932,3082,"And no one here is going to do"],[3082,3219,"anything about it."],[3269,3390,"Please, just let me go."],[3912,3978,"Who did this?"],[4141,4212,"Three years."],[4225,4346,"Three fucking years."],[4387,4583,"You'd never let me lay a hand on you."],[4592,4654,"And now what?"],[4654,4733,"You're spreading your legs"],[4733,4817,"for some other man?"],[4854,4979,"You call me a cheater?"],[5005,5217,"But you're a fucking lying whore."],[5234,5292,"Stop!"],[5292,5392,"Tell me who marked you."],[5409,5484,"Tell me right now! - Let me go, please."],[5484,5547,"Otherwise,"],[5547,5718,"I bury you tonight."],[5864,5922,"Ryan."],[5976,6126,"Ok, Ryan Larsen."],[6147,6260,"Your fiancée's father,"],[6293,6439,"your future father-in-law."],[6723,6802,"Are you happy now?"],[6856,6973,"Oh, damn."],[7019,7215,"She's saying the old man billionaire"],[7215,7282,"banged her?"],[7336,7482,"She must be really losing it."],[7499,7553,"What is this?"],[7553,7716,"Your audition for Mrs. Billionaire?"],[7795,7874,"That's rich."],[7907,7978,"You're insane."],[8024,8137,"Just trying to say that"],[8137,8220,"to get back at me."],[8224,8441,"What, you think my future father-in-law,"],[8458,8621,"the richest man in the country,"],[8646,8817,"would ever sleep with you?"],[8871,8938,"Yes."],[9092,9180,"She slept with me."],[9388,9426,"Who the hell?"]],"11":[[208,287,"Who the hell?"],[1993,2122,"Who the fuck are you?"],[2310,2385,"Mr..."],[2473,2565,"Let's get out of here."],[2694,2761,"Help me."],[3382,3440,"You ready?"],[3724,3791,"I should have rolled out"],[3791,3895,"the red carpet for you."],[4416,4587,"My legs feel like jelly."],[6493,6652,"I never thought I'd see him again."],[6698,6765,"But then,"],[6777,6911,"when I needed someone most,"],[6923,6981,"he came."],[7524,7657,"Maybe he doesn't hate me,"],[7716,7853,"maybe he cares"],[7907,8024,"even if it's just a little."],[8066,8133,"Miss Carter."],[8179,8245,"Yeah?"],[8287,8412,"Can you let go of my hand now?"],[8621,8692,"Sorry."],[9296,9359,"You're hurt."],[9659,9884,"Thank you for saving me today,"],[9905,9964,"but"],[10101,10247,"were you only at the golf club"],[10256,10326,"to see me?"]],"12":[[20,179,"Were you only at the golf club"],[179,250,"to see me?"],[1034,1092,"Miss Carter,"],[1092,1201,"did you tell your boyfriend"],[1201,1288,"that we slept together"],[1288,1380,"just to get him mad?"],[1397,1480,"No, I can't lie."],[1480,1572,"It was a smart move."],[1626,1751,"However, the issue is now"],[1751,1968,"you dragged me and my daughter"],[1968,2060,"into your mess."],[2097,2160,"No."],[2248,2352,"I was just scared."],[2410,2660,"And it just kind of came out, I'm sorry."],[2748,2923,"And Chris isn't my boyfriend anymore."],[2948,3078,"I'll vet Chris myself."],[3086,3186,"After what happened today,"],[3186,3340,"he's not the right fit for my daughter."],[3415,3503,"But as for you,"],[4379,4517,"write any amount you need,"],[4592,4696,"under one condition."],[4829,4900,"What is it?"],[5113,5246,"That we never see each other again."],[5451,5568,"So saving me today"],[5568,5730,"was just clearing things up"],[5730,5809,"with your daughter?"],[5876,5935,"Miss Carter,"],[5935,6043,"I can't have my family"],[6043,6177,"get tangled up in your mess."],[6231,6335,"Saving me back there,"],[6373,6456,"buying me off,"],[6456,6544,"it's all just about"],[6544,6623,"helping his daughter."],[6623,6752,"That's all I am to him."],[6810,7086,"A problem he'll pay to make disappear."],[7565,7724,"You don't have to humiliate me."],[7807,7966,"I know my place, Mr. Larsen."],[8037,8095,"And we're never"],[8095,8195,"seeing each other again."],[9205,9284,"God, Nola."],[9321,9476,"You are such a joke."],[9526,9592,"I can't believe"],[9592,9734,"you actually caught feelings"],[9734,9797,"for that guy."]],"13":[[66,145,"Tim, let's go."],[417,529,"Damn, that was close."],[546,646,"I haven't lost control"],[646,775,"over someone in years."],[855,1005,"But the way she looked back there,"],[1009,1138,"those helpless eyes."],[1188,1368,"I