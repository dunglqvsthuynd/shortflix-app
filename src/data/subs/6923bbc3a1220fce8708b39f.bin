],[646,792,"around the office like a horse,"],[813,1001,"then maybe I'll forgive him."],[1034,1188,"Who taught you to disrespect"],[1188,1322,"your classmates like that?"],[1330,1413,"What's the big deal?"],[1447,1605,"I ride my servants like horses"],[1605,1672,"all the time."],[1710,1760,"If Lucas"],[1760,1876,"doesn't wanna get kicked out,"],[1926,2043,"he's gonna have to let me ride him"],[2043,2202,"around the office like a horse."],[2344,2435,"Get down now."],[2610,2698,"Get down."],[3903,4041,"How dare you shove my son,"],[4041,4124,"you little punk!"],[4250,4291,"No!"],[4754,4959,"I'll make sure your son never gets"],[4959,5125,"into another school in this country."],[5155,5326,"He'll rot in the streets."],[5397,5559,"Where the hell is security?"],[5626,5714,"Right away, ma'am."],[5739,5930,"Security, get in here!"],[6239,6318,"Don't touch him."],[6381,6539,"You say this is a school for the elite,"],[6539,6669,"but if Lucas is going here,"],[6681,6819,"what does that say about his father?"]],"43":[[20,183,"You say this is a school for the elite,"],[183,308,"but if Lucas is going here,"],[321,462,"what does that say about his father?"],[504,596,"Please."],[667,875,"Who are you trying to scare?"],[955,1096,"Go on then, tell us."],[1130,1330,"Who is Lucas' father supposed to be?"],[1505,1672,"I know Ryan wanted Lucas"],[1672,1835,"to grow up like any other kid,"],[1864,2047,"without everyone knowing his name,"],[2068,2185,"but they've gone too far."],[2273,2444,"Lucas is the Larsen heir."],[2510,2740,"Ryan Larsen is Lucas' father,"],[2769,2927,"the biggest donor to this school."],[2998,3140,"Ryan Larsen?"],[3411,3482,"Lucas,"],[3557,3745,"there's nothing in your file about that."],[3853,4070,"You actually believe that?"],[4116,4187,"So what?"],[4187,4300,"You're claiming to be"],[4300,4441,"Ryan Larsen's wife?"],[4504,4637,"Damn it, I forgot."],[4679,4859,"I'm only posing as Lucas' mom."],[4875,4959,"If I admit that,"],[4959,5063,"they'll never believe me."],[5