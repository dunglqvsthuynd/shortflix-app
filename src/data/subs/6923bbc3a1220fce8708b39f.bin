This has nothing to do with Nola."],[1272,1372,"You are my age,"],[1388,1497,"so I know your type."],[1509,1680,"You're just into my dad for his money."],[1689,1814,"Well, leave my family alone-"],[1814,1868,"Eva!"],[2006,2093,"Respect her"],[2106,2235,"or we're done here, yeah?"],[3007,3186,"Did you throw Chris in jail for her?"],[3311,3420,"Chris has crossed the line"],[3420,3532,"more than just once."],[3545,3682,"He even tried to force himself"],[3682,3774,"onto Nola."],[3820,3953,"Is that the trash you want?"],[4049,4154,"No, I don't believe you."],[4179,4304,"You hate that we're engaged."],[4304,4421,"This is you just setting him up."],[4508,4567,"Really?"],[4625,4721,"Take a look at this."],[4800,4913,"This is his rap sheet."],[4975,5080,"Count after count."],[5192,5301,"He leveraged our name"],[5301,5509,"to gain access, to grift,"],[5534,5772,"round after round of investments."],[5847,5976,"Sorry to tell you this, sweetheart,"],[5976,6056,"but he's with you"],[6056,6193,"because of our last name,"],[6272,6448,"because I'm Ryan Larsen."],[6498,6552,"What?"],[6598,6798,"No, he said that he loved me."],[6944,7102,"Why wouldn't you tell me that earlier?"],[7211,7428,"Because technically you were stepping"],[7428,7590,"into someone else's relationship."],[7590,7724,"I didn't want you crushed."],[8016,8074,"What?"],[8187,8312,"For three years."],[8450,8529,"We broke up"],[8529,8666,"the day he proposed to you."]],"63":[[33,91,"What?"],[287,396,"While he was with you,"],[508,704,"he tried to make me his mistress."],[767,863,"I stumbled into"],[863,971,"being Lucas's nanny"],[971,1092,"after he blacklisted me."],[1530,1672,"Why would he do that to me?"],[1822,1910,"I loved him."],[2010,2173,"I even fought my dad for him and"],[2252,2381,"I gave him all my money."],[2381,2427,"Why would he-"],[2427,2510,"You what?"],[2615,2748,"Girl, you could not have been"],[2748,2827,"that love-drunk."],[2827,2940,"You gave him your money?"],[2940,3028,"That's your money."],[3057,3215,"Yeah, it's my money."],[3249,3374,"So why are you upset?"],[3420,3545,"I blocked it, sweetheart."],[3787,3874,"Thank God."],[3970,4033,"So what?"],[4083,4158,"You were just sleeping"],[4158,4208,"with my dad"],[4208,4308,"to get back at Chris?"],[4333,4387,"No."],[4483,4625,"I'm with Ryan because"],[4729,4800,"I love him."],[4879,4967,"And for the record,"],[4971,5113,"he tried to cut me a check"],[5113,5242,"to walk away for you."],[5284,5351,"Nola."],[5472,5530,"See?"],[5593,5730,"He actually loves you."],[5780,5885,"So stop torching him"],[5885,6018,"over some scumbag."],[6068,6285,"You're gorgeous and an heiress."],[6331,6493,"Every blue blood in the city"],[6493,6631,"would trip over himself"],[6631,6744,"for a chance with you."],[6831,7073,"Don't waste another tear on that loser."],[8274,8500,"After Chris got arrested,"],[8500,8712,"all of my friends called to roast me."],[8737,8812,"You, like,"],[8938,9025,"I tore you apart"],[9034,9196,"and you still gave me a compliment."],[9284,9446,"Why are you so nice?"],[9563,9722,"Will you be like my girlfriend?"],[9759,9880,"Like my actual friend?"],[10026,10114,"Oh no, now."],[10114,10226,"She's my girlfriend."],[10865,11127,"No, I want her to be my mom."]]}