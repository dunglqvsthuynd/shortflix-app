ot setting foot in this house again"],[7716,7795,"until she's gone."]],"35":[[233,296,"Sam."],[508,554,"Yes, sir."],[592,759,"Father and daughter just went nuclear,"],[759,909,"and I'm dead center."],[921,1021,"Does he fire me now?"],[1071,1159,"Tell Tim to start"],[1159,1280,"unwinding our investment"],[1280,1368,"with Chris Wilton."],[1472,1614,"And send a medic kit up here."],[1664,1747,"Very good, sir."],[4187,4316,"It's not that bad."],[4429,4512,"I don't need medicine."],[4512,4617,"I'll just get some ice."],[4637,4700,"Wait, wait, wait."],[4813,4884,"Don't move."],[4925,5009,"Unless you want Lucas"],[5009,5125,"to think that I did this."],[5568,5647,"I'm sorry,"],[5789,5901,"for everything today."],[6047,6135,"It's not on you."],[6239,6327,"Even without today,"],[6327,6477,"I wouldn't sign off on Chris."],[6631,6798,"Miss Eva said she'd only forgive you"],[6798,6869,"if I leave."],[7069,7140,"What's your call?"],[7478,7570,"She's my daughter."],[7757,7832,"Great."],[7862,7974,"Dumb question, Nola."],[8641,8717,"What's going on?"],[9200,9280,"Take off your shirt."],[9547,9588,"What?"]],"36":[[58,145,"Take off your shirt."],[304,350,"What?"],[437,608,"Your back, it took a beating."],[3432,3599,"You know I was in the room next door."],[3611,3741,"If you would have called for help,"],[3803,3862,"you wouldn't have gotten"],[3862,3953,"this banged up."],[4033,4129,"He's so gentle."],[4179,4387,"Those hands click and move millions"],[4387,4608,"and now they're tending me?"],[4804,4879,"What are you thinking?"],[5055,5134,"Mr. Larsen."],[5230,5280,"Hmm?"],[5505,5622,"I don't think I wanna keep"],[5622,5730,"the distance anymore."],[5893,5964,"Can I..."],[6210,6302,"sleep with you?"]],"37":[[25,87,"Can I..."],[342,433,"sleep with you?"],[621,663,"No."],[925,992,"Now don't move."],[992,1076,"I'm not done yet."],[1297,1334,"Why?"],[1334,1480,"Is my body not good enough for you?"],[1630,1780,"Miss Carter, you're too young for me."],[1889,1968,"Don't pick a game"],[1968,2