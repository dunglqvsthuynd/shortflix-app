4,558,"this would help sell the story, don't you?"],[738,838,"So long, Honey."],[1071,1167,"It's Hawney."],[1526,1672,"Thank God, that's the last time"],[1672,1818,"I will ever have to speak to you,"],[1818,1943,"Brady Wilder."],[2223,2352,"It may be senior year,"],[2352,2610,"but colleges look at everything."],[2644,2744,"And frankly,"],[2744,2990,"all of you should be very concerned."],[3153,3228,"That is, except"],[3228,3411,"for the one student that got an A,"],[3620,3770,"Harper Hawney."],[3945,4012,"Nerd."],[5860,6064,"Alright, let's go."],[6064,6260,"Shower time."],[6731,6861,"Wilder."],[6861,6986,"We need to talk."],[7307,7436,"You're in big trouble, son."]],"4":[[0,66,"You may be the best"],[66,129,"damn hockey player"],[129,183,"this boarding"],[183,283,"school has ever seen."],[304,367,"But you would not be"],[367,471,"the laziest."],[471,538,"Lazy?"],[588,684,"Coach, are you serious?"],[684,875,"I've been busting my ass on the ice."],[875,1051,"I'm talking about your study, son."],[1272,1422,"If you don't get at least a B"],[1422,1551,"on your chemistry final,"],[1614,1651,"you're going to"],[1651,1830,"lose your spot on the team."],[1893,2039,"Trust me, it'll hurt me"],[2039,2156,"more than it hurts you."],[2485,2560,"That is, except"],[2560,2756,"for the one student that got an A,"],[2806,2890,"Harper Hawney."],[3332,3411,"Don't worry."],[3474,3570,"I've got a plan."],[3616,3770,"This team counts on you, son."],[4254,4391,"Puckhead, what are you doing?"],[4391,4446,"I'm sorry,"],[4446,4542,"but this is the only way I know"],[4542,4675,"to get you to talk to me."],[4675,4750,"This is my hostage,"],[4750,4829,"until you hear me out."],[5130,5442,"I need you to tutor me in chemistry."]],"5":[[66,100,"Brady,"],[100,204,"I need my camera back."],[204,354,"These pictures are for the yearbook."],[408,517,"Look, don't worry,"],[517,621,"I got good photos of you,"],[621,813,"and your game winning smile."],[813,892,"You like my smile?"],[967,1151,"As much as I l