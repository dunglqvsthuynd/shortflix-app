{"1":[[446,704,"Yo, let's fucking go!"],[1292,1401,"I've been living below"],[1401,1597,"Brady Wilder for two months now."],[1597,1751,"To any other girl being so close"],[1751,1897,"to the most popular hockey star at"],[1897,1968,"Lockwood Prep"],[1968,2056,"would be a dream."],[2056,2168,"But for me,"],[2168,2239,"it's been nothing"],[2239,2377,"short of a nightmare."],[2660,2844,"Hot hot hot hot hot."],[3378,3578,"No, no, no, no,"],[3578,3732,"This was on loan for yearbook."],[4066,4162,"That's it."],[4341,4466,"Puckhead!"],[4466,4671,"Shut up!"],[6206,6339,"Brady Wilder?"],[6339,6519,"What is my nemesis doing here?"],[6735,6902,"Sorry to barge in, but"],[6961,7069,"I got a dare to win."],[7098,7269,"Damn, Brady,"],[7269,7415,"you already got her pants off?"],[7415,7574,"Man, you work fast."],[7595,7745,"What are you talking about?"],[7920,8099,"What are you doing, Puckhead?"],[8120,8241,"Can you just trust me for a second,"],[8241,8316,"Harper Honey?"],[8316,8445,"It's Harper Hawney!"],[8600,8666,"Hey, Brady,"],[8666,8771,"where are you going?"],[8771,8858,"The dare was to make out"],[8858,9054,"with nerdy Harper in front of us."],[9384,9505,"This would be better."],[9605,9718,"I promise."],[10226,10377,"You better start explaining."],[10377,10518,"Oh, I thought you knew everything."],[10518,10643,"About science."],[10643,10698,"Not about you"],[10698,10848,"and your degenerate friends."],[10848,10915,"Now talk."],[10915,11052,"Didn't you just yell at me to shut up?"],[11077,11173,"I think the whole dorm"],[11173,11248,"heard that."],[11298,11415,"If you don't start talking,"],[11415,11532,"I'm screaming for help"],[11532,11682,"in three, two..."],[12178,12291,"Okay, fine."],[12399,12499,"I need a favor."],[12641,12733,"I need your underwear."]],"2":[[62,116,"Aww!"],[191,283,"Did you just bite me?"],[283,400,"Did you seriously just ask"],[400,496,"for my underwear?"],[533,658,"Have you taken too many pucks"],[658,792,"to the head, hockey star?"],[809,888,"Listen