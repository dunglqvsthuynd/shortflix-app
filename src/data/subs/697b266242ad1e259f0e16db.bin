t been around much."],[3086,3232,"You two get in a fight?"],[3357,3524,"He...got a new girlfriend"],[3524,3620,"so he's just"],[3653,3732,"been busy."],[3991,4099,"That's a shame."],[4149,4200,"Good night."],[4220,4279,"Good night."],[5672,5809,"I shouldn't see him again."],[5918,6126,"But I want to hear what he has to say."],[6239,6356,"Get some closure."]],"32":[[717,863,"You've got some nerve showing your"],[863,1021,"face at Judy's birthday party."],[1055,1109,"Watch out,"],[1134,1343,"loser, and stay out of my way."],[1522,1593,"Or,"],[1697,1943,"are you just into getting beatings?"],[2022,2139,"You know what, Jasper?"],[2248,2431,"All this talk of you beating me,"],[2477,2606,"bullying me,"],[2673,2823,"doesn't make you more of a man."],[2952,3111,"Why are you so obsessed with me?"],[3161,3336,"I was invited to the party."],[3432,3486,"So..."],[3574,3691,"You don't get to kick me out."]],"33":[[216,350,"Where's Lucien?"],[909,1021,"Who are you looking for?"],[1055,1172,"Nun-yuh."],[1272,1430,"None of your business."],[1463,1509,"So,"],[1559,1743,"what'd you get Judy for her birthday?"],[1772,1976,"Or did you come empty-handed?"],[2089,2189,"Hey,"],[2344,2519,"I actually got you a present."],[2560,2815,"I threw out your ratty old pair, so..."],[2861,2948,"Here's a new one."],[2982,3073,"Looks like you still"],[3073,3161,"haven't learned your lesson."],[3574,3782,"I know your dirty little secret,"],[3782,3858,"Chris."],[3866,3941,"Hmm."],[4020,4116,"That's funny."],[4166,4350,"I didn't know I had any secrets."]],"34":[[45,141,"Give that back!"],[450,646,"Why don't you share with the class?"],[729,925,"I'm sure everyone here"],[925,1051,"would love to see what"],[1051,1163,"our valedictorian's"],[1163,1330,"really been studying."],[1459,1764,"Are all your dirty fantasies about men,"],[1789,1851,"Chris?"],[1885,1939,"Shut up!"],[1997,2060,"Let me go!"],[2060,2147,"You're so desperate,"],[2147,2331,"you're like a bitch in heat."],[4596,4683,"I can't believe"],[4683,4821,"a goody-two-shoes like Chris"],[4821,4946,"is such a creep!"],[5034,5226,"Ew, this is just so gross."]],"35":[[300,354,"Stop!"],[354,437,"Wait, no-"],[1013,1142,"That's enough, Jasper."],[1172,1292,"I'm done with your shit."],[1326,1468,"He's one of them, a, a..."],[1468,1534,"A creep!"],[1534,1701,"We don't want Chris at our party!"],[1701,1885,"You're the one who's a creep, Jasper."],[2227,2348,"You think being a bully"],[2348,2485,"makes you so cool?"],[2519,2606,"So important?"],[2606,2669,"Huh?"],[2731,2844,"Grow up."],[3941,4220,"Hey, Jasper, smile for the camera."],[4358,4550,"I mean you look like a baby!"],[4934,5055,"Shut up! Okay? Just..."],[5125,5246,"Stop taking pictures!"]],"36":[[54,137,"Ah, gorgeous."],[221,283,"What?"],[312,467,"It's just a prank, bro."],[588,692,"Can you not take a"],[692,834,"joke when it's on you?"],[971,1059,"You can go."],[1113,1213,"Enjoy the party."],[1626,1705,"And if I catch you"],[1705,1835,"bullying Chris again,"],[1897,2010,"you're done."],[2260,2339,"Good boy."],[2882,3019,"Time to get started, Lucien."],[3332,3474,"So this is why you called me here?"],[3507,3657,"To give Jasper my sketchbook?"],[3657,3828,"To humiliate me in front of everybody?"],[3862,3916,"Oh."],[4004,4099,"Are you satisfied?"],[4333,4441,"Chris!"],[4562,4667,"Let go."]],"37":[[12,91,"Let go."],[125,354,"Remember what you promised me."],[517,692,"I may have agreed to be your boyfriend."],[721,909,"That doesn't mean I can stand you"],[909,1138,"or Jasper or Tom and Bianca."],[1226,1397,"I'm sick of you bullying Chris."],[1426,1572,"I didn't do anything."],[1601,1664,"Oh,"],[1680,1751,"well,"],[1780,2043,"then I'm sure you can make them stop,"],[2043,2139,"right, baby?"],[2377,2556,"That's part of our deal, too."],[2861,3061,"You didn't say happy birthday to me yet."],[3415,3599,"Happy birthday, Judy!"],[3837,3995,"Happy birthday, Judy."]],"38":[[154,241,"What are you doing?"],[241,304,"Huh?"],[362,496,"I need to apologize."],[529,663,"Chris, I'm so sorry."],[729,817,"But I did not give"],[817,930,"Jasper your sketchbook,"],[930,959,"okay?"],[959,1071,"He stole it."],[1167,1226,"Okay,"],[1226,1347,"I must have jumped to conclusions."],[1372,1443,"Sorry."],[1443,1705,"Come on, will you talk to me, please?"],[1735,1889,"I saw her kiss you!"],[2231,2306,"I kept thinking you"],[2306,2369,"would come back"],[2369,2439,"and explain everything,"],[2439,2577,"and I waited around like a fool."],[2719,2827,"And you never showed up."],[2907,3036,"Judy threatened me."],[3128,3265,"She said that if I didn't do it,"],[3265,3378,"then she would go tell"],[3378,3465,"the teachers and then"],[3465,3561,"get you expelled,"],[3561,3724,"so I had to."],[4037,4124,"Just admit it."],[4241,4337,"You want her."],[4400,4521,"I can see it."],[4608,4754,"Say it, and I'll leave you alone."],[4767,4813,"Fine."],[5055,5221,"Actions speak louder than words, right?"]],"39":[[383,596,"Hey, don't you dare ignore me,"],[633,700,"okay?"],[738,905,"Okay, I can't, I can't take it."],[963,1051,"Every time you tell me that"],[1051,1138,"it's none of my business,"],[1138,1209,"I just..."],[1276,1426,"I just want to show you."],[1601,1793,"You've been my business all along."],[3908,4049,"Fuck, Lucien, really?"],[4137,4179,"You're hard-"],[4179,4258,"Hard?"],[4408,4462,"Yeah."],[4587,4788,"I can't control myself around you."],[4850,5009,"Is this your way of humiliating me?"],[5034,5163,"You invited me here to embarrass me"],[5163,5296,"in front of your girlfriend?"],[5338,5467,"I invited you?"],[6193,6339,"I didn't send that."],[6523,6619,"You didn't?"],[6619,6773,"Then who would?"],[6861,6961,"Lucien!"],[7036,7152,"Are you in there?"]],"40":[[258,362,"Judy must have sent that"],[362,442,"text from your phone."],[442,571,"Yeah, she's been glued to my side."],[571,608,"She's the only"],[608,754,"one that could have sent it."],[842,1001,"Those fuckers did it together."],[1001,1113,"One of them lured you here,"],[1113,1155,"and the other"],[1155,1288,"one stole your sketchbook."],[1322,1434,"You can't accuse them of anything"],[1434,1497,"without proof."],[1643,1789,"I'll figure something out."],[1789,1835,"Um..."],[2122,2227,"Trust me, okay?"],[2227,2344,"Once they learn their lesson,"],[2377,2565,"they won't pick on you again, okay?"],[2786,2890,"Are you in there?"],[3019,3128,"Lucien, are you in there?"],[3161,3265,"We're gonna cut the cake."],[3290,3386,"You should probably get out there."],[3386,3499,"Your girlfriend's waiting for you."],[3520,3691,"Don't you fucking say that shit to me,"],[3691,3712,"okay?"],[3745,3953,"You're the only one I've ever wanted."],[5267,5417,"Babe, are you in there?"],[5730,5801,"What's up?"],[5834,5980,"I think Lucien's in there."]],"41":[[108,196,"What's up?"],[229,404,"I think Lucien's in there."],[658,796,"Babe, are you in there?"],[825,1013,"Is someone in there with you?"],[1076,1309,"Tom, let's break this door down."],[1981,2068,"Jesus Christ,"],[2068,2164,"can't a guy take a shit"],[2164,2268,"in peace around here?"],[4004,4266,"Chris, come on, let's go dance."],[4429,4587,"Lucien, over here."],[4708,4804,"Wait for me."],[4929,5059,"I'll take care of this."]],"42":[[905,1042,"Hey, eyes on me."],[1067,1192,"What are you looking at?"],[1418,1497,"Just making sure my"],[1497,1626,"study partner's okay."],[1659,1764,"Funny."],[1793,1939,"Did you come up with that yourself,"],[1939,2122,"or did Judy tell you to say that?"],[2469,2577,"Don't."],[2740,2857,"Thank you, everyone,"],[2857,2952,"for coming out to my"],[2952,3090,"birthday party celebration!"],[3370,3532,"I have a big announcement."],[3778,3962,"Lucien and I are officially"],[3962,4037,"dating-"],[4037,4220,"Actually, we're not dating."],[4441,4692,"I'm actually dating somebody else."],[4754,4954,"Lucien's dating another girl?"],[5146,5376,"Who said anything about a girl?"],[5626,5851,"The person that I'm dating..."],[6348,6443,"is Chris."],[7440,7736,"Lucien is joking, everyone."]],"43":[[0,233,"Lucien's joking, everyone."],[642,809,"What do you think you're doing?"],[842,913,"Don't forget,"],[913,1051,"I'm the only person that"],[1051,1192,"can keep Chris from getting expelled."],[1217,1413,"Ms. Stone is on my side."],[1626,1722,"Keep pissing me off,"],[1722,1868,"and I'll make his life hell."],[2185,2277,"Good boy."],[2335,2548,"Now just stand there and look pretty."],[2706,2811,"I wonder what they're"],[2811,2890,"talking about."],[2923,3136,"Judy does not look happy."],[3169,3324,"Is she having a fight with Lucien?"],[3353,3482,"If you get Chris expelled,"],[3516,3666,"then I'm just gonna go too."],[3753,3978,"I'm with Chris no matter what."],[4012,4233,"Your threats don't scare me, Judy."],[4266,4341,"Especially,"],[4441,4600,"when they're on record."],[4967,5055,"Give that back!"],[5055,5192,"Oh, actually."],[5246,5376,"What are you going to do?"],[5451,5643,"Not let Chris get expelled?"],[5776,5834,"And..."],[5834,5939,"there we go."],[5939,6064,"Sent it to your dad."],[6097,6168,"Keep it up,"],[6168,6314,"and I'll send it to the principal."],[6343,6410,"Then,"],[6510,6623,"you'll be the one getting expelled."],[7027,7123,"That was quick."],[7745,7811,"Judy,"],[7811,7920,"you've been throwing my name"],[7920,8074,"around to bully your classmates?"],[8162,8350,"I'm freezing all your credit cards."],[8375,8462,"Fix your act,"],[8462,8662,"or I'll send you to boarding school."],[8737,8892,"Remember what I said, Judy."],[8988,9088,"Bye."],[9313,9426,"Mind if I get in?"],[9484,9547,"Fine."],[9830,9893,"Hi."]],"44":[[0,179,"Let's dance and celebrate."],[1259,1426,"This is all your fault!"],[1484,1618,"You're the reason why Lucien's"],[1618,1718,"treating me this way."],[1876,1972,"I'm pretty."],[1993,2081,"I'm hot."],[2114,2202,"I should be the one"],[2202,2335,"with the hockey captain."],[2498,2594,"We're meant to be."],[2635,2719,"You know, actually,"],[2731,2911,"Chris has nothing to do with this."],[2948,3148,"I've told you repeatedly"],[3148,3228,"that I'm not interested."],[3240,3378,"So you can blackmail me"],[3378,3536,"and threaten me all you want."],[3586,3682,"But this?"],[3699,3858,"Never gonna happen, sweetheart."],[3883,3987,"Seriously?"],[4012,4179,"Is Judy that desperate?"],[4212,4354,"She had to blackmail Lucien"],[4354,4500,"to be her fake boyfriend?"],[4529,4654,"That's so embarrassing."],[4738,4808,"Shut up!"],[4867,5075,"All of you, you don't get it."],[5138,5242,"Get out of here!"],[5855,5901,"Come on."],[5972,6076,"Let's keep dancing."],[6222,6281,"Okay."],[6769,6881,"That's enough."],[6915,7115,"Lucien, home, now."]],"45":[[258,367,"That's enough."],[400,550,"Lucien, home, now."],[583,784,"Dad, what are you doing here?"],[809,967,"You think you can hide from me?"],[1009,1184,"I always know where you are."],[1217,1305,"Party's over."],[1330,1447,"Let's go."],[1751,1830,"This will be fine."],[1830,1906,"I'm going to take care of it."],[1926,1997,"You should go home and I'll"],[1997,2056,"see you at school,"],[2056,2089,"okay?"],[2122,2210,"Wait."],[2243,2344,"Lucien!"],[2831,2927,"Straight F's?"],[3040,3178,"You're useless."],[3328,3482,"Your teacher called me."],[3499,3636,"Ms. Stone says you've been"],[3636,3803,"picking fights instead of studying."],[3803,3974,"Lucien, what are you thinking?"],[4008,4120,"Is that what you want to be?"],[4145,4287,"A useless thug?"]],"46":[[183,304,"Get back here!"],[304,429,"I didn't send you to school"],[429,550,"for you to waste your time"],[550,692,"ruining your own life."],[817,896,"What?"],[996,1109,"Like you even care?"],[1167,1343,"You barely show up, and when you do,"],[1343,1447,"it's just to tell me how"],[1447,1589,"fucking useless I am!"],[1622,1743,"Do you even care how"],[1743,1893,"school's been for me?"],[1926,2039,"If all you wanted was a..."],[2127,2218,"a perfect,"],[2218,2389,"emotionless fucking robot,"],[2389,2565,"I should have never been even born!"],[2719,2806,"I don't care."],[2836,3007,"I've spent a fortune donating"],[3007,3123,"to your school to keep