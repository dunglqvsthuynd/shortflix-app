,6498,"So what?"],[6560,6844,"Clearly, good grades aren't contagious."],[6931,7148,"Are you really ready to make that bet?"],[7178,7298,"I'll take your bet."],[7353,7499,"I believe in Lucien."],[7661,7753,"Fine."],[7849,8074,"This is Lucien's last chance."],[8116,8245,"You get straight A's,"],[8245,8370,"you can stay."],[8404,8500,"Anything less,"],[8529,8625,"and you're going straight"],[8625,8700,"to the military."],[8804,8979,"And you know I'll keep my word."],[9092,9171,"He can do it."]],"48":[[137,191,"We'll see."],[546,629,"You didn't do anything wrong,"],[717,759,"okay?"],[846,1030,"You're gonna ace every single"],[1030,1188,"one of your final exams,"],[1188,1251,"and you're gonna make"],[1251,1355,"your dad so proud."],[1814,1947,"Chris, um..."],[2147,2268,"I haven't told you yet, but..."],[2606,2652,"I love you."],[2831,2902,"I love you too."],[3716,3858,"I'm applying to Princeton, Lucien."],[4029,4149,"Will you apply with me?"],[4458,4546,"Me?"],[4750,4867,"Do you really think I can do that?"],[5125,5217,"How about some motivation?"],[5271,5380,"You get your grades straightened out,"],[5417,5492,"get into Princeton,"],[5605,5722,"then you get yourself"],[5722,5776,"a boyfriend."],[5826,5880,"But if you don't-"],[5880,5972,"No, I can do it."]],"49":[[734,771,"Oh!"],[834,896,"Good afternoon, ma'am."],[930,1034,"I'm here for tutoring with Chris,"],[1034,1138,"and I need all the time I can get,"],[1138,1209,"so I'm just gonna head up there."],[1209,1334,"If that's okay, thank you so much!"],[1710,1843,"What has gotten into that kid?"],[1935,2089,"He's never been that excited"],[2089,2239,"about tutoring before."],[3853,3924,"Not bad."],[4054,4112,"You're improving."],[4312,4425,"We'll stop here for today."],[5059,5109,"Lucien?"],[6931,7032,"Please..."],[7194,7253,"Hey,"],[7357,7474,"remember your promise."],[7611,7782,"I already applied early to Princeton,"],[7816,7866,"so..."],[8216,8345,"Ball's in your court now."],[8658,8787,"I can't wait to get to college with you."],[8929,9004,"Maybe huh..."],[9142,9259,"try for some extra credit?"]],"50":[[346,467,"Are you kidding me?"],[492,529,"No."],[663,767,"better head home, boyfriend."],[1051,1130,"Boyfriend?"],[1188,1242,"Yeah."],[1534,1626,"I like it."],[1968,2147,"Studying is so hard."],[2243,2410,"Can't I just get like a little"],[2410,2510,"sneak peek at my reward?"],[2681,2781,"Come on, no one has to know."],[2915,3015,"You're hopeless."],[4254,4412,"My juicy little orange."],[4496,4608,"You smell good enough to eat."],[4838,4917,"This is cheating."],[5105,5234,"Just a kiss isn't cheating."],[5438,5764,"But I can do so much more if you let me."],[5864,6026,"I want more."],[6247,6339,"Every inch of me"],[6514,6660,"is yours to explore."],[6806,6927,"I'm going to take my color and"],[7065,7169,"see where it ends."],[8837,9063,"So, this is what you meant by tutoring."]],"51":[[50,229,"So this is what you meant by tutoring."],[713,767,"You should go."],[1121,1176,"Now."],[2310,2419,"What is going on"],[2419,2527,"between you and Lucien?"],[2702,2882,"We're just friends, Mom."],[2882,2936,"I'm his tutor."],[3128,3207,"Tutor."],[3307,3365,"Right."],[3453,3620,"Tomorrow I will call your teacher"],[3682,3732,"and tell them"],[3757,3903,"that Lucien needs a new tutor"],[3937,4099,"and you will not see him again."]],"52":[[104,250,"And you will do as I say."],[1468,1614,"Mom doesn't approve of us."],[1689,1764,"What do I do?"],[2306,2389,"I..."],[2623,2752,"I've been accepted early decision"],[2752,2852,"to Princeton University?"],[3511,3620,"Chris, are you okay?"],[3678,3824,"Is your mom giving you a hard time?"],[3991,4024,"Lucien,"],[4074,4175,"I want to see you tomorrow night."],[4229,4275,"I have something"],[4275,4362,"important to tell you."],[6051,6214,"Stop moving."],[6264,6385,"There's too many people here."],[7862,8020,"You ask me out on a dinner date"],[8020,8116,"to celebrate your"],[8116,8274,"acceptance to Princeton."],[8366,8470,"And I can't even hold your hand?"]],"53":[[41,91,"How's your mom?"],[521,583,"She'll come around."],[721,834,"Might take some time, but..."],[1222,1330,"Will you face it with me?"],[1438,1501,"Together?"],[2139,2252,"Of course I will."],[2752,2869,"Don't let me distract you though."],[2973,3094,"If anybody finds out about you,"],[3132,3236,"especially your dad,"],[3386,3553,"no one's gonna take you seriously."],[3553,3674,"Yes, especially my dad."],[3749,3828,"He's been trying to ship me"],[3828,3945,"off to the military for, like,"],[4041,4104,"ever."],[4329,4454,"That one work out old."],[4921,5030,"If we weren't here right now,"],[5205,5296,"you'd have absolutely"],[5388,5492,"no chance of keeping"],[5492,5568,"your clothes on."],[6477,6560,"Lucien?"],[6727,6794,"Dad?"],[6973,7077,"What are you two doing?"]],"54":[[12,120,"What are you two doing?"],[208,442,"We just finished a study session so we"],[442,550,"were getting some food."],[596,675,"Just grabbing a bite to eat."],[788,871,"You only got a couple"],[871,992,"of days until exams."],[1055,1138,"Remember our bet."],[1172,1388,"Straight A's or else."],[1480,1584,"I won't show mercy."],[1668,1726,"You never do."],[1972,2152,"You two are so close."],[2223,2352,"Is this how boys"],[2381,2498,"are making friends nowadays?"],[2519,2706,"We're very good friends."],[2827,2911,"Best friends."],[2998,3040,"Yeah,"],[3040,3094,"but we were just going to"],[3094,3186,"grab some food, so..."],[3211,3324,"we won't interrupt you guys."],[3340,3407,"Have a nice night."],[3449,3478,"Oh,"],[3478,3557,"why don't we all just"],[3557,3645,"have dinner together?"],[4062,4254,"And I was wondering how to kick you out."],[4295,4400,"Looks like I found your"],[4400,4529,"dirty little secret."],[5000,5171,"That is a great idea."],[5643,5789,"No wonder you're worried"],[5789,5872,"about Lucien."],[5872,5930,"I mean..."],[5972,6114,"treating himself to a fancy"],[6114,6272,"dinner after getting straight F's."],[6373,6594,"Maybe sending him to the military"],[6614,6710,"would be the best."],[7278,7465,"That's Anya, my dad's girlfriend."],[7557,7691,"She's been trying to get me kicked out"],[7691,7799,"forever so that she can"],[7799,7866,"have all his money."],[8128,8183,"Come on, babe."],[8233,8291,"Can't wait."]],"55":[[525,713,"You two are so cute together."],[713,896,"Lucien, I thought he was your boyfriend."],[1063,1126,"Nope."],[1176,1288,"We're just study buddies."],[1397,1455,"You know, actually,"],[1455,1564,"Dad was the one who wanted"],[1564,1710,"Chris to tutor me in the first place,"],[1710,1760,"so..."],[1847,1910,"Of course."],[2010,2056,"After all,"],[2056,2264,"your dad does need someone"],[2264,2448,"to carry on the family business."],[2540,2686,"I mean, if you don't step up,"],[2686,2836,"I'm gonna have to have a baby boy"],[2836,2982,"to keep the company going."],[3040,3098,"Enough."],[3182,3307,"I don't need another son."],[3837,3949,"Don't worry, baby."],[3949,4079,"I'll make sure to kick Lucien"],[4079,4233,"out before you're born."],[4241,4458,"Everything Arthur has will be yours"],[4458,4521,"one day."],[4683,4954,"Lucien, you look so sharp tonight."],[4954,5055,"Do you have a hot date?"],[5121,5221,"Nope, no date."],[5359,5438,"You know, actually,"],[5438,5580,"we were just gonna get takeout,"],[5580,5613,"so-"],[5626,5697,"Let's order."],[6056,6193,"Good evening, sir, ma'am."],[6239,6373,"Will the young gentleman still be"],[6373,6514,"enjoying the Romantic Couple's"],[6514,6656,"Special that was reserved tonight?"],[6656,6723,"I'm sorry, the..."],[6781,6877,"The what now?"]],"56":[[0,120,"The Romantic Couple's Special."],[162,258,"We'll go get it ready."],[671,809,"I knew it!"],[829,980,"You are too cute together to be"],[980,1059,"just friends."],[1096,1234,"That is so sweet."],[1267,1334,"The couple special"],[1334,1418,"is just a better deal,"],[1418,1451,"that's all."],[1530,1701,"I'm tutoring to make ends meet already,"],[1701,1897,"but I don't want Lucien to pay"],[1897,1931,"for me."],[2060,2114,"That wouldn't be fair."],[2160,2239,"Yeah."],[2460,2506,"That's all."],[4567,4654,"Oh!"],[4654,4946,"This is so romantic."],[4946,5059,"Even if they did come"],[5059,5138,"as just friends,"],[5138,5317,"they might leave as a couple."],[5484,5680,"Enjoy your dinner."],[5755,5826,"I'm leaving."],[6498,6594,"Enjoy your evening."],[7169,7286,"You can stop now."],[7378,7474,"For the love of God."]],"57":[[112,154,"You okay?"],[254,291,"I'm fine."],[575,679,"I'm used to it."],[846,1034,"Anya been trying to kick me out"],[1034,1084,"for years,"],[1084,1130,"so just"],[1297,1401,"forget it, okay?"],[2014,2085,"No, I'm sorry."],[2085,2206,"Tonight was supposed to be"],[2206,2385,"about us celebrating you getting"],[2385,2498,"into Princeton,"],[2498,2523,"okay?"],[2523,2606,"Let's focus on that."],[2681,2727,"Forget that."],[2882,3065,"Do you want to just get out of here?"],[3399,3461,"I have an idea."],[3553,3603,"Oh?"],[4254,4333,"Not here."]],"58":[[1676,1772,"Take off your shirt."],[3536,3603,"Take off your pants."],[5451,5509,"Sit."]],"59":[[300,408,"Hands on the armrests."],[1038,1109,"Spread your legs."],[1526,1580,"More."],[2765,2898,"You just like you do"],[2898,2969,"when you're grading me."],[3015,3165,"So strict."],[3244,3440,"Well then consider this your final exam."],[5000,5071,"Don't move."],[5213,5288,"Eyes on me."],[6035,6147,"I like it."],[6243,6377,"So, uh..."],[6410,6506,"What's next?"]],"60":[[821,871,"I mean..."],[1009,1080,"That's not new."],[1272,1418,"I can't control myself around you."],[2014,2131,"Come on, Teach."],[2131,2198,"If you can't even hold"],[2198,2277,"your pencil steady,"],[2369,2502,"how are you going to teach me anything?"],[2686,2919,"I am very steady."],[3098,3186,"Surgeon steady."]],"61":[[542,767,"Why don't you just come closer"],[796,921,"if you want to draw me?"],[1472,1593,"I don't know if I can get it all."],[1822,1868,"But..."],[1976,2264,"I guess I can just focus"],[2264,2356,"on my favorite parts."],[2602,2656,"Go on then."],[2790,3003,"Enjoy your favorite parts."],[3161,3274,"I promise I won't stop you."],[3499,3553,"You sure?"],[3753,3966,"Not scared I'm gonna get carried away?"],[4170,4216,"Baby,"],[4383,4504,"I'll take whatever you got."],[6923,7002,"Take me."],[7361,7436,"Say it again."],[7757,7795,"Take me."]],"62":[[196,312,"So is this my present tonight?"],[421,467,"You like it?"],[1493,1618,"Congrats on getting into college."],[1768,1926,"Now let's see how you handle me."],[3574,3649,"Up."],[3728,3924,"On your knees,"],[4587,4692,"You feel how bad I've been"],[4692,4779,"waiting for this?"]],"63":[[25,100,"Don't stop."],[262,371,"I don't plan on."],[479,563,"You're mine tonight."],[679,713,"Every"],[834,900,"inch of you."],[3545,3632,"Hey, Mom."],[3753,3862,"I'm home."],[4283,4362,"Mom?"],[4833,4888,"Hello?"],[4959,5155,"Hello, is this Chris Banning?"],[5188,5226,"Yes."],[5288,5401,"Your mother fainted."],[5401,5497,"She's at the hospital."]],"64":[[763,880,"Ma'am, you're awake."],[880,992,"I'll go get the doctors."],[1017,1138,"No, no, it's okay."],[1138,1226,"I'm feeling better."],[1313,1388,"Thank you, Lucien."],[1514,1626,"I'm really sorry"],[1626,1797,"about the way I acted earlier."],[1931,2002,"It's okay."],[2035,2081,"It's not."],[2193,2339,"I owe you both an apology."],[2398,2631,"It's not that I don't accept you."],[2631,2727,"I was just surprised."],[2802,2948,"I thought you'd be able to come to me"],[2948,3044,"or something like that."],[3123,3265,"But I guess we all have our secrets,"],[3265,3349,"don't we?"],[3382,3482,"You didn't do anything wrong."],[3507,3557,"Mom."],[3687,3728,"I should have"],[3757,3912,"been braver and told you sooner."],[4012,4091,"I was just scared."],[4129,4208,"No."],[4366,4433,"I was scared that you"],[4433,4562,"were going to look at me differently"],[4562,4637,"or that you"],[4696,4875,"might treat me differently."],[4921,5242,"I could never be disappointed in you."],[5242,5317,"I was scared."],[5363,5568,"You know, after Chris' dad died,"],[5568,5726,"it was just the two of us."],[5784,5964,"And I guess I just held on too tight."],[6043,6156,"And that wasn't fair to you."],[6260,6368,"Or to Lucien."]],"65":[[20,162,"If he makes you happy..."],[258,367,"That's all that matters."],[454,542,"No, Mom."],[729,800,"I'm still me."],[975,1121,"I'm always gonna be your Chris."],[1201,1251,"I know."],[1939,2052,"Thank you, ma'am."],[2990,3065,"Sorry."],[3566,3624,"What's wrong?"],[3687,3878,"It's Ms. Stone."],[3949,4079,"I have to go see her tomorrow morning."],[4133,4191,"I'll go with you."]],"66":[[37,112,"It's already done."],[141,246,"Lucien will be here soon."],[333,437,"Don't worry, Anya."],[1051,1080,"Come in."],[1680,1847,"Your exam scores are back, Lucien."],[1885,1989,"Straight F's again."],[2035,2181,"I'll have to inform your father."],[2243,2293,"Okay, no."],[2293,2377,"That's impossible."],[2419,2460,"Ms. Stone,"],[2498,2602,"there's got to be some mistake here."],[2602,2752,"Lucien's been taking practice exams"],[2752,2873,"with me all week."],[2873,2957,"There's no way that he's"],[2957,3019,"failed all of them."],[3098,3228,"I've already double checked."],[3228,3315,"There's no mistake."],[3770,3858,"Let me guess."],[3962,4145,"This is Anya, isn't it?"],[4220,4275,"What?"]],"67":[[4,183,"This is Anya, isn't it?"],[346,429,"Bingo."],[525,650,"Why are you doing this, Ms. Stone?"],[692,834,"Anya's just Arthur's girlfriend."],[834,938,"They're not even married yet."],[988,1142,"Lucien's his only son."],[1142,1280,"Anybody in their right mind"],[1280,1372,"would bet on Lucien."],[1497,1555,"Only son?"],[1605,1689,"Not for long."],[1689,1768,"Anya's..."],[2097,2168,"Pregnant."],[2185,2277,"Got it."],[2277,2360,"I didn't say anything!"],[2406,2477,"Get out now!"],[2560,2602,"Let's go."],[2873,2994,"You are so fucked."],[3015,3174,"And this time, figuratively."],[4583,4662,"Enter."],[5134,5196,"Principal Parker,"],[5321,5459,"I'm here to report Ms. Eleanor Stone"],[5459,5555,"for taking bribes and"],[5555,5676,"intentionally changing Lucien's"],[5676,5814,"exam scores to fail him."],[6164,6243,"Do you know what you're saying?"]],"68":[[246,321,"I've been tutoring Lucien"],[321,408,"for a while now."],[467,592,"I know how hard he's worked."],[613,746,"I can accept that he doesn't test well,"],[746,850,"but this is not that."],[850,975,"This is sabotage."],[1001,1063,"Don't forget,"],[1063,1201,"I'm the only person that"],[1201,1343,"can keep Chris from getting expelled."],[1368,1568,"Ms. Stone is on my side."],[1618,1693,"I'll take care of this."],[1693,1735,"You can go."],[1876,1968,"Well, how are you going to handle it?"],[2239,2335,"We'll gather evidence"],[2335,2414,"against Ms. Stone."],[2444,2565,"She'll pay for her crimes."],[2565,2665,"She'll get fired from teaching."],[2740,2794,"Satisfied?"],[3003,3086,"I want Lucien's grades."],[3132,3215,"His real scores."],[3361,3399,"Of course."],[3774,3949,"Have all Lucien's exams sent to me."],[3995,4045,"I'm going to look"],[4045,4141,"them over personally."]],"69":[[8,125,"This was your promise?"],[162,333,"This is what I get for trusting you?"],[375,617,"Darling, don't be so hard on him."],[617,658,"Lucien,"],[696,900,"maybe sending him to the military"],[934,1042,"would be for the best."],[1080,1184,"I'm not going."],[1280,1334,"Wait!"],[1355,1418,"Stop!"],[1568,1789,"Mr. Alaric, Anya's been lying to you."],[1951,1993,"Here."],[2156,2256,"Lucien's real test score"],[2256,2419,"graded by the principal himself."],[2569,2602,"He did it."],[2656,2698,"Straight A's."],[2915,2952,"How?"],[3028,3165,"What is the meaning of this?"],[3324,3357,"Ask her."],[3478,3553,"She's the one who"],[3578,3749,"called Ms. Stone to change his grades"],[3799,3928,"because she's pregnant."],[3953,4004,"She wanted Lucien"],[4004,4066,"out of the picture"],[4066,4158,"in order to make way for her"],[4158,4250,"own child's inheritance."],[4300,4387,"How did you know?"]],"70":[[108,371,"I told you I didn't want another child."],[371,546,"Lucien is my only heir."],[579,742,"We are done."],[804,980,"I want you out of my house today."],[1009,1101,"and I never wanna"],[1101,1226,"fucking see you again."],[1430,1580,"And you, Lucien,"],[1647,1860,"this doesn't change a thing."],[1914,2060,"You're still going to the military."],[2398,2473,"Lucien!"],[2660,2731,"Where the hell do you think"],[2731,2773,"you're going?"],[2836,2936,"You walk out that door,"],[3015,3086,"you're cut off."],[3591,3728,"Will you still love me when I'm broke?"],[4016,4170,"Well, I still have my scholarship, so..."],[4237,4333,"I guess I can keep you."],[4408,4504,"You hear that, Dad?"],[4621,4708,"I choose Chris."],[4854,4921,"From now on,"],[4946,5125,"I live for myself and not"],[5125,5213,"for your approval."],[5367,5438,"Lucien!"],[5501,5609,"Lucien!"]],"71":[[421,546,"Your dad's getting kind of desperate."],[567,646,"He even tried calling me."],[684,817,"He wants to have dinner this weekend."],[817,888,"Do you want to go?"],[1051,1184,"Looks like he came around to you."],[1313,1393,"Sure."],[1530,1580,"We'll go together."],[1705,1743,"Hey."],[1793,1956,"Uh, can I get your number?"],[2002,2060,"Huh..."],[2127,2193,"Sorry."],[2277,2331,"He's taken."],[2448,2540,"Booked for life."],[2619,2706,"Oh, sorry."],[2706,2819,"I didn't know he already"],[2819,2898,"had a girlfriend."],[3019,3078,"Well who said anything"],[3078,3144,"about a girl?"]]}