{"1":[[796,880,"Where's Dorian?"],[967,1059,"That baby's coming any"],[1059,1130,"second now."],[1188,1276,"What kind of husband"],[1297,1463,"disappears in a moment like this?"],[1463,1559,"He'll be here soon."],[1651,1764,"He's going to get his mom."],[1822,2022,"Seriously, thank you, Anita,"],[2085,2218,"for, for being here."],[2248,2402,"I'm your best friend."],[2464,2665,"I wouldn't miss this for the world."],[2823,2944,"I'm gonna go grab the doctor."],[4158,4245,"Chairman Astor,"],[4291,4425,"this gift just came in for you."],[4446,4642,"The CEO of Cartelier."],[4704,4825,"It's a custom Cheetah Brooch."],[4892,5092,"It's the purest ruby on the planet."],[5271,5342,"Not bad."],[6548,6606,"Dad."],[6744,6877,"I'm about to have the baby."],[6948,7002,"What?"],[7190,7265,"Iris!"],[7399,7457,"What?"],[7499,7711,"Are you really walking out"],[7711,7820,"on your family?"],[7820,7887,"Dad!"],[7982,8187,"You were wrong about Dorian, okay?"],[8220,8433,"He doesn't care about money!"],[8458,8579,"He loves me!"],[8629,8808,"And I choose him!"],[8896,9159,"If you walk through that gate,"],[9159,9434,"you are no longer my daughter."],[9459,9559,"And you'll have nothing to do"],[9559,9763,"with the Astor name ever again."],[10218,10347,"Even if you never call me"],[10347,10472,"your daughter again."],[10527,10652,"I'm still your child."],[10919,11052,"And I love you, Dad."],[11140,11265,"I always will."],[11407,11524,"But I choose him."],[11561,11736,"Because our love is real, Dad."],[11899,12070,"And I'm gonna prove it to you."],[13500,13613,"Congratulations, sir."],[13655,13772,"You're gonna be a grandfather."],[14139,14443,"Dorian still rubs me the wrong way."],[14481,14585,"He barely looks like"],[14585,14752,"he could take care of a goldfish,"],[14752,14864,"let alone a family."],[14969,15177,"Still, Iris chose him."],[15248,15390,"And now they're about to have"],[15390,15457,"a baby."],[15557,15669,"Maybe it's time I gave the guy"],[15669,15765,"a chance."],[15932,16128,"Get the finest gifts money can buy."],[16174,16278,"I want my grandchild"],[16278,16445,"to enter the world like royalty."],[16812,16925,"Guess I'll finally see"],[16925,17175,"if Dorian's truly worthy of Iris."],[17271,17680,"If not, he'll have me to answer to."]],"2":[[1685,1755,"What's wrong?"],[1780,1901,"Mr. Holland, what's wrong?"],[1918,1972,"What happened?"],[1972,2018,"You sounded like"],[2018,2152,"you were having a heart attack."],[2152,2223,"Hurry."],[2223,2377,"I need to get the Poltimore Tiara"],[2377,2460,"from the vault."],[2477,2694,"I need it delivered to Miss Astor ASAP."],[2702,2861,"You're giving that away?"],[2882,3044,"I just got word that Miss Astor,"],[3044,3169,"the richest heiress on earth,"],[3169,3278,"is having a baby today."],[3307,3386,"We must congratulate her"],[3386,3536,"with the most spectacular gift."],[3566,3695,"If we pull this off,"],[3695,3778,"we can have a partnership"],[3778,3991,"with the Astor Dominion."],[4012,4220,"We're talking billions, Jessica!"],[4220,4300,"Billions!"],[4300,4387,"Now go!"],[4387,4441,"Run."],[4441,4496,"Now."],[6101,6302,"A private hospital?"],[6327,6506,"Doesn't it cost like two grand a night"],[6506,6627,"just to stay here?"],[6644,6819,"She's burning through your money"],[6819,6965,"like it grows on trees."],[6998,7140,"Mom, please don't get worked up."],[7169,7386,"The doctor said Iris has placenta previa."],[7403,7494,"It's serious."],[7528,7657,"There's a real risk of bleeding."],[7699,7924,"Oh, Dorian."],[7941,8137,"Your wife's just being dramatic."],[8153,8283,"And who does she think she is?"],[8283,8445,"Some royal heiress or something?"],[8512,8696,"This is why we're bleeding money."],[8725,9000,"If you let her stay in a fancy hospital"],[9000,9121,"like this today,"],[9121,9234,"tomorrow,"],[9234,9413,"she's gonna want a live-in nanny."],[9434,9526,"And then what?"],[9526,9647,"A private chef?"],[9680,9780,"A butler?"],[9838,9951,"What do I do, Mom?"],[10018,10080,"You haven't paid"],[10080,10210,"the hospital bill yet, right?"],[10226,10343,"No, not yet."],[10381,10431,"Good."],[10456,10589,"When we get inside,"],[10614,10873,"stay quiet and follow my lead."],[10915,10985,"Okay, Mom."],[10985,11094,"Just remember,"],[11111,11378,"no other woman will ever love you"],[11378,11557,"as much as Mommy does."],[11582,11836,"Oh, my precious baby."],[12057,12324,"Iris, placenta previa is serious."],[12362,12541,"You need to rest and take it easy."],[12541,12633,"We've got you covered"],[12633,12725,"around the clock."],[12737,12879,"We'll do everything we can"],[12879,13079,"to keep you and your little one safe."],[13154,13213,"Thank you."],[13617,13780,"Mommy and Daddy are so excited"],[13780,13855,"to meet you."],[13947,14139,"You are going to be the happiest baby"],[14139,14318,"in the entire planet, I promise."],[14818,15015,"Tessa, Dorian, you're here."]],"3":[[29,183,"Look at this room."],[279,425,"This isn't a hospital."],[425,592,"She's treating labor"],[592,771,"like it's a spa retreat."],[804,946,"Do you know that"],[975,1163,"my friend's daughter-in-laws"],[1163,1334,"gave birth at local clinics"],[1372,1764,"and it only cost three grand total."],[1797,1989,"But your wife is spending"],[1989,2168,"two grand a night."],[2289,2339,"I don't know, Mom."],[2339,2456,"I think she's just trying to"],[2456,2569,"do what's best for the baby."],[2690,2815,"Oh, Dorian."],[2865,3023,"Don't be stupid."],[3111,3324,"This has nothing to do with the baby."],[3370,3470,"She's flaunting."],[3524,3707,"She just wants to tell her friends that"],[3707,3958,"she gave birth in some luxury suite."],[3983,4108,"I warned you,"],[4145,4433,"she is not as sweet as she seems."],[4521,4679,"If you keep letting her"],[4679,4863,"burn through your money like this,"],[4875,4967,"one day you're gonna"],[4967,5246,"wake up with nothing left."],[5405,5513,"Then what do I do?"],[5638,5834,"Don't worry, my sweet boy."],[5880,6064,"Let me handle everything, okay?"],[6139,6197,"Okay."],[6256,6327,"Let's go."],[6448,6552,"Tessa, Dorian."],[6589,6681,"What were you guys talking about?"],[6681,6794,"Oh, actually, um,"],[6835,6994,"the doctor said the bill was due."],[6994,7057,"Do you think you could"],[7057,7132,"take care of that?"],[7303,7561,"Iris, do you have any idea"],[7561,7699,"what all this costs?"],[7699,8012,"A room like this runs 50, 60 grand."],[8049,8316,"Dorian busts his ass every day"],[8316,8458,"to support this family."],[8479,8821,"Stop blowing through his savings"],[8846,8954,"and leave this hospital"],[8954,9050,"immediately."],[9359,9405,"What-"]],"4":[[33,58,"What?"],[58,166,"Leave the hospital?"],[183,396,"A good wife doesn't rack up"],[396,508,"mountains of debt"],[508,696,"before the baby's even born."],[717,900,"Could you just think about Dorian"],[900,1013,"for once?"],[1272,1497,"Tessa, I love him."],[1622,1793,"I'm not wasting anyone's money."],[1814,1926,"I chose this hospital"],[1926,2064,"because I have placentia previa."],[2102,2185,"I could bleed out."],[2202,2314,"And it's the only hospital"],[2314,2373,"that is equipped"],[2373,2510,"for that kind of emergency."],[2569,2731,"I'm not here for comfort."],[2844,2990,"I'm here to protect the baby"],[2990,3107,"and make sure that they're safe."],[3232,3557,"Dorian, I know how hard you work."],[3670,3899,"Just let me stay one night"],[3899,4037,"and just to make sure"],[4037,4133,"the baby is stable"],[4133,4308,"and then we can transfer, I promise."],[4358,4621,"Son, don't fall for that."],[4621,4713,"We don't even know"],[4713,4892,"if the baby's coming tonight."],[4934,5105,"If she drags this out,"],[5105,5246,"it's gonna be thousands more"],[5246,5330,"down the drain."],[5347,5455,"Tessa, this is between"],[5455,5555,"my husband and I."],[5609,5768,"Please just give us a moment."],[5768,5876,"I'm his mother."],[5918,6139,"Dorian's opinion is my opinion."],[6139,6227,"Now, come on."],[6252,6493,"We are leaving this hospital."],[6548,6598,"Ow!"],[6861,6923,"Dorian!"]],"5":[[62,116,"Ah!"],[116,183,"Dorian!"],[446,763,"Iris, let's just go to a local clinic."],[779,934,"Raising a kid is expensive."],[934,1059,"We need to save where we can."],[1084,1138,"That's right."],[1192,1376,"We're not the bad guys here."],[1384,1539,"Tons of women give birth"],[1539,1680,"at local hospitals."],[1701,2085,"But you are a greedy little leech."],[2102,2210,"And I'm not letting you"],[2210,2348,"bleed my son dry."],[2381,2519,"What do you think he is?"],[2565,2711,"Your personal ATM?"],[2761,2827,"I'm not trying to"],[2827,2936,"waste anyone's money."],[3007,3186,"I have a low-lying placenta."],[3219,3374,"And if something goes wrong,"],[3428,3549,"the baby could die."],[3636,3791,"Don't go soft on her"],[3791,3916,"and let her play you."],[3924,4049,"Every pregnant woman"],[4049,4200,"has complications."],[4220,4350,"Just because it's risky"],[4350,4496,"doesn't mean it's gonna happen."],[4512,4637,"If you cave now,"],[4646,4808,"she will bleed you dry"],[4808,4963,"for the rest of your life."],[5030,5113,"You're right, Mom."],[5196,5326,"Thanks for always having my back."],[5522,5647,"I'm here for you."],[5663,5897,"Unlike certain people,"],[5897,6047,"I will never"],[6047,6264,"let someone make a fool of you."],[6335,6510,"Iris, if you want to"],[6510,6635,"stay in this hospital,"],[6673,6740,"fine."],[6740,6965,"But you're gonna pay for it yourself."],[7002,7119,"I'm not letting"],[7119,7444,"a greedy little wife like you"],[7469,7628,"waste one more cent"],[7628,7757,"of my son's money."],[7966,8062,"Something's wrong with me."],[8166,8295,"Can you call the doctor, please?"],[8299,8345,"No!"],[8420,8633,"Do not take one more step"],[8650,8896,"until she agrees to pay for it herself."]],"6":[[2152,2293,"I'll see Iris first."],[2394,2477,"You wait here."],[2727,2923,"Do not take one more step"],[2940,3190,"until she agrees to pay for it herself."],[3261,3424,"Dorian, what happened to you?"],[3461,3549,"Okay."],[3599,3753,"Well, then, I'll pay for it."],[4195,4266,"Hi."],[4316,4404,"Could you settle the bill"],[4404,4496,"with this, please?"],[4546,4617,"Thank you."],[4675,4758,"See?"],[4788,5021,"She had the cash all along."],[5142,5313,"Women like her,"],[5313,5497,"always pretend that they're broke"],[5497,5697,"until it's time to spend your money."],[5709,5910,"If she doesn't feel the pressure now,"],[5939,6072,"she's never gonna know"],[6072,6151,"what it takes"],[6151,6293,"to keep a family afloat."],[6293,6356,"You're right, Mom."],[6377,6456,"You always are."],[6519,6635,"You really are the only person"],[6635,6777,"that's truly looking out for me."],[6777,6861,"That's right."],[6894,7044,"My precious baby boy."],[7253,7336,"I'm sorry, Ma'am."],[7336,7465,"Your card was declined."],[7499,7686,"You're short about $20,000."],[7778,7878,"If you can't pay,"],[7949,8070,"we have to discharge you."],[8575,8737,"This is everything I have left."],[8821,8975,"Is she really broke?"],[9000,9109,"Doesn't make any sense."],[9175,9263,"With her three jobs,"],[9263,9359,"she should have saved"],[9359,9480,"at least 20 grand."],[9505,9584,"Yeah, well that's because"],[9584,9747,"I cover all the household bills."],[9780,9905,"And ever since I got pregnant,"],[9930,10001,"everything has been"],[10001,10105,"going to prenatal stuff."],[10105,10239,"Vitamins, supplements,"],[10239,10335,"hospital visits."],[10335,10481,"I mean, it all adds up Dorian."],[10564,10773,"What on earth has she been through"],[10773,10915,"these past three years?"],[10973,11081,"Dorian, can you just..."],[11211,11361,"Please, just consider it a loan."],[11361,11407,"Just,"],[11515,11661,"I swear I'll pay you back."],[11695,11886,"Absolutely not."],[11903,12032,"Don't fall for this."],[12070,12458,"Every wife stashes emergency cash."],[12458,12637,"Did you see how she pulled that card out"],[12637,12746,"like it was nothing?"],[12746,12883,"Do you think it's her only one?"],[12921,13096,"She's still hiding money."],[13154,13259,"I know she is."]],"7":[[33,145,"Dorian, please."],[166,354,"Please just help me pay the 20 grand."],[354,454,"I swear"],[454,575,"I will pay you back."],[638,821,"Don't fall for her act."],[863,1017,"I know what you're playing at."],[1034,1209,"You're trying to squeeze money"],[1209,1317,"out of Dorian."],[1343,1547,"And then you're just gonna run away"],[1559,1710,"without paying a cent."],[1768,1901,"How could you say that?"],[2302,2360,"Okay."],[2469,2556,"Okay, Dorian."],[2602,2786,"I think something's wrong with the baby."],[2836,2986,"The baby's in trouble."],[2994,3186,"You're not fooling anyone."],[3207,3382,"If you're really so broke,"],[3420,3624,"why are you insisting on staying at"],[3624,3828,"such a luxury hospital?"],[3853,4116,"You've already drained him dry."],[4170,4333,"What more do you want from him?"],[4375,4437,"Dorian."],[4487,4546,"Dorian, please."],[4546,4617,"I am begging you."],[4617,4738,"Please just say something."],[4829,5034,"Don't fall for her drama."],[5050,5171,"You have two choices."],[5188,5334,"Either we can transfer her"],[5334,5467,"to a cheaper hospital,"],[5488,5663,"or she can pay for everything herself."],[5718,6010,"And if she doesn't want to do either,"],[6051,6227,"then we don't want the baby anyway."],[6348,6398,"Okay."],[6510,6614,"I'll listen to you, Mom."]],"8":[[8,62,"Okay."],[166,262,"I'll listen to you, Mom."],[333,454,"Dorian, I gave up my family"],[454,533,"to be with you."],[650,696,"And when you"],[696,775,"started your business,"],[775,900,"I supported you."],[930,1142,"I gave you everything that I have."],[1288,1422,"I mean, I paid for the mortgage"],[1422,1518,"and the car payments."],[1518,1672,"I have nothing left."],[1672,2052,"Please save us the sob story."],[2052,2202,"You ruined your own ties"],[2202,2310,"with your family."],[2310,2489,"Don't blame Dorian for that."],[2515,2798,"If you want to stay here, then fine."],[2848,2986,"Pay for it yourself."],[3028,3174,"But the Bates family"],[3174,3399,"is not paying a single cent."],[3728,3828,"Dorian, it hurts."],[3933,4033,"Please, could I just,"],[4091,4250,"could I just see a doctor first?"],[4250,4391,"Oh my God, Iris."],[4391,4533,"Stop acting like the victim."],[4587,4708,"Now it all makes sense."],[4771,4900,"You stayed here to show off."],[4934,5071,"When did you become so shallow?"],[5226,5338,"You think I'm shallow?"],[5417,5538,"Well, aren't you?"],[5555,5659,"If you were really"],[5659,5830,"worried about the baby,"],[5893,6056,"why wouldn't you take out a loan?"],[6081,6243,"This is 2025."],[6264,6406,"There's apps for that."],[6406,6581,"You want me to take out"],[6581,6723,"a highly predatory,"],[6781,6969,"a high-interest loan to give birth?"],[7011,7165,"It's gonna be your grandchild."],[7207,7411,"I mean, how could you be so heartless?"],[7449,7703,"Are you really guilt-tripping me"],[7703,7782,"right now?"],[7824,7895,"You're the one"],[7895,8141,"refusing to pay for your own baby!"],[8183,8341,"But, in my day, we didn't need"],[8341,8562,"luxury hospitals to give birth."],[8562,8817,"We gave birth at home for free."],[8879,9079,"I don't know what my son saw"],[9079,9242,"in a gold digger like you."],[9271,9376,"This is ridiculous."],[9455,9676,"I didn't marry Dorian for the money."],[9680,9909,"Stop lying!"],[9914,10189,"If you weren't after our money,"],[10235,10368,"why haven't you taken out"],[10368,10447,"the loan yet?"],[10506,10631,"Quit stalling."],[10935,11040,"God, it hurts!"],[11353,11440,"Bastards!"],[11453,11582,"How dare you treat"],[11582,11770,"my precious daughter like this?"]],"9":[[229,329,"A loan?"],[358,446,"Are you seriously"],[446,588,"making Iris take out a loan?"],[625,759,"Oh my God, Iris!"],[900,988,"Are you okay?"],[1197,1267,"I got you."],[1313,1363,"Okay?"],[1455,1589,"What is wrong with you?"],[1634,1739,"She's your wife!"],[1739,1876,"She's about to give birth!"],[1885,1997,"This is a family matter."],[1997,2089,"Stay out of it."],[2114,2214,"Stay out of it?"],[2243,2335,"You expect me"],[2335,2469,"to watch you and your mom"],[2469,2623,"abuse my best friend?"],[2752,2815,"Hold on."],[2927,2990,"Okay."],[3044,3103,"You're okay."],[3211,3370,"Nurse, nurse, please check her."],[3370,3499,"She's in so much pain."],[3532,3653,"Is the baby coming?"],[3741,3862,"She's in early labor."],[3908,4045,"Internal bleeding started."],[4045,4154,"We have to admit her now."],[4154,4254,"Sir, you have to pay"],[4258,4387,"the hospital bill immediately."],[4412,4567,"You haven't paid the bill yet?"],[4604,4704,"That's why you want her"],[4704,4825,"to take out a loan?"],[4888,5075,"She's about to give birth to your child"],[5075,5255,"and you want her to pay by herself?"],[5284,5467,"What kind of man does that?"],[5513,5714,"Thank god, at least my baby girl"],[5714,5910,"has a good friend by her side."],[5918,6064,"Shut your mouth!"],[6110,6306,"This has nothing to do with you."],[6335,6514,"Get your shit together."],[6514,6660,"Doctor says she's high risk."],[6660,6773,"This isn't about luxury."],[6773,6865,"It's about survival."],[6865,6911,"She's here"],[6911,7107,"to keep herself and the baby alive."],[7107,7215,"What the hell do you know?"],[7240,7286,"It's not like"],[7286,7465,"you've ever given birth before."],[7465,7607,"Exactly."],[7620,7832,"You're just a loud mouth that thinks"],[7832,8033,"that screaming makes you right."],[8066,8199,"You're just like your friend."],[8199,8304,"A gold digger."],[8324,8470,"If you care so much,"],[8483,8554,"why don't you pay"],[8554,8729,"the damn 20 grand yourself?"],[8758,8967,"We're not paying a cent."],[9004,9217,"She can give birth on the floor"],[9217,9321,"if she wants."],[9346,9547,"What's the worst that can happen?"],[9634,9926,"You two are unbelievable!"],[10130,10201,"Touch my mom"],[10201,10251,"and there's more"],[10251,10339,"where that came from,"],[10364,10527,"even if you are Iris' friend."]],"10":[[20,79,"Touch my mom"],[79,133,"and there's more"],[133,225,"where that came from."],[254,308,"Anita?"],[354,471,"Don't fight them, okay?"],[550,646,"Dorian,"],[684,784,"just don't hurt her."],[829,959,"I will take out the loan."],[1084,1267,"Couldn't win with your words,"],[1267,1443,"so you had to use your fists, huh?"],[1476,1572,"How classy."],[1589,1689,"I'm so sorry, Mom."],[1714,1785,"Are you alright?"],[2118,2227,"I'll be okay."],[2264,2369,"For your sake."],[2623,2711,"You've never been"],[2711,2844,"a good daughter-in-law."],[2844,2957,"Your parents didn't even"],[2957,3115,"send a dime for the wedding."],[3182,3328,"Do you know that"],[3328,3532,"when Mrs. Smith's son got married,"],[3570,3853,"her in-law sent 50 grand cash?"],[3878,4095,"And they gave her a brand new Tesla!"],[4129,4337,"Not only did you show up"],[4337,4421,"with nothing,"],[4450,4546,"now you're trying to"],[4546,4721,"empty his bank account too."],[4800,4984,"I'm sorry, baby."],[5059,5238,"You deserve so much better than that."],[5684,5822,"Nurse, could you please"],[5822,5897,"settle the bill with this"],[5897,5972,"quickly, please?"],[6060,6122,"See?"],[6172,6302,"Was it that hard?"],[6327,6452,"That's what it means to be"],[6452,6581,"part of the Bates family."],[6648,6790,"But you're not off the hook yet."],[6810,6898,"What else could you"],[6898,7069,"possibly want from me?"],[7098,7353,"Well, you're still married to Dorian,"],[7353,7503,"so he could be responsible"],[7503,7595,"for your debt."],[7636,7732,"But you took out the loan"],[7732,7845,"on your own, right?"],[7866,8049,"You should be the one to pay it back."],[8078,8245,"So here's what's gonna happen."],[8283,8641,"You're gonna sign a simple statement"],[8641,8829,"that says that Dorian"],[8829,9034,"is not responsible for any of it."],[9150,9321,"What the hell did you just say?"]],"11":[[12,129,"I said,"],[154,450,"I want you to sign this disclaimer"],[450,613,"that exempts Dorian"],[613,821,"from any liability for your debt."],[855,950,"No way!"],[996,1222,"I am not just having this baby alone."],[1222,1438,"I mean, this is Dorian's child too!"],[1468,1572,"And more importantly,"],[1572,1735,"this child isn't yours!"],[1776,1939,"The financial decisions are"],[1943,2264,"solely between my husband and I."],[2268,2560,"How dare you raise your voice to me?"],[2627,2811,"Do you think you're hot shit"],[2811,3019,"just because Dorian knocked you up?"],[3061,3190,"You are nothing"],[3190,3520,"but a disrespectful little brat"],[3520,3653,"speaking to your mother-in-law"],[3653,3716,"that way."],[3737,3883,"Iris, seriously,"],[3883,3970,"you should treat my mother"],[3970,4054,"with more respect."],[4054,4204,"Are you hearing this?"],[4204,4346,"I was just standing here"],[4346,4471,"sticking up for you"],[4471,4671,"and then she gives me this attitude."],[4696,4863,"When she pushes the baby out,"],[4863,4963,"you're gonna need to"],[4963,5130,"put your foot down with her."],[5338,5647,"Iris, you've already taken out the loan."],[5672,5897,"So why are you dragging your feet"],[5897,6056,"signing the disclaimer?"],[6081,6231,"Sign the damn disclaimer!"],[6264,6514,"You two are unbelievable."],[6539,6781,"This baby has your family's DNA."],[6819,7011,"Refusing financial liability"],[7015,7123,"is one thing."],[7123,7386,"But putting her health at risk"],[7386,7515,"right before birth?"],[7561,7703,"It's diabolical!"],[7732,7920,"Like my mom said, all pregnancies"],[7920,8045,"come with some level of risk."],[8045,8116,"But you don't see"],[8116,8216,"every pregnant woman"],[8216,8370,"spending a fortune, do you?"],[8391,8479,"If Iris wants to"],[8479,8662,"stay in this plush-ass hospital,"],[8687,8846,"then she can cough up the cash for it."],[8867,8925,"Bastard!"],[9029,9096,"Oh!"],[9167,9230,"Don't fight them,"],[9230,9321,"it's not worth it, okay?"],[9476,9563,"Dorian,"],[9676,9838,"I will sign the disclaimer."],[9872,10039,"But you have to promise me"],[10176,10368,"that you will not tell my dad."],[10460,10673,"I don't want him to worry about me."],[10731,10823,"It took a long time"],[10823,11086,"to get him to accept you."],[11123,11315,"And when this baby is born,"],[11344,11557,"I just want us to have a complete family."],[11690,11820,"What does Iris's dad do?"],[11828,11920,"I'm not sure."],[11920,12112,"I've only met him once."],[12166,12316,"Just seemed like your average Joe."],[12354,12508,"So he's just a nobody?"],[12696,12867,"Accept Dorian?"],[12921,13000,"Who the hell"],[13000,13179,"does your father think he is?"],[13179,13363,"Some billionaire CEO."],[13492,13759,"He's just a broke-ass bum"],[13759,13863,"who didn't even go to"],[13863,13993,"his daughter's wedding."],[14014,14356,"He doesn't give a damn about you."],[14443,14656,"He never even loved you anyways."]],"12":[[179,262,"Dad?"],[454,571,"You're already here."],[671,754,"Yes, baby."],[880,975,"Daddy's here now."],[1430,1576,"If I got here any later,"],[1639,1755,"God knows what these two"],[1755,1856,"would have done to you."],[1918,2139,"So, you're Iris's father."],[2198,2348,"You got here just in time."],[2377,2681,"As her father, I demand that you"],[2681,2948,"sign this disclaimer on her behalf."],[3219,3445,"Tessa, you leave my Dad out of this!"],[3465,3645,"Oh my God, Dorian!"],[3645,3866,"Your wife just won't stop yelling at me!"],[3866,4054,"Iris, if you can't start showing my mom"],[4054,4183,"some basic respect,"],[4183,4354,"I'm gonna have to stop playing nice."],[4375,4592,"Iris, is this the man"],[4650,4867,"you gave up everything for?"],[4921,5071,"Dorian is a wonderful man."],[5188,5309,"But his mom is gaslighting him."],[5309,5447,"I mean, he can't see"],[5522,5597,"how severe"],[5597,5714,"the situation is with the baby."],[5714,5910,"Iris, all she's trying to do is help."],[5910,6051,"If she wanted to help,"],[6081,6235,"then she would be here causing"],[6235,6322,"a scene!"],[6556,6710,"Oh, Mr. Astor."],[6731,6881,"If you're so concerned,"],[6915,7182,"why don't you sign the form"],[7182,7323,"and take on your daughter's"],[7323,7444,"20 grand of debt?"],[7490,7695,"Mr. Astor, don't listen to her."],[7716,7828,"First, she forced Iris"],[7828,7912,"to take out a loan"],[7912,8045,"with a crazy high interest rate,"],[8045,8245,"and now she wants you to pay it back."],[8245,8375,"She's way out of line."],[8383,8546,"Well, Dorian sure as hell"],[8546,8675,"isn't gonna pay it!"],[8675,8967,"Iris' debt has shit to do with him!"],[8967,9134,"I'm just trying for everyone"],[9134,9321,"to stop ganging up on my boy."],[9363,9488,"Anita, keep digging your nose"],[9488,9597,"into our family's business"],[9597,9672,"and I'll have security"],[9672,9780,"drag your ass out."],[10335,10769,"Iris, is this the true love"],[10894,11152,"you threw your whole life away for?"],[11261,11378,"And we are gonna be"],[11524,11703,"living happily ever after,"],[11728,11928,"even if we have absolutely nothing."],[11957,12132,"Because our love is real, Dad."],[12208,12374,"And I'm gonna prove it to you."]],"13":[[4,196,"Have you got a screw loose?"],[196,458,"You can't have true love without money."],[458,734,"This is real life, not some fairy tale."],[746,925,"Now quit stalling"],[925,1172,"and sign the damn disclaimer!"],[1192,1388,"Your mom is making my dad"],[1409,1514,"sign this disclaimer"],[1514,1730,"and you were just gonna stand there?"],[1730,1897,"Iris, all I've ever asked is that"],[1897,1976,"you be sympathetic"],[1976,2122,"to my financial constraints"],[2122,2256,"and not be wasteful with money."],[2264,2377,"How is that still so hard"],[2377,2473,"for you to understand?"],[2569,2844,"I can't believe I'm about to"],[2844,3132,"sign off on a measly 20 thousand."],[3186,3319,"Word gets out,"],[3319,3490,"I'll be the laughingstock"],[3490,3666,"of every boardroom in town."],[3866,4216,"Iris, if this is really"],[4241,4433,"the happily ever after you want,"],[4458,4550,"I'll do it."],[4575,4708,"For you and the baby."]],"14":[[154,200,"No!"],[475,575,"Consider this contract"],[575,667,"null and void."],[1484,1676,"I gave you an out"],[1701,1843,"and this is how you react?"],[1868,2143,"You are leaving this hospital right now."],[2143,2381,"I don't care where that baby is born,"],[2406,2644,"but it sure as hell is not gonna be here."],[2644,2806,"Just shut up!"],[3111,3340,"This baby is between Dorian and I,"],[3357,3582,"so stop getting in-between us!"],[3582,3916,"You are one monstrous disgrace"],[3916,4037,"of a woman."],[4162,4325,"What did you just call me?"],[4350,4487,"A disgrace."],[4542,4892,"Dorian, I stood up for you"],[4934,5084,"through everything!"],[5167,5334,"When you, you wanted to"],[5334,5438,"chase your dreams"],[5438,5630,"and start your business,"],[5630,5910,"I gave you all of my savings"],[5910,6452,"and now, now I swallow my pride"],[6452,6756,"and I take out this, this predatory loan"],[6756,6827,"while,"],[6898,7086,"because you, you don't even"],[7086,7140,"want to pay"],[7140,7428,"for the birth of your own child!"],[7457,7624,"And now you're asking my dad"],[7624,7953,"to sign this bullshit disclaimer!"],[7982,8395,"Dorian, you, you should be ashamed"],[8395,8487,"of yourself."],[8529,8696,"Iris, I was not trying to-"],[8696,8767,"Dorian,"],[8783,8946,"don't fall for her act."],[9000,9492,"She is just a spoiled, materialistic snob"],[9492,9655,"who insists on giving birth"],[9655,9905,"in the most expensive hospital."],[9922,9984,"You're right, Mom."],[10043,10368,"Iris, stop acting like the victim."],[10385,10639,"You chose this place to show off."],[10664,10735,"Trying to make yourself"],[10735,10956,"look rich and important."],[10956,11106,"Look, if you don't want to"],[11106,11286,"sign the disclaimer, fine,"],[11286,11423,"but don't expect any help from me"],[11423,11524,"when the baby comes."],[11549,11615,"So,"],[11832,12078,"you would turn your back on your baby"],[12270,12387,"because of money?"],[12558,12612,"Okay."],[12733,12787,"Fine."],[13029,13254,"Then I will raise this baby on my own."]],"15":[[29,145,"Dorian,"],[145,254,"I want a divorce."],[2281,2360,"Iris."],[2448,2640,"Iris, stop."],[2686,2798,"What do you mean you want a divorce?"],[2798,2907,"Do you not love me anymore?"],[3169,3294,"I feel like I should be asking"],[3294,3449,"if you ever really loved me."],[3486,3620,"Dorian, what were you doing in there"],[3620,3770,"when your control freak of a mother"],[3770,3891,"was harassing me,"],[3908,3999,"and forcing my dad"],[3999,4124,"to sign the disclaimer?"],[4124,4195,"I told you not to"],[4195,4312,"talk about my mom like that."],[4325,4483,"All she's trying to do is help."],[4508,4650,"Well, if that is what you're thinking, then"],[4650,4775,"you should just live with your mom"],[4775,4900,"for the rest of your life."],[4900,5163,"Iris, have you ever actually"],[5163,5280,"looked in the mirror?"],[5338,5526,"You're trash."],[5597,5784,"And trash doesn't get to"],[5784,6022,"talk to my son like that."],[6022,6197,"Don't touch me with your filthy hands."],[6331,6410,"Dorian!"],[6423,6548,"At first, she was just"],[6548,6694,"spouting threats at me."],[6727,6806,"And now,"],[6848,7161,"she's actually flat out assaulting me!"],[7198,7419,"You're a complete psycho!"],[7440,7620,"Iris, did you just push my mom?"],[7678,7749,"I mean, you're acting like"],[7749,7878,"a fucking lunatic."],[7878,8008,"You're just gonna pin this on me"],[8008,8162,"because I'm psycho?"],[8199,8721,"Iris, I gave you sound financial advice"],[8721,8929,"out of the kindness of my own heart."],[8929,9117,"And instead of being grateful,"],[9138,9275,"you attack me."],[9292,9430,"Is that not exactly"],[9430,9659,"what a psycho would do?"],[9659,9722,"No."],[9826,9926,"It's not."],[9976,10072,"But this is."],[10435,10614,"You bitch!"],[10652,10852,"How dare you fucking hit me?"],[10877,11052,"I'm gonna fucking kill you."],[11244,11394,"Touch my daughter again"],[11394,11503,"and you're dead!"]],"16":[[79,346,"Dorian, they're ganging up on me."],[346,437,"They're trying to beat up"],[437,583,"your poor old mother."],[608,813,"Iris, I was blind"],[813,925,"to marry someone like you."],[925,1121,"No, Dorian, I was the blind one."],[1197,1280,"I was the one"],[1280,1388,"who abandoned my family"],[1388,1593,"for a scumbag like you!"],[1639,1755,"You know, I really thought"],[1755,1881,"that you were different."],[1947,2189,"I thought that you were a kinder man,"],[2223,2456,"a man who didn't care about money."],[2456,2665,"A man who truly loved me."],[2706,3028,"But it turns out, you are the type of man"],[3028,3203,"who abandons their own child"],[3203,3407,"over 20,000 dollars"],[3407,3528,"and lets their mother"],[3528,3695,"manipulate my father"],[3724,3974,"into signing a stupid agreement!"],[3974,4371,"Iris, you took out the loan yourself."],[4396,4550,"Give me one good reason"],[4550,4771,"why my son should be responsible"],[4771,4904,"for your debt."],[4938,5263,"Honestly, I've never seen anyone"],[5263,5405,"so shameless."],[5463,5597,"You know, my Dorian"],[5597,5805,"was a real catch back then."],[5876,6051,"And out of all the girls"],[6051,6193,"he could have chosen,"],[6222,6606,"he ended up with a useless wife like you."],[6652,6869,"A broke-ass bitch"],[6869,6994,"who couldn't even afford"],[6994,7094,"to pay for the wedding."],[7136,7215,"You know,"],[7215,7394,"since you've married my son,"],[7394,7620,"you've done nothing for our family."],[7628,7857,"I mean, you could barely afford"],[7857,8024,"the mortgage and car payments."],[8037,8124,"You only forked out"],[8124,8295,"a few thousand dollars"],[8295,8400,"when Dorian was trying to"],[8400,8525,"start his own business."],[8558,8771,"And now you are trying to"],[8771,8900,"bleed him dry."],[8921,9071,"His wife covers the mortgage"],[9071,9200,"and the car payments"],[9200,9296,"and she gave him money"],[9296,9396,"to start a business?"],[9401,9526,"That sounds like enough to me."],[9526,9638,"I mean, what more do they"],[9638,9718,"want from her?"],[9776,9851,"They're clearly the ones"],[9851,9964,"bleeding her dry."],[9972,10080,"If I had a wife like that,"],[10093,10185,"I'd be living the dream."],[10185,10264,"Right."],[10264,10335,"That guy's mom"],[10335,10464,"looks super controlling."],[10464,10606,"She's probably trying to drive a wedge"],[10606,10752,"between her son and his wife."],[10769,10994,"What the hell do you idiots know?"],[10994,11098,"I'm just trying to"],[11098,11261,"protect my son's interests."],[11277,11382,"You don't know shit."],[11407,11515,"Unlike some moms,"],[11515,11682,"mine actually cares about me."],[11695,11870,"So shut up and stay out of our business."],[11907,11995,"And you."],[12045,12270,"You didn't even send a dime"],[12270,12483,"when Dorian and Iris got married."],[12525,12716,"And now you show up"],[12716,12925,"empty-handed again today."],[13025,13229,"Who says I came empty-handed?"]],"17":[[16,221,"Who says I came empty-handed?"],[250,404,"Oh, please."],[404,684,"Look at these fake designer clothes."],[734,988,"So my clothes are fake now?"],[1021,1234,"No shit they are."],[1259,1551,"Cartelier is a Parisian"],[1551,1693,"jewelry brand"],[1693,2085,"and you are wearing a blatant counterfeit"],[2085,2227,"of their Cheetah Brooch,"],[2227,2435,"their most iconic item."],[2464,2640,"If everything that you were wearing"],[2640,2727,"were legit,"],[2727,2844,"your outfit would cost"],[2844,3011,"hundreds of thousands of dollars."],[3053,3311,"If you really had the means"],[3311,3549,"to afford top-of-the-line stuff,"],[3549,3899,"why would Iris leave her family"],[3899,4129,"and work three jobs"],[4145,4350,"just to support herself?"],[4400,4525,"My baby girl,"],[4579,4779,"you've been through so much"],[4779,4909,"these last few years."],[4954,5105,"Shut up!"],[5188,5530,"Don't yell at me, you shrew!"],[5559,5801,"Dorian and I get to decide"],[5801,6147,"where and when that baby gets born."],[6268,6502,"Looks like the only way"],[6502,6715,"to get you two to shut up"],[6844,7027,"is to bring out my gifts."],[7428,7615,"Erik, bring the gifts in."],[7761,7820,"Now."],[7916,8174,"You are still keeping up that act?"],[8266,8370,"We're here, boss."],[9492,9826,"Did you hire a group of actors?"],[9968,10080,"Did you really think that"],[10080,10239,"we were gonna fall for this?"],[10276,10422,"Iris, this entire thing started"],[10422,10497,"just because I wanted you"],[10497,10614,"to save a little money."],[10614,10714,"Are you seriously blowing it"],[10714,10856,"this far out of proportion?"],[10890,11019,"No, no, no, sweetie."],[11052,11111,"Leave it."],[11111,11357,"I'm actually dying to see"],[11390,11574,"what luxury gifts"],[11574,11765,"this twenty-grand-in-debt"],[11765,11986,"broke old bum brought with him."]],"18":[[70,179,"Good God!"],[208,392,"I've never seen that much hard cash."],[392,554,"And with this many cases,"],[554,613,"it's gotta be,"],[613,796,"what, seven or eight million?"],[796,875,"No way."],[884,1046,"That's at least 10 mil."],[1109,1255,"This was supposed to be"],[1255,1384,"your wedding gift."],[1430,1626,"You mean this 10 million dollars?"],[1626,1739,"If it's gonna be mine?"],[1822,1906,"Open the rest."],[2861,2927,"These are the gifts"],[2927,3090,"I've prepared for Iris's baby."],[3144,3278,"That's the Pink Star,"],[3278,3499,"the world's most expensive diamond,"],[3524,3645,"along with Bulgari's"],[3645,3841,"classic Emerald Jewel Set."],[3870,4066,"Only the best for my grandchild."],[4124,4379,"Holy shit, the Pink Star Diamond."],[4404,4567,"The jewels in that case are worth"],[4592,4742,"almost 100 million."],[4779,5084,"Those are the deeds to seven mansions,"],[5084,5363,"all worth around 70 million dollars,"],[5384,5605,"because seven is Iris's lucky number."],[5659,5989,"This is my grandchild's"],[5989,6076,"trust fund,"],[6122,6423,"worth over 200 million in assets."],[6506,6706,"I've also arranged for the child"],[6706,7027,"to have one million dollars per month"],[7061,7198,"until they turn 18."]],"19":[[54,187,"200 million dollar trust fund"],[187,350,"for a child that's not even born yet?"],[379,475,"That's crazy."],[517,675,"If you two hadn't decided"],[675,963,"to abuse Iris today,"],[1046,1222,"all of this could have been yours."],[1259,1443,"That's an insane amount of wealth."],[1472,1751,"Man, that guy was so close"],[1751,1926,"to being the luckiest son-in-law"],[1926,2014,"in the world."],[2014,2114,"And him and his mom"],[2114,2277,"were just calling her broke."],[2277,2360,"They burned bridges"],[2360,2481,"with their super rich in-laws"],[2481,2640,"over a little 20 grand."],[2723,2848,"I guess that's what the dude gets"],[2848,3015,"for being such a momma's boy."],[3036,3178,"If his evil mom had just"],[3178,3315,"treated her daughter-in-law"],[3315,3553,"with the minimum bare decency,"],[3582,3670,"she would have all that money"],[3670,3770,"in her pocket right now."],[3803,3916,"It should have been mine."],[4074,4195,"It was all supposed to be mine."]],"20":[[16,241,"You didn't speak a single word"],[254,429,"in Iris's defense today."],[450,650,"If you just stood up for your wife,"],[688,859,"this could have all belonged to you."],[884,1013,"You're supposed to be"],[1034,1180,"my daughter's husband,"],[1180,1359,"my grandchild's father."],[1359,1605,"But you just stood there"],[1643,1818,"while your crazy mother"],[1818,1956,"tormented Iris"],[1989,2218,"and put the baby at risk."],[2256,2610,"You are a goddamn coward!"],[2715,2898,"Mom, look what you've done."],[2898,3003,"This is all your fault."],[3003,3282,"Dorian, don't be rash."],[3303,3395,"Think about it."],[3420,3757,"If Iris really was filthy rich,"],[3757,3983,"why would she need to take out a loan?"],[4024,4404,"Why would she need to work three jobs"],[4421,4571,"just to pay for the wedding?"],[4604,4704,"No!"],[4771,4938,"We're getting played."],[4959,5146,"Iris and her father"],[5146,5321,"are putting on an act."],[5714,5847,"Oh, stay back!"],[5905,6039,"Don't take one more step."],[6197,6260,"What?"],[6260,6477,"You're gonna beat up an old lady"],[6477,6656,"in front of all these witnesses?"],[6748,6948,"You stole from me, okay?"],[6990,7257,"The thief doesn't get to play the victim."],[7411,7728,"You actually had me there, old man."],[7749,7887,"For a second,"],[7903,8170,"I actually thought that you were rich."],[8170,8437,"But look what we have here."],[8437,8758,"A fake Cartelier brooch."],[8758,8842,"It's a fake?"],[8842,9034,"As fake as they come,"],[9067,9238,"my best friend is"],[9238,9588,"Cartelier California's Regional Manager."],[9834,10135,"You see, Cartelier Cheetah Brooches"],[10135,10293,"have red ruby eyes"],[10293,10514,"and black diamond bodies."],[10564,10885,"But yours has white diamonds."],[10885,11269,"It's nothing but a shoddy knockoff."],[11269,11498,"And if this is fake,"],[11561,11861,"then all those other luxury gifts"],[11861,11986,"are fake as well."]],"21":[[41,95,"Wait."],[95,287,"Mom, so you're saying the cash,"],[287,433,"jewelry, even the trust fund,"],[433,525,"they're all fake?"],[542,754,"Don't be silly, Dorian."],[784,1013,"If he really had money,"],[1067,1222,"why would he be wearing"],[1222,1418,"a fake brooch?"],[1526,1618,"That's enough."],[1630,1847,"My best friend Sadie"],[1847,2022,"is Cartelier California's"],[2022,2147,"Regional Manager."],[2185,2331,"I'll just give her a call."],[2331,2502,"Tell her to come down here"],[2502,2723,"to prove that this is a fake."],[2852,3057,"Sadie, it's me."],[3073,3211,"I have someone here"],[3211,3591,"with a blatant fake Cartelier brooch."],[3666,3849,"I need you to come down here"],[3878,4120,"to prove that it's a counterfeit."],[4754,4846,"Well,"],[4942,5063,"the craftsmanship"],[5063,5280,"on this brooch is impeccable,"],[5280,5351,"I must say."],[5384,5459,"However,"],[5484,5701,"we don't make Cheetah Brooches"],[5701,5872,"with a white diamond."],[5910,6231,"Tessa, this is counterfeit."],[6272,6406,"Tell me where you got it"],[6406,6602,"so that I can trace it back to its source."],[6614,6769,"Where do you think?"],[6886,7102,"From Iris's wannabe"],[7102,7311,"rich daddy over there."],[7361,7657,"And, get this, he also showed up"],[7657,7962,"with several million dollars in cash,"],[7962,8179,"property deeds, jewelry."],[8195,8408,"I mean, can you believe this guy?"],[8541,8779,"Well, I'll be damned."],[8975,9154,"I can't believe the nerve of them"],[9154,9334,"to try and pull a fast one"],[9334,9442,"on you like this."],[9463,9651,"I can confidently say"],[9684,9922,"that all of this stuff you see here,"],[9922,10014,"everything,"],[10130,10335,"it's all fake."],[10352,10527,"Fake, you say?"],[10910,11111,"Then let's double check."]],"22":[[863,1238,"Well, must be fake to break that easily."],[1292,1413,"Spit it out."],[1501,1576,"Where did you get"],[1576,1701,"the counterfeit brooch?"],[1739,1997,"Well ma'am, your brand"],[1997,2202,"custom-designed it for me."],[2248,2444,"It's worth over two million dollars."],[2464,2594,"Now that you've destroyed"],[2594,2669,"my brooch,"],[2669,2756,"how do you plan on"],[2756,2890,"compensating me for it?"],[3111,3403,"Wow, Grandpa's gone off his rocker."],[3403,3670,"You are just some broke old geezer"],[3670,3845,"wearing fake jewelry."],[3870,4016,"What are you talking about"],[4016,4137,"compensation?"],[4162,4275,"Let's face facts."],[4287,4625,"I caught you wearing a knockoff"],[4625,4767,"of our brand."],[4792,4934,"And parading around here"],[4934,5088,"with all this fake currency."],[5100,5255,"I'm going to call headquarters"],[5255,5326,"to report you"],[5326,5526,"and then I'm calling the police."],[5572,5780,"Our CEO, Mr. Holland,"],[5780,5943,"is the richest man in the city."],[6014,6214,"You cross him and you're dead."],[6352,6493,"Who's Mr. Holland again?"],[6527,6694,"Sir, Mr. Holland is the one"],[6694,6756,"who gifted you"],[6756,6848,"with the brooch this morning."],[6952,7148,"Give me a break!"],[7178,7461,"Mr. Holland is our CEO."],[7511,7707,"He would never in a million years"],[7707,7966,"give you such a precious gift,"],[7970,8128,"you broke old geezer."],[8170,8404,"Who do you think you are?"],[8437,8646,"The richest fucking man on earth?"]],"23":[[25,287,"You think you can fake it"],[287,408,"until you make it?"],[442,692,"I am going to call headquarters"],[692,763,"to report you"],[763,955,"and then I'm going to call the police."],[955,1101,"You can rot in jail"],[1101,1267,"for selling counterfeit goods."],[1422,1514,"Tessa, dear."],[1543,1672,"Please keep an eye on them"],[1672,1751,"for me, will you?"],[1760,1860,"We cannot let this"],[1860,2060,"family of swindlers escape."],[2060,2164,"They deserve to spend"],[2164,2377,"the rest of their lives behind bars."],[2761,3036,"The 10 million dollars cash."],[3073,3386,"The 200 million dollar trust fund."],[3449,3599,"All fakes."],[3649,3757,"The jig is up."],[3757,3862,"You're nothing"],[3862,4212,"but a couple of low-class crooks."],[4237,4320,"You know what?"],[4371,4733,"It's one thing to buy counterfeit goods,"],[4813,4979,"but forging currency"],[4979,5176,"is a federal offense."],[5176,5447,"I just can't wait for you"],[5447,5655,"to waste away in prison"],[5655,5893,"with your looser daddy."]],"24":[[25,266,"I just can't wait for you"],[266,487,"to waste away in prison"],[487,717,"with your looser daddy."],[813,1080,"Yeah, you're totally right."],[1180,1368,"Just because you say it's fake"],[1368,1572,"definitely means it's fake."],[1668,1818,"Dorian, see?"],[1847,2077,"This is the woman that you married."],[2152,2398,"Nothing but a cheap scammer"],[2398,2523,"who teams up"],[2523,2681,"with her father"],[2719,3007,"to trick us with shoddy fakes."],[3044,3299,"And now that the cat's out of the bag,"],[3319,3495,"they're not even denying it."],[3495,3645,"So this is the real you, Iris?"],[3728,3870,"A woman who enlists her father"],[3870,4008,"to try and scam her own husband?"],[4041,4195,"You never loved me at all, did you?"],[4241,4450,"I bet you orchestrated"],[4450,4537,"this whole charade"],[4537,4675,"just to get your hands on my money."],[4829,4963,"You disgust me, Iris."],[5000,5184,"No, Dorian, you disgust me."],[5284,5413,"God, how did I even end up"],[5413,5618,"with a complete fucking idiot?"],[5643,5860,"How dare you talk about my son"],[5860,5930,"that way?"],[6026,6327,"I can't wait until the cops show up"],[6352,6619,"and throw your sorry ass in jail."],[6619,6798,"Okay, well don't get ahead of yourself."],[6827,6940,"When the cops get here,"],[6940,7086,"they're gonna ask you to compensate"],[7086,7269,"for the brooch that you destroyed."],[7307,7407,"And when they do,"],[7419,7607,"don't come begging us for mercy."]],"25":[[16,166,"Iris, I believed you back then."],[200,325,"I thought you left your family"],[325,417,"because you loved me."],[437,546,"Turns out, you're actually"],[546,642,"just a shameless fraud"],[642,717,"this whole time."],[717,850,"Dorian, could you just,"],[913,1001,"please, just,"],[1071,1263,"use your fricking brain for once."],[1284,1413,"You do not have anything"],[1413,1593,"that is, that is worth stealing"],[1593,1693,"in the first place."],[1751,1864,"I was the one that covered"],[1864,1989,"all of our household bills"],[1989,2093,"and expenses."],[2093,2189,"I was the one that covered"],[2189,2373,"our mortgage and our car."],[2373,2460,"Everything."],[2540,2623,"Actually, you know what?"],[2711,2777,"I'm done."],[2777,3040,"I, I'm, I am tired."],[3040,3178,"And I am exhausted."],[3178,3328,"And I really do not want"],[3328,3516,"to deal with you right now."],[3516,3641,"And so, actually, you know what?"],[3703,3853,"Starting today, Dorian,"],[3953,4074,"you mean nothing to me"],[4216,4337,"and to my child."],[4458,4546,"Let's go, dad."],[4617,4692,"Hey!"],[4717,4838,"Stop right there!"],[4863,5013,"You can get divorced,"],[5013,5130,"but this baby"],[5130,5276,"belongs to our family."],[5276,5534,"And it's not going anywhere."],[5543,5722,"You are out of your mind, let me go!"],[6039,6106,"Iris!"],[6773,6823,"Iris!"]],"26":[[1059,1380,"If anything happens to my daughter,"],[1509,1634,"you'd better believe"],[1689,1906,"I'll send you both to hell!"],[1926,2056,"You think threats"],[2056,2306,"from a down-and-out scammer like you"],[2306,2381,"scares us?"],[2381,2544,"Plus, your daughter's the one"],[2544,2656,"who lost her footing."],[2686,2977,"I swear, if that baby"],[2977,3174,"doesn't make it out of there alive,"],[3174,3328,"I will make sure"],[3328,3557,"that your daughter doesn't either."],[4012,4195,"Iris, stay with me."],[4220,4412,"Iris, the baby is almost here."],[4412,4546,"I need one big push."],[4546,4604,"Let's go."],[5234,5388,"Why is she so quiet?"],[5601,5780,"Why can't I hear her crying?"]],"27":[[108,271,"The baby's heartbeat has stopped."],[287,387,"We need to focus on"],[387,487,"stabilizing the mother."],[721,842,"Oh, no, baby."],[925,1109,"Oh, please don't leave me."],[2540,2761,"Please, God, please save my baby."],[2915,3023,"Mommy's here."],[3040,3190,"Come back, my baby."]],"28":[[54,300,"You just got my daughter"],[325,483,"sent to the ICU!"],[529,763,"I have a mind to kill you right now!"],[779,834,"What?"],[846,1030,"Stay back."],[1030,1146,"What are you gonna do?"],[1172,1359,"Hit me in front of my son?"],[1580,1735,"Stay away from my mom!"],[1735,1835,"The reason the baby"],[1835,2002,"is fighting for its life in the ICU"],[2002,2185,"is because Iris was acting all crazy."],[3257,3432,"The baby's heart has started again!"],[3470,3570,"It's a miracle."],[3670,3757,"She's alive!"],[3795,3924,"Quick, go save the baby."],[4058,4133,"She's okay."],[4166,4237,"She's alive."],[4450,4617,"You heartless monster!"],[4646,4750,"Your wife and child"],[4750,4888,"are in the brink of death in the ICU,"],[4888,5009,"and instead of worrying about them,"],[5009,5096,"you're defending"],[5096,5255,"your piece of shit mom?"],[5342,5501,"What if the baby really dies"],[5501,5593,"because of this?"],[5672,5801,"Would you not have even"],[5801,5985,"the slightest remorse?"],[6047,6235,"I'll be happy if the baby dies."],[6423,6581,"What did you just say?"],[6756,6961,"That baby would end up just like its mom."],[6986,7223,"Another greedy, lying con artist."],[7223,7336,"Better to just not have it"],[7336,7424,"in the first place!"]],"29":[[12,166,"I hate to break it to you,"],[266,408,"but while you were praying"],[408,542,"for my daughter's downfall,"],[542,692,"our baby's death,"],[734,880,"God sent her back to me."],[1038,1151,"She survived."],[1413,1534,"And after today,"],[1534,1797,"you will never see her again."],[1889,2031,"Iris, thank God."],[2093,2173,"How are you feeling?"],[2252,2344,"I'm alright."],[2590,2765,"She almost didn't make it, but..."],[2915,3007,"She's a fighter."],[3007,3090,"She held on."],[3503,3862,"That baby belongs to the Bates family."],[3924,4120,"If my son hadn't been"],[4120,4320,"working his ass off"],[4320,4625,"to support your pathetic, broke ass,"],[4637,4750,"you wouldn't have even been"],[4750,5030,"able to afford a basic hospital."],[5109,5201,"Go ahead."],[5263,5426,"Divorce my son."],[5459,5601,"But that baby"],[5601,5860,"is not going anywhere with you."],[5935,6047,"Like it or not,"],[6047,6289,"that thing is coming home with us."],[6335,6393,"Take her."],[6906,7169,"What are you doing?"]],"30":[[208,333,"You almost killed my baby"],[333,496,"and you were trying to take her from me?"],[575,675,"Over"],[709,750,"my"],[804,892,"dead"],[917,980,"body."],[1092,1192,"Iris, calm down."],[1192,1280,"Get off of her, Iris."],[1280,1330,"Calm down."],[1330,1459,"You're acting like a fucking lunatic."],[1722,1810,"My mom's right."],[1810,1968,"You're not fit to raise my child."],[1968,2143,"With a violent abuser for a mother,"],[2143,2273,"the only place this kid's gonna end up"],[2273,2360,"is juvie."],[2373,2498,"Iris, you can go wherever you want,"],[2498,2635,"but you're leaving the baby with us."],[2656,2790,"I'll consider it compensation"],[2790,2948,"for surviving three years of marriage"],[2948,3073,"to a broke, scamming"],[3073,3169,"psycho like you."],[3370,3566,"My baby is a human being."],[3591,3870,"She is not an object for you"],[3870,4004,"to bargain over!"],[4099,4300,"Dorian Bates, marrying you"],[4300,4404,"was the biggest mistake"],[4404,4521,"of my entire life."],[4558,4654,"And I get it."],[4725,4838,"I get what you're doing."],[4909,5155,"You think, because I am poor,"],[5196,5392,"that I am easy to push over."],[5438,5697,"You have no idea"],[5793,5951,"who you are messing with."],[6010,6189,"That brooch that my father has"],[6227,6414,"is worth more than you could ever make"],[6473,6694,"in ten lifetimes."]],"31":[[0,229,"That brooch that my father has"],[266,450,"is worth more than you could make"],[471,688,"in ten lifetimes."],[721,850,"Are you still trying to"],[850,1030,"pass for some hotshot"],[1030,1384,"with that plastic fake brooch?"],[1430,1530,"You are nothing"],[1530,1960,"but a destitute, blood-sucking leech."],[1960,2131,"Actually, it's embarrassing"],[2131,2302,"how shameless you are."],[2302,2610,"If I hadn't seen through your facade,"],[2635,2890,"you and your fraudster father"],[2890,2948,"would still"],[2948,3340,"be bleeding my son dry as we speak."],[3382,3528,"Don't worry, baby."],[3616,3828,"Mommy's got it under control."],[3866,4079,"This family makes me sick."],[4133,4450,"They are not going anywhere"],[4450,4604,"with that baby."],[4658,4746,"The only place"],[4746,4996,"that these cheap fuckers are going"],[5021,5159,"is prison."],[5230,5376,"Stay strong, Iris."],[5376,5605,"I can't let them have my baby."]],"32":[[20,95,"The only place"],[95,350,"that these cheap fuckers are going"],[371,504,"is prison."],[654,1026,"Erik, collect all the broken pieces"],[1026,1092,"of the brooch"],[1092,1247,"and assess the damages."],[2085,2210,"You hopeless fools."],[2273,2435,"The CEO of the Cartelier"],[2435,2581,"made this custom"],[2581,2761,"for the chairman of the Astor Dominion."],[2781,2869,"It's the only one of its kind"],[2869,2940,"in the world."],[2952,3073,"You know what that means, right?"],[3098,3244,"You're gonna be repaying this debt"],[3244,3382,"for the rest of your lives!"],[3457,3570,"The Astor Dominion?"],[3570,3691,"That's the world's number one"],[3691,3816,"financial conglomerate."],[3849,4008,"They're worth over 700 billion"],[4008,4104,"on the stock market."],[4120,4304,"Isn't that Chairman Alec Astor,"],[4337,4466,"the richest man in the world?"],[4529,4675,"Wait, and his daughter's name"],[4675,4775,"is Iris, too."],[4804,4892,"That must be her."],[4892,5184,"That's Iris Astor, the Astor heiress."]],"33":[[29,75,"Are you really"],[75,175,"part of the Astor Dominion?"],[275,412,"I'm not just part of it."],[525,671,"My father is the chairman"],[671,792,"of the Astor Dominion,"],[813,930,"and I am his sole heir."],[971,1242,"And my baby will be my successor."],[1326,1564,"I didn't tell you who I was because"],[1605,1868,"I gave up all of it to be with you."],[1993,2097,"And I recently got back"],[2097,2231,"in contact with my father"],[2302,2402,"to tell him the good news"],[2402,2485,"about the baby."],[2548,2706,"I was planning on telling you"],[2706,2857,"about my family background."],[2898,3019,"But now I'm glad I didn't."],[3157,3303,"Because you turned out to be"],[3328,3616,"a total piece of shit, Dorian."],[3678,3841,"You are not worthy of being"],[3841,3953,"my husband."],[4016,4216,"Let alone the father of my child."],[4250,4446,"Oh, come on!"],[4466,4646,"The fake goods were bad enough."],[4662,4850,"But now you're trying to impersonate"],[4850,5050,"the world's richest family?"],[5188,5372,"It just keeps getting better and better!"],[5413,5576,"So because your tiny little brain"],[5576,5876,"can't wrap around this fact, it's fake?"]],"34":[[0,162,"So because your tiny little brain"],[162,462,"can't wrap around this fact, it's fake?"],[550,600,"Fine."],[675,788,"Believe what you want."],[813,1021,"You're really full of shit."],[1155,1284,"If you really were"],[1284,1484,"the world's richest heiress,"],[1518,1626,"why would you"],[1626,1814,"leave your fortune behind"],[1814,1943,"to marry my son?"],[2031,2214,"And for such an important occasion,"],[2243,2344,"wouldn't the hospital"],[2344,2527,"be swarming with gifts?"],[2527,2777,"I don't see any A-list celebrities"],[2777,2873,"coming here"],[2873,3061,"to celebrate the birth of your heir."],[3115,3340,"All that you need to know is that"],[3340,3490,"my baby is coming home with me."],[3532,3645,"And that if either of you"],[3645,3720,"try to do anything,"],[3720,3782,"I will make sure"],[3782,3920,"that you both rot in hell."],[4391,4654,"Mr. Holland, you spent 8 million"],[4654,4733,"on this tiara"],[4733,4954,"to win the Sotheby's bid ten years ago."],[5034,5201,"Are you sure you want to give it away?"],[5301,5363,"Hurry!"],[5367,5513,"I need to get the Poltimore Tiara"],[5513,5593,"from the vault."],[5593,5847,"I need it delivered to Miss Astor ASAP."],[5885,6010,"You're giving that away?"],[6072,6164,"If we pull this off,"],[6177,6256,"we can have a partnership"],[6256,6460,"with the Astor Dominion."],[6489,6685,"We're talking billions, Jessica!"],[6685,6785,"Billions!"],[6819,7007,"You've still got a lot to learn, Jessica."],[7007,7152,"That's this Iris Astor"],[7152,7232,"we're talking about."],[7232,7449,"The heiress to the Astor Dominion."],[7503,7628,"I only found out yesterday"],[7628,7720,"she was giving birth."],[7795,7949,"All that matters is that we get"],[7949,8095,"this gift delivered to her on time."],[8500,8554,"Sir?"],[8662,8787,"Someone's claiming to have found"],[8787,8946,"a counterfeit Cheetah Brooch."],[9004,9134,"I hate it when people bother me"],[9134,9238,"with this petty crap."],[9292,9359,"This is what I have a team"],[9359,9438,"of lawyers for."],[9480,9563,"Step on it!"],[9563,9688,"I need to be the first one"],[9688,9872,"to deliver Miss Astor a baby gift!"]],"35":[[0,133,"No, no, no, no, no, no, no!"],[196,429,"You're just a, a filthy skank!"],[454,696,"You're not even fit to shine my shoes!"],[779,905,"And you think you can make me"],[905,1001,"burn in hell?"],[1021,1138,"Oh no!"],[1222,1347,"Enough of your bullshit!"],[1393,1634,"I'm gonna teach you a lesson now!"]],"36":[[187,354,"You've got some nerve"],[354,592,"trying to mess with the Bates family."],[713,821,"But guess what?"],[867,1063,"It's not gonna work."],[1130,1209,"Come on down."],[1238,1330,"Come on, Dorian."],[1351,1430,"Come on down."],[1472,1735,"Rip up this fake Monopoly money."],[1772,1910,"Show them what happens"],[1910,2152,"when you mess with the Bates family."],[2214,2289,"Dorian,"],[2435,2598,"I will give you one final warning."],[2786,2915,"Don't join your mother's"],[2915,2994,"temper tantrum."],[3128,3228,"If you do,"],[3365,3566,"I promise it will be the end of you."],[3653,3753,"Bullshit."],[3807,4024,"Your empty threats don't scare us."],[4195,4391,"Don't let that bitch deceive you."],[4529,4775,"You don't tear up the cash right now."],[4875,5038,"She's just gonna keep scaming."],[5330,5388,"Come on."],[5434,5522,"Listen to Mommy."],[5605,5689,"Tear it up."],[5718,5801,"Rip it up."],[5843,5905,"Come on."],[5943,6001,"Do it."],[6060,6151,"Rip it up."]],"37":[[20,216,"Come on, rip it up!"],[246,417,"Dorian, wake up!"],[458,542,"If you don't,"],[542,742,"your mom's gonna be the death of you."],[742,859,"Shut the fuck up."],[888,1001,"My mom's the only person"],[1001,1117,"who's ever loved me for me."],[1146,1284,"She'd never do anything to hurt me."],[1309,1363,"You're just trying to"],[1363,1455,"turn me against her."],[2093,2202,"That's what happens"],[2202,2402,"when you fuck with the Bates family."],[2615,2706,"Remember, Iris."],[2727,2844,"You brought this on yourself."],[2844,3003,"I just wanted you to save a little money,"],[3003,3186,"but you and your dad had to orchestrate"],[3186,3361,"this crazy plan to try and scam me?"],[3361,3445,"Now, you're living with"],[3445,3532,"the consequences."],[3532,3674,"Exactly."],[3724,4016,"My son is an absolute catch."],[4033,4175,"A real ten out of ten."],[4216,4325,"And what do you do?"],[4362,4525,"You try to scam him"],[4525,4679,"with all those fake goods?"],[4688,4934,"You should've been grateful"],[4934,5146,"to have a husband like Dorian."],[5146,5301,"We've had enough of your games, Iris."],[5442,5551,"Let's get divorced."],[5693,5764,"Hear that?"],[5809,5935,"He wants out."],[5935,6072,"Divorce him"],[6097,6218,"and get the hell away"],[6218,6339,"from the Bates family."],[6339,6427,"As you wish."],[6468,6569,"But as the defendants"],[6569,6690,"in this case,"],[6690,6831,"are you prepared to rot in jail"],[6831,6944,"for the rest of your lives?"]],"38":[[0,141,"Are you prepared to rot in jail"],[141,254,"for the rest of your lives?"],[367,454,"Defendants?"],[462,550,"What are you talking about?"],[567,650,"Defendants?"],[663,817,"What the hell kind of scheme"],[817,930,"are you cooking up now?"],[930,1071,"I'm suing the both of you."],[1151,1305,"For defamation, for destruction of"],[1305,1413,"personal property,"],[1413,1543,"and for attempted murder."],[1601,1760,"You're suing us?"],[1814,2068,"Your scammer dad is trying to"],[2068,2256,"distribute counterfeit goods."],[2256,2469,"We should be suing you."],[2469,2719,"Iris, we were married for three years."],[2748,2852,"We have a child."],[2869,3019,"Do you really want to drag me to court?"],[3040,3140,"You really have the nerve"],[3140,3240,"to talk about our child"],[3240,3319,"when you sat there"],[3319,3520,"while your mother abused me"],[3536,3762,"and almost let the baby die."],[3762,3937,"Don't try to push the blame onto my mom."],[3978,4120,"Yeah, she might have a unique"],[4120,4220,"way of showing her love for me,"],[4220,4350,"but at least she loves me."],[4350,4491,"You're the one who started all this."],[4508,4654,"You insulted her first."],[4688,4754,"Forget it."],[4796,4996,"I'm not gonna waste my breath"],[4996,5150,"on a vile woman like you."],[5176,5267,"We're getting divorced."],[5267,5317,"Now."],[5543,5751,"I've been waiting for this day to come."],[6051,6164,"Sign it and scram."],[6189,6327,"I don't ever want to see you again."],[6627,6740,"You know, you really are"],[6740,6840,"as dumb as it gets."],[6865,6977,"Did you even think about"],[6977,7061,"the consequences"],[7061,7165,"that you would face"],[7165,7369,"if these gifts were real?"]],"39":[[12,125,"Did you even think about"],[125,208,"the consequences"],[208,304,"that you would face"],[304,529,"if these gifts were real?"],[625,825,"That's impossible."],[825,1038,"It's impossible that they're not fake."],[1063,1213,"Play time's over, bitch."],[1242,1505,"Dorian already told you to beat it."],[1526,1722,"Now quit stalling and sign"],[1722,1885,"the damn divorce papers."],[1885,2022,"The Bates family wants nothing"],[2022,2102,"to do with you."],[2102,2273,"Fine, I will sign the papers."],[2306,2431,"But you have to give me back"],[2431,2506,"what's mine."],[2598,2761,"Give you back what's yours?"],[2781,2948,"We have nothing of yours."],[2973,3278,"And not to mention that you've been on"],[3278,3432,"unpaid maternity leave"],[3432,3591,"for the past two weeks."],[3611,3920,"And Dorian has been covering everything."],[4004,4166,"I already told you."],[4220,4512,"Your money and your baby"],[4533,4725,"belong to the Bates family."],[4892,5075,"So if you want to leave,"],[5100,5363,"you leave with nothing."],[5442,5701,"So, Dorian, you already know"],[5701,5860,"what your wonderful mother"],[5860,5943,"thinks of me."],[5985,6064,"What about you?"],[6064,6147,"I'm with her."],[6147,6314,"She's only ever done what's best for me."],[6314,6460,"What's best for you"],[6460,6623,"is ruining your chance"],[6623,6748,"of becoming a billionaire"],[6777,6856,"and turning you"],[6856,7144,"into a bankrupt criminal?"]],"40":[[20,316,"Shut up, you old fraud!"],[316,554,"I was tired of you like two hours ago."],[613,959,"And you don't even think about"],[959,1180,"trying to get a penny out of Dorian."],[1209,1422,"Iris, you married me with nothing,"],[1422,1518,"now you're leaving with nothing."],[1518,1680,"Isn't that exactly how it should be?"],[1714,1893,"Stop painting yourself as a victim."],[1985,2060,"Three years ago"],[2060,2202,"I gave you an emerald ring."],[2289,2460,"I want it back, nothing else."],[2515,2702,"An emerald ring?"],[2936,3219,"Iris, you gave him that ring?"],[3261,3445,"It's the only thing your mother"],[3445,3607,"left behind when she passed."],[3607,3883,"You wasted three years of love"],[3883,4087,"on this asshole."],[4362,4487,"But after today,"],[4521,4604,"I know you'll never"],[4604,4729,"let that happen again."],[4800,4954,"You've grown up, Iris."]],"41":[[16,346,"Why does the emerald on this ring"],[346,458,"look so fake?"],[529,646,"Just give it back to me,"],[646,800,"and I will sign the divorce papers."],[800,925,"We will have a clean break."],[996,1046,"Fine."],[1063,1121,"Whatever."],[1142,1255,"Wait!"],[1334,1501,"You gave this ring to my son,"],[1501,1818,"which makes it Bates family property."],[1830,1906,"There's no way"],[1906,2060,"we're giving it back to you."],[2089,2298,"Please, Dorian, this is my only request."],[2331,2439,"If you give me back the ring,"],[2439,2594,"we will not only sign the divorce papers,"],[2594,2744,"I will pay off the mortgage"],[2786,2865,"and the car."],[2998,3174,"Please, it is the last thing"],[3174,3265,"my mother left."],[3728,3795,"What are you doing?"],[3841,3999,"What do you think I'm doing?"],[4041,4204,"This is my son's ring,"],[4204,4775,"so I will do whatever the hell I want to"],[4775,4838,"with it."],[4859,4909,"No!"]],"42":[[12,66,"No!"],[250,442,"Look at you!"],[479,754,"Going so crazy over this dumb ring."],[775,1021,"Isn't it just a cheap glass ring?"],[1071,1309,"I wouldn't be caught dead wearing it."],[1343,1480,"Only a broke,"],[1526,1864,"ignorant skank like you"],[1864,2097,"would turn this piece of trash"],[2097,2268,"into a rare kind of treasure."],[2310,2444,"I said just give it back!"],[2531,2673,"Look at you."],[2673,2857,"With all this going crazy,"],[2857,3019,"you'd think it was the real deal."],[3098,3290,"I said give it back."],[3370,3461,"Stay back."],[3541,3824,"Take one more step"],[3824,4074,"and I will smash it to the ground."]],"43":[[20,275,"And I will smash it to the ground."],[342,575,"Dorian, I have done so much for you."],[667,821,"I paid for the mortgage"],[821,1013,"and I supported you with your business."],[1038,1176,"When have I ever done you wrong?"],[1305,1463,"What more can you ask of me?"],[1593,1710,"Quit the whining."],[1835,1993,"You sound like nails on a chalkboard."],[2031,2243,"It's just like a stupid old ring."],[2243,2318,"Alright?"],[2356,2535,"It is not a stupid old ring!"],[2556,2761,"It is an Astor family heirloom!"],[2777,2890,"And it is the last thing"],[2890,3011,"that my mother left me."],[3044,3132,"And it is..."],[3240,3403,"And it is absolutely priceless."],[3570,3616,"Fine."],[3616,3770,"Mom, just give it back."],[3791,3858,"It says a lot about"],[3858,3945,"the type of person she is"],[3945,4054,"that she is willing to go this far"],[4054,4208,"over some trashy ring."],[4250,4329,"Get the ring!"],[4350,4429,"And be careful!"],[5388,5622,"Give something to the Bates family"],[5655,5935,"and you are not getting it back."]],"44":[[275,613,"I swear to God, you are pure evil."],[658,767,"All you have been doing"],[767,925,"since the second you got here"],[925,1205,"is abuse and humiliate Iris."],[1272,1359,"And you,"],[1438,1547,"hopeless,"],[1597,1705,"cowardly,"],[1751,1901,"shit-for-brains"],[1901,1997,"momma's boy."],[2064,2327,"I bet your mommy still wipes your ass"],[2327,2477,"every time you go potty."],[2556,2673,"Now look what you've done."],[2686,2794,"You've destroyed"],[2794,2977,"her mother's family heirloom."],[2998,3228,"You're monsters in human form."],[3228,3657,"Absolutely disgusting filth."],[3724,4004,"You shut the fuck up."],[4004,4133,"One more word out of you"],[4133,4208,"and I'm gonna make you"],[4208,4333,"get on all fours,"],[4333,4587,"lick my shoes and beg for forgiveness."],[4871,5017,"Did you just hit me?"],[5050,5221,"Nobody hits me."],[5472,5663,"You wanna go, Grandpa?"],[5705,5789,"Let's go."],[5897,6022,"Hands off my mom, Iris."],[6264,6335,"Baby!"],[6335,6473,"You are a scumbag!"],[6535,6639,"You destroyed the only thing"],[6639,6744,"that my mother gave me."],[6777,6998,"And I swear on her name"],[6998,7232,"that I will make you both pay!"],[7353,7620,"I am calling the cops."],[7620,7970,"You two are getting locked up."],[9142,9238,"Mr. Astor."]],"45":[[33,120,"Mr. Astor."],[216,287,"It's an honor."],[287,575,"I'm Byron Holland, CEO of Cartelier."],[575,704,"I sent over the Cheetah Brooch"],[704,784,"earlier this morning."],[846,934,"Appreciate it."],[1042,1251,"That's the CEO of Cartelier."],[1251,1326,"I've seen him"],[1326,1530,"on magazine covers before."],[1605,1739,"Oh wow, he's treating that girl's father"],[1739,1843,"with such respect."],[1843,1926,"Who is he?"],[1956,2072,"If I had to guess,"],[2097,2302,"he's the chairman of the Astor Dominion,"],[2323,2485,"the richest man on the planet."],[2523,2698,"Oh my God, that tiara is shining."],[2731,2915,"Mr. Astor, I heard your daughter"],[2915,3028,"had to give birth today."],[3040,3244,"I prepared a small gift to celebrate."],[3274,3378,"Oh, thank you."],[3378,3499,"That's very nice."],[3499,3641,"But really, there's no need."],[3670,3732,"Oh no,"],[3757,3895,"he just turned down Mr.Holland"],[3895,4045,"in front of everyone?"],[4045,4170,"Mom, that tiara"],[4170,4283,"doesn't look fake to me."],[4283,4375,"What if Iris and her dad"],[4375,4487,"are actually the real deal?"],[4554,4763,"No, that's impossible."],[4808,4879,"There's no way"],[4879,5067,"a bottom feeder like her"],[5067,5246,"would be the world's richest heiress."],[5326,5467,"Think about it, Dorian."],[5467,5705,"Why would a rich heiress"],[5705,5868,"leave everything behind"],[5868,5980,"and work three jobs"],[5980,6177,"just to marry a regular guy like you?"],[6206,6389,"That tiara must be a fake."],[6398,6531,"Don't fall for it, Dorian."],[6560,6748,"What kind of nonsense is that?"]],"46":[[25,221,"What kind of nonsense is that?"],[421,721,"And a CEO, please!"],[738,942,"More like a deadbeat actor"],[942,1109,"they hired off the street."],[1121,1305,"Mom, you really think they're faking it?"],[1388,1634,"Of course they are, Dorian."],[1659,1797,"Look, you're lucky"],[1797,1939,"that you're divorcing her."],[1939,2131,"Not only did she show up"],[2131,2285,"with all those knockoff goods,"],[2302,2406,"she brought in"],[2406,2660,"a group of cheap actors"],[2660,2781,"to back her up."],[2781,2919,"Are you kidding me?"],[2936,3103,"This is the Poltimore Tiara."],[3115,3328,"I dropped 8 million at Sotheby's on it."],[3357,3445,"And I have the certificate"],[3445,3516,"to prove it."],[3520,3632,"Oh, yeah."],[3699,3787,"And how do we know"],[3787,3958,"the certificate's not fake?"],[3974,4241,"I mean, if you can forge currency"],[4241,4696,"and impersonate the CEO of Cartelier,"],[4750,4913,"faking a paper's nothing."],[4929,5030,"You're insane!"],[5030,5213,"Everything you say is nonsense!"],[5234,5417,"I'm insane?"],[5455,5739,"You're the one pissing me off!"],[5764,5939,"I'm gonna fuck you up!"]],"47":[[525,713,"You crazy old bitch!"],[738,850,"I'm gonna kill you!"],[946,1055,"Dorian!"],[1071,1163,"Baby!"],[1209,1280,"Did you see"],[1280,1426,"what they did to your Mommy?"],[1426,1785,"Your ex-wife hired those gangsters"],[1785,1885,"to kill me!"],[1901,2031,"I'm gonna call the cops!"],[2052,2268,"I'm gonna get you all arrested."],[2306,2510,"Go find the best jeweler you can."],[2531,2702,"We need to get that tiara fixed now!"],[2702,2802,"Yes, sir!"],[3057,3199,"If it can't be repaired,"],[3261,3432,"I'm gonna make you regret it!"]],"48":[[291,392,"You can't just hit her like that."],[392,483,"That's assault!"],[500,650,"You people are the real criminals!"],[654,788,"Here we go again."],[817,946,"You're just like your mom,"],[980,1130,"always pointing fingers,"],[1130,1338,"never owning up to anything."],[1363,1605,"Nothing but dead weight."],[1659,1789,"Your mom just trashed"],[1789,1926,"someone else's property"],[1947,2110,"and you're calling him the criminal"],[2110,2264,"for standing up for himself."],[2335,2448,"Mr. Holland!"],[2489,2631,"What brings you here?"],[2694,2773,"You know her?"],[2844,3003,"No, no, of course not."],[3023,3144,"You may not remember me,"],[3144,3315,"but I'm Sadie Smith,"],[3315,3436,"Regional Manager"],[3436,3661,"for Cartelier's California branch."],[3661,3774,"In fact, that whole"],[3774,3883,"Cheetah Brooch scandal,"],[3883,3970,"I was the one that"],[3970,4124,"called it into headquarters."],[4141,4225,"I couldn't have known"],[4225,4383,"it was gonna cause such a fuss,"],[4383,4600,"much less bring you here in person."],[4617,4742,"The Cheetah Brooch you talk about,"],[4859,4946,"where is it?"],[4975,5063,"Let me take a look."]],"49":[[20,91,"Where is it?"],[129,221,"Let me take a look."],[233,346,"Yes, absolutely."],[346,467,"Uh, you."],[500,646,"You there with the fake brooch."],[654,825,"Show it to Mr. Holland immediately."],[875,1076,"Oh, that fake brooch."],[1230,1426,"Mr. Holland gave it to me himself."],[1455,1710,"Why don't ask him if it's real or not?"],[1818,2143,"From Mr. Holland, the CEO of Cartelier."],[2185,2569,"Tessa, everything you see is fake."],[2711,2873,"Why don't we double check?"],[2890,3098,"It must have been fake for it"],[3098,3274,"to break so easily."],[3328,3453,"Seriously?"],[3474,3632,"You're gonna keep making stuff up"],[3632,3853,"when the CEO is standing right here"],[3853,3933,"in front of you?"],[3978,4162,"Sir, please don't take it personally"],[4162,4266,"but, men like him"],[4266,4437,"can't afford the real thing,"],[4437,4604,"so they masquerade in fakes."],[4604,4813,"Frankly, I think it damages our image."],[4833,4934,"I have a friend"],[4934,5113,"who's a journalist at CBS."],[5125,5330,"If you like, I could put in a call to her"],[5330,5405,"so that she can bring"],[5405,5601,"this whole scandal to the news media."],[5618,5759,"You wanna take this to the media?"]],"50":[[25,204,"You wanna bring the media in on this?"],[204,279,"Of course!"],[279,383,"I think it would be best"],[383,496,"to protect our image."],[508,650,"Or it will ruin the company."],[658,763,"Fucking idiots!"],[800,921,"Mr. Holland."],[946,1109,"Why would you do that?"],[1109,1305,"I was just trying to protect the company!"],[1359,1455,"You deserve it!"],[1455,1543,"Mr. Holland."],[1785,2064,"You arrogant asshole."],[2093,2327,"Who the fuck do you think you are"],[2327,2473,"hitting my friend like that?"],[2473,2694,"Do you even know who she is?"],[2715,2948,"This is Sadie Smith,"],[2948,3328,"Regional Manager of Cartelier California."],[3495,3657,"She's your friend?"]],"51":[[16,158,"She's your friend?"],[171,342,"No, no, no, no, no, no, no."],[600,884,"Babe, you gotta back me up on this."],[884,934,"No."],[959,1005,"What?"],[1080,1405,"All I did was crush that cheap-ass tiara"],[1405,1518,"to prove that it was fake."],[1539,1726,"And now everyone's lashing out at me."],[1768,1856,"They hit me."],[1864,1964,"Call the cops!"],[1964,2139,"I want everything documented!"],[2139,2344,"I'm suing all of them!"],[2344,2506,"You smashed the tiara?"],[2506,2581,"Yes!"],[2623,2756,"You idiot!"],[2756,3053,"This is our CEO of Cartelier,"],[3053,3190,"Mr. Holland."],[3190,3399,"Apologize to him right now!"],[3436,3561,"He's Mr. Holland?"],[3716,4054,"I just slapped the CEO of Cartelier?"]],"52":[[0,350,"I just slapped the CEO of Cartelier?"],[350,500,"You didn't just hit me."],[529,709,"You destroyed the gift"],[709,871,"I brought for Miss Iris."],[921,1063,"It's not just any tiara,"],[1088,1201,"it's a Poltimore tiara."],[1247,1397,"A cultural relic"],[1447,1735,"I paid millions for at Sotheby's"],[1735,1860,"with the highest bid."],[1968,2122,"Something you would never afford,"],[2122,2281,"even if you sold everything you own."],[2306,2548,"If you're the CEO of Cartelier,"],[2656,2823,"and you brought a present"],[2915,3115,"for Iris Astor?"],[3186,3265,"No way."],[3311,3432,"You morons."],[3490,3687,"You two still don't understand."],[3720,3924,"That man that you mocked"],[3924,4266,"for wearing a fake brooch is Alec Astor,"],[4300,4533,"Chairman of the Astor Dominion,"],[4575,4804,"the richest man on Earth."],[4863,4988,"With a net worth of"],[4988,5296,"over seven hundred billion."],[5321,5584,"And this is Miss Iris Astor,"],[5593,5759,"his only daughter,"],[5809,6076,"sole heir to his entire empire."],[6076,6168,"Mr. Astor,"],[6168,6285,"you're the world's richest man."],[6306,6489,"That means I could have been"],[6489,6619,"son-in-law of the wealthiest man"],[6619,6677,"in the world."],[6715,6852,"I would have this whole fortune."],[6936,7032,"It could be mine."]],"53":[[20,179,"So this bitch really is"],[179,337,"the world's richest heiress."],[437,517,"Damn it."],[567,825,"If this keeps going, I'll lose Dorian"],[850,988,"and everything I've got."],[1113,1305,"Dorian, don't listen to her."],[1338,1514,"Iris lied to you for years"],[1514,1664,"about who she really was."],[1672,1835,"She's a manipulative bitch."],[1868,2047,"Even if you two stayed married,"],[2052,2231,"do you think she'd even give you a cent?"],[2410,2619,"Say one more word about my daughter"],[2619,2794,"and I'll rip your tongue out!"],[2794,2848,"But she-"],[3103,3194,"Iris,"],[3211,3403,"what do you want to do about this?"],[3424,3624,"These two have done enough"],[3624,3832,"to lose everything they've ever owned"],[3832,4074,"and spend the rest of their lives in prison."]],"54":[[454,546,"Iris."],[638,709,"Please!"],[742,863,"We're family, right?"],[1042,1117,"I promise."],[1180,1330,"Dorian and I didn't really"],[1330,1430,"mean to hurt you."],[1430,1614,"We didn't actually know who you were."],[1634,1818,"After three years together,"],[1839,1964,"do you think you can find it"],[1964,2173,"in your heart to just let this go?"],[2377,2594,"How dare you guilt-trip"],[2631,2727,"Miss Astor?"],[2840,2986,"Didn't you say that you hated me?"],[3015,3103,"That you never wanted"],[3103,3194,"to see me again?"],[3607,3674,"Iris, baby."],[3678,3728,"Iris."],[3812,3912,"This is all my fault."],[3945,4095,"I know I messed up and I'm sorry."],[4095,4162,"Really."],[4212,4308,"You used to love me."],[4308,4425,"Doesn't that still mean anything?"],[4471,4617,"Are you really gonna let me go to jail?"],[4667,4750,"What about our daughter?"],[4796,4921,"She needs to see her dad."],[4963,5030,"I swear,"],[5063,5125,"I will,"],[5142,5334,"I will never listen to another word"],[5334,5413,"my mom says."],[5413,5622,"From now on, I will only listen to you."],[5697,5822,"You almost got our baby killed"],[5822,5935,"because you couldn't stand up"],[5935,6039,"to your own mother."],[6093,6197,"And you have the nerve"],[6197,6314,"to ask that of me?"],[6414,6569,"You're a bastard, Dorian."],[6798,6861,"We're done."],[7040,7140,"Marrying you"],[7248,7349,"was the worst mistake"],[7349,7557,"that I ever made in my entire life."]],"55":[[41,145,"You know your stupidity"],[145,316,"cost you every single cent"],[316,383,"you could have got"],[383,487,"from the Astor Fortune."],[608,779,"Dad, we'll let the lawyers and the cops"],[779,905,"handle the rest of this."],[917,1101,"I want every single cent"],[1101,1272,"reimbursed from the tiara."],[1272,1393,"As for Dorian,"],[1422,1572,"I won't be pressing charges"],[1572,1689,"for the child's sake."],[1705,1776,"But he will be"],[1776,1901,"spending the rest of his life"],[1901,2056,"paying back the debt that he owes."],[2131,2406,"As for Tessa, if she can't pay back"],[2406,2535,"the money that she owes,"],[2535,2606,"then she will spend"],[2606,2819,"the rest of her life rotting in jail."],[2911,2994,"That's what she deserves"],[2994,3132,"for trying to kill my child."],[3324,3374,"Please."],[3428,3490,"Iris."],[3549,3657,"Officers, we'll let you"],[3657,3741,"take it from here."],[3741,3824,"No, no, no."],[3824,3878,"No!"],[3928,3987,"No!"],[4012,4070,"No!"],[4070,4208,"What are you doing?"],[4208,4287,"No!"],[4600,4929,"Iris, congrats on making it out of hell."],[5117,5238,"Let's go home."],[5430,5551,"Thank you all for coming."],[5568,5684,"I've called this meeting"],[5684,5851,"to share some good news."],[5897,6177,"As of today, Iris Astor,"],[6177,6435,"rightful heir to the Astor Dominion,"],[6473,6656,"has officially returned."],[7657,7824,"Thank you all for the warm welcome."],[7862,8049,"Starting today, I will be stepping in"],[8049,8249,"as the new CEO for the Astor Dominion."],[8287,8554,"So, can we start our first meeting?"]],"56":[[684,838,"These fucking assholes."],[917,1071,"Don't they know I was the son-in-law"],[1071,1188,"of the world's richest man?"],[1326,1505,"Yesterday, Iris Astor,"],[1505,1605,"the newly appointed"],[1605,1780,"CEO of the Astor Dominion,"],[1810,1914,"celebrated her daughter's"],[1914,2035,"first birthday,"],[2035,2218,"renting out the entire Four Seasons"],[2218,2310,"in Beverly Hills."],[2356,2510,"Cameras spotted Miss Astor"],[2510,2669,"in fully head-to-toe designer"],[2669,2873,"with her baby Ivy in her arms."],[2886,3048,"The young heiress is set to inherit"],[3048,3128,"one of the world's"],[3128,3282,"largest private fortunes."],[3357,3415,"Wait."],[3524,3666,"Why didn't I think of this soon?"],[3728,3987,"Divorced or not, I'm still Ivy's dad."],[4921,4971,"Hello."],[5080,5138,"Some of you"],[5138,5280,"may have heard of Iris Astor,"],[5280,5467,"the new CEO of the Astor Dominion."],[5588,5714,"I'm her ex-husband."]],"57":[[62,150,"I'm gonna get you."],[254,375,"I am going to get you."],[375,596,"Miss Astor, you need to see this."],[596,658,"What?"],[704,896,"It's yourr ex-husband live,"],[896,1030,"spreading rumors about you."],[1071,1313,"We're married for three years."],[1422,1493,"But in the end,"],[1509,1697,"she and her billionaire father,"],[1697,1885,"Alec Astor, kicked me out"],[1885,2035,"just because I wasn't rich enough."],[2060,2185,"And the worst part is,"],[2260,2527,"they've taken our daughter, Ivy."],[2552,2681,"This is outrageous."],[2740,2852,"I cut Dorian some slack"],[2852,2936,"because he's Ivy's father"],[2936,3065,"and this is how he repays me?"],[3065,3211,"By slandering me online?"],[3286,3395,"It's spreading fast."],[3415,3465,"Miss Astor,"],[3465,3599,"people are calling for a boycott."],[3611,3749,"And now our company's stock"],[3749,3908,"just dropped by eight percent."]],"58":[[792,963,"I never thought it'd end up like this."],[963,1188,"Iris and her father,"],[1251,1434,"they've used their power to ruin my life."],[1434,1576,"They took my daughter away"],[1609,1755,"before I even got to hold her."],[1772,2039,"And now, they're forcing me to pay"],[2039,2231,"hundreds of millions in debt"],[2285,2398,"I can't afford!"],[2419,2531,"They even had my mom"],[2531,2619,"thrown in prison."],[2677,2840,"I'm not doing this to hurt anybody."],[2865,3040,"I just want to see my little girl again."],[3078,3194,"I don't have any power."],[3207,3311,"I don't have money."],[3403,3624,"All I can do is speak the truth"],[3653,3837,"and hope somebody out there hears me."],[3941,4229,"Please, help me get my daughter back."],[4316,4537,"Miss Astor, boards are furious."],[4558,4612,"They're demanding you"],[4612,4804,"to fix this immediately."],[5246,5363,"What the hell do you want?"]],"59":[[62,179,"What the hell do you want?"],[208,346,"Come on, Iris."],[346,487,"We were married for three years."],[487,663,"Don't act like I'm some stranger now."],[696,817,"I know you still care."],[817,1001,"I just, uh, I don't want Ivy"],[1001,1109,"growing up without her dad."],[1109,1172,"Alright?"],[1172,1251,"I promise."],[1276,1443,"This time, I'll do whatever you say."],[1443,1568,"I won't listen to anyone else."],[1584,1693,"Dorian, I cut you some slack"],[1693,1822,"and this is how you repay me?"],[1822,1972,"This isn't a threat, Iris."],[1989,2152,"I'm doing this because I love you."],[2168,2310,"If you're willing to take me back,"],[2310,2402,"marry me again,"],[2402,2548,"then I'll take the videos down."],[2548,2660,"Shut down all the rumors."],[2660,2736,"I swear,"],[2769,2957,"your stock won't drop another cent."],[2982,3057,"Wow."],[3111,3215,"You know, you just burned"],[3215,3315,"the last bit of mercy"],[3315,3424,"that I had left for you."],[3553,3607,"Fine."],[3636,3795,"I will see you in court."],[3816,3987,"I'm gonna make sure the entire world"],[3987,4170,"knows exactly who you are."],[4433,4542,"Ungrateful bitch!"],[4542,4733,"I'm still Ivy's biological father."],[5009,5146,"You had your chance, Iris."],[5192,5438,"Now, I'm gonna destroy you."],[5663,5851,"Erik, I need you to go get a lawyer."],[5851,5939,"I'm gonna be suing Dorian"],[5939,6014,"for defamation"],[6014,6164,"and for federal securities laws."],[6164,6222,"Miss Astor."],[6297,6452,"You will win in court, no doubt."],[6489,6648,"The damage to your reputation,"],[6648,6765,"I don't think it can be undone."],[6927,6969,"Wait."],[7002,7111,"What if we take him"],[7111,7203,"on one of those"],[7203,7361,"reality courtroom shows?"],[7361,7440,"We lay it all out there"],[7440,7570,"for the whole country to see."],[7611,7732,"We'll set the record straight."],[7786,7870,"I like that idea."],[7903,7982,"And if we're gonna do this,"],[7982,8091,"we're gonna make sure we do it"],[8091,8174,"so the whole world sees"],[8174,8304,"exactly who he is."],[8362,8525,"And we are not gonna hold back."]],"60":[[333,462,"Plaintiff Dorian Bates,"],[483,667,"you are suing Iris Astor"],[688,813,"for deprivation of custody"],[813,963,"of your daughter Ivy Astor."],[984,1076,"You want to modify"],[1076,1172,"the custody agreement."],[1172,1272,"Is that correct, sir?"],[1309,1405,"Yes, Your Honor."],[1480,1593,"She took my daughter away"],[1593,1651,"on the basis of"],[1651,1776,"having a wealthier family."],[1801,1856,"And now,"],[1856,1968,"she's forcing me to pay back"],[1968,2131,"a hundred million dollars in debt."],[2177,2327,"This is so much money."],[2598,2719,"Order in the court."],[2719,2882,"This is not a talk show."],[2915,3111,"Defendant, do you have any evidence"],[3111,3244,"to counter his claims?"],[3261,3353,"Thank you, Your Honor."],[3524,3653,"Mr. Bates is lying."],[3691,3824,"I have here the divorce agreement"],[3824,3962,"that he forced me to sign"],[3962,4079,"the day that I gave birth."],[4112,4245,"He left me and Ivy."],[4287,4346,"God."],[4358,4471,"I believe that a father"],[4471,4587,"who files for divorce"],[4587,4717,"the same day that their daughter"],[4717,4825,"enters this world"],[4825,4996,"does not deserve any custody."]],"61":[[8,108,"I believe that a father"],[108,225,"who files for divorce"],[225,358,"the same day that their daughter"],[358,479,"enters this world"],[479,638,"does not deserve any custody."],[658,825,"Only because she lied to me first,"],[825,888,"Your Honor."],[950,1101,"She hid her real identity"],[1101,1280,"and pretended to be from a poor family."],[1280,1388,"If I'd known she was the heiress"],[1388,1547,"to the wealthiest family in the world,"],[1547,1668,"I never would have left."],[1693,1906,"So you're saying it's perfectly fine"],[1906,2131,"to divorce your wife if she's poor."],[2160,2223,"No, no."],[2248,2414,"Your Honor, that's not what I'm saying."],[2523,2686,"As for the debt, Miss Astor,"],[2706,2823,"can you provide any evidence"],[2823,2902,"in your defense?"],[2923,2986,"Yes, Your Honor."],[3144,3311,"My father brought gifts for my daughter"],[3353,3478,"the day that I gave birth to her"],[3478,3661,"worth over a hundred million dollars."],[3778,3916,"As you can see here,"],[3933,4095,"my ex-husband and his mother,"],[4095,4175,"they destroyed"],[4175,4308,"absolutely everything."],[4337,4487,"Show them what it means"],[4487,4750,"to fuck with the Bates family!"],[4829,4979,"I simply want compensation"],[4979,5113,"in a fair and legal manner."],[5176,5234,"Wow."],[5251,5363,"This guy's shameless."],[5384,5484,"He asked for a divorce"],[5484,5634,"the day his wife gave birth,"],[5651,5797,"trashed all his daughter's gifts,"],[5797,5955,"and now he has the audacity"],[5955,6014,"to blame her"],[6014,6135,"for causing all this mess?"],[6168,6264,"The way they treated her,"],[6264,6448,"it's a miracle she didn't lose the baby."],[6448,6652,"Honestly, the Astor heiress is smart"],[6652,6798,"not to let him have custody."],[6798,7011,"He's not a father, he's a selfish leech"],[7011,7140,"who only cares about money."]],"62":[[0,208,"He's not a father, he's a selfish leech"],[208,329,"who only cares about money."],[350,462,"What the hell do you two know?"],[533,679,"This is clearly all her fault!"],[679,863,"If she told me her real identity earlier,"],[863,992,"none of this would have happened!"],[992,1142,"I tried to tell you at the hospital,"],[1142,1238,"but you didn't listen"],[1238,1380,"and suddenly this is my fault now."],[1380,1530,"I, you're-"],[1559,1622,"Order!"],[1705,1960,"Mr. Bates, I've heard more than enough"],[1960,2106,"to back the defendant's claims."],[2106,2243,"If all you've got"],[2243,2394,"are excuses and attitude,"],[2414,2577,"I'm ready to make my ruling."],[2577,2669,"Your Honor, please."],[2669,2840,"I'm still Ivy's biological father,"],[2840,2936,"doesn't her opinion matter?"],[2936,3007,"Just trust her."],[3007,3053,"See,"],[3053,3169,"she loves me more than anyone."],[4250,4412,"Biological dad or not,"],[4412,4583,"she's scared out of her mind."],[4621,4817,"That guy's just a money-hungry leech."]],"63":[[725,838,"You're okay, sweetheart."],[875,1021,"Looks like the future heiress's"],[1021,1192,"favorite person is still her Mommy."],[1334,1488,"I'm in favor of giving full custody"],[1488,1559,"to the mother."],[1584,1789,"A man who uses his own daughter"],[1789,1926,"as a pawn for money"],[1926,2068,"shouldn't even be a father."],[2189,2339,"I support Miss Astor."],[2398,2598,"We support Miss Astor!"],[2615,2794,"We support Miss Astor!"],[2811,2973,"We support Miss Astor!"],[3048,3107,"Order!"],[3144,3319,"I'll now announce the verdict."],[3432,3661,"Full custody will go to..."]],"64":[[45,333,"Full custody will go to..."],[467,692,"The defendant, Miss Iris Astor."],[713,771,"What?"],[796,846,"No."],[871,950,"This is rigged."],[950,1071,"She paid you all off."],[1088,1176,"I want an appeal."],[1201,1322,"Either give me my daughter"],[1322,1443,"or pay me alimony."],[1705,1776,"Bailiffs!"],[1851,1943,"Hey, hey, hey!"],[1943,2014,"Stop!"],[2022,2077,"Iris!"],[2118,2277,"You still haven't paid me any alimony"],[2277,2373,"since we got divorced."],[2381,2460,"That's illegal!"],[2464,2569,"Did you forget, Dorian?"],[2569,2706,"You were the one that forced me"],[2706,2823,"to sign the divorce papers."],[2823,2998,"You clearly stated that you wanted"],[2998,3174,"nothing to do with my assets"],[3174,3282,"or my debt."],[3286,3328,"No."],[3328,3478,"Any fortune you pushed away"],[3478,3553,"is on you."],[3586,3678,"No, that can't be."],[3749,3845,"It can't be like this."]],"65":[[25,158,"I'm refiling for divorce."],[158,241,"You can file for"],[241,362,"whatever you want, Dorian,"],[362,529,"but I recommend getting a lawyer."],[538,734,"I'm suing you for defamation"],[734,846,"and for violating"],[846,988,"Federal Security's laws."],[1005,1176,"Thanks to you, the Astro Dominion"],[1176,1317,"has lost over 10 billion"],[1317,1443,"in market value,"],[1443,1589,"which you will pay off in prison."],[1589,1697,"Iris, my baby."],[1739,1943,"Please, don't do this."],[1943,2014,"It would be heartless"],[2014,2068,"to let our daughter"],[2068,2164,"grow up without her father."],[2206,2481,"A greedy, selfish father"],[2527,2736,"would ruin our daughter."],[2790,2898,"She'd be better off with one."],[2919,2998,"Right, Dorian?"],[3103,3303,"That baby would end up just like its mom."],[3324,3553,"Another greedy, lying con artist."],[3570,3678,"Better to just not have it"],[3678,3782,"in the first place!"],[4079,4141,"Get off."],[4350,4450,"Everything's going to be"],[4450,4558,"different now, Ivy."],[4646,4829,"Mommy's got us a brand new start."]]}