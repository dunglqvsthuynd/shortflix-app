[3779,3916,"Well, I can understand that"],[3966,4183,"everything I'm saying is a lot, so"],[4329,4470,"you can take your time."],[6504,6579,"Where"],[6595,6679,"am I?"],[6679,6891,"You and Blake don't have a romance."],[6904,7108,"It's just a business transaction."],[7154,7291,"I can't remember anything"],[7291,7416,"after I talked to Vivian."],[7616,7754,"Did I drink too much?"]],"39":[[200,462,"Blake and I were never meant to last."],[479,587,"If Vivian is right,"],[587,750,"then I need to figure out my next move"],[750,904,"without Blake."],[929,1112,"Once I do, I'm gone."],[1316,1400,"Cleo, hey."],[1475,1512,"Hey."],[1591,1666,"Are you leaving?"],[1725,1825,"Please don't leave."],[1850,1954,"I haven't gotten to spend"],[1954,2029,"any time with you."],[2254,2350,"You and"],[2425,2604,"Vivian seem close."],[2650,2712,"Close?"],[2875,3000,"The closest thing about us is that"],[3000,3154,"we share the same publicist."],[3237,3337,"Miles."],[3337,3391,"This guy."],[3437,3550,"Miles Nash."],[3612,3825,"He wants me to"],[3912,4087,"share tomorrow night at the Met Gala"],[4087,4225,"my next big role."],[4304,4341,"So..."],[4341,4379,"Oh,"],[4437,4612,"VIP club tonight,"],[4675,4837,"Met Gala tomorrow."],[4962,5062,"How do you ever have time"],[5062,5179,"for anything normal,"],[5179,5287,"Mr. Wilder?"],[5437,5725,"Normal like what, Ms. Marlowe?"],[5787,6037,"Like sleeping, eating,"],[6187,6316,"falling in love."],[6350,6429,"Falling in love?"],[6500,6554,"Oh gosh."],[6629,6750,"I don't think I've ever had time to"],[6879,7037,"fall in love in my life."],[7141,7300,"I'm not even sure I really even know"],[7300,7412,"what love is."],[7837,7929,"Anyway, um..."],[8012,8075,"But"],[8116,8212,"surely you must know"],[8212,8291,"what it feels like."],[8291,8450,"I mean, you've acted it out enough."],[8450,8600,"What does love feel like to you?"]],"40":[[54,154,"I think..."],[266,391,"Love feels magical,"],[479,904,"exciting, like being kissed in the rain."],[1079,1154,"It's like,"],[1204,1354,"even when the sky's opening up"],[1354,1454,"all around you,"],[1604,1695,"you're still safe."],[1908,1983,"You're home."],[2091,2304,"So she's a romantic."],[2529,2616,"Have you ever been in love?"],[3504,3679,"What doesn't matter if it's love."],[3704,3841,"Blake doesn't do love."],[3841,4091,"At least, not with women like me."],[4091,4241,"Is this research?"],[4329,4479,"Is the great Blake Wilder"],[4479,4691,"studying love for his next role?"],[4733,4916,"Hey, I already have my next role."],[4954,5041,"Thanks to you."],[5191,5429,"So, now that you've landed"],[5566,5691,"the great Blake Wilder."],[5791,5895,"What's next?"],[6045,6129,"Uh,"],[6216,6408,"Fine. I'm still figuring that out."],[6529,6604,"Come with me"],[6695,6866,"to the Met Gala tomorrow."],[6966,7041,"I mean, after all,"],[7041,7195,"you're the one that"],[7195,7304,"got this whole thing booked."],[7304,7429,"You at least deserve it."],[7491,7654,"Come with me."],[7833,7966,"Maybe he's being nice now"],[7966,8104,"to make the breakup easier."],[8191,8329,"I bet his other flings didn't take it"],[8329,8495,"very well when he cut things off."],[8733,8879,"Uh, sure."],[8954,9104,"I mean, what kind of casting assistant"],[9104,9304,"would I be if I missed my star's big night?"],[9441,9554,"I told her how I feel,"],[9554,9791,"but things between us still seem so"],[10145,10316,"uncertain, delicate."],[10354,10491,"I mean, is she holding back,"],[10491,10716,"or is this what love feels like?"],[11279,11458,"I told you he was smitten with that"],[11458,11583,"slutty little nobody."],[11583,11804,"Let me handle this."],[11829,12129,"I'll remind her exactly where she stands."],[12295,12341,"Come on."]],"41":[[554,662,"Mr. Wilder, over here!"],[1000,1104,"Mr. Wilder, over here."],[1300,1366,"Mr. Wilder."],[1400,1466,"Look this way."],[1712,1816,"Cleo, come."],[2225,2279,"Come on."],[2429,2529,"Go stand with him."],[2762,2862,"Hey, you."],[4004,4087,"Ms. Marlowe."],[4150,4225,"Bryan Garcia."],[4287,4475,"Reel Vista's Managing Director"],[4475,4562,"here in New York."],[4575,4812,"I heard that you're the genius"],[4812,5041,"behind Blake Wilder's transition"],[5041,5175,"to prestige film."],[5175,5304,"Congratulations."],[5362,5491,"Thank you so much."],[5550,5762,"I have a job for you in New York."],[5779,5875,"Head of casting."],[5954,6091,"We'd love to have you."],[6162,6275,"Head of casting?"],[6350,6487,"I'd be in charge for once"],[6487,6566,"and I wouldn't need"],[6566,6675,"Blake's help anymore."],[6729,6825,"Maybe this is the chance"],[6825,6937,"I've been waiting for."],[7000,7054,"Uh,"],[7154,7291,"I'm flattered,"],[7300,7400,"Mr. Garcia."],[7425,7516,"I'll think about it."],[7566,7612,"Great."],[7629,7812,"I'll expect your answer in a week."],[8254,8304,"Mr. Wilder."],[8304,8425,"Mr. Wilder, over here."],[8550,8687,"Just one question, Mr. Wilder."],[8716,8787,"It won't take long."],[8891,8962,"Please."],[9029,9087,"Blake,"],[9150,9300,"answer the man's question, please."],[9300,9366,"Oh, uh,"],[9404,9500,"I'm so sorry."],[9525,9575,"No problem."],[9575,9625,"What were you saying?"],[9662,9795,"You've been on quite the run,"],[9816,10000,"biggest star in the last ten years."],[10012,10095,"How does it feel?"],[10116,10200,"Ms. Marlowe,"],[10250,10325,"Mr. Nash,"],[10325,10487,"Blake's publicist would like a word."],[10550,10629,"Follow me."]],"42":[[145,387,"Mr. Nash, it's so nice to finally meet you."],[412,458,"I-"],[458,612,"Save the small talk, Ms. Marlowe."],[695,800,"Word is you're..."],[845,925,"straightforward,"],[925,1012,"so I'll be direct."],[1070,1145,"Whatever's going on"],[1145,1233,"between you and Blake,"],[1233,1320,"it needs to end."],[1762,1887,"Don't worry, whatever's"],[1970,2120,"going on between Blake and I"],[2120,2208,"isn't there anymore."],[2308,2433,"I know I'm nobody"],[2433,2533,"in this world of"],[2533,2750,"famous Hollywood movie superstars"],[2750,2845,"like Blake."],[2920,3087,"I don't expect anything from him"],[3087,3233,"and he doesn't expect anything"],[3233,3308,"from me."],[3437,3508,"Lovely."],[3537,3670,"Then do us both a favor"],[3670,3800,"and walk away from Blake,"],[3800,3875,"today."],[3970,4058,"I've already got the perfect"],[4058,4183,"new match for him."],[4208,4362,"Vivian St. James."],[4387,4545,"It'll be the summer's biggest story,"],[4545,4675,"and it'll be quite the buzz"],[4675,4787,"for your next film."],[4870,5000,"Vivian St. James?"],[5037,5158,"Of course."],[5204,5379,"They're perfect for each other."],[5575,5670,"I, uh,"],[5720,5808,"I understand."],[5808,5870,"Cool."],[6008,6095,"Lovely."],[6308,6375,"Mr. Wilder?"],[6420,6500,"One moment."],[6533,6620,"I just saw Cleo leaving"],[6620,6770,"after speaking with Miles."],[7412,7558,"Any more questions?"],[7933,8100,"Where you get this dress from?"],[8145,8300,"Oh, it's custom made."],[8308,8420,"-Of course. -Yes."],[8483,8579,"Please leave us a message"],[8579,8666,"and we'll get back to you..."],[8970,9045,"Miles!"],[9095,9162,"Blake."],[9187,9325,"What the hell did you say to Cleo?"]],"43":[[0,162,"What the hell did you say to Cleo?"],[166,262,"Look, Blake,"],[275,366,"before you get upset,"],[412,512,"she told me,"],[562,616,"that she doesn't believe"],[616,725,"in your future together."],[725,825,"She told me"],[825,1000,"that her relationship with you is"],[1012,1112,"convenient."],[1141,1200,"That's all."],[1304,1412,"I'm sorry, my friend."],[1575,1650,"She's using you."],[1837,1900,"I don't want to tell you."],[2466,2625,"Take that back or I swear to God."],[2625,2829,"Why would I lie to you, Blake?"],[2829,2950,"I've always done what's best for you,"],[2950,2987,"Blake."],[3162,3350,"I stood by you during your worst mistakes"],[3350,3487,"in your entire career, haven't I?"],[3541,3591,"But her..."],[3700,3812,"Do you even know her, really?"],[4154,4266,"I thought I did."],[4291,4437,"I thought Cleo was different."],[4912,5037,"Look, Blake."],[5137,5250,"If you must have a girlfriend,"],[5262,5387,"please, for the love of God,"],[5387,5525,"make it Vivian St. James."],[5575,5704,"The fans will love it."],[5754,5837,"And she's a star,"],[5837,5925,"just like you."],[6000,6087,"I've already got the press release"],[6087,6154,"ready to go."],[6225,6287,"What do you say?"],[6466,6616,"I say stay the fuck out of"],[6616,6725,"my personal life."],[6962,7087,"Jesus, fuck."],[7450,7525,"Vivian,"],[7525,7812,"he will not let go of that little skank!"],[7912,8012,"I need you to convince him"],[8012,8091,"he's making a mistake."],[8462,8537,"I should have known"],[8537,8712,"it would never last with Blake."],[8791,8900,"This New York offer"],[8900,9062,"couldn't have come at a better time."],[9516,9825,"A fresh start is exactly what I need."],[9937,10050,"Cleo, a word?"]],"44":[[16,141,"Cleo, a word?"],[225,291,"If I were you"],[291,454,"I would get on that plane to New York."],[475,637,"There is nothing left for you here."],[675,866,"You don't have to threaten me, Vivian."],[950,1050,"I know who I am,"],[1062,1150,"where I belong."],[1287,1412,"And it's not with Blake."],[1454,1504,"So..."],[1562,1712,"Well then what are you still doing here?"],[1787,1925,"Leave him, tonight."],[1962,2087,"I don't need your pathetic,"],[2087,2312,"tear-streaked face all over the tabloids,"],[2312,2550,"ruining my perfect romance with Blake."],[2587,2654,"Don't worry."],[2779,2991,"There's nothing between Blake and I."],[3100,3204,"And there never was."],[3266,3425,"So, if you'll excuse me,"],[3425,3562,"I have to catch a flight back to LA."],[4125,4225,"Blake deserves to know"],[4225,4475,"what his little slut really thinks of him."],[5262,5354,"There's nothing"],[5379,5487,"between Blake and I."],[5587,5691,"And there never was."]],"45":[[575,637,"Blake?"],[683,837,"What are you doing here?"],[1191,1262,"Oh, shit."],[1325,1487,"Are you drunk?"],[1829,1904,"Just a little."],[2300,2425,"I'll get you some water."],[2425,2491,"Water?"],[2512,2587,"Yeah."],[2587,2650,"Sit down."],[2737,2841,"Woo!"],[3279,3462,"What do you really want from me?"],[3500,3554,"What is it?"],[3691,3875,"If he won't tell me what he wants,"],[3916,4104,"or if he won't break up with me himself,"],[4237,4425,"then I have to do it."],[4541,4600,"I..."],[4650,4762,"have something to tell you."],[4950,5012,"What is it?"],[5175,5250,"I'm moving"],[5375,5462,"to New York."],[5587,5666,"Thank you for everything"],[5666,5725,"you've done."],[5741,5787,"Oh."],[5825,5900,"Thank you."],[6087,6166,"You're welcome."],[6279,6500,"So, what are you really saying?"],[6704,6754,"I..."],[7004,7141,"can't live here anymore."],[7141,7200,"I mean,"],[7312,7491,"after your and Vivian's publicist-"],[7491,7554,"Vivian?"],[7704,7837,"That Vivian was probably"],[7837,7962,"the only one who was right."],[8000,8100,"Fucking Vivian."],[8200,8287,"Now you're leaving."],[8475,8541,"Thank you."],[8541,8841,"No, I wasn't using you, Blake."],[8862,9037,"I was happy with you."],[9100,9154,"But we both know"],[9154,9266,"this isn't going to work."],[9287,9425,"See, that's where you're wrong."],[9575,9654,"Just..."],[10600,10700,"Please..."],[10829,10929,"Stay please.."],[11341,11541,"I have to leave tonight."],[11666,11725,"Bryan,"],[11812,11912,"it's Cleo Marlowe."],[11979,12050,"I thought about it"],[12050,12237,"and I'll take the job in New York."],[12533,12612,"Goodbye, Blake."]],"46":[[875,1029,"I was never using you, Blake."],[1075,1225,"I was happy with you."],[1450,1600,"I was wrong about her."],[3425,3529,"Cleo, listen."],[3575,3675,"You can't leave"],[3675,3791,"without saying goodbye."],[3800,3950,"Please, just let me explain,"],[3950,4037,"just once."],[4091,4191,"If you still wanna leave,"],[4191,4300,"I won't stop you."],[4375,4425,"Okay."],[4562,4654,"Send me the location."],[4987,5037,"Blake?"],[5312,5462,"What is all this?"],[5662,5812,"Oh, this is..."],[6104,6216,"This is me saying sorry."],[6400,6500,"Okay, for everything I said"],[6500,6550,"the other night,"],[6550,6687,"I was wrong."],[6825,6962,"I'm sorry for saying that..."],[7012,7129,"I thought you were using me."],[7141,7237,"It's okay, Blake."],[7262,7412,"I'm not angry, but..."],[7604,7729,"I've come to accept that"],[7816,8016,"I'll never be the right woman for you."],[8062,8112,"You're wrong."],[8254,8466,"Because you're the only woman for me."],[8487,8591,"Look, all this stuff,"],[8591,8691,"this career,"],[8691,8779,"these movies,"],[8816,8875,"the fame..."],[8925,9050,"I don't want any of that"],[9050,9250,"if I can't keep you."],[9550,9662,"Stay."],[11812,11912,"You did this for me?"],[12112,12229,"Remember what you said that night"],[12229,12304,"at the club?"],[12454,12712,"I think, love feels magical,"],[12754,12916,"exciting, like..."],[13091,13262,"being kissed in the rain."]],"47":[[195,345,"I know that you don't want to go."],[450,545,"Blake, I..."],[1058,1120,"I can't."],[1262,1375,"As much as I want to,"],[1425,1675,"I can't let myself be pulled back in."],[1675,1825,"Your own publicist thinks"],[1825,1958,"this is a disaster."],[1958,2062,"The news is reporting"],[2062,2162,"you're with Vivian."],[2200,2383,"Nobody knows I even exist."],[2383,2470,"Forget them."],[2583,2687,"For one damn second,"],[2687,2770,"forget them."],[2800,2883,"And look at me."],[2895,3000,"And you tell me."],[3095,3200,"What do you want?"],[3312,3358,"I..."],[3383,3487,"What do you want?"],[3650,3758,"I have to be strong."],[3812,4083,"End it before it destroys us both."],[4287,4450,"I want my old life back."],[4650,4858,"Everything spiraled since we met."],[4858,4933,"The fame,"],[4933,5058,"the attention, the pressure."],[5058,5170,"I wasn't built for"],[5170,5295,"the spotlight, Blake."],[6220,6325,"The other night at the club,"],[6545,6720,"I told you that I wanted you."],[6895,6962,"Only you."],[7133,7195,"And you,"],[7212,7337,"you didn't say anything."],[7420,7483,"Why?"],[7800,7912,"You did? I..."],[8158,8250,"I don't remember."],[8250,8345,"Everything was a blur."],[8345,8512,"Blake, why didn't you tell me again?"],[8512,8595,"Because I thought"],[8595,8712,"that you would leave!"],[8883,8983,"That I would scare you"],[8983,9083,"and you would go!"],[9208,9333,"And you're proving me right,"],[9383,9508,"because it's what you're doing..."],[9550,9625,"right now."],[9858,10175,"This, us, it won't work."],[10175,10258,"Your career,"],[10258,10345,"my career,"],[10345,10450,"everything is at risk,"],[10450,10645,"and the whole world is waiting for us"],[10645,10733,"to fall apart."],[10733,10870,"Then let them watch."],[10975,11108,"Who cares what they think?"],[11545,11775,"I'm standing right here."],[12312,12395,"Don't go."],[14158,14245,"Blake, I..."],[14395,14458,"I can't."],[14458,14545,"Not like this, I..."],[14562,14645,"I need space."],[14645,14720,"I'm sorry."],[15595,15808,"Please just stay one more night."]],"48":[[212,354,"I'm gonna have the maid"],[354,475,"take care of"],[475,637,"some quarters for you tonight."],[862,900,"Cleo-"],[900,979,"Blake, I..."],[1129,1187,"You..."],[1270,1362,"You can go first."],[1466,1575,"Sit down."],[1787,1975,"Just promise me you won't shut me out."]],"49":[[633,795,"So I guess you've decided to stay?"],[1083,1133,"I..."],[1183,1370,"I never promised anything."],[1583,1858,"Then what was last night?"],[1983,2083,"Just..."],[2308,2495,"Two responsible adults"],[2495,2608,"enjoying themselves."],[2908,3075,"I hate how cold I sound,"],[3120,3308,"but I can't be with him."],[3333,3487,"I'll never fit into his world."],[3550,3595,"OK."],[3737,3808,"So you wanna"],[3895,3945,"do it?"],[5162,5312,"Cleo, I know you're wrapping things up"],[5312,5450,"for your New York transfer today,"],[5458,5583,"but before you go,"],[5637,5795,"I got a request for you to work a day"],[5795,6100,"on a set for a very high-profile actor."],[6158,6283,"Uh, sure."],[6283,6383,"Tell me where to be."],[6433,6683,"And Cleo, I'm sorry I ever doubted you."],[6712,6820,"You did great work here,"],[6845,6995,"even before you met Blake Wilder."],[7070,7200,"Thanks, Julian."],[7883,8062,"This will be your director,"],[8116,8233,"for today, Miss."],[8370,8445,"Vivian?"]],"50":[[37,195,"Just the person I wanted to see."],[233,387,"This coffee needs more sugar."],[387,483,"Tastes very bitter."],[483,583,"I'm with casting,"],[600,800,"not working as your personal assistant."],[833,983,"And this is my set."],[1037,1125,"So you will be whatever"],[1125,1245,"I want you to be today."],[1283,1408,"Unless you want me to contact"],[1408,1520,"your new boss in New York"],[1520,1620,"and have him rescind your offer."],[1658,1858,"I leave for New York tonight."],[1858,1958,"Blake and I are over,"],[1958,2062,"so you can stop trying to"],[2062,2150,"take me down."],[2175,2270,"The problem with that is"],[2270,2358,"I don't trust you"],[2358,2483,"as far as I can throw you."],[2520,2637,"So I will be watching you"],[2637,2758,"very closely today,"],[2758,2870,"making sure that you can't"],[2870,3020,"crawl back to Blake."],[3070,3175,"Wait, did you say Blake?"],[3258,3400,"Vivian, you two are perfect together."],[3433,3587,"Talk about an IT couple."],[4145,4283,"Blake's not going to miss you."],[5283,5333,"Come here."],[5412,5495,"Go sit in that chair,"],[5495,5587,"I'm gonna give you some notes."],[6308,6583,"Okay, so on this beat right here."],[6583,6795,"Your coffee, Vivian."],[6937,7058,"Just put it on the table."],[7945,8112,"Oh God, you are useless."],[8200,8283,"Don't just stand there"],[8283,8345,"and look at me."],[8345,8495,"You can't stain the costumes."],[8495,8583,"Clean it up."],[8733,8883,"She can't even handle coffee."],[8912,9108,"She sure can handle Ross, though."],[9108,9270,"Bitch work assistant blows"],[9270,9320,"up-and-coming"],[9320,9408,"star on set."],[9433,9587,"Guess that's one way to make headlines."],[9720,9787,"Uh,"],[9850,9950,"what the hell is going on?"]],"51":[[54,162,"What the hell is going on here?"],[300,500,"Obviously, Cleo was getting a little"],[500,662,"too cozy with the actor."],[687,804,"I guess that's just her M.O."],[879,950,"I told you,"],[1000,1104,"she moves quickly."],[1204,1362,"Blake, it's not what it looks like."],[1362,1529,"She set me up."],[1716,1900,"I was so cold to him this morning."],[1900,2025,"Will he believe me now?"],[2470,2558,"Thank you."],[2662,2825,"You guys want a story, right?"],[2825,2941,"That's why we're all here."],[2987,3075,"For a story."],[3837,3966,"Then how's this for a story?"],[4000,4075,"And it's the truth."],[4141,4262,"Cleo's with me."],[4362,4400,"Got it?"],[4600,4729,"But I thought that-"],[4729,4837,"Look, I..."],[4937,5100,"I don't want us to separate."],[5150,5204,"Ever."],[5329,5425,"I love you."],[5512,5579,"And Vivian?"],[5637,5787,"She should be the one that's terrified of"],[5787,5950,"the headlines tomorrow, okay?"],[6004,6112,"Up and coming starlet"],[6112,6241,"abuses new assistant,"],[6241,6354,"should be really flashy."],[6354,6450,"I'm proud of you."],[6525,6616,"So you believe me?"],[6804,6875,"Always."],[7091,7191,"Are you still getting on that flight"],[7191,7279,"to New York tonight?"],[7337,7400,"Why?"],[7475,7654,"There's this woman that"],[7654,7791,"I'm trying to win back, so..."]],"52":[[54,191,"You see, there's this woman,"],[241,366,"who I'm trying to win back,"],[366,429,"so..."],[566,641,"And,"],[704,854,"she described loving me one time."],[904,1020,"When she told me, I realized"],[1020,1191,"that's exactly how I felt about her."],[1279,1354,"She sounds like she might be"],[1354,1441,"worth the trouble."],[1666,1758,"Although, if she got into"],[1758,1870,"a little less trouble,"],[1870,1983,"maybe she'd have an easier time"],[1983,2058,"finding a boyfriend."],[2095,2179,"I'm sure you could find"],[2179,2329,"an easier woman to be with."],[2329,2379,"I mean,"],[2395,2641,"you've got dozens of actors and models"],[2641,2829,"lined up to marry you."],[2829,2991,"I don't want any of that."],[2991,3095,"This is all bullshit."],[3204,3316,"Hell, I'd get rid of all of it and"],[3316,3483,"let it all go if it just meant that I..."],[3545,3641,"never lost you again."],[3758,3833,"You really mean that?"],[3891,3995,"Of course I do. I-"],[5366,5466,"I'll still do your movie,"],[5466,5570,"so don't worry about that."],[5629,5754,"But when we wrap,"],[5754,5808,"we should,"],[5875,5908,"you know,"],[5908,5995,"we should go get a villa"],[5995,6145,"in south of France or something,"],[6145,6220,"just you and me."],[6266,6366,"Leave all this behind"],[6366,6504,"where nobody can find us."],[6566,6658,"I like the sound of that."],[6783,6891,"Plus, you still owe me a movie"],[6891,7016,"from four years ago."],[7016,7079,"So..."],[7491,7633,"Wait, wait, love at first sight."],[7670,7879,"Kiss me so they can't see my face, please."],[7941,8079,"That was you!"],[8079,8216,"I knew it!"],[8379,8491,"Why didn't you tell me?"],[8658,8783,"Maybe I wanted you to fall in love"],[8783,8908,"with me all over again."],[9120,9379,"Listen, there's a film festival tonight."],[9404,9558,"It's the Avalon Film Festival."],[9558,9658,"I'm going and you should"],[9658,9729,"come with me."],[9779,9866,"Okay."],[9941,10054,"I just have a phone call"],[10054,10166,"I have to make first."],[10195,10241,"Sure."],[10308,10429,"Cancel my flight to New York."],[10579,10645,"I'm staying."],[11158,11241,"Let's get out of here."],[11241,11266,"Yeah."]],"53":[[100,179,"You ready?"],[300,354,"You got this?"],[600,687,"Oh, shit."],[725,791,"It's Miles."],[812,950,"Sorry I'm gonna take this, but"],[1037,1104,"I'll catch up with you."],[1104,1175,"You go ahead."],[1650,1704,"Hello?"],[2529,2650,"What the fuck are you doing here?"],[2650,2766,"You're supposed to be in New York."],[2837,2987,"Newsflash, Vivian."],[2987,3116,"I don't follow your rules."],[3175,3312,"Blake wants me,"],[3312,3366,"and he doesn't care"],[3366,3479,"what the world thinks."],[3525,3712,"You worthless little bitch."],[3712,3850,"If you don't walk out of here right now,"],[3850,3925,"I will make sure-"],[3925,3991,"You'll what?"],[4275,4512,"You'll make up another fake fling"],[4512,4637,"with Blake in your head?"],[4975,5216,"I apologize for my client's behavior."],[5275,5400,"Clearly she's under a lot of pressure."],[5475,5537,"I thought I was"],[5537,5666,"Blake's PR nightmare."],[5787,5850,"Vivian!"],[5937,6062,"What was that, Vivian?"],[6062,6225,"We do not hit anyone in public,"],[6225,6354,"especially not her."],[6354,6512,"I'm tired of that little tramp"],[6512,6679,"prancing around like she belongs here."],[6679,6762,"Relax."],[6804,6941,"After tonight, she won't."],[7012,7075,"I have a plan."],[7191,7287,"Trust me."],[7579,7637,"Are you ready?"],[7762,7837,"For 10k,"],[7875,8037,"I'll even cry on cue."],[8050,8129,"Wonderful."],[8325,8437,"You selfish,"],[8462,8616,"ungrateful whore."]],"54":[[62,137,"You thought you could just hide"],[137,266,"behind some washed up celebrity?"],[275,429,"I haven't forgot about you, little sis."],[462,650,"Let me go, Carter."],[679,800,"It's not that easy."],[816,979,"See, you bailed on the loan sharks"],[979,1087,"and they hunted me down."],[1104,1262,"Well, payback's a bitch."],[1262,1379,"It was your debt,"],[1400,1479,"not mine."],[1562,1650,"Isn't that the gold digger"],[1650,1791,"that's always chasing Blake?"],[1850,1916,"Cleo!"],[1937,2166,"How could you forget your own family?"],[2304,2429,"Just come home, please."],[2504,2587,"We love you."],[2675,2812,"What the fuck, Carter?"],[2912,2987,"Just making sure"],[2987,3137,"you never work in this town again."],[3166,3337,"But mom's been crying for weeks"],[3337,3491,"and dad's dying."],[3512,3675,"And you're the only one"],[3691,3862,"who can pay for her surgery."],[3862,3912,"Help us!"],[3954,4141,"The tabloids are going to eat this up!"],[4237,4350,"Really, Carter?"],[4362,4500,"All of this just for money?"],[4504,4575,"Can you believe it?"],[4575,4687,"My own sister!"],[4737,4987,"Everything is a transaction to her."],[4987,5062,"Even family."],[5075,5154,"That's so cold."],[5225,5354,"All she does is use people."],[5391,5479,"Her family."],[5525,5625,"Blake Wilder."],[5662,5800,"You should be ashamed of yourself."],[5825,5925,"Enough!"],[6387,6462,"Nobody,"],[6462,6600,"and I mean nobody"],[6662,6787,"insults my girlfriend."]],"55":[[8,145,"Mr. Wilder, is it true that you and"],[145,308,"Vivian St. James are no longer together?"],[320,433,"We never even began."],[583,695,"Where the fuck are you going?"],[950,1033,"You are never,"],[1087,1258,"ever going to hurt her again."],[1295,1370,"Do you understand?"],[1420,1545,"Please, please, Mr. Wilder,"],[1545,1683,"I was just trying to help you."],[1683,1833,"What the fuck are you talking about?"],[1920,1995,"Miles Nash!"],[2033,2158,"He said that he would pay me 10k"],[2158,2295,"if I were to break you two up."],[2441,2500,"Blake, you're not going to"],[2500,2595,"believe this imbecile"],[2595,2708,"over your own publicist-"],[2708,2883,"Oh, shut the fuck up, Miles."],[2950,3033,"Jesus Christ."],[3283,3450,"I want every news media outlet"],[3450,3550,"to understand."],[3562,3708,"I want the two of their faces"],[3708,3858,"in the tabloids tomorrow morning,"],[3858,3925,"so everyone knows"],[3925,4033,"what the fuck you've done."],[4070,4145,"Don't be rash."],[4158,4245,"After everything we've built,"],[4245,4320,"you can't do that!"],[4320,4404,"Please, Mr. Wilder."],[4404,4475,"I would-"],[4475,4620,"No, no, Mr. Wilder!"],[4733,4858,"No, no!"],[5033,5095,"Are you okay?"],[5200,5270,"I am now."],[5350,5412,"Mr. Wilder."],[5462,5550,"Is it official?"],[5550,5733,"Are you and Cleo Marlowe"],[5783,5900,"officially together?"],[5945,6025,"Yes."],[6770,7095,"If Miles can't get rid of her, I will."]],"56":[[129,241,"This is all my fault."],[441,516,"I'm so sorry."],[600,716,"You don't need to apologize."],[816,975,"You protected me again."],[1012,1137,"But I promise"],[1250,1450,"nothing is going to come between us"],[1450,1500,"ever again."],[1600,1650,"Come with me,"],[1750,1887,"to the film premiere tomorrow,"],[1887,1950,"on the red carpet."],[2012,2100,"God, I am never"],[2100,2212,"letting go of you again."],[2266,2404,"And when the right moment comes,"],[2462,2612,"I'll ask her to marry me."],[4137,4241,"You look incredible."],[4325,4562,"Honestly, I can't wait for this to be over"],[4562,4691,"so it can just be me and you."],[4804,4887,"Blake Wilder,"],[4887,4954,"you can't be late for"],[4954,5075,"your own movie premiere."],[5100,5141,"You're right."],[5187,5241,"You're right."],[5300,5462,"You know, Cleo, I haven't always"],[5462,5625,"been the easiest guy to be around."],[5675,5754,"Admittedly."],[5791,5912,"But I don't know, something with you,"],[5912,6079,"it just feels right."],[6237,6375,"I promise I'll be by your side"],[6375,6437,"the whole time."],[6541,6600,"Ready?"],[6725,6787,"Let's go."],[6875,6979,"Blake, Blake!"],[6979,7087,"Blake, Blake!"],[7129,7229,"Right over here, Blake!"],[7229,7312,"Right over here!"],[7312,7391,"Yeah!"],[7391,7525,"Nice, Blake, nice!"],[7891,8000,"One more step..."],[8050,8279,"and your stupid fairy tale ends."]],"57":[[1425,1650,"What I wanted to say earlier..."],[2500,2575,"Look out!"],[2704,2783,"Oh, shit, move!"],[3112,3175,"Blake!"],[3212,3275,"Blake!"],[3362,3429,"Nailed it."],[3429,3562,"Somebody call an ambulance!"],[3616,3716,"Help!"],[3737,3812,"We need help!"]],"58":[[458,587,"Is Blake gonna be okay?"],[645,800,"He has a mild concussion."],[800,945,"He'll be groggy for a few days,"],[945,1025,"but fine."],[1025,1175,"Thank you, doctor."],[1850,1983,"I can't believe"],[1983,2308,"he risked his life to save mine."],[2437,2520,"How's he doing?"],[2700,2850,"Olivia, find the person"],[2850,3087,"that did this and make them pay."],[3112,3275,"We're reviewing all security footage."],[3358,3425,"We'll know soon."],[3495,3533,"Thank you."],[3820,4025,"You have to wake up."],[4025,4212,"I haven't had a chance to say yes."]],"59":[[279,354,"Blake?"],[529,591,"You're awake."],[629,754,"How do you feel?"],[754,816,"I'm..."],[833,933,"I'm okay."],[933,983,"I'm fine."],[983,1158,"The doctor said you need to rest."],[1179,1291,"You have a concussion."],[1483,1616,"Wait, someone tried to kill you."],[1679,1733,"I'm not going to rest"],[1733,1904,"until we put that bitch behind bars."],[2095,2304,"Mr. Wilder, we found footage"],[2304,2566,"of Vivian and Ross rigging the light."],[2579,2654,"And that's not all."],[2691,2816,"Vivian is linked to"],[2816,3045,"drugging Cleo at the VIP club."],[3233,3354,"Do you know who I am?"],[3354,3479,"You have no right to touch me."],[3504,3641,"Blake, can you please?"],[3691,3841,"Do you really think that I would do any-"],[3841,3891,"Vivian."],[4091,4179,"You disgust me."],[4216,4316,"And you're going to rot in prison."],[4370,4529,"Ms. St. James, you're under arrest for"],[4529,4716,"attempted murder and the suspected"],[4716,4833,"drugging of Cleo Marlowe."],[4904,5041,"You can't prove anything!"],[5066,5166,"This is defamation!"],[5166,5241,"I want my lawyer!"],[5258,5354,"We have the footage."],[5408,5504,"You and Mr. Sutherland are going"],[5504,5654,"away for a very long time."],[5716,5829,"No, no!"],[5870,5991,"Get your hands off me!"],[6016,6208,"This...this is not over!"],[6208,6279,"This is not over!"],[6279,6354,"Take them away."]],"60":[[658,825,"I'll be honest, I don't want to rest at all."],[1062,1245,"Now that you and I are finally alone."],[1720,1870,"We'll have plenty of time for that"],[1870,2000,"once you're fully recovered."],[2270,2350,"Hey."],[2658,2758,"I just want you to know."],[3020,3208,"I promise you'll never have to run"],[3320,3408,"ever again."],[3608,3737,"I'll always keep you safe."],[3845,3933,"And I mean that."],[3995,4175,"I'm safe because you saved me, Blake."],[4258,4308,"Thank you."],[4458,4537,"You've changed me."],[4537,4650,"You've made me whole."],[4650,4670,"You've..."],[4812,4995,"You've made life worth living."],[5033,5220,"If you hadn't helped me,"],[5220,5345,"I don't know"],[5345,5462,"what would have happened to me."],[5633,5695,"I love you."],[5783,5870,"I love you too."],[7150,7245,"Cleo Marlowe."],[7433,7562,"Would you marry me?"],[7637,7720,"Yes!"]]}