{"1":[[79,200,"I'm Cleo Marlowe,"],[241,337,"casting assistant."],[412,525,"I need Blake Wilder..."],[612,787,"the biggest star."],[787,875,"What the hell?"],[875,1016,"Mr. Wilder!"],[1062,1175,"I helped him once."],[1212,1300,"Maybe he'll..."],[1337,1462,"return the favor?"],[1837,1925,"She reminds me of that girl"],[1925,2016,"who saved me."],[2812,2920,"How did the paparazzi"],[2920,3025,"find me here?"],[3062,3229,"I have to hide before they get their shot."],[3812,3875,"It's..."],[3887,3975,"him!"],[4062,4195,"Blake Wilder!"],[4670,4770,"Fuck."],[4800,4933,"Oh god."],[4941,5012,"Come with me."],[5012,5100,"I can get you out of here."],[5366,5450,"There's no time."],[5450,5487,"Kiss me,"],[5487,5566,"so they can't see my face."],[5670,5716,"Please."],[6116,6179,"Is that him?"],[6195,6250,"This way!"],[7541,7641,"Thank you."],[7775,7825,"I'm Blake."],[7900,7950,"Uhh..."],[8016,8137,"Oh, you're here for film school."],[8333,8370,"Yeah."],[8370,8425,"How long you've been-"],[8425,8537,"We gotta move, now!"],[8600,8675,"Wait, I'm..."],[8733,8775,"I'm sorry,"],[8800,8891,"I didn't get your name."],[8891,8966,"Maybe I can do a movie"],[8966,9050,"with you one day."],[9050,9129,"I owe you one."],[9158,9195,"It's..."],[9195,9254,"It's Cleo."],[9345,9425,"Cleo Marlowe."],[9566,9720,"Mr. Wilder!"],[9837,9904,"It can't be."],[10275,10379,"You can go ahead and drive."],[10775,10891,"I'm Cleo Marlowe!"],[10891,11008,"Casting assistant!"],[11325,11416,"No, please!"],[13591,13712,"No! Please, I, I..."],[13725,13825,"I work in Hollywood."],[13825,14012,"I just need a minute with Mr. Wilder."],[14029,14200,"You stalkers all say the same shit."],[14241,14350,"No, I'm serious."],[14350,14441,"If you think I'm lying, here."],[14462,14650,"I work as a casting assistant."],[14787,14891,"Nice try, sweetheart."],[15025,15187,"Mr. Blake isn't into catty-"],[15204,15266,"No!"],[15291,15437,"psycho star fuckers like you."],[15475,15587,"Get out of here!"],[16500,16600,"Blake!"],[16600,16712,"Blake."],[16879,16987,"Blake, please!"]],"2":[[0,95,"Blake!"],[133,245,"Blake."],[458,625,"Mr. Wilder!"],[745,870,"Blake, please!"],[975,1037,"No!"],[1091,1183,"No, please!"],[1512,1595,"No!"],[2083,2162,"Julian,"],[2162,2270,"Julian, Julian, Julian."],[2270,2366,"Please, just give me"],[2395,2545,"one more chance!"],[2562,2725,"You had your chance, Cleo."],[2725,2770,"Remember?"],[2808,3000,"You promised to sign Blake Wilder"],[3000,3100,"to lead to our movie,"],[3145,3220,"and you failed."],[3258,3370,"But Blake's the biggest"],[3370,3512,"movie star in the world."],[3512,3720,"I mean, I contacted his agent,"],[3745,3820,"his publicist."],[3870,4070,"I even went to his mansion myself."],[4133,4220,"It's not good enough, Cleo."],[4283,4333,"You're fired."],[4512,4583,"What?"],[4650,4787,"Julian, please-"],[4995,5050,"I..."],[5120,5275,"I need this job."],[5870,5970,"What the hell?"],[6183,6287,"What the hell would I wanna"],[6287,6395,"keep you around for?"],[6470,6583,"Pay up tonight,"],[6600,6795,"or we smash your pretty little face!"],[6845,7020,"I gotta deal with debt collecting goons"],[7020,7175,"smashing up my office,"],[7175,7325,"trying to collect a mountain of debt"],[7325,7483,"that your deadbeat brother owes!"],[7483,7570,"No, Julian,"],[7612,7833,"I swear I'll pay for the damages,"],[7833,7925,"I promise."],[7945,8158,"You forfeit your last month's salary"],[8183,8308,"and your severance check"],[8308,8475,"and I won't press charges."],[8483,8583,"Julian,"],[8583,8737,"I'll convince Blake,"],[8737,8845,"I swear."],[9150,9295,"It's never gonna happen!"],[9295,9370,"Security!"],[9408,9533,"Get her and her stuff out!"],[9533,9587,"Everything!"],[9612,9662,"I don't want to see it!"],[9662,9750,"No! No!"],[9750,9845,"Julian, please!"],[9845,9962,"Please don't do this!"],[9962,10083,"I'll figure it out!"],[10083,10283,"I'll try his personal assistant!"],[10283,10358,"Please!"],[11720,11850,"Baby girl."],[11895,12125,"Promise me you'll follow your dreams."],[12125,12287,"My biggest regret was"],[12287,12458,"not fighting harder for mine."],[12558,12658,"I promise, mommy."],[12762,12875,"Take care of your brother."],[13070,13225,"He's all you have now."],[14208,14408,"If I don't repay that debt, I'm dead!"],[14408,14545,"And so are my dreams!"],[14595,14783,"I need Blake Wilder!"],[15337,15470,"Is this..."],[15495,15608,"what he wants?"],[15670,15833,"Is this how I get his attention?"],[16108,16233,"You're a professional, Cleo."],[16233,16400,"You can't do this!"],[16758,16833,"But..."],[16875,17008,"It might be the only way."],[17454,17645,"Another fake tabloid scandal."],[17708,17854,"When will it end?"],[18295,18370,"What the hell?"],[18875,18933,"Open it."],[19770,19845,"Just for the record,"],[19920,20025,"I didn't order this."]],"3":[[887,970,"You?"],[1033,1112,"We told you to get"],[1112,1212,"the fuck out of here."],[1212,1275,"No, no!"],[1275,1375,"Mr.Wilder, please."],[1375,1475,"I, I just need..."],[1475,1562,"only need five minutes"],[1562,1645,"of your time."],[1662,1733,"Please."],[2295,2345,"What the hell?"],[2583,2729,"It's the girl from last night."],[2729,2770,"Stop."],[2858,2908,"Leave us."],[3262,3337,"Maybe I can do a movie"],[3337,3425,"with you one day,"],[3425,3520,"I owe you one."],[3745,3858,"Does he remember me from"],[3858,3970,"all those years ago?"],[4175,4220,"Wow."],[4450,4545,"You know, you probably"],[4545,4637,"have no idea"],[4637,4795,"how many women are trying to"],[4795,4895,"figure out where I live so"],[4895,4958,"they can come here"],[4958,5087,"and try to get me to sleep with them."],[5175,5258,"But I must say,"],[5345,5483,"this is a first."],[5545,5595,"So,"],[5733,5800,"I'll bite."],[6208,6262,"Go ahead."],[6637,6695,"No."],[6745,6833,"He thinks I'm just another"],[6833,6995,"fame-hungry groupie,"],[7025,7158,"I didn't break into Hollywood"],[7158,7295,"by selling my body!"],[7337,7425,"But if seducing Blake"],[7425,7620,"is the only way to save myself,"],[7708,7783,"then..."],[7833,7925,"Fine."],[9595,9670,"I want you,"],[9808,9895,"Blake."],[10258,10583,"You've been my favorite actor since"],[10679,10800,"forever."],[10879,11045,"At least, that's not a lie."],[11887,11945,"Alright."],[12045,12145,"Okay, stop."],[12145,12170,"What?"],[12170,12295,"I thought this is what you wanted."],[12320,12412,"Listen, miss."],[12412,12558,"You are, you're gorgeous."],[12650,12804,"But I can tell that you're not here"],[12804,12883,"because you wanna sleep with me."],[12920,12987,"Okay?"],[13008,13175,"And you don't know what I want."],[13300,13333,"So,"],[13458,13533,"why are you really here?"],[13533,13595,"What do you want?"]],"4":[[12,87,"Why are you really here?"],[87,162,"What do you want?"],[495,583,"I'm Cleo Marlowe,"],[583,683,"a casting assistant."],[733,908,"I've come to offer you a leading role."],[1025,1158,"You've...A role?"],[1220,1387,"You're here to offer me a role?"],[1525,1620,"Dressed like that?"],[1758,1820,"Let me guess."],[1875,2025,"You've read all about my"],[2025,2150,"romantic scandals,"],[2179,2391,"and you think that I'm the perfect actor"],[2391,2616,"for the sleazy playboy role"],[2616,2775,"in your low-budget rom-com?"],[2804,2845,"Whatever."],[2845,2958,"Well, I can tell you."],[3145,3212,"I'm not interested,"],[3212,3320,"and I'm not your man."],[3320,3445,"So, if you could please."],[3558,3587,"No."],[3587,3700,"Get dressed decently."],[3700,3737,"No."],[3737,3766,"Get out."],[3766,3800,"No."],[3800,3933,"And see yourself out the back."],[3933,3970,"No, no, no, no."],[3970,4029,"I would appreciate it."],[4029,4095,"No, wait."],[4120,4175,"Please."],[4383,4516,"I know you've been snubbed by"],[4516,4683,"the Oscars your entire career."],[4858,4929,"I know you want to be"],[4929,5008,"so much more than a,"],[5037,5170,"a popcorn-screen"],[5170,5295,"movie actor."],[5375,5554,"A tabloid scandal waiting to happen."],[5591,5712,"I work for Reel Vista."],[5945,6045,"I've come to offer you the"],[6045,6150,"ten-million-dollar"],[6150,6358,"leading role in our next prestige drama."],[6400,6662,"It'll change your entire career."],[6662,6770,"It'll make you a legend."],[7016,7091,"How do you..."],[7687,7800,"Is this script..."],[7895,7970,"Is it finished?"],[8050,8100,"Yeah."],[8287,8375,"What am I saying?"],[8375,8500,"This girl waltzes in here and claim"],[8500,8625,"she can save my career?"],[8641,8695,"I don't buy it."],[8695,8795,"You know what, uh,"],[8795,8887,"forget I even said that."],[8887,9033,"Listen, I'm not interested."],[9033,9212,"Wait, no, please, Mr. Wilder-"],[9212,9320,"-I can't take no -So if you could"],[9320,9458,"-for an answer. -please,"],[9537,9675,"and see yourself out the back door,"],[9712,9825,"I'd appreciate it."],[9908,9945,"Thank you."],[10150,10258,"I'm not gonna beg him"],[10258,10408,"to remember his promise."],[10445,10487,"I'm..."],[10533,10620,"not gonna lose"],[10620,10820,"what little dignity I have left."],[11108,11162,"You're right."],[11208,11287,"I'm sorry, I..."],[11420,11508,"should have never come here."],[11583,11662,"Thank you for your time."],[12233,12320,"Who does she think she is"],[12320,12458,"showing up here dressed like that"],[12458,12558,"with her whole..."],[12583,12695,"fake seduction?"],[12820,12908,"Olivia."],[12950,13025,"Hi."],[13083,13233,"Listen, I need you to do a little research"],[13233,13383,"into a Cleo Marlowe."],[13483,13583,"Yeah, I just need to find out"],[13583,13720,"if she is who she"],[13720,13808,"really says she is."],[13937,14000,"Thank you."],[14575,14700,"She must think I'll sleep with"],[14700,14837,"any woman who breathes."],[14937,15100,"That's what everyone thinks."],[15233,15320,"That couldn't be"],[15320,15420,"further from the truth."]],"5":[[233,404,"I thought if I got Blake's attention,"],[420,470,"then,"],[491,670,"I could convince him to take the role."],[708,875,"I have to find another way to keep my job"],[875,1091,"and get those loan sharks off my back."],[1216,1383,"Hey, little sis."],[1529,1629,"Where's my 10K?"],[1708,1891,"Carter, I don't have it."],[1891,1991,"You and those psycho"],[1991,2116,"debt collector goons"],[2116,2254,"already took everything from me."],[2291,2370,"You're going to refuse"],[2370,2516,"to help your own brother?"],[2541,2729,"I've given you every extra cent"],[2729,2883,"I've earned since Mom died,"],[2883,3008,"and you never even treated me"],[3008,3079,"like a sister."],[3129,3304,"You act like I'm your personal ATM."],[3341,3416,"Please."],[3479,3629,"Those guys are after me."],[3629,3716,"After us!"],[3716,3783,"Today,"],[3820,4008,"you're the only one who can help me."],[4079,4320,"I've done everything I can, Carter,"],[4320,4466,"and you've bled me dry."],[4516,4670,"Why don't you get a job for a change"],[4670,4791,"and pay back your own debt?"],[5129,5308,"I don't like your tone, little sis."],[5395,5516,"See, if you don't get me out of this,"],[5541,5729,"I'll blacklist you so hard"],[5729,5833,"you won't even be able to"],[5833,5954,"sweep a studio lot again."],[5991,6045,"Hmm?"],[6116,6279,"I'd love to see you try."],[7104,7291,"Hey, I don't have your money,"],[7329,7591,"but I think I have something better."],[7741,7833,"Sorry sis,"],[7870,8045,"you don't say no to family!"]],"6":[[620,733,"Hey, pretty girl."],[795,912,"Come with us."],[1050,1320,"It's my brother's debt, not mine."],[1320,1400,"You want your money?"],[1400,1483,"Go find him."],[1483,1545,"Oh, no."],[1545,1695,"It's not the cash we're after this time,"],[1695,1787,"sweetheart."],[1908,2112,"Your brother cut us an even better deal."],[2258,2395,"Money dries up,"],[2395,2483,"but a girl like you?"],[2545,2633,"Steady income."],[2708,2858,"We'll get years out of you"],[2858,3033,"before you're too dry to, um..."],[3170,3258,"you know?"],[3408,3595,"Get away from me, you creep!"],[3595,3770,"Hey, come on, play nice."],[3820,3900,"Just having some fun."],[4137,4245,"What the hell is that?"],[4312,4445,"The strongest aphrodisiac"],[4445,4533,"in the world."],[4595,4720,"We always test our merchandise"],[4720,4845,"out first."],[4900,4995,"Don't worry."],[4995,5087,"In a minute,"],[5087,5283,"you'll be begging us to touch you."],[5333,5520,"Just a little taste of what the rest"],[5520,5687,"your life has."],[6358,6425,"Talk to me."],[6458,6633,"So there was a Cleo Marlowe"],[6633,6733,"at Reel Vista."],[6733,6870,"But she was fired yesterday."],[6933,7050,"Sounds like she's a hard worker,"],[7050,7208,"but her boss is a real piece of work."],[7462,7537,"Okay."],[7537,7587,"Thank you."],[7825,7920,"That's why she needed me"],[7920,8008,"to take the role."],[8083,8237,"She wasn't lying..."],[8283,8470,"And I sent her away..."]],"7":[[179,291,"You're sick!"],[691,754,"Fucking bitch!"],[841,916,"Someone, help!"],[966,1075,"Come on, get up. Come on"],[1108,1150,"Go get her."],[1341,1391,"Someone,"],[1441,1491,"help me!"],[2133,2254,"Someone, please!"],[2254,2420,"Help me, help me! Please!"],[2466,2579,"Someone, please!"],[2816,2879,"Cleo?"],[2904,2954,"Blake?"],[2983,3104,"Please, save me!"],[3154,3254,"Hold on, get in."],[4370,4470,"Is that them-"],[4666,4766,"What are you doing-"]],"8":[[191,291,"You see where she went?"],[395,558,"She went this way."],[1958,2062,"I don't think she's here."],[2183,2266,"Let's go over there."],[3254,3341,"Okay..."],[3441,3533,"Ms. Marlowe, would you..."],[3645,3754,"like me to take you home?"],[3754,3820,"We can..."],[3858,4033,"Those men, they..."],[4091,4204,"sprayed me with"],[4329,4383,"something."],[4566,4729,"I'm just really..."],[4904,4954,"hot."],[5266,5370,"Is this the aphrodisiac"],[5370,5466,"I'm feeling?"],[5466,5545,"Or something..."],[5616,5683,"More?"],[5791,5883,"The truth is,"],[5883,6004,"I've wanted Blake Wilder"],[6004,6179,"ever since our kiss four years ago."],[6341,6454,"If you're not feeling well,"],[6454,6541,"let me get you some help, okay?"],[6541,6608,"No, no."],[6666,6741,"I'm okay now."],[6920,7091,"But I want him more than ever."],[7266,7408,"Oh