{"1":[[84,220,"I bring you breaking news"],[220,362,"the seven sons of the Sinclair"],[362,510,"have achieved remarkable success"],[510,640,"in the fields of business,"],[640,704,"medicine,"],[704,787,"academia,"],[787,867,"and more."],[903,1111,"Today they return home in triumph,"],[1111,1275,"inviting the people of Sun City"],[1275,1488,"to celebrate their mother's 50th birthday."],[2471,2544,"Very simple."],[3044,3112,"Time to head home"],[3112,3264,"for Mom's 50th birthday!"],[3315,3500,"Today they return home in triumph..."],[3500,3592,"Their mother must be a"],[3592,3739,"witch of some kind."],[3739,3839,"No way"],[3839,3971,"she is normal with these"],[3971,4079,"kinds of sons."],[4164,4243,"Right, Lena?"],[6007,6160,"High Strategos."],[6471,6545,"I thought I told you to"],[6545,6656,"keep it quiet when you visit."],[6800,7071,"The gifts for your son's Crowning Day are ready"],[7071,7171,"as you requested."],[7204,7295,"Dragon sword!"],[7348,7479,"Jonas will be able to rally"],[7479,7628,"an army one million strong."],[7671,7795,"The trillion-dollar deal"],[7820,7979,"will pave the way for Caleb"],[7979,8120,"to be the richest man in the world."],[8131,8248,"With this wand,"],[8284,8455,"Silas will be the name"],[8455,8639,"every healer looks up to."],[8668,8835,"The rest will be delivered tomorrow"],[8835,8959,"on your birthday banquet,"],[9007,9112,"each one is crafted"],[9112,9236,"to take your sons"],[9236,9372,"to the top of their game."],[9387,9448,"And,"],[9448,9592,"as we expected,"],[9628,9834,"your powers will be returned as well."],[9968,10107,"My boys weren't born geniuses,"],[10107,10251,"but they have passion and drive."],[10307,10459,"They've never forgotten where they came from."],[10484,10623,"As long as I can help them reach the top,"],[10623,10756,"then I've done my part as their mother."],[10779,10912,"High Strategos,"],[10912,11104,"you returned from the battlefield"],[11140,11215,"half dead,"],[11228,11479,"still ran into that fire to save those babies."],[11543,11684,"Lost your power that day,"],[11740,11843,"and your youth."],[11915,12012,"Your back"],[12012,12195,"hasn't been the same since..."],[12371,12456,"That scar..."],[12507,12576,"Tell me,"],[12620,12740,"High Strategos."],[12828,12975,"Was it truly worth it?"],[14931,15125,"I lost Lucas that day in the fire."],[15159,15400,"I could not let it happen again."],[15415,15543,"As long as they made it out of life,"],[15619,15792,"I would suffer a thousand scars."],[15796,16043,"You guided them from the shadows."],[16043,16236,"You're still not going to tell them"],[16259,16312,"the truth."],[16375,16496,"Actually..."],[16571,16689,"It's perfect timing."],[16740,16940,"I can already feel some of my powers returning."],[16975,17136,"At the banquet, I will tell them everything."],[17200,17315,"Then I can finally retire"],[17315,17463,"and live out my life in peace."],[19747,19928,"Had this handmade in Milan."],[19928,20156,"Platinum hand-set stones."],[20156,20312,"Mom deserves something timeless."],[20387,20563,"Mom's back has been acting up a little bit,"],[20587,20712,"so I brewed a healing potion"],[20712,20819,"just for her."],[20859,21000,"Should clear it right up."],[21008,21300,"My trophy for Mother is my precious dragon fang."],[21300,21424,"I am sure she'll love it."],[21424,21540,"Word is,"],[21540,21691,"Collin Cruz,"],[21691,21940,"secondly commander of the Order of Aegis,"],[21940,22080,"is arriving tomorrow night"],[22080,22212,"with our Crowning Gifts."],[22243,22331,"And get this."],[22412,22600,"It is said that the High Strategos"],[22600,22785,"might actually be making an appearance."],[22785,22952,"Nobody has even seen her."],[22952,23036,"She is a legend."],[23068,23100,"Oh, man,"],[23147,23324,"if the Order Leader's really backing us,"],[23324,23436,"it will change everything."],[23436,23619,"It will take us straight to the top!"],[23619,23752,"And mom's gonna flip."],[23752,23812,"Let's get home."],[23859,23918,"Mom's probably been"],[23918,24031,"pacing around all night."],[24956,25070,"It's us."],[25143,25280,"We are your real parents."],[25280,25381,"What?"]],"2":[[8,152,"Boys, she is right."],[152,279,"We are your real parents."],[279,375,"It's right."],[375,624,"25 years ago, we all stood in the"],[624,775,"same hospital room,"],[775,991,"and the woman you call Mom?"],[991,1175,"She is the one who set the fire and"],[1175,1367,"took you while we are all gone!"],[1367,1580,"Talk about our mother like that again,"],[1580,1700,"I dare you!"],[1700,1880,"I know it is hard to believe,"],[1880,2164,"but I swear we're telling the truth."],[2251,2383,"DNA does not lie."],[2383,2464,"Give me that."],[3528,3724,"Find out if I am adopted right now."],[3743,3903,"Sweetheart, you have no idea"],[3903,4100,"what I've been through all these years!"],[4132,4207,"I get it."],[4217,4319,"It's a lot."],[4375,4488,"But once you see this,"],[4524,4620,"you gonna understand."],[4884,4947,"It's Mom."],[5032,5207,"She is no mother of yours."],[5207,5388,"She is a goddamn kidnapper."],[5388,5564,"She stole you from us,"],[5564,5747,"and she brainwashed all of you to"],[5747,5884,"call her Mom."],[5884,6092,"25 freaking years!"],[6092,6184,"No wonder"],[6184,6328,"I always felt like something is off,"],[6388,6576,"like she was hiding something from us."],[6576,6712,"Now that I think about it,"],[6712,6915,"she did used to always sneak off to go"],[6915,7023,"meet people."],[7023,7151,"And whenever I brought it up,"],[7151,7287,"she just brush it off or"],[7287,7371,"change the subject."],[7515,7631,"So, this is it."],[7631,7756,"This is the dirty secret that"],[7756,7861,"she's been keeping from us"],[7861,7992,"this whole time."],[8007,8198,"We have been lied to by that woman"],[8198,8400,"for our entire lives!"],[8712,8931,"Today they return home in triumph..."],[9048,9187,"Those sick children..."],[9187,9271,"fame,"],[9271,9364,"awards,"],[9364,9459,"power!"],[9479,9687,"The heights we could never hope to reach."],[9687,9823,"Let me tell you something."],[9823,10031,"If we planed to bleed these people dry,"],[10031,10292,"we'd better all be on the same damn page."]],"3":[[0,76,"Sweetheart."],[124,304,"I built an empire for you."],[304,436,"Everything I have..."],[436,532,"it's all yours!"],[532,732,"All you have to do is come home with me!"],[732,824,"Wait,"],[824,943,"this feels strange."],[943,1119,"She raised us for 25 years,"],[1119,1232,"we never heard from you."],[1232,1408,"You suddenly show up randomly now."],[1408,1486,"How do we know this isn't"],[1486,1580,"some elaborate setup."],[1580,1764,"I know it's hard to believe"],[1764,2000,"and if you do not want to come home with us,"],[2000,2103,"we understand."],[2103,2232,"She just used you"],[2232,2344,"for her purposes."],[2344,2503,"You were just a tool for her!"],[2503,2587,"But us..."],[2587,2712,"we aged,"],[2712,2800,"we cried,"],[2800,2907,"we worked ourselves"],[2907,2996,"into the ground"],[2996,3119,"just to find you."],[3119,3292,"Because we are the ones who love you."],[3292,3392,"For real!"],[3515,3664,"She played us for fools."],[3664,3767,"And to think we just got her"],[3767,3907,"gifts for her birthday party,"],[3907,4071,"She tore our families,"],[4071,4167,"That's despicable!"],[4167,4288,"Let us make her pay."],[4428,4571,"Boys, don't act so rashly."],[4571,4711,"This bitch looks innocent"],[4711,4760,"but"],[4760,4892,"she is ruthless."],[4892,5071,"If she turns this around,"],[5071,5275,"it will ruin your future."],[5275,5424,"Your mother is right, son."],[5424,5571,"We don't wannad see you get hurt again."],[5571,5688,"I agree with them."],[5688,5928,"Now is not the time to go nuclear, Jonas."],[5928,6039,"Not yet, at least."],[6143,6356,"We can hit her hard at her birthday party,"],[6356,6476,"catch her off guard."],[6515,6759,"Make sure she never recovers."],[7159,7328,"Lena, I gotta say,"],[7328,7404,"I am jealous."],[7443,7576,"Seven sons,"],[7576,7751,"all stars in their field."],[7779,7912,"You really made it!"],[7912,8012,"And now,"],[8040,8251,"with the Order of Aegis leader"],[8251,8379,"backing these boys,"],[8379,8535,"there is no telling"],[8535,8623,"how far they will go."],[8656,8759,"It is all them."],[8759,8835,"They earned it."],[9779,9879,"Freedom!"],[10048,10159,"High Strategos,"],[10204,10381,"the enemy has been crushed."],[10415,10599,"You've led us out of the very depths"],[10599,10740,"of hell and brought peace"],[10740,10906,"back into the world."],[11184,11370,"Fire reached the nearby hospital."],[11771,11951,"My precious boys,"],[11951,12158,"today, I will help you reach the top."]],"4":[[0,84,"Boys,"],[84,184,"you're finally home."],[243,360,"Look at you all."],[360,500,"Why you look so tired?"],[520,695,"You must have been so busy."],[728,775,"Come on."],[824,940,"Let's get you boys some food."],[967,1172,"The party can start now that you are all here."],[1300,1440,"We are not here for your party."],[1719,1923,"We have a very special gift for you"],[1948,2144,"You boys don't need to get me anything."],[2144,2239,"Your health and happiness"],[2239,2451,"are the best gifts I could ask for."],[2451,2507,"Well,"],[2560,2680,"you do not have a choice."],[3728,4003,"Give her a coffin at a birthday party?"],[4003,4311,"She is turning 50, not dropping dead."],[4311,4400,"Jonas?"],[4507,4632,"What is this?"],[4632,4820,"That was the first gift."],[4875,5003,"This is the second."],[5003,5132,"Maternal Severance?"],[5132,5207,"Why?"],[5207,5352,"What do you mean by this?"],[5352,5588,"You are not our mother anymore."],[5752,5988,"I suggest you sign it before Mr. Cruz arrives."],[6020,6170,"Confess the truth you've been hiding"],[6170,6292,"for 25 years!"],[6292,6371,"It'll hurt a lot more"],[6371,6457,"if we have to do it."],[6487,6707,"So, you've found out."],[6720,6820,"Yes,"],[6831,7043,"25 years ago, the hospital caught fire."],[7087,7268,"I heard your cries and I rushed in to save-"],[7268,7359,"You stole us!"],[7371,7540,"You ripped us from our real families"],[7540,7632,"and don't lie because"],[7632,7778,"we know everything!"],[7787,7891,"Stole?"],[7891,8069,"No, your parents abandoned-"],[8069,8171,"Enough!"],[8295,8440,"Shut your filthy"],[8464,8543,"lying"],[8564,8640,"mouth!"],[9000,9156,"Seven Deadly Sins?"],[9156,9331,"We gave you the chance to come clean."],[9448,9523,"You failed."],[9543,9607,"Fine."],[9656,9758,"Now, Let us show everyone"],[9758,9920,"the monster behind the mask."]],"5":[[0,191,"You set fire to the hospital"],[191,300,"and snatched us out."],[300,432,"That was the first sin!"],[500,636,"You preyed on other people's pain"],[636,796,"and separated families."],[796,932,"That was the second."],[1337,1402,"Ig-Nit!"],[1551,1812,"You deceived us all and buried the truth."],[1812,2007,"That's the third sin."],[2007,2276,"Fourth, you feel no guilt."],[2380,2483,"Not even an ounce."],[2483,2560,"Fifth!"],[2651,2816,"You are old enough to know better."],[2860,3017,"But you still chose to be trash."],[3044,3183,"And sixth,"],[3183,3371,"your heart drips with venom."],[3392,3467,"And seventh?"],[3524,3684,"Your evil knows no bounds."],[3720,3939,"Seven deadly sins,"],[3939,4223,"each one enough to kill you a hundred times over."],[4447,4611,"Boys, please."],[4611,4767,"I would never do that."],[4767,4888,"I'm not who you think I am,"],[4888,5011,"but not like that."],[5011,5171,"Still lying to us,"],[5171,5279,"even now."],[5384,5471,"Fine."],[5584,5811,"Today, we're going to completely"],[5811,5907,"destroy you."],[7179,7340,"Recognize them, Lena?"],[8476,8643,"These are your biological parents."],[8656,8807,"Now that we have reunited,"],[8807,8940,"you must be terrified."],[8940,9092,"My conscience is clean."],[9092,9240,"Theirs are not."],[9240,9412,"25 years ago,"],[9412,9535,"they left you to burn."],[9600,9768,"I ran into the fire."],[9776,9909,"I raised you."],[9922,10023,"Bullshit!"],[10087,10222,"You say one more word"],[10222,10376,"I swear I will have my son"],[10415,10523,"put you in the ground!"],[10556,10740,"You are a baby snatcher."],[10792,10912,"A sick arsonist!"],[10948,11131,"Can't believe Lena is the type of person."],[11187,11324,"She couldn't have kids of herself."],[11324,11544,"So, she stole kids"],[11544,11800,"and left seven families in pieces."],[11835,12035,"You are just here to leech off their success,"],[12076,12199,"but you won't succeed."],[12287,12384,"Not while I am here."],[12568,12656,"Watch your mouth,"],[12656,12707,"bitch!"]],"6":[[172,360,"They are twisting everything."],[455,644,"You are my dearest sons."],[732,959,"They do not know me but you do,"],[1003,1059,"don't you?"],[1135,1327,"We know exactly who you are."],[1391,1488,"A thief!"],[1600,1716,"You stole our lives to ride on"],[1716,1912,"the coattails of our successes!"],[1916,2119,"Everything you did was a setup,"],[2119,2405,"bleed us dry so you could live like a queen."],[2439,2603,"You believe them, not me."],[2864,3012,"For the sake of the 25 years"],[3012,3171,"I raised you single-handedly,"],[3264,3379,"if you apologize"],[3432,3511,"and really mean it,"],[3607,3734,"I will forgive you just this once."],[4135,4207,"Forgive them?"],[4284,4415,"You deranged bitch!"],[4415,4586,"You do not deserve apologies!"],[4647,4711,"Don't I?"],[4815,4911,"I fed them."],[4971,5075,"I bathed them."],[5115,5303,"I held them through every fever,"],[5303,5424,"every nightmare."],[5500,5603,"You weren't there,"],[5603,5688,"I was!"],[5756,5875,"Everything they are now?"],[5907,5971,"That's me!"],[5992,6096,"Save it!"],[6096,6239,"You're not the victim here."],[6239,6415,"You raised us on lies."],[6415,6556,"At 25 years old,"],[6556,6692,"I became a commander."],[6731,6892,"I earned my name in blood,"],[6928,7087,"so much so that the High Strategos"],[7087,7171,"recognized me."],[7171,7287,"You think that was you?"],[7431,7607,"Are you out of your fucking mind?"],[7659,7776,"I built an empire."],[7823,8059,"I took our company to the top of the country."],[8059,8171,"And now I am winning the favor of"],[8171,8268,"the High Strategos, about to"],[8268,8412,"become the richest man in the nation."],[8448,8648,"And you think you get credit for that?"],[8707,8823,"You are not just a thief,"],[8864,9012,"you are a goddamn liar."],[9012,9176,"Who the hell do you think you are?"],[9235,9476,"The High Strategos of the Order of Aegis?"],[9659,9764,"A liar?"],[9851,9931,"A thief?"],[10040,10140,"I see."],[10204,10312,"That's who I am to you."],[10364,10451,"What else would you be?"],[10507,10652,"Look at that scar,"],[10684,10803,"those shabby clothes."],[10848,10931,"What makes you think"],[10931,11012,"you deserve to be the"],[11012,11143,"mother of the chosen ones?"],[11204,11315,"Just cut the act!"],[11620,11751,"If this is about money,"],[11879,11964,"here's a million."],[12068,12187,"That should cover whatever it costs"],[12187,12284,"to raise us."],[12307,12393,"And the rest?"],[12412,12548,"Consider it for your funeral."]],"7":[[40,124,"You know, Lena."],[504,579,"Every time"],[748,840,"I look at this"],[1083,1272,"picture-perfect family photo,"],[1483,1588,"behind your"],[1671,1816,"smiling face,"],[2060,2239,"all I see"],[2287,2444,"are lies."],[2596,2876,"And it makes me fucking sick!"],[3071,3343,"And this guardian angel you gave us for protection?"],[3343,3479,"What a fucking joke!"],[4252,4439,"I, Caleb Sinclair,"],[4439,4603,"here by sever all ties with you."],[4628,4771,"You are no longer my mother."],[4811,5077,"You are my sworn enemy until death!"],[5100,5264,"I always knew this day would come."],[5384,5524,"You would find your birth parents,"],[5584,5739,"restart your life with them."],[5867,6022,"But not once,"],[6035,6228,"not in my darkest thoughts"],[6303,6456,"did I ever imagined this."],[6576,6807,"I raised you for 25 years,"],[6887,7035,"and this is the thanks I get?"],[7112,7200,"This is what you want."],[7292,7371,"I will sign it."],[8120,8222,"But don't come crying to me"],[8222,8331,"when it all falls apart."],[9368,9428,"Wait."]],"8":[[8,52,"Stop!"],[112,191,"What now?"],[231,372,"Who said you could walk away?"],[372,500,"You think this all forgives you"],[500,632,"for what you have done?"],[632,808,"You've taken everything from us."],[808,908,"All of us!"],[972,1116,"Ripped us from our families,"],[1188,1359,"wasted our entire lives."],[1416,1527,"So you know what you are gonna do?"],[1527,1667,"You're gonna get down"],[1667,1803,"on your knees"],[1803,1912,"and bow."],[1971,2180,"And beg for our forgiveness."],[2180,2271,"Me?"],[2271,2412,"Kneel to you?"],[2412,2564,"You tore our families apart."],[2564,2832,"Kneeling is the least you can do."],[2832,2955,"Kneel to the boys"],[2955,3092,"I dragged from the fire?"],[3092,3215,"Watch your words, Caleb."],[3264,3428,"You better be ready for what comes next."],[3428,3496,"Save it."],[3496,3603,"Get her down!"],[3628,3811,"You will kneel before us, you old hag."],[3811,3911,"Whether you like it or not."],[3935,4096,"Get on your fucking knees!"],[4315,4467,"Mom, when I grow up,"],[4467,4792,"I'll be a mighty warrior and protect you."],[4792,4907,"I will make lots of money"],[4907,5092,"and I will take care of you, Mommy."],[5264,5511,"We wanna do that, too."],[5564,5835,"We'll always be your best boy, Mom."]],"9":[[143,212,"Son,"],[212,520,"the High Strategos values honor."],[520,691,"But living with this wretch?"],[691,911,"That's a stain on your name."],[911,1080,"You need to get it over with"],[1080,1211,"and kill her."],[1424,1639,"Crowning gifts are almost here."],[1639,1755,"Don't show mercy."],[1755,1860,"Kill her."],[1871,1983,"Prove your loyalty."],[2087,2203,"You know what to do."],[2507,2592,"Do it."],[3920,4135,"Your sins won't be washed away by kneeling."],[4243,4367,"Some debts"],[4424,4592,"must be paid in blood."],[4815,4947,"As your chance,"],[4947,5024,"take it."],[5024,5143,"If you do it yourself,"],[5420,5532,"we might forgive you."],[5532,5632,"Once you're dead,"],[5675,5971,"we'll bury your body with this treachery."],[6356,6487,"Say that again."],[6528,6637,"We'll say it a thousand times"],[6637,6731,"if we have to."],[6792,6904,"Today, you die."],[6904,7079,"Everything you gave us,"],[7079,7228,"we'll give it back."],[7228,7335,"But today,"],[7351,7549,"you end yourself."],[8607,8792,"Well, well."],[8792,8912,"My seven sons,"],[9068,9276,"my seven perfect sons."],[9276,9376,"You hit me."],[9448,9584,"You made me kneel."],[9664,9784,"I took it all without complaining,"],[9784,9968,"knowing you've been misled."],[10004,10092,"But this?"],[10123,10248,"Now you want me dead?"],[10340,10523,"I was ready to hand you the world."],[10523,10623,"But now I see,"],[10651,10784,"see things clearly."],[10843,11104,"You don't deserve a damn thing."],[11292,11364,"Collin."],[11459,11612,"Those seven sons of mine."],[11712,11920,"They're all heartless monsters."],[11920,12012,"They don't deserve a"],[12012,12188,"single piece of the things"],[12192,12300,"of what I've given them."],[12384,12492,"Call off their Crowning."],[12515,12648,"Strip them of everything."],[12664,12748,"Everything!"],[12896,13003,"Oh, please."],[13047,13159,"These were never yours to give away"],[13159,13252,"in the first place."],[13284,13384,"Ridiculous!"],[13408,13537,"The High Strategos herself"],[13537,13700,"arranged these gifts for us."],[13700,13887,"You have no place here."],[13887,13963,"Enough!"],[14219,14343,"This is your birthday party."],[14600,14780,"We're turning it into your funeral."],[14936,15059,"Right on time."],[15175,15259,"Here come my gifts"],[15259,15415,"for my darling sons."],[16756,16863,"Envoy Joe"],[16863,17028,"of the Order of Aegis"],[17028,17319,"has arrived with the seven Crowning gifts."]],"10":[[204,312,"Envoy Joe"],[312,475,"of the Order of Aegis"],[475,771,"has arrived with the seven Crowning gifts."],[1651,1728,"Jonas."],[1728,1828,"Caleb."],[1848,1980,"Our gifts are here."],[1996,2203,"Our boys are locked-in."],[2203,2264,"Power."],[2264,2323,"Fame."],[2344,2432,"All of it."],[2432,2555,"We're hitching a ride"],[2555,2671,"straight to the top."],[2671,2828,"Well, well."],[2839,2986,"The Envoy is here."],[3016,3207,"Let's see how she spins this one."],[3275,3452,"Should be one hell of a show."],[3564,3679,"The Seven are about to"],[3679,3850,"run this whole damn country,"],[3888,4053,"let alone this city."],[4071,4211,"Talking about next level."],[4843,4975,"Didn't you say these were your gifts,"],[4975,5029,"Lena?"],[5079,5132,"Great."],[5188,5252,"Tell the envoy to"],[5252,5392,"pack 'em up and leave."],[5435,5515,"What are you waiting for?"],[5515,5596,"Didn't you hear him?"],[5652,5756,"Bring out the gifts!"],[5784,5911,"Nobody makes a move,"],[5911,6092,"unless she says so."],[6092,6184,"Without me,"],[6184,6371,"you won't dominate a damn thing."],[6480,6566,"What?"]],"11":[[20,200,"You've completely lost it, Lena."],[279,450,"First, you threaten to take away everything,"],[450,548,"and now"],[548,687,"you're spouting nonsense"],[687,779,"in front of the Envoy?"],[840,1035,"If anyone's spouting nonsense,"],[1035,1143,"it's the seven of you."],[1251,1316,"Sir,"],[1340,1419,"this old hag"],[1419,1597,"is disrespecting the Order of Aegis"],[1639,1764,"right to your face!"],[1764,1903,"Aren't you gonna do something about it?"],[1935,2032,"Shut up."],[2400,2467,"Sir,"],[2467,2551,"what are you doing?"],[2576,2683,"We're right here."],[2744,2880,"Just handling that bitch first,"],[2880,2973,"Silas."],[3000,3092,"We'll get our gifts."],[3247,3328,"Just wait."],[3443,3520,"As ordered,"],[3567,3775,"your Crowning Gifts have arrived."],[3775,3900,"They are yours to command."],[3947,4110,"At your command."],[4228,4303,"What?"],[4503,4628,"The gifts are from Lena?"],[4784,4820,"What?"],[6164,6328,"She arranged all of this?"],[6492,6576,"No way."],[6648,6792,"Holy shit!"],[6792,6866,"Don't tell me she's"],[6866,7107,"the High Strategos of the Order of Aegis!"]],"12":[[44,124,"Wait,"],[124,252,"she was telling the truth?"],[451,520,"Now what?"],[544,598,"Relax."],[640,819,"She probably just hired some actors and"],[819,929,"picked up these junk from some"],[929,1043,"movie studio prop bin."],[1227,1480,"Who knew the hot dog lady"],[1480,1590,"had so much clout."],[1683,1739,"What?"],[1780,1948,"You want us to call you the"],[1948,2055,"High Strategos?"],[2132,2216,"I'm sorry."],[2287,2355,"Thank you"],[2451,2564,"for blessing me"],[2564,2696,"with the role of Commander."],[2776,2860,"You should thank me."],[2903,3019,"You'd be nothing without me."],[3019,3136,"Bullshit!"],[3247,3328,"Everything that I have"],[3328,3411,"I fought for."],[3447,3511,"You know that."],[3643,3779,"Who the hell do you think you are,"],[3779,3900,"trying to steal my credit?"],[3932,4024,"Really, Jonas?"],[4152,4315,"You were never cut out for the battlefield."],[4401,4492,"Becoming a Commander?"],[4492,4664,"That was never in the cards."],[4728,4847,"It was me"],[4847,5060,"that tracked down the best of the best,"],[5060,5279,"the Four Capos' own lieutenants and"],[5279,5388,"begged them"],[5388,5471,"to train you."],[5503,5612,"That's the only reason you ever walked off"],[5612,5757,"those battlefields alive."],[5771,5900,"How the hell does she"],[5900,6069,"know about the Four Capos?"],[6084,6203,"You think those"],[6203,6362,"rookie moves of yours are what earned you"],[6362,6451,"the Dragonblade？"],[6476,6559,"The power to"],[6559,6728,"command a million troops?"],[6904,7048,"That's the real deal!"],[7128,7223,"What's next, Lana?"],[7304,7469,"Say you made me CEO?"],[7600,7646,"Caleb."],[7740,7843,"You think you rose to the top"],[7843,8009,"of the business world all on your own?"],[8059,8207,"Without my say-so,"],[8207,8371,"those Wall Street wolves wouldn't've even"],[8371,8530,"picked up your phone calls."],[8592,8741,"And you think the Martin deal was"],[8741,8871,"just handed you"],[8871,9095,"out of admiration for you?"],[9615,9728,"How do you know about the Martin deal?"]],"13":[[32,206,"There's no way that contract"],[206,352,"has anything to do with you."],[352,424,"Silas,"],[424,648,"you never had the healing gift on your own."],[667,779,"I brought in"],[779,1035,"masters from all corners of the world,"],[1035,1143,"shamans,"],[1143,1275,"herbalists,"],[1275,1361,"energy workers,"],[1361,1591,"to nurture you since you were a child."],[1591,1728,"By eight, you were reading auras."],[1728,1844,"By fifteen,"],[1844,2003,"energy healers"],[2003,2127,"whispered your name"],[2127,2280,"like it meant something sacred."],[2280,2419,"Without me,"],[2419,2516,"you wouldn't've even"],[2516,2667,"stepped into that world,"],[2667,2800,"let alone lead it."],[2807,2880,"You..."],[3028,3224,"What a load of crap!"],[3284,3628,"My Lopez bloodline is legendary"],[3628,3766,"in magical medicine."],[3792,3967,"My son got that gift from me."],[3967,4139,"What the hell does any of that"],[4139,4260,"have to do with you?"],[4296,4464,"Everything you have"],[4520,4664,"came from me."],[6132,6293,"Having me as your mother was the"],[6293,6420,"best stroke of luck"],[6420,6659,"your sorry bloodlines could ever have."],[6659,6792,"Without me,"],[6840,7007,"you wouldn't even be footnotes in this world."],[7007,7071,"Enough!"],[7156,7312,"Just 'cause you've got some"],[7312,7443,"insider info"],[7443,7604,"doesn't mean you know jack shit"],[7604,7733,"about our success."],[7748,7868,"Everything that we have,"],[7868,7995,"we earned"],[7995,8156,"through hard work and talent."],[8231,8543,"Not because of some old washed-up bitch."],[8543,8614,"Power?"],[8731,8795,"Talents?"],[8812,8984,"I never needed that in a son."],[8995,9185,"All I wanted was for you all to be happy."],[9220,9338,"But betraying me?"],[9359,9492,"I can't allow that."],[9492,9615,"I'll burn it all down"],[9615,9671,"and take back"],[9671,9887,"every damn thing"],[9887,9987,"I gave you."],[9987,10143,"You dumb bitch!"],[10143,10323,"Big talk for someone who still sells hot dogs, huh?"],[10448,10643,"You think you can touch the Horizon Group,"],[10643,10783,"my trillion-dollar company?"],[10783,10887,"Go ahead!"],[10887,10935,"Try!"],[10987,11095,"As you wish."],[11276,11507,"Tank Horizon Group in sixty seconds."]],"14":[[620,748,"The Horizon Group"],[748,940,"is backed by the Order of Aegis"],[940,1048,"with global assets"],[1048,1219,"and the trillion-dollar Martin deal."],[1280,1378,"You think you can crush that"],[1378,1472,"with a phone call?"],[1472,1623,"Tank his stock"],[1623,1839,"with world-class hot dogs."],[1887,1976,"Come on, Lena."],[1992,2144,"Save the theatrics."],[2144,2400,"This isn't some kind of vertical series."],[2400,2519,"Thirty seconds left."],[2967,3076,"What's going on?"],[3239,3432,"We're under a coordinated short attack,"],[3471,3615,"multiple funds dumping at once."],[3675,3771,"If this keeps up,"],[3800,3916,"Horizon's gonna get nuked"],[3916,4028,"before the opening bell."],[4028,4102,"What?"],[4207,4267,"Caleb,"],[4288,4396,"this bitch is crazy."],[4396,4492,"Make her eat her words."],[4492,4520,"No."],[4588,4724,"She went after my company,"],[4724,4796,"I want her to suffer."],[5339,5375,"Boss,"],[5375,5511,"this is urgent."],[5511,5667,"Horizon's getting hit."],[5667,5735,"Hard!"],[5735,5857,"An unknown party"],[5857,5992,"just crashed our stock."],[5992,6192,"It's been total free-fall."],[6192,6388,"We're already down billions."]],"15":[[80,132,"Jonas,"],[204,287,"my company..."],[416,451,"It's okay."],[451,540,"She's a witch."],[540,659,"It's her game."],[679,744,"Yes,"],[744,867,"this is all a setup."],[867,951,"She's just trying to"],[951,1072,"claw her way to the top"],[1072,1219,"by latching onto us."],[1288,1424,"Latch onto you?"],[1651,1783,"Your little \"successes\""],[1783,1923,"arn't even worth my time."],[1935,2102,"Oh, don't flatter yourself."],[2135,2304,"I've been a natural healing prodigy"],[2304,2500,"since I was fifteen years old."],[2500,2600,"People line up just to"],[2600,2755,"have five minutes with me."],[2787,2954,"And now I'm engaged to the daughter"],[2954,3103,"of the legendary alchemist,"],[3103,3256,"Nicolas Flamel."],[3256,3343,"Soon,"],[3343,3469,"I'll inherit the formula"],[3469,3624,"to his immortality potion."],[3643,3737,"The world's been waiting for"],[3737,3820,"the next Flamel,"],[3867,4032,"and it's going to be me."],[4056,4103,"Please,"],[4103,4271,"I canceled that engagement."],[4271,4411,"The next Flamel?"],[4479,4547,"Keep dreaming."],[4596,4724,"That's delusional."],[4752,4871,"Who do you think you are?"],[4888,5039,"You're not even worthy of saying"],[5039,5200,"Nicolas Flamel's name."],[5307,5371,"I already have"],[5371,5524,"Master Flamel's blessing."],[5532,5800,"Unless the High Strategos herself steps in,"],[5800,6064,"no one's calling off my engagement."],[6079,6435,"A letter from Master Flamel just arrived."],[6576,6692,"Oh, look."],[6728,6835,"It's official."],[6879,7087,"We've already been preparing the wedding."],[7087,7231,"You're all invited, by the way."],[7231,7379,"Clear your calendars"],[7404,7535,"We'll be there."],[7576,7640,"Are you sure"],[7640,7771,"there's still gonna be a wedding?"],[7771,7851,"Oh, yes."],[8220,8348,"What the fuck?"],[9071,9215,"This has to be fake,"],[9215,9323,"you fucking bitch!"],[9323,9407,"If you've done anything"],[9407,9548,"to sabotage my son,"],[9548,9707,"I swear to God."],[10112,10236,"This letter came straight from"],[10236,10392,"Master Flamel himself!"],[10392,10548,"Question it again,"],[10548,10702,"and you'll shame yourself"],[10702,10787,"for blaming him."],[10815,10840,"They..."],[10879,11043,"They called off the engagement?"]],"16":[[0,72,"No."],[72,176,"No, this isn't happening."],[216,408,"Master Flamel respects me."],[428,648,"And Resa said she'd never marry anyone else."],[696,763,"Damn!"],[827,1024,"Maybe this lady's got some pull after all."],[1024,1119,"You've been dumped."],[1172,1256,"Come on."],[1280,1448,"Now, I've seen this before."],[1448,1638,"It is just a little lovers spat."],[1648,1880,"Have you been ignoring Resa lately?"],[1880,1965,"I mean,"],[1965,2212,"I've been busy with the Crowning ceremony."],[2212,2423,"I haven't seen her for the past few weeks."],[2464,2580,"There you go."],[2580,2760,"She just wants your attention."],[2807,3048,"Just say some sweet words,"],[3048,3224,"and she will come around."],[3256,3356,"So,"],[3356,3539,"the witch has been lying."],[3615,3720,"Again!"],[3720,3885,"Lena, I'm sure you've had fun"],[3885,4003,"playing your games and all."],[4003,4111,"But we are sick of it,"],[4111,4156,"and"],[4256,4343,"it's our turn."],[4407,4596,"Your turn for what, Jonas?"],[4639,4707,"Alright, alright."],[4707,4779,"Let's see what you've got"],[4779,4879,"with the bargain basement"],[4879,4984,"skills out of yours."],[5003,5135,"You humiliated me"],[5135,5252,"for the last time."],[5684,5732,"What's happening?"],[5867,6028,"Those weak powers of yours"],[6028,6146,"might scare some rookie,"],[6146,6230,"but not me."],[6300,6360,"Dream on."],[6360,6420,"You bitch!"],[6451,6571,"I've slayed dragons!"],[6704,6851,"You think I can't kill you?"],[6995,7119,"That is Thánatos,"],[7140,7288,"Jonas personal blade."],[7307,7512,"Prepare to die, witch!"]],"17":[[48,128,"Thánatos was..."],[246,331,"It was forged from"],[331,540,"Stygian steel and Basilisk bone!"],[612,696,"How the hell did you-"],[716,913,"A weapon like Thánatos"],[919,1070,"only reveals its power"],[1070,1151,"to the worthy,"],[1151,1235,"the righteous."],[1291,1359,"And you?"],[1359,1475,"You are not even close."],[1839,1939,"Nonsense."],[1967,2132,"She must've swapped the sword."],[2148,2264,"You crazy witch!"],[2264,2344,"I'm gonna kill you!"],[2612,2696,"Mother!"],[2741,2904,"Hey! You bitch!"],[2904,3055,"Nobody scratch my wife."],[3149,3188,"Ugh."],[3288,3332,"Dad!"],[3396,3479,"You!"],[3479,3688,"You've gone too far!"],[3832,3932,"Who's next?"],[4235,4347,"I can do this all day."],[4740,4849,"That was just a warning."],[4871,5028,"I'm already being too generous,"],[5043,5207,"but if you come to your senses"],[5235,5415,"and cut ties with these hypocrites,"],[5535,5674,"I'll take you back to the top."]],"18":[[36,88,"Bitch!"],[108,231,"I see what this is."],[231,404,"You're just trying to turn all of us"],[404,500,"against each other."],[628,696,"Son."],[696,951,"Don't believe a word she says."],[951,1183,"We can handle some losses."],[1183,1283,"Exactly."],[1283,1419,"You've already been recognized"],[1419,1550,"by the High Strategos."],[1564,1689,"No one can touch you now."],[1707,1771,"Jonas."],[1912,2071,"It's all smoke and mirrors."],[2103,2279,"We just reunited with our true parents."],[2316,2471,"We can't trust a word she says."],[2651,2800,"Take us back to the top?"],[2892,2955,"Please."],[3023,3115,"She couldn't even crawl"],[3115,3260,"out of a hot dog cart!"],[3464,3547,"Fine."],[3584,3747,"I gave you one final chance,"],[3747,3915,"and you've decided to waste it."],[3915,4115,"Now, you have to deal with the consequences."],[4264,4343,"Jonas."],[4343,4575,"You are hereby stripped of the title of Commander."],[4575,4784,"The Order of Aegisis is closed to you."],[4784,4864,"Forever."],[5324,5384,"Caleb,"],[5424,5584,"your precious Horizon Group?"],[5584,5656,"Gone."],[5728,5903,"Crushed under your leadership."],[5903,6047,"You're hereby blacklisted"],[6047,6247,"from every corner of the corporate world."],[6468,6564,"And Silas."],[6564,6728,"You call yourself a healer?"],[6815,6920,"Not anymore."],[7020,7259,"Every drop of magic in you is gone."],[7295,7482,"You will never save another life."],[7528,7616,"You won't even be able to"],[7616,7748,"fix a paper cut."],[8362,8442,"And you!"],[8502,8554,"You!"],[8645,8699,"You."],[8810,8892,"And you."],[9807,9976,"In ten minutes, everything you've"],[9976,10195,"built will crumble to dust."],[10195,10423,"And then you will finally see"],[10423,10528,"what's left of you"],[10623,10704,"without me."]],"19":[[176,273,"What a performance."],[283,330,"Bravo!"],[360,432,"You old hag,"],[496,596,"take a good look in the mirror."],[616,688,"You may talk big,"],[688,880,"but still nothing more than a hot dog whore."],[903,956,"We are meeting with"],[956,1103,"the High Strategos tonight."],[1103,1172,"Remember?"],[1172,1283,"And even without her,"],[1283,1351,"the seven of us"],[1351,1522,"run this damn country."],[1531,1612,"What could you do to"],[1612,1742,"possibly break us?"],[1755,1816,"Yeah, unless you are"],[1816,1960,"the High Strategos herself."],[2083,2253,"More like the Hot Dog Strategos,"],[2253,2316,"am I right?"],[2839,2917,"Give it two minutes,"],[2917,3070,"you'll see exactly how this ends."],[3083,3235,"Even if that contract is legit,"],[3239,3423,"you can't crush an entire company."],[3439,3524,"The Horizon Group is"],[3524,3679,"a national powerhouse."],[3703,3739,"And me?"],[3764,3800,"Well,"],[3843,3956,"I am still filthy rich,"],[4056,4175,"untouchable!"],[4196,4271,"Really?"],[4343,4452,"Check your account balance,"],[4452,4547,"see what's left."],[4567,4697,"I'm tired of your bullshit."],[4711,4788,"Get out of here!"],[4788,4843,"Now!"],[4860,4922,"Boss!"],[4992,5149,"It's all fucked."],[5156,5288,"The board pulled out,"],[5288,5430,"the supply chains are dead."],[5452,5607,"We've lost everything."],[5643,5928,"I am talking trillions of dollars of lost."],[5960,6066,"We are bankrupt."],[6200,6279,"Bankrupt?"]],"20":[[56,100,"Bankrupt?"],[304,491,"You've gotta be fucking kidding me."],[512,619,"I wish I were."],[708,859,"A trillion-dollar company"],[883,999,"gone in two minutes?"],[1032,1111,"You are lying!"],[1111,1200,"You have to be lying, liar."],[1200,1275,"I swear, sir."],[1275,1403,"I'd never dare lie."],[1967,2122,"Mr. Caleb Sinclair."],[2128,2228,"As of this moment,"],[2228,2432,"Horizon Group is officially bankrupt."],[2432,2512,"Post-liquidation,"],[2544,2800,"you're liable for a thirty-billion dollar"],[2800,2964,"contract breach to the Martins."],[2964,3044,"Payment is due"],[3044,3119,"immediately."],[3696,3796,"You bastards!"],[3879,4032,"How much is this bitch paying you?"],[4092,4192,"Get out of here, now!"],[4303,4367,"Move!"],[4475,4643,"Why would they listen to you?"],[4643,4800,"Your empire's gone."],[4984,5024,"Son,"],[5147,5335,"it's stamped and sealed."],[5335,5500,"Your company's really gone."],[5567,5691,"No, no, no."],[5691,5748,"There's no way...."],[5748,5810,"There's no way!"],[5843,5903,"It can't be."],[5932,6078,"There is no way I've lost everything."],[6084,6157,"You are not the only one"],[6157,6288,"about to lose everything."],[6731,6768,"What?"],[6879,7040,"They blacklisted me from the Academy!"],[7300,7359,"It's over."],[7628,7708,"We're done."]],"21":[[100,124,"Jonas,"],[316,436,"she really took us down!"],[467,550,"Could she be the one?"],[596,636,"No!"],[687,791,"She must teamed up with"],[791,948,"our enemies to tear us down!"],[964,1160,"This whole thing is a fucking setup!"],[1172,1280,"You think I am scared"],[1280,1454,"because you razed a few empires?"],[1464,1584,"I don't need gold."],[1607,1739,"I don't need armies."],[1755,1871,"I have skill,"],[1871,1944,"rage,"],[1944,2103,"and nothing left to lose."],[2132,2239,"You want war?"],[2260,2435,"Well, I'll give you extinction."],[2515,2657,"Sol Victus!"],[2935,2993,"What?"],[3032,3123,"What's happening?"],[3151,3256,"You're supposed to heal,"],[3256,3339,"not hurt."],[3356,3471,"You turn that gift into a weapon"],[3471,3584,"and it bites back."],[3584,3684,"Best case scenario,"],[3692,3781,"you lose your magic."],[3803,3867,"And the worst?"],[3896,3992,"It eats you alive."],[4003,4088,"Bullshit!"],[4132,4271,"I'll kill you right here."],[4292,4371,"Right now!"],[4371,4500,"Sol Victus!"],[4811,4960,"And the darker your intent"],[4975,5111,"the faster it turns on you."],[5111,5164,"You!"],[5864,5920,"What?"],[5947,6088,"What did you do to me?"],[6188,6267,"Keep trying."],[6292,6412,"Soon, you will be a body"],[6412,6528,"they won't bother to bury."]],"22":[[32,167,"Screw that!"],[167,287,"I don't buy it!"],[783,856,"No..."],[935,1116,"My magic is gone!"],[1188,1235,"You"],[1280,1332,"bitch!"],[1332,1427,"Silas!"],[1912,1996,"Dad!"],[2023,2119,"Help me."],[2419,2455,"I..."],[3000,3123,"I don't wanna die."],[3824,3930,"It hurts."],[4507,4583,"Mom."],[4667,4720,"What?"],[4935,5036,"What did you call me?"],[5120,5199,"Mom..."],[5300,5362,"Please..."],[5560,5679,"Please, save me."],[5864,5967,"Please save..."],[6192,6310,"Save me..."]],"23":[[32,80,"Silas!"],[360,436,"Are you okay?"],[500,583,"Son!"],[583,696,"Are you alright?"],[819,1008,"How dare you poison my son"],[1008,1180,"and then pretend to save him?"],[1208,1405,"Hell of a performance you did there."],[1535,1660,"Son, don't be fooled."],[1723,1844,"You venomous snake!"],[1887,2060,"You raised Silas single-handedly,"],[2060,2203,"and yet you try to kill him!"],[2203,2380,"Is that still what you think of me?"],[2380,2496,"Damn straight!"],[2555,2749,"You tried to murder your own son."],[2816,3019,"It's clear you'll do anything to take us down."],[3083,3203,"As his brother,"],[3203,3375,"I'll deal with this myself."],[3375,3460,"Mother."],[3460,3534,"My weapon."],[3647,3764,"So, that's it."],[3764,3900,"You really want me dead."],[3967,4052,"I do."],[4984,5300,"I fed you for 25 years."],[5300,5475,"I should've save my efforts."],[5520,5652,"You turned out weak, anyway."],[5652,5775,"You!"],[5788,5903,"Finish her, Jonas."],[5924,5988,"Damn it."],[5988,6178,"How is this old woman this strong?"],[6200,6279,"Kill her."],[6315,6428,"Useless."],[7464,7538,"My armor..."]],"24":[[60,187,"That golden armor is meant to deflect"],[187,339,"everything from blades to bullets!"],[400,512,"How the hell did it just"],[596,659,"shatter?"],[659,724,"My armor..."],[748,824,"My tomahawk."],[964,1080,"You bitch!"],[1151,1296,"I'll fucking kill you!"],[2132,2235,"Get my troops."],[2280,2367,"Now!"],[2467,2592,"I want ten thousand men"],[2592,2683,"ripping her apart"],[2683,2796,"limb from limb!"],[2867,2980,"No need for that."],[3012,3252,"The Commander of the Guard is already here."],[3556,3708,"As the Commander of the Order of Aegis,"],[3708,3852,"I order you to kill her!"],[4120,4224,"What are you doing?"],[4356,4456,"Jonas Sinclair,"],[4456,4681,"for betrayal and disgracing the Sinclair name,"],[4711,4884,"by direct order of High Strategos,"],[4896,5092,"you are hereby stripped of your title"],[5092,5203,"and banished from the Order."],[5228,5296,"What?"],[5379,5432,"No!"],[5532,5624,"No, this can't be real."],[5624,5688,"Give me that."],[6307,6388,"Jonas."],[6388,6512,"What's going on?"],[6540,6648,"You must be one of Lena's"],[6648,6731,"puppets then."],[6812,6892,"It's too late."],[6928,7062,"Commander Apollo's on the way."],[7062,7129,"When he gets here,"],[7129,7271,"he's gonna kill all of you!"],[7282,7441,"Isn't Apollo the top commander"],[7441,7607,"for the First Shield?"],[7640,7728,"Collin Cruz?"],[7728,7804,"That's right."],[7823,7943,"And you mess with us,"],[7968,8148,"you mess with the entire Order."],[8187,8320,"You two are done."],[8328,8404,"Apollo?"],[8428,8592,"Collin's lapdog?"],[8607,8859,"He's not even close to being in my league."],[9520,9679,"Who dares show me"],[9679,9823,"such this disrespect?"]],"25":[[80,184,"Commander Apollo."],[256,356,"Finally,"],[391,479,"you're here."],[479,608,"What's going on?"],[608,724,"Sir,"],[724,896,"we were celebrating."],[896,1024,"But this bitch is doing everything"],[1024,1267,"she can to ruin our Crowning ceremony."],[1267,1408,"What did you say?"],[1408,1564,"She said she made us what we are"],[1564,1751,"and even claimed to be the High Strategos!"],[1751,1916,"If that isn't spitting in the face of our legacy,"],[1916,2007,"I don't know what is."],[2007,2051,"And"],[2051,2212,"that's not all."],[2212,2307,"Years ago,"],[2307,2651,"she started a fire and kidnapped our sons."],[2651,2839,"Bring justice down upon her!"],[2839,3019,"Such cruelty."],[3019,3203,"You vile creature!"],[3203,3320,"I demand you kneel"],[3320,3520,"and confess your sins."],[3520,3620,"Now!"],[3620,3745,"You don't have what it takes"],[3745,3843,"to make me kneel."],[3843,3975,"Do you know who I am?"],[3975,4128,"How dare you!"],[4128,4228,"Does that matter?"],[4228,4435,"I wasn't gonna waste my time and energy"],[4435,4675,"on a vile, simple woman like you."],[4692,4864,"But I stand for the Syndicate."],[4864,4964,"Our name"],[4964,5132,"and our power will not be mocked."],[5132,5300,"You've been a Collin's errand boy"],[5300,5384,"for a while now,"],[5384,5447,"haven't you?"],[5447,5615,"Is this how he teaches you to behave?"],[5615,5703,"Watch it!"],[5743,6000,"Collin is the High Strategos's right-hand man."],[6032,6192,"You watch what you say about him."],[6220,6332,"In this country,"],[6332,6484,"yhere isn't a name"],[6484,6635,"I'm not allowed to say."],[6635,6792,"You insolent bitch!"],[6792,6992,"These halls are full of nobles."],[6992,7160,"You think your peasant tongue"],[7179,7279,"is welcome here?"],[7279,7468,"In the Sanchez's name,"],[7468,7607,"we beg you."],[7607,7728,"Kill that bitch!"],[7728,7835,"That's right."],[7835,8076,"Our family stands with the Order."],[8076,8220,"Cut her off for good!"],[8220,8420,"We want her gone for good!"],[8420,9123,"Cut her off!"],[9123,9235,"You see that, Lena?"],[9284,9492,"You pissed off the entire room."],[9520,9659,"You're not making it out alive."],[9659,9835,"We don't usually bully the weak."],[9835,10020,"But when people raise their voice,"],[10020,10192,"justice must be done."],[10192,10323,"We shouldn't waste the coffin."],[10323,10428,"Break her legs,"],[10428,10543,"stuff her inside,"],[10595,10704,"nail it shut."],[10764,10900,"Let her rot in there."],[10900,10976,"Forever!"],[11587,11695,"Collin,"],[11695,11868,"if you are not here in two minutes,"],[11868,12123,"you can say goodbye to being First Shield."]],"26":[[128,212,"Yes, ma'am."],[212,291,"Collin,"],[291,459,"if you are not here in two minutes,"],[459,748,"you can say goodbye to being First Shield."],[840,908,"Step on it."],[908,1000,"We have to be at the"],[1000,1148,"banquet hall in two minutes."],[1619,1876,"Got ten seconds left to enjoy breathing."],[2271,2392,"Still bluffing,"],[2392,2464,"even now?"],[2500,2719,"Do you really think a lowlife like you"],[2719,2932,"could summon the First Shield Collin"],[2932,3071,"with a single call?"],[3379,3567,"First Shield Collin"],[3567,3778,"will be here in two minutes."],[4352,4547,"But not to back you up."],[4547,4792,"He will deal with your death sentence himself."],[4896,4979,"Oh, yes."],[5028,5232,"With the First Shield coming himself,"],[5232,5471,"this bitch is as good as dead."],[5496,5684,"You're a little country rat!"],[5684,5852,"It's a good thing my son is smart enough"],[5852,5996,"to cut ties with you!"],[6160,6271,"Ten seconds left."],[6352,6412,"Still"],[6412,6531,"running your mouth?"],[6531,6684,"Take her down."],[7159,7356,"What the hell do you think you're doing?"]],"27":[[683,740,"Welcome,"],[740,816,"Deputy Colin."],[983,1140,"Welcome, Deputy Colin."],[1219,1319,"You're finished."],[1380,1511,"Deputy Collin is here."],[1739,1896,"I won't repeat myself again."],[1907,2003,"What the hell is going on here?"],[2032,2216,"My apology, sir."],[2244,2415,"Just a little hiccup at the banquet hall."],[2428,2596,"She is the one causing trouble."],[2635,2707,"Jonas,"],[2707,2799,"Deputy Collin is here."],[2844,2935,"Don't worry, Deputy."],[2935,3044,"We're just in the process of"],[3044,3371,"kicking this crazy tramp out."],[3371,3471,"Did you just call her a tramp?"],[3496,3641,"She's our twisted foster mother."],[3641,3843,"We just cut ties with her, so,"],[3843,3921,"feel free to do"],[3921,4032,"whatever you like with her."],[4175,4279,"What's with the coffin?"],[4375,4488,"It is for her funeral."],[4528,4759,"She committed all of the seven deadly sins."],[4779,4867,"They are right there,"],[4867,4996,"in the family photo."],[5584,5723,"That's why you called her a tramp."],[5735,5858,"And on her birthday,"],[5884,5996,"you brought her a coffin."],[6631,6711,"Impressive."],[6779,6890,"Truly impressive!"],[7495,7571,"Thank you, sir."],[7595,7703,"We'll make damn sure"],[7703,7807,"we're worthy of your favor."],[7807,7966,"And these Crowning Gifts,"],[7966,8076,"we're about to receive."],[8235,8343,"Oh, you want your gifts?"],[8423,8531,"Come over here."],[9359,9604,"You ungrateful little shits!"]],"28":[[32,118,"This is your gift."],[118,204,"You like it?"],[204,300,"Here, have another."],[1655,1800,"You treacherous,"],[1800,1987,"heartless parasites!"],[1987,2171,"Cold-blooded bastards!"],[2171,2251,"Sir,"],[2303,2428,"what's the meaning of this?"],[2428,2692,"Your mother gave you everything,"],[2692,2867,"even her lifeblood."],[2867,3187,"And you repay her with betrayal!?"],[3211,3339,"Seven brothers,"],[3339,3615,"and not a single one with a heart!"],[3615,3720,"Disgraceful!"],[3720,3820,"What?"],[3843,3935,"Sir."],[3975,4192,"She's faked the boss's gifts,"],[4192,4320,"and has been running her mouth like"],[4320,4507,"she is the High Strategos."],[4547,4679,"You should go after her."],[4724,4847,"Seriously?"],[4924,5056,"Are you telling me"],[5100,5239,"how to do my job?"],[5239,5315,"No, sir."],[5335,5503,"For the Order of Aegis's Honor,"],[5503,5656,"I'll deal with her myself."],[5735,5835,"I will end her."],[5835,5896,"Now!"],[6143,6252,"End yourself."],[6303,6392,"Sir,"],[6431,6559,"what are you saying?"],[6600,6792,"Do you need me to spell it out for you?"],[6823,6951,"All of you!"],[6968,7284,"You are all blind fools!"],[7300,7515,"The person you are trying to kill"],[7595,7964,"is the most powerful person"],[7964,8159,"in this entire hall."],[8479,8676,"The most powerful?"],[8676,8731,"No, no."],[8731,8859,"It can't be."],[8860,8964,"With all due respect. sir."],[8964,9156,"She is just a hot dog vendor."],[9156,9276,"She wouldn't even be in this building"],[9276,9376,"without a say."],[9376,9523,"How she is so powerful."],[9523,9676,"Shut up!"],[9676,9812,"She's a thousand times"],[9812,9987,"more important than all of you!"],[9987,10184,"You don't even deserve to say her name."],[10312,10392,"Who is she?"],[10392,10500,"Listen up."],[10500,10764,"You slice of excrement."],[10764,10959,"This so-called tramp"],[11031,11159,"that you are mocking—"],[11159,11464,"Lena Sinclair—"],[11923,11992,"is..."]],"29":[[20,119,"Collin, stop."],[119,243,"They don't deserve to know"],[243,368,"who I really am."],[396,500,"Understood."],[500,655,"After what they've pulled,"],[655,740,"they deserve to be"],[740,896,"stripped of everything,"],[896,1040,"begging in the streets."],[1040,1156,"Shit!"],[1156,1339,"That Deputy Collins is giving"],[1339,1572,"that woman actual respect."],[1572,1771,"I guess she really is a big shot."],[1771,1967,"I am not begging on the street."],[1967,2155,"This is all your fault！"],[2155,2287,"I only followed along because"],[2287,2412,"you said those sickly kids"],[2412,2503,"would make us rich."],[2503,2612,"Now,"],[2612,2735,"look at them."],[2735,2887,"They lost everything."],[2887,2976,"And we are"],[2976,3103,"not getting anything either!"],[3128,3211,"Don't look at me."],[3311,3415,"Do something."],[3443,3571,"You can do something."],[3960,4067,"What the hell, Mom?"],[4100,4167,"Lena,"],[4167,4343,"I just gave birth to that guy."],[4343,4515,"I have nothing to do with him."],[4515,4607,"Otherwise,"],[4635,4768,"you can punish him"],[4768,4852,"as you like."],[4996,5107,"You said you love me."],[5156,5196,"Love?"],[5196,5260,"No."],[5303,5428,"I never said that."],[5488,5532,"Did you?"],[5543,5588,"No."],[5652,5720,"You see?"],[5732,5803,"We're done with him."],[5843,5932,"Right."],[6211,6264,"Here."],[6339,6428,"He's yours."],[6443,6500,"Mom."],[6564,6692,"You said you built an empire for me"],[6692,6820,"that I would inherit everything."],[6820,6935,"What empire?"],[6935,7068,"I've got nothing"],[7068,7176,"for you."],[7176,7251,"See?"],[7300,7451,"We're not related anymore."],[7935,7990,"Take him."],[8376,8523,"You can have him, too."],[8523,8735,"Last but not least, please."],[9023,9328,"You all deserve the Parents of the Goddamn Year."]],"30":[[24,128,"Drag them over here!"],[215,672,"-Alright, you heard him. -No. Get off me."],[708,816,"Lena, say the word,"],[816,935,"and they're done."],[1148,1232,"No!"],[1232,1383,"It is not our fault."],[1411,1472,"Please,"],[1472,1591,"spare us, sir."],[1648,1748,"Lena."],[1748,1807,"No,"],[1807,1883,"I mean, ma'am,"],[1883,1992,"you can take the boys"],[1992,2051,"if you want them."],[2051,2223,"But don't punish us!"],[2223,2300,"Boys,"],[2300,2448,"say something!"],[2471,2596,"Help us."],[2609,2769,"Apollo disrespected"],[2769,2964,"the honored guest of the Aegis."],[2964,3060,"You are fired."],[3060,3116,"No."],[3200,3247,"Please!"],[3296,3403,"As for these seven?"],[3435,3479,"Sir."],[3507,3675,"Cut off their resources across"],[3675,3747,"all sectors!"],[3796,3935,"Anyone caught helping them"],[3935,4071,"blacklisted immediately!"],[4096,4232,"Now, get them out of my sight!"],[4252,4292,"Let's go."],[4292,4339,"No."],[5124,5228,"Please, sir."],[5375,5451,"Forgive us."],[6020,6067,"Sir."],[6107,6190,"We know we messed up,"],[6190,6392,"but please have mercy on us."],[6431,6587,"Who the hell are you really?"],[6587,6687,"Why the hell are they listening-"],[6687,6851,"You watch your mouth!"],[6928,7148,"You don't even deserve to be speaking to her!"],[7148,7312,"Who I am"],[7312,7487,"is none of your business anymore."],[7571,7700,"The seven of you,"],[7764,7884,"chasing power,"],[7884,8007,"blind to loyalty."],[8059,8207,"This is what you deserve."],[8259,8315,"What the hell"],[8315,8435,"do you want with us?"],[8435,8607,"You ruined our Crowning ceremony,"],[8607,8768,"turned our families against us."],[8768,8971,"Now you've got the Order of Aegis involved."],[9131,9271,"We won't forget this."]],"31":[[24,237,"Your parents ditched you as soon as"],[237,408,"they found out you had no power."],[455,535,"Cowards!"],[620,696,"You"],[751,956,"old bitch!"],[996,1089,"None of this would've happened"],[1089,1172,"if it weren't for you."],[1172,1411,"You shut your damn mouth!"],[1448,1635,"You ungrateful"],[1664,1719,"brats!"],[1844,2087,"She did everything for you."],[2160,2351,"And this is how you repay her?"],[2351,2458,"You should get down on your knees"],[2458,2632,"and beg for her forgiveness."],[2692,2780,"Or you will lose a lot"],[2780,2907,"more than your pride."],[3132,3171,"What?"],[3200,3252,"Down!"],[3279,3328,"Now!"],[3896,3984,"Collin, let's go."],[4156,4196,"Wait."],[4292,4437,"What about our Crowning gifts?"],[4503,4684,"All you care about are those gifts?"],[4915,5052,"Kneeling to me now"],[5096,5232,"is so you'll still get those"],[5792,5864,"Fuck!"],[5864,6052,"You think you can destroy us?"],[6052,6196,"We'll come back stronger,"],[6196,6407,"and I'll drag you to hell myself!"]],"32":[[212,316,"High Strategos,"],[326,536,"the seven brothers have lost everything,"],[536,675,"and so have their parents."],[775,888,"Should we go ahead and"],[888,996,"completely shut them out?"],[1027,1096,"No."],[1167,1256,"It's enough."],[1332,1447,"They've lost everything."],[1483,1548,"Call the governor,"],[1548,1651,"give them one more chance."],[1796,1903,"Okay."],[2012,2112,"Absolutely."],[2192,2264,"Understand."],[2480,2587,"Brothers,"],[2632,2723,"we are not done yet."],[2751,2839,"That was the governor."],[2860,2987,"Everything that we just saw"],[3016,3116,"was staged"],[3180,3292,"by Lena and Collin."],[3314,3352,"What?"],[3407,3541,"That bitch hooked up with Collin"],[3541,3624,"to ruin us."],[3660,3696,"But,"],[3747,3907,"we're at the top of our game."],[3932,4050,"How could she orchestrate all of this"],[4050,4156,"if she didn't"],[4156,4320,"have something powerful behind her?"],[4320,4388,"I agree."],[4460,4699,"There's no way Collin has that much pull"],[4699,4820,"to bring us down like this."],[4892,5011,"Something is off."],[5028,5111,"I got it."],[5156,5307,"With the real boss out of the way,"],[5307,5398,"Collin thought he could get away with"],[5398,5507,"staging a takeover."],[5571,5684,"He reached out to Lena"],[5684,5828,"for help with this shady little stunt."],[5871,5975,"That must be it."],[6047,6102,"They've been using"],[6102,6228,"the High Strategos's name"],[6228,6328,"to pull this off."],[6335,6470,"And once we rise again,"],[6507,6593,"Collin's position"],[6593,6728,"will be in danger."],[6728,6892,"And Lena knew we'd abandon her,"],[6892,6995,"so she reached out to Collin."],[7028,7148,"That explains everything."],[7215,7404,"How dare they try and get away with that?"],[7480,7539,"Hey."],[7664,7764,"She ruined us."],[7951,8076,"Let's get her back."]],"33":[[56,151,"The first thing we need to do"],[151,351,"is find the real High Strategos."],[408,567,"She'll help us restore our power."],[567,700,"But we've never seen her."],[744,903,"How the hell are we supposed to get near her?"],[903,994,"Don't worry, Mason."],[1027,1188,"She's hosting a return banquet."],[1251,1356,"In three days."],[1391,1472,"See you there."],[1483,1519,"What?"],[1612,1730,"After all these years,"],[1780,1907,"how do we get an invitation?"],[1916,2039,"I've got connections with Head Seth."],[2039,2171,"He's down at the border."],[2171,2251,"He'll get us in."],[2516,2580,"Excellent."],[2712,2787,"It's settled."],[2864,2978,"We'll crash the banquet."],[2978,3221,"We'll expose Lena and Collin."],[3268,3424,"And we'll burn them to the ground."],[4732,4792,"Go ahead."],[4956,5072,"I need some time alone."],[5188,5285,"Yes, Your Grace."],[5988,6211,"Godforsaken brats"],[6211,6325,"She raised them for"],[6325,6585,"25 dakeless years."],[6592,6835,"Now they've all turned their backs on her."]],"34":[[1211,1280,"Slow down!"],[1280,1350,"You'll fall."],[1967,2020,"There you go."],[2020,2083,"You got it."],[2095,2144,"Sit down."],[2152,2228,"Let us help."],[2264,2339,"Okay, okay."],[2919,3012,"That feels good,"],[3012,3080,"right, Mom?"],[3100,3206,"Of course."],[3243,3324,"Thanks, baby."],[3346,3402,"Look at you,"],[3402,3543,"already taking care of your mom."],[3950,4037,"Mom,"],[4037,4274,"why doesn't your face look like ours?"],[4320,4428,"Because"],[4560,4732,"that's what happens when mom gets older."],[4832,5024,"Mom, don't get old."],[5024,5291,"I want to stay with you forever."],[5320,5400,"I'll be a doctor"],[5400,5527,"and keep you healthy forever."],[5547,5611,"Mom,"],[5643,5820,"how long is forever?"],[5835,5920,"Forever..."],[5964,6167,"is a long, long time..."],[6239,6641,"Yeah, that means we get to be with you forever."],[6658,6863,"Yeah!"],[7592,7720,"They come and they go."],[7951,8059,"In the end,"],[8251,8407,"I'm still alone."],[8879,8992,"Lucas,"],[9284,9484,"I miss you so much."]],"35":[[220,335,"We found your mother."],[379,424,"What?"],[959,1048,"It's really her."],[1111,1175,"Mom."],[2107,2167,"Mom?"],[2692,2827,"Mommy is here, sweetheart."],[2976,3083,"Here, drink this."],[3083,3235,"It'll help bring your fever down."],[4556,4724,"It's been 25 years."],[4724,4879,"I wanna know how you've been doing."],[4879,4932,"Sir."],[4932,5103,"They deliberately erased her identity."],[5139,5288,"That's why we couldn't trace her."],[5288,5335,"But,"],[5367,5488,"earlier today news broke"],[5488,5615,"about the Sinclair brothers."],[5639,5728,"Turns out the woman"],[5728,5828,"that raised them"],[5996,6047,"is your mother."],[6056,6111,"What?"],[6164,6300,"They turned on her"],[6300,6456,"at her 50th birthday party."],[6512,6675,"They even tried to force her to kill herself."],[6768,6831,"Bastards!"],[6887,7048,"They'll pay for what they've done to her."]],"36":[[655,779,"Mommy,"],[803,888,"cuddle."],[1111,1159,"Mom,"],[1196,1324,"where've you been?"],[1388,1527,"My tummy's rumbling."],[1680,1823,"Lucas, I'm so sorry."],[2055,2183,"Mommy was too late."],[2364,2496,"It's all my fault."],[3879,4047,"My son's in there!"],[4132,4256,"Lucas!"],[4747,4832,"Lucas,"],[4915,5003,"if only I were able"],[5003,5096,"to save you that day..."],[5224,5415,"You may here now all grown up."],[5611,5792,"I tried to make it right."],[5884,5967,"I thought if I raised"],[5967,6124,"the seven boys like my own,"],[6264,6487,"I could make peace with the past."],[6635,6756,"I was wrong."],[6756,6904,"I was so wrong."],[7000,7187,"I miss you so much..."],[11612,11695,"You..."],[11764,11859,"you're..."],[12028,12123,"you're..."],[12207,12274,"Mom."],[12404,12508,"Lucas?"]],"37":[[56,124,"Is it..."],[396,483,"really..."],[679,748,"Is it..."],[748,848,"Is it really you?"],[1103,1159,"Yes."],[1196,1243,"Lucas."],[1256,1340,"It's me."],[1939,2065,"Lucas, I am so sorry."],[2065,2176,"I couldn't save you."],[2176,2283,"It's all my fault."],[2387,2481,"No, it's not your fault."],[2496,2628,"Someone did this to us."],[2655,2748,"If anything, it's my fault"],[2748,2923,"for not being there for you all these years."],[3016,3107,"You're here now."],[3207,3320,"That's all that matters."],[3435,3516,"What happened?"],[3588,3732,"I was saved by a master."],[3771,3867,"He healed me and..."],[3903,4035,"Taught me everything I know."],[4088,4279,"But I never stopped looking for you."],[4871,4988,"You're home now."],[5047,5155,"That's enough."],[5324,5407,"I can't believe you're living in"],[5407,5515,"a shabby old house."],[5624,5732,"Now, come stay with me"],[5732,5807,"at my villa."],[5807,5900,"I will take care of you."],[6256,6315,"Collin."],[6420,6515,"The return banquet."],[6648,6839,"Plan it for three days in Elysian Heights"],[6879,6989,"Elysian Heights?"],[6992,7123,"Wasn't that the estate gifted"],[7123,7276,"to Young Master Lucas?"],[7313,7391,"You told Luke"],[7391,7568,"to keep it sealed ever since..."],[7568,7687,"Lucas is back."],[7779,7920,"Everyone is going to see him."]],"38":[[124,187,"Sir,"],[187,348,"at your mother's birthday banquet."],[348,496,"the brothers lost everything."],[496,591,"But shortly after that,"],[591,816,"they bounced back like nothing ever happened."],[816,935,"Did you find out why?"],[935,975,"No."],[1027,1091,"Keep digging."],[1132,1265,"And if those bastards show their faces,"],[1265,1356,"I will end them myself."],[1472,1532,"Also,"],[1575,1755,"found footage from twenty-five years ago."],[1832,2032,"Seven brothers' biological parents"],[2032,2176,"conspiring to abandon them."],[2419,2564,"They're all sick, anyway."],[2635,2744,"Let the flames do"],[2744,2828,"what we could not."],[2855,3055,"We can't afford the treatment."],[3092,3254,"It's better they die this way."],[3275,3415,"The fire is getting close."],[3452,3488,"Run!"],[3571,3607,"Run!"],[4460,4656,"My mother took them in."],[4696,4767,"And in return,"],[4767,4878,"they treated her like dirt"],[4878,5013,"on the bottom of their shoes."],[5084,5200,"They'll pay for this."],[5239,5488,"Every single one of them."]],"39":[[608,704,"High Strategos."],[819,903,"Ethan's here too."],[1051,1149,"High Strategos."],[1188,1411,"Here are the DNA test results"],[1451,1559,"for you and Lucas."],[1575,1650,"Please take a look"],[1676,1783,"I knew he was my Lucas"],[1783,1887,"the moment I saw him."],[1900,1976,"Just a protocol."],[2032,2144,"My fairest leader,"],[2144,2283,"the return banquet is all set."],[2323,2428,"All the noble families have"],[2428,2544,"accepted their invitations,"],[2544,2707,"and we screened every guest."],[2707,2803,"No riffraff"],[2803,2864,"will be allowed."],[2900,2967,"Also,"],[3019,3151,"the seven brothers"],[3151,3275,"heard about your return,"],[3311,3484,"and had Head Seth contact me"],[3484,3596,"for a banquet"],[3596,3692,"invitation."],[3711,3771,"It was my fault"],[3771,3852,"they could reach me."],[3852,3903,"Please,"],[3939,4030,"forgive my errors."],[4047,4100,"Forget it."],[4167,4271,"If they're just there to network,"],[4271,4375,"we can ignore them."],[4375,4515,"But if they try anything,"],[4560,4647,"don't go easy on them."],[4760,4860,"Yes, ma'am."],[4884,4966,"My Grace."],[5071,5132,"Here are the clothes"],[5132,5232,"we've prepared for you."],[5900,5939,"Good."]],"40":[[483,571,"The High Strategos is"],[571,705,"supposed to be here tonight."],[744,891,"We wanna make a good impression."],[891,967,"This return banquet"],[967,1100,"is technically invite-only"],[1100,1219,"for the noble families."],[1219,1316,"But since Head Seth"],[1316,1444,"requested your presence,"],[1448,1518,"we made an exception."],[1596,1648,"Grazie."],[1771,1892,"I heard they reopened this estate"],[1892,2048,"just for the High Strategos's return."],[2087,2187,"Once we meet with her,"],[2223,2333,"show her our loyalty."],[2348,2451,"We'll be back on top for sure."],[2851,2923,"Guys, look."],[2960,3092,"What's she doing here?"]],"41":[[279,420,"Do you know where you are?"],[536,683,"How did you even get in here?"],[683,783,"Get in?"],[867,967,"This is my party."],[967,1027,"The city's elite"],[1027,1164,"all came to see me."],[1164,1261,"You and Deputy Collin"],[1261,1340,"lied through your teeth"],[1340,1483,"at the birthday banquet."],[1483,1616,"I thought you were finished."],[1616,1764,"But now, in front of all these people,"],[1764,1896,"you're still acting."],[1992,2135,"I hope you don't think we're scared"],[2135,2296,"because you're dressed up."],[2296,2364,"Last time,"],[2364,2580,"you impersonated the High Strategos,"],[2580,2748,"and now you're here trying to"],[2748,2932,"hijack her return?"],[2987,3180,"You can't stand being abandoned,"],[3180,3279,"so you insist on"],[3279,3415,"dragging us down with you."],[3503,3667,"You flatter yourself too much."],[3667,3896,"This banquet is for the High Strategos."],[3896,4052,"Commander Ethan is on his way."],[4052,4164,"You keep making a scene."],[4164,4284,"Not even Deputy Collin"],[4284,4379,"will be able to save you."],[4379,4439,"Ethan?"],[4492,4543,"That's right."],[4556,4600,"Ethan"],[4611,4830,"is the only apprentice of the High Strategos,"],[4843,4896,"and"],[4896,5071,"he runs the Elysian Heights estate."],[5071,5264,"Even the the Four Great Families respect him."],[5264,5456,"Ethan doesn't tolerate disrespect,"],[5456,5615,"yet here you are"],[5615,5764,"disrespecting him."],[5800,5935,"Take it up with Ethan."],[5935,6028,"He'll tell you this banquet"],[6028,6152,"wouldn't start without me."],[6371,6508,"Why are you still"],[6508,6640,"running your mouth?"],[7328,7468,"Lay one finger on my mother"],[7468,7564,"and I'll end you!"]],"42":[[139,260,"Who the hell are you?"],[260,324,"Jonas."],[2335,2451,"You bastard!"],[2828,2912,"You've got guts"],[2912,3076,"coming after my mother like that."],[3180,3228,"Mother?"],[3771,3825,"You..."],[3979,4111,"You're her real son."],[4111,4279,"She thought you were dead,"],[4279,4409,"which is probably why she"],[4409,4647,"kidnapped us and ruined our lives."],[4647,4752,"Real son?"],[4752,4820,"Are you being fooled"],[4820,4947,"by this woman too?"],[5107,5292,"Even if he is her real son,"],[5292,5371,"so what?"],[5452,5603,"Trash breeds trash."],[5603,5815,"Watch your mouth!"],[6000,6100,"Lena, you better stop"],[6100,6215,"while you're ahead."],[6215,6388,"Just because you have Collin"],[6388,6486,"doesn't mean that you can keep"],[6486,6611,"messing around with us."],[6640,6868,"You came after my mother first."],[6868,7028,"A beatdown is the least that you deserve."],[7028,7235,"This banquet is held for the return"],[7235,7365,"of the High Strategos,"],[7365,7623,"and you two pests are making a mess."],[7684,7792,"Throw them out!"]],"43":[[20,104,"That's my boy."],[412,555,"Where'd you learn power like that?"],[555,700,"You're not worthy of knowing."],[759,880,"Could he be"],[880,1019,"someone important?"],[1111,1172,"No."],[1172,1275,"Don't let him fool you."],[1275,1491,"We have Head Seth on our side, remember?"],[1491,1644,"You think we got to the top on our own?"],[1671,1738,"We have the support"],[1738,1851,"of the High Strategos,"],[1867,2009,"and Head Seth from the Northern Legion"],[2009,2083,"backing us!"],[2116,2319,"Head Seth will be here shortly."],[2319,2486,"I'm sure you'll beg for mercy"],[2486,2571,"when he arrives,"],[2571,2639,"but..."],[2639,2812,"Unfortunately, for you,"],[2812,2964,"it's already too late."],[3076,3155,"Seth?"],[3155,3256,"Yes!"],[3256,3479,"Head Seth of the Northern Legion."],[3479,3652,"He answers to the Grand Marshal."],[3711,3835,"The Grand Marshal defeated"],[3835,4039,"18 gangs single-handedly."],[4039,4143,"He's a legend."],[4239,4384,"I hate to break it to you,"],[4420,4592,"but your legendary Seth"],[4592,4839,"is gonna bow the second he sees me."],[4839,4924,"How"],[4979,5092,"dare you?"],[5292,5352,"Watch."],[5543,5643,"I'll deliver your head"],[5643,5828,"to the Grand Marshal myself."],[5867,5996,"Don't dare lay a hand on him."]],"44":[[48,187,"Don't dare lay a hand on him."],[187,268,"Head Seth."],[343,395,"Welcome."],[451,500,"Lena,"],[540,684,"you could have died with honor."],[691,848,"Instead, you will die with shame"],[848,940,"and pain."],[967,1167,"I'd love to see you try to hurt her."],[1167,1243,"Head Seth."],[1283,1367,"Finally..."],[1396,1544,"This woman right here stole us"],[1544,1699,"from our families when we were young."],[1751,1923,"Now she's here causing trouble with her..."],[1992,2116,"so-called son."],[2200,2323,"We tried to kick them out, but"],[2367,2464,"they have power."],[2516,2680,"We require your assistance."],[2680,2787,"You try to what?"],[2787,2900,"We were defending your honor"],[2900,3076,"when this bastard was running his mouth."],[3116,3267,"He said you should bow before him."],[3267,3343,"Seth."],[3375,3498,"Get over here now."],[3579,3707,"How dare you command"],[3707,3934,"Head Seth with such insubordination"],[3956,4015,"Lena,"],[4015,4231,"look at the trash that you raised."],[4447,4552,"Shut up!"],[4596,4639,"What?"],[4684,4825,"Get out of here."],[4875,4924,"What?"],[4964,5032,"Damn it."],[5032,5139,"What is going on?"],[5192,5275,"I don't know."],[5360,5472,"All I know"],[5472,5739,"is that this bitch and her brat"],[5779,5884,"are gonna get it."],[6712,6850,"At your service, Grand Marshal."]],"45":[[8,48,"What?"],[84,115,"He..."],[148,264,"He's the Grand Marshal?"],[308,407,"The one who single-handedly"],[407,597,"took down eighteen gangs?"],[883,1013,"I can't believe my son"],[1013,1224,"is the Grand Marshal of the Northern Legion."],[1280,1359,"It can't be!"],[1451,1527,"Head Seth,"],[1564,1735,"he's just some bastard kid."],[1735,1844,"Shut up!"],[1987,2023,"Come."],[2023,2083,"Sit with me."],[3000,3071,"Well."],[3151,3332,"Do you have anything to say for yourselves?"],[3379,3415,"Yeah."],[3767,3902,"Who the fuck do you think you are,"],[3902,4008,"sitting on that throne?"],[4020,4167,"That's the High Strategos's chair."],[4171,4256,"You and your son"],[4279,4431,"have no right to touch it."],[4656,4764,"What are you looking at?"],[4839,4984,"You're just gonna let that lady sit there"],[4984,5200,"and defile the High Strategos's chair?"],[5200,5337,"You crazy hag!"],[5347,5532,"You've got a death wish or what?"],[5564,5852,"Don't you have any idea what that seat means?"],[5852,5996,"It's for the High Strategos,"],[5996,6152,"the one everyone bows to!"],[6200,6360,"And who's to say I'm not the one"],[6360,6482,"everyone bows to?"]],"46":[[0,112,"Such arrogance!"],[120,164,"Seth,"],[164,336,"this bitch thinks she can do whatever she wants"],[336,475,"just because she's with Collin."],[512,647,"She's destroyed everything"],[647,747,"and now she dares to get"],[747,903,"the Order of Aegis involved."],[903,1043,"You might be close to Collin,"],[1043,1164,"but you can't touch Ethan!"],[1164,1343,"I won't allow you to bring us to your level."],[1343,1456,"Seth."],[1456,1556,"What are you doing?"],[1556,1648,"Grand Marshal,"],[1648,1776,"I respect you,"],[1776,1900,"but I'm giving you one chance."],[1900,2019,"Get her out of that seat,"],[2019,2164,"or I'm not gonna hold back."],[2164,2248,"She is my mother,"],[2248,2383,"and you're just a soldier."],[2383,2503,"How dare you defy me?"],[2503,2596,"Banquet is starting,"],[2596,2864,"and the High Strategos will soon be here."],[2864,3051,"I can't let you ruin this moment."],[3051,3148,"I may follow orders,"],[3148,3279,"but I don't do it blindly."],[3279,3360,"I do what's right."],[3552,3679,"What do you mean by that?"],[3679,3864,"I'm now a member of the Order of Aegis."],[3864,3988,"You were my commander before,"],[3988,4096,"but not anymore."],[4096,4196,"You picked your side."],[4752,4935,"Don't blame me for what happens next."]],"47":[[44,112,"See? Lena."],[196,279,"It doesn't matter that"],[279,420,"your son is the Grand Marshal."],[536,708,"You both die today!"],[708,1008,"A lowly Solar grunt defying orders?"],[1032,1156,"You've got some nerve!"],[1156,1251,"Damn right."],[1251,1374,"I served the High Strategos's"],[1374,1561,"one and only disciple,"],[1570,1630,"Ethan."],[1644,1728,"And this blade?"],[1783,1951,"The personal gift from him."],[1976,2092,"That rusty thing?"],[2092,2228,"That's the basic sword"],[2228,2444,"all Aegis footsoldiers receive."],[2444,2564,"It's nothing special."],[2564,2671,"No matter."],[2671,2750,"It's more than enough"],[2750,2860,"to end you both."],[2860,3107,"You betrayed the Northern Legion"],[3107,3256,"for that toy sword?"],[3256,3467,"The High Strategos will be returning today,"],[3467,3579,"and I have"],[3579,3675,"her favor."],[3675,3767,"You?"],[3767,3871,"Just a muscle head"],[3871,4047,"with worms for brains."],[4328,4443,"Lena."],[4443,4624,"Ethan will be here very soon,"],[4624,4907,"and all your twisted games will end then."],[4907,5115,"You and Collin will be dust."],[5188,5279,"We'll bring both your heads"],[5279,5365,"to the High Strategos,"],[5365,5543,"and tell her about your fake gifts."],[5620,5747,"Then we'll be back on top."],[5747,5875,"If I don't approve,"],[5956,6037,"none of you would"],[6037,6196,"get a goddamn thing!"],[6228,6347,"Keep running your mouth."],[6448,6536,"You'll see how cocky you are"],[6536,6643,"when you're six feet under."],[6684,6742,"Lucas,"],[6751,6864,"if you kneel before me,"],[6864,6934,"I might"],[6934,7120,"consider giving you a quick death."],[7120,7328,"I taught you everything you know."],[7356,7484,"You really wanna try your skills"],[7484,7584,"with your master?"],[7584,7664,"Not bad."],[7712,7828,"But I have the Strategos'"],[7828,7956,"ultimate techniques"],[7956,8084,"up my sleeve."],[8084,8187,"Ending you"],[8187,8335,"would be child's play."],[8335,8407,"Try me!"]],"48":[[875,924,"Watch out!"],[1880,2012,"You fight dirty."],[2012,2144,"Tactics 101."],[2144,2264,"You said it yourself."],[2264,2464,"Win at all costs."],[2464,2580,"You want dirty?"],[2580,2636,"Try me!"],[2636,2719,"Mom!"],[2719,2778,"It's okay."],[2803,2848,"It's okay."],[2907,2983,"Just go."],[3035,3100,"Don't worry, Lucas."],[3100,3220,"As long as I'm here,"],[3220,3298,"nothing can hurt you."],[3518,3641,"Aw."],[3732,3837,"How sweet."],[3875,4000,"You should thank Seth"],[4000,4096,"for giving you"],[4096,4256,"one last moment together,"],[4256,4407,"because hell is waiting for you."],[4817,4876,"Stop!"]],"49":[[36,272,"You've got some real nerve, Seth."],[335,483,"Drawing blood at this banquet."],[811,866,"Jonas."],[951,1048,"Go greet, Ethan."],[1091,1289,"Catch him up on everything that's happened before"],[1289,1444,"she twists everything."],[1456,1519,"Lena."],[1519,1651,"Now that Ethan's here,"],[1651,1828,"why don't you do the noble thing,"],[1867,2003,"and let you"],[2051,2219,"and your garbage son out?"],[2255,2387,"I'm afraid not."],[2387,2467,"Ethan,"],[2512,2598,"this is the thief that"],[2598,2729,"kidnapped us from our families"],[2729,2860,"when we were babies"],[2860,2996,"We cut ties from her."],[2996,3183,"But after that, she seduced Collin,"],[3211,3373,"and ruined our Crowning ceremony."],[3396,3539,"And she snuck in what you heared—"],[3539,3692,"the High Strategos was returning."],[3728,3856,"And she made a huge scene."],[3856,4084,"She claims to be the High Strategos herself,"],[4084,4225,"your master."],[4260,4515,"And we didn't kill her at the birthday party."],[4547,4747,"Which was a mistake, I'll admit that."],[4784,4896,"But now,"],[4920,5103,"you get to kill her."],[5103,5279,"Well, well, well."],[5435,5614,"You boys really outdid yourselves."],[5624,5708,"Thanks."],[5743,5788,"Ethan,"],[5847,5952,"let me spare you the headache,"],[5952,6075,"and take care of this mess."],[6075,6215,"The only mess here is you!"],[6300,6407,"You seven"],[6407,6607,"stupid jackasses!"],[6763,6817,"Hey!"],[6817,6892,"Asshole!"],[6913,7010,"Lena's the one that's been"],[7010,7124,"causing problems!"],[7207,7271,"Caleb!"],[7300,7423,"Ethan, what are you doing?"],[7543,7656,"I chose you for leadership"],[7656,7820,"because you served under the Marshal."],[7843,7915,"Clearly,"],[7928,8023,"I was wrong."],[8023,8148,"Now, get out of my sight!"],[8207,8374,"High Strategos."],[8892,9048,"High Strategos."]],"50":[[540,751,"The Heads of the Four Families"],[751,908,"bring their gifts."],[956,1188,"The Martin family presents a bronze"],[1188,1432,"war helm from the Temple of Zeus."],[1559,1745,"The Kopeler family presents"],[1745,1948,"a Van Gogh oil painting,"],[1948,2183,"and a thousand year-old jade necklace."],[2183,2355,"The Del Pino family presents a"],[2355,2671,"bottle of 1895 Bordeaux wine."],[2700,2846,"The Bourbon family presents"],[2846,3023,"the royal crown of Hestia,"],[3023,3200,"guardian of hearth and flame."],[3360,3528,"The Four Families greet"],[3528,3743,"the High Strategos's return"],[3743,3956,"to the Order of Aegis."],[4100,4189,"Rise."],[4288,4364,"Strategos?"],[4364,4510,"Why are Ethan and the Four Famiiles"],[4510,4647,"calling her the High Strategos?"],[4647,4828,"No, no, no, no,"],[4828,4919,"it's impossible."],[4919,5011,"You mean the Crowning Gifts"],[5011,5148,"weren't fake?"],[5148,5259,"They were real?"],[5260,5420,"Blind mutts!"],[5456,5654,"The Strategos's position is sacred."],[5667,5809,"How dare you insult her?"],[5896,6035,"How should we deal with them?"],[6152,6292,"I thought I taught you a lesson"],[6292,6451,"in humility the other day,"],[6495,6615,"but no."],[6692,6859,"You continued to cause a fuss."],[6884,7020,"Going after my son?"],[7035,7092,"Seth"],[7135,7235,"is finished."],[7276,7468,"Anyone who dares help him"],[7495,7715,"shall banish from this land forever."]],"51":[[152,196,"No."],[248,356,"High Strategos, please."],[455,628,"I didn't mean to insult you,"],[628,730,"or hurt your son."],[744,910,"Forget your excuses!"],[956,1067,"You used your power"],[1067,1216,"to bully the weak."],[1216,1396,"That is unforgivable!"],[1396,1655,"It is time you lose everything."],[1667,1767,"Don't think"],[1780,2012,"I'm scared just because you're the Strategos."],[2012,2132,"I'll kill you right here,"],[2132,2283,"and take that title from you myself!"],[3183,3292,"Take out the trash."],[3667,3743,"Jonas,"],[3815,3975,"we really screwed up."],[4020,4207,"She really is the High Strategos."],[4207,4296,"No, no, no."],[4360,4446,"We're doomed."],[4471,4635,"No, we still have a chance."],[4671,4834,"She raised us for 25 years."],[4871,4971,"Maybe if we beg,"],[5043,5127,"she'll spare us."],[5996,6183,"Why didn't you just tell us the truth"],[6192,6343,"from the beginning?"],[6343,6592,"Why did you steal us from our families?"],[6604,6792,"We were this close"],[6792,6940,"to being on top of the country."],[6979,7035,"And you took"],[7035,7164,"everything away!"],[7240,7351,"How could you..."],[7351,7608,"I saved you from that fire"],[7608,7856,"and raised you as my own."],[7856,8100,"Everything you have is from me."],[8204,8373,"Did you even consider that?"],[8392,8428,"No."],[8456,8625,"Our real parents would never do that."],[8648,8792,"They would never abandon us!"],[8792,8896,"You burned down that hospital"],[8896,9104,"for your lost son and kidnapped us in revenge."],[9104,9284,"If you don't believe me,"],[9351,9476,"there's nothing left to say."],[9712,9800,"Bring them in."],[10056,10107,"Mom!"],[10192,10243,"Dad!"],[10743,10843,"Take a good look."],[10843,11004,"See for yourselves who abandoned you"],[11004,11123,"and who really loved you."]],"52":[[200,356,"They are all sick, anyway."],[420,524,"Let the flames do"],[524,632,"what we could not."],[632,864,"We can't afford the treatment."],[864,1059,"It's better they die this way."],[1401,1482,"No..."],[1517,1569,"No..."],[1605,1665,"No!"],[1697,1760,"No. Mom!"],[1760,1900,"Tell me that it's not real."],[1932,2012,"That is true."],[2051,2228,"But when the fire broke out,"],[2251,2432,"the ICU became a deathtrap"],[2432,2647,"and you were sick babies"],[2647,2716,"and"],[2716,2900,"we could not afford treatment."],[2960,3023,"So,"],[3039,3128,"we left you,"],[3176,3311,"and we thought you were dead"],[3311,3471,"until we saw the news"],[3507,3779,"about seven sons of Sinclair"],[3779,4007,"and you were famous and rich."],[4020,4143,"And we found the"],[4200,4371,"birth parents of your brothers and"],[4475,4539,"plotted"],[4547,4642,"to reclaim"],[4642,4770,"what was lost."],[5128,5235,"Even if that's true,"],[5311,5396,"you still lied to us."],[5396,5435,"You-"],[5500,5552,"You can't erase"],[5552,5644,"everything we've built."],[5664,5814,"You didn't build"],[5814,5924,"anything on your own!"],[5975,6152,"Everything you had"],[6152,6440,"was because the High Strategos backed you."],[6559,6776,"And this is how you repay her."],[6776,6851,"No!"],[6851,6987,"We didn't know!"],[6987,7140,"Mom, please forgive us."],[7140,7259,"We didn't mean to!"],[7315,7484,"Mom, we're sorry."],[7571,7664,"We were wrong."],[7664,7795,"Mom!"]],"53":[[504,644,"When I found you,"],[755,952,"I wanted to keep you away from that life"],[952,1119,"to protect you from my enemies."],[1164,1327,"That's why I raised you as normal kids."],[1364,1580,"I never thought you'd turn on me so easily"],[1580,1707,"for your birth parents."],[1760,1928,"Maybe that's my failure as a mother."],[2019,2144,"But things end"],[2187,2267,"today."],[3388,3475,"Mom!"],[3567,3685,"It's my fault."],[3724,3767,"Punish me."],[3767,3864,"Don't hurt them."],[4264,4330,"Goddamn."],[4364,4415,"Stop!"],[4628,4679,"Mom,"],[4796,4911,"please don't abandon us."],[4979,5099,"We were fooled, we didn't know."],[5099,5139,"Just..."],[5220,5348,"Please give us another chance."],[5392,5428,"Please!"],[5535,5600,"Please, Mom."],[5664,5692,"I..."],[5692,5779,"I swear,"],[5792,5867,"from now on,"],[5867,6003,"you're the only mother for me."],[6303,6375,"No."],[6412,6515,"It is done."],[6631,6731,"From this day forward,"],[6731,6920,"your lives have nothing to do with me."],[7100,7159,"We're done."],[8356,8510,"How can we be so blind?"],[8751,8907,"We turned our backs on the one person"],[8907,9004,"that loved us."],[9102,9227,"And did everything for those"],[9227,9376,"that left us to die."],[10107,10224,"I guess we really did"],[10224,10392,"bring this upon ourselves."]]}