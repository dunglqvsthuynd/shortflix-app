{"1":[[8,95,"Breaking news."],[108,287,"A Webster Motor car with faulty breaks"],[287,417,"caused a deadly explosion,"],[417,583,"killing three college students."],[583,717,"As the company's silence"],[717,892,"raises questions about accountability,"],[892,1055,"authorities are investigating."],[1055,1159,"God damn it!"],[1267,1359,"Do you see this?"],[1359,1576,"They're calling our car a burning coffin."],[1576,1630,"They act like"],[1630,1793,"we killed those kids ourselves."],[1793,1860,"We need to figure out"],[1860,1943,"why the door jammed"],[1943,2093,"or Webster's going belly under."],[2093,2206,"I hear you, but we've already"],[2206,2352,"dropped $100,000"],[2352,2502,"on diagnostic tests alone."],[2519,2665,"And nothing, nada!"],[2665,2836,"I don't want to hear your excuses!"],[2836,3069,"You're a goddamn Ivy League graduate."],[3069,3249,"I pay you $200,000 a year."],[3249,3374,"Either figure it out"],[3374,3503,"or find a new job."],[3557,3632,"And what the hell"],[3632,3753,"do you think you're doing?"],[3812,3941,"Tinkering around."],[3941,3987,"We have to run"],[3987,4154,"a whole AI diagnostic system"],[4154,4304,"and you're over here fiddling."],[4346,4554,"With all due respect, Mr. Russell,"],[4600,4742,"I know the Webster Corsair"],[4742,4867,"like the back of my hand."],[4888,5030,"I designed this car back in the day."],[5030,5150,"I'll figure out what's wrong with it."],[5150,5267,"We have a million dollar"],[5267,5380,"AI diagnostic system"],[5380,5497,"that can't turn up anything,"],[5497,5609,"but you're gonna figure it out"],[5609,5751,"with a five dollar wrench?"],[5751,5926,"Well, fancy gadgets"],[5926,6147,"and high-minded degrees,"],[6147,6227,"can be important,"],[6227,6356,"but sometimes what you need"],[6356,6464,"is plain old experience."],[6464,6544,"You know what?"],[6560,6623,"Go at it,"],[6623,6702,"I got nothing to lose."],[6702,6810,"But if anything goes wrong,"],[6810,6923,"it's on your ass."],[6923,7011,"Don't worry."],[7048,7161,"I won't mess this up."],[7228,7290,"Let's go."],[8833,8908,"Found It."],[9146,9205,"See that?"],[9259,9351,"It's from a shirt."],[9351,9438,"The car owner must have made an"],[9438,9613,"illegal modification."],[9613,9722,"It snagged on a thread"],[9722,9826,"during the installation."],[9838,10014,"It jammed the latch during impact."],[10039,10147,"Webster's not at fault."],[10210,10306,"You just saved the company"],[10306,10402,"a few million, buddy."],[10481,10556,"Let's go show the boss."],[10556,10668,"You are embarrassing me"],[10668,10744,"and you're embarrassing"],[10744,10810,"yourself!"],[10810,10931,"I think I found the problem."],[11236,11323,"Ah!"],[11323,11436,"You old son of a bitch!"],[11436,11519,"You did it!"],[11519,11678,"Alright, I'm gonna go to the press"],[11678,11857,"and tell the board all the good news."],[11878,12066,"You're a hero at Webster Motor."]],"2":[[204,321,"Attention, everyone."],[321,479,"This concludes today's shift."],[521,650,"Please shut down your stations"],[650,729,"and clock out."],[729,938,"Drive safe and we'll see you tomorrow."],[1559,1659,"Oh, Mr. Walker."],[1672,1772,"Can I have a word?"],[1810,1897,"Oh."],[1939,2035,"Of course."],[2840,3048,"This is a car my nephew got"],[3048,3132,"from his grandmother."],[3190,3328,"It's a collector's item,"],[3328,3490,"which means it's one of a kind."],[3490,3632,"And you're the only one I trust to fix it."],[3632,3695,"It's funny."],[3695,3858,"Last week it was a plane."],[3858,3978,"This week it's a car."],[4083,4170,"Your nephew sure likes"],[4170,4270,"to break things, huh?"],[4337,4421,"They're just messy."],[4421,4479,"Teenagers."],[4479,4508,"Yeah."],[4508,4587,"Tell me about it."],[4629,4771,"My daughter was the same way."],[4842,4963,"I can have it back to you tomorrow."],[5038,5088,"Great."],[5121,5205,"Here's your payment,"],[5238,5351,"$100,000."],[5538,5622,"Miss Wolff."],[5663,5764,"It's an easy fix."],[5764,5864,"You don't have to pay me."],[5989,6068,"Good to see you."],[6068,6243,"Oh, Hank, wait."],[6560,6702,"Hank, wait."],[7069,7203,"I'll be straight with you, okay?"],[7203,7273,"You've been at Webster"],[7273,7394,"for forty years."],[7394,7565,"You know cars."],[7565,7695,"You're one of the best engineers"],[7695,7803,"in the world."],[7803,7899,"But they treat you worse"],[7899,7970,"than the mechanics"],[7970,8074,"that work for an hourly rate."],[8229,8375,"Why don't you come work for me"],[8437,8521,"at Mach 15?"],[8521,8683,"We're developing a new supercar,"],[8683,8804,"Silver Lynx Model A."],[8804,8917,"And I want you to be in charge."],[8938,9196,"The starting pay is ten million dollars."],[9275,9421,"That's a lot of money."],[9471,9659,"But you said so yourself, Miss Wolff."],[9809,9976,"I've been with Webster Motors"],[9976,10076,"for forty years."],[10105,10268,"And any time I have remaining,"],[10301,10443,"I just assume it'd be with them."],[10510,10577,"Old mucks like me,"],[10577,10739,"we're, we're the backbone"],[10739,10844,"of Detroit's industry."],[10844,11006,"And you got a good job on your hands"],[11006,11236,"and you should give it to a youngster."],[11257,11578,"As for me, I'll just stick to toy cars."],[12103,12274,"Hey, look who's early."],[12383,12487,"Hey, Hank, how you doing, man?"],[12487,12520,"Good."],[12520,12595,"Oh, hey."],[12641,12700,"Hank."],[12733,12929,"Here comes the Tom Norris."],[12975,13058,"You reckon he's here to give"],[13058,13146,"us our bonus?"],[13221,13292,"I doubt it."],[13388,13442,"Move."],[13463,13596,"Move, move, move, move."],[13596,13684,"Alright, alright, alright."],[13684,13805,"Hey, listen up."],[13855,13980,"I have an announcement."],[14009,14159,"Webster Motors has gone through"],[14159,14276,"a change of hands."],[14297,14410,"We've been purchased"],[14410,14543,"by Tessolux."],[14852,15169,"Yes, that Tessolux, the EV car company."],[15169,15294,"So our big man upstairs"],[15294,15557,"is now some guy named Elon."],[15557,15782,"Tessolux is a tech company."],[15782,15970,"Big emphasis on tech."],[15995,16287,"So all you boomers, you're fired."]],"3":[[0,100,"You're fired!"],[141,208,"What? Wait."],[241,387,"Wait, what? - Wait, wait, wait."],[521,638,"We're all fired?"],[725,834,"That can't be right."],[863,900,"Oh?"],[900,1046,"You need me to spell it out for you?"],[1046,1105,"Fine."],[1172,1322,"Webster Motors has purchased"],[1322,1568,"a cutting edge AI detection system"],[1568,1922,"from Apex AI for over ten billion."],[1943,2072,"And let me tell you,"],[2072,2181,"this software makes"],[2181,2318,"all of you has-been boomers"],[2318,2510,"look like a bunch of fucking amateurs."],[2569,2786,"It'll do more for this company"],[2786,2886,"in 10 minutes"],[2886,3061,"than you could do in 10 years."],[3123,3299,"So, go home."],[3336,3474,"Wait for death to come knocking."],[3595,3661,"No, whoa..."],[3661,3732,"No, hold on."],[3732,3903,"That ain't right."],[3903,4091,"Look, we are the backbone"],[4091,4270,"of Webster Motors, right?"],[4270,4362,"We built this company up"],[4362,4483,"from the ground."],[4483,4575,"Hell, some of us were here"],[4575,4688,"before Webster was."],[4688,4792,"You can't just let us go."],[4792,4963,"That is, is, is workplace"],[4963,5125,"discrimination, right boys?"],[5130,5234,"Yeah! Right!"],[5234,5347,"We're gonna fucking sue you!"],[5355,5597,"Well, it's not ageism if you're just bad."],[5597,5780,"We're a tech company now."],[5801,6026,"We need computer people who write AI"],[6026,6197,"that does what you do,"],[6197,6418,"but they do it better and faster."],[6460,6535,"Face it."],[6556,6731,"This is the 21st century."],[6731,6848,"Everything is fast,"],[6865,6956,"and digital."],[6969,7127,"It's time for you washed up old farts"],[7127,7432,"to pack your little bags and fuck off."],[7465,7536,"Because like it or not,"],[7536,7645,"you've been replaced."],[7645,7832,"I might not know anything about AI."],[7899,8041,"But I do know one thing."],[8066,8299,"These machines here, they're finicky."],[8299,8433,"And unless real people"],[8433,8504,"are monitoring"],[8504,8683,"the assembly line at all times,"],[8683,8808,"it's only a matter of time"],[8808,8950,"before something goes boom."],[9096,9246,"And all production stops."],[9246,9309,"That's right."],[9405,9471,"What do you mean"],[9471,9559,"everything goes boom?"]],"4":[[20,208,"I've worked here for 40 years."],[254,375,"I know these machines."],[392,521,"They need to be checked on"],[521,617,"and re-serviced."],[617,834,"Otherwise, you're gonna lose billions."],[834,1021,"Oh, okay."],[1021,1247,"So, so, so you're saying"],[1267,1359,"the reason that"],[1359,1572,"I can't fire you old fucks"],[1584,1701,"is because I need someone"],[1701,1860,"to watch the machine all day"],[1860,1947,"or it's gonna go boom?"],[1947,2006,"That's right."],[2006,2089,"And you better make sure"],[2089,2193,"they have the experience"],[2193,2302,"to know what they're looking for."],[2302,2540,"Oh, holy fuck!"],[2573,2727,"You're a real fucking shameless one,"],[2727,2794,"you know?"],[2819,2894,"I know you won't be able"],[2894,2990,"to get another job,"],[2990,3044,"but that doesn't mean"],[3044,3178,"you can make shit up either."],[3178,3345,"I'm not making anything up."],[3411,3549,"I'm telling you how it is"],[3549,3670,"based on my experience."],[3670,3724,"Alright."],[3724,3845,"Old man, I gotta go."],[3845,3899,"Alright?"],[3949,4133,"But don't think you're anything special"],[4133,4237,"because of yesterday."],[4237,4375,"I downloaded the source code"],[4375,4546,"from the diagnostic test myself"],[4546,4779,"and that car was perfectly fine."],[4817,4988,"You lucked out with that screw."],[5005,5238,"So all you need to do is go back"],[5238,5426,"and rot in hospice."],[5459,5501,"No, no, no."],[5501,5622,"How dare you?"],[5630,5705,"How dare you?"],[5705,5922,"We built this city with our own hands."],[5922,5989,"We are the ones"],[5989,6135,"that brought industry to Detroit."],[6135,6181,"Yeah."],[6181,6331,"We did all that hard labor"],[6343,6435,"so kids like you"],[6435,6602,"could go run off to college."],[6614,6660,"And now this is"],[6660,6752,"how you're gonna treat us?"],[6785,6852,"Shut up."],[6877,6965,"Shut up!"],[7007,7228,"You disgusting old fucking hicks."],[7257,7369,"Or I'll call the cops."],[7432,7565,"As of now, you're fired."],[7603,7753,"So this is trespassing."],[7795,7857,"Tom."],[7949,8041,"You need to tell"],[8041,8170,"the assembly line supers"],[8170,8291,"about the maintenance."],[8299,8383,"If something happens"],[8383,8479,"to one of these machines,"],[8479,8650,"it's gonna cost Webster millions."],[8650,8825,"And it's a safety hazard."],[8825,8958,"I do not give a fuck"],[8958,9104,"about your experience."],[9104,9313,"That is all subjective bullshit."],[9330,9588,"We have the cold hard facts right here."],[9601,9805,"Our new AI detection system"],[9805,9930,"will be fully operational"],[9930,10085,"in a few short days."],[10085,10147,"You really think"],[10147,10410,"it can't handle a few finicky machines?"],[10410,10577,"It'll have them back in tip top shape"],[10577,10727,"before you old schmucks"],[10727,10848,"can even get your gloves on."],[10906,11065,"Now hurry up and scram"],[11065,11290,"or you can forget about"],[11290,11457,"your final fucking paychecks."],[11886,11991,"It's alright."],[11991,12112,"It's alright, let it go, okay?"],[12112,12237,"Look, you warned him plenty"],[12237,12366,"about the assembly line, huh?"],[12370,12508,"It's his own fault now"],[12508,12595,"if he won't listen."],[12746,12829,"Come on fellas, let's go."],[12829,12900,"Let's get out of here."],[12937,13033,"That guy's a creep."],[13096,13267,"What do you mean you can't fix it?"],[13284,13480,"I pay you millions of dollars for what?"],[13526,13638,"Mach 15 is on the line"],[13638,13713,"and if you can't fix it-"],[13713,13826,"Miss Wolff! Miss Wolff!"],[13847,13968,"Can't you see that I'm on the phone?"],[13968,14093,"Webster Motors just fired"],[14093,14180,"that old car mechanic"],[14180,14293,"you told me to keep an eye on."],[14464,14535,"I'll call you back."],[14602,14823,"They fired Hank Walker?"],[14877,15098,"Evelyn, I need you to find him."],[15098,15211,"Our CNC mills just suffered"],[15211,15290,"a critical error"],[15290,15440,"and he's the only one that can fix it."],[15448,15603,"Make sure he gets here, okay?"],[15603,15682,"We need him!"],[15682,15732,"Got it, boss."],[15732,15861,"I'll, I'll offer him a job."],[15861,15986,"What's the pay ceiling?"],[16095,16178,"There's no ceiling."],[16232,16362,"We're paying him whatever he wants."],[16549,16733,"I'll have you, Hank."]],"5":[[0,133,"Hey, I'll catch up with you, Hank."],[421,600,"Hi, I'm looking for a Mr. Walker."],[617,696,"Who, Hank?"],[696,809,"Yeah, you just missed him."],[809,930,"He went to go see his daughter."],[1192,1301,"Grandpa!"],[1797,2010,"Grandpa, I missed you so much."],[2010,2156,"I didn't even get to play with you"],[2156,2344,"all last the whole week."],[2344,2481,"I know, kiddo."],[2481,2640,"Your grandpa was busy at work."],[2669,2882,"But, I'm gonna have a lot more time now."],[2902,2994,"I can come over every day"],[2994,3061,"if you want."],[3061,3090,"Yay."],[3094,3157,"Yeah?"],[3378,3490,"Oh, you're getting strong."],[3495,3545,"Dad!"],[3645,3745,"Shouldn't you be at work?"],[3828,3928,"I'm actually"],[3928,4004,"not gonna be"],[4004,4112,"working there anymore."],[4112,4320,"Webster laid me off."],[4320,4416,"You got fired?"]],"6":[[20,79,"Fuck!"],[187,246,"What are we gonna do"],[246,346,"about the mortgage now?"],[379,467,"Mortgage?"],[487,583,"What are you talking about?"],[583,721,"The mortgage for this house,"],[721,855,"you stupid old fuck!"],[871,950,"Helen and I have been"],[950,1026,"using your paycheck"],[1026,1146,"to pay off the mortgage."],[1146,1255,"What are we gonna do now?"],[1255,1380,"They're gonna foreclose on us."],[1380,1459,"Hey, Jesse."],[1488,1639,"I've been giving you my paycheck"],[1639,1839,"since you and Helen got married."],[1839,1956,"Why isn't the mortgage"],[1956,2039,"paid off yet?"],[2068,2248,"Because a whole year's worth"],[2248,2360,"of your salary"],[2373,2444,"didn't even last me"],[2444,2598,"a single night in Vegas."],[2623,2744,"So you were gambling it?"],[2852,3069,"I bust my back ten hours a day"],[3069,3153,"and what?"],[3153,3261,"You gambled it all away"],[3261,3399,"in one night on craps?"],[3399,3465,"Poker?"],[3507,3649,"I can't believe you two."],[3649,3766,"Alright, I've given everything"],[3766,3845,"for you guys."],[3845,3970,"I stopped drinking coffee"],[3970,4041,"for you, alright?"],[4041,4408,"I, I barely scrape by on $300 a month"],[4408,4646,"and you flush it down the drain gambling?"],[4775,4971,"Look, old man, I don't care."],[4971,5138,"But Helen and I need the money"],[5138,5284,"to pay off the mortgage."],[5284,5417,"And until you get another job,"],[5417,5618,"I want you to stay away from Audrey."],[5726,5935,"No, Grandpa!"],[6031,6131,"What's gotten into you?"],[6131,6468,"Jesse, I'm near retirement, okay?"],[6573,6664,"What's an old man like me"],[6664,6752,"supposed to do?"],[6852,7073,"You and Helen and little Audrey,"],[7073,7228,"you guys are all that I have."],[7248,7399,"I just want to see this little girl"],[7399,7486,"grow up, okay?"],[7586,7645,"Please."],[7732,7857,"I already lost my wife."],[7857,7991,"Don't talk about my mom."],[8078,8233,"If you weren't so stubborn,"],[8233,8370,"if you would have just left Detroit"],[8370,8470,"when you had the chance,"],[8479,8546,"she would have had"],[8546,8637,"better insurance coverage"],[8637,8687,"and not"],[8733,8775,"die."],[8929,9075,"I would be in a better place too."],[9129,9213,"And now we're all stuck"],[9213,9442,"in this...hellhole,"],[9563,9638,"because of you."],[9780,9918,"You're useless."],[9955,10160,"My buddy Tom Norris got promoted"],[10160,10402,"to senior engineer in a year."],[10402,10552,"You've been there for decades."],[10581,10627,"And you're still"],[10627,10827,"just some low-level mechanic."],[10827,10898,"Grandpa."],[10915,11006,"Now get out!"],[11019,11156,"And stay away from Audrey!"],[11211,11348,"Grandpa!"],[11353,11461,"Grandpa!"],[11490,11615,"You want to see Audrey again?"],[11661,11928,"You can bring us a nice, fat paycheck."],[11970,12082,"Grandpa! - Jesse's right."],[12095,12203,"Dad, get a job."],[12212,12320,"You owe that to us."],[12320,12499,"Now go dumpster dive if you have to."],[12499,12629,"Grandpa!"],[12666,12800,"Grandpa!"],[12958,13146,"No, Grandpa!"],[13167,13288,"I just didn't want to"],[13288,13388,"give up on my city,"],[13388,13605,"is that... so wrong?"]],"7":[[196,275,"Ew!"],[283,475,"Oh, look at that stinky hobo."],[492,571,"Let's cross the street"],[571,763,"before he gets all his germs on us."],[1618,1785,"Webster still hasn't given us"],[1785,1935,"our last paycheck,"],[1935,2147,"and I haven't eaten since last night."],[3224,3382,"Guess this will have to be my dinner."],[4054,4262,"Holy shit."],[4316,4412,"Hank Walker!"],[4466,4650,"The rock star engineer"],[4650,4896,"behind our 1987 Webster Corsair."],[4896,4996,"What are you doing?"],[5042,5171,"Eating out of a dumpster?"],[5184,5321,"Tom, you know this guy?"],[5342,5397,"Yep."],[5442,5584,"Fired him yesterday."],[5601,5730,"He's a piece of shit mechanic"],[5730,5864,"who wouldn't stop going on about,"],[5864,6101,"oh, the assembly line's gonna explode."],[6118,6214,"So I got rid of him."],[6339,6477,"It's no laughing matter, Tom."],[6506,6581,"I'm serious."],[6581,6677,"If you're not careful,"],[6677,6790,"that whole assembly line"],[6790,6902,"is gonna malfunction."],[6902,7019,"Oh, fuck, man."],[7057,7161,"You still stuck on that?"],[7194,7349,"That is bullshit."],[7403,7499,"Hank Walker."],[7515,7653,"They may have kept you around"],[7653,7724,"for 40 years"],[7724,7841,"because they're dumb."],[7841,8041,"But I know you're nothing special."],[8058,8183,"If you were anything like me,"],[8183,8308,"you'd at least be a manager."],[8329,8466,"Well, they did ask me."],[8546,8650,"But I turned them down."],[8679,8925,"Because I want to work with cars."],[8925,9042,"That's what I do best."],[9042,9221,"And I don't need some empty title."],[9234,9384,"But Tom, you have got to"],[9384,9509,"listen to me, okay?"],[9509,9667,"Have your guys watch the line."],[9667,9743,"Otherwise, it's gonna"],[9743,9855,"cost Webster millions."],[9855,9926,"What a joke."],[10022,10151,"I can't with you."],[10218,10502,"Look, this is our newest software."],[10502,10677,"All the lights are green."],[10677,10890,"Green means good."],[10902,10960,"See?"],[10960,11131,"Nothing can possibly go wrong."],[11311,11515,"Warning, malfunction detected."],[11536,11770,"Initiating emergency stop protocol."],[11986,12220,"No way this bastard got it right."]],"8":[[120,266,"What the hell happened here?"],[266,429,"The machine, it's smoking."],[429,504,"I don't know."],[504,667,"It shouldn't be doing that."],[725,784,"We're following"],[784,880,"the exact same procedures"],[880,967,"we've always done."],[980,1076,"Well, it is."],[1076,1176,"Look at it."],[1176,1388,"If this machine goes down,"],[1388,1443,"we're gonna have to"],[1443,1609,"shut down the whole plant!"],[1609,1810,"We're gonna lose millions of dollars."],[1956,2122,"Norris, I don't care what you do."],[2135,2352,"Fix it by the end of the day"],[2352,2485,"or you're done!"],[2948,3094,"What are you just standing there for?"],[3094,3169,"Fix it!"],[3240,3432,"Um, well, Tom, the thing is"],[3432,3586,"we don't know what the problem is."],[3586,3703,"We don't know what's wrong."],[3703,3787,"What do you mean?"],[3787,3887,"Didn't you go to college"],[3887,4012,"for this fucking shit?"],[4012,4079,"We just used to do"],[4079,4270,"what the older guys and Hank would do."],[4295,4383,"They would diagnose it"],[4383,4550,"and, and they would solve it."],[4550,4604,"Fuck."],[4667,4829,"I'm so fucking sick of"],[4829,4984,"this fucking Hank guy."],[5059,5146,"What do you want me to do?"],[5146,5263,"You want me to go back"],[5263,5405,"and bring back those old fossils"],[5405,5572,"that I just fucking fired?"],[5572,5651,"Fuck off."],[5689,5834,"This whole plant isn't gonna"],[5834,5935,"suddenly cease to function"],[5935,6147,"because a few wrinkly old farts"],[6147,6239,"got laid off."],[6272,6335,"That's bullshit."],[6335,6460,"Now fucking fix it."],[6485,6577,"Faster!"],[6923,7107,"Miss Wolff, I just don't see"],[7107,7215,"why we need a mechanic"],[7215,7323,"like Hank Walker right now."],[7323,7490,"Don't we already have an expert"],[7490,7590,"from Apex AI"],[7590,7761,"working on the CNC machine mill?"],[7761,7999,"We already lost one full production line."],[7999,8070,"If we lose another,"],[8070,8262,"that could mean hundreds of millions"],[8262,8404,"of dollars of loss in profits."],[8433,8558,"Look, you keep an eye on the factory"],[8591,8687,"and I will go find Hank"],[8687,8758,"because he's the only one"],[8758,8908,"I trust to fix this."],[8908,9063,"There will never be a replacement"],[9063,9246,"for good, old-fashioned"],[9246,9334,"human ingenuity."],[9363,9451,"Machines and humans"],[9451,9567,"can work together"],[9567,9718,"to create the most efficient outcome."],[9784,9893,"But a machine will never"],[9893,9968,"replace a human."]],"9":[[283,392,"Getting scraps, sir?"],[392,471,"You know it."],[492,704,"We still have a lot of material"],[704,813,"that we need to get rid of."],[855,1030,"If you can carry it, it's all yours."],[1030,1121,"Thank you."],[1230,1368,"Sir, there must be something"],[1368,1426,"you can do."],[1426,1547,"We need to fix this now."],[1547,1601,"Well, luckily"],[1601,1730,"you came to the right place."],[1730,1881,"I mean, we here at Apex AI"],[1881,2052,"know exactly what we're doing."],[2052,2177,"We can handle stuff like this"],[2177,2260,"in our sleep."],[2260,2360,"So we're just gonna"],[2360,2552,"have our diagnostics run on it,"],[2552,2711,"figure out a problem, and boom,"],[2744,2819,"Bob's your uncle."],[2873,3023,"So this is Apex AI's"],[3023,3161,"new detection software?"],[3161,3282,"It looks brilliant."],[3478,3582,"Jesus, lady."],[3582,3766,"I mean, what did you do to this thing?"],[3766,3941,"This is a critical failure."],[3941,4083,"Is there any way you can get it fixed"],[4083,4154,"by the end of the day?"],[4154,4291,"We need to have production"],[4291,4375,"back on schedule"],[4375,4512,"or my boss is gonna kill me."],[4558,4667,"I know that machine!"],[4667,4763,"The reading is off"],[4763,4929,"simply because the sensor skips"],[4929,5055,"without a manual check."],[5055,5134,"I mean, this is not a job"],[5134,5280,"that you can finish in a day, okay?"],[5280,5413,"I mean, this is gonna take like a week."],[5413,5497,"We don't have a week."],[5497,5609,"We have a client waiting on us."],[5609,5826,"We have to get these parts machined now."],[5826,5985,"Is there anything else you can do,"],[5985,6060,"please?"],[6197,6468,"I mean, we might have a solution."],[6481,6548,"It's just the,"],[6548,6619,"it's the pay"],[6619,6719,"that you're offering, though."],[6719,6919,"$2,000 for an eight-hour workday?"],[6919,6998,"Then..."],[7057,7207,"It just needs a reset,"],[7207,7403,"they're asking for even more?"],[7411,7494,"Ah."],[7582,7707,"Mr. Pierre and Mr. Esteban,"],[7707,7828,"money is not an issue."],[7828,7999,"I will give you $2 million each"],[7999,8091,"for your work here today."],[8091,8245,"And if all goes well,"],[8245,8350,"there will be a little bonus in it"],[8350,8433,"for you both as well."],[8433,8495,"Okay."],[8495,8583,"All right, well, don't worry about it,"],[8583,8650,"good-looking."],[8650,8787,"All right, fixing machines,"],[8787,8858,"that's our job."],[8883,9034,"It's a very tough and"],[9034,9088,"thankless,"],[9088,9225,"and a very, very difficult job."],[9225,9371,"But we'll get it up and running for you."],[9442,9584,"I can't believe they just"],[9584,9726,"scammed that poor girl!"],[9793,9889,"And then you're gonna twist it"],[9889,9959,"the other way."],[10005,10068,"Get in there."],[10139,10197,"See?"],[10197,10389,"Our new AI tool has a solution"],[10389,10468,"for everything."],[10869,11090,"Step 37, that's what it said."],[11090,11219,"Jeez, this used to never happen"],[11219,11327,"when Hank was around."],[11327,11415,"Shut up!"],[11448,11594,"Did I really fuck up"],[11594,11740,"by firing those old-timers?"],[11753,11824,"I'm not gonna have to"],[11824,11961,"bring Hank back on board, am I?"],[12283,12341,"What?"],[12391,12545,"Apex AI's tech experts"],[12545,12650,"are over at Mach 15?"]],"10":[[50,166,"Oh, perfect."],[183,321,"Those guys are a golden ticket"],[321,429,"to fixing this machine."],[487,600,"I'll head over right now."],[1288,1355,"All righty."],[1430,1501,"Fire it up."],[1751,1814,"No!"],[2006,2052,"Not yet."],[2268,2327,"You can't."],[2327,2565,"You gotta reset the machine first."],[2565,2715,"Otherwise, you'll be operating"],[2715,2869,"under the faulty presets."],[2894,3048,"You're leading this machine down"],[3048,3136,"a one-way path"],[3136,3265,"to catastrophic failure."],[3315,3370,"Okay, I'm sorry."],[3370,3507,"Who the fuck is this guy?"],[3545,3649,"Go back, get your scrap,"],[3649,3812,"get out of here, okay?"],[3812,3933,"You're distracting us"],[3933,3987,"from this"],[3987,4187,"billion dollar machine here."],[4212,4312,"It's an easy fix."],[4408,4517,"But I bet you two knew that,"],[4517,4567,"didn't you?"],[4592,4725,"You talked it up to her"],[4725,4867,"so you could get that extra pay."],[4950,5042,"What are you talking about?"],[5042,5084,"Wow."],[5084,5155,"You know what, Miss Evelyn?"],[5155,5255,"Can you get your guys"],[5255,5376,"to get him out of here, okay?"],[5376,5601,"He's distracting us from working."],[5601,5743,"Sir, I'm gonna have to ask you"],[5743,5809,"to step back, please."],[5809,5930,"We have plenty of scrap metal"],[5930,6081,"and I'd be happy to help you get it"],[6081,6181,"but we- - Miss, Miss, forget"],[6181,6268,"the scrap metal."],[6268,6381,"If you give me ten minutes"],[6381,6456,"with this machine,"],[6456,6581,"I will tell you exactly"],[6581,6648,"what's wrong with it."],[6710,6944,"And I'll fix it for you, free of charge."],[6965,7082,"Whoa, whoa, whoa. Okay."],[7082,7198,"So you're saying"],[7198,7357,"you could fix this in ten minutes?"],[7357,7474,"We're two of the best mechanics"],[7474,7528,"in the world"],[7528,7682,"armed with a brand spanking new"],[7682,7799,"AI detection system."],[7799,7907,"Now, if we can't pull this off"],[7907,7974,"in ten minutes,"],[7974,8124,"what's a scruffy old fart like you"],[8124,8174,"gonna do?"],[8199,8379,"You may have your fancy AI,"],[8425,8516,"but these machines,"],[8550,8700,"they were built by people."],[8700,8779,"And they're meant to be"],[8779,8896,"maintenanced by people."],[8929,9054,"I've been in this industry"],[9054,9138,"for forty years."],[9138,9188,"Trust me,"],[9188,9305,"I know what I'm talking about."],[9325,9530,"We need somebody like Hank Walker."],[9530,9605,"Miss Wolff said"],[9605,9759,"he's a genius car mechanic"],[9759,9922,"and he would know how to fix this."],[10352,10414,"That's me."]],"11":[[33,141,"I am Hank Walker."],[183,316,"Wait, Hank Walker?"],[321,533,"Isn’t that the genius supercar engineer"],[533,684,"that boss wanted to hire?"],[684,821,"I need to call her."],[825,1021,"Forty years in the industry."],[1021,1088,"Oh, you was a,"],[1088,1209,"you was a custodian, right?"],[1209,1267,"What makes you think"],[1267,1355,"you know more than someone"],[1355,1476,"with a master's degree, man?"],[1476,1676,"Do you really, really think"],[1676,1735,"that you know"],[1735,1835,"more than this"],[1872,2127,"billion dollar AI detection system?"],[2127,2231,"You're taking us for a ride,"],[2231,2356,"you stupid old fuck."],[2369,2502,"Watch your tongue, young man."],[2535,2702,"If she had pressed that start button,"],[2702,2790,"this machine,"],[2819,2982,"she would have fried the microcontroller."],[2982,3174,"What you need to do is reset the system."],[3174,3319,"Let it cool down first."],[3328,3424,"And you start it back up"],[3424,3528,"before you run anything."],[3595,3687,"How did you know that?"],[3720,3916,"Because I'm the best technician"],[3916,4020,"for fourty years."],[4020,4083,"Do you really think"],[4083,4241,"that you can fix this in ten minutes?"],[4275,4354,"Of course I can."],[4441,4592,"No, he can't."],[4608,4821,"This redneck is a useless"],[4821,5009,"piece of shit union monkey"],[5009,5092,"that I"],[5092,5276,"fired from Webster yesterday."],[5276,5476,"He doesn't know jack about tech."],[5476,5601,"He's just out of a job"],[5601,5751,"and desperate for cash."],[5751,5960,"Oh, you really had us going,"],[5960,6089,"you disgusting old fart."],[6089,6164,"Here we are thinking"],[6164,6360,"you're just some genius engineer."],[6360,6489,"You ain't nothing but a scammer."],[6577,6664,"Tom Norris."],[6685,6790,"Something must have gone"],[6790,6865,"very wrong"],[6865,6936,"at Webster"],[6936,7098,"for you to be here at a competitor."],[7190,7307,"I told you to watch those machines."],[7307,7378,"Shut up!"],[7449,7674,"You spent the last forty years"],[7674,7841,"swapping out blinker fluid."],[7882,8045,"What do you know about cars,"],[8066,8170,"or engineering?"],[8229,8333,"You see this?"],[8333,8637,"This blows you out of the fucking water."],[8637,8800,"What did you say to Hank Walker?"],[8988,9046,"Oh my gosh,"],[9046,9129,"why is boss here?"],[9129,9238,"Oh, Miss Wolff?"]],"12":[[275,483,"Hank, I'm asking you as a front."],[483,688,"If you can fix this, I owe you a big one."],[729,871,"We have a huge order coming in"],[871,996,"and we have to fill it."],[996,1105,"Or we break contract"],[1105,1292,"and we get sued into oblivion."],[1388,1480,"Don't worry, Miss Wolff."],[1480,1534,"Wait, Miss Wolff."],[1534,1689,"Out of respect, I'm, I'm so sorry."],[1689,1931,"Do you really trust him?"],[1939,2064,"You, you're putting him against"],[2064,2168,"a billion dollar"],[2168,2323,"AI detection system here."],[2348,2427,"It's my machine."],[2527,2669,"And I will take responsibility."],[2711,2823,"And I would appreciate it that"],[2823,2986,"if you stopped insulting my guest."],[3094,3186,"He may not look it,"],[3474,3553,"but Hank is one of"],[3553,3720,"the best auto engineers"],[3737,3812,"in the world."],[3824,3970,"And he's been fixing machines"],[3970,4095,"since before you were born."],[4137,4346,"Are we looking at the same guy here?"],[4379,4483,"Miss Wolff,"],[4554,4725,"I am from one of your competitors."],[4725,4971,"But I would hate for you to get scammed."],[4984,5155,"He got fired from Webster"],[5155,5326,"because he is worthless."],[5326,5401,"I'm sorry."],[5417,5488,"Who are you?"],[5513,5668,"And what are you doing in my factory?"],[5726,5951,"I'm a senior engineer at Webster."],[5989,6139,"And a graduate from MIT."],[6189,6373,"I'm happy to give you my advice,"],[6373,6448,"Miss Wolff."],[6473,6598,"Hank is useless."],[6627,6815,"He's gonna break that machine."],[6815,6956,"And he can't afford to pay you back."],[7228,7394,"Tom Norris, why don't you and I"],[7394,7515,"make a little bet, huh?"],[7553,7699,"If I fix this machine here,"],[7699,7816,"I want you to write"],[7816,7982,"a formal letter of apology."],[8016,8179,"To all my old co-workers,"],[8179,8354,"everyone that you fired."],[8416,8512,"And in that letter,"],[8558,8679,"I want you to tell them"],[8708,8871,"that there is no substitute"],[8900,8996,"for a seasoned,"],[8996,9146,"experienced mechanic."],[9238,9317,"Not even AI."],[9492,9601,"Sure thing, buddy."],[9667,9822,"And if you fuck it up,"],[9843,10014,"I want you to post online"],[10014,10231,"that you're a stupid old fuck."],[10231,10389,"And a useless liar."],[10598,10848,"And then, I want you to come back."],[10869,11090,"I want you to lick my shoes clean."]],"13":[[0,104,"You shut your mouth."],[141,300,"I don't care who you are."],[300,367,"Miss Wolff."],[367,425,"But if you continue"],[425,546,"to disrespect my guest,"],[546,684,"I will have security toss you out!"],[684,792,"He was my subordinate."],[792,1063,"I know exactly what he is capable of,"],[1084,1305,"which is to say nothing."],[1409,1463,"I..."],[1476,1551,"Miss Wolff."],[1655,1747,"Miss Wolff, it's okay."],[1935,2047,"I'm warning you right now."],[2089,2193,"Let's shake on it then."],[2248,2310,"Our bet."],[2698,2944,"Let's see what you can do, old fuck."],[3132,3253,"I'll make damn sure"],[3253,3449,"the next generation learns that"],[3449,3616,"experience is the one asset"],[3616,3762,"no machine can replace."],[3762,3912,"And l'll prove the value"],[3912,4058,"of every fellow workers"],[4058,4279,"who built this industry in Detroit."],[4441,4521,"Watch and learn."],[5246,5326,"Hank!"],[5380,5543,"What the hell do you think you're doing?"],[5647,5701,"Jesse."],[5764,5830,"Grandpa!"],[5872,5939,"Audrey."],[6076,6177,"Tom called me."],[6177,6368,"He told me that you're at Mach 15"],[6368,6452,"working on some"],[6452,6619,"multi-million dollar tech."],[6619,6865,"Your name is on the house."],[6886,7119,"If you get sued and we lose the house,"],[7119,7248,"where are we gonna go?"],[7282,7369,"You stop this."],[7369,7499,"You stop this right now."],[7540,7686,"It's for your own good, Hank."],[7711,7899,"You barely make $1000 a month."],[7899,8070,"You can't afford to pay them back."],[8070,8212,"It's simple game theory."],[8212,8316,"Did you hear that, old man?"],[8337,8512,"If you touch that machine again,"],[8512,8654,"we are cutting you off."],[8679,8921,"And you are never, ever gonna see"],[8921,9084,"Helen or Audrey again."]],"14":[[8,79,"No, no!"],[79,208,"I don't want you to leave!"],[208,412,"Please, grandpa, please don't go!"],[421,525,"Dad, come on."],[525,692,"Stop making a fool of yourself."],[692,804,"I know you're a mechanic,"],[804,992,"but you work on old beat-up cars."],[1017,1226,"Not million dollar heavy machinery."],[1226,1368,"I mean, even the freaking AI"],[1368,1459,"is stumped."],[1459,1580,"How the hell are you gonna know"],[1580,1664,"how to fix it?"],[1685,1739,"Helen."],[1830,1922,"What happened to you?"],[2006,2177,"You used to believe in me."],[2210,2331,"You used to say,"],[2331,2523,"you can fix anything."],[2598,2777,"I started working with cars"],[2802,2902,"because you loved them."],[2969,3065,"Don't you remember?"],[3128,3307,"You drew this for me."],[3382,3541,"And I kept it in my wallet every day"],[3541,3628,"for inspiration."],[3687,3749,"Helen."],[3820,3899,"What happened to you?"],[3974,4079,"Why are you like this?"],[4400,4500,"I was six."],[4500,4562,"Okay?"],[4604,4742,"But now I'm a grown ass woman."],[4796,4929,"And I became this way"],[4963,5121,"because I have a dead beat father."],[5121,5305,"He's too afraid to leave a dying city."],[5305,5413,"And let his whole family"],[5413,5518,"just suffer with him."],[6406,6460,"Look."],[6481,6648,"If you still care about me at all."],[6702,6861,"Stop whatever you're doing."],[6877,7048,"You already ruined my life."],[7082,7353,"My mom died because of you."],[7449,7582,"You're just a nobody,"],[7582,7728,"stuck in a dead end job,"],[7728,7795,"in an industry"],[7795,7970,"that's way past its glory days."],[7995,8179,"And you're still waiting for a miracle."],[8241,8375,"Bad mommy!"],[8445,8633,"No, I trust you grandpa."],[8633,8754,"You can get the machine"],[8754,8888,"working again."],[8888,8950,"Thank you"],[9029,9188,"for still believing in me, Audrey."],[9205,9392,"Give it up, Hank."],[9392,9547,"You can't fix shit."],[9572,9680,"And you know it."],[9680,9855,"That combination mill"],[9855,10043,"is worth millions."],[10043,10172,"And your daughter's property"],[10172,10289,"won't even start to cover it."],[10610,10673,"Hank."],[10681,10806,"Don't worry about the damages."],[10806,10915,"This is my company."],[10948,11031,"And I trust you."],[11056,11177,"If you mess anything up."],[11198,11319,"I will eat the cost."],[11319,11457,"And you won't owe a single cent."],[11632,11799,"A deal is a deal."],[11799,11986,"And if Hank fixes this machine,"],[11986,12078,"you owe him"],[12078,12174,"and everybody else"],[12174,12266,"you laid off an apology."],[12379,12424,"Well,"],[12491,12600,"let me show you how it's done."]],"15":[[2627,2681,"All done."],[2681,2794,"Holy shit."],[2819,2973,"9 minutes and 41 seconds."],[2973,3048,"I mean, how on earth"],[3048,3153,"did you manage that?"],[3315,3440,"I used to do it all the time."],[3474,3574,"Back at Webster,"],[3574,3732,"I'd fix 20 CNC machines"],[3732,3803,"in one afternoon"],[3803,3874,"on a bad day."],[3874,3987,"20 of these things."],[3987,4187,"Even with our AI detection software,"],[4187,4437,"it would take a week to do that many."],[4733,4804,"Thank you"],[4850,4950,"so, so much."],[5005,5155,"There aren't words for what you did."],[5196,5355,"You just bailed us out of bankruptcy."],[5426,5476,"No."],[5476,5643,"No, you lost."],[5647,5722,"Because I just plugged"],[5722,5822,"some algorithms in."],[5822,5893,"And my data,"],[5893,5985,"it's showing me."],[5985,6122,"That there is no way"],[6122,6235,"you could have fixed this machine"],[6235,6318,"in 10 minutes."],[6318,6402,"You're a liar."],[6402,6448,"I knew it."],[6448,6602,"I was onto you from the very beginning,"],[6602,6744,"you greasy old fart bag."],[6744,6844,"You didn't even turn it on,"],[6844,6890,"did you?"],[6890,7086,"And our processing unit is still going."],[7086,7186,"So you have zero proof"],[7186,7294,"that you even did anything."],[7294,7349,"Yeah."],[7365,7436,"Who's to say"],[7436,7582,"it was even gonna run, huh?"],[7653,7741,"A clown."],[7778,7941,"All these union rats are the same."],[7978,8187,"They're like the vermin of Detroit."],[8204,8404,"Grandpa Hank's not a rat."],[8404,8650,"He's the coolest guy in Detroit."],[8700,8771,"That's right."],[8771,8871,"Mechanics like me,"],[8896,9042,"we're the backbone of Detroit."],[9088,9138,"Just watch."],[9138,9259,"When I pull that lever there,"],[9292,9417,"it's gonna start up like a gem."],[9818,9872,"Ready?"]],"16":[[905,1046,"Looks like your little pet project"],[1046,1134,"didn't do much."],[1134,1288,"You better grab a puke bag,"],[1305,1355,"because you're gonna"],[1355,1543,"lick my shoes clean."],[1856,1964,"Wait to see."],[3265,3328,"It's okay."],[3328,3570,"Everything's reading completely safe but,"],[3682,3782,"you actually did it"],[3782,3908,"in less than ten minutes."],[3908,4099,"No, there is no way"],[4099,4241,"that boomer actually did it."],[4266,4458,"He doesn't know jack about tech."],[4792,4913,"Yay, Grandpa!"],[4913,5075,"I knew you can do it!"],[5221,5367,"Thank you so, so much."],[5397,5492,"I mean, you just"],[5492,5634,"brought us back billions."],[5672,5814,"You saved Mach 15."],[5830,5935,"I was happy to do it."],[6010,6151,"So what if he did fix it?"],[6193,6310,"He's still unemployed,"],[6310,6406,"and he's still not bringing home"],[6406,6468,"any money."],[6527,6777,"Stop being mean to Grandpa!"],[7069,7173,"He really fixed it,"],[7211,7307,"like he said he would."],[7328,7611,"Hank, I would again like to"],[7611,7703,"offer you a position."],[7741,7857,"I want you as my lead"],[7857,7962,"supercar engineer."],[8153,8270,"With a starting salary"],[8324,8450,"of ten million dollars."],[8867,9079,"Ten million dollars?"],[9309,9488,"That is unheard of for an engineer."],[9488,9730,"Because I'm not an idiot like you."],[9826,9997,"And I recognize a diamond in the rough"],[9997,10051,"when I see it."],[10556,10635,"No way."],[10756,10985,"It actually says ten million dollars."],[11077,11215,"Someone is really offering"],[11215,11415,"to pay millions for my Dad?"],[11440,11540,"And here I thought"],[11540,11736,"he was old and useless."],[11736,11932,"I was so wrong about him."]],"17":[[116,367,"And he's worth every single penny"],[367,458,"that's coming to him."],[483,775,"And I'm offering him company shares."],[1401,1514,"Sign it, Hank."],[1534,1609,"After everything you've done"],[1609,1693,"for this industry."],[2035,2110,"Miss Wolff,"],[2402,2456,"I can't"],[2481,2569,"thank you enough,"],[2569,2844,"but I can't in good conscience"],[2844,2998,"take ten million dollars."],[2998,3169,"No, no, no, no, no, wait."],[3169,3269,"Wait, hold that thought."],[3307,3390,"Yes you can, Hank."],[3453,3532,"And you should."],[3553,3645,"That lady said that"],[3645,3828,"you are worth every single cent."],[3874,3999,"That means you're a pro."],[3999,4120,"I've always known"],[4195,4295,"that you'd have a knack"],[4295,4416,"for this engineering thing."],[4454,4621,"But this, this, this proves it."],[4679,4909,"Dad, if you take that money,"],[4934,5046,"you could pay off our mortgage."],[5059,5117,"We only have"],[5117,5226,"a hundred thousand left."],[5280,5417,"And Audrey. We could afford"],[5417,5572,"to send her to the best school"],[5572,5764,"and buy that pony she's always wanted."],[5764,5943,"Yes, yes, yes, yes, yes, yes."],[5955,6039,"Just think about it."],[6039,6189,"If you'd be working at Mach 15,"],[6189,6443,"you'd have dibs on all their supercars."],[6468,6698,"I have been itching to"],[6698,6856,"get my hands on a new ride."],[6877,7094,"And just think how cool it would be"],[7094,7244,"for Audrey to go to school"],[7244,7428,"in one of those beasts."],[7482,7557,"Funny."],[7661,7828,"I don't remember the two of you"],[7828,7928,"treating Hank this way"],[7928,8058,"when you first walked in here."],[8216,8316,"I'm not buying it."],[8316,8433,"There is no way"],[8433,8571,"that he fixed that machine."]],"18":[[8,287,"What the hell are you talking about?"],[287,392,"He just fixed it."],[421,542,"We all watched him fix it."],[542,696,"If it wasn't him, who was it?"],[721,959,"He just tapped in a few nuts and bolts."],[1001,1076,"You think that's gonna"],[1076,1238,"magically solve anything?"],[1276,1488,"This machine is only working"],[1488,1730,"of Esteban and Pierre's AI software."],[1785,1972,"All we had to do was turn it on"],[1972,2043,"and it would have been working"],[2043,2156,"as good as new"],[2156,2243,"like it is now."],[2302,2473,"Hank just swooped in"],[2473,2577,"and took all the credit."],[2598,2686,"Yeah, that's right."],[2711,2869,"All you did was pull a lever."],[2869,2965,"Meanwhile, Pierre and I"],[2965,3107,"did everything else."],[3148,3290,"You jerk, you lied to us."],[3357,3457,"That's why you didn't want us"],[3457,3561,"to turn it on before."],[3561,3716,"Because you knew it would work."],[3766,3928,"You just wanted to steal our thunder."],[3958,4024,"Miss Wolff,"],[4024,4183,"that is unacceptable behavior"],[4183,4275,"for a future hire."],[4275,4471,"That's not what happened."],[4471,4583,"And you all know that."],[4975,5080,"Tom Norris!"],[5080,5280,"Where the hell are you?"],[5280,5476,"When are those experts"],[5476,5609,"gonna get here!"],[5718,5860,"I am on my way."],[5860,5989,"They're coming right now, boss."],[5989,6060,"I promise."],[6081,6264,"Ha. You'd better show up soon"],[6264,6460,"cause if we don't get it fixed by"],[6460,6589,"the end of the day,"],[6602,6785,"you are fired!"],[7165,7349,"No time to waste on you freaks anymore."],[7415,7524,"Mr. Esteban and Mr. Pierre,"],[7524,7590,"would you mind"],[7615,7761,"popping over to Webster Motors"],[7761,7811,"with me?"],[7811,7970,"We're just in a little bit of a,"],[7970,8103,"little bit of a pickle"],[8103,8216,"with one of our machines."],[8216,8433,"And we could really use your expertise."],[8433,8591,"I promise you we would treat you"],[8591,8746,"with the utmost respect."],[8746,8967,"Unlike these rude idiots at Mach 15."],[8988,9050,"Yeah, you know what?"],[9063,9138,"Sure."],[9292,9388,"Because everybody else has sided"],[9388,9580,"with this fake mechanic over here."],[9580,9655,"Let's go somewhere"],[9655,9843,"where our skills will be appreciated."],[9855,9930,"Thank you kindly."],[9930,9997,"Absolutely."],[10030,10214,"Tom, it's no use."],[10214,10297,"They're not gonna be able to"],[10297,10397,"fix your machine."]],"19":[[16,129,"Well, I beg to differ."],[175,412,"I think they have real skill and talent"],[412,487,"unlike you."],[517,579,"Yeah, Hank."],[608,767,"While you're busy pulling levers"],[767,875,"and flipping buttons"],[875,1021,"and doing whatever you're doing,"],[1117,1234,"we do all the real work."],[1359,1459,"And you know what?"],[1476,1680,"You're the one who broke that machine."],[1718,1789,"So you're gonna"],[1789,1951,"come back with me to Webster's"],[1951,2039,"and fix it."],[2448,2548,"Well."],[2585,2727,"We'll find out soon enough."],[2727,2927,"Hell no, we won't go!"],[2932,3103,"Hell no, we won't go!"],[3111,3290,"Hell no, we won't go!"],[3294,3503,"Hell no, we won't go! - Boo!"],[3528,3695,"Hell no, we won't go! - Boo!"],[3716,3941,"Hell no, we won't go, -Boo!"],[3949,4195,"Hell no, we won't go,"],[4200,4350,"Boo!"],[4383,4533,"Boo!"],[4562,4704,"Hell no, we won't go!"],[4725,4825,"Boo!"],[4859,4954,"Hell no, we won't-"],[4954,4988,"Ted."],[4988,5063,"Hey, Hank."],[5075,5159,"What's going on here?"],[5188,5321,"We're protesting the layoffs."],[5321,5388,"What do you think, man?"],[5388,5501,"Hey, hey, come on."],[5509,5580,"Join us!"],[5580,5718,"I, I, I can't today."],[5776,5885,"They're here doing some repairs,"],[5885,6006,"and I'm tagging along to make sure"],[6006,6126,"nothing bad goes and happens."],[6126,6289,"One of the assembly line machines"],[6289,6356,"malfunctioned."],[6456,6560,"It malfunctioned?"],[6627,6698,"Already?"],[6727,6819,"It serves them right."],[6819,6877,"You know, I bet they're"],[6877,6965,"running around in there"],[6973,7127,"like a bunch of headless chickens."],[7127,7307,"Can't do anything right without us,"],[7307,7357,"huh?"],[7357,7419,"You know what?"],[7419,7540,"I gotta see it for myself."],[7540,7674,"Come on, I'm going in with you."],[7695,7791,"Keep going, fellas!"],[7791,7920,"Hell no, we won't go!"],[7937,8103,"Hell no, we won't go!"],[8103,8195,"We won't go!"],[8204,8366,"Hell no, we won't go!"],[8596,8692,"Fix it!"],[8796,8938,"It's what you're paid for."],[8938,9096,"Boss, I brought them."],[9159,9250,"Oh, nice."],[9271,9334,"Here they are."],[9334,9413,"Good to see you, Tom."],[9413,9555,"Yes, yes, yes."],[9859,9964,"Ted, Hank?"],[9964,10051,"What are you doing here?"],[10051,10147,"We laid you off!"],[10147,10314,"Came to watch you crash and burn,"],[10314,10389,"that's what."],[10389,10468,"Yeah, I wanted to see"],[10468,10593,"how things were holding up."],[10610,10856,"Now that you're using this faulty AI"],[10856,11065,"instead of us experienced folk."],[11077,11207,"I'll deal with you later."],[11207,11365,"Tom, boss just called."],[11365,11478,"He's breathing down my neck."],[11478,11532,"If we don't get this"],[11532,11632,"figured out and fixed,"],[11632,11707,"we're both fired."],[11707,11832,"Please, you're the experts, right?"],[11832,11932,"You, you got to help us."],[11936,12024,"Yeah, relax, Tom."],[12024,12095,"Lucky for you,"],[12095,12274,"we got the world's best AI on our side."],[12274,12374,"So we'll just get this bad boy"],[12374,12470,"started up quickly"],[12470,12650,"and um, we'll be on our way."],[12650,12708,"No."],[12771,12908,"You got this all wrong, okay?"],[12908,13038,"It's a heat issue."],[13067,13142,"It's not something"],[13142,13338,"one little AI test can resolve."],[13392,13450,"If you want to"],[13450,13567,"get to the root of this problem,"],[13634,13738,"it's gonna take some time."]],"20":[[0,254,"Shut up about your heat, Hank, okay?"],[254,446,"Because when the experts fix this"],[446,571,"with their detection system"],[571,638,"and it turns out"],[638,779,"not to be a heat problem,"],[779,892,"you're gonna look like"],[892,1042,"a pathetic liar."],[1042,1163,"Look, I'm telling you, Tom,"],[1188,1288,"you got to do something"],[1288,1368,"about the heat."],[1368,1455,"Otherwise, it's just gonna"],[1455,1526,"keep erroring."],[1526,1614,"Okay, okay."],[1614,1730,"That's nonsense, okay?"],[1743,1805,"This guy doesn't have"],[1805,1910,"the slightest idea"],[1910,2014,"of the powers of AI."],[2035,2131,"Tom, I'm telling you,"],[2131,2239,"do not waste your time"],[2239,2331,"on clowns like him."],[2414,2548,"All right, success is imminent."],[2585,2769,"Once production is back online,"],[2769,2965,"I'm gonna expose your lies to hell"],[2965,3123,"and back online."],[3123,3240,"And then everyone's"],[3240,3307,"gonna hate you"],[3307,3411,"and Mach 15 will have to"],[3411,3532,"fire you for PR."],[3532,3578,"You better pray"],[3578,3653,"they know what they're doing"],[3653,3707,"because it certainly"],[3707,3812,"doesn't look like that."],[5063,5188,"Oh, yeah."],[5251,5405,"Yeah, yeah."],[5442,5509,"All right."],[5647,5705,"Turn it on."],[5705,5789,"No, you can't."],[5789,5922,"Oh, yeah, yeah, yeah, yeah."],[5922,5997,"You and your heat."],[5997,6101,"You know what, buddy?"],[6101,6268,"Screw you, okay."],[6268,6373,"I've checked this time."],[6373,6510,"Everything's completely fine."],[6539,6731,"So get with the times, old man."],[6765,6965,"All our checks are AI-driven now"],[6981,7107,"and the experts are saying"],[7107,7240,"the heat is not an issue."],[7240,7340,"So turn it on."],[7482,7691,"I said turn it on!"],[9405,9463,"Oh."],[9505,9563,"See?"],[9605,9705,"What did I say?"],[9780,9884,"I'm telling you, boomer,"],[9884,9989,"we don't need you."]],"21":[[12,79,"Look."],[116,216,"It may be running fine"],[216,287,"right now,"],[350,496,"but it's just gonna keep overheating"],[496,613,"until it malfunctions again."],[613,804,"Buddy, do you think anyone here"],[804,955,"actually cares about what you're saying?"],[1005,1163,"You're fucking screwed, buddy,"],[1184,1351,"because everyone knows"],[1351,1438,"that you're a liar,"],[1459,1564,"you can't fix shit,"],[1564,1747,"and that you lucked out back at Mach 15"],[1747,1818,"with their machine."],[1818,1964,"Yeah, you know what, Hank?"],[1964,2060,"When I first met you,"],[2060,2143,"I did think that you were"],[2143,2243,"something special."],[2318,2439,"Now I agree with Tom."],[2510,2602,"You're nothing but a fraud."],[2656,2731,"I knew it."],[2773,2940,"I knew it from the moment I saw you."],[2998,3148,"I knew you weren't no genius engineer."],[3232,3307,"I can't believe you, man."],[3307,3390,"You make me sick,"],[3411,3582,"over here comparing yourself to us."],[3603,3682,"Please."],[3716,3995,"Anyway, thank you gentlemen so much"],[3995,4066,"for coming in."],[4066,4220,"You saved me and Tom's asses."],[4220,4291,"Oh yeah, well you know,"],[4291,4408,"it's just part of the job, alright?"],[4408,4633,"Um, I'm sure Tom here"],[4633,4783,"let you know that we charge,"],[4783,4833,"uh..."],[4871,4959,"20."],[5009,5055,"Thousand-"],[5055,5084,"What?"],[5084,5171,"$20,000?"],[5188,5246,"For what?"],[5246,5434,"Hang on, I'm getting the impression here"],[5434,5618,"that you don't think that our work was,"],[5647,5743,"was worth it."],[5776,5855,"Last time I checked,"],[5855,5935,"I just saved your ass"],[5935,6026,"from getting fired."],[6051,6143,"Okay, get out of my way."],[6143,6314,"No, not at all, Mr. Esteban."],[6314,6506,"The way I see it, 20k?"],[6523,6639,"Plenty reasonable."],[6639,6865,"I mean, 20k got us results,"],[6865,7052,"which is much more than"],[7052,7194,"what Hank did for 10 million"],[7194,7344,"twiddling his little thumbs."],[7344,7403,"You know,"],[7424,7511,"I can't believe"],[7511,7736,"you'd lie to the CEO of Mach 15."],[7757,7841,"A woman."],[7878,7991,"If I were you,"],[8016,8145,"I'd call her right now"],[8145,8254,"and tell her everything"],[8254,8375,"before I get sued."]],"22":[[50,166,"Speak for yourself, Tom."],[250,333,"This machine's gonna"],[333,442,"error any day now."],[442,608,"Shut up, okay?"],[625,821,"Security, kick him out."],[821,946,"Throw him into oncoming traffic"],[946,1005,"for all I care."],[1005,1059,"Alright, that's it."],[1059,1163,"You've gone too far, son."],[1180,1242,"You know something?"],[1242,1359,"Old folks like us"],[1359,1455,"have worked way too hard"],[1455,1564,"so you could get where you're at."],[1564,1685,"And I'm not gonna stand by"],[1685,1797,"and let you treat Hank like dirt."],[1797,1868,"No, no, no."],[1868,1935,"Tom."],[2131,2231,"The machins's gonna error again."],[2406,2481,"Three."],[2544,2602,"Two."],[2669,2719,"One..."],[3103,3395,"Oh fuck, fuck, fuck."]],"23":[[45,154,"What the hell happened?"],[154,350,"I thought you said it was fixed, Mr. 20k?"],[350,479,"It was fixed, okay?"],[479,596,"I don't know what happened, it just..."],[638,725,"Just let me see something."],[725,884,"You are wasting my time."],[913,1096,"Tom, where did you find these quacks?"],[1096,1151,"They were the,"],[1151,1288,"they were the best experts around."],[1288,1338,"I swear..."],[1438,1664,"These are your best experts?"],[1705,1843,"With their empty talk"],[1843,2043,"about their high concept"],[2043,2285,"fancy AI software whatever."],[2377,2456,"Let me tell you something."],[2456,2673,"These two bozos and their pink shirts"],[2673,2923,"can't hold a torch to Hank Walker."],[2961,3140,"This sort of stuff never happened"],[3140,3219,"back when he was around."],[3219,3324,"Fucking shut up."],[3324,3428,"Because he didn't do anything"],[3428,3570,"about the assembly line, okay?"],[3620,3682,"Fix it."],[3699,3770,"Right now."],[3770,3862,"Look, I don't care what the fuck"],[3862,3962,"you need to do."],[3962,4041,"But if you don't,"],[4041,4137,"I'm gonna blame it on you."],[4137,4191,"Hang on, hang on."],[4191,4250,"I don't know why you're"],[4250,4329,"blaming us here, okay?"],[4329,4421,"This is your machine."],[4421,4558,"Because you're the one who broke it,"],[4558,4642,"you asshole!"],[4675,4783,"So fix it."],[4821,4909,"And if you get me fired,"],[4909,5038,"I'm gonna hack into your code base"],[5038,5146,"and make you two pay."],[5146,5201,"Okay, okay."],[5201,5313,"Just hang, just hang"],[5313,5417,"on there real quick, okay?"],[5417,5476,"We'll just,"],[5518,5613,"just look into it, okay?"],[5613,5638,"Um."],[5768,5905,"We'll look into the, uh..."],[6289,6348,"No."],[6352,6648,"Heat dissipation processes."]],"24":[[325,383,"Heat?"],[454,608,"Like what Hank said earlier?"],[863,905,"No way."],[905,1009,"How'd he guess that?"],[1034,1126,"I told you, Tom."],[1222,1372,"If you had just listened to me,"],[1372,1522,"we would have been out the door"],[1522,1626,"an hour ago."],[1793,1876,"Lorne Russell!"],[1906,2056,"What is taking so long?"],[2056,2177,"I want results now!"],[2177,2310,"We're, we're on it."],[2310,2431,"We're working on it right now."],[2431,2548,"It's gonna be done soon."],[2615,2756,"What's with all the stuttering?"],[2790,3061,"I've said it once, and I'll say it again."],[3115,3203,"Show me results"],[3203,3349,"or don't bother showing up!"],[3520,3674,"Useless S.O.B.s."],[3699,3782,"All of them!"],[3816,3903,"We bought Webster's"],[3903,3970,"because they had"],[3970,4108,"the best machines around."],[4162,4337,"What happened to their operations?"],[4433,4600,"I have to go take a look myself."]],"25":[[12,87,"Hey, hey, Tom."],[87,229,"Hey, just, just relax, okay?"],[229,304,"We'll figure something out,"],[304,337,"all right?"],[337,546,"You've got one last fucking shot!"],[667,775,"Hank, Hank, Hank."],[775,909,"You said you know what this is, right?"],[909,950,"That you said"],[950,1088,"this was a heat dissipation process."],[1088,1126,"So that means"],[1126,1251,"you know how to fix it, right?"],[1251,1309,"Right?"],[1347,1434,"Of course I can."],[1434,1480,"All right, well,"],[1480,1614,"can you please fix it for us, all right?"],[1614,1760,"Whatever they're paying us,"],[1793,1851,"we'll give you half."],[1851,1889,"We just..."],[1889,1947,"What?"],[1947,2068,"We cannot lose our"],[2068,2160,"million-dollar machine."],[2160,2231,"Hey, pal."],[2231,2444,"You messed up that machine yourself."],[2464,2623,"It's got nothing to do with Hank."],[2623,2665,"Yeah, well,"],[2665,2748,"we've been thinking about that,"],[2748,2802,"and, um."],[2865,2990,"Look, to just tell you the truth, man,"],[2990,3057,"we lied about it"],[3057,3140,"from the very beginning, okay?"],[3140,3236,"Times are tough, man,"],[3236,3382,"and we tried to extend this job"],[3382,3482,"just to get a quick buck."],[3482,3599,"Yeah, yeah, man."],[3599,3691,"You really fed us"],[3691,3837,"our humble pie today, and,"],[3874,3987,"who knew you would fix the whole thing"],[3987,4074,"in ten minutes?"],[4074,4216,"So, Hank, please."],[4216,4308,"You're the only one"],[4308,4416,"that can help us with this, man."],[4416,4567,"Please, please help us."],[4629,4771,"Where is the machine?"],[4771,4884,"Why is it smoky?"]],"26":[[58,204,"Where is the machine?"],[204,312,"Why is it smoky?"],[312,479,"Tom, Tom, I thought you hired"],[479,533,"the experts."],[533,600,"Yeah, they're here. They're here."],[600,679,"Where are they?"],[729,804,"They're here."],[1363,1476,"You must be the expert."],[1501,1609,"We need to fix this machine."],[1609,1705,"We need to fix it fast."],[1705,1893,"We're willing to pay anything."],[1893,1993,"No, no, no, no."],[1993,2110,"That's the expert."],[2110,2160,"Hi."],[2160,2193,"Yeah."],[2193,2248,"Hello."],[2473,2515,"Uh..."],[2531,2602,"About that, yeah."],[2602,2752,"We can't fix it, okay?"],[2752,2877,"Hank is the only one that can."],[2877,3028,"He is the real expert, not us."],[3128,3182,"Hank?"],[3219,3311,"Hank Walker?"],[3386,3440,"Hank."],[3474,3599,"Hank Walker."],[3628,3795,"You know, he has been on"],[3795,3983,"about this fucking bullshit for ages."],[3983,4108,"Just ignore him."],[4162,4308,"The only thing Hank is good at"],[4308,4500,"is getting fired and lying."],[4500,4583,"Now hold on."],[4583,4808,"You did not just say that."]],"27":[[4,87,"Now, hold on."],[87,304,"You did not just say that."],[304,608,"Hank was our go-to guy for 40 years"],[608,746,"before you fired him."],[800,880,"You don't get it."],[900,1167,"You could spend all day on your gadgets."],[1192,1292,"You still won't know"],[1292,1418,"half the stuff Hank does"],[1418,1551,"about Webster's machines."],[1584,1643,"That's..."],[1710,1751,"You know what?"],[1751,1951,"Your old boss used to rave about"],[1951,2047,"how good you were."],[2118,2398,"But seeing as we are a tech company now,"],[2419,2460,"uh,"],[2489,2581,"our production line"],[2581,2827,"is under full supervision"],[2827,3007,"of our new AI detection system."],[3007,3299,"So your grandpa skills"],[3361,3486,"are no longer needed."],[3520,3599,"Capiche?"],[3757,3895,"So, you must be the expert."],[3895,4133,"Uh, we need this up and running fast."],[4149,4362,"You're not listening to me, okay?"],[4362,4446,"I can't do it."],[4446,4537,"Pierre can't do it."],[4537,4721,"Hank here is the only expert."],[4721,4825,"We're useless."]],"28":[[45,221,"You heard what Tom said."],[237,487,"This is, this is some old fart"],[487,646,"that we just fired last week."],[646,784,"He's an incompetent union pig"],[784,917,"just like the rest of them."],[971,1067,"I wouldn't even trust him"],[1067,1184,"to fix my vacuum,"],[1184,1309,"let alone a state-of-the-art"],[1309,1447,"million-dollar machine."],[1463,1559,"He's gonna break it. - Look."],[1601,1726,"You're gonna have to find someone else."],[1785,1889,"I'm done with Webster."],[1889,1981,"Hey, wait, wait, wait, wait."],[2022,2085,"You know what?"],[2085,2168,"If Hank's done,"],[2198,2289,"then we're out of here too."],[2289,2369,"We're not touching it."],[2369,2414,"What?"],[2448,2498,"Why?"],[2506,2698,"He's just a stupid union hack."],[2761,2919,"Please, Webster is counting on you."],[2919,2982,"We need you."],[3086,3190,"Wait, wait, wait, wait, wait."],[3257,3432,"What if we can pay Hank to fix it?"],[3495,3591,"Like, like purchasing"],[3591,3695,"like a patented method."],[3695,3774,"What if we can get him"],[3774,3903,"to sell his technique"],[4020,4175,"and then like, therefore it would"],[4175,4320,"technically be ours, right?"],[4320,4379,"Yeah, yeah, yeah."],[4379,4429,"That's good thinking."],[4446,4491,"Good thinking."],[4517,4558,"Okay."],[4596,4658,"Hey, Hank."],[4713,4850,"My associate here and I"],[4850,4909,"would actually like"],[4909,5025,"to offer you a position."],[5025,5105,"If you're willing to show us"],[5105,5180,"your techniques,"],[5209,5317,"we'd be willing to buy them."],[5351,5593,"Think of it as like a sort of patent."],[5722,5926,"You want to pay me for my"],[5926,6014,"tinkering skill?"],[6043,6110,"Exactly."]],"29":[[29,229,"Mr. Walker, our company is definitely"],[229,321,"wanting your skill"],[321,454,"set to be on board with us"],[454,796,"and we've prepared a very generous offer."],[934,992,"And if you would just"],[992,1105,"show your, show your technique"],[1105,1184,"just one more time."],[1230,1288,"Really?"],[1380,1584,"I mean, are my skills"],[1584,1714,"really worth that much?"],[1714,1768,"Well, yeah."],[1805,1843,"Yes."],[1843,1981,"And just to reiterate,"],[1981,2077,"all you got to do is show us."],[2077,2193,"And if you're willing to sell it,"],[2264,2364,"we'd be willing to buy it."],[2464,2552,"Come on, Hank."],[2673,2731,"Let them be, man."],[2731,2932,"These guys laid us off."],[2969,3144,"It's not on us to help them anymore."],[3144,3303,"Let the machines break down on them."],[3303,3370,"it'll serve them right"],[3370,3470,"for hanging us out to dry."],[3470,3603,"Ted, it's all right, okay?"],[3674,3812,"I worked here for 40 years."],[3858,3999,"I may not care about management,"],[3999,4137,"but I care about those machines."],[4320,4396,"I'll fix them."]],"30":[[8,66,"I'll fix them."],[196,312,"But I'm only gonna show you once,"],[312,400,"so keep your eyes peeled."],[400,500,"Okay? - Fair enough."],[521,575,"Wait, who?"],[575,629,"Whoa, whoa."],[650,696,"Hey."],[750,880,"He can't just go in there"],[880,1009,"and start banging things around."],[1034,1142,"If you break something,"],[1142,1259,"that's, that's on you."],[1259,1343,"Not me,"],[1343,1451,"not Lorne."],[1484,1539,"You."],[1539,1664,"I can't afford that."],[1664,1906,"That's a PRA-HWK cutter."],[1964,2060,"That's a twenty million dollar"],[2060,2168,"machine, minimum."],[2214,2348,"Now you just wait a second, okay?"],[2348,2464,"Have some faith in Hank."],[2464,2577,"He's the only man that can do it."],[2577,2723,"So just let him do it, okay?"],[2723,2948,"If he breaks it, it's gonna cost."],[2948,2990,"Okay, yeah."],[2990,3098,"Well, if he breaks it,"],[3244,3303,"we'll pay for it."],[3303,3386,"Whoa."],[3386,3445,"All right."],[3449,3499,"All right."],[3511,3570,"Deal."],[3603,3820,"But you better not go back on your word."],[4008,4058,"Hank."],[4275,4341,"The floor is yours."]],"31":[[33,204,"Boss, why did you let this wacko"],[204,312,"touch our machine?"],[312,442,"It stumped even the experts."],[442,550,"He's gonna break it."],[596,688,"Exactly."],[688,800,"If he breaks the machine,"],[800,863,"we could sue him"],[863,992,"and get a brand new model."],[992,1126,"We won't have to fix it anymore"],[1126,1209,"if it's brand new."],[1238,1347,"Yeah, nice."],[1372,1551,"All right, I will get some footage,"],[1551,1668,"and I'll prep our evidence"],[1668,1739,"for the courts."],[2431,2489,"All right."],[2548,2615,"All done."],[2673,2882,"It's been like five minutes."],[2919,3032,"Did you not break something?"],[3094,3190,"Take a look for yourself."],[3190,3249,"Start her up."],[3319,3357,"Okay."],[3357,3436,"Turn it on, then."],[3453,3520,"Let's see."],[5034,5092,"Yes!"],[5192,5351,"Oh my God, Hank, you did it!"],[5451,5555,"We knew you were the right guy"],[5555,5626,"for the job."],[5626,5801,"Wait, wait, wait, he fucking did it?"],[5855,5960,"You're surprised?"],[5980,6151,"You young bucks were so caught up"],[6151,6398,"in your computers and your AI,"],[6427,6664,"you forgot real hands-on experience."],[6664,6773,"And when it comes to that,"],[6773,6944,"nobody better than Hank Walker."],[7048,7178,"Letting him go was probably"],[7178,7286,"one of the worst mistakes"],[7286,7369,"you ever made."],[7436,7620,"Well, I'm gonna take off then."],[7649,7807,"Experts, you wanna talk about"],[7807,7920,"buying my techniques?"],[7974,8053,"I'm all ears."],[8074,8204,"No, not yet."]],"32":[[0,125,"No, not fucking yet."],[125,221,"You stay right there."],[350,433,"What is it now?"],[533,696,"I fixed your machine, didn't I?"],[738,884,"Well, fucking says you, dude."],[930,1080,"Okay, let me see here."],[1117,1267,"So, I'll give it to you"],[1267,1476,"that all the sensors are green."],[1476,1551,"But we don't know"],[1551,1705,"when it's gonna fucking break again."],[1705,1839,"So you are staying here"],[1839,2027,"to make sure it doesn't break again."],[2072,2264,"Tom, you fired the guy."],[2264,2444,"He still fixed the machine for you."],[2444,2565,"You can't just keep him here."],[2565,2702,"Like Tom said, alright?"],[2702,2932,"If he leaves, we're all alone."],[2932,3061,"Hank has to stay."],[3061,3111,"Yeah."],[3111,3294,"Last time, you told us it was fixed"],[3294,3445,"and then it got jammed."],[3465,3616,"If you wanna leave,"],[3616,3883,"you have to fucking give us something."],[3945,4191,"You gotta pay us, insurance."],[4283,4333,"Pay you?"],[4433,4487,"For what?"],[4487,4688,"Because you fucking broke our machine."],[4713,4863,"I recorded everything"],[4863,5050,"and I'm gonna plug in some algorithms"],[5050,5205,"and it's gonna tell me exactly"],[5205,5347,"what steps you did wrong."],[5426,5563,"Now wait just a damn minute, okay?"],[5563,5709,"Hank here has done everything"],[5709,5830,"that you guys have asked him to,"],[5830,5972,"so he doesn't owe you anything."],[6047,6243,"Hank, we are willing to offer you"],[6243,6423,"a blank check"],[6464,6635,"if you just tell us"],[6635,6735,"how you fixed the machine."]],"33":[[37,166,"We are willing to offer you"],[166,312,"a blank check"],[312,421,"if you just tell us"],[421,517,"how you fixed the machine."],[579,804,"Esteban is serious about that offer."],[838,996,"Don't tell me Hank's actually"],[996,1176,"a genius engineer in disguise."],[1209,1317,"If that's the case,"],[1317,1468,"I gotta figure out a way to keep him."],[1505,1593,"To be honest,"],[1689,1881,"I'm not sure what my skills are worth."],[1881,1976,"I promise you,"],[1976,2135,"any number that you put on that check,"],[2135,2218,"we will honor that."],[2239,2394,"Hank, your skills are priceless."],[2439,2544,"Well, let me sleep on it."],[2702,2769,"Wait!"],[2827,2902,"You still have to"],[2902,3023,"fix all the other machines"],[3023,3119,"in the assembly line."],[3140,3244,"And why should I do that?"],[3336,3386,"Huh?"],[3470,3549,"You fired me."],[3574,3716,"Threw me away like trash."],[3716,3870,"I won't have anything else to do"],[3870,3983,"with Webster Motors, okay?"],[3983,4083,"It's not my job."],[4137,4254,"We may have fired you,"],[4254,4404,"but the skills you learned,"],[4404,4504,"you learned them here,"],[4533,4562,"okay?"],[4562,4675,"You can leave."],[4675,4738,"That's fine."],[4738,4959,"But your skills, they stay here."],[5005,5176,"Do you even hear yourself right now?"],[5226,5276,"Yeah."],[5321,5422,"40 years."],[5451,5588,"That's decades of experience"],[5588,5830,"that you owe to Webster Motors."],[5830,5964,"The, the least you could do"],[5964,6135,"is fix the rest of the machines."],[6135,6243,"You owe us!"],[6289,6356,"I owe you?"],[6577,6669,"40 years."],[6723,6944,"I was here 40 goddamn years."],[6998,7311,"Rain, sleet, hail, snow, I came in."],[7382,7561,"I did the work no one else wanted to do."],[7732,7836,"My back is shot."],[7928,8020,"My knees scream"],[8020,8137,"when I wake up in the morning."],[8137,8395,"But I showed up every goddamn shift!"]],"34":[[54,187,"You paid us minimum wage"],[237,358,"and acted like it was charity."],[387,475,"Called us essential,"],[475,638,"then threw us away like trash."],[721,834,"You know why I stayed?"],[950,1051,"Webster Motors."],[1126,1317,"That name used to mean something."],[1472,1580,"My father worked here."],[1726,1801,"I thought..."],[1931,2114,"I believed I was a part of something."],[2223,2306,"Something that helped"],[2306,2419,"build America."],[2519,2631,"When my wife got sick,"],[2740,2898,"our health plan was worthless."],[2961,3057,"I buried her..."],[3215,3294,"with a pocket"],[3294,3465,"full of overdue hospital bills."],[3516,3574,"My daughter,"],[3574,3699,"she won't speak to me anymore."],[3741,3924,"She says I chose this place"],[3995,4087,"over family."],[4087,4141,"And you know what?"],[4237,4325,"Maybe she's right."]],"35":[[120,212,"Maybe I did."],[387,521,"But I stayed in Detroit."],[575,796,"I watched jobs disappear,"],[796,942,"factories shut down."],[971,1076,"But I stayed here."],[1130,1184,"Because I thought"],[1184,1322,"loyalty meant something."],[1468,1543,"A pension."],[1605,1651,"A promise."],[1651,1785,"That's all I ever wanted."],[1893,2089,"But instead, I got nothing."],[2110,2202,"Not a paycheck."],[2231,2327,"No security."],[2439,2531,"Not even a thank you."],[2648,2827,"And you sit in your glass office,"],[2865,2977,"wearing your suit paid for"],[2977,3182,"by the bones of men like me."],[3182,3336,"So don't you dare tell me"],[3336,3457,"that I didn't give enough!"],[3595,3712,"We gave you everything."],[3770,3903,"And you gave us nothing."],[4091,4266,"There's nothing left for us to give."],[4496,4658,"And before you kicked us to the curb,"],[4658,4754,"I warned him"],[4867,4984,"about those machines."],[5059,5205,"And did he do anything about it?"],[5321,5372,"No."],[5372,5459,"You didn't, did you?"],[5497,5693,"He warned you about the machine?"]],"36":[[108,304,"He warned you about the machines?"],[667,779,"I think he might have said something."],[779,838,"I..."],[871,1034,"I thought he was talking shit."],[1034,1146,"You thought wrong!"],[1172,1301,"That thinking of yours"],[1301,1518,"cost us millions of dollars."],[1518,1685,"How would I know what would happen?"],[1685,1872,"You, you fucking fuck!"],[1926,2106,"Now you're the one that has to pay."],[2106,2239,"No, I, I can't afford twenty"],[2239,2306,"million dollars."],[2306,2398,"Please, sir, please."],[2623,2815,"My apologies, Mr. Walker."],[2815,2977,"It's all Tom's fault, okay?"],[2977,3065,"We, we want you back."],[3065,3269,"We're gonna double your salary."],[3324,3457,"Double his salary?"],[3920,4012,"What is that, like"],[4012,4154,"like three thousand dollars?"],[4291,4625,"Miss Wolff, you're the CEO of Mach 15."],[4625,4733,"What are you doing here?"],[4733,4884,"Hank works for me now."],[4925,5000,"So I'm here to take him"],[5000,5084,"back to my company."],[5146,5263,"And just so we're clear,"],[5305,5417,"do you want to take a wild guess"],[5417,5559,"about how much I'm paying him?"],[5801,5993,"10, 10, 10K?"],[6197,6318,"Try ten million."],[6698,6794,"Ten million?"]],"37":[[16,120,"Ten million dollars?"],[145,250,"You've got to be kidding me."],[266,337,"Not at all."],[337,613,"I mean, I have no reason to lie to you."],[658,746,"I have been offering"],[746,834,"this position to Hank"],[834,1034,"time and time again."],[1059,1255,"And every time, he tells me no."],[1434,1497,"So it's a good thing"],[1497,1647,"you fired him when you did,"],[1647,1726,"or I would have never"],[1726,1805,"gotten him on board."],[1851,1951,"This is your fault."],[2022,2081,"You're the one"],[2081,2256,"that fired all these people!"],[2298,2414,"You're, you’re the reason"],[2414,2610,"we lost our diamond in the rough."],[2631,2786,"Hank, let's go."],[2815,2894,"Wait, Hank."],[2969,3061,"I mean, have you had a moment"],[3061,3244,"to think about our offer?"],[3336,3578,"We really want to patent your methods."],[3611,3737,"I need some more time."],[3770,3928,"Wait a minute, your methods?"],[3974,4070,"What is going on?"],[4070,4241,"Miss Wolff, our parent company"],[4241,4379,"is very, very interested"],[4379,4479,"in Hank's skills."],[4479,4612,"And we are prepared"],[4612,4859,"to give a very, very generous offer"],[4938,5163,"in exchange for his repair techniques."],[5201,5271,"How much?"],[5338,5547,"Well, we'll start at $10,000."]],"38":[[191,279,"$10,000?"],[279,367,"You can't be serious-"],[437,596,"You were all acutely aware"],[646,771,"of what a catch this man is."],[846,942,"And you're still trying to"],[942,1084,"pull the wool over his eyes"],[1084,1222,"with some lowball offer like that?"],[1222,1292,"Think again."],[1292,1401,"Wow, wow, wow. - Wait, wait, wait."],[1401,1484,"Just hold on, hold on."],[1584,1693,"We'll offer him"],[1793,1893,"one million dollars."],[1931,2135,"Oh please, Mr. Esteban."],[2135,2202,"Now you're just trying to"],[2202,2310,"play us for fools."],[2310,2640,"His salary is ten million dollars a year."],[2702,2777,"There's no way"],[2777,2932,"you're offering a million dollars"],[2932,3044,"for a patented skill."],[3044,3286,"He's demonstrated not once, but twice."],[3286,3370,"Just today."],[3399,3516,"Two million, two million."],[3549,3620,"At the end of the day,"],[3620,3720,"you wouldn't want to see"],[3720,3899,"Webster Motors fall, would you?"],[3941,4237,"It's, it's only for 10 minutes of your time."],[4270,4320,"Hang on, buddy."],[4320,4421,"You can't just butt in, okay?"],[4421,4533,"He was about to accept our offer"],[4533,4637,"for one million dollars."],[4696,4850,"It's a free market, all right?"],[4871,4950,"Free market."],[4984,5067,"It's Hank's decision."]],"39":[[79,154,"Okay, fine."],[275,346,"Three million."],[375,550,"Four, four, four million."],[550,613,"Five!"],[613,675,"Eight!"],[717,813,"Eight million."],[959,1155,"We are way outside of budget."],[1155,1343,"You are bleeding money right now."],[1359,1405,"No."],[1426,1543,"Fuck, fine, okay."],[1543,1605,"We fold."],[1659,1847,"Miss Wolff, eight million dollars."],[1901,1972,"Appreciate it."],[1972,2152,"Just to patent his methods"],[2185,2231,"for us."],[2264,2298,"I'm sorry,"],[2298,2348,"I think you're talking to"],[2348,2435,"the wrong person."],[2477,2581,"They're Hank's methods."],[2640,2756,"So it's his decision."],[2831,2894,"Mr. Walker?"],[2998,3086,"Hank. Hank."],[3086,3128,"Yeah."],[3128,3236,"Eight, eight million dollars."],[3236,3386,"That's just the starter, though."],[3386,3599,"Um, you're gonna get five million"],[3599,3728,"year by year after."],[3728,3903,"And you won't even have to lift a finger."],[3928,4054,"I've already made my decision."],[4204,4270,"When Miss Wolff"],[4270,4425,"brought me on to Mach 15,"],[4450,4683,"my skills were no longer just mine."],[4721,4813,"They're hers now, too."],[4846,4967,"Her company's been nothing"],[4967,5080,"but respectful to me"],[5080,5163,"from the beginning."],[5163,5246,"I'm sorry, Gary."],[5280,5367,"I'm not selling."],[5388,5476,"Clearly we might have"],[5476,5576,"overstayed our welcome."],[5718,5772,"Come on."],[5814,5976,"My engineers are dying to meet you."]],"40":[[37,262,"Miss Wolff, here are the optimizations"],[262,417,"for our next gen supercar"],[417,475,"that I worked on"],[475,608,"for the past three months."],[650,796,"Well, they look good so far."],[838,900,"Great."],[996,1117,"I also heard that"],[1117,1188,"you're still looking for"],[1188,1376,"the lead engineer for the project."],[1376,1568,"I'll be more than happy to fill that in-"],[1568,1647,"What is this?"],[1997,2114,"500 horsepower?"],[2193,2306,"That is not what we discussed."],[2306,2423,"I asked for 800."],[2439,2644,"I hired you from Webster"],[2644,2698,"because they're known"],[2698,2794,"for innovation."],[2811,2923,"So I don't want to see"],[2923,3111,"any more regurgitated garbage"],[3111,3257,"like this ever again."],[3257,3411,"Do I make myself clear?"]],"41":[[200,308,"Can't believe Boss"],[308,412,"poached that numbskull"],[412,500,"from Webster."],[521,713,"I hear they have a genius engineer"],[713,771,"working there"],[771,950,"who has never made a machine"],[963,1084,"he can never fix."],[1113,1213,"Rumor has it,"],[1213,1559,"not even the latest AI detection software"],[1559,1718,"can rival his expertise."],[1739,1889,"Why can't we get that guy instead?"],[1935,1993,"Right?"],[2010,2198,"Man, I wish we had an older guy"],[2198,2277,"with more experience"],[2277,2373,"rather than this kid."],[2373,2498,"I heard that super engineer"],[2498,2590,"from Webster"],[2590,2756,"has been there for 40 years."],[2756,2819,"Practically built"],[2819,2944,"their first cars himself."],[2994,3123,"There's no way we'll get past him."],[3215,3282,"And Ricky,"],[3319,3470,"I already have someone in mind"],[3470,3591,"for the lead engineer position."],[3657,3762,"What I would suggest"],[3762,3895,"is you worry about your own job"],[3895,4037,"before worrying about anyone else."],[4079,4212,"Yeah, Ricky, haven't you heard?"],[4279,4412,"Boss has brought in a new guy"],[4412,4508,"to be team lead."],[4562,4708,"Insane salary, too."],[4733,4879,"And they didn't tell me?"],[4929,5017,"Whoever it is,"],[5017,5155,"you stole that job right out"],[5155,5234,"from under me."],[5284,5455,"You better have some real skills,"],[5455,5609,"or I'm never letting this go!"]],"42":[[41,116,"Miss Wolff."],[254,308,"He's here."],[658,721,"Perfect."],[838,1084,"Everyone, this is Hank Walker,"],[1105,1217,"your new lead engineer."],[1288,1393,"I spent a fortune on him,"],[1393,1680,"but he's well worth every single cent."],[1714,1805,"He's a phenomenal"],[1805,1960,"designer and engineer,"],[2002,2097,"and I hope you all can learn"],[2097,2168,"a lot from him."],[2202,2398,"Wow. He's so handsome..."],[2460,2635,"From the way Miss Wolff looks at Hank,"],[2635,2831,"I know a crush when I see one."],[2861,3015,"Welcome to Mach 15, Mr. Walker!"],[3111,3278,"Happy to be here, folks."],[3324,3457,"Whoa, whoa, whoa, wait."],[3695,3895,"You're the guy from the dumpsters!"]],"43":[[8,196,"You're the guy from the dumpsters!"],[362,500,"Tom, you know this guy?"],[521,575,"Yep."],[608,738,"Fired him yesterday."],[792,930,"He's a piece of shit mechanic"],[930,1059,"who wouldn't stop going on about,"],[1059,1305,"oh, the assembly line's gonna explode."],[1347,1447,"So I got rid of him."],[1505,1697,"I know that guy."],[1710,1810,"That's the stupid old hobo"],[1810,1935,"that Tom fired."],[1981,2089,"He's a scrap collector."],[2089,2277,"How'd he end up at Mach 15"],[2277,2414,"as a lead engineer?"],[2473,2627,"Well, if anyone has any questions"],[2627,2748,"about engineering,"],[2769,2894,"feel free to ask Hank."],[2911,3011,"Most importantly,"],[3011,3128,"Hank will be taking over"],[3128,3249,"our supercar project."],[3294,3495,"the Silver Lynx Model A."],[3586,3674,"So from here on out,"],[3741,3878,"you'll all be reporting directly to him."],[3878,4170,"Wait, Ricky, wasn't that your project?"],[4170,4279,"She just up and handed it"],[4279,4341,"to the new guy?"],[4383,4562,"Boss, you can't do that."],[4637,4738,"This is my project."],[4796,4934,"Hank is not even an engineer!"],[4963,5159,"I, I caught him dumpster diving."],[5159,5334,"He's selling scrap metal for a living."],[5334,5451,"Ricky, watch your tone."],[5509,5697,"Hank is a generational talent."],[5747,5868,"And I hired him here"],[5868,6018,"with the express purpose"],[6018,6202,"of him taking over the supercar project."],[6202,6352,"But I, I saw him-"],[6352,6414,"Enough!"],[6523,6748,"I suggest if you want to keep your job,"],[6748,6902,"that you remain silent."],[7278,7365,"Fuck!"],[7741,7836,"Fuck!"],[7937,8037,"Fuck!"]],"44":[[0,87,"Fuck!"],[725,804,"I'm sorry"],[842,913,"about Ricky."],[950,1096,"I'm gonna be out of town for a few days."],[1155,1322,"I'm leaving Silver Lynx in your hands."],[1376,1438,"Don't worry."],[1551,1768,"We'll get results for you in no time."],[1976,2106,"Don't miss me too much while I'm gone."],[2156,2356,"Have a safe flight, Miss Wolff."],[2356,2498,"Hank, please."],[2606,2690,"Call me Emily."],[2752,2944,"That wouldn't be proper, ma'am."],[3007,3098,"You're my boss."],[3257,3319,"All right."],[3395,3570,"Well, I'll see you around."],[3649,3712,"Hopefully."],[4562,4779,"Well, everyone,"],[4779,4963,"just wanted you all to know"],[4963,5130,"that I'm honored to be here."],[5138,5263,"Let's get right down to it."],[5263,5380,"Who has the new specs?"],[5397,5513,"I got you, Mr. Walker."],[5776,5885,"He got you all wrapped around"],[5885,5951,"his finger."],[6018,6118,"Newsflash!"],[6118,6260,"He's a fraud."],[6339,6448,"Not an engineer."],[6473,6606,"He's a con artist."]],"45":[[8,162,"These people might not know"],[162,221,"who you are,"],[250,342,"but I do."],[392,588,"I saw you wolfing down scraps"],[588,692,"behind that dumpster."],[713,880,"You expect me to believe"],[880,1084,"you're a top notch engineer?"],[1134,1184,"Wait."],[1209,1401,"This guy was living out of a dumpster?"],[1426,1659,"And boss just hired him for no reason"],[1659,1755,"to be our team lead?"],[1830,1881,"What?"],[1926,2173,"I was going through a rough patch."],[2198,2360,"I didn't actually live out of a dumpster-"],[2360,2439,"Yeah, right."],[2473,2569,"You're no engineer."],[2606,2798,"You're a dirty, disgusting fraud."],[2798,2894,"Hey, hold on."],[3003,3148,"Let's listen to what he has to say."],[3148,3336,"Our CEO brought him on personally."],[3361,3474,"She probably knows him"],[3474,3549,"better than we do."],[3549,3616,"No."],[3616,3720,"No, no, no."],[3720,3820,"Let me explain."],[3966,4266,"This guy worked for Webster for 40 years"],[4266,4429,"and then got fired."],[4471,4708,"Imagine how incompetent"],[4708,4821,"you have to be"],[4821,5025,"to dumpster diving for food."],[5167,5321,"He even fucked with Webster's machines"],[5321,5401,"when he left."],[5447,5634,"What are you even wearing?"],[5910,6064,"You expect me to believe"],[6064,6202,"you're a genius engineer"],[6202,6310,"wearing that?"],[6510,6627,"You might have weaseled your way"],[6627,6760,"into Mach 15,"],[6819,6919,"but I know"],[6961,7278,"that you're a useless and fake fraud."],[7736,7832,"I'm not a fraud."]],"46":[[33,129,"I'm not a fraud."],[150,262,"Yeah, that's what a fraud"],[262,346,"would say, right?"],[383,458,"All right, guys."],[458,496,"Come on."],[496,575,"Are you really gonna"],[575,671,"work for this fraud"],[671,863,"or are you going to work with me?"],[863,917,"No."],[946,1038,"Screw the old guy."],[1046,1393,"Boo."],[1463,1589,"Congratulations."],[1622,1826,"Your first day as a lead engineer,"],[1826,2064,"and I already have your entire team"],[2064,2152,"under my thumb."],[2227,2406,"You need some real skill"],[2406,2527,"to survive here, bud."],[2585,2660,"You know what?"],[2790,2844,"We know that"],[2844,2977,"our boss is gonna be gone"],[2977,3073,"for some time, right?"],[3140,3307,"Why don't we both work on"],[3307,3503,"the Silver Lynx Model A project?"],[3549,3778,"Different designs, separate teams,"],[3845,3953,"and then we can test it"],[3953,4070,"at the Nurburgring."],[4108,4241,"Whoever's car performs better"],[4241,4387,"stays at Mach 15,"],[4387,4596,"and the loser, you gotta quit,"],[4654,4725,"forever."],[4788,4971,"You wanna make a bet?"],[5009,5063,"What?"],[5075,5171,"Are you afraid?"],[5171,5363,"You know, you can always just say no,"],[5392,5513,"admit you're a fraud."],[5538,5597,"Just quit."],[5630,5739,"They'll never respect me"],[5739,5851,"if I don't agree to this."],[5851,5943,"Worse, they'll think"],[5943,6068,"Emily Wolff is incompetent."],[6068,6147,"I have to do this."],[6168,6235,"I'll do it."],[6364,6452,"I'll make a bet with you."],[6610,6848,"Well then, Gramps, your fate is sealed."],[6848,7077,"Oh, I'm just dying to see you"],[7077,7294,"hand in your two weeks notice."],[7319,7469,"Because as soon as this happens,"],[7486,7657,"I will be the lead engineer,"],[7703,7945,"and you'll be sitting at home, balding."],[8058,8254,"I wouldn't be so sure about that, kid."],[8404,8516,"I may not look like it,"],[8537,8733,"but I know a thing or two about cars."]],"47":[[250,392,"Wow."],[554,696,"Wow, what an actor!"],[696,754,"Wow!"],[754,867,"I almost believed you."],[867,934,"But you know what?"],[934,1063,"I can call your bluff."],[1105,1388,"Our CEO, she might like you, but I don't."],[1418,1584,"When you lose,"],[1622,1776,"I expect you to hold up"],[1776,1918,"your end of the bargain, alright?"],[1976,2068,"A deal's a deal."],[2168,2239,"If I lose,"],[2310,2502,"I'll hand in my two week notice myself."],[2610,2806,"Because if I'm really worse than you,"],[2882,3040,"then I don't deserve the job,"],[3040,3178,"or the money that comes with it."],[3219,3440,"Mr. Walker, are you sure?"],[3457,3649,"Ricky's a cum laude graduate from MIT."],[3670,3749,"We can always wait"],[3749,3870,"until boss comes back."],[3945,4175,"You see, even the resident girl thinks"],[4175,4287,"you don't have what it takes."],[4287,4404,"Just save us some trouble,"],[4404,4521,"consider it now,"],[4521,4671,"before we rip what's left"],[4671,4829,"of your dignity to shreds."],[4992,5067,"It's okay."],[5109,5251,"What's your name? Yulia."],[5292,5388,"I know my limits."],[5543,5634,"What are your terms?"]],"48":[[8,233,"Our boss wants the Silver Lynx"],[233,387,"to clock in 800 horsepower,"],[387,508,"so we'll bet on that."],[567,792,"And whoever performs better"],[792,1013,"at Nurburgring wins."],[1080,1180,"As for the deadline,"],[1234,1376,"I'll give you a month."],[1572,1634,"You're on."],[1697,1830,"Well, boomer,"],[1864,2327,"your time starts now."],[2339,2481,"I can't wait to see you"],[2481,2585,"bawling your eyes out"],[2585,2794,"in just four weeks."],[2869,3011,"I wouldn't be so sure about that."],[3036,3211,"Shut up!"],[3261,3340,"All right, boys."],[3374,3461,"Let's get to work."],[3824,3899,"That's everybody."],[4074,4220,"We don't even have the drafts."],[4220,4320,"How are we supposed to"],[4320,4450,"design and build a car"],[4450,4562,"in just one month?"],[4579,4692,"This takes me back."],[4746,4917,"You know, I used to do this all the time,"],[4917,5000,"by myself."],[5046,5138,"Come on, I'll show you."]],"49":[[934,1021,"No way."],[1071,1234,"Did he just do that freehand?"],[1263,1447,"That's cleaner than our CAD outputs."],[1447,1680,"And he did all the calculations, too."],[1739,1860,"Who is this guy?"],[1972,2031,"Wait."],[2043,2206,"I thought boss rejected this design."],[2206,2339,"Aren't we supposed to be making it better?"],[2352,2460,"What do women even know"],[2460,2602,"about supercars, anyway?"],[2631,2890,"This is some cutting-edge shit."],[2915,2965,"We just need to"],[2965,3082,"throw more power on it."],[3119,3207,"We're more than enough"],[3207,3349,"to beat that old Hank guy."],[3361,3528,"Oh, look at that caveman."],[3557,3820,"Working harder, stupider."],[3862,3995,"At this rate, they won't even finish"],[3995,4099,"drawing the blueprint,"],[4099,4229,"much less build it."],[4275,4391,"When I to beat Hank,"],[4416,4592,"all of you guys are getting promotions."],[4608,4742,"Especially you, Max."],[4808,5046,"Now go be a champ, print it out for us,"],[5046,5184,"and have the team start assembling,"],[5184,5230,"all right?"],[5230,5292,"Got it, boss."],[5292,5447,"I'll tell them to go as fast as possible."],[5447,5576,"We're gonna have the best car around."]],"50":[[16,183,"Oh, Hank Walker."],[287,500,"You stole my lead engineer job"],[500,633,"right out from under me."],[675,871,"I'll show you what a real engineer does."],[959,1092,"In just four weeks,"],[1092,1276,"Emily Wolff will have to promote me"],[1276,1426,"because you will be dead."],[1993,2097,"What's up, Tommy boy?"],[2135,2231,"How's it going?"],[2293,2427,"How's Webster doing without me?"],[2560,2731,"You laid off their top engineer"],[2731,2977,"and lost hundreds of millions of revenue?"],[3065,3153,"Hold on."],[3236,3315,"What's his name?"],[3453,3599,"Don't tell me it's..."]],"51":[[563,625,"All right."],[746,863,"Where are your engine mills?"],[884,1088,"He's done in just two hours?"],[1134,1380,"But even our renders aren't this fast,"],[1405,1526,"or this precise."],[1584,1664,"We only have"],[1664,1826,"one fully automated engine assembly,"],[1826,2014,"and Ricky has commandeered it."],[2077,2227,"The other one is decades old"],[2227,2389,"and requires manual assembly"],[2389,2502,"on nearly every part."],[2531,2740,"But these tolerances are insanely tight."],[2740,2798,"There's no way"],[2798,2911,"you can build a supercar engine"],[2911,2961,"on that."],[2982,3107,"Don't knock it till you try it."],[3282,3428,"He wants to do it manually,"],[3428,3511,"all by himself?"],[3553,3703,"I guess that's what 40 years"],[3703,3807,"in the industry gets you."],[3849,4012,"I'm starting to believe in this guy."],[4037,4179,"Maybe he does have a shot at this."],[4250,4350,"Trust me, Ricky."],[4350,4529,"That Hank guy is a fraud."],[4546,4733,"He jumped in right after our experts"],[4733,4825,"fixed the machine,"],[4825,4959,"and took all the credit for himself."],[4988,5142,"I can't believe he actually swindled"],[5142,5196,"your CEO."],[5238,5401,"Women are so dumb and gullible."],[5455,5613,"Oh, thank God!"],[5672,5860,"I really thought that fucking dinosaur"],[5860,6014,"was a genius engineer."],[6131,6252,"They're starting on it, boss."],[6272,6368,"In just a few days,"],[6368,6464,"we're gonna have a brand new engine."],[6523,6644,"We'll start testing early."],[6710,6794,"Perfect."],[6861,6977,"Hank Walker."],[7057,7198,"You are a dinosaur!"]],"52":[[625,746,"Yulia."],[817,984,"I didn't expect you to show up."],[1038,1101,"What?"],[1101,1222,"Hank managed to scrap"],[1222,1343,"some beater together?"],[1359,1505,"I know you did this on purpose."],[1547,1689,"A month's nowhere near enough time"],[1689,1785,"to build a car, but,"],[1860,1935,"just you wait."],[1935,2035,"It's all excuses."],[2056,2223,"Hank already agreed to the terms."],[2223,2381,"You better pray your car holds up,"],[2381,2527,"or Hank's going bye-bye."],[2544,2669,"Speaking of which,"],[2769,2865,"where is that guy?"],[2944,3036,"Where's his car?"],[3086,3236,"Did he hightail it out of here?"],[3265,3453,"Just wait until you see what he's built."],[3490,3641,"He's been working day and night"],[3641,3799,"pushing that car to its limits."],[3837,3941,"I have full confidence"],[3941,4041,"our car's gonna make it."],[4041,4170,"Really?"],[4220,4337,"Because I heard"],[4371,4550,"that he's been putting it together"],[4550,4833,"on this old manual junk station"],[4833,5117,"that has been abandoned for years."],[5130,5263,"We had to use the old one"],[5263,5380,"because you commandeered"],[5380,5513,"our new assembly line."],[5538,5593,"Hank would have been done"],[5593,5663,"it weeks ago"],[5663,5759,"if it wasn't for you."],[5814,5980,"Ten minutes until official start time,"],[5980,6085,"and he's still AWOL."],[6106,6218,"I wonder what the hell he's doing."],[6218,6352,"Cold feet, I bet."],[6456,6702,"Probably crying back home"],[6702,7027,"because he knows he's going to lose."],[7098,7207,"If he doesn't show up"],[7207,7357,"in the next five minutes,"],[7399,7540,"I'm calling a forfeit."]],"53":[[8,108,"If he doesn't show up"],[108,254,"in the next five minutes,"],[321,483,"I'm calling forfeit."],[959,1163,"Today is the day"],[1163,1418,"Hank Walker loses everything."],[1497,1697,"And I'm going to call Miss Wolff"],[1697,1906,"and tell her how wrong she was"],[1906,2014,"about this guy."],[2089,2260,"Because he's a failure,"],[2293,2435,"he's a fuck-up,"],[2452,2748,"and he's a dog-shit engineer."],[2861,3057,"Super genius, my ass!"],[3094,3207,"Right on, Ricky."],[3253,3336,"You're the only one"],[3336,3499,"that deserves to be the lead engineer."],[3541,3616,"That's right."],[3674,3820,"And when that happens,"],[3824,3916,"you'll be the first one"],[3916,4024,"I'm going to promote."],[4704,4833,"As for you, Yulia,"],[4867,5075,"you're going down with Hank."],[5113,5217,"Because I don't need a"],[5217,5376,"disloyal woman like you"],[5376,5459,"around me."],[5509,5626,"No, I believe in Hank."],[5659,5814,"He's not gonna lose to you."],[5814,6026,"It's just five minutes before the go time."],[6026,6156,"Even if he shows up,"],[6156,6302,"he's still going to lose."],[6318,6393,"If I were you,"],[6393,6527,"I would start getting prepared"],[6527,6648,"for the unemployment life."],[6752,6915,"That's not for you to decide."]],"54":[[20,208,"That's not for you to decide."],[241,408,"Mr. Walker, I knew you'd come."],[487,567,"How's our car doing?"],[567,721,"Bad, of course."],[800,930,"There's no fucking way"],[930,1134,"this fossil can build a supercar"],[1134,1409,"using this antique manual station."],[1438,1614,"Let alone something that runs."],[1614,1689,"Oh, I hate to"],[1689,1818,"disappoint you, Ricky, but-"],[1818,1926,"All right, Ricky,"],[1926,2039,"you're looking at Hank's car."],[2039,2131,"We're ready when you are."],[2811,2911,"Is that your car?"],[2977,3078,"You actually managed"],[3078,3165,"to build something?"],[3294,3349,"You know what?"],[3370,3432,"It's fine."],[3570,3670,"If it looks like a car"],[3670,3828,"but doesn't drive like a car,"],[3870,3974,"that's not a car."],[4033,4141,"Don't be too hasty."],[4233,4316,"The numbers are gonna"],[4316,4412,"speak for themselves."],[4412,4575,"Shut up!"],[4629,4804,"We're about to start getting testing."],[4825,5067,"And as soon as the results are in,"],[5067,5305,"you are out of Mach 15."],[5317,5734,"And you are going to regret everything."],[5814,6110,"And I'm going to point at you"],[6193,6389,"and laugh."],[6552,6610,"All right,"],[6631,6810,"first up we have Ricky's prototype."],[7203,7315,"Gotta hand it to him."],[7336,7490,"That car sure is fast."],[7536,7699,"And mine's no slacker either."],[7757,7903,"I've been making a lot of adjustments,"],[7903,8041,"just gotta pray we'll beat him."]],"55":[[129,300,"Okay, we have the readings"],[300,379,"to Ricky's car."],[412,500,"Come on, God."],[500,621,"800."],[679,825,"The car reached a maximum speed"],[825,1017,"of 240 miles per hour"],[1088,1247,"and 800 horsepower."],[1735,1818,"Yes!"],[1818,1897,"We did it!"],[1918,2064,"And only a handful of cars"],[2064,2198,"could go that fast."],[2218,2289,"I won!"],[2356,2560,"I won! In your face!"],[2560,2848,"In your stupid fucking face!"],[2848,2915,"Fuck you!"],[3386,3470,"Look at this."],[3532,3745,"800 horsepower."],[3749,3853,"You will never fucking"],[3853,3949,"measure up to it."],[3995,4104,"Just forfeit."],[4375,4721,"Mr. Walker, we're not gonna lose, are we?"],[4771,4854,"It's not over yet."],[4950,5075,"Now we're gonna test my car."],[5075,5246,"Oh, shut the fuck up!"],[5246,5426,"You know you can't surpass that."]],"56":[[20,154,"You haven't seen it yet, have you?"],[204,312,"So you wanna test, huh?"],[367,425,"All right."],[462,529,"All right."],[613,834,"But we're going to raise the ante."],[855,959,"What are you suggesting?"],[984,1121,"Well, I heard that you were hired"],[1121,1297,"because you fixed one of our machines."],[1313,1522,"And Miss Wolff is paying you"],[1551,1814,"Ten million dollars."],[1830,2006,"Ten million dollars?"],[2006,2173,"That's seven zeros."],[2173,2243,"Oh my God,"],[2243,2394,"that's an insane amount of money."],[2419,2506,"I knew it."],[2560,2727,"If boss is paying him that much,"],[2748,2890,"he has to be the real deal."],[2936,3140,"You useless piece of shit."],[3140,3357,"You are one foot in the grave."],[3357,3461,"Why do you even need"],[3461,3566,"so much money?"],[3586,3753,"It's supposed to be mine."],[3753,3937,"Ricky, I'm not here for the money."],[4029,4325,"I'm here to do real, serious work."],[4354,4479,"Miss Wolff, she's paying me"],[4479,4646,"to make Mach 15 proud."],[4646,4675,"All right?"],[4675,4783,"I'm not wasting that money"],[4783,4909,"on something that doesn't matter."],[4909,5005,"Yeah, yeah, yeah."],[5005,5059,"We all know"],[5059,5171,"you're doing this for the money."],[5221,5392,"And this is my new ante."],[5417,5505,"Your salary."],[5601,5701,"If you lose,"],[5722,5864,"you're going to give me"],[5880,6064,"Ten million dollars."],[6210,6289,"That's okay."],[6410,6539,"I don't plan on losing."]],"57":[[4,91,"You hear this guy?"],[104,262,"Enough with bragging."],[291,487,"You're going to lose!"],[517,771,"You seem awfully confident in that."],[771,875,"Fuck yeah, I'm confident."],[875,1051,"I asked around about you, Hank."],[1134,1288,"I know you're a fraud."],[1338,1497,"You managed to swindle Emily Wolff"],[1497,1655,"because she doesn't know better."],[1760,2231,"So accept my bet or admit you're a fake."],[2260,2389,"Mr. Walker, don't."],[2389,2569,"Our boss is on her way here right now."],[2577,2660,"As soon as she gets here,"],[2660,2781,"she'll settle all of this."],[2936,3007,"It's all right."],[3048,3157,"I know that a lot of you"],[3157,3332,"feel a certain way about me."],[3353,3611,"That I'm old, dumb, and uneducated."],[3645,3816,"You think I don't deserve to be here."],[3891,4070,"And that I don't deserve that salary."],[4158,4316,"But I'm here to prove"],[4316,4650,"every single one of you wrong."]],"58":[[25,241,"So, is it a yes?"],[304,504,"Will you give me your salary?"],[542,654,"What do I get if I win?"],[709,804,"Come on."],[846,971,"There's no fucking way"],[971,1063,"you're going to win."],[1121,1276,"That's not how this works."],[1301,1384,"You have to put something"],[1384,1451,"on the line."],[1480,1555,"How about this?"],[1568,1705,"If you lose,"],[1705,1922,"we get to parade you around the office,"],[1922,2052,"wearing a sign that says,"],[2052,2310,"Hank Walker is a genius engineer."],[2331,2489,"And you get to explain to everybody"],[2489,2573,"why that is."],[2573,2631,"What?"],[2673,2865,"That's, that's public humiliation."],[2865,2986,"I'm, you can't do that."],[2986,3111,"I'm going to report you to HR."],[3111,3203,"Are you scared?"],[3282,3490,"Hank has ten million on the line"],[3490,3674,"and you can't do one lap"],[3674,3787,"around the office?"],[3832,3903,"Um..."],[4220,4283,"Fine!"],[4408,4475,"I'll do it."],[4533,4596,"I'll do it."],[4646,4825,"Let's shake on this, old man."],[5113,5359,"Your ten million is mine."],[5576,5630,"Hey!"],[5680,5843,"Go and test Hank's car!"]],"59":[[342,542,"Oh, just three minutes left."],[558,729,"Oh, I can't wait to see"],[729,984,"both of you on your knees,"],[1026,1292,"begging me to let you off the hook."],[1376,1559,"Give it up, Mr. Jurassic."],[1559,1664,"No beat-junker car"],[1664,1822,"can get up to 800 horsepower."],[1822,1881,"You might as well"],[1881,1964,"tuck your tail and run"],[1964,2043,"while you still can."],[2043,2139,"And as for Ricky,"],[2139,2235,"he's gonna get a promotion."],[2235,2339,"Sit tight, son."],[2414,2485,"Who knows?"],[2527,2648,"Maybe we'll get a miracle."],[2731,2827,"My prototype reached"],[2827,2994,"800 horsepower weeks ago."],[3065,3161,"I'm just here to see"],[3161,3282,"how far I can push it."],[3370,3607,"The only miracle would be"],[3607,3862,"if that this piece of junk"],[3862,4049,"can score at least half"],[4070,4237,"of the required horsepower."],[4237,4475,"Just fork ten million dollars over,"],[4533,4717,"and go die in a hole,"],[4717,4917,"you fucking eyesore."],[5000,5184,"You're so behind times,"],[5184,5434,"you might as well just off yourself."],[5434,5593,"Take that back, Ricky."],[5651,5805,"Mr. Walker's been working on cars"],[5805,5947,"longer than you've been alive."],[5980,6114,"Have some respect for him,"],[6114,6318,"and the auto industry, and Detroit."],[6631,6702,"I don't even know"],[6702,6806,"why I'm looking at this."],[6819,6986,"There's no fucking way."]],"60":[[120,216,"No!"],[233,329,"Hank Walker's car"],[329,417,"reached a maximum speed"],[417,608,"of 260 miles per hour"],[650,813,"and 1,000 horsepower."],[975,1188,"No wonder the boss loves him so much."],[1217,1405,"He's so sexy."],[1426,1493,"You did it!"],[1493,1601,"I knew you could!"],[1601,1651,"No."],[1689,1730,"No."],[1747,1801,"No, Liam."],[1801,1830,"No."],[1830,1893,"There's no way."],[1918,1972,"There's no way"],[1972,2102,"that piece-of-shit car"],[2118,2302,"could muster up 1,000 horsepower."],[2302,2373,"Go run the numbers."],[2373,2452,"Go check them again."],[2473,2552,"That's bullshit."],[2615,2744,"They fucked up the numbers."],[2877,3053,"Have them tested again"],[3094,3228,"and check double,"],[3240,3440,"triple times the numbers."],[3511,3720,"Ricky, they test thousands of cars."],[3720,3841,"We can trust their data."],[3841,4187,"I don't give a fuck!"],[4216,4387,"There's no fucking way"],[4387,4521,"his car is more powerful"],[4521,4642,"and faster than mine."],[4775,4867,"It's about the details."],[5067,5296,"Run the test again!"],[5380,5609,"Well, Mr. Walker, are you okay with that?"],[5630,5714,"You're well within your right"],[5714,5818,"to refuse a retest."],[5935,6177,"Oh, you would love to refuse, right?"],[6222,6406,"Because you fucked with numbers."],[6406,6585,"I bet you've paid those Germans"],[6585,6735,"to fake results for you."],[6765,6952,"Don't worry about Ricky, Mr. Walker."],[6986,7182,"Our CEO is on her way here right now."],[7182,7290,"She'll sort this all out"],[7290,7369,"when she gets here."],[7457,7678,"Ricky, we'll do it."],[7720,7849,"No, Mr. Walker, don't."],[7895,8091,"I want to see how far we can push this car."]],"61":[[41,196,"Alright, if that's the case,"],[196,396,"I'll run the numbers live on screen"],[433,563,"before Ricky can accuse us"],[563,642,"of cheating again."],[667,750,"Fucking Judah."],[1630,1714,"He's doing it!"],[1722,1956,"It just passed 250 and it's still going!"],[1985,2135,"No, no, no, no, no!"],[2135,2298,"That's not supposed to be happening!"],[2298,2502,"He's a fucking old hobo!"],[2527,2673,"A dumpster diver!"],[2706,2877,"A manuscript collector!"],[2877,3061,"How the fuck is his car"],[3061,3182,"better than mine?"],[3194,3524,"Hank's car clocked in at 1,500 horsepower"],[3524,3628,"with a maximum speed"],[3628,3853,"of 285 miles per hour."],[3912,3974,"Yes!"],[4058,4145,"You did it!"],[4170,4266,"I knew you could!"],[4366,4462,"What do I do?"],[4500,4575,"I think I'm starting to"],[4575,4700,"have a crush on him, too."],[4808,4913,"Kids these days."]],"62":[[25,208,"You really showed them, Mr. Walker."],[216,342,"You did it the old-fashioned way"],[342,446,"with a pen and paper"],[446,533,"and you still did better"],[533,713,"than Ricky's whole team could do."],[713,950,"Oh, shucks, Miss Yulia."],[1009,1197,"Just doing what I know best."],[1247,1330,"It's much easier for me"],[1330,1422,"than that new-fangled"],[1422,1580,"technology you guys use."],[1593,1726,"No, no, no, no, no, no, no, no."],[1726,1818,"You're lying!"],[1897,2064,"You lying motherfucker!"],[2160,2302,"I won't let you win."],[2335,2460,"I won't lose to you."],[2477,2627,"I can't lose to you!"],[2669,2777,"Run the test again."],[2777,2898,"Ricky, that's too far."],[2898,3036,"You already made him scrap the results"],[3036,3128,"from the first test."],[3174,3261,"Just admit it."],[3299,3411,"Hank is better than you."],[3499,3645,"You've lost."],[3666,3812,"Hank Walker."],[3874,4295,"I hate you!"],[4320,4446,"I'm not gonna let you win."],[4483,4633,"Have them run the third test!"],[4637,4754,"Enough."],[5326,5438,"A third test"],[5463,5622,"won't change the results, Ricky."],[5705,5814,"You lost."],[6164,6339,"Hank, it's nice to see you again."]],"63":[[33,116,"Miss Wolff."],[204,387,"I, I really needed to tell you."],[408,633,"He's been lying all this time to you."],[650,834,"When he was fired from Webster,"],[834,980,"he was not a genius engineer."],[980,1184,"He was just a stupid mechanic."],[1267,1397,"He was a dumpster diver"],[1397,1518,"when he swindled you."],[1518,1780,"I am aware of Hank's situation."],[1805,2052,"But it would seem"],[2164,2268,"that he's a better fit"],[2268,2473,"for this company than you are."],[2952,3044,"It's fake!"],[3069,3144,"It's fake!"],[3165,3365,"There's no way this car"],[3365,3687,"is even close to 2,000 horsepower."],[3687,3862,"I trust my employees, Ricky."],[3908,4091,"My eyes and ears at this company"],[4091,4195,"told me everything."],[4270,4371,"You lost."],[4412,4554,"And don't forget your end of the bargain."],[4554,4650,"We're gonna parade you"],[4650,4737,"around the facility"],[4737,4892,"with a sign around your neck."]],"64":[[446,521,"Off you go!"],[521,617,"Ah, you know what?"],[617,667,"It's okay."],[667,796,"We should just let it slide."],[834,992,"You know, he is one of our designers."],[992,1084,"After all, I,"],[1159,1426,"I feel like we've taken this too far."],[1493,1559,"No."],[1639,1718,"Leave it."],[1839,1918,"It's what he gets."],[2006,2152,"Maybe this will teach you"],[2152,2264,"not to hedge your bets."],[2289,2356,"Let's go."],[3232,3557,"This isn't over yet, Hank Walker."],[3566,3737,"What I'm about to do to you"],[3753,4012,"is your own damn fault!"]],"65":[[258,312,"Hank."],[367,446,"Take a seat."],[496,642,"Sorry, Miss Wolff."],[704,921,"That was a bit reckless of me"],[921,1038,"to take that bet."],[1038,1084,"Oh."],[1126,1188,"That?"],[1251,1355,"No, that was great."],[1451,1685,"In fact, I wanted to thank you"],[1685,1814,"for taking Ricky down a peg again."],[1885,2056,"He's been an absolute menace"],[2056,2164,"to all of our employees"],[2181,2289,"ever since he got hired."],[2369,2498,"So, you saved me the trouble of"],[2498,2577,"having to do it myself."],[2577,2644,"I see."],[2802,2932,"I actually wanted to talk to you"],[2932,3036,"about your prototype"],[3053,3186,"for the Silver Lynx Model A."],[3290,3370,"I want to move forward"],[3370,3436,"with your design."],[3436,3620,"In six months, Mach 15 will be"],[3620,3762,"attending the Supercar Expo"],[3762,3841,"in Monaco."],[3908,4045,"I plan to host a press conference"],[4045,4158,"to unveil the Silver Lynx."],[4316,4379,"Do you think you could"],[4379,4487,"have a road-ready model finished"],[4487,4567,"by then?"],[4625,4859,"Six months is a tight turnaround."],[4975,5075,"But it's not a problem"],[5075,5176,"for an old hand like me."],[5372,5451,"I'll get right on it."],[5509,5551,"Great."],[5668,5759,"I'll get right to it."]],"66":[[1426,1488,"Um."],[1559,1772,"Hank, I was actually wondering"],[1772,1868,"if you would"],[1918,2052,"want to get a drink together sometime?"],[2106,2223,"Who else is gonna be there?"],[2298,2444,"Does Hank like Miss Wolff too?"],[2569,2635,"No one."],[2773,2877,"I was thinking it could"],[2952,3061,"maybe just be the two of us."],[3107,3190,"Oh, uh,"],[3244,3357,"Miss Wolff, I uh-"],[3357,3415,"Emily."],[3570,3682,"Please just call me Emily."],[3820,3999,"How about this weekend, maybe?"],[4287,4375,"Um..."],[4475,4550,"Apologies."],[4583,4708,"Emily, uh."],[4779,4833,"Sorry."],[4833,4884,"Um."],[4909,4971,"Miss Wolff."],[4971,5030,"You know, I,"],[5105,5288,"I have some things I need to take care of."],[5288,5338,"Um."],[5772,5939,"That man is as dense as a rock,"],[6010,6114,"but I'll crack him some day."]],"67":[[246,450,"Tom Norris, I thought you said that"],[450,658,"this old fuck you fired was a fraud."],[675,796,"Then why did my CEO"],[796,925,"pick his design over mine?"],[967,1142,"He found every inefficiency"],[1142,1197,"in my draft"],[1197,1322,"and fixed everything!"],[1351,1534,"What the hell are you on about Ricky?"],[1559,1639,"There's no way"],[1639,1701,"he could have done that."],[1701,1860,"I told you he's useless."],[1918,2106,"Hey, shut up!"],[2185,2235,"Do you know"],[2235,2360,"what they did to me in Nürburg?"],[2410,2606,"It was a social suicide."],[2606,2690,"Hey, look."],[2706,2882,"I don't know how he did that."],[2944,3053,"Maybe your boss hates you"],[3053,3148,"and slipped him some intel"],[3148,3236,"on the down-low."],[3257,3424,"All I can promise you is that"],[3424,3570,"when he worked at Webster,"],[3574,3687,"he was useless"],[3687,3874,"and knew jack shit about engineering."],[3974,4058,"Fuck!"],[4162,4241,"They made me look like"],[4241,4341,"a clown out there!"],[4416,4537,"Now he's in control"],[4537,4700,"of Silver Lynx's project"],[4700,4833,"and I got demoted."],[4875,5013,"Everyone loves him now"],[5013,5130,"and everybody's treating me"],[5130,5251,"like I'm fucking looney."],[5271,5488,"You know, you just gave me an idea."],[5622,5709,"How would you feel about"],[5709,5860,"ruining Hank's reputation?"],[5968,6164,"Everything he has will be yours,"],[6239,6448,"including that ten million dollar salary."],[6489,6569,"What's the plan?"],[6873,7036,"Are you sure this will work?"],[7057,7152,"110%."],[7182,7294,"I'm a reporter now."],[7311,7424,"I get front row seats"],[7424,7582,"to every single press conference"],[7582,7649,"in the world."],[7699,7853,"Once I get word out to the media,"],[7899,8058,"Hank's reputation will be ruined."]],"68":[[1601,1814,"Hank, we have everything prepared"],[1814,1897,"for you over there."],[1972,2131,"Um, I'm gonna do some networking"],[2131,2256,"before the press conference starts."],[2281,2389,"Go work your magic."],[2477,2581,"I'm gonna wait here"],[2581,2698,"for my granddaughter"],[2698,2823,"and I’ll come in with her."],[2873,2961,"Of course."],[3541,3603,"Hank."],[3741,3841,"Would you look at that?"]],"69":[[108,179,"Hank."],[266,383,"Would you look at that?"],[396,650,"It's our quote, unquote star"],[650,729,"of the show."],[746,934,"Ten million dollar salary, huh?"],[1030,1217,"What's a big man like you doing"],[1217,1330,"all alone, huh?"],[1368,1480,"Unless you're lying."],[1514,1739,"Tom, what are you doing here?"],[1789,1901,"Isn't it obvious?"],[2014,2147,"I'm a reporter now."],[2198,2268,"Thanks to you."],[2331,2502,"I got fired from Webster!"],[2502,2736,"You cost us millions of dollars!"],[2769,2952,"But I'll let bygones be bygones."],[2973,3207,"I'm a very important reporter now."],[3249,3345,"We're doing an exclusive"],[3345,3424,"on you later."],[3465,3616,"So you better watch your mouth"],[3645,3757,"or I'll ruin you."],[3774,3853,"Oh, but,"],[3870,4074,"Tom, I'm mighty glad"],[4074,4204,"that you found a new job."],[4254,4341,"I hope you"],[4354,4504,"don't do any of that funny business"],[4504,4633,"like you did over at Webster."],[4658,4733,"I'm sure you'll do great."],[4733,4925,"Shut up, you little piece of-"],[4925,5017,"Grandpa!"],[5689,5776,"Grandpa!"],[5985,6277,"Grandpa, is it true that you made"],[6277,6489,"the Silver Lynx Model A?"],[6544,6690,"Of course I did, Audrey."],[6710,6944,"I made that car all by myself."],[7011,7182,"Like hell you did."],[7261,7353,"Listen, kid."],[7386,7632,"Your grandpa doesn't know anything."],[7661,7887,"He's a big, fat loser."]],"70":[[33,262,"He's a big, fat loser."],[296,671,"So you didn't make the car, Grandpa?"],[684,784,"No way, Audrey."],[863,934,"Remember?"],[1017,1142,"Grandpa's a super cool"],[1142,1259,"car designer now."],[1280,1493,"And he makes a lot of money"],[1493,1643,"at Mach 15."],[1668,1822,"I'm sure he built that car."],[1860,1989,"Long time no see, old man."],[2031,2206,"How's that paycheck coming along?"],[2298,2540,"So, we were wondering"],[2610,2873,"if we could just borrow"],[2873,3069,"a teeny bit of more money,"],[3069,3282,"um, just to pay off the mortgage."],[3303,3390,"The bank's really been"],[3390,3457,"on our ass about it."],[3457,3636,"Dad, they're gonna foreclose on us"],[3636,3753,"if we don't get them the money."],[3820,3966,"And you don't want Audrey"],[3966,4099,"to be homeless, right?"],[4141,4287,"Freezing out on the streets?"]],"71":[[12,166,"We were wondering"],[166,316,"if we could just borrow"],[316,508,"a teeny bit of more money."],[521,579,"Uhm..."],[579,679,"You don't want Audrey"],[679,767,"to be homeless,"],[767,838,"Wait a minute. - right?"],[850,917,"Wait a minute."],[1001,1130,"I gave you guys money."],[1172,1276,"Six months ago."],[1284,1418,"That should have been plenty enough"],[1418,1518,"to cover the mortgage"],[1518,1597,"and then some."],[1630,1685,"What happened?"],[1822,1976,"Uh, here's the thing."],[2072,2306,"We decided to invest some of the money."],[2360,2556,"And we bought some shares"],[2556,2690,"in a up and coming"],[2690,2869,"social media sensation."],[2898,3065,"But then,"],[3148,3244,"out of nowhere,"],[3324,3445,"they completely collapsed."],[3482,3741,"And now we owe them $500,000"],[3741,3824,"and you're the only one"],[3824,3870,"Please! - who can help"],[3870,3920,"us out."],[4008,4220,"$500,000 is basically like"],[4220,4337,"spare change to you."],[4354,4471,"You are gonna make millions"],[4471,4567,"with a supercar."],[4592,4675,"Please, Dad,"],[4675,4829,"just help us out one more time."]],"72":[[20,116,"Please, Dad,"],[116,258,"just help us out one more time."],[333,454,"If I give them the money now,"],[454,529,"Jesse's just gonna"],[529,675,"blow it all on gambling again."],[700,809,"I'll call the servicer"],[809,971,"about the mortgage myself tomorrow."],[1021,1259,"I'm sorry, I, I can't."],[1376,1476,"I don't have the money."],[1509,1555,"No!"],[1555,1584,"What?"],[1584,1634,"No!"],[1710,1897,"You make ten million dollars a year."],[1935,1981,"That's almost"],[1981,2097,"a million dollars a month!"],[2160,2339,"$500,000 is like chump change"],[2339,2389,"to you."],[2435,2598,"You care that little for us?"],[2635,2798,"Either that or"],[2852,2969,"he never had the money"],[2969,3098,"in the first place."],[3174,3286,"What are you saying?"],[3370,3645,"Well, he never had the money."],[3687,3858,"Because he's not an engineer"],[3858,4008,"and he's not getting paid."],[4008,4187,"He lied about everything."]],"73":[[4,175,"He lied about everything."],[212,300,"No, no, no."],[300,392,"You're pulling my leg."],[425,608,"We were in the factory with him"],[663,809,"when he signed the contract."],[809,892,"I saw it."],[900,1063,"It said ten million dollars."],[1063,1242,"There's no way that that was a fake."],[1263,1343,"That was real."],[1438,1634,"But he got fired a week later"],[1634,1839,"when the CEO, Emily Wolff,"],[1839,2064,"realized what I knew all along,"],[2064,2327,"that Hank is a fraud, and a liar"],[2356,2615,"who doesn't know anything about cars."],[2615,2694,"Damn it!"],[2777,2861,"Fuck you!"],[2861,2965,"I knew it!"],[3003,3190,"I bet you didn't even build that car."],[3190,3294,"No, Jesse."],[3319,3553,"That is not what happened, okay?"],[3553,3828,"Well, so you didn't make the car,"],[3828,3908,"Grandpa?"],[3916,4225,"I told all my friends I'll get pictures."]],"74":[[66,116,"No."],[166,266,"Look at me, Audrey."],[266,379,"Look at grandpa."],[379,667,"I promise you, I made that car."],[704,880,"For six months,"],[880,1130,"I put my blood, sweat, and tears"],[1130,1276,"into that car."],[1359,1463,"You're gonna get that picture."],[1551,1618,"Really?"],[1668,1768,"Pinky promise."],[1872,1960,"Oh, Hank."],[2018,2097,"You probably don't know"],[2097,2206,"how things work,"],[2227,2419,"but everything is already set up"],[2419,2515,"for the press conference,"],[2515,2694,"and I don't see your name"],[2694,2827,"on a single thing here."],[2890,3048,"You're not fooling anyone."],[3048,3140,"What are you talking about?"],[3157,3336,"I built that car, alright?"],[3374,3532,"My name better be next to it."],[3553,3641,"If you don't believe me,"],[3699,3828,"we'll go take a look ourselves."],[3883,3958,"Sure thing, buddy."],[3958,4095,"You, you lead the way."],[4133,4233,"Because I can't wait"],[4233,4383,"to show your precious,"],[4383,4562,"little granddaughter,"],[4583,4796,"how much of a liar you are."],[4842,4921,"Come on, Audrey."],[6306,6377,"That can't be right."],[6377,6535,"It says it was designed"],[6535,6623,"by Ricky Stroll."]],"75":[[0,83,"Okay."],[129,212,"Ah!"],[275,429,"Ricky Stroll."],[450,554,"That can't be right."],[592,771,"I was the lead designer, not Ricky."],[796,1030,"That is just insane at this point."],[1067,1134,"The evidence is"],[1134,1259,"right in front of your nose,"],[1259,1451,"so why don't you fess up"],[1451,1555,"and stop lying?"],[1593,1772,"You didn't design jack shit."],[1793,1881,"Screw you."],[1926,1997,"You got fired"],[1997,2147,"and you didn't even tell us about it?"],[2168,2260,"You're not a designer."],[2306,2402,"You're a fraud."],[2419,2498,"Come on, Audrey."],[2523,2686,"We're never seeing Grandpa again."],[2944,3028,"No, no, no. Wait."],[3065,3128,"Jesse."],[3148,3249,"You have to believe me."],[3274,3307,"Okay?"],[3307,3507,"I was working on this day and night."],[3545,3578,"Alright?"],[3578,3657,"Me and my team."],[3657,3762,"I swear to you."],[3812,3883,"Alright, they must have just"],[3883,4012,"put the wrong name up there."],[4033,4091,"Please."],[4120,4283,"I spent six months on this."],[4304,4387,"Oh, okay."],[4416,4512,"Six months?"],[4512,4675,"Is that the best you could get"],[4675,4792,"from the lie factory?"],[4792,5038,"Everyone knows that supercars like this"],[5038,5159,"take years to design."],[5159,5359,"No one could do it in six months."],[5359,5401,"Dad."],[5401,5472,"I can't."],[5472,5572,"I already hated you"],[5572,5709,"for what you did to Mom, and now,"],[5718,5847,"you're a liar, too?"],[5935,6206,"Grandpa, did you really lie to us?"],[6222,6452,"You always said to be honest."],[6452,6569,"I promise you, Audrey."],[6639,6777,"I didn't lie about anything."],[6798,6906,"Shut up, old man."],[6923,6981,"Your excuses"],[6981,7102,"aren't gonna work this time."],[7111,7186,"We're leaving."],[7253,7311,"Now."],[7549,7607,"Stop!"],[8062,8128,"Stop!"],[8274,8379,"He's telling the truth."],[8416,8521,"I'll vouch for him."]],"76":[[12,112,"He's telling the truth."],[145,225,"Hank Walker has been"],[225,358,"working night and day"],[358,471,"on the Silver Lynx Model A"],[471,579,"for the past six months."],[625,754,"He's the first one in the morning"],[754,884,"and the last one out at night,"],[884,1017,"and we would not be here today"],[1017,1105,"without his efforts."],[1105,1176,"Who are you?"],[1197,1276,"A car model?"],[1276,1363,"Get out!"],[1401,1539,"I spent the last six months"],[1539,1680,"as Hank's assistant."],[1693,1918,"I was with him every step of the way."],[1918,2143,"Hank Walker built this car."],[2502,2594,"You must be Audrey."],[2652,2798,"I promise your grandpa"],[2798,2882,"didn't lie to you."],[2940,3157,"He is a top-notch engineer,"],[3157,3307,"the best in the whole world."],[3349,3420,"Does that mean"],[3420,3636,"we can go see the car after?"],[3699,3820,"Of course we can, Audrey."],[3912,4033,"As soon as we're done with this,"],[4095,4220,"we can even go for a ride."],[4220,4316,"How's that sound?"],[4358,4425,"Good."],[4537,4696,"Not so fast, boyo."],[4817,5071,"This is my car."],[5109,5238,"I designed it myself,"],[5238,5518,"and I won't let anyone else touch it."]],"77":[[79,204,"You really thought you could"],[204,487,"just crash my press conference"],[529,804,"and lie to all these wonderful people"],[804,1034,"about designing my supercar?"],[1059,1213,"Jigs up, old man."],[1255,1376,"What do you have to say for yourself,"],[1376,1434,"huh?"],[1455,1630,"Because our real designer"],[1630,1760,"is standing right here."],[1793,2060,"Lead engineer, Ricky Stroll."],[2102,2331,"Ricky, you're not supposed"],[2331,2435,"to be here today."],[2481,2535,"Why?"],[2715,2811,"This is my name."],[2865,3032,"This is my press conference."],[3057,3374,"Oh, man, I'm so glad I showed up in time."],[3374,3516,"Otherwise, you would have taken credit"],[3516,3695,"for my hard work."],[3720,3999,"Ricky Stroll, when you lost that bet"],[3999,4045,"in Nurburg,"],[4045,4254,"you handed over the projects to Hank."],[4283,4466,"Since then, you've done no work on it."],[4466,4600,"It's a new car."],[4625,4692,"You're just doing this"],[4692,4842,"as payback to Mr. Walker, aren't you?"],[4904,5009,"Oh, baby."],[5096,5201,"We haven't even gotten"],[5201,5305,"to the payback yet."]],"78":[[8,137,"Welcome, everyone."],[200,333,"I think it's finally time"],[333,492,"to start this press conference."],[492,567,"Am I right?"],[975,1322,"I'm Ricky Stroll, your humble host"],[1322,1518,"and the designer of the new"],[1518,1814,"Mach 15's next-gen supercar,"],[1826,2056,"Silver Lynx Model A."],[2298,2402,"It's him,"],[2402,2481,"he’s,"],[2485,2623,"he must be that guy,"],[2623,2756,"diamond in the rough,"],[2790,2915,"genius designer."],[2932,3265,"He worked on that car, the Silver Lynx."],[3265,3382,"Yeah, what a beaut."],[3457,3691,"Him or the car?"],[3787,4024,"He's so dreamy."],[4095,4337,"He's such good looking."],[4337,4421,"Okay. - So hot."],[4421,4529,"Thank you."],[4567,4667,"Thank you so much."],[4667,4875,"But please, hold your applause."],[4971,5263,"This is a very important day."],[5355,5701,"But unfortunately, I have bad news."],[5797,6122,"We have a mole in our midst."],[6197,6548,"A big, fat liar"],[6548,6756,"who's been going around,"],[6756,7052,"taking credit for my designs."],[7307,7399,"What are you saying, Ricky?"]],"79":[[8,196,"That unsavory man"],[196,404,"has been lying to you all."],[404,629,"That he was a chief designer"],[629,955,"responsible for Silver Lynx project."],[984,1184,"Hadn't I showed up in time,"],[1213,1380,"he would have fooled"],[1380,1564,"every single one of you."],[1584,1710,"I can't believe"],[1710,1839,"someone would do that."],[1864,1968,"At such a prestigious"],[1968,2056,"car show?"],[2152,2231,"Whoever it is"],[2231,2423,"should be blacklisted from the venue."],[2456,2527,"Right."],[2548,2719,"And tell us who he is."],[2740,2952,"The top auto magazines"],[2952,3090,"of the world"],[3090,3240,"are here in this room."],[3340,3478,"The reporters are gonna"],[3478,3620,"kill him to death."],[3620,3716,"You know what?"],[3757,4020,"Maybe he should never work again"],[4020,4191,"in the auto industry."],[4191,4362,"Ricky, what are you doing here?"],[4362,4487,"You know full well"],[4487,4617,"who designed that car."],[4729,4792,"Duh!"],[4825,4892,"Me!"],[4946,5021,"Hello?"],[5021,5171,"I designed that car."],[5171,5372,"It's my pride and joy."],[5413,5547,"I told you, Hank."],[5605,5855,"I will be the end of you."],[5935,6076,"Say bye bye"],[6076,6335,"to your beloved auto industry."]],"80":[[8,145,"Say bye bye"],[145,387,"to your beloved auto industry."],[417,608,"You think that old guy is the person"],[608,792,"who stole Ricky's designs?"],[792,917,"I wouldn't be surprised."],[917,1046,"You can tell he stinks"],[1046,1180,"just by the looks of him."],[1180,1259,"A hobo?"],[1276,1384,"A compulsive liar?"],[1405,1514,"Disgusting!"],[1584,1851,"People like that are the worst."],[1885,2139,"Always cheating and plagiarizing."],[2285,2477,"He should never be allowed"],[2477,2773,"to work ever again in the auto industry."],[2773,2873,"Ever again!"],[2894,2965,"Boo!"],[2969,3032,"Boo!"],[3036,3157,"Boo!"],[3157,3324,"Boo!"],[3324,3649,"Boo! - Black list him!"],[3657,3762,"Boo!"],[3791,3933,"Boo!"],[3933,4116,"Black list him!"]],"81":[[108,179,"No!"],[179,296,"No, listen!"],[346,550,"I designed the Silver Lynx Model A."],[604,829,"Alright, please, you have to believe me."],[871,934,"Alright?"],[934,1055,"Ricky, he's just trying to"],[1055,1146,"trick all of you."],[1184,1267,"Six months?"],[1317,1455,"That's preposterous."],[1476,1735,"You would be a genius to do that."],[1760,1989,"Actually, he's right about that."],[2068,2268,"In fact, I designed"],[2268,2410,"and built this beauty"],[2410,2556,"in just six months."],[2594,2969,"As expected for our genius designer,"],[2982,3436,"Ricky Stroll is the only man in the world"],[3465,3741,"to be able to prepare and create"],[3741,4029,"this fabulous, perfect design"],[4037,4316,"in just six months."],[4316,4575,"And for you, stop lying, old man!"],[4592,4667,"Stop!"],[4667,4742,"Boo!"],[4754,4829,"Boo!"],[4842,4917,"Boo!"]],"82":[[4,125,"I guess you really can't"],[125,316,"teach an old dog new tricks."],[337,400,"Woof."],[421,471,"Woof."],[508,738,"This old geezer was lying out of his ass"],[738,917,"when he was my coworker at Webster."],[959,1092,"He even got fired"],[1092,1209,"and then tried to mess up"],[1209,1317,"one of our machines."],[1317,1497,"He's the worst of the worst."],[1505,1609,"And get that,"],[1609,1943,"he actually lied to our poor"],[1943,2122,"female CEO,"],[2122,2281,"that he knows everything"],[2281,2402,"about cars."],[2431,2544,"You know cars."],[2569,2656,"You're the best engineer"],[2656,2744,"in the world."],[2798,2948,"And she hired him."],[2982,3090,"She did fire him,"],[3090,3294,"when she realized he's worthless."],[3361,3595,"But now he's back to screw with us."],[3616,3707,"Again!"],[3770,4024,"Stop being mean to my grandpa!"],[4033,4212,"He's not a liar."],[4220,4408,"I trust him!"],[4441,4521,"Really, Hank?"],[4567,4733,"You even brought your granddaughter"],[4733,4846,"to lie for you?"],[4863,5100,"How low can you possibly fall?"],[5163,5434,"People like you are a tumor"],[5434,5672,"on the face of auto industry."],[5905,6001,"I have to go get Miss Wolff"],[6001,6206,"or Mr. Walker might actually get hurt."]],"83":[[16,95,"Ricky Stroll."],[216,312,"I know you don't like me."],[346,529,"You never have since that car race."],[571,704,"But your designs were flawed."],[767,938,"And I can't in good conscience"],[938,1113,"sell that to Mach 15 clients."],[1130,1409,"You, you, you really count that as a win?"],[1476,1735,"I would have won square and fair,"],[1780,2035,"if I hadn't used outdated design."],[2147,2331,"So that doesn't count."],[2360,2523,"Why don't you stop lying?"],[2577,2786,"You know, I just can't believe"],[2786,3169,"they left such filth through the door."],[3236,3516,"Security, please take this guy"],[3516,3586,"out of here."],[3586,3691,"Out of the room, now!"],[3691,3762,"Look."],[3812,3958,"I designed this car."],[3987,4108,"I can prove it to you all."],[4179,4320,"You have to believe me, okay?"]],"84":[[12,166,"I designed this car."],[187,308,"I can prove it to you all."],[358,483,"Still running your mouth, huh?"],[579,709,"We don't want liars here."],[784,1101,"So better get your family and get out."],[1142,1276,"Or we'll throw you out."],[1301,1430,"Throw them out."],[1463,1626,"Throw them out!"],[1639,1797,"Throw them out!"],[1818,1968,"Throw them out!"],[1989,2160,"Throw them out!"],[2248,2506,"Oh, good work."],[2577,2815,"Now they just need to blacklist Hank."],[2852,2998,"I'll link the word to the media,"],[3044,3215,"and Hank is toast."],[3278,3607,"I love you, you magnificent bastard."],[3653,3791,"This is the best day of my life."],[3845,3949,"They actually believe"],[3949,4233,"I built the Silver Lynx Model A."],[4237,4483,"I just need to sit and wait"],[4483,4650,"for all the multi-million offers"],[4650,4963,"to just start rolling in!"],[5000,5088,"Tom was right."],[5180,5321,"You're a filthy liar."],[5409,5513,"If you don't have the money,"],[5513,5680,"stop wasting my time."],[5714,5876,"Audrey, let's go."],[5897,5955,"Now!"],[5972,6143,"I trust Grandpa!"],[6143,6364,"And Grandpa would never lie to me!"]],"85":[[4,371,"Your grandpa is a dirty, disgusting liar."],[371,571,"And if you spend more time with him,"],[592,875,"you're gonna be dirty and poor"],[875,988,"just like him."],[988,1071,"We're leaving."],[1113,1176,"Now."],[1197,1255,"Please."],[1288,1484,"If you really had ten million dollars,"],[1484,1601,"you wouldn't even think twice"],[1601,1718,"about paying our mortgage."],[1755,1860,"You got fired."],[1918,2131,"You never really had the money, did you?"],[2131,2173,"No."],[2173,2289,"I, I do."],[2360,2398,"Okay?"],[2398,2515,"I just didn't want Jesse"],[2515,2711,"to blow it all away gambling."],[2711,2777,"That's all."],[2777,2919,"I'll pay off your mortgage."],[2944,3194,"But I want to save the rest for Audrey."],[3232,3278,"No."],[3311,3528,"What's Audrey's is ours."],[3574,3628,"If you're gonna"],[3628,3737,"give it to her anyways,"],[3737,3883,"you might as well give it to us"],[3883,4141,"and we, her parents,"],[4141,4308,"will invest it for her."],[4308,4375,"Yeah."],[4475,4550,"Unless you can't."],[4550,4600,"Why?"],[4629,4771,"What, because you don't trust us?"],[4771,4825,"No."],[4850,4975,"That money needs to go into"],[4975,5117,"a college fund for Audrey."],[5117,5246,"I can't hand it over to them."],[5271,5513,"Do you see what are we actually"],[5513,5638,"dealing with here?"],[5676,5918,"His own daughter doesn't trust him."],[5960,6060,"Why should we?"],[6177,6227,"You know what?"],[6227,6310,"I say,"],[6381,6535,"we should blacklist his ass"],[6535,6698,"from the auto industry forever."],[6802,7203,"Everybody who's in favor, say aye!"],[7211,7336,"Aye!"],[7349,7453,"Aye!"],[7469,7607,"Blacklist him!"],[7640,7782,"Blacklist him!"],[7799,7928,"Blacklist him!"],[7966,8103,"Blacklist him!"]],"86":[[4,62,"Boss!"],[95,200,"Boss, you have to come quick."],[200,271,"It's Mr. Walker."],[308,337,"Hank?"],[337,408,"What happened?"],[429,496,"They changed the name"],[496,567,"in the presentation."],[567,613,"Now it says"],[613,754,"Ricky Stroll designed the car."],[754,859,"And everyone in there thinks"],[859,942,"Hank is a fraud."],[959,1009,"What?"],[1071,1184,"How could they do this to him?"],[1255,1343,"Okay, we'll make them pay."],[1343,1405,"Let's go."],[1722,1914,"What a beautiful fall from grace."],[1914,2147,"No one is ever gonna hire you again."],[2177,2385,"They will want me instead."],[2456,2623,"Ricky Stroll,"],[2665,2836,"the greatest engineer,"],[2865,2986,"the brilliant designer,"],[3053,3232,"the most desired bachelor, maybe."],[3257,3424,"But the only way they'll remember you"],[3424,3561,"will be a liar,"],[3561,3737,"who tried to mess with me."],[3812,3891,"But you know what?"],[3916,4004,"I'm merciful."],[4045,4233,"I'll give you one last chance."],[4254,4408,"Get down on your knees,"],[4454,4608,"kiss my shoes,"],[4629,4813,"and I will forgive you."],[5017,5213,"I might even hire you as my janitor."],[5276,5555,"I won't let you hurt my grandpa!"],[5789,5872,"You shit."],[5872,6047,"You little imp!"],[6085,6147,"Security!"],[6185,6252,"Seize them."],[6293,6373,"Throw them out!"],[6389,6452,"Stop!"]],"87":[[433,533,"I'm Emily Wolff."],[571,817,"And I am the CEO of Mach 15."],[888,1005,"I hired Hank."],[1042,1172,"And I personally asked him"],[1172,1259,"to take the lead"],[1259,1409,"on the Silver Lynx Model A."],[1484,1593,"Nobody will touch him."],[1693,1793,"Not on my watch."],[1818,1876,"What?"],[1876,2052,"But earlier Ricky said,"],[2052,2156,"he designed the car."],[2344,2423,"Ricky Stroll, you better"],[2423,2565,"have a good explanation for this!"],[2681,2748,"We'll wait till"],[2748,2902,"the Monaco Supercar Expo."],[2961,3078,"We'll switch the designer name"],[3078,3148,"with yours."],[3190,3386,"That way you'll be famous"],[3386,3553,"and everyone will think Hank's a liar."],[3553,3757,"No one will hire him ever again"],[3757,3962,"and his reputation will be ruined."],[4008,4083,"Hey!"],[4141,4237,"Miss Wolff."],[4262,4337,"I thought you'd be busy"],[4337,4416,"with the interview."],[4450,4533,"Well, it's a good thing"],[4533,4637,"I came here instead,"],[4637,4721,"so I could see exactly"],[4721,4867,"what you've done with my own eyes."],[4875,5005,"You have an awful lot of nerve,"],[5005,5067,"you know that?"],[5067,5226,"Taking Hank's name off this project"],[5226,5317,"and adding yours?"],[5359,5455,"Wait, what?"],[5530,5826,"I thought Ricky was your genius designer,"],[5872,6227,"not this old guy who is just a mechanic"],[6227,6448,"and didn't he just get laid off?"],[6535,6669,"No, no Ricky has been lying"],[6690,6794,"to all of you."],[6827,7023,"This is the true talent"],[7023,7207,"behind the Silver Lynx Model A,"],[7248,7328,"Hank Walker."],[7428,7490,"What?"]],"88":[[29,91,"What?"],[125,296,"Wait, so Ricky tricked us?"],[333,650,"So the real genius designer is Hank,"],[650,779,"this old guy?"],[800,1172,"So, Hank is the lead designer at Mach 15."],[1213,1326,"Does that also mean that"],[1326,1497,"his ten-million-dollar contract is real?"],[1534,1618,"Thank you, Miss Wolff."],[1693,1810,"I was at my wit's end"],[1810,1922,"trying to convince everyone here"],[1922,2077,"that I designed this car."],[2118,2210,"Don't worry, Hank."],[2252,2410,"You've been an excellent employee"],[2431,2556,"and a fantastic role model"],[2556,2665,"for everyone at this company."],[2686,2907,"Mach 15 will use all of our resources"],[2907,2977,"to protect you."],[3232,3390,"As for you,"],[3445,3520,"I thought you might"],[3520,3607,"have a change of heart"],[3607,3741,"when you lost to Hank in that race."],[3757,3908,"I won't let you win."],[3908,4004,"You lost."],[4033,4187,"But, looks like I'm gonna"],[4187,4358,"have to fire you after all."],[4379,4437,"You know what?"],[4525,4621,"Go ahead."],[4696,4875,"Tom just send the pictures"],[4875,5009,"to all media outlets."],[5042,5205,"The whole world"],[5205,5347,"thinks I designed that car"],[5347,5647,"and that Hank is a stupid hillbilly."],[5668,5880,"I'll find a job in no time."]],"89":[[8,212,"I'll find a job in no time."],[229,358,"No wonder Tom showed up"],[358,471,"the same time as you."],[571,813,"You're both colluding to bring me down."],[834,925,"Oh my God."],[942,1055,"Well, great."],[1055,1180,"You figured it out."],[1222,1343,"It's too late, old man."],[1343,1539,"Your reputation is already ruined."],[1539,1672,"This is payback"],[1672,1730,"for taking a"],[1730,1922,"ten million dollar salary"],[1922,2081,"while getting me fired."],[2127,2210,"You're dead."],[2252,2352,"I don't think so."],[2410,2469,"Great."],[2506,2640,"Keep saying that."],[2665,2802,"And keep hiring Hank."],[2802,2940,"But your stock is gonna be"],[2940,3032,"in the gutter,"],[3032,3165,"because of Hank's PR."],[3165,3232,"No."],[3382,3457,"They won't be."],[3870,3941,"Because I intercepted"],[3941,4029,"your materials."],[4074,4258,"Uh, boss, what are you doing here?"]],"90":[[12,171,"Leo is a good friend of mine."],[250,325,"And we just had"],[325,546,"the most lovely conversation."],[579,867,"Tom Norris, I was wrong about you."],[875,1059,"You filthy liar!"],[1084,1163,"Spreading fake news"],[1163,1284,"just to make a quick buck."],[1297,1418,"That's libel."],[1451,1551,"You're fired!"],[1576,1634,"No, no, boss."],[1634,1735,"Please, please, I..."],[1747,1881,"This is the best gig I could find."],[1881,1993,"I can't lose this job."],[1993,2047,"Please."],[2047,2152,"Wait, wait, wait."],[2177,2364,"The pictures don't make it to the media."],[2364,2665,"They won't think I designed that car"],[2665,2882,"and that I'm a brilliant engineer."],[2944,3078,"What do I do?"],[3094,3307,"Well, you'll probably never work again."],[3324,3516,"And from the big names"],[3516,3687,"I see in this room,"],[3766,3974,"you'll probably also get blacklisted"],[3974,4099,"from the automotive industry."],[4137,4216,"Yeah, that's right."],[4291,4371,"He is a liar."],[4391,4487,"Let's blacklist him."],[4517,4575,"No."],[4596,4729,"No, no, no, no, no, no."],[4729,4871,"Please, please, Ms. Wolff."],[4888,4992,"If you blacklist me,"],[4992,5209,"I will never find a job again."],[5242,5392,"I think you're apologizing"],[5392,5501,"to the wrong person."],[5601,5697,"Hank!"],[5697,5822,"I mean Mr. Walker."],[5880,6006,"I shouldn't have done that."],[6022,6118,"I'm sorry."],[6206,6381,"Please, just give me one more chance."],[6381,6544,"That's all I'm asking for."],[6577,6635,"Hank."],[6635,6694,"Hank."],[6710,6777,"Please, please."],[6777,6798,"Just."],[6827,7040,"Just forgive me for old time's sake."],[7040,7090,"Please."],[7111,7344,"You want me to forgive you?"],[7970,8120,"Have you forgotten how you treated me?"]],"91":[[12,133,"Not ten minutes ago,"],[133,216,"you were insulting me"],[216,304,"in front of everyone."],[329,387,"You threatened"],[387,513,"my granddaughter, Audrey."],[513,650,"And now that your plan's not working,"],[650,784,"you want me to forgive you?"],[817,892,"It's not happening."],[934,1176,"Miss Wolff, I'll let you deal with them"],[1176,1255,"however you want."],[1301,1363,"Evelyn,"],[1397,1580,"blacklist them from this venue."],[1580,1659,"Blacklist them"],[1659,1726,"from all the automotive"],[1726,1764,"companies."],[1764,1885,"Matter of fact,"],[1885,2022,"contact every company"],[2022,2147,"that we've ever worked with."],[2160,2268,"And make sure they know"],[2289,2560,"they are not to work with Tom Norris"],[2631,2927,"or Ricky Stroll ever again."],[2986,3086,"You got it, boss."],[3107,3194,"Security."],[3411,3465,"Out."],[3653,3724,"Please, please."],[3724,3766,"Hank!"],[3766,3849,"No! No!"],[3849,3912,"Forgive us!"],[3920,4079,"Miss Wolff, Miss Wolff, no!"],[4079,4187,"Forgive us, boss, please."],[4187,4371,"Miss Wolff, Mr. Walker,"],[4371,4487,"fuck you both."],[4496,4612,"Please, Hank! - No, no, no!"],[4612,4725,"Please! Please, forgive me!"],[4725,4788,"No!"]],"92":[[150,221,"Miss Wolff,"],[375,454,"level with me."],[492,704,"Is my father-in-law really going to be"],[704,896,"making ten million dollars a year?"],[930,1009,"It's true."],[1042,1163,"We did have a contract."],[1343,1397,"We're really gonna"],[1397,1526,"make ten million dollars a year."],[1555,1614,"Dad!"],[1672,1747,"I knew it!"],[1747,1826,"I always knew it."],[1826,1931,"I always had faith in you."],[1931,2277,"Dad, Dad, we were just lied to,"],[2277,2327,"okay? - Yes."],[2327,2419,"They tricked us."],[2439,2527,"Drop the act."],[2644,2736,"I know both of you"],[2736,2865,"are only in it for the money."],[2898,2969,"Quite frankly,"],[2969,3144,"I'm disappointed in both of you."],[3144,3315,"I will start a trust fund for Audrey."],[3357,3516,"But you two will not see"],[3516,3703,"another penny from me, okay?"],[3703,3820,"I'll pay your mortgage,"],[3841,3966,"so Audrey has a place to live."],[3987,4129,"I will pay her living expenses"],[4129,4208,"moving forward."],[4220,4366,"I will pay for her education."],[4475,4575,"The rest of that money,"],[5105,5234,"I'm gonna give it back to Detroit."]],"93":[[8,104,"The rest of that money,"],[221,367,"I'm gonna give it back to Detroit."],[408,650,"To build schools and hospitals."],[709,950,"Ah, Detroit, Detroit, Detroit."],[1038,1230,"Who cares about fucking Detroit?"],[1251,1422,"It's a dying city."],[1422,1580,"Detroit doesn't need the money."],[1597,1685,"That's true."],[1760,1897,"Detroit ain't what it used to be."],[1931,2135,"But its bones built this country."],[2156,2256,"Something a man like you"],[2256,2377,"would never understand,"],[2410,2552,"which is even more reason why"],[2552,2677,"you're never gonna see my money."],[2702,2827,"When Audrey turns eighteen,"],[2877,3044,"she will have access to the trust fund."],[3169,3257,"That money is for her."],[3336,3474,"Not for you two."],[3520,3570,"Hank, you-"],[3883,4058,"This is all your fault."],[4129,4304,"You pitted me against my own Dad."],[4471,4567,"I want a divorce."],[4608,4683,"I hate you."],[5801,5860,"Grandpa,"],[5880,6039,"can I go take pictures now?"],[6039,6147,"With the car?"],[6164,6293,"Of course you can, honey."],[6360,6477,"You can even go for a ride."],[6564,6664,"I'll take good photos."]],"94":[[279,383,"Hank."],[467,613,"Have you thought about the proposal?"],[725,792,"Being my boyfriend,"],[792,863,"what do you think?"],[913,967,"I don't know."],[1017,1209,"I mean, you are still my boss."],[2056,2173,"Hank, I don't care."],[2344,2506,"That is, unless you like that girl, Yulia."],[2548,2635,"Yulia?"],[2781,2969,"I'm old enough to be that girl's father."],[3061,3132,"No way."],[3240,3357,"So you think she's young."],[3520,3616,"I like you."],[3803,3928,"I wouldn't be here if I didn't."],[4079,4149,"Great."],[4254,4354,"Let's go to my place then."],[4421,4496,"Okay."],[5150,5209,"Hank? - Hank?"],[5580,5730,"Hank, don't waste your breath"],[5730,5814,"on them, okay?"],[5914,6010,"Karma's a bitch."],[6056,6122,"And what goes around"],[6122,6177,"comes around."]]}