{"1":[[1789,1943,"Jaxon."],[2260,2356,"Jaxon."],[2356,2515,"Have you lost your mind?"],[2515,2648,"Are you crazy?"],[2811,2890,"Not here."],[2890,3036,"Anyone can walk in."],[3053,3232,"You married me for money, didn't you?"],[3407,3541,"Let's make sure you cash in"],[3541,3674,"with an Astor heir!"],[3870,3999,"Scream louder!"],[3999,4083,"Scream all you want."],[4975,5034,"You are nothing"],[5034,5142,"but a contract to me."],[5834,5980,"Jaxon."],[5980,6281,"why can't you ever believe me?"],[7219,7432,"Take the money and leave Jaxon,"],[7432,7528,"you bitch."]],"2":[[0,175,"Look at you!"],[175,383,"Half-naked and desperate."],[383,588,"Your husband won't even touch you."],[588,759,"Who's the real sluts here?"],[767,850,"Get out!"],[930,1080,"I'm his wife."],[1080,1238,"You're just his side chick."],[1238,1368,"Oh, really?"],[1368,1493,"The one who is not wanted"],[1493,1659,"Is the real side chick."],[1672,1876,"What if Jaxon finds out the truth?"],[1989,2102,"Believe me,"],[2102,2214,"he won't."],[2264,2464,"What saint man would trust"],[2464,2610,"a woman who just married him"],[2610,2711,"for his money?"],[3357,3578,"That's not true."],[3578,3837,"You just confused him with your lies."],[3837,3953,"I think he'd rather believe"],[3953,4154,"you're the liar now."],[4187,4383,"Isabella is right."],[4533,4758,"All you ever do is lie,"],[4758,4979,"you backstabbing snake."],[5201,5263,"How dare you"],[5263,5413,"lay a finger on Isabella?"],[5413,5655,"She saved my son's life."],[5655,5747,"What have you ever done"],[5747,5955,"except trick your way into this family?"],[6093,6218,"Look at you."],[6218,6435,"Dressed like a maid."],[6435,6560,"If you think your face"],[6560,6652,"can fool us forever,"],[6652,6744,"think twice."],[6844,6952,"Exactly."],[6998,7090,"I bet"],[7090,7286,"you think you can bet your eyes"],[7286,7440,"everything would be okay."],[7490,7624,"Pathetic."],[8483,8666,"Do you really think you deserve to be"],[8666,8771,"Mrs. Astor?"],[9672,9930,"I didn't marry him for money."],[10210,10377,"And when this three year contract"],[10377,10472,"is over,"],[10593,10769,"I'm gone for good."],[10860,11061,"She really can't wait to leave me."]],"3":[[513,542,"Please."],[542,771,"I won't let you hurt him any more."],[1735,1876,"That was crossing the line."],[1876,2027,"Apologize now."],[2027,2139,"No."],[2139,2273,"She pushed me."],[2273,2506,"Did you actually think I'd attack her?"],[2652,2786,"I know Natasha hates me."],[2811,3003,"She blames me for your resentment."],[3003,3103,"I never wanted to come"],[3103,3274,"between the two of you."],[3307,3399,"Apologize."],[3399,3478,"Right."],[3478,3553,"Now."],[3945,4108,"Jackson,"],[4108,4258,"why can't you and your family"],[4258,4375,"never see the truth?"],[4654,4808,"Why would I believe a gold digger?"],[4808,4934,"You know Isabella's condition,"],[4934,5059,"and you still hurt her."],[5146,5284,"Say you're sorry."],[5284,5372,"or you’ll regret it."],[5372,5434,"No!"],[5488,5584,"I’m not going to apologize for"],[5584,5734,"something I didn't do."],[5784,5922,"I'm your wife,"],[5935,6022,"Not the punching bag"],[6022,6093,"for your mistress."],[6581,6735,"Are you sure she pushed you?"]],"4":[[16,254,"Jaxon, I..."],[254,371,"I'm fine."],[417,608,"Please don't blame her too much."],[684,763,"After all,"],[763,913,"she's the one that grandpa picked."],[913,1051,"I have to respect that."],[1117,1217,"Please."],[1238,1330,"You’re the one"],[1330,1497,"who’s eyeing the Astor fortune."],[1584,1676,"Natasha,"],[1785,1981,"I know you hate me."],[1981,2052,"Please don't question"],[2052,2210,"my love for Jackson."],[2702,2790,"Ow!"],[2790,2965,"My stomach."],[2965,3144,"Natasha, how could you?"],[3144,3257,"You know I'm pregnant."],[3257,3307,"Are you trying to hurt"],[3307,3432,"Jackson's child?"],[3603,3699,"A baby?"],[3908,4037,"I was going to tell you later,"],[4037,4216,"but I wanted it to be a surprise."],[4308,4404,"A baby?"],[4404,4550,"That's wonderful news."],[4550,4696,"Oh, my dear Isabella,"],[4696,4833,"congratulations."],[5472,5618,"Thank you, Jaxson."]],"5":[[312,517,"Just stop me, Natasha."],[517,713,"If you feel angry about this."],[746,855,"Well,"],[980,1180,"I wish you two a happy life."],[2106,2227,"Natasha, what's wrong?"],[3995,4162,"Jaxon."],[4245,4441,"Are you God sent to catch me?"],[4500,4800,"It seems your fate is tied to mine forever."],[6085,6164,"Oh,"],[6164,6235,"it hurts."],[6235,6356,"Jaxon, our baby..."],[6377,6473,"Jackson, for the sake of"],[6473,6594,"my grandchild."],[6594,6664,"Come over here"],[6664,6744,"and be with Isabella."],[6744,6790,"Right."],[6790,6894,"Now."],[7582,7674,"I’m hurt."],[7674,7770,"Now! Jaxon."]],"6":[[709,817,"Oliver."],[817,967,"What are you doing here?"],[967,1067,"The hospital director"],[1067,1126,"is a friend of mine."],[1126,1234,"He let me in."],[1455,1551,"Natasha."],[1797,1897,"You are pregnant?"],[2481,2598,"This isn't the right time."],[2598,2740,"Don't worry."],[2740,2877,"No matter what,"],[2877,3040,"I will always be with you."],[3294,3403,"Oliver,"],[3403,3570,"please."],[3570,3787,"We have to keep this between us"],[3787,3862,"for now."],[3887,3962,"I will."],[4354,4446,"How touching!"],[4521,4708,"My wife and her best friend"],[4708,4896,"sharing such a heartfelt moment."],[4942,5067,"Jaxon."],[5109,5201,"You heard..."],[5201,5288,"everything?"],[5351,5584,"What else am I not supposed to hear?"]],"7":[[29,141,"Mr. Astor, please."],[141,275,"She needs to rest right now."],[275,316,"Okay?"],[429,525,"How dare you"],[525,700,"tell me what my wife needs?"],[742,792,"At least"],[792,875,"I was there for her"],[875,946,"when she was vulnerable."],[946,1001,"Unlike you,"],[1001,1134,"her so-called husband,"],[1134,1222,"who hurt her."],[1251,1376,"Excuse me?"],[1376,1493,"Who the hell are you?"],[1493,1634,"My wife's secret lover?"],[1639,1772,"Jaxon, enough!"],[1822,2031,"You're defending him against me?"],[2031,2181,"What, is he better in bed than me?"],[2790,2923,"Get out!"],[3299,3407,"Don't forget,"],[3428,3478,"you're the one"],[3478,3591,"who begged Grandpa"],[3591,3657,"to marry me."],[3657,3762,"Don't forget,"],[3762,3870,"your mistress"],[3870,4074,"is already carrying your child."],[4095,4195,"That's not true."],[4195,4358,"Get out Mr. Astor."],[4512,4658,"That's enough."],[4658,4934,"You have no right to question me."],[4934,5059,"And as for you,"],[5113,5201,"I don't need to"],[5201,5301,"explain myself to you."],[5326,5488,"You're going to die an Astor."],[5572,5764,"Whether you like it or not."],[8199,8412,"Natasha,"],[8412,8541,"I won't let you take Jaxon"],[8541,8633,"from me again!"]],"8":[[479,550,"Natasha."],[784,930,"Can we talk privately?"],[930,1126,"I have a lot to apologize for."],[1184,1242,"Well,"],[1242,1463,"I'll let you ladies talk then."],[1476,1568,"I have some things that"],[1568,1722,"I need to take care with myself."],[2489,2615,"Natasha."],[2660,2898,"We used to be best friends,"],[2898,3086,"and now we're pregnant"],[3086,3249,"by the same man."],[3591,3753,"How did you know I was pregnant?"],[3753,3899,"Jackson found your report,"],[3899,3983,"and he told me."],[4062,4225,"Now you know why he"],[4225,4441,"kept me and tossed Oliver aside?"],[4533,4646,"There's some things I need to"],[4646,4738,"take care with myself."],[5205,5409,"He doesn't want somebody like you"],[5409,5622,"to have his baby!"],[5764,5860,"No..."],[6202,6289,"Natasha!"],[6327,6477,"Oliver Henderson."],[6477,6685,"Natasha is my wife."],[6685,6823,"Stay away from her."],[6823,6977,"And yet all you do is hurting her."],[6977,7082,"I'll take care of her"],[7082,7228,"better than you ever could."],[7361,7474,"Try saying that again."],[7474,7586,"I said I’ll..."]],"9":[[175,262,"Oh my God,"],[262,362,"it hurts so much."],[429,588,"So much blood..."],[588,734,"Am I dying?"],[992,1080,"I know you hate me,"],[1080,1255,"but please don't hurt my baby."],[1255,1409,"It's all my fault."],[1409,1530,"I shouldn't be coming..."],[1530,1755,"She hates me so much."],[1805,1914,"What did you do?"],[2010,2147,"Are you trying to kill Isabella?"],[2147,2235,"No!"],[2235,2348,"No, I..."],[2348,2456,"I didn't."],[3144,3215,"You're lying."],[3215,3303,"When did you become"],[3303,3395,"so cold blooded?"],[3395,3457,"When I walked in,"],[3457,3549,"you were holding a knife."],[3549,3674,"No!"],[3687,3862,"No...Isabella puts it there."],[3862,4054,"Watch your mouth before you speak."],[4054,4179,"Shut the hell up!"],[4179,4329,"I'm speaking with my wife."],[4904,5000,"That's enough!"],[5000,5080,"Natasha."],[5100,5246,"Stop lying!"],[5246,5355,"Isabella injured herself"],[5355,5509,"trying to save me."],[5509,5709,"Her health is fragile."],[5847,5955,"Unless she wants to die,"],[5955,6160,"She wouldn't risk her life"],[6160,6268,"trying to frame you."],[6302,6439,"No..."],[6439,6614,"But it was her."],[6752,6886,"If anything happens to her,"],[6927,7061,"I'll make you pay for it."]],"10":[[50,162,"And if I die,"],[229,392,"who's going to pay for my life?"],[467,729,"Oh my God, it hurts so much."],[729,884,"Jackson, where are you?"],[1426,1488,"Don't worry."],[1488,1593,"It's going to be okay."],[1593,1705,"I'm going to take you to the doctor."],[1705,1789,"Right?"],[1822,1910,"It's okay."],[2006,2085,"Out of my way!"],[2085,2198,"She's in danger."],[2198,2331,"You two should stop acting."],[2419,2464,"You"],[2464,2619,"were the one that stabbed Isabella."],[2777,2915,"Please,"],[2915,2977,"let's go."],[3207,3336,"Who allowed you to leave?"],[3336,3424,"She's injured."],[3424,3507,"If you don't save her,"],[3507,3636,"you will damage not only her"],[3636,3778,"but the one that's inside her."],[3778,3862,"Jackson,"],[3862,4062,"do you want me to tell you that"],[4062,4270,"I'm lying and I'm being injured?"],[4279,4346,"How would I know"],[4346,4441,"you are telling the truth?"],[4441,4554,"You're full of lies."],[5476,5626,"What exactly happened?"]],"11":[[350,458,"No..."],[458,554,"Natasha."],[554,675,"You bitch!"],[721,834,"You still want to get pregnant with"],[834,975,"Jackson's child?"],[1001,1138,"Dream on."],[1897,2198,"Oh, this scene isn't over yet."],[2640,2781,"What are you doing?"],[3015,3153,"Oh my God."],[3153,3257,"Oh..."],[3428,3545,"Who did this?"],[3553,3737,"Who else but your mistress?"],[3757,3845,"No."],[3845,3999,"She's too timid and kind."],[4325,4508,"Look at me now."],[4508,4742,"And you still believe her?"],[5046,5201,"You told me that Isabella wouldn't"],[5201,5326,"risk her life."],[5326,5492,"Well, neither will I."],[5492,5563,"Please,"],[5563,5793,"Jaxon, just leave me alone."],[5997,6060,"Get lost."],[6060,6235,"I'm taking her to the ER."],[6235,6356,"Natasha Astor"],[6356,6477,"is my wife!"],[6477,6610,"Now and forever,"],[6648,6856,"saving her is my job,"],[6856,6936,"not yours!"],[6936,6994,"Back off!"],[7807,7924,"Stay away from me!"]],"12":[[229,367,"The patient wasn't cooperating,"],[367,496,"just did a quick patch-up."],[1092,1159,"Natasha."],[1159,1242,"You're bleeding."],[1242,1355,"He's my private doctor"],[1355,1526,"and the best expert in the world."],[1526,1634,"Let him take a look."],[1710,1868,"Natasha, just calm down."],[1931,2014,"I want to know what's going on"],[2014,2106,"and why you're hurt."],[2106,2235,"Yeah, and if I tell you,"],[2235,2344,"will you believe me?"],[2456,2535,"No."],[2535,2736,"You only believe Isabella."],[2773,2840,"Because she already"],[2840,2973,"has your baby."],[3023,3178,"Why don't you just let me go."],[3178,3290,"So do you want to leave me?"],[3340,3553,"Do you want to cut things off like this?"],[3553,3661,"Or are you just pushing me away"],[3661,3757,"because of Oliver?"],[4571,4725,"You are"],[4725,4892,"the only one I've slept with."],[5593,5751,"Enjoy while it’s last,"],[5751,5880,"Jaxon."],[5880,6181,"Because you may have my body,"],[6181,6318,"but my heart"],[6318,6468,"never again."],[6493,6652,"And who's that going to be,"],[6652,6744,"Oliver?"],[6744,6848,"That's too bad,"],[6848,6965,"because you're my wife,"],[6965,7094,"and you do as I say."],[7486,7553,"No."],[8454,8717,"Am I nothing but a tool to you?"],[8746,8908,"Do you really hate me this much?"],[8908,9109,"Is it a pain when I touch you?"]],"13":[[116,312,"Hate me all you want."],[312,450,"But don't you dare"],[450,583,"walk away from me."],[1255,1313,"What?"],[1351,1593,"Isabella's unconscious."],[1593,1705,"I'll be there right away."],[1860,1960,"Stay here"],[1960,2035,"and don't"],[2035,2135,"try to get out."],[2152,2360,"I'll make sure all the doors are locked."]],"14":[[654,834,"Isabella, you're not unconscious."],[834,875,"I..."],[875,988,"I just woke up."],[988,1209,"I was putting on makeup for you."],[1222,1397,"How did Natasha get hurt?"],[1501,1639,"Maybe she accidentally"],[1639,1739,"scratched herself"],[1739,1868,"when she attacked me."],[1868,1943,"Or..."],[1943,2114,"Or maybe she was scared that"],[2114,2239,"you'd blame her."],[2335,2460,"Natasha wouldn't do that."],[3069,3144,"Jaxon,"],[3144,3274,"after I was injured,"],[3274,3449,"I was just worried about our baby,"],[3449,3566,"so..."],[3566,3616,"I..."],[3616,3787,"I don't know what happened after that."],[3787,3828,"But..."],[3828,3937,"But luckily, the doctor said that"],[3937,4066,"our baby's fine."],[4095,4220,"Enough, Isabella."],[4220,4366,"We both know you're not pregnant"],[4366,4458,"with my child."],[4462,4617,"We were never together."],[4629,4704,"You're just trying to"],[4704,4871,"push Natasha away, aren't you?"],[4938,5030,"Jaxon, I..."],[5100,5155,"I let you"],[5155,5284,"call yourself my girlfriend"],[5284,5401,"all these years,"],[5417,5559,"and I never expose you"],[5559,5739,"because I owe you for saving my life."],[5751,5914,"But why'd you lie, Isabella?"],[5914,6031,"It's crossing a line."],[6172,6414,"I saved you from those thugs,"],[6414,6460,"and..."],[6527,6644,"and ended up with this scar."],[6644,6760,"because of it, I mean,"],[6760,6886,"I could have been an actress,"],[6886,7048,"but that ruined it."],[7048,7269,"Natasha gets that perfect face."],[7269,7399,"So you're trying to push"],[7399,7528,"Natasha away?"]],"15":[[4,129,"Jaxon,"],[225,425,"you're all I have."],[437,558,"I've always dreamed of"],[558,688,"having your child."],[775,946,"Maybe I've lost track of"],[946,1101,"what's real and what's not."],[1138,1251,"I promised"],[1251,1355,"that the Astor family"],[1355,1488,"would take care of you for life."],[1488,1634,"If you want to pursue acting, then"],[1634,1751,"I'll support you."],[1751,1926,"But that's where it ends."],[1926,2164,"Natasha is my wife."],[2164,2289,"I will never marry you."],[2398,2602,"I promise I won't cause you"],[2602,2865,"any trouble if you want me to stay."],[2865,3048,"Stay away from Natasha"],[3048,3123,"and we're good."],[3144,3290,"If you hurt her again,"],[3390,3465,"we're done."],[3541,3657,"Years ago,"],[3657,3782,"I'd have died to save you."],[3782,3820,"But..."],[3908,4045,"I'll do whatever it takes"],[4045,4200,"to get rid of my jealousy."],[5163,5342,"You know I'd die without you."],[5492,5626,"As for Natasha,"],[5643,5897,"Oliver seems to care for her deeply."],[5922,6268,"I wonder if her child is his,"],[6423,6544,"and not yours."]],"16":[[1242,1384,"Doctor,"],[1455,1555,"my baby..."],[1593,1797,"You're stable now, Miss Miller."],[1797,2031,"But take it easy for the baby's sake."],[2439,2660,"You're putting both your lives at risk."],[2702,2815,"Thank you"],[2815,2998,"for answering the call on time."],[3123,3232,"I don't know how much longer"],[3232,3336,"I can hang on."],[3465,3657,"Media mogul Jaxon Astor"],[3657,3824,"and actress Isabella Sterling"],[3824,4004,"recently signed a long term deal."],[4016,4116,"They were spotted together"],[4116,4266,"at the hospital for a pregnancy checkup."],[4554,4675,"My belly."],[4733,4967,"Natasha, he is not worth your pain."],[4967,5092,"Just rest."],[5092,5267,"Focus on your baby"],[5267,5442,"and work on your screenwriting."],[5442,5534,"What?"],[5643,5755,"My writing."],[5784,5905,"You shouldn't waste your talent"],[5905,5985,"as a screenwriter."],[6026,6168,"You're right."],[6256,6519,"When I married him, I..."],[6519,6760,"almost lost myself."],[7165,7240,"The pain is..."],[7378,7478,"It's gone."],[7674,7857,"It doesn't hurt anymore."],[8216,8429,"Are you saying you'll support my art?"],[8479,8629,"I'll protect you always."],[8742,8867,"I promise."],[9180,9342,"I'll protect both of you."],[9605,9726,"Natasha Miller."],[9855,10047,"Whose child are you carrying?"]],"17":[[20,137,"The baby"],[137,250,"is mine."],[571,717,"Oh, what?"],[717,846,"Now the father wants to be the hero."],[1539,1643,"Oliver."],[3582,3687,"Natasha."],[4158,4408,"You had my heart once, Jaxon."],[4625,4704,"But you crushed it"],[4704,4900,"without a second thought."],[5109,5230,"Jaxon,"],[5359,5555,"are you a God sent to catch me?"],[5609,5910,"It seems your fate is tied to mine forever."],[6489,6619,"So this is your revenge on me"],[6619,6831,"getting knocked up by another man?"],[6844,7044,"I don't care who the father is."],[7044,7215,"Get rid of that kid."],[7215,7353,"Don't bring shame to my family."],[7674,7928,"So is Isabella, right?"],[7928,8229,"You want to get rid of our baby?"],[8341,8521,"You married me for money, didn't you?"],[8521,8596,"Just make sure"],[8596,8829,"you cash in with an Astor heir."],[8829,8971,"Scream louder."],[8971,9109,"Scream all you want."],[9109,9371,"You are nothing but a contract to me."],[10272,10393,"Natasha."],[10548,10769,"I'm going to divorce Jaxon."]],"18":[[346,421,"Mr. Astor,"],[421,521,"you've just signed Isabella"],[521,588,"as an actress."],[588,763,"Are the wedding bells next?"],[817,917,"What?"],[959,1109,"Where did you hear about that?"],[1217,1405,"Who is she?"],[1405,1655,"She's gorgeous."],[4800,4913,"If we have good news,"],[4913,5042,"we will be the first to share."],[5042,5105,"Right,"],[5105,5221,"Jaxon?"],[5805,5939,"Jaxon Astor."],[6239,6314,"Before you"],[6314,6519,"announce your engagement,"],[6519,6685,"when you’re planning on"],[6685,6790,"divorce me?"]],"19":[[16,133,"Divorce?"],[133,396,"So Isabella is just a side chick."],[400,496,"Jackson wants to sign"],[496,692,"his side chick as an actress?"],[742,842,"Who would watch a movie"],[842,971,"starring someone like that?"],[996,1121,"What are we supposed to do?"],[1121,1230,"We just signed a contract"],[1230,1405,"and everyone thinks I'm a side chick."],[1438,1543,"You blacklisting"],[1543,1622,"your company is going to"],[1622,1739,"be ridiculed."],[1764,1835,"Oh my God,"],[1835,1981,"she's trying to ruin us."],[2139,2248,"Come with me."],[2318,2477,"Answer me first."],[2477,2652,"When do you plan on divorcing me?"],[2652,2802,"Because I don't enjoy"],[2802,2952,"being cuckolded every day."],[2990,3048,"Oh,"],[3078,3174,"let me do you a favor."],[3303,3557,"Do you enjoy being with my husband?"],[3724,3920,"You are misunderstanding."],[3949,4104,"We're just friends."],[4104,4212,"I mean,"],[4245,4479,"you don't need to be so insecure."],[4479,4575,"Trust Jaxon."],[4575,4679,"He loves you."],[4825,4975,"He loves me."],[4975,5038,"Well,"],[5038,5167,"then why would you two"],[5167,5305,"be holding hands?"],[5447,5584,"You know what, Natasha?"],[5584,5680,"Here's the truth."],[5726,5910,"I was Jaxon's first love."],[5910,6085,"And you slept with him for money."],[6085,6214,"That's the truth."],[6235,6385,"That's enough."],[6385,6502,"Alright."],[6535,6690,"Well, if you say so."],[6727,6819,"Jaxon."],[6906,7048,"I want a divorce."]],"20":[[0,141,"Are you divorcing me for him?"],[337,567,"No, I'm doing this for myself."],[663,821,"Never gonna happen!"],[1551,1618,"Remember."],[1618,1668,"Jaxon."],[1668,1730,"It was you"],[1730,1935,"who pushed me away first."],[1976,2102,"Just let it go."],[2160,2373,"And now everyone knows"],[2389,2535,"about you and Isabella."],[2723,2911,"So why would we stay married?"],[3749,3883,"I will never let you go,"],[3883,4008,"Natasha."],[4158,4379,"I'll go grab a car."],[5872,5951,"How dare you"],[5951,6131,"ruin my signing ceremony?"],[6131,6285,"Go to hell!"]],"21":[[592,892,"I'm the father of the child."],[1914,2002,"Jaxon."],[2031,2147,"It hurts."],[3311,3361,"Damn it!"],[3399,3436,"Don't worry."],[3436,3524,"I'm going to call an ambulance."],[3524,3586,"Is it okay?"],[3666,3737,"Okay."],[3962,4116,"Hey! Anybody!"],[4116,4258,"Anybody help us!"],[4587,4679,"Jaxon!"],[4679,4792,"Natasha needs help, please."],[4792,4871,"Can you save her?"],[4950,5075,"Oliver seems to care deeply"],[5075,5184,"for his child."],[5401,5572,"I'm the father of the child."],[5847,5935,"Kid isn't mine."],[6143,6264,"It's none of my business."]],"22":[[679,863,"My baby..."],[863,1017,"Don't worry."],[1017,1134,"Everything's fine."],[1188,1455,"Baby must be an angel to survive."],[1851,1972,"Will you pass a message"],[1972,2114,"to Jaxon for me?"],[2406,2569,"Meet me"],[2569,2765,"Monday, 9 a.m."],[2765,2877,"at the company,"],[2907,3215,"to finalize the divorce papers."],[4579,4713,"Mr. Astor, are you and Isabella"],[4713,4821,"really having an affair?"],[4821,4963,"Is Isabella your true love?"],[4963,5121,"Will you leave your wife for her?"],[5121,5213,"Did you sign Isabella"],[5213,5326,"because of the affair?"],[5626,5709,"Mr. Astor!"],[5709,5868,"Mr. Astor, comment?"],[5868,5922,"Anything?"],[5922,5985,"A comment?"],[6748,6806,"Natasha,"],[6806,6886,"you still have time"],[6886,6969,"to change your mind."],[7057,7215,"You're overthinking."],[7215,7378,"I'm just happy to be free."],[7390,7536,"Natasha, if you apologize"],[7536,7686,"for what you did to Isabella,"],[7686,7782,"I can forgive you."],[7836,8008,"You humiliated her in public."],[8008,8137,"And you're with Oliver now."],[8137,8333,"Well, I don't need your forgiveness"],[8333,8391,"for anything."],[8425,8550,"Natasha."],[8675,8879,"Just sign the papers."],[8879,9013,"Stop wasting my time."],[9922,10005,"Well,"],[10005,10172,"as your ex-wife,"],[10172,10314,"I congratulate you"],[10314,10427,"and your side chick."],[10427,10598,"And finally being together."],[10756,10960,"Natasha, I can't wait for the day"],[10977,11098,"that you regret this."],[11102,11198,"And you come crawling"],[11198,11269,"back to me."],[11290,11369,"Well then,"],[11494,11636,"keep waiting."]],"23":[[880,959,"Mom,"],[1080,1142,"I'm here."],[2143,2260,"I have good news."],[2560,2723,"I'm pregnant."],[2886,2982,"But..."],[3119,3299,"Jaxon and I are"],[3299,3440,"divorced."],[3507,3737,"When dad died"],[3737,3895,"and you remarried."],[3916,4170,"You raised me on your own."],[4170,4245,"But..."],[4316,4471,"Now I'm..."],[4654,4867,"So scared."],[4946,5096,"Maybe if I..."],[5096,5292,"If I hadn’t taken his grandpa’s money,"],[5292,5409,"or..."],[5409,5505,"if I hadn't agreed"],[5505,5622,"to the marriage contract,"],[5622,5755,"things wouldn't be as bad as they are"],[5755,5822,"right now."],[6368,6406,"Hey."],[6619,6777,"You have to keep this baby."],[6777,6890,"It's an Astor."],[6931,7194,"You can't order me to do anything."],[7194,7336,"Sorry, Miss."],[7336,7469,"Your dad died too soon."],[7561,7620,"Either way,"],[7620,7728,"you have to call me 'dad'."],[7757,7962,"You've never gave a damn about me"],[7962,8058,"or my mother."],[8116,8358,"What you care about is money!"],[8358,8521,"That's right."],[8521,8625,"I’ll stop paying"],[8625,8704,"your mother's medical bills,"],[8704,8900,"if you divorce Jaxon."],[8904,9084,"But fortunately,"],[9084,9205,"you're having a child."],[9225,9338,"And that child"],[9338,9526,"makes you more valuable."],[9555,9772,"I will not use my child as a deal."],[9901,10105,"Stupid bitch."],[10105,10251,"Wait, I’ll tell Jaxon Astor"],[10251,10347,"the good news."]],"24":[[1130,1192,"Grandpa,"],[1192,1276,"I’m sorry..."],[1405,1659,"Maybe I can't keep my promise."],[1676,1805,"Oh, honey."],[1805,1856,"It's..."],[1856,2043,"It's all my fault."],[4008,4120,"Miss, please stop!"],[4120,4170,"No."],[4200,4279,"It's okay."],[4279,4421,"I know first aid."],[4421,4571,"If anything happens for him,"],[4571,4729,"I'll take blame for it."],[5647,5726,"Try this."],[6514,6690,"Thanks, young lady."],[6852,6931,"I had..."],[6977,7190,"a little blood sugar crash."],[7478,7640,"Are you going to an interview?"],[7728,7982,"It's my dream to be a screenwriter."],[7982,8179,"If I could just get closer to Jaxon."],[8179,8245,"But..."],[8433,8529,"It's..."],[8529,8654,"Everyone wants to work"],[8654,8812,"at the Astor Group."],[8892,8988,"I can help."]],"25":[[8,137,"Thank you, but I believe"],[137,241,"I can make it on my own."],[417,546,"Back then, I,"],[546,629,"I just knew"],[629,767,"you were the one for Jaxon."],[817,988,"I'm so sorry, kid."],[1113,1267,"I truly wish there was something"],[1267,1401,"I could do to make up for it."],[1793,1981,"You are the only one"],[1981,2114,"who can get through to him."],[2181,2268,"Please."],[2348,2548,"Make him sign this divorce papers,"],[2590,2736,"and let me go."],[3265,3365,"I just found out"],[3365,3566,"he forged his signature."],[3682,3983,"He lied to me."],[4116,4212,"Natasha."],[4471,4596,"Grandpa,"],[4596,4713,"where's Natasha?"],[4713,4846,"Look, I misunderstood her."],[4875,4942,"James told me everything."],[4942,5238,"Don't you dare bother her again."],[5597,5734,"This can't be true."],[5734,5818,"I have to found her."],[5818,6168,"I am just so disappointed in you."],[6247,6377,"When this is over,"],[6464,6635,"I'm going to go on a vacation in Europe."],[6635,6802,"Grandpa please,"],[6802,6869,"you have to tell me"],[6869,6927,"where she is."],[6927,7119,"If you really care about her,"],[7119,7282,"just sign these papers"],[7378,7520,"and let her go."]],"26":[[1201,1288,"Jaxon,"],[1338,1434,"let's forget about everything"],[1434,1543,"and enjoy tonight."],[1576,1639,"Natasha?"],[1951,2043,"You're not Natasha."],[2043,2152,"Go away."],[2152,2289,"Just try to make you happy."],[2289,2456,"Stay away from me."],[2456,2686,"Why are you so crazy about her?"],[2777,2898,"Natasha,"],[2969,3123,"where are you?"],[3178,3328,"I miss you so much."],[3328,3478,"You ruined my life."],[3582,3691,"You owe me."],[5130,5180,"Natasha?"]],"27":[[250,379,"Natasha?"],[446,517,"Was that Natasha?"],[517,592,"Am I hallucinating?"],[663,792,"Natasha again?"],[792,971,"That hunting bitch!"],[1051,1234,"You must be seeing things."],[1234,1384,"Natasha is just a housewife."],[1384,1476,"What would she be doing in"],[1476,1664,"Director Alex's party?"],[1760,1876,"Thank you for bringing me here,"],[1876,1939,"darling."],[1993,2289,"I really want the lead in Director"],[2289,2398,"Alex's new movie."],[3203,3290,"Oh my God!"],[3887,3995,"What makes you think someone"],[3995,4104,"like you can join this party?"],[4154,4295,"Hey, hey!"],[4587,4633,"Are you okay?"]],"28":[[33,133,"What's going on?"],[204,271,"Is everything okay?"],[404,554,"Mr. Jones,"],[625,763,"I'm Isabella Sterling."],[763,884,"I'm an actress."],[1026,1263,"I am such a big fan of your work."],[1376,1539,"I was wondering if I could help you"],[1539,1722,"on your new film, Miracle?"],[1839,2002,"Oh, I don't think there's a part"],[2002,2122,"you could play in this film."],[2177,2348,"What gives you the right to judge me?"],[2389,2477,"Natasha,"],[2602,2890,"you are the heart of my story,"],[2890,3169,"the best partner, star of tonight."],[3169,3345,"Natasha. What?"],[3382,3595,"Oh my God. It's so nice to meet you."],[3595,3741,"Are you doing another adaptation"],[3741,3878,"of the Henderson book?"],[3878,4037,"Oliver said he's willing to invest"],[4037,4183,"more because he believes in you."],[4304,4408,"Am I really losing you?"],[4408,4525,"Oh you are so talented."],[4525,4688,"Why does it hurt so bad?"]],"29":[[625,804,"What are you doing?"],[804,975,"Where have you been all this time?"],[1059,1226,"Mr. Astor,"],[1226,1413,"need I remind you?"],[1413,1651,"We are strangers now."],[1651,1801,"Strangers?"],[1801,1893,"Interesting."],[2444,2602,"Are you crazy?"],[2794,2982,"The taste of a stranger..."],[2982,3090,"not bad."],[3090,3390,"Don't do this to me again."],[3916,3974,"You slut!"],[3974,4158,"Are you still trying to seduce Jaxon?"],[4504,4537,"You know,"],[4537,4721,"maybe you should ask yourself"],[4721,4884,"if you actually love him"],[4884,4996,"or if you're just"],[4996,5159,"trying to take him from me."],[5476,5568,"Natasha"],[5568,5659,"you've got it all wrong"],[5659,5801,"about me and Jaxon."]],"30":[[12,70,"I'm sorry."],[70,225,"Please don't hit me Natasha."],[350,504,"It was, it was just a misunderstanding."],[504,721,"She didn't mean to push me."],[942,1001,"Jaxon,"],[1030,1188,"please explain to Natasha"],[1188,1376,"that I just wanted a shot at the role."],[1443,1551,"Natasha,"],[1551,1680,"it is not the time."],[1680,1793,"If we need to talk about something."],[1856,2110,"Jaxon. We're divorced."],[2110,2318,"And you still fall for her tricks?"],[2364,2439,"What?"],[2439,2531,"No."],[2531,2706,"Who I am worried about is..."],[2706,2781,"Get the shot!"],[2781,2902,"Alex's screenwriter bullying a newbie?"],[2969,3082,"The miracle is done."],[3157,3261,"Everybody, please!"],[3261,3332,"Give us some space"],[3332,3415,"to work this out."],[3465,3661,"Give some privacy for me,"],[3661,3745,"Jaxon Astor."],[3891,4066,"Natasha, I know I'm just a newbie"],[4066,4270,"and can't really compete with you."],[4270,4491,"But please, if you insist that"],[4491,4654,"I apologize, I will..."],[4971,5088,"You bitch!"],[5271,5593,"Isabella, you are so good at fake crying."],[5634,5797,"It's too bad you can't fake talent."]],"31":[[166,442,"Wow, what a crazy girl."],[442,567,"It's no wonder why we're partners,"],[729,817,"Alex."],[817,988,"If Isabella is in the film,"],[1030,1117,"I'm out."],[1242,1297,"Whoa, wait."],[1297,1393,"How did I get drug into this?"],[1393,1568,"I agree, we have the rights."],[1568,1743,"We can find another team."],[1743,1947,"I'm on your side, Natasha."],[1947,2110,"Come on, let's talk this out."],[2506,2556,"I don't know"],[2556,2648,"why she's going after me."],[2648,2694,"Please,"],[2694,2786,"please help me."],[2865,2982,"Jaxon,"],[2982,3282,"gets those reporters to go after Natasha."],[3282,3461,"She's a conniving bitch."],[3461,3520,"She's just going to"],[3520,3641,"keep causing trouble."],[3670,3766,"Get out of here."],[3791,3899,"Now!"],[4195,4375,"Natasha is my wife."],[4375,4575,"Quit spreading rumors about her."],[4575,4658,"Mess with her,"],[4704,4813,"and you mess with Astor."]],"32":[[400,658,"Hey, Jaxon."],[658,792,"I have some coffee."],[792,909,"We need to talk."],[1280,1488,"You faked that fall to frame Natasha,"],[1488,1572,"didn't you?"],[1584,1668,"No."],[1722,1943,"Jaxon, I didn’t."],[1943,2085,"I swear."],[2085,2231,"Take a look at yourself."],[3015,3103,"No, I."],[3269,3486,"I ruined my face to save you."],[3578,3678,"And everyone at the party"],[3678,3770,"looks down at me."],[3770,3883,"And you,"],[3883,3978,"I saw you and Natasha"],[3978,4087,"make out in the restroom..."],[4087,4208,"I warned you."],[4283,4525,"Don't dare her!"],[4525,4658,"She's my wife."],[4738,4950,"That's enough Jaxon."],[4950,5084,"Natasha has already"],[5084,5238,"embarrassed the Astor family."],[5238,5376,"Just divorce her."],[5376,5563,"Isabella is the one who actually"],[5563,5676,"belongs here."],[5730,5993,"Natasha is my only wife."],[5993,6143,"Period."],[6544,6698,"If Natasha keeps fooling Jaxon,"],[6698,6865,"she's going to ruin the Astor name."],[6865,6969,"If she stays in this family"],[6969,7086,"who knows what kind of mess"],[7086,7144,"she'll make."],[7144,7298,"I won't allow this."],[7298,7553,"Maybe she needs to learn a lesson"],[7553,7649,"to learn her place."]],"33":[[321,437,"Natasha."],[437,608,"Your stuff is still here."],[608,779,"What are you planning to settle in for?"],[779,850,"Good."],[850,1063,"Throw it out if you want."],[1063,1226,"Tell her Jaxon already signed the"],[1226,1330,"divorce papers."],[1409,1509,"Do you want to come pick up the divorce papers?"],[1509,1668,"divorce papers Jaxon signed?"],[2606,2773,"Where are the papers?"],[2773,2969,"Don't waste my time."],[3078,3311,"Take it and get lost."],[3378,3445,"Natasha,"],[3478,3582,"I am telling you"],[3595,3816,"stay away from Jaxon."],[3816,3933,"The Astor family doesn't need"],[3933,4212,"someone like you ruining our name."],[4366,4429,"Well,"],[4525,4662,"then maybe you should watch out for"],[4662,4758,"your son."],[4758,4967,"How dare you talk to me like this?"],[6539,6664,"Someone's been injured."],[6664,6790,"We need an ambulance."],[6790,6948,"You're a murderer."]],"34":[[300,392,"Why did you push Emily Astor"],[392,492,"down the stairs?"],[496,638,"I didn't."],[1013,1155,"Ma’am put your phone down."],[1205,1401,"It's my mom's hospital."],[1401,1572,"I have a right to answer that."],[1730,1906,"Miss."],[2027,2164,"I'm in charge here."],[3269,3445,"Get up and confess your crimes!"],[3803,3870,"Natasha, hang in there!"],[3870,3953,"Jaxon."],[4008,4091,"The baby..."],[4458,4688,"You know I am An Astor,"],[4742,4854,"and I promise you"],[4854,4975,"you’ll be tearing off that uniform yourself."],[5163,5334,"She tried to kill your mom."],[5334,5513,"We have a witness."],[5513,5780,"I trust her more than anyone else."],[6443,6644,"Patient's miscarried!"],[6644,6848,"Prep for D&C stat!"],[8362,8500,"What?"],[8525,8646,"Natasha’s mom..."]],"35":[[454,483,"You've"],[483,604,"been handling her mom's"],[604,784,"arrangements all night."],[796,967,"You need to rest."],[967,1159,"Natasha just lost her baby."],[1159,1247,"I need to tell her about her"],[1247,1455,"mother's death in person."],[2406,2598,"Natasha, please wake up."],[2598,2898,"I need to tell you something."],[3503,3799,"I heard my mother died."],[3799,3912,"Did you kill her?"],[3912,4041,"No."],[4041,4154,"You didn't get the call"],[4154,4270,"when you're in surgery."],[4270,4471,"They notified me instead."],[4471,4650,"You were the last person to see my"],[4650,4771,"mom before she died."],[4854,5009,"If I find out you had anything"],[5009,5084,"to do with this,"],[5084,5217,"I'll make you pay."],[5484,5651,"Is that really what you think of me?"],[6398,6652,"Mom. So sorry"],[6652,6760,"you never got to see"],[6760,6952,"my work on the screen."],[7036,7178,"She'd want you to keep going,"],[7282,7449,"to make it happen regardless."],[7686,7803,"You're right."],[8258,8441,"I lost my mom,"],[8541,8679,"my baby."],[8696,8800,"I've lost everything."],[9284,9480,"I can't let the people who hurt me win."],[9818,9997,"Do you have any information"],[9997,10105,"on that cop?"],[10105,10251,"It was all staged by Isabella."]],"36":[[571,871,"You know, I didn't do anything right?"],[1301,1376,"Make sure that"],[1397,1518,"bitch gets what's"],[1518,1818,"coming to her."],[2160,2318,"Isabella, you're going to pay"],[2318,2506,"for everything you've done."],[3753,3870,"Natasha,"],[3870,3978,"shouldn't a murderer"],[3978,4170,"like you be hiding somewhere?"],[4250,4371,"Really?"],[4371,4583,"Maybe that means that you should be"],[4583,4642,"hiding."],[4642,4829,"Shut up!"],[5401,5534,"Are you out of your mind?"]],"37":[[291,538,"Jaxon."],[538,700,"Jaxon."],[700,867,"Look what Natasha just did."],[867,975,"She's not even supposed"],[975,1034,"to be here."],[1034,1201,"Now, she's ruining everything."],[1201,1363,"No, I think you got it all wrong."],[1363,1551,"Natasha is still my go-to writer."],[1551,1639,"So what?"],[1639,1780,"She's just a writer."],[1780,1872,"He has the right."],[1872,2064,"If Natasha is on the review panel."],[2064,2198,"I've invested twice as much as"],[2198,2264,"Mr. Astor."],[2264,2381,"And I trust in Natasha's"],[2381,2565,"judgment, over years."],[2711,2773,"Natasha,"],[2773,2919,"why are you using someone else's"],[2919,3019,"influence against me?"],[3086,3253,"Listen, I'm sorry about your mother."],[3253,3457,"Please, just listen to what I have to say."],[3457,3620,"I don't need to explain myself"],[3620,3653,"to you."],[3682,3870,"I don't need your explanations."],[4020,4154,"Mr. Jones,"],[4237,4358,"she's a murderer."],[4358,4533,"If you keep her on this team,"],[4533,4696,"she will ruin this film."],[4742,4904,"The screenwriter"],[4904,5042,"accused of murder."],[5138,5309,"That's great publicity."],[5384,5626,"As the police will find out the truth,"],[5647,5822,"until then, let's focus on the film."]],"38":[[258,412,"Jaxon, Natasha is taking revenge"],[412,467,"on us."],[467,571,"My role has been changed to"],[571,625,"a mistress,"],[625,763,"and the plot clearly mirrors"],[763,846,"our situation."],[1071,1238,"Why did you change the script?"],[1309,1526,"Well, this script has more conflict."],[1526,1722,"It will resonate with the audience more."],[1722,1964,"Does it resonate with the audience"],[1964,2077,"or does it resonate with you?"],[2189,2364,"The female lead gets dumped"],[2364,2519,"and successfully avenges herself"],[2519,2665,"against the male lead."],[2665,2815,"Are you trying to mock me,"],[2902,3003,"or are you just flaunting"],[3003,3094,"your relationship with Oliver?"],[3132,3261,"Don't overthink it."],[3324,3545,"This script is my baby"],[3545,3724,"and I wouldn't change it for trash."],[3841,4095,"What the hell? Look here."],[4095,4270,"The mistress pushes"],[4270,4433,"the lead man's mother down"],[4433,4504,"the stairs,"],[4517,4696,"leaving her in a coma,"],[4696,4825,"and frames the lead girl."],[4833,4979,"Isn't this about us?"],[5084,5234,"Art imitates life."],[5234,5513,"Do these scenes seem real to you?"],[5513,5701,"Don't slander me."],[5701,5914,"Shut up! Isabella! You liar!"],[5914,6051,"The one who pushed Jaxon's"],[6051,6214,"mother down the stairs was you."],[6443,6614,"You were there."],[6614,6740,"If I pushed her down the stairs,"],[6740,6906,"why didn't you try and stop me?"],[6906,7140,"Why did I call 911 and go with"],[7140,7248,"his mother to the hospital."],[7349,7499,"Jaxon, if I was going to"],[7499,7561,"harm your mother,"],[7561,7716,"don’t you think I would have fled the scene"],[7716,7928,"instead of going with her?"],[8091,8320,"I was too nervous."],[8320,8466,"None of that matters now."],[8466,8637,"What matters is that I didn't harm"],[8637,8767,"his mother."],[8796,9150,"But Jaxson, you might have killed mine."]],"39":[[37,187,"This is absurd."],[187,433,"Your mother died of an illness."],[433,513,"Your mother's passing"],[513,621,"had nothing to do with me."],[621,921,"She passed after you visited her."],[963,1080,"I suspected you."],[1080,1267,"You did something or said something"],[1267,1380,"to her to make her die."],[1384,1605,"Natasha. Is that how you see me?"],[1605,1805,"You have given me no reason to believe otherwise."],[1805,1906,"to believe otherwise."],[2018,2152,"Jaxon isn't like that."],[2152,2385,"Shut up, you liar!"],[2419,2527,"Natasha,"],[2527,2681,"If I prove I had nothing to do"],[2681,2811,"with your mother's death,"],[2890,3003,"what will you do?"],[3148,3286,"Well,"],[3286,3624,"I will kneel and apologize."],[3653,3953,"I hope you keep your word."],[4145,4216,"This is the last footage"],[4216,4358,"seen by the hospital"],[4358,4504,"before your mom's passing."],[4571,4646,"Mom!"],[4767,4821,"I'm sorry."],[4821,4938,"We did everything we could."]],"40":[[542,696,"Get the helicopter ready."],[696,875,"Bringing the best specialists now."],[1509,1714,"It's ok, kid."],[1714,1889,"I know it's my time."],[1889,1997,"Natasha is on her way."],[2035,2181,"She's filming her first movie"],[2181,2302,"with Oscar winning director."],[2377,2677,"I won't get the chance to watch it."],[2769,2886,"Promise me..."],[2973,3236,"you'll look after her."],[3282,3486,"She has no one else now."],[3532,3653,"I promise."],[3653,3837,"I promise I'll protect her."],[3874,3953,"From now on nothing"],[3953,4049,"will hurt her."],[4462,4621,"And there is a secret I need"],[4621,4721,"to tell her..."],[5826,5889,"What do you want to say"],[5889,5997,"to me...Mom?"],[6022,6193,"I will find out the truth."],[6193,6381,"So sorry."],[6381,6539,"I'll keep my promise to apologize."]],"41":[[250,429,"Hi. Welcome, Isabella."],[429,538,"Today is the opening day of our"],[538,679,"movie and I cannot wait to see you dress up."],[679,725,"dress up."],[725,842,"I'm sure you're going to look"],[842,921,"beautiful."],[1067,1176,"The supporting actors are getting"],[1176,1267,"ready down the hall in the public"],[1267,1309,"dressing room."],[1309,1418,"Right this way."],[1468,1735,"I actually got here early."],[1735,1985,"I was wondering could I please"],[1985,2177,"use the private dressing room first?"],[2177,2348,"Natasha's actually using it."],[2473,2602,"That way."],[2602,2898,"Love you minutes."],[3799,3832,"Excuse me."],[3832,4024,"Natasha, can you sign for me?"],[4024,4129,"Of course."]],"42":[[1530,1722,"I'll get someone to get you a new dress."],[1722,1785,"What's your size?"],[1785,1997,"No, no, guys. It's fine."],[1997,2131,"I'm just the screenwriter."],[2131,2248,"Nobody's even going to care"],[2248,2306,"what I'm wearing."],[2306,2364,"What?"],[2364,2581,"You're the face of the movie."],[2581,2665,"Oh my God."],[2665,2756,"I've got it covered."],[2819,2936,"I know my wife"],[2936,3057,"better than anyone else."],[3219,3386,"I've got a new dress right here."],[3712,3870,"Thank you."],[3870,3987,"Watch your tongue."],[4963,5092,"Is someone out there?"],[6085,6164,"Get out!"]],"43":[[58,187,"Looks like the dress I got you"],[187,337,"suit your figure perfectly."],[517,617,"If anyone..."],[696,913,"Go ahead and try."],[971,1076,"Let’s see they'll come in and"],[1076,1155,"see what this."],[1368,1589,"A new screenwriter"],[1589,1735,"with a guy..."],[1735,1939,"or should I say ex-husband"],[1939,2185,"gets intimate in the dressing room? Wow."],[2243,2414,"Wow, that's some good publicity."],[2540,2715,"Natasha, I’m just trying to help"],[2715,2806,"you with that zipper,"],[2907,3103,"which look perfect for your big day."],[3190,3378,"Show me some respect."],[4354,4604,"You're beautiful."],[4604,4713,"Hope today will be a big success"],[4713,4813,"for you."],[7273,7411,"You said you could never fall"],[7411,7574,"for a woman like me."],[7674,7853,"You got it all wrong."],[7853,8070,"I was just thinking how much you've"],[8070,8179,"changed from the awkward girl"],[8179,8366,"in high school."],[8366,8666,"Looks like I did pick the perfect dress."]],"44":[[342,642,"What are you doing now?"],[1184,1380,"Trying to get back something I lost."],[1455,1755,"Something important."],[1956,2064,"I am Isabella"],[2064,2256,"and played the villain in Miracle."],[2344,2602,"Isabella, you're gorgeous."],[2602,2777,"Why take such an evil role"],[2777,2902,"for your debut?"],[3048,3349,"Actually, Natasha picked it for me."],[3395,3549,"I went out for the lingerie role,"],[3549,3724,"but, hey, I'm cool with this one."],[3782,3937,"I mean, it's a challenge,"],[3937,4095,"but I'm up for it."],[4225,4429,"Natasha, do you have any comment"],[4429,4546,"on Isabella's statement?"],[4600,4829,"I mean, we all remember how you"],[4829,5050,"treated Isabella at that party."],[5192,5413,"Oh, this guy is also the one"],[5413,5513,"creating conflicts at"],[5513,5680,"the last press conference."]],"45":[[475,729,"Isabella has gotten out of hand."],[729,880,"If this scandal breaks, it's going to"],[880,980,"ruin our film."],[1105,1326,"Here is what I've captured."],[1326,1422,"It could be the biggest story"],[1422,1501,"of the day."],[1893,1976,"Firstly,"],[1976,2177,"I want to thank everyone"],[2177,2460,"for their interest in our film miracle."],[2519,2877,"What you just saw was Isabella's"],[2877,3178,"audition footage."],[3182,3319,"Because there is such a"],[3319,3457,"stark contrast"],[3457,3595,"between the way she looks"],[3595,3895,"and how intense that performances."],[3970,4158,"I convinced director Alex"],[4158,4266,"to give her the part,"],[4300,4700,"even though she's so, so new."],[4758,4917,"Audition footage?"],[4917,5084,"It looks like she really wants to"],[5084,5230,"leave you with nothing to wear."],[5301,5492,"Well, that just goes to show"],[5492,5793,"how talented all our actors are."],[5893,5947,"Now"],[5947,6068,"let's get back to talking about"],[6068,6126,"the film."],[6126,6473,"It is my first film, so I might cry,"],[6473,6639,"especially if none of you are"],[6639,6898,"interested in it."],[8170,8370,"Are you crazy?"]],"46":[[233,400,"Natasha, what's your problem?"],[400,604,"I gave you this opportunity"],[604,742,"because I thought you had potential."],[771,896,"But now you keep messing with"],[896,1071,"the crew over your petty drama."],[1101,1292,"Keep this up and I will make sure you"],[1292,1551,"do not work another day in this industry."],[1634,1889,"Jaxon, help! Natasha is crazy!"],[1889,1968,"Natasha..."],[2147,2185,"Well."],[2185,2394,"I'm sorry, did I hurt your"],[2394,2481,"little girlfriend?"],[2569,2727,"Did you come to protect her?"],[3311,3382,"Look,"],[3382,3520,"I just wanted to apologize"],[3520,3678,"for Isabelle."],[3807,3949,"Anything else?"],[3949,4112,"I have to meet with Producer Leyden"],[4112,4250,"about the final edit."],[4258,4337,"Well."],[4337,4504,"If you want,"],[4504,4612,"If you want, you could always sign with Aster."],[4612,4863,"Yeah, let's just hope you keep"],[4863,5071,"that promise."]],"47":[[759,930,"Come on, let's get to work."],[1872,2173,"Oh, Natasha, you look tired."],[2364,2494,"Why don't you just lay down and rest"],[2494,2590,"for a while? Oh."],[3036,3136,"Excuse me."],[4204,4312,"I need help."],[4421,4533,"Natasha? What's wrong?"],[4533,4629,"Where are you?"],[4963,5109,"Let's have a long conversation"],[5109,5238,"about this script."],[6060,6281,"Our famous screenwriter."],[6281,6406,"How does it feel to be treated"],[6406,6581,"like this?"],[6715,6815,"Really?"],[6815,7090,"Isabella, this is the best you've got."],[7090,7415,"Still acting tough, Why don't you bark"],[7415,7528,"like a dog?"],[7574,7749,"Maybe then I'll let you go,"],[7828,7974,"Beg like a dog?"],[7974,8116,"Not going to happen."],[8212,8350,"Piss on her head."],[8350,8604,"Show her the real dog is."]],"48":[[95,396,"Natasha, are you in there?"],[417,717,"Jaxon, help!"],[1401,1701,"It's okay."],[2481,2535,"Lydon,"],[2535,2715,"I swear on the Astor name you're done."],[2715,2827,"I’ll make sure you never work in"],[2827,2927,"this business again."],[2927,2994,"No,"],[3040,3224,"there was another one."],[3224,3328,"Who else? Tell me!"],[3411,3541,"Please, I swear I never"],[3541,3645,"I never even touched her..."],[3666,3753,"Just let me go..."],[4692,4788,"Jaxon, help me..."],[4904,5042,"Isabella, what are you doing here?"],[5109,5292,"I was doing a scene with Lydon,"],[5292,5497,"and then he got, interested."],[5497,5601,"But I don't even know"],[5601,5714,"how Natasha got involved."],[5730,5893,"My God, I'm freaking out."],[5893,6060,"Oh, just watch the security footage."],[6060,6110,"Then you'll see"],[6110,6214,"what really happened."],[6272,6331,"Natasha,"],[6456,6514,"you've been through enough"],[6514,6594,"tonight."],[6594,6752,"Let's go home and get some rest."],[6831,6890,"No,"],[6994,7094,"I want to stay here,"],[7094,7332,"watch these two get arrested myself."],[7415,7457,"Natasha,"],[7457,7565,"I will talk to Isabella."],[7720,7912,"No matter what she does,"],[7962,8262,"you were always going to protect her."],[8554,8646,"Let me go."],[8721,8821,"I can walk on my own."]],"49":[[325,421,"Ah."],[504,721,"Natasha, I'm sorry."],[721,863,"I was just too scared."],[863,1013,"That's why I didn't help you."],[1013,1121,"I swear."],[1301,1413,"Let me take you home."],[1480,1572,"No."],[1630,1743,"Why don't you just make sure"],[1743,1972,"your perfect mistress get home safe"],[2052,2273,"and sign the divorce papers."],[2640,2752,"Natasha, are you okay?"],[2794,2877,"Alex told me you were here"],[2877,2923,"for the script."],[2923,3073,"And I heard Lydon's got some shady"],[3073,3190,"business deals going on."],[3203,3282,"I'm fine."],[3315,3449,"I'm just a little tired."],[3478,3520,"Okay."],[3520,3586,"You don't have to explain"],[3586,3657,"everything right now."],[3670,3787,"Just tell me whenever you're ready."]],"50":[[254,354,"Mr. Astor,"],[404,613,"She needs to rest right now."],[613,704,"I don't think Lydon"],[704,817,"any more than he did,"],[817,896,"but"],[896,1084,"I heard a loud crash before I came in..."],[1213,1380,"Check her arm for any injuries."],[1380,1501,"And get her safe, please."],[1705,1810,"Take her home."],[1810,1872,"Thank you."],[2644,2790,"Send me the surveillance footage,"],[2790,2944,"now."],[3962,4166,"Didn't I warn you about touch"],[4166,4262,"Natasha."],[4396,4575,"I was just so angry Jaxon."],[4575,4729,"She pushed Emily down the stairs!"],[4767,4838,"I just wanted Lydon"],[4838,4909,"to give her a lesson..."],[4909,5159,"I didn't think he'd... push it too far."],[5171,5392,"If it weren't for you saving my life,"],[5392,5559,"I'd have you arrested right now."],[5563,5734,"Touching Natasha again."],[5734,5805,"And I'll make sure"],[5805,5926,"you’ll be out of this country for good."]],"51":[[955,1105,"I've signed the divorce papers."],[1105,1284,"I'll bring them over now."],[3069,3207,"How did you get in here?"],[3253,3461,"You married into the Astor family,"],[3461,3670,"and you live in an apartment."],[3874,3928,"Come on."],[4216,4337,"What do you want?"],[4337,4625,"Tell Jaxon to pay up for the abortion"],[4625,4775,"and break up payout."],[4808,5038,"It was me who divorced him."],[5121,5246,"I got you in his bed,"],[5246,5422,"and you can't even get the money."],[5476,5580,"What a joke."],[5830,5997,"I stayed that night,"],[5997,6110,"because you drugged me."],[6110,6331,"I said because I wanted to."],[6373,6623,"I liked him since high school,"],[6719,6898,"but I regret that now."],[6898,7065,"I don't care if you love him."],[7165,7361,"Get me the money."],[7849,7974,"If you don't get the money,"],[7974,8120,"you'll be the one bleeding."],[8233,8475,"Besides, you're not my real daughter."],[8587,8666,"You're not even your"],[8666,8767,"mother's daughter."],[8767,8921,"No one cares about you."],[8921,9038,"That's a lie."],[9250,9417,"No no"],[9417,9538,"no no."],[9538,9655,"Please."],[10026,10210,"Natasha might take this to court."],[10210,10377,"Oh, I'm not that polite."],[10377,10518,"Maybe I should toss you in the ocean"],[10518,10694,"for fish."],[10727,10856,"Maybe that's too nice."],[10856,10990,"Oh. I'm sorry."],[10990,11136,"It's my fault."],[11136,11232,"Actually, it's not my fault,"],[11232,11323,"it was Isabella's fault."],[11323,11432,"She gave me the address."]],"52":[[675,817,"No."],[1201,1322,"So how'd it go?"],[1322,1393,"Did she agree to"],[1393,1480,"give you the money?"],[1480,1680,"If not, we'll just take that pathetic bitch"],[1680,1805,"and throw her into a nightclub"],[1805,1901,"to sleep around."],[1972,2039,"Don't worry."],[2039,2181,"If you help me keep Natasha"],[2181,2235,"away from Jaxon,"],[2235,2339,"the money's all yours."],[2364,2535,"But just don't let Jaxon find out."],[2535,2640,"Find out about what?"],[2748,2882,"Jaxon?"],[2882,2965,"Why you."],[2965,3128,"Oh. I'm sorry."],[3128,3470,"I may have exposed you to your lover."],[4175,4337,"Hi. Police."],[4337,4437,"Yeah, I need help."],[4437,4617,"Someone broke into my apartment."],[4779,4846,"Oh."],[4846,5221,"Covering for your little affair again."],[5242,5388,"Bodyguards are outside."],[5388,5480,"They'll handle James way"],[5480,5689,"better than the police."],[5689,5922,"No."],[5922,6222,"Listen, please. I'm sorry. Please."],[6277,6398,"I'm really your father."],[6398,6539,"You can call me dad."],[6539,6777,"Okay. Please. Please."],[6777,6973,"No no, listen please."],[6973,7098,"Let's talk about this."],[7098,7286,"Come on. We could work it out. Please."],[7286,7365,"No."],[7574,7707,"You should go too."],[7782,7974,"I handled your problem. I'm thirsty."],[7974,8083,"Can I get a drink?"],[8083,8383,"Do I have to call the police again?"],[8954,9050,"So a guy living here."]],"53":[[66,208,"It's none of your business."],[208,417,"Then why did you call me for help?"],[500,800,"I was drugged and confused."],[888,988,"Looks like I'm still your first"],[988,1138,"emergency contact."],[1138,1226,"Not anymore."],[1297,1443,"Let me remind you."],[1468,1768,"You came here to drop off signed"],[1789,1901,"divorce papers."],[2223,2318,"Oh."],[2494,2598,"I got what I need."],[2635,2686,"I..."],[2957,3115,"I got an alert from the security system."],[3115,3203,"Is everything okay?"],[3403,3520,"Are you two living together?"],[4371,4462,"Stop!"],[4717,4804,"Jaxon."],[4821,5096,"Get out of my house now!"],[5284,5376,"Go."]],"54":[[171,250,"Okay."],[250,387,"Looks like security system"],[387,479,"is working again."],[542,608,"Sorry about that."],[608,734,"We set up all this stuff to make it"],[734,880,"look like a guy who's living here."],[913,1042,"Just didn't plan for you"],[1042,1209,"get in trouble from."],[1234,1401,"Well, I guess the roommate"],[1401,1618,"rumor's pretty much confirmed."],[1705,1935,"So why don't we make it real?"],[2143,2310,"Oliver. I."],[2527,2811,"You've always done so much for me,"],[2811,3061,"and I appreciate that."],[3061,3269,"I mean, I was just a"],[3269,3449,"fan of Henderson Publishing."],[3449,3557,"I never even thought"],[3557,3678,"I'd get to meet you."],[3728,3853,"And then you introduced me to"],[3853,3978,"Director Alex,"],[3978,4195,"and that helped me so much."],[4320,4550,"But I was in love with someone,"],[4550,4713,"and I just think"],[4713,4871,"I need to be by myself right now."],[5121,5271,"But I can help you with anything."],[5472,5605,"I'm sorry."],[5605,5730,"There is actually something"],[5730,5851,"I need you to agree to."],[5943,6064,"Anything."],[6106,6218,"What can I do?"],[6218,6519,"Be my girlfriend."],[6610,6727,"Oliver, I..."],[6727,6831,"I just..."],[6831,7002,"No, no, I mean as a fake one."]],"55":[[91,233,"You remember how I told you that"],[233,446,"I was adopted by Mrs. Henderson?"],[525,692,"Yeah, I read her biography."],[754,934,"It's what made me a fan of Henderson"],[934,1017,"Publishing."],[1017,1142,"Well, she's not doing well"],[1142,1213,"right now,"],[1276,1455,"and all she's ever want in her entire"],[1455,1601,"life is to see me get married."],[1659,1718,"What if."],[1718,1843,"What if I'm not the woman"],[1843,2039,"she sees you with."],[2039,2177,"I feel like no matter what"],[2177,2310,"she's going to like you."],[3403,3499,"Oh my God."],[3591,3762,"Oh, you."],[3908,4062,"My daughter was taken"],[4062,4225,"from the hospital, I think."],[4316,4471,"I think you're her?"],[4546,4829,"Oh. No,"],[4934,5084,"that's not possible."],[5084,5221,"My mom's been gone"],[5221,5317,"for a long time."],[5613,5780,"You'll be the one bleeding."],[5901,6147,"Besides, you're not my real daughter,"],[6256,6327,"you're not even"],[6327,6427,"your mother's daughter."],[6427,6602,"No one cares about you."],[6690,6861,"Did my mom"],[6861,7032,"meant to tell me that I was adopted?"],[7240,7336,"You have a"],[7336,7490,"heart shaped birthmark"],[7490,7636,"on your back, right?"],[8045,8299,"Thanks God, I think I've found you."]],"56":[[246,575,"Oh! Oh"],[654,767,"My dear."],[867,1209,"I truly, I want you both to be happy."],[1501,1797,"Natasha,"],[1843,1964,"I want to spend the rest of my life"],[1964,2060,"with you."],[2085,2152,"Oh."],[2394,2494,"Will you marry me?"],[3078,3378,"Oh, and I need to get better fast."],[3378,3599,"I can make it to your wedding."],[3816,3899,"Mom."],[3912,4133,"Oh."],[4562,4662,"Wow."],[4662,4938,"What a touching proposal scene,"],[5038,5205,"And you already calling her mom?"],[5205,5359,"You're really eager."],[5409,5530,"Who? Who are you?"],[5588,5718,"I'm Jaxon Astor,"],[5784,5955,"Natasha's husband."],[5997,6231,"Jaxon, we've been divorced for a while."],[6231,6452,"Stop trying to make a scene here."],[6539,6715,"Divorced?"],[6715,6835,"Well,"],[6886,6990,"I didn't signed it."],[7007,7052,"What?"],[7357,7440,"What's."],[7453,7565,"What's going on?"],[7611,7782,"Oh, please, let me explain."],[7803,8016,"Your son has been interfering"],[8016,8133,"with my marriages."],[8191,8262,"No."],[8287,8516,"No way. I raised him."],[8516,8708,"He would never do that."],[9142,9250,"Maria,"],[9250,9351,"are you okay?"]],"57":[[112,287,"Maria, are you okay?"],[287,375,"Nurse!"],[375,529,"Nurse, we need a nurse in here."],[1226,1405,"We're done, Jaxon."],[1405,1543,"The moment you started hurting"],[1543,1701,"my people, we're done."],[2060,2185,"We're getting married."],[2348,2527,"Stay out of my life."],[2590,2711,"Jaxon, why do you have to"],[2711,2869,"take everything from me?"],[2961,3136,"My mother is dead."],[3136,3265,"I lost my baby,"],[3265,3474,"and I finally found my birth mother."],[3611,3812,"Yet you still hurt me like this."],[3887,3933,"God."],[3962,4020,"Jaxon."],[4020,4154,"What do you want from me?"],[4279,4416,"Just let me go!"],[4608,4729,"It’s okay."],[4729,4909,"I just wanted to say sorry..."],[4934,5067,"how’d it end up like this?"],[5100,5226,"I screwed up again..."],[5935,6022,"Grandpa, I was wrong"],[6022,6114,"about Natasha."],[6131,6272,"You finally get it."],[6423,6573,"I supported your marriage to"],[6573,6823,"Natasha because I saw how much"],[6823,6961,"she truly loved you."],[6961,7090,"Unlike Isabella,"],[7090,7261,"who was just clinging to you."],[7261,7453,"I paid Natasha's mother's"],[7453,7561,"medical bills."],[7582,7820,"And to avoid her refusing"],[7820,7924,"my kindness,"],[7949,8141,"I framed it as a contract marriage."],[8166,8370,"I regret it now, boy."],[8370,8420,"So,"],[8562,8829,"she wasn't after power and fame."],[8829,9000,"She's a good girl."],[9067,9209,"I was too selfish,"],[9230,9330,"thinking she could be"],[9330,9471,"perfect wife for you."],[9592,9663,"I'll fix this."],[9718,9901,"Natasha is the only girl for me."],[9901,10005,"It's too late."],[10005,10139,"Sign the papers"],[10164,10318,"and don't hurt her anymore."]],"58":[[679,850,"I asked a specialist to treat Maria,"],[850,967,"and she's now out of danger."],[1030,1109,"Thanks."],[1222,1363,"Can we start over?"],[1443,1584,"It's too late, Jaxon."],[2043,2122,"I promised your mom"],[2122,2248,"that I'd make you happy."],[2310,2452,"I'm sorry I failed."],[2452,2615,"I hope Oliver brings you joy."],[2665,2815,"I agree to a divorce."],[5388,5622,"Jaxon, are we really over?"],[6331,6527,"I just wanted to apologize in person."]],"59":[[771,959,"It's that Natasha."],[959,1188,"Wow. She looks stunning!"],[1188,1501,"And that jewelry is gorgeous!"],[1501,1659,"But why are the Hendersons"],[1659,1818,"giving her so much attention?"],[1818,1968,"I'm not sure,"],[1968,2043,"but she's standing right"],[2043,2152,"next to Mr. Henderson."],[2202,2360,"They look great together."],[2360,2481,"Yeah."],[3165,3303,"Mrs. Henderson,"],[3303,3549,"I deeply apologize for my actions"],[3549,3678,"at the hospital last time."],[3712,3787,"It was very rude,"],[3787,3924,"and I truly regret it."],[3953,4016,"Well."],[4104,4183,"Thank you."],[4183,4300,"The specialist"],[4300,4546,"and I have heard"],[4546,4813,"all about you and Natasha,"],[4946,5067,"but I'm sorry."],[5067,5213,"That is over now."],[5626,5709,"Natasha,"],[5768,5876,"I heard you landed"],[5876,6143,"Oliver and the Henderson fortune."],[6202,6389,"I'm so happy for you"],[6460,6623,"and I'm grateful"],[6623,6810,"that you bagged another rich guy"],[6810,6927,"and kicked Jaxon to the curb."],[7111,7449,"Money's still your game, right?"],[7507,7782,"So Natasha is just a gold digger."],[7816,7987,"Don't listen to this garbage."],[8003,8149,"Natasha is the heir"],[8149,8279,"of the Henderson family."],[8329,8504,"She still needs to steal men"],[8504,8583,"for money?"],[8583,8616,"Please."]],"60":[[25,100,"Wait."],[154,354,"Natasha, is the Henderson heir?"],[525,650,"I didn't send you away"],[650,775,"when you were sick."],[775,955,"Not for you to test my patience again."],[955,1188,"You're blaming me for this gold digger?"],[1188,1368,"I saved your life, remember?"],[1368,1651,"I remember there's no excuse for this."],[1651,1881,"Oh, don't get cocky."],[1881,1997,"Jaxon will be mine!"],[1997,2177,"I'm an independent writer"],[2177,2335,"and a Henderson heir."],[2377,2615,"And you're just a scheming woman"],[2615,2819,"who has to compete for men's attention."],[2873,3123,"I never took you seriously, Isabella."],[3182,3282,"Everyone."],[3282,3561,"We are gathered here to celebrate"],[3561,3778,"my long-lost child,"],[3862,4020,"Natasha."],[4287,4587,"And yes, she is my daughter."],[4654,4875,"So from now on,"],[4909,5209,"anyone who tries to harm her"],[5226,5526,"will answer to the Henderson family."],[5551,5726,"You must have been fooled by her."],[5726,5826,"A liar like Natasha"],[5826,5993,"could never be your daughter."],[6193,6339,"Oh."],[6431,6931,"No one will ever harm her again."],[6931,7073,"Just go."],[7474,7691,"Why did you come to insult Natasha?"],[7691,7895,"I warned you not to target her again."],[7895,8049,"Are you still in love with Natasha?"],[8049,8216,"Yes I am."],[8216,8320,"Even if that bitch"],[8320,8425,"is going to marry someone else."],[8425,8625,"Don't call her that."],[8666,8767,"Everything you do"],[8767,8888,"come back to you."],[9205,9321,"Natasha."],[9321,9388,"Natasha,"],[9388,9572,"loved by the whole world."],[9663,9980,"Let's see you die a miserable death."],[10018,10235,"Come on. Destroy Natasha."]],"61":[[25,112,"Today."],[112,346,"I am so excited"],[479,625,"that the Henderson Group"],[625,763,"has a new member."],[846,1180,"My beautiful daughter Natasha"],[1180,1343,"officially joins"],[1351,1534,"the board of directors."],[2039,2289,"I'm Natasha Henderson."],[2289,2473,"Please,"],[2473,2640,"please, please."],[2640,2736,"I’m your father."],[3144,3411,"I'm Natasha's adoptive father."],[3411,3716,"And I'm asking him to save me."],[3753,4087,"I was sick, I needed money"],[4170,4291,"for treatment."],[4458,4696,"And she wanted to send me to jail!"],[4842,4929,"She's heartless."],[4929,5117,"Look, Natasha is going to lose"],[5117,5230,"her reputation."],[5305,5576,"First of all, you're not sick."],[5576,5885,"Second of all, I only called the police"],[5905,6139,"because you broke into my home,"],[6202,6285,"beat me,"],[6285,6414,"humiliated me,"],[6414,6652,"and threatened me with a knife."]],"62":[[0,179,"What father treats her daughter"],[179,362,"like that, even if she's adopted."],[425,700,"As long as you call me dad, you should support me."],[967,1096,"And give me money."],[1201,1280,"All right."],[1280,1480,"Ever since my mother brought me"],[1480,1634,"into your home, you have done"],[1655,1931,"nothing but beat and scold me."],[1993,2177,"My mother paid for my tuition"],[2177,2281,"and my living expenses"],[2281,2377,"all on her own."],[2448,2523,"She was sick."],[2523,2765,"And you didn't even give her pennies."],[2765,3011,"God didn't even give her pennies"],[3011,3140,"except for scolding her."],[3199,3315,"And the amount of money"],[3315,3486,"I gave you over the years"],[3486,3887,"should be around $10 million."],[3891,4116,"$10 million?"],[4116,4270,"That's more than I've ever made in"],[4270,4400,"my whole life."],[4408,4583,"Natasha is so kind to"],[4583,4708,"her adoptive father."],[4746,5046,"Her adoptive father is like a vampire."],[5059,5255,"I'm lucky that my mother was"],[5255,5372,"supportive of my dreams of"],[5372,5484,"becoming a writer."],[5543,5793,"She took me from the shadows and."],[5793,5968,"And helped me become a writer."],[6072,6348,"And now you want to destroy that?"],[6348,6594,"I won't let you."],[6594,6735,"Over a million people"],[6735,6927,"are watching this live."]],"63":[[20,316,"I'm very, very lucky to have"],[316,525,"so many people support me"],[525,663,"unconditionally."],[663,992,"And now I hope to do the same."],[992,1142,"All the money that"],[1142,1292,"I make from this next film,"],[1330,1430,"I will donate"],[1430,1647,"to build a women's empowerment fund."],[1726,1868,"I hopes that I can"],[1868,2056,"lift young women from their pain"],[2056,2243,"and help them find their worth."],[2431,2498,"Can a murderer"],[2498,2615,"get away with everything?"],[2744,2927,"You think some pretty words"],[2927,3140,"will cover up your dirty past?"],[3219,3432,"This woman stabbed me"],[3432,3545,"in my room"],[3545,3695,"so I couldn't have children anymore."],[3737,3832,"What?"],[3832,4079,"She ruined my life."],[4129,4266,"And she stands up here"],[4266,4429,"and pretends to support women."],[4429,4654,"Nope, I didn't. That was you."],[4767,4921,"You expect me to believe"],[4921,5063,"I stabbed myself"],[5063,5217,"and made myself infertile."],[5259,5442,"Who would buy that lot?"],[5442,5651,"Whoa! Natasha."],[5651,5793,"Liar!"],[5947,6172,"A disgrace to women."],[6172,6393,"Arrest this murderer!"],[6393,6498,"Shut up!"]],"64":[[45,346,"Shut up."],[642,725,"Mr. Aster,"],[725,859,"are you here to battle for your lover"],[859,967,"and artist, Isabella?"],[988,1234,"Natasha is my only love."],[1280,1463,"Natasha was once my wife,"],[1530,1818,"and I fully attest to her character."],[1860,2060,"In his head is the Aster group."],[2106,2268,"I fully support Natasha."],[2339,2577,"And for you, Isabella."],[2631,2794,"Your lies and disgusting"],[2794,2948,"behavior will be exposed today."],[3019,3144,"Show the evidence."],[3541,3762,"Oh. Oh."],[3799,3916,"That's impossible."],[3966,4066,"The surveillance footage"],[4066,4104,"from that day"],[4104,4187,"was lost."],[4254,4421,"Oh, I'm glad you remembered."],[4441,4558,"The recordings were lost,"],[4600,4775,"but you forgot one thing."],[4859,5055,"Deleted recordings can be recovered."],[5075,5288,"I have some more evidence if you'd like to see."],[5288,5447,"Like the video of you and Leyden"],[5492,5672,"plotting against Natasha."],[5730,5847,"The police bribery"],[5847,6006,"or the video"],[6006,6222,"of your conspiracy with that drunkard James."],[6231,6352,"That's crazy."],[6477,6606,"I already called the police."],[6623,6748,"And remember I told you."],[6748,6881,"What you did,"],[6881,6990,"Will come back to you."],[7040,7340,"Oh. Poor Jackson."],[7386,7636,"You always seem to pick the wrong side."],[7811,8058,"Guess why Emily hasn't woken up yet."]],"65":[[179,296,"I drugged her,"],[371,517,"And I'm the only one"],[517,671,"with the antidote."],[796,1017,"Now, if you want your mother"],[1017,1197,"to live, there's only one"],[1197,1338,"thing you can do."],[1355,1488,"Marry me."],[1488,1726,"Why do I have to marry you?"],[1726,1847,"You can't force my love."],[1847,2085,"Jaxon, you're so naive."],[2185,2352,"It's not your love I want."],[2352,2606,"It's your money now."],[2723,2877,"For your mother's sake,"],[2877,3040,"do the right thing."],[3307,3390,"Everyone."],[3390,3465,"Everyone,"],[3465,3670,"there has been a misunderstanding."],[3858,3978,"Jaxon asked her"],[3978,4166,"and I have reached an agreement."],[4208,4325,"He has admitted that the video"],[4325,4425,"footage is fake."],[4512,4813,"Also, we have more good news."],[4888,5063,"We're getting married."],[5121,5205,"Please, everyone,"],[5205,5422,"join us at our wedding."],[5463,5676,"Gosh, this is too dramatic."],[5676,5972,"Well, after all this, you still choose"],[5972,6106,"Isabella."],[6106,6414,"Isabella."],[6414,6585,"I can't believe that"],[6585,6794,"I let you fool me for so long."],[6919,7027,"Mom!"],[7027,7215,"Hello, honey."],[7215,7357,"If your grandfather hadn't"],[7357,7507,"found the antidote in time,"],[7507,7661,"Isabella might perceive"],[7661,7803,"this forever."],[7874,8066,"The police are already on the way,"],[8066,8199,"Isabella."],[8366,8554,"You can't do this to me."]],"66":[[237,271,"Oh."],[271,412,"This is how it's going to be."],[429,571,"Go to hell with me."],[571,696,"No."],[838,963,"Oh, no."],[988,1113,"You're willing to die for her,"],[1146,1247,"and I'll help you."],[1247,1322,"Oh."],[1322,1418,"By the way,"],[1418,1572,"it wasn't me who saved you,"],[1572,1730,"it was Natasha."],[1730,1810,"Oh, no."],[1810,1960,"I paid the price."],[1960,2181,"I found a doctor for her sick mom."],[2243,2414,"In exchange for her silence."],[2631,2731,"Jaxon."],[2731,2844,"Natasha."],[2919,3032,"Oh, fuck."],[3032,3190,"No, no."],[3340,3470,"Why did you do this?"],[3553,3732,"You saved me once."],[3732,3903,"It's my turn to protect you."],[4037,4183,"Don't cry,"],[4183,4325,"I'll be fine."],[5050,5184,"Where's Natasha?"],[5184,5334,"You're awake."],[5334,5476,"She's been caring for you"],[5476,5634,"for the past few days."],[5651,5826,"Today she has some business"],[5826,5951,"to deal with."],[6185,6460,"Your wounds still not fully healed."],[6460,6585,"If I don't find my wife,"],[6585,6735,"there's a wound in my heart"],[6735,6886,"that will never heal."]],"67":[[191,325,"Thank you all for joining"],[325,462,"the Henderson group book launch."],[462,650,"And thank you to Natasha,"],[650,846,"our very talented author."],[1163,1217,"Thank you,"],[1217,1355,"Natasha, for writing such a"],[1355,1501,"a beautiful story."],[1501,1685,"It really restored my faith and love"],[1685,1793,"and gave me the strength"],[1793,1872,"to move forward."],[2047,2348,"Well, thank you for such kind words."],[2348,2523,"That is exactly the message"],[2523,2627,"I was trying to get across."],[2702,2952,"That love can make you brave enough"],[2952,3065,"to start over."],[4266,4400,"Natasha,"],[4466,4575,"will you give me another chance"],[4575,4671,"to start over?"],[5059,5171,"Oliver,"],[5217,5376,"If you, if you want to fight."],[5376,5568,"No, no. I gave up on that."],[5626,5689,"You see that?"],[5689,5784,"They're both willing to die"],[5784,5876,"for each other."],[5997,6118,"They should be together."],[6222,6439,"I'm not asking you to forgive me now, but"],[6594,6806,"I just ask if you give me a chance"],[6806,6906,"to pursue you again."],[6906,6956,"Okay."],[7169,7403,"I'm not sure now's the right time."],[7528,7682,"Did the doctor let you out?"],[8383,8487,"Oh."],[8687,8754,"Jaxon."],[9325,9455,"Jaxon."],[9563,9747,"Are you a God sent to catch me?"],[9813,10068,"It seems your fate is tied to mine forever."],[10468,10573,"Maybe."],[10710,10827,"Maybe it's my fate"],[10827,10952,"to stay in your arms forever."]]}