{"1":[[638,779,"Tonight's the night, Shay."],[930,1063,"You're finally ready"],[1063,1234,"to lose your virginity to Dean."],[1313,1614,"Your first time is going to be special."],[1676,1764,"Perfect."],[1872,1981,"You want him,"],[2010,2139,"and believe it or not,"],[2198,2310,"he wants you too."],[2515,2606,"I'm ready, Dean."],[2606,2686,"Let's go all the-"],[2756,2831,"Shay!"],[3716,3820,"I thought you were working."],[3853,3999,"I took off to surprise you."],[4154,4237,"Who the hell are you?"],[4237,4446,"I don't think that's any of your business."],[4446,4558,"Well, that's my boyfriend's dick"],[4558,4629,"you're sucking."],[4742,4888,"I guess ex-boyfriend now."],[4971,5150,"Oh, sweetheart, don't be salty."],[5918,6068,"Oh, look at you."],[6135,6343,"Like a little child playing dress up."],[6418,6581,"You see, men have needs."],[6673,6827,"And those needs can't be met"],[6827,7061,"by some, flat-chested"],[7061,7228,"little virgin."],[7315,7403,"You told her?"],[7511,7653,"How could you do this to me?"],[7691,7803,"You can't blame me, Shay."],[7862,7945,"I mean,"],[8008,8166,"look how sexy she is."],[8262,8375,"Couldn't keep my hands off her."],[8612,8787,"I've never felt that way about you."],[8879,9096,"I told you I wanted my first time"],[9096,9184,"to be special."],[9246,9451,"I let you leech off of me for months"],[9451,9630,"because I thought you loved me."],[9734,9859,"I thought you would wait for me."],[9914,10022,"You weren't worth waiting for."],[10251,10343,"It's no big deal, babe."],[10452,10514,"We can-"],[10564,10689,"Don't touch me!"],[10935,11069,"We're over, Dean."],[11457,11544,"Idiot!"],[11569,11703,"You can't let her get away,"],[11703,11899,"that's gonna ruin our plans."],[11932,12012,"Don't worry."],[12057,12145,"I'll get her."],[12616,12687,"Yeah you will."],[13021,13121,"How could I let him"],[13121,13242,"take advantage of me?"],[13288,13438,"How could I let myself believe"],[13438,13592,"anyone would want a girl like me?"],[13659,13709,"They're right."],[13742,13863,"I'm not sexy."],[13888,13976,"I'm stupid."],[13976,14068,"I'm pathetic."],[14084,14130,"I'm..."],[15094,15277,"I can see our whole future together."],[15774,15865,"She's..."],[15995,16078,"my mate."],[16345,16437,"But she's..."],[16558,16629,"a human."]],"2":[[141,258,"Who is this man?"],[337,496,"And why is he sniffing me?"],[588,679,"You're my mate."],[934,1017,"Excuse me?"],[1088,1213,"Didn't she see our bond?"],[1288,1380,"Didn't she feel it?"],[1413,1522,"I'm not in the mood"],[1522,1730,"to deal with another cocky asshole."],[1830,2031,"Oh God, but he's so hot."],[2118,2289,"I'm not your anything."],[2323,2373,"Okay?"],[2414,2523,"Just please leave me alone."],[3407,3586,"He just... vanished."],[5259,5326,"Easy."],[5409,5484,"Don't come closer."],[9221,9280,"You..."],[9330,9426,"you protected me."],[9534,9701,"I feel drawn to him."],[10489,10589,"This feels like something"],[10589,10748,"out of a fairy tale."],[11344,11398,"It's her."],[11511,11628,"The one I was meant to find."],[11761,11820,"The one"],[11907,12028,"that will break my curse."]],"3":[[1605,1743,"Hey, bestie."],[1764,1839,"Nikki..."],[1935,2102,"Oh my God, my life is over."],[2160,2264,"Dean cheated on me, and"],[2298,2469,"I almost got attacked by a wolf."],[2469,2577,"And I don't know where to go"],[2577,2656,"or what to do."],[2681,2773,"Whoa, whoa, whoa, whoa."],[2773,2836,"Slow down."],[2869,3007,"You're already crashing at my place."],[3032,3098,"You can stay here"],[3098,3228,"until you get back on your feet."],[3294,3411,"In the meantime,"],[3432,3586,"we'll go somewhere fun tonight."],[3611,3745,"Get your mind off of things."],[3770,3862,"Okay."],[3891,3958,"Thank God I have you"],[3958,4037,"looking out for me."],[4079,4220,"You would never betray me like Dean."],[4258,4333,"Thank you."],[4850,5196,"How did that weak, human bitch"],[5196,5422,"survive your wolf attack?"],[5451,5513,"It was him."],[5597,5730,"The Alpha."],[5730,5814,"He protected her."],[5814,6056,"I cursed that Alpha for killing my father"],[6056,6252,"and breaking my sister's heart."],[6310,6468,"If he marks Shay as his true mate..."],[6589,6706,"It’ll all be for nothing."],[6886,7215,"You stupid, useless rogue."],[7269,7436,"You were supposed to take her virginity."],[7511,7678,"You were supposed to mark her"],[7678,7895,"and ruin her for the Alpha!"],[7966,8070,"I'm sorry."],[8504,8558,"No matter."],[8654,8708,"I'll take her"],[8708,8946,"to the seediest shifter bar in town"],[8992,9171,"and have her ravaged"],[9171,9342,"by the roughest wolves"],[9342,9442,"in these packlands."],[9530,9647,"Whatever happens,"],[9772,9951,"she must stay away from the Alpha."]],"4":[[1409,1547,"What the hell is a human doing"],[1547,1664,"at a shifter bar?"],[1680,1751,"Don't know."],[1780,2002,"But she looks like a delicious snack"],[2002,2077,"to me."],[2243,2318,"Cheers."],[2348,2535,"To new horizons."],[2548,2656,"I'll drink to that."],[3332,3503,"You know, I'm done waiting for"],[3503,3670,"some fairy tale romance."],[3716,3858,"I'm gonna sleep with the first guy"],[3858,3991,"who buys me a drink tonight."],[4362,4487,"That's just what I wanted."],[4838,4979,"These creeps will ruin"],[4979,5088,"innocent little Shay."],[7887,7970,"Can I buy you a drink?"]],"5":[[0,116,"Maybe there's a reason"],[116,225,"he found me tonight."],[283,425,"Maybe he's exactly"],[425,596,"what I need to get over Dean."],[809,1009,"You can absolutely buy me a drink."],[1026,1151,"What is the Alpha doing"],[1151,1284,"in a dump like this?"],[1343,1418,"If he and Shay"],[1418,1526,"discover they’re mates,"],[1543,1668,"it will ruin everything."],[1810,1901,"This spell will make him"],[1901,2056,"forget she exists."],[2686,2815,"I don't want you."],[2919,3069,"I was talking to your friend."],[3737,3803,"Hello?"],[3928,4012,"Seriously?"],[4033,4262,"Could you give us some space?"],[4567,4671,"Sorry."],[5442,5634,"I knew he was a cocky asshole."],[5714,5918,"This day couldn't get any worse."],[6456,6606,"What's a little girl like you doing"],[6606,6735,"in a place like this?"],[6881,7052,"Don't you know that wolves like us"],[7052,7182,"will eat you alive?"]],"6":[[16,116,"I was just leaving."],[150,312,"My friend's waiting for me inside."],[492,571,"Your friend’s busy."],[600,696,"You're all alone."],[742,821,"Luckily for you,"],[821,967,"we know how to take care of a woman."],[1138,1251,"You wanna take turns?"],[1288,1413,"She has a pretty mouth."],[1438,1597,"I bet she can take us both."],[1630,1747,"Stay back, asshole!"],[1839,1976,"The only thing I'll be doing with my mouth"],[1993,2114,"is screaming bloody murder."],[2177,2302,"Ah, God!"],[2456,2527,"That’s okay..."],[2565,2706,"We like it when you scream."],[3490,3582,"How did I end up here"],[3582,3678,"with this woman?"],[3753,3891,"And where is my mate?"],[4145,4254,"Help!"],[4308,4416,"Stop fighting!"]],"7":[[1092,1138,"Help!"],[1138,1238,"Stop fighting!"],[1238,1326,"If you're a good girl,"],[1326,1434,"we'll make this quick."],[1609,1659,"Bitch!"],[1693,1797,"Now you’re gonna get it!"],[2018,2110,"Don't let her get away!"],[2306,2394,"That's better."],[2394,2502,"That's where you belong."],[4788,4867,"I said,"],[4904,5146,"keep your fucking paws off my mate."]],"8":[[296,375,"Alpha Mal."],[421,575,"We didn't know it was your girl, sir."],[629,763,"We didn't know it was you."],[867,946,"Alpha?"],[992,1076,"His girl?"],[1096,1217,"We swear, we didn't know."],[1580,1818,"Not another word."],[1868,1968,"On your knees."],[2185,2310,"We're so sorry."],[2348,2460,"Please show mercy."],[2460,2631,"We'll never cross you again, Alpha."],[2652,2740,"Who is he?"],[2798,2973,"And why are they so afraid of him?"],[3119,3186,"I said,"],[3282,3536,"not another word."],[4124,4229,"If you two think about"],[4229,4337,"touching her again,"],[4366,4483,"you're dead."],[6189,6247,"Are you hurt?"],[6277,6339,"Just say the word"],[6339,6435,"and I'll kill them in a second."],[6473,6531,"Kill them?"],[6598,6677,"Are you insane?"],[6798,6936,"She's... human."],[7094,7273,"She has no idea I'm the Alpha."],[7307,7444,"If you knew who I was,"],[7532,7661,"or how those men could hurt you,"],[7799,7924,"you'd be thanking me right now."],[8233,8429,"Thank you very much, but..."],[8466,8571,"If I may remind you,"],[8571,8733,"just ten minutes ago,"],[8733,8888,"you chose my friend over me."],[8983,9063,"Awe."],[9180,9259,"Are you jealous?"],[9388,9501,"I meant to buy a drink for you"],[9501,9597,"instead of her but,"],[9676,9784,"I don't know what got over me."],[9914,10043,"Let gonna make it up to you."],[10623,10677,"Do you think"],[10677,10814,"I'm just some..."],[10814,10940,"helpless little girl"],[10940,11102,"who you can reject"],[11102,11357,"and then butter back up with this hero act"],[11357,11498,"so I can fall into your arms"],[11498,11578,"and beg you to"],[11578,11657,"take me home-"],[12670,12737,"I'll..."],[12825,12917,"I'll take you home."],[13150,13200,"But..."],[13246,13388,"I won't promise you won't beg."]],"9":[[104,200,"What makes you so sure"],[200,308,"I want to go home with you?"],[396,542,"I can smell it all over you."],[633,713,"Admit it."],[763,880,"I shouldn't want him."],[955,1080,"I don't even know him."],[1180,1347,"But I can't help it."],[1434,1601,"Admit, it."],[1739,1789,"I..."],[1947,1997,"I..."],[2085,2152,"want you..."],[7699,7811,"What am I doing?"],[7903,8087,"Is my first time really gonna be"],[8087,8345,"in a bar bathroom with a total stranger?"],[8833,8892,"Shay?"],[8946,9034,"Are you in there?"],[9138,9213,"Shay?"],[9242,9313,"Come out."],[9396,9451,"I'm sorry."],[9451,9626,"That's my friend."],[9851,9951,"She sounds worried."],[9951,10055,"I should probably..."],[10055,10135,"Do you want to?"],[10389,10502,"I just met you..."],[10848,10981,"You have five seconds."],[11098,11161,"What?"],[11173,11244,"If you don't leave"],[11244,11411,"then I won't be able to control myself."],[11565,11653,"Four..."],[11891,11953,"Three..."],[12037,12241,"Why is it so hard to resist him?"],[12278,12387,"Wake up, Shay."],[12404,12487,"Two..."],[13013,13175,"How does she not know she's my mate?"]],"10":[[358,433,"What the hell?"],[496,625,"I've been looking everywhere for you."],[679,734,"Let's go."],[775,900,"Tell me you didn't just fuck that guy"],[900,1026,"from earlier in the bathroom."],[1188,1297,"I've done everything I can"],[1297,1451,"to keep her away from the Alpha."],[1522,1705,"If they sleep together and he marks her,"],[1726,1835,"then my plan to destroy him"],[1835,1947,"is ruined."],[1947,2018,"God, no."],[2060,2218,"Talking to him was a mistake."],[2289,2348,"Good."],[2419,2535,"Now, to make sure"],[2535,2660,"she never sees him again."],[2690,2848,"I've heard people here gossiping."],[2907,3136,"Apparently that guy is a total man whore."],[3136,3390,"I'd stay very far away from him."],[3395,3632,"Besides, you wanted your first time"],[3632,3737,"to be special."],[3737,3812,"Remember?"],[3862,4145,"Not with some rando in a public bathroom."],[4304,4437,"I knew he was just trying to"],[4437,4546,"get me into bed."],[4696,4867,"But why did I want him so bad?"],[4913,5084,"Yeah, you're right."],[5121,5246,"At least this broke bitch"],[5246,5422,"is already crashing at my place."],[5463,5622,"I can keep a close eye on her."],[5655,5747,"And make sure she stays"],[5747,5897,"far away from the Alpha."],[5951,6043,"Aw..."],[6823,6877,"I’ll..."],[6952,7052,"I'll pick up some ice cream"],[7052,7169,"and, and meet you at home?"],[7198,7253,"Okay."],[8654,8737,"Those men at the bar"],[8737,8904,"were supposed to take care of Shay!"],[9117,9321,"That bastard Alpha got in the way."],[9346,9409,"Again!"],[9526,9667,"Their bond is so strong"],[9667,9751,"I can already feel them"],[9751,9880,"breaking through my magic."],[9905,10039,"You need to get down"],[10039,10264,"on your hands and knees,"],[10264,10564,"and beg for her forgiveness."],[10618,10789,"You need to get her into bed."],[10819,10973,"You need to take her virginity."],[10990,11182,"And you need to mark her"],[11182,11394,"before the Alpha does."]],"11":[[4,187,"And you need to mark her"],[187,408,"before the Alpha does."],[563,633,"I will,"],[725,788,"Davina."],[896,996,"I promise."],[1051,1167,"But in the meantime,"],[1238,1368,"you promised you would..."],[1476,1589,"satisfy me."],[2198,2289,"You want me?"],[3136,3357,"Only good boys get lollipops."],[3720,3874,"Take care of Shay."],[3920,4058,"Ruin her"],[4058,4179,"for the Alpha."],[4208,4270,"Or else..."],[8149,8266,"It was just a dream."],[8341,8533,"Oh my God, what is happening to me?"],[9642,9793,"And your dream was..."],[9843,9939,"intense."]],"12":[[41,187,"And your dream was..."],[241,316,"intense."],[417,525,"What are you doing in here?"],[546,650,"I should scream."],[725,871,"I should be terrified."],[930,1013,"But I feel..."],[1130,1226,"turned on."],[1355,1497,"I haven't stopped thinking about you"],[1497,1630,"ever since the moment we touched."],[1676,1743,"And..."],[1835,1939,"I know you feel the same."],[2731,2911,"I bet you say that to all the girls."],[3395,3465,"If you want me to go,"],[3595,3653,"then..."],[3820,3912,"tell me to go."],[4004,4095,"It's just..."],[4262,4387,"you don't even know my name."],[4483,4575,"I don't know yours."],[4654,4825,"Mal Haywood."],[5063,5188,"I know more than you think..."],[5217,5492,"Shay Santos."],[5930,6010,"Don't, I..."],[6081,6210,"I can't think straight"],[6210,6339,"when you look at me like that."],[6468,6614,"With your hands on me."],[6765,6881,"I wonder why that is."],[6998,7152,"Why your body aches for me."],[7344,7436,"Why you come so hard"],[7436,7515,"when you dream about me?"],[7682,7820,"How... how do you..."],[7836,7916,"I can smell it."],[7970,8074,"I can sense"],[8112,8199,"when you need me."],[8304,8395,"When you want me."],[8504,8600,"Close your eyes."],[8746,8825,"I'll show you."],[10643,10723,"What is this?"],[10773,10865,"You see it, too."],[11040,11294,"You are drawn to me,"],[11294,11428,"as much as I am to you,"],[11473,11544,"Shay."],[11628,11711,"You..."],[11753,11874,"are..."],[11874,11957,"my mate."]],"13":[[25,108,"You"],[150,271,"are"],[271,354,"my mate."],[471,542,"What does that mean?"],[767,838,"Shay?"],[913,1042,"Are you okay in there?"],[1142,1255,"I hear voices."],[1347,1422,"It's my friend."],[1472,1626,"Fine, just..."],[1626,1735,"talking to myself."],[1918,2002,"Let me down."],[2043,2135,"Where are you taking me?"],[2177,2331,"If the alpha is here to claim her"],[2331,2456,"he will break the curse."],[2481,2606,"I can’t let that happen."],[2973,3082,"I don't need to be babysat"],[3082,3203,"by some lackey, you know."],[3203,3336,"I'm not gonna steal anything."],[3420,3478,"Beta."],[3553,3611,"What?"],[3645,3728,"I'm not a lackey."],[3766,3866,"I'm Mal's beta."],[3920,4008,"His right hand man."],[4245,4333,"Send her in."],[4500,4612,"The Alpha will see you now."],[4704,4767,"Alpha?"],[6614,6710,"What are you looking at?"],[6794,6861,"What?"],[6969,7027,"Nothing."],[7098,7223,"I can sense your blood pumping."],[7328,7403,"The heat..."],[7536,7640,"between your legs."]],"14":[[479,538,"How?"],[679,800,"Can you read my mind?"],[996,1105,"You're my mate, Shay."],[1343,1472,"You're gonna have to get used to it."],[1568,1634,"Mate?"],[1872,1972,"Is that like..."],[2060,2160,"a girlfriend,"],[2252,2335,"or a wife?"],[2435,2544,"Something like that."],[2631,2819,"Once a wolf shifter and his mate"],[2819,2944,"consummate their marriage"],[2944,3036,"and he marks her,"],[3119,3186,"their bond..."],[3307,3415,"can never be broken."],[3507,3578,"Just,"],[3770,3887,"a small bite,"],[3924,4066,"right..."],[4179,4266,"here."],[4692,4775,"I'm sorry,"],[4792,4929,"did you say..."],[4929,5046,"wolf shifter?"],[5163,5326,"I thought that was just fairy tale."],[5513,5759,"I am the Alpha of the Tamarack Pack."],[5851,5985,"And this is very much real."],[6101,6185,"And you..."],[6272,6468,"are very much my mate."],[6598,6648,"But..."],[6740,6823,"why me?"],[6961,7052,"I'm human."],[7140,7340,"I don't know you or your world."],[7415,7469,"You’re..."],[7553,7632,"an Alpha."],[7716,7828,"And I'm just a girl."],[7857,8033,"It's unusual for a wolf"],[8033,8145,"to have a human mate,"],[8145,8337,"but not impossible."],[8470,8533,"Of course..."],[8629,8775,"you will have to accept me."],[8917,9000,"Just admit to me."],[9109,9250,"Is he talking about..."],[9313,9396,"sex?"],[9459,9526,"Oh God,"],[9526,9655,"He doesn't know I'm a virgin."],[9809,9947,"What happens if I don't"],[9947,10114,"accept you as my mate?"],[10147,10222,"Shay..."],[10368,10443,"I'm cursed."],[10598,10706,"If you reject me,"],[10769,10860,"I’ll die."]],"15":[[16,95,"Die?"],[713,825,"Do you see this tattoo?"],[1034,1242,"It's the mark of a witch's curse."],[1430,1618,"This witch, Davina,"],[1672,1814,"she said that if I don't find"],[1814,2068,"and mark my mate by my 30th birthday,"],[2106,2310,"I will die."],[2727,2886,"What did you do to deserve that?"],[2898,3073,"A good Alpha isn't afraid"],[3073,3278,"to make enemies to protect his pack."],[3478,3636,"Even my own father"],[3636,3832,"was murdered by someone he trusted,"],[3858,3995,"by someone he considered a friend."],[4062,4241,"I just hope I don't meet the same fate."],[4262,4346,"But you will."],[4400,4592,"Unless I sleep with you"],[4592,4771,"and let you mark me as your mate."],[4792,4892,"There's one more thing."],[5080,5226,"I will also need to impregnate you"],[5226,5296,"with my pup."],[5338,5480,"You want me to have your baby?"]],"16":[[16,171,"You want me to have your baby?"],[396,533,"Shay, it's part of the curse."],[592,725,"And you're carrying my pup,"],[779,934,"this tattoo will disappear"],[934,1067,"and the curse will be broken."],[1151,1222,"But I need to do it"],[1222,1359,"before my 30th birthday."],[1418,1497,"And when is that?"],[1735,1835,"Two weeks from today."],[1835,1926,"Oh my God."],[2110,2218,"This is crazy."],[2369,2448,"This is too much."],[2448,2494,"I..."],[2552,2648,"This can't be real."],[2690,2777,"This can't be real."],[2777,2873,"You saw our mate bond."],[2923,3094,"Shay, you... you felt it."],[3161,3282,"I don't know what I saw."],[3403,3649,"I mean, you could just be tricking me"],[3649,3774,"into sleeping with you."],[3891,3978,"Shay."],[4024,4141,"I would never."],[4166,4270,"I don't know you."],[4458,4596,"I don't know what to believe."],[4838,4946,"Then believe this."],[5634,5722,"It was him."],[6118,6352,"He was the wolf who saved me."]],"17":[[638,738,"Now you believe me?"],[950,1138,"He is an Alpha wolf."],[1213,1447,"A very well-endowed Alpha wolf."],[2285,2477,"It's okay to give in to your desires."],[2673,2781,"I won't mark you,"],[2877,3098,"until you feel the same way that I do."],[3240,3340,"I won't mark you,"],[3386,3582,"until you, are,"],[3632,3745,"in love..."],[3774,3841,"with me."],[3941,4145,"Did he just say he loves me?"],[4308,4425,"I'm sorry, Mal."],[4521,4629,"I don't know how I feel."],[5442,5509,"Zaid."],[5588,5689,"She's the one."],[5709,5768,"Mal."],[5855,6043,"I haven't seen you this far gone before."],[6126,6202,"Not since..."],[6360,6473,"You know how that ended."],[6539,6598,"Zaid."],[6598,6719,"She's nothing like her."],[6735,6848,"She's my true mate."],[6948,7082,"I can feel it."],[7082,7203,"She’s a human..."],[7228,7407,"Alright, the elders won't like it."],[7449,7661,"Leading the pack with a human Luna..."],[7728,7857,"won't be easy."],[8229,8354,"I won't be able to lead the pack"],[8354,8420,"if I’m dead."],[8541,8742,"I need to bring Shay into our world,"],[8742,8825,"Zaid."],[8875,9046,"We have to get our pack to trust her."],[9192,9296,"I need to break this curse."],[9392,9442,"But..."],[9592,9684,"I need Shay."],[10752,10873,"What the hell are you doing in my house?"]],"18":[[33,162,"What the hell are you doing in my house?"],[162,291,"I wanted to do something special"],[291,383,"to make it up to you,"],[383,500,"so Nikki let me in."],[746,892,"She believes in us, Shay."],[938,1001,"Why don't you?"],[1046,1192,"Why would my best friend"],[1192,1347,"let in my cheating ex?"],[1388,1551,"Is no one on my side?"],[1551,1630,"It's too late."],[1672,1793,"We're done, Dean."],[1868,1939,"Now get out."],[1939,1985,"No."],[2039,2127,"Have dinner with me."],[2210,2302,"Let me explain."],[2360,2448,"You're not gonna really throw away"],[2448,2552,"our whole relationship"],[2552,2631,"over a little..."],[2702,2844,"blowy, are you?"],[2865,2977,"You're kidding, right?"],[3098,3203,"I can't believe I fell for"],[3203,3336,"all your idiotic bullshit"],[3336,3461,"for as long as I did, but..."],[3561,3712,"I'm finally coming to my senses."],[4375,4512,"I said, out!"],[5055,5096,"I'll come back"],[5096,5205,"when you're not on your period,"],[5271,5330,"bitch."],[5501,5605,"Don't come back at all..."],[5638,5709,"asshole."],[6227,6343,"What did you just call me?"],[6418,6498,"You heard me."],[7082,7240,"You women are all the same."],[7278,7403,"You play such perfect,"],[7403,7549,"innocent little fucking prudes,"],[7549,7632,"but I know better."],[7649,7741,"I know you want me."],[7791,7978,"I bet you like it rough and dirty, huh?"],[8191,8283,"Don't cry, Shay."],[8358,8425,"I'm gonna give you"],[8425,8600,"the first time you always dreamed of."]],"19":[[583,800,"Get your hands off my mate."],[1368,1472,"Who the hell are you?"],[1526,1626,"A better man."],[1747,1910,"One who actually deserves Shay."],[3144,3211,"And you..."],[3282,3545,"You ugly, cowardly,"],[3545,3695,"leech."],[3766,3924,"Too scared to fight me, but..."],[3991,4104,"you’ll put your hands"],[4104,4270,"on a beautiful, strong woman"],[4270,4375,"who loved you."],[4621,4808,"You disgust me!"],[5138,5255,"The hell are you doing?"],[5255,5380,"Teaching you a lesson."],[5380,5472,"He's all yours."],[5851,5997,"This is for cheating on me,"],[6064,6139,"lying to me,"],[6206,6293,"and harassing me."],[6956,7032,"You're a wolf?"],[7052,7349,"Of course I am, you stupid fucking bitch."],[7365,7474,"Oh, you're a dead man."],[7957,8008,"Mal!"],[8062,8124,"Mal, stop!"],[8124,8204,"You're killing him!"]],"20":[[145,204,"Mal, stop!"],[204,296,"You're killing him!"],[342,513,"I'm trying to earn Shay's trust,"],[529,633,"not scare her."],[821,875,"Leave."],[930,1096,"If I see you in the packlands again,"],[1096,1167,"you're dead."],[2043,2110,"Are you okay?"],[2185,2252,"Yeah."],[2281,2414,"Why didn't you tell me your ex is a wolf?"],[2464,2531,"I didn't know."],[2565,2635,"I swear."],[3303,3374,"Did he hurt you?"],[3432,3490,"I'm okay."],[3607,3724,"I'm glad you came here, Mal."],[3891,3966,"I made a mistake"],[3966,4070,"walking away from you."],[4212,4379,"I don't want to break our mate bond."],[4558,4692,"I don't want you to be cursed."],[4954,5042,"Did he mark you?"],[5230,5280,"What?"],[5342,5434,"Did he bite your neck?"],[5501,5584,"Did he claim you?"],[5668,5768,"Because if he did,"],[6018,6101,"then I'm dead."]],"21":[[29,125,"Did he claim you?"],[221,300,"If he did,"],[446,542,"then I'm dead."],[567,621,"No."],[658,754,"No, he didn't."],[775,863,"How could he?"],[884,1030,"We've never even slept together."],[1276,1405,"What do you mean you'd be dead?"],[1526,1676,"This witch, Davina,"],[1693,1768,"she said that"],[1768,1960,"if I don't find and mark my mate"],[1960,2089,"by my 30th birthday,"],[2127,2323,"I will die."],[2410,2552,"Two wolves can't mark you."],[2615,2798,"If Dean claimed you,"],[2861,2961,"then,"],[3023,3148,"it would destroy our mate bond."],[3182,3340,"I would never be able to break the curse."],[3357,3490,"I don't want that to happen."],[3682,3753,"Oh, Shay..."],[4016,4187,"I am so sorry for scaring you."],[4371,4437,"When Dean..."],[4487,4575,"when he was hurting you,"],[4729,4833,"I lost it."],[4884,4950,"Because you thought"],[4950,5038,"you were gonna die."],[5130,5180,"No."],[5284,5363,"Shay..."],[5459,5555,"when it comes to you,"],[5638,5914,"it is so hard for me to keep control."]],"22":[[20,120,"When you're in danger,"],[120,241,"when you need me?"],[333,692,"I will do anything to help you,"],[692,792,"to be closer to you."],[934,1026,"Not fair."],[1067,1176,"I can't hide from you."],[1255,1434,"Shay, that night at the bar..."],[1497,1630,"When I yelled at you,"],[1630,1764,"I knew you wanted me,"],[1764,2102,"and that turned me on so much."],[2152,2268,"I couldn't see straight."],[2456,2590,"I know what that feels like."],[5380,5584,"I can smell that dirtbag all over you."],[5714,5847,"Let me wash it off."],[5901,5943,"Yeah."]],"23":[[800,859,"Better?"],[2848,3032,"If I keep kissing you like that,"],[3111,3261,"it will be impossible to stop."],[3532,3678,"Maybe I don't want you to stop."],[4129,4187,"Shay?"],[4270,4337,"Come out."]],"24":[[29,104,"Shay?"],[191,287,"What happened in here?"],[354,467,"What am I gonna tell Nikki?"],[487,613,"We wrecked her house."],[663,767,"Not the truth."],[813,921,"She can't know I’m a wolf."],[1526,1643,"Thank God you're okay."],[1685,1793,"I thought someone broke in."],[1889,2139,"No! No, I was just..."],[2139,2239,"redecorating."],[2498,2660,"What is Alpha Mal doing here?"],[2694,2844,"If he marks Shay as his mate,"],[2882,3007,"then the curse I put on him"],[3007,3094,"will be broken."],[3199,3261,"Shay,"],[3336,3528,"it's not safe for him to be here."],[3578,3661,"He needs to go."],[3695,3782,"I agree."],[3824,3995,"Shay, I think you should"],[3995,4066,"come with me."],[4087,4166,"Are you kidding?"],[4166,4320,"That guy's a total fuckboy."],[4450,4517,"Well, you're a dumbass"],[4517,4596,"if you're forgetting"],[4596,4725,"what he did to you at the bar."]],"25":[[154,275,"I thought..."],[312,408,"that you were in love with Dean."],[483,579,"He loves you too!"],[592,754,"I told him to come here,"],[754,809,"and tell you that."],[809,846,"Yeah, well,"],[846,988,"he assaulted me instead."],[1121,1247,"Look, if you were really my friend,"],[1247,1292,"you would see that"],[1292,1422,"Mal is a better man for me."],[1472,1551,"He protects me,"],[