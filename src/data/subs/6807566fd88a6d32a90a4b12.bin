mad?"],[2531,2631,"I'm just disappointed"],[2631,2706,"that you didn't trust me"],[2706,2765,"and tell me sooner."],[2919,3078,"Dean promised me he would wait,"],[3078,3165,"and then he-"],[3620,3753,"You are my mate."],[3841,4037,"I will never betray you"],[4037,4141,"like your cheating ex."],[4295,4479,"I guess I was also a little nervous."],[4650,4742,"You're an Alpha"],[4742,4959,"and I'm not very experienced."],[5180,5271,"You could've fooled me."],[5380,5459,"You know,"],[5638,5734,"I kind of love that"],[5734,5826,"no man has ever made you"],[5826,5905,"come before."],[6006,6168,"But, I told you, Shay,"],[6277,6368,"I'm not gonna push you."],[6456,6598,"I'm not gonna mate you"],[6639,6998,"until you fall in love with me."]],"35":[[112,262,"I'm falling for you, Mal."],[462,583,"I'm ready to go all the way,"],[654,825,"ready for you to mark me tonight."],[1359,1609,"I can't wait for you to be my Luna."],[1609,1726,"The mother of my pup."],[1847,1926,"Go get ready."],[1976,2097,"I'll make sure that"],[2097,2206,"Freya and Zaid are gone."],[2369,2444,"Then..."],[2460,2831,"I'm gonna claim you in every room"],[2919,3028,"of this house."],[5776,5897,"Aren’t you gonna welcome your"],[5897,6010,"true Luna home?"]],"36":[[200,325,"Selina, what are you doing here?"],[358,567,"I banished you to the rogue territories."],[592,721,"You threatened to."],[721,975,"But, I left before we could make it official."],[1046,1234,"I'm still a part of this pack."],[1351,1455,"I should have broken our bond"],[1455,1555,"when I had the chance."],[1589,1739,"When your father murdered mine"],[1739,1964,"and started an all-out pack war."],[1964,2210,"Which you ended by spilling my own"],[2210,2352,"father's blood"],[2352,2473,"and breaking my heart."],[2577,2761,"I should have been your Luna, Mal."],[2890,3003,"I love you,"],[3003,3190,"and I've forgiven you"],[3190,3382,"for all the pain that you've caused me."],[3440,3687,"You could make things right again."],[3687,3895,"You could mark me as your Luna"],[3895,4154,"and stay cursed until you die."],[4354,4512,"I haven't forgiven you."],[4537,4713,"You used me to get to my father."],[4792,4942,"You never loved me."],[4942,5113,"And you were never my true mate."],[5180,5367,"You disgust me."],[5455,5551,"Mal?"],[5551,5634,"Is someone here?"],[5851,5993,"It's... It's just us."],[5993,6110,"I'll be up in a minute."],[6197,6368,"She is my true mate."],[6368,6510,"I'll be marking her tonight."],[6510,6652,"And if you don't leave now,"],[6652,6831,"then I'll make sure your pack"],[6831,6956,"will banish you again."]],"37":[[12,112,"What did you give me?"],[162,387,"Oh, a little shot of Wolfsbane."],[387,504,"It’s strong enough to make you lose"],[504,675,"control of your body but,"],[675,921,"weak enough to keep you awake."],[950,1126,"I want you to watch while I torture"],[1126,1297,"your precious little mate."],[1797,2022,"I'm finally going to get the first time"],[2022,2143,"I've always dreamed of."],[2256,2556,"I'm going to lose my virginity to my mate."],[3503,3582,"Mal?"],[4250,4329,"Mal?"],[4441,4567,"Where are you?"],[4621,4700,"I'm ready to-"]],"38":[[8,125,"Get away from my mate!"],[212,316,"I think you mean"],[316,412,"my mate."],[571,654,"Who are you?"],[750,913,"What the hell did you do to him?"],[971,1130,"I wore him out, clearly."],[1163,1267,"That's what happens when"],[1267,1459,"two true mates make love."],[1472,1559,"Not like you would know."],[1609,1747,"I think I know him better than you."],[1747,1881,"I’m his- - Luna?"],[1976,2093,"Yeah, right."],[2252,2410,"Is that human I smell?"],[2540,2761,"A weak little bitch like you would never"],[2761,2898,"be marked by an Alpha."],[2923,2977,"You’re wrong."],[3073,3174,"Then prove it."],[3203,3361,"I don't have to answer to you."],[3591,3682,"I was right."],[3682,3803,"There's no mate mark."],[3958,4154,"Mal has an Alpha sex drive."],[4175,4316,"What makes you think some dumpy"],[4316,4537,"little human prude like you"],[4537,4717,"could keep him satisfied?"],[4721,4892,"Mal wants me."],[4954,5075,"He's waiting for me."],[5075,5271,"He's going to mark me, and only me."],[5271,5326,"Really?"],[5422,5559,"Well then, what's this?"],[5759,5901,"He, he marked you?"],[6018,6089,"But"],[6089,6218,"I saw our mate bond,"],[6218,6314,"I felt it!"],[6314,6410,"Really?"],[6410,6552,"Because Mal’s been begging me"],[6552,6685,"to come back to him."],[6781,6931,"I guess he just needed a"],[6931,7082,"easy backup option."],[7190,7273,"Someone to..."],[7273,7382,"keep our bed warm."],[7461,7549,"You’re lying."],[7820,8012,"When I showed him this,"],[8012,8174,"he forgot about you immediately."],[8525,8633,"That's right."],[8654,8808,"I'm pregnant with Mal’s pup."]],"39":[[325,508,"I can't wait for you to be my Luna."],[529,650,"The mother of my pup."],[763,1026,"He was thrilled when I told him the news."],[1088,1255,"He couldn't keep his hands off me."],[1359,1418,"You're lying."],[1484,1726,"If Selena really is Mal's true mate,"],[1768,1947,"if she's pregnant with his pup,"],[1997,2143,"then the curse will be broken."],[2193,2352,"His tattoo will be gone."],[2389,2623,"Get your slimy little human hands"],[2623,2744,"off of my mate."],[2882,3132,"Shay, I'm trying to come back to you."],[3215,3290,"Mal?"],[3424,3541,"Tell me she's wrong."],[3624,3757,"Tell me you didn't mark her."],[3757,3916,"Tell me she's not having your pup."],[3983,4091,"Shay's in danger."],[4112,4241,"Selena can rip her apart."],[4295,4475,"And if I can't protect her"],[4542,4646,"she has to leave,"],[4646,4688,"now."],[4959,5038,"Shay."],[5142,5192,"Yes?"],[5263,5355,"Yes, I'm here."],[5467,5526,"Go."],[5651,5780,"Leave me with Selena."]],"40":[[70,129,"Go."],[237,371,"Leave me with Selena."],[717,796,"You heard him."],[871,1034,"This pack would never"],[1076,1242,"accept a human Luna."],[1292,1430,"And neither would the Alpha."],[1518,1726,"I'm his true love."],[1793,2006,"I'm the mother of his child."],[2039,2444,"And you, you're just a worthless nobody."],[2569,2723,"Mal needs his true mate"],[2723,2936,"to break the curse and save his life."],[2990,3128,"If that's Selena,"],[3174,3357,"then what am I even doing here?"],[3858,3970,"I'll find you, Shay."],[4016,4137,"I'll make this up to you."],[4487,4675,"Mal knew how much Dean hurt me"],[4675,4750,"when he cheated"],[4750,4896,"and broke his promise to me."],[4942,5109,"How could he do the same thing?"],[5176,5301,"Where will I go now?"],[5451,5701,"I hope my best friend will forgive me."]],"41":[[33,104,"Nikki."],[283,329,"It's me."],[329,396,"I need you."],[454,538,"What happened?"],[654,775,"You were right about Mal."],[804,925,"He doesn't care about me."],[1005,1188,"I should have never trusted him over you."],[1226,1338,"It's okay, bestie."],[1343,1430,"Just come home."],[1480,1584,"I forgive you."],[2352,2473,"That whiny human bitch"],[2473,2644,"fell right into our trap, sister."],[2694,2823,"She'll come crying to me."],[2882,2952,"And I'll drug her"],[2952,3098,"and dump her in Dean's bed."],[3169,3303,"That's what she deserves."],[3324,3386,"Good."],[3403,3536,"While you're finishing her,"],[3657,3791,"I'll take care of the Alpha."]],"42":[[246,421,"I'm not letting this bitch leave"],[421,675,"until I know her Alpha mate is dead."],[1818,1976,"Mal is bad news, Shay."],[2089,2173,"I told you."],[2306,2464,"I'm sorry I didn't listen to you."],[2585,2731,"I thought what we had was real."],[2794,2877,"I saw it."],[2907,3015,"I felt it."],[3186,3324,"But I guess I was wrong."],[3353,3524,"I'm so sorry, bestie."],[4346,4429,"Awe."],[4429,4512,"Come here."],[4763,4900,"You know what was real?"],[5046,5196,"What you had with Dean."]],"43":[[0,108,"He made some mistakes."],[133,271,"But he always cared about you."],[271,375,"What the hell, Nikki?"],[408,508,"I'm not getting back together"],[508,621,"with my cheating ex."],[667,759,"He betrayed me."],[779,888,"He assaulted me."],[971,1080,"Don't you want better for me?"],[1288,1430,"I should have never come back here."],[1430,1534,"This was a mistake."],[1534,1589,"Wait!"],[1655,1772,"I'm sorry, Shay."],[1797,1968,"But where are you gonna go?"],[2018,2210,"You're homeless, broke."],[2256,2406,"You're not even that pretty."],[2414,2560,"Ugly, really."],[2606,2756,"And you don't put out."],[2848,2977,"Who else would want you?"],[3094,3174,"I see why you want me"],[3174,3307,"to get back together with Dean."],[3340,3424,"You're just as much of a"],[3424,3541,"monster as he is."],[3766,3883,"You two can have each other."],[4525,4587,"Mal,"],[4629,4750,"I need you."]],"44":[[58,175,"No, no."],[412,663,"Now that your little human bitch is gone,"],[663,917,"it's time for us to have some fun."],[980,1267,"No, no."],[2264,2381,"Just because you didn't"],[2381,2506,"want to mark me,"],[2610,2819,"doesn't mean that I can't mark you."],[3728,3853,"The Wolfsbane in your system"],[3853,4104,"makes the pain even worse."],[4154,4279,"If you weren't an Alpha,"],[4333,4416,"you would die"],[4416,4604,"from being cut from a silver dagger."],[5234,5455,"Now, I'll sink my teeth into you"],[5455,5563,"and mark you"],[5597,5726,"so that I can ruin you"],[5726,5939,"for your true human mate."],[6068,6135,"And then you'll be cursed"],[6135,6227,"until you’re dead."],[7782,7957,"You lied to my mate."],[8045,8137,"You tortured her."],[8220,8366,"And now you're gonna die."]],"45":[[62,175,"You can't kill me."],[229,371,"The Wolfsbane is too strong."],[404,558,"I have to fight this poison."],[579,738,"I have to break through this"],[738,867,"and save my mate."],[913,1130,"You might not die from a cut"],[1130,1251,"from a silver dagger,"],[1313,1505,"but you'll die from a stab to the heart."],[1572,1847,"It's time to join your dear old dad in hell."],[2777,2898,"Your pitiful scratches"],[2898,3044,"are already starting to heal."],[3165,3311,"Do you still think I'm weak?"],[3311,3349,"No."],[3349,3607,"How dare you lie to my mate?"],[3607,3666,"I didn't. I..."],[3678,3970,"How dare you turn her against me?"],[3970,4074,"I didn't, I didn’t,"],[4074,4154,"I don't..."],[4525,4637,"You told her"],[4637,4796,"you were pregnant with my pup."],[4838,4975,"I never marked you,"],[4992,5125,"I never even slept with you."],[5125,5330,"I wouldn't touch a murderous,"],[5330,5547,"power-hungry traitor like you."],[5547,5747,"I did you a favor, Mal."],[5830,5985,"You can't mate a human."],[6006,6172,"She can't be Luna."],[6210,6281,"I can."],[6322,6452,"I can save your life."],[6535,6694,"I can break the deadly curse."],[6744,6815,"Just let me go."],[6940,7052,"How do you know about the curse?"],[7211,7286,"It was you."],[7357,7419,"You were the one"],[7419,7557,"who sent the witch to curse me."]],"46":[[16,116,"It was you."],[183,229,"You were the one"],[229,362,"who sent the witch to curse me."],[362,479,"No, please."],[525,633,"Don't kill me, please."],[688,838,"What was I supposed to do?"],[909,1076,"You murdered my father."],[1163,1317,"You rejected me."],[1363,1463,"And then you moved on"],[1463,1668,"with some pathetic human."],[1668,1801,"She's not pathetic."],[1910,2052,"Selina, I banished you."],[2085,2198,"Any other Alpha"],[2198,2344,"would have had you executed"],[2344,2464,"for treason and murder"],[2464,2602,"alongside your father."],[2656,2773,"And how do you repay me?"],[2819,2952,"By cursing me."],[2952,3186,"By turning my mate against me."],[3399,3545,"By almost killing me."],[3545,3682,"I didn't curse you."],[3732,3841,"My sister did."],[3862,4004,"And soon the same will happen"],[4004,4070,"with Shay."],[4070,4183,"Davina is your sister."],[4287,4346,"Mal."],[4446,4525,"I need you."],[4583,4692,"What did she do to her?"],[4692,4800,"Your precious little mate"],[4800,4900,"will be marked by another"],[4900,5042,"by the time you get to her."],[5113,5226,"I might not have been able"],[5226,5321,"to kill you tonight,"],[5384,5518,"but the curse will soon."]],"47":[[396,529,"You didn't even hurt me."],[654,813,"You are such a coward, Mal."],[838,925,"And you never deserved"],[925,1013,"to be Alpha."],[1067,1142,"I should have killed you"],[1142,1230,"when I had the chance."],[1534,1626,"You never deserved"],[1626,1772,"to wear my pack's mark,"],[1789,1997,"and you never were my true mate."],[2477,2565,"Pure silver!"],[2840,2952,"I'm not an Alpha."],[3103,3224,"This won't heal."],[3261,3436,"I'll bleed out!"],[3474,3541,"Slowly,"],[3649,3816,"the silver will poison and kill you,"],[3866,4079,"but it will take days."],[4162,4391,"Don't you ever lay a hand on me"],[4391,4500,"or my mate again."]],"48":[[425,538,"I got your distress call."],[596,633,"What's-"],[633,675,"Tie her up."],[675,771,"Don't let her leave."],[788,942,"I need to find my mate now."],[963,1217,"Alpha, don't act rashly here."],[1259,1372,"We can call for backup"],[1405,1514,"and I can help you find her."],[1514,1576,"No."],[1576,1672,"I need to get to her."],[1672,1785,"I need to find her."],[1818,1906,"Are you sure"],[1906,2047,"a human can save you?"],[2085,2306,"Are you sure she's worth all of this?"],[2419,2473,"Zaid,"],[2606,2715,"she's not just a human."],[2756,2902,"And she's worth everything to me."],[3207,3336,"If you try anything else,"],[3336,3516,"you'll get this in the heart."],[4062,4158,"I’m coming, Shay."],[4158,4254,"Just hold on."],[6214,6285,"Nikki?"],[6343,6418,"Is that you?"],[6581,6727,"You're supposed to be my best friend."],[6727,6852,"Why would you do this to me?"],[6869,7023,"Because, bestie..."],[7161,7298,"I’m not really Nikki."],[7545,7620,"It's you!"],[7853,7907,"You're the bitch"],[7907,8045,"who slept with my boyfriend."]],"49":[[75,137,"So..."],[137,271,"this whole time,"],[271,458,"you've just been pretending"],[458,592,"to be my best friend."],[613,779,"A simple glamour spell."],[859,1084,"I couldn't let Mal break my curse,"],[1084,1259,"so I transformed myself"],[1355,1447,"into Nikki,"],[1539,1630,"your bestie."],[1689,1847,"So you let me crash with you,"],[1847,1976,"so you can control me?"],[2097,2214,"This whole time,"],[2214,2331,"you've just been a witch"],[2331,2540,"trying to rip me away from my true mate."],[2581,2681,"What can I say?"],[2790,3019,"It's easy to manipulate a weak,"],[3057,3399,"innocent, broke little human like you."],[3449,3636,"And now you really have nothing."],[3732,3816,"No one."],[3958,4166,"My sister made sure of that."],[4258,4333,"Your sister?"],[4391,4550,"Mal's true mate,"],[4629,4725,"Selina."],[4750,4984,"The one he should have made his Luna."],[5017,5142,"The one who poisoned him"],[5142,5246,"with Wolfsbane"],[5246,5472,"and is currently killing him"],[5547,5638,"as we speak."],[5651,5709,"No."],[5726,5772,"No."],[5772,5922,"Mal, where are you?"],[5922,6047,"Help!"],[6051,6156,"Help!"],[6189,6272,"Help!"],[6289,6364,"Help-"],[6619,6981,"You humans all squeal like little pigs."],[7132,7261,"He's not coming."],[7399,7774,"And even if he did, you'd long be ruined."],[7845,8024,"Already marked by another."]],"50":[[700,838,"Don't be afraid, Shay."],[871,1009,"I'm gonna give you a first time"],[1009,1121,"you'll never forget."],[1368,1659,"So weak, so scared."],[1701,1856,"So sad."],[1876,1947,"I'm gonna enjoy"],[1947,2085,"sinking my teeth in you."],[2189,2344,"And you'll be mine forever."],[2398,2594,"To use however I want."],[2769,2848,"I promise."],[2890,3015,"I'll make it worth the wait."],[3336,3457,"Get off me!"],[3557,3699,"I'm not waiting for you"],[3699,3816,"because I want you."],[3816,3870,"I'm waiting"],[3870,3974,"because I can't stand the thought"],[3974,4062,"of you touching me."],[4062,4133,"You bitch."],[4133,4229,"Hold her legs!"],[4433,4512,"You like that?"],[4592,4733,"No, let me go!"],[4733,4825,"God, your voice is like"],[4825,4963,"nails on a chalkboard."],[4975,5109,"A nice bite to the throat"],[5109,5259,"should shut you right up."],[5918,6035,"Consummate my mark,"],[6035,6252,"and ruin you for the Alpha forever."],[7411,7507,"I told you what would happen"],[7507,7607,"if you touched her again."]],"51":[[0,112,"I told you what would happen"],[112,212,"if you touched her again."],[212,337,"No, please, Alpha"],[337,425,"I promise."],[471,579,"I won't hurt her again."],[579,646,"I won't touch her."],[646,746,"She's yours, I promise."],[746,817,"You're right."],[838,896,"You won't."],[913,1117,"Because you just took your last breath."],[2873,2952,"What are you gonna do?"],[2952,3040,"Kill me?"],[3140,3294,"It won't break the curse."],[3340,3399,"Mal."],[3420,3528,"He bit me..."],[3574,3670,"Dean bit me."],[3712,3791,"Shay!"],[3883,4058,"It's too late to break the curse."],[4099,4183,"Now that your precious"],[4183,4237,"little human"],[4237,4396,"is dying from a wolf bite."],[4662,4758,"You can kill me"],[4842,4954,"or you can save her."],[5000,5113,"The choice is yours."],[5159,5259,"Mal, I need you."],[5259,5326,"It hurts."],[5384,5509,"If this doesn't kill you,"],[5509,5714,"I will rip you apart, limb from limb,"],[5730,5860,"until you rot in hell!"],[5860,5918,"Wait!"],[6368,6427,"Hang on."]],"52":[[779,1009,"Can't I at least just have some water?"],[1038,1130,"Sorry, Selina."],[1188,1301,"I'm to keep an eye on you,"],[1301,1422,"and not get too close."],[1534,1647,"Alpha and Beta's orders."],[1722,1918,"We used to be friends, Frey..."],[2127,2218,"Now you're just treating me"],[2218,2389,"like I'm some dirty criminal."],[2506,2677,"I'm dying slowly."],[2740,2857,"Why can't I at least"],[2857,2990,"just have something to drink?"],[4596,4692,"I don't have hands."],[4871,4979,"Can you help me, please?"],[6147,6206,"Freya!"],[6485,6531,"Hey!"],[6690,6781,"Go to hell."],[7520,7624,"What they did to me..."],[7970,8183,"That bitch and her Alpha are gonna pay."]],"53":[[538,667,"Mal, Mal, it hurts."],[725,829,"I'm so sorry, Shay."],[900,984,"But a wolf's bite"],[984,1117,"is like poison to humans."],[1238,1351,"If I don't mark you..."],[1438,1534,"if you don't drink"],[1576,1668,"the blood of an Alpha"],[1735,1810,"you'll die."],[2193,2252,"Do it."],[2360,2410,"Mark me."],[5588,5676,"Your turn."]],"54":[[2510,2594,"Your wound."],[2748,2840,"It's fully healed."],[2990,3069,"How do you feel?"],[3319,3395,"Strong."],[3520,3607,"Powerful."],[3795,3862,"Like I..."],[3924,4045,"Need you."]],"55":[[642,725,"It's still there."],[775,913,"Selina isn't your true mate."],[1101,1188,"She never was."],[1292,1413,"Whatever she told you tonight..."],[1480,1584,"it was all lies."],[1639,1843,"The only person I marked was you."],[2135,2210,"My true mate."],[3574,3728,"I want you so badly."],[3770,3845,"It hurts."],[4066,4158,"Mal, I..."],[4291,4408,"I'm sorry I left you."],[4550,4654,"I'm sorry I doubted you."],[4758,4904,"I'm sorry that you were hurt."],[4992,5209,"The thought of Dean marking you,"],[5242,5359,"of breaking our bond..."],[5522,5668,"I can't live without you."],[5805,5926,"Not because I'm cursed."],[6010,6064,"But..."],[6189,6327,"because I love you."],[6460,6502,"It feels like"],[6502,6631,"I loved you my whole life."]],"56":[[8,75,"Mal, I..."],[166,266,"I don't know what to say."],[358,479,"You don't have to say anything."],[538,604,"Not now."],[775,855,"Not ever."],[946,1092,"I promised I'd wait for you."],[1192,1288,"And I will."],[1447,1614,"As long as you need it, I..."],[1747,1847,"I don't wanna to wait."],[1968,2072,"I love you too, Mal."],[2202,2281,"I want you."],[2373,2439,"I need you."],[3078,3161,"Fuck."],[3336,3545,"The smell of you is driving me insane."],[3653,3895,"You have no idea"],[3924,4091,"how long I wanted this."],[4129,4325,"How hard it is for me"],[4325,4546,"not to lose control around you."],[4746,4888,"I want you to lose control."]],"57":[[54,183,"Are you sure about that, Shay?"],[1192,1263,"Don't do that."],[1505,1601,"Don't hold back."],[1685,1843,"I want to hear you scream my name."],[1960,2064,"Now that I've marked you,"],[2139,2206,"I'm going to show you"],[2206,2485,"what it really means to be my mate."]],"58":[[20,212,"Mal turns thirty next week,"],[212,404,"and he has not marked a mate,"],[404,563,"nor produced an heir."],[713,842,"Should we be concerned?"],[842,992,"I certainly am."],[992,1238,"Our pack will die with our Alpha,"],[1259,1455,"if he's not mated soon."],[1455,1601,"I've heard whispers"],[1634,1926,"that he's recently with a human."],[2198,2339,"This cannot be true."],[2381,2640,"We must find him a suitable mate."],[2765,2961,"Ugh, if he marks with a human,"],[2990,3136,"he's no Alpha of mine."],[3174,3278,"It is true."],[3382,3457,"Selina."],[4149,4287,"Selina, you've returned."],[4287,4458,"Your Alpha has rejected me,"],[4458,4742,"his fated mate, in favor of a human."],[4854,4984,"I returned to him,"],[5013,5125,"pregnant with his pup."],[5217,5442,"And his human whore disfigured me"],[5442,5576,"with a silver dagger."],[5605,5772,"I'm dying slowly."],[5876,6035,"The only thing that can save me"],[6035,6168,"is the Alpha's blood."],[6339,6564,"But that human bitch is in my way."],[6835,6944,"We'll find them, Selina."],[7002,7111,"And we'll kill the human"],[7111,7207,"that did this to you."]],"59":[[37,183,"So Selina's sister is the witch"],[183,254,"who cursed you."],[362,513,"She disguised herself as my friend"],[513,588,"to keep us apart."],[825,1013,"Why did Selina leave in the first place?"],[1121,1242,"Why did you break her heart?"],[1539,1751,"Her father murdered and betrayed mine."],[1864,2010,"I thought Selina loved me,"],[2068,2281,"but she was just using me."],[2364,2548,"She helped her father murder mine,"],[2619,2769,"and her father almost murdered me,"],[2819,2873,"but..."],[2994,3107,"but I beat him to it."],[3203,3332,"And the saddest part is,"],[3395,3541,"I actually believed her"],[3541,3670,"when she said she regretted it."],[3670,3874,"So, I banished her,"],[3978,4162,"and I never told the pack"],[4225,4316,"of her banishment,"],[4429,4512,"of her betrayal."],[4562,4662,"They all think she moved away"],[4662,4929,"because she was too grief-stricken"],[4929,5046,"over her father's passing."],[5547,5638,"Maybe she's right."],[5764,5914,"Maybe I'm not fit to be Alpha."]],"60":[[33,221,"If only I'd killed her for her crimes,"],[337,671,"then, I might not be cursed."],[813,867,"You..."],[1038,1146,"might have not been hurt."],[1230,1317,"We could just"],[1430,1680,"live happily as mates."],[2160,2335,"There's no shame in having a heart."],[2394,2498,"It's what I love about you."],[2594,2752,"And as for the curse?"],[2811,2944,"Davina would have found some way"],[2944,3086,"of punishing you no matter what."],[3490,3574,"It's still there."],[3691,3883,"You're still cursed, even after last night."],[3899,3983,"It can't be broken"],[3983,4129,"until you're pregnant with my pup."],[4179,4283,"How long will that take?"],[4333,4421,"When will I know?"],[4496,4587,"Only time will tell,"],[4679,4733,"but"],[4821,4900,"until then..."],[4971,5155,"I'm gonna to fill you up so much,"],[5180,5388,"you'll be dripping for weeks."],[5426,5530,"What did you just say?"],[5588,5805,"I'm gonna claim you in every room."],[5855,5993,"You'll be pregnant with my pup"],[5993,6097,"in no time..."],[6097,6177,"Mal!"],[6247,6435,"Oh my God, I can read your mind?"]],"61":[[8,79,"Mal!"],[158,329,"Oh my God, I can read your mind?"],[400,517,"You know what that means?"],[558,608,"What?"],[638,942,"You are officially my Luna."],[1021,1105,"Alphas and their Lunas"],[1105,1226,"share a special mind link."],[1322,1451,"Sort of like a walkie-talkie."],[1505,1605,"Just the two of us."],[1659,1772,"I guess I have to be more careful"],[1772,1843,"around you now."],[1876,2002,"I can't hear all your thoughts."],[2168,2260,"It's about intention."],[2485,2723,"If I want you to hear what I'm thinking,"],[2836,3040,"then you will."],[3098,3186,"Do you want to hear"],[3186,3290,"what I'm thinking now?"],[3470,3570,"Absolutely."],[3682,3828,"Especially if it's dirty."],[3978,4166,"My first time was perfect."],[4166,4383,"I can't wait to do it again"],[4391,4575,"and again and again."],[5438,5618,"But wait, Davina's still out there."],[5684,5755,"Are we safe?"],[5860,5930,"This cabin."],[6047,6160,"It's run by magic."],[6177,6322,"Good magic."],[6389,6560,"The only people that know about this"],[6619,6756,"are the pack elders and Zaid."],[6936,7015,"Don't worry, Shay."],[7073,7165,"We are all..."],[7453,7520,"alone?"]],"62":[[525,600,"Alpha Mal!"],[675,763,"Open up!"],[809,975,"We must speak with you immediately!"],[1309,1388,"It's the Elders."],[1438,1618,"You mean the wolves who hate humans."],[1685,1751,"The wolves who could"],[1751,1826,"break our bonds"],[1826,1914,"if they want to."],[2293,2398,"I can't reach Zaid."],[2414,2485,"Alpha!"],[2548,2660,"We know you're in there!"],[2781,2852,"Open up,"],[2886,3053,"or we'll break down this door!"],[3111,3207,"Mal, I'm scared."],[3299,3420,"Hey, it's okay."],[3490,3641,"Now that I've marked you as my mate,"],[3657,3745,"you can pass as a wolf."],[3828,3953,"Whatever they want from me,"],[4179,4316,"I won't let them hurt you."],[5772,5880,"That's the human bitch"],[5880,5976,"who stabbed me."],[6018,6089,"Kill her."]],"63":[[191,308,"That's the human bitch"],[308,396,"who stabbed me."],[442,525,"Kill her."],[525,604,"She's lying."],[625,754,"She didn't hurt Selina."],[800,875,"I did."],[934,1113,"Her and her witch sister"],[1113,1288,"ripped my mate from me"],[1288,1518,"and tried to murder me in cold blood."],[1547,1764,"She is a treasonous psychopath."],[1843,1918,"One who deserves"],[1918,2285,"a slow and painful death."],[2344,2394,"Mal,"],[2448,2585,"that is no way to talk about"],[2585,2752,"the mother of your child."],[2857,2994,"I'm your true mate."],[3032,3224,"Murdering an innocent member"],[3224,3319,"of this pack,"],[3319,3415,"and the woman"],[3465,3624,"who was to be your destined mate,"],[3624,3691,"no less?"],[3728,3974,"Mal, you know the punishment,"],[4016,4124,"for such an act,"],[4179,4275,"is death."],[4308,4421,"No, you can't!"],[4742,5030,"Even if she is pregnant with a child,"],[5030,5117,"it's not mine."],[5234,5372,"We never slept together,"],[5380,5505,"and we certainly never"],[5505,5601,"marked each other."],[5626,5747,"You don't have to lie to protect"],[5747,5968,"this little fragile bitch's feelings."],[5980,6131,"We all know that a powerful Alpha"],[6131,6285,"would never mark a pathetic human."],[6318,6448,"Then how do you explain this?"]],"64":[[4,150,"Then how do you explain this?"],[412,600,"Shay is my mate."],[600,713,"If you reject her,"],[759,921,"you're rejecting your Alpha."],[1034,1226,"You would choose this woman"],[1255,1451,"over your own pack?"],[1484,1739,"This woman is your Luna."],[1776,1893,"I will choose her"],[1893,2189,"over anything and anyone."],[2627,2894,"She doesn't smell human."],[2919,3082,"She doesn't look like one either."],[3123,3516,"There's a certain power about her."],[3641,3770,"Wait a second, are you kidding?"],[3832,4066,"She's a worthless nobody."],[4066,4120,"Look at her,"],[4120,4300,"she's weak, and stupid and-"],[4300,4412,"Ahem."],[4521,4571,"Mal?"],[4571,4650,"Mal, what is it?"],[5301,5413,"The tattoo"],[5442,5543,"it’s fading."],[5701,5772,"The curse..."],[5876,5980,"it’s broken."],[6081,6197,"That must mean I'm..."],[6289,6414,"pregnant. - Pregnant."]],"65":[[29,116,"That must mean I'm..."],[225,350,"pregnant. - Pregnant."],[538,600,"What?"],[684,746,"My pup."],[1284,1455,"You saw that with your own two eyes."],[1493,1593,"I'm not a nobody."],[1626,1830,"I'm the mother of the Alpha's child."],[1885,2027,"I'm the true Luna."],[2072,2189,"We're so sorry, Alpha."],[2210,2298,"We didn't know."],[2406,2560,"We thought she was a human."],[2560,2702,"And what if she is?"],[2740,3007,"She is strong enough to face you all."],[3036,3424,"Strong enough to defend me, my pup,"],[3424,3520,"and our family."],[3566,3699,"You'd be lucky enough"],[3699,3895,"to call her your Luna."],[3895,4004,"You're really gonna accept"],[4004,4245,"this freak hybrid spawn,"],[4245,4416,"as the heir of this pack?"],[4416,4579,"My baby might be a hybrid,"],[4579,4721,"but at least it won't be a desperate"],[4721,4909,"psychotic murderer like you."],[5121,5280,"You will not have Mal's baby."],[5392,5584,"You are not gonna break this curse."]],"66":[[471,525,"Shay!"],[1030,1192,"You're gonna die today, bitch."],[1459,1739,"Don't you ever touch my pup again."],[2268,2369,"You can't kill me."],[2460,2535,"Do you wanna bet?"],[3015,3098,"Sister!"],[3661,3853,"Looks like you're outnumbered now."],[4012,4104,"Move an inch,"],[4187,4258,"and you die."],[4333,4425,"Shay, listen to her."],[4600,4771,"If you touch her, I will kill you."],[5055,5134,"I'm not scared."],[5192,5313,"My magic has you frozen."],[5384,5689,"So now, you get to watch us"],[5689,5839,"kill your little mate."]],"67":[[279,346,"No!"],[542,600,"No!"],[763,842,"Come, Sister."],[1130,1188,"Drink."],[2535,2627,"Now kill the girl."],[2786,2894,"With pleasure."]],"68":[[446,571,"Come back to me, Mal."],[617,709,"I need you."],[721,846,"I'm fighting, Shay."],[850,1117,"I'm fighting for you and our pup."],[1822,1981,"Selina, he's breaking through my magic!"],[2273,2352,"Selina?"],[2669,2715,"No!"],[2744,2840,"No, no no no!"],[2882,2994,"No, no!"],[3069,3153,"Don't kill me."],[3532,3674,"Any last words, Selina?"],[3791,3974,"Die, you human slut!"],[4592,4642,"Sister."]],"69":[[321,517,"No!"],[909,963,"You!"],[1343,1413,"Turn away."],[1518,1626,"I suggest you don’t look."],[2348,2460,"I warned you, Davina."],[2535,2723,"You cursed me,"],[2811,3028,"tried to kill my mate,"],[3103,3174,"my pup."],[3265,3424,"I’ve already lost my sister."],[3465,3549,"I think I’ve had"],[3549,3695,"enough pain for one day."],[3695,3962,"You don't know what pain is."],[3991,4241,"You wouldn't know what pain was,"],[4279,4550,"until I rip your heart out."]],"70":[[934,1005,"Go."],[1030,1088,"Now."],[1151,1355,"Tell the pack that there is a new Luna"],[1355,1443,"to report to."],[1530,1630,"Yes, Alpha Mal."],[1931,2010,"Luna Shay."],[2719,2827,"You saved me,"],[2844,2907,"again."],[3078,3148,"I don’t know."],[3211,3432,"All I saw was you kicking Selina's ass."],[3490,3566,"She's one of the strongest"],[3566,3653,"she-wolves I know."],[3695,3787,"How'd you do it?"],[3803,3862,"I don't know."],[3970,4212,"I guess when she tried to hurt the baby,"],[4212,4291,"I just kinda..."],[4362,4421,"lost it."],[4537,4704,"Maybe it was his Alpha powers"],[4704,4771,"kicking in."],[4788,4875,"His?"],[4946,5013,"The baby?"],[5171,5276,"What makes you so sure?"],[5359,5430,"I don't know."],[5451,5534,"I just feel it."],[5839,5926,"I know what you mean."],[6093,6252,"The tattoo has faded."],[6322,6410,"The curse is broken."],[6498,6577,"It's all over."],[6719,6781,"Are you okay?"],[6827,6890,"The pup."],[7069,7140,"I'm fine."],[7382,7419,"Hey!"],[7624,7691,"The baby."],[7736,7841,"Something's wrong."]],"71":[[671,725,"What is this?"],[767,850,"What's wrong with her?"],[921,992,"It hurts."],[1013,1088,"Mal, it hurts."],[1313,1418,"Pups grow much faster"],[1418,1551,"than regular human babies."],[1630,1743,"Maybe it's too much for her body"],[1743,1805,"to handle."],[1939,2185,"Mal, if she carries this pup"],[2185,2273,"to full term,"],[2377,2464,"she could die."],[2573,2694,"Maybe it's best if we-"],[2719,2769,"No!"],[2786,2827,"No!"],[2827,2923,"I'm not losing my baby."],[2952,3044,"I will not choose"],[3044,3232,"between my mate and my pup."],[3737,3816,"Wait a minute."],[3928,4012,"She's not in pain"],[4012,4112,"because of the baby."],[4112,4183,"She's in pain"],[4183,4300,"because she's becoming a wolf."]],"72":[[12,112,"What's happening to me?"],[200,333,"I feel so different."],[554,696,"Dean's bite."],[817,909,"And then my blood."],[980,1067,"Instead of killing you,"],[1138,1238,"it must have changed you."],[1422,1476,"That must be why"],[1476,1751,"you were able to fight Selina,"],[1789,1918,"why you were able to carry my pup."],[1960,2239,"Shay, you are a wolf now."],[2344,2523,"And once you deliver my pup,"],[2627,2756,"you'll be able to fully shift."],[2852,2907,"I..."],[2986,3036,"I don't..."],[3182,3299,"You don't have to be scared."],[3457,3549,"We can teach you,"],[3666,3757,"look after you."],[3945,4029,"If you need us,"],[4054,4145,"you know where to reach us."],[4491,4604,"I feel more like myself"],[4604,4721,"than I ever have before."],[4808,5092,"Like I can see everything,"],[5167,5292,"smell everything,"],[5405,5551,"feel everything."],[5805,5972,"Like I can do this."],[6986,7107,"I love you, my Luna."],[7307,7432,"I love you, my Alpha."]]}