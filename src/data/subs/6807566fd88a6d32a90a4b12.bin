en I need you."],[4066,4133,"But..."],[4279,4350,"if this is all,"],[4529,4600,"too much,"],[4688,4779,"you need to reject me,"],[4846,4934,"then do it now."],[4934,5025,"I can take it."]],"28":[[25,120,"I don't want you to die."],[225,316,"Look, I..."],[316,412,"I know we just met,"],[475,579,"but..."],[579,688,"somehow I feel like"],[688,771,"if you died,"],[821,950,"a part of me would die with you."],[1067,1197,"Does that mean you won't reject me?"],[1438,1543,"I wanna be your mate."],[2706,2836,"So,"],[2886,3019,"what comes next?"],[3253,3370,"Pack your things."],[3465,3566,"You're moving in with me."],[3799,3883,"Wait, what?"],[4779,4867,"Oh my gosh, they’re here!"],[5038,5125,"Shay,"],[5159,5305,"this is my beta Zaid"],[5342,5426,"and his mate, Freya."],[5551,5772,"Guys, this is your new Luna,"],[5772,5851,"Shay."],[6252,6331,"Luna?"],[6389,6631,"But, she's a human."]],"29":[[800,896,"I'm human too."],[963,1105,"Well, ha!"],[1222,1326,"I'm so happy"],[1326,1518,"Mal finally found his true mate."],[1555,1680,"It's nice to officially meet you."],[1910,1956,"Hey."],[2043,2106,"Don't worry."],[2147,2256,"Your secret's safe with them."],[2285,2473,"They will help me protect you."],[2535,2744,"And teach you the ways of the wolves."],[2769,2848,"Come with me."],[2873,3065,"We have so much to talk about."],[3178,3261,"Is this safe?"],[3586,3816,"Shay, I know this is all a lot for you,"],[3883,4045,"but, Freya here is gonna help you"],[4045,4145,"adjust to life here."],[4254,4337,"When you're done,"],[4400,4604,"you better come find me in my room."]],"30":[[4,208,"Oh my God."],[233,442,"Tell me everything."],[517,750,"What's it like being mated to an Alpha?"],[838,1051,"Um... intense."],[1184,1242,"I don't know."],[1242,1393,"I feel like whenever I'm around him,"],[1393,1543,"I totally lose control."],[1630,1776,"Like I can't think straight."],[1776,1906,"It's almost painful."],[1943,2035,"Is that normal?"],[2043,2122,"Totally."],[2177,2268,"If you're a wolf,"],[2306,2