{"1":[[371,475,"He's coming,"],[613,875,"the heir of the Varigold Group!"],[875,1142,"Oh my god, he's so hot!"],[1142,1292,"I would die a million times"],[1292,1484,"if that meant I could touch those muscles"],[1484,1615,"just once!"],[1747,2056,"Water Scarcity and Clean Access."],[2056,2214,"Alice,"],[2214,2410,"what the fuck are you doing here?"],[2410,2502,"Get out of my way!"],[2502,2606,"Doormat!"],[3090,3219,"What are you doing?"],[3219,3336,"What am I doing?"],[3732,3912,"Look how pathetic she is."],[4049,4179,"I have an idea."],[4179,4361,"Why don't we light her hair on fire?"],[4361,4535,"It'll be fun."],[4535,4633,"What?"],[4733,4929,"No, stop, stop!"],[4929,4992,"No!"],[4992,5071,"Please!"],[5071,5213,"No, stop!"],[5342,5413,"Honey."],[5413,5531,"Stop it! Let her go!"],[5576,5704,"Oh, Max."],[5704,5867,"It's so nice to finally meet you."],[5867,5960,"I'm Anna."],[8316,8479,"Thank you."],[8479,8646,"—My name is... —It's no big deal."],[8829,8942,"Take care!"],[9292,9371,"But..."],[9672,9889,"Can you tell he has no interest in you?"],[9972,10192,"Well, he's clearly not interested"],[10192,10293,"in you guys either."]],"2":[[183,312,"What the hell? You can't touch her."],[312,383,"He's behind us."],[1046,1159,"Let's go, ladies."],[1597,1776,"Stop dreaming."],[1776,1835,"Guys like him"],[1835,2060,"will never be interested in someone like me."],[2410,2485,"What?"],[2485,2646,"Why do I need to marry your friend's daughter?"],[2646,2857,"So what if her father helped you out?"],[2857,3057,"It doesn't have to destroy my life."],[3057,3294,"It's not like that, Max!"],[3294,3616,"Mr. Taylor's daughter is a lovely girl."],[3616,3691,"You'll like her."],[3791,4016,"The marriage will benefit both sides."],[4074,4241,"If you want to give up your inheritance"],[4241,4362,"right to the Varigold Group,"],[4441,4662,"feel free to ignore us!"],[5680,5755,"Oh!"],[5755,5922,"Fucking asshole!"],[5922,6101,"Hey, who threw that phone?"],[6247,6293,"Oh."],[6360,6477,"Sorry, boss."],[7111,7169,"Mom,"],[7282,7428,"what if he doesn't like me?"],[7469,7638,"I mean, should I really be marrying someone"],[7638,7743,"that I don't even know?"],[7832,8095,"Do this for me, Alice, please."],[8233,8412,"Things have been tough since your..."],[8579,8721,"since we lost your father."],[9029,9159,"And from now on,"],[9159,9396,"we're going by my surname."],[9480,9846,"So, you won't be Alice Taylor anymore."],[9868,10001,"You'll be Alice Smith."],[10047,10147,"What? No!"],[10181,10377,"It's how it has to be, Alice!"],[10514,10769,"We need the Brown's support."],[10769,10894,"Please."],[11561,11632,"Okay."],[11740,11861,"I'll do it for you, Mom."],[12650,12700,"Boss,"],[12741,12862,"I suggest you take these."],[12983,13044,"For what?"],[13096,13238,"If this woman isn't what you want,"],[13238,13409,"then better not let her see your face"],[13409,13488,"and fall in love."],[13776,13893,"Good idea."],[15261,15656,"So, seeing as we are already married,"],[15703,15815,"maybe we should go..."],[15874,16082,"grab a coffee and get to know each other."],[16412,16487,"Are you serious?"],[16487,16591,"Who is this guy?"],[17992,18055,"Quickly, sir,"],[18055,18159,"we don't wannna be late."]],"3":[[129,308,"Congrats."],[821,963,"When will he arrive?"],[963,1071,"Don't worry, Alice."],[1071,1234,"It must be a traffic jam."],[1234,1368,"He will come soon!"],[1430,1497,"What?"],[1555,1685,"Come back now!"],[1722,1839,"Don't you know today is your wedding?"],[1885,2090,"My flight to Australia is leaving in ten minutes."],[2090,2273,"And I've already signed the contract papers."],[2318,2435,"You got what you wanted, Dad."],[2485,2548,"Goodbye."],[2982,3123,"So pathetic."],[3123,3291,"I heard the bride's father"],[3291,3395,"recently passed away,"],[3395,3496,"and she's marrying him"],[3496,3692,"just to save her family financially."],[3692,3881,"The groom probably figured out her tricks"],[3881,3970,"and ran away."],[3970,4204,"Who wants to marry a gold digger anyway?"],[5377,5502,"You said you never beat your wife,"],[5502,5577,"Mr. Carter?"],[5672,5809,"Let's welcome our investigator,"],[5809,5960,"Miss. Alice Smith, then."],[8049,8320,"These are just some of the graphic images"],[8320,8441,"of my client"],[8441,8596,"after a particularly"],[8596,8829,"hostile exchange with the defendant."],[8904,9038,"And might I add, Mr. Carter,"],[9038,9129,"that your bedroom window"],[9129,9263,"opens up into the living room"],[9263,9405,"of your neighbor's house,"],[9405,9597,"who just so happens to be..."],[9663,9776,"a photographer."],[10335,10548,"I would consider my career and reputation"],[10548,10639,"if I were you,"],[10639,10698,"Mr. Carter."],[11861,11899,"Henry,"],[11991,12145,"you know any marriage investigators in the city?"],[12178,12299,"Why an investigator?"],[12374,12470,"I thought you were going to find a lawyer,"],[12470,12525,"directly."],[12612,12747,"We're gonna need some proof first."],[12783,12837,"No, these cases"],[12837,13025,"don't tend to swing in favor of the husbands."],[13025,13221,"Not to mention if that woman gets greedy"],[13221,13367,"and tries to take everything from us."],[13405,13488,"Makes sense."],[13563,13725,"Well, I heard the best investigator here"],[13725,13884,"is a young lady named Alice Smith."],[14089,14168,"Hmm."],[14535,14664,"This is Alice Smith."]],"4":[[567,642,"Oh!"],[642,796,"What the hell's going on?"],[796,870,"Well, sorry, lady,"],[870,1009,"but you stopped all of a sudden."],[1009,1148,"I don't have time for this."],[1148,1209,"Here,"],[1209,1292,"take my card."],[1292,1393,"We'll figure it out later."],[1534,1647,"And next time..."],[1647,1735,"watch where you're going."],[2202,2277,"So, it's our fault."],[2327,2389,"That's interesting."],[2769,2852,"Alice Smith?"],[3361,3453,"Max,"],[3461,3545,"why don't you meet that woman"],[3545,3717,"and decide if you want a divorce or not?"],[3732,3843,"Maybe you'll like her."],[3870,4074,"That sounds like the last thing I wanna be doing."],[4166,4245,"How do you know?"],[4404,4525,"Because I'm not interested in meeting"],[4525,4708,"someone who uses marriage as a tool."],[4846,4988,"Are you sure that's what she's doing?"],[5130,5211,"Is there any other reason"],[5211,5333,"that a woman would marry somebody"],[5333,5430,"that they don't even know?"],[5476,5522,"Hm,"],[5563,5626,"makes sense."]],"5":[[87,233,"You're ruining my life, Alice!"],[308,465,"I can't live without my wife!"],[479,621,"Just calm down, okay?"],[621,734,"I'm just doing my job."],[784,855,"Besides,"],[855,906,"you should know that"],[906,1101,"an unhappy marriage ends in a grave..."],[1101,1213,"for one or both parties."],[1213,1351,"I don't give a damn!"],[1351,1534,"Stay out of my marriage!"],[1534,1659,"You're ruining everything for me!"],[1659,1726,"Let go of me!"],[1726,1843,"Or I'll call the police."],[1922,2064,"What the fuck is going on?"],[2444,2598,"Leave the lady alone."],[2598,2725,"What if I say no?"],[3157,3257,"Ow! You're hurting me!"],[3332,3395,"Get out."],[4149,4291,"What are you guys doing here?"]],"6":[[575,905,"Allow me to formally introduce you to..."],[905,1121,"This is Max Brown, the CEO of Legend Group."],[1192,1334,"And I guess you are..."],[1334,1439,"Miss. Alice Smith."],[1584,1649,"Who would have thought"],[1649,1810,"you're the investigator we're looking for!?"],[1964,2089,"Thank you for your help earlier."],[2127,2164,"Please,"],[2210,2273,"take a seat."],[3307,3449,"Could Max be..."],[3545,3595,"No,"],[3645,3867,"my husband's company is Varigold Group,"],[3903,3983,"not Legend Group."],[4145,4212,"Mr. Brown,"],[4287,4491,"I already have my fair share of clients"],[4491,4599,"and headaches,"],[4621,4775,"especially after this morning,"],[4775,4901,"now I have to go to the car shop."],[4992,5062,"So,"],[5084,5212,"why should I take your case?"],[5226,5426,"Well, let's not allow past conflicts"],[5426,5553,"to cloud your judgment."],[5655,5755,"As you said,"],[5755,5885,"an unhappy marriage..."],[5926,6001,"is a grave."],[6381,6435,"Okay..."],[6548,6649,"I'll take your case."],[6731,6773,"Really?"],[6902,6994,"Yes,"],[6994,7161,"I believe everyone deserves a fair chance."],[7336,7574,"So, tell me about your wife."],[7574,7699,"Why do you want to get the divorce?"],[7699,7928,"What's the main issue in the relationship?"],[7978,8094,"I just don't know anything"],[8094,8159,"about the woman."],[8204,8383,"And my parents arranged the marriage years ago."],[8692,8762,"Interesting."],[8850,9042,"Well, have you given any thought to"],[9042,9200,"how you want to divide up the property?"],[9280,9334,"Yes."],[9417,9672,"I have set aside $10 million,"],[9813,9972,"if she requests anything else,"],[9972,10097,"I'm prepared to take care of it."],[10143,10290,"That's very generous."],[10364,10460,"You may not need my help."]],"7":[[20,116,"Now, hold on."],[204,367,"We've been married for..."],[367,437,"four years now."],[437,525,"It's a dead marriage."],[525,692,"For all we know, she's planning something."],[775,846,"Four years?"],[938,1084,"What was the name of..."],[1084,1134,"your wife?"],[1192,1355,"Oh, her..."],[1488,1572,"The name..."],[1830,1910,"Her name..."],[1951,2031,"Oh, I'm sorry."],[2031,2122,"I need to take this."],[2289,2360,"Hello?"],[2389,2489,"Alice,"],[2489,2646,"Max has just returned."],[2646,2857,"Come to my home and I'll introduce you guys."],[2857,2936,"Okay."],[3290,3557,"I have an emergency that I need to handle."],[3557,3787,"So, I will take a look at your case,"],[3787,3920,"and I'll get back to you later."],[3920,3974,"Thank you."],[4208,4341,"Not that professional, is she?"],[4466,4558,"I think you should ask for more"],[4558,4738,"detailed information from your mom first."],[4896,4963,"Yeah, let's do it."]],"8":[[137,216,"Mom, please,"],[216,328,"I have no interest in this woman."],[442,594,"Give it at least a month."],[646,880,"By then, if you still want a divorce,"],[913,971,"I'll agree."],[1034,1080,"Deal!"],[2602,2702,"Hi, Emma."],[2702,2823,"Come on in, Ally."],[2823,2943,"You look gorgeous."],[2977,3090,"Max is waiting for you."],[4096,4147,"Um."],[4175,4383,"He probably felt bad about not having a gift."],[4433,4525,"Don't worry, he'll..."],[4554,4646,"You'll meet him later."],[4808,4884,"Right."],[4979,5063,"You know,"],[5063,5184,"I... I have some work..."],[5209,5305,"that I could get done."],[5342,5455,"I'll Uber home."]],"9":[[229,316,"Max, where did you go?"],[358,500,"Let's stop wasting our time!"],[583,719,"We agreed to give it a month."],[767,817,"No need,"],[850,991,"I already hired a very good investigator"],[991,1063,"to find proof,"],[1063,1234,"and later I'll find a lawyer for divorce."],[2364,2469,"He said he'll meet you later"],[2469,2585,"after better preparation."],[2610,2708,"I hope you don't blame him"],[2708,2919,"for leaving without notice four years ago."],[2994,3061,"No,"],[3061,3240,"Emma, I understand that it's a"],[3240,3353,"difficult situation."],[3495,3720,"Tomorrow, there's an important charity event."],[3720,3816,"Make sure you go."],[3816,3924,"I'll take care of the rest."],[3924,4008,"A charity event?"],[4162,4212,"Okay."],[4525,4600,"Henry,"],[4600,4751,"tomorrow's charity event,"],[4758,4909,"make sure Max goes, okay?"],[5021,5150,"Why don't you tell him directly?"],[5234,5427,"I don't want him to suspect anything."],[5634,5814,"His sweet wife, Ally, will be there, too."],[6093,6310,"I must make sure he doesn't run away this time."],[6373,6418,"I see,"],[6460,6498,"wait..."],[6569,6756,"his wife's name is Ally?"],[6848,6990,"Did she happen to work in a law firm?"],[7048,7123,"Yes, why?"],[7261,7336,"I gotta go now."],[7432,7494,"Wait!"]],"10":[[0,70,"Wait!"],[233,420,"Arrange to donate in Alice's name"],[420,542,"at the charity dinner."],[633,817,"Max likes girls who are passionate about"],[817,971,"meaningful social events."],[1013,1201,"He may fall for her after that."],[1201,1347,"Will the event be hosted under the name of"],[1347,1514,"Legend or Varigold Group?"],[1514,1614,"Legend Group."],[1614,1826,"I want our new branch to build its reputation."],[1897,1951,"OK."],[2631,2777,"Dude, let me ask you."],[2777,2932,"Are you sure about the divorce?"],[2932,3015,"Yes."],[3111,3228,"How sure are you?"],[3382,3545,"100% sure, why?"],[3620,3670,"Well,"],[3737,3978,"you better leave some room for more possibilities."],[4154,4275,"Where'd you go earlier?"],[4379,4512,"Went back to visit the chairwoman."],[4567,4646,"I see."],[4738,4884,"So, my mom's trying to get you to persuade me"],[4884,5017,"to give up on the divorce."],[5109,5242,"That's right, but..."],[5355,5422,"Shut up!"],[5522,5605,"Hold on!"],[5684,5822,"Do you know who your wife is?"],[5893,6028,"I've heard enough about that woman."],[6064,6177,"Are you sure?"],[6177,6297,"You seemed interested in the investigator,"],[6297,6385,"but I actually found out she is..."],[6385,6452,"Enough!"]],"11":[[0,83,"What?"],[83,296,"Henry, you're trying to just set me up, right?"],[371,471,"How much is my mom paying you?"],[513,571,"What?"],[608,684,"Come on!"],[850,915,"Please. Okay."],[915,999,"I need to focus on"],[999,1205,"the Legend Group's charity gala event."],[1205,1309,"It's gonna be tomorrow."],[1509,1609,"After that, we can talk about"],[1609,1822,"this all so-called wife later."],[1893,2106,"Max, there's something you really should know..."],[2106,2181,"Save it."],[2231,2285,"Please."],[2439,2519,"Enough."],[3336,3520,"Boss, there's someone here to see you."],[3728,3891,"Well, I don't have any meetings on today."],[4108,4166,"When did you start"],[4166,4270,"scheduling my meetings, Henry?"],[4325,4396,"I just thought it was"],[4396,4537,"somebody that you'd like to see."],[4679,4746,"I think she's outside."],[4746,4825,"Hold on."],[5330,5497,"Oh, hi, Alice!"]],"12":[[0,162,"Oh, hi, Alice."],[596,663,"What's up?"],[754,813,"What are you doing here?"],[988,1148,"Henry said that you wanted to see me..."],[1488,1539,"Right."],[1618,1676,"Of course."],[1822,1964,"Just wanted to talk more about the case."],[2027,2102,"Right."],[2185,2318,"Yeah, I'm really sorry for"],[2318,2444,"leaving so abruptly earlier."],[2540,2640,"No need to apologize."],[2786,2869,"Actually, I had a question"],[2869,2998,"I wanted to ask you."],[3132,3244,"We're doing the..."],[3244,3424,"Legend Group charity gala event tomorrow."],[3465,3524,"You wanna join me?"],[3616,3770,"You want me to join you?"],[3903,3974,"Oh,"],[3974,4087,"you want to make your wife jealous,"],[4087,4276,"so she agrees to sign the divorce papers."],[4371,4450,"Smart, yeah."],[4575,4717,"Also, don't forget that I'm the victim here."],[4984,5159,"This marriage is just a whole farce."],[5255,5401,"What a coincidence."],[5413,5534,"Emma also invited me."],[6431,6493,"Alice,"],[6635,6727,"you look..."],[6781,6873,"ravishing tonight."],[6931,7023,"What the hell, Tom?"]],"13":[[70,191,"What the hell, Tom?"],[362,579,"Alice, how dare you seduce my husband!"],[646,779,"What are you talking about?"],[938,1101,"How can someone like you"],[1101,1326,"attend such a high-class event anyway?"],[1509,1768,"Well, Linda, if someone like you can be here,"],[1768,1906,"I can definitely be here."],[2093,2281,"I heard your husband left the country"],[2281,2389,"four years ago,"],[2389,2498,"just to get away from you."],[2656,2798,"How horrible is that?!"],[2936,3103,"Actually, she's my wife."],[3432,3503,"And I don't allow anyone"],[3503,3620,"to talk to my wife like that."],[3745,3782,"You are?"],[3928,4124,"Show some respect or I'm gonna call security."],[4170,4341,"We all know Alice's husband"],[4341,4491,"fled the country four years ago"],[4491,4583,"just to get away from her."],[4692,4817,"Yeah, well, he's back now."],[5113,5176,"Tom,"],[5213,5330,"the CEO of Legend Group,"],[5330,5488,"would like to meet with you at tonight's gala."],[5768,5872,"I just got a call,"],[5872,5939,"and tonight,"],[6001,6227,"I'm meeting a very important contact."],[6227,6335,"Really, honey?"],[6456,6502,"Let's go."],[6556,6923,"Let's not waste time on these low-class people."],[7711,7811,"Thanks."],[7811,7857,"Sure."]],"14":[[283,429,"Alright, ladies and gentlemen,"],[429,684,"it is now time for tonight's main event."],[754,959,"Tonight's winner, who donates the most,"],[959,1222,"will receive a special collaboration opportunity"],[1301,1401,"with our sponsor,"],[1522,1584,"Legend Group!"],[1818,2010,"I heard the value of the collaboration"],[2010,2273,"is worth more than the top donation amount last year."],[2377,2469,"So let's get it."],[2581,2706,"I'll donate 10 million!"],[2706,2794,"10 million!"],[2927,3011,"50 million."],[3069,3153,"50 million!"],[3211,3299,"60 million."],[3299,3353,"60 million!"],[3353,3449,"100"],[3449,3553,"million!"],[3695,3837,"100 million!"],[3970,4066,"Going once..."],[4099,4166,"Going twice..."],[4229,4308,"Oh, wow!"],[4629,4791,"It seems that a mysterious donor"],[4791,4892,"by the name of Alice"],[4892,5134,"just donated $200 million."],[5330,5409,"It wasn't me."],[5447,5601,"It's just a coincidence, right?"],[6060,6126,"Alice!"],[6297,6368,"Alice?"],[6464,6585,"There is no way"],[6639,6756,"that the Alice who donated"],[6756,6890,"is this same Alice."],[6890,7044,"Where would she get all that money? Huh?"],[7044,7082,"Tell me!"],[7082,7239,"What kind of tricks are you guys"],[7239,7361,"trying to pull here?"],[7499,7628,"What are you doing to my boss?"],[7657,7720,"Henry?"],[7757,7878,"Your boss?"],[7878,7987,"This is Max,"],[7987,8112,"the CEO of Legend Group."],[8174,8275,"He's the important person"],[8275,8408,"I was gonna introduce you to tonight."],[8454,8537,"What?!"]],"15":[[258,350,"Get better, Alice."],[1226,1301,"Mom,"],[1301,1447,"will you send me my wife's number?"],[1530,1663,"I'm confused."],[1935,2002,"Oh, my head..."],[2293,2464,"I think I have low blood sugar."],[2515,2585,"Hey!"],[2690,2761,"Hi!"],[2819,2919,"Have something to eat."],[2919,3036,"It's gonna make you feel better."],[3611,3691,"Thank you."],[4612,4708,"You know, I noticed that your husband"],[4708,4808,"didn't show up yet."],[4954,5109,"How's your relationship with him?"],[5109,5205,"If you don't mind me asking."],[5397,5505,"Actually, I do mind."],[5609,5751,"I don't really wanna talk about him."],[5935,6014,"I understand."],[7549,7624,"Hello?"]],"16":[[45,129,"Hello?"],[321,392,"Who is this?"],[467,550,"Where's my wife?"],[579,675,"Hello?"],[675,759,"Who am I speaking to?"],[809,959,"Yes, I'm fine."],[1109,1176,"I'll be okay."],[1267,1413,"I just need a rest."],[1418,1480,"Hello?"],[1480,1587,"She's probably speaking"],[1587,1697,"to her husband now."],[1697,1743,"Hello?"],[1743,1876,"But I shouldn't enquire."],[1876,2065,"Besides, I have my own problems to deal with."],[2097,2164,"I love you too."],[2264,2389,"Okay, bye."],[3199,3599,"Max, I checked the donation details."],[3599,3855,"It's your wife who made the donation."],[3855,3987,"I see."],[4083,4254,"I guess it can't be Alice Smith."],[4254,4400,"There's no way she'd be able to afford it."],[4400,4574,"Well, you know, there is another woman"],[4574,4733,"at the law firm named Ally."],[4733,4904,"One of their high-profile lawyers."],[4904,5125,"I can look into her instead."],[5125,5309,"Yeah, yeah, go do that."],[5701,5805,"Who is that, babe?"],[5805,5846,"I don't know."],[5846,5980,"Probably one of Alice's clients."],[6039,6193,"I'm surprised she hasn't realized yet"],[6193,6419,"that she left her work phone in your office."],[6460,6527,"Okay."],[6527,6681,"Forget about her."],[6681,6845,"Steven, you said you would divorce"],[6845,6927,"your wife by now."],[6927,6999,"How long are you gonna"],[6999,7082,"keep me waiting?"],[7082,7189,"Okay, okay."],[7189,7369,"I'll settle things with her tonight."],[8983,9088,"Hello?"],[9088,9139,"Hey."],[9170,9367,"We haven't seen each other in four years."],[9367,9517,"So I bet we can get a divorce."],[9554,9734,"How about I give you $10 million?"],[9734,9846,"Is this Alice's husband,"],[9846,9995,"the one she's never even met?"],[10010,10168,"Wow, he's rich."],[10168,10352,"Let me see what I can get out of this."],[10352,10422,"What?"],[10552,10652,"Okay."],[10652,10831,"I understand."],[10831,10956,"Why don't we meet and talk?"],[10957,11044,"Good."],[11044,11169,"I got a place in mind."]],"17":[[262,367,"Would you believe it, Alice?"],[417,542,"I know my wife is cheating on me."],[675,784,"I need to go and sort this out."],[846,934,"Would you come with me?"],[1034,1159,"Yeah, sure."],[1192,1272,"But..."],[1272,1459,"don't say too much, okay?"],[1459,1534,"Let's remember..."],[1576,1710,"let her speak first."],[3194,3249,"Ally?"],[3332,3553,"Oh, so I guess you're investigating me now."],[3611,3732,"Wait, you two know each other?"],[3828,4041,"Yeah, we work at the same law firm."],[4692,4813,"What are you looking at?"],[4896,5033,"Is that a limited edition?"],[5033,5201,"I think I saw it in a magazine."],[5422,5526,"Let's get to the point."],[5663,5747,"I don't wanna divorce"],[5747,5836,"unless you pay me enough."],[5876,6039,"Okay, is 10 million enough?"],[6089,6285,"That's not even enough to pay for your watch."],[6619,6664,"Okay."],[6752,6852,"How much is enough?"],[6956,7073,"Hmm..."],[7073,7190,"Let me think..."],[7820,7966,"Okay, while you're thinking about that,"],[7966,8087,"why don't you go"],[8087,8184,"figure out a number"],[8184,8316,"and then you can come back."],[8375,8537,"For now, I need to talk with Alice."],[8837,8892,"OK."]],"18":[[421,571,"Max, I'm really sorry that"],[571,663,"you're going through this."],[663,750,"I mean,"],[750,941,"Ally is clearly using your own emotions"],[941,1021,"to extort you."],[1184,1305,"Well, you know, it's like you said, Alice."],[1372,1539,"An unhappy marriage is a grave."],[1789,1906,"I'm just really happy that you're here."],[1972,2027,"Thanks."],[2027,2127,"Of course."],[2235,2448,"Actually, I got you something."],[2957,3057,"Wow."],[3578,3724,"Max, I can't accept this."],[3724,3828,"This is too nice."],[3945,4037,"No, no."],[4120,4275,"Please, I insist, okay?"],[4275,4416,"It's just a gift from a friend."],[4650,4708,"Thanks."]],"19":[[325,417,"Oh, Alice,"],[538,654,"this is..."],[654,734,"Mr. Roberts."],[734,842,"He's the manager of the cafe."],[842,930,"Mr. Roberts, Alice."],[930,1101,"She's been a great help to me lately."],[1101,1226,"Hello, Alice, lovely to meet you."],[1292,1455,"Sorry, I actually have to take this."],[1639,1949,"What a strange way for Max to introduce his wife..."],[1993,2139,"Would you like to order now, Mr. Brown,"],[2139,2260,"or should we wait for your wife?"],[2260,2439,"Please, not just any woman is my wife."],[2481,2606,"Oh, I see."],[2656,2731,"They must've had a fight..."],[2777,2886,"Perhaps it was something to do with"],[2886,2957,"that other woman."],[3019,3090,"Very well."],[3090,3178,"I shall wait for the lady."],[3503,3557,"Hey, Emma?"],[3607,3674,"Alice,"],[3674,3820,"did Max call you?"],[3820,3958,"He said he's been trying to reach you."],[3999,4154,"No, he hasn't called, actually."],[4254,4366,"Oh, you know what,"],[4416,4554,"I think I gave you my work phone number."],[4554,4683,"I don't check that one as often."],[4758,4863,"Oh, that's a relief."],[4900,4975,"I was worried."],[5025,5234,"Emma, can you send me Max's number again?"],[5305,5359,"Okay."],[5409,5509,"Great, thanks."],[6202,6331,"Okay, Mom, hi."],[6381,6527,"I'm going through the divorce."],[6527,6660,"Please, I think that woman's a gold digger."],[6668,6744,"No way!"],[6744,6873,"She's not that kind of woman."],[6919,7065,"Are you meeting with someone new?"]],"20":[[100,208,"Yes."],[208,308,"Yes, actually, I am."],[308,433,"And she's kind."],[492,621,"She's got this grace about her."],[834,909,"Sorry, I gotta go."],[909,1030,"Mom, I'll call you later."],[1347,1468,"I didn't mean for you to overhear that."],[1593,1814,"Sorry, I didn't realize you were there."],[1876,1939,"That's okay."],[2031,2202,"I'm glad you think so highly of me."],[2364,2423,"I do."],[2627,2761,"I mean, I really do."]],"21":[[275,367,"Here's you."],[709,804,"So,"],[804,905,"cousin Max,"],[905,1088,"you have got to tell me"],[1088,1226,"all about what you've been up to"],[1226,1301,"Down Under!"],[1401,1643,"A little thunder from Down Under, I expect."],[1723,1830,"Well, it..."],[1830,1931,"It isn't a short story."],[1931,2043,"I could tell you that much, Mike."],[2181,2260,"But first,"],[2306,2473,"since when did you get back from the UK?"],[2556,2627,"Oh, I..."],[2694,2794,"Well, I just got back."],[2907,3057,"Right after my parents divorced."],[3182,3294,"—It's a little sensitive... —Sorry."],[3294,3432,"Boss, it's time to go."],[4391,4525,"Why give a shit about him?"],[4621,4727,"Remember how his dad tried to"],[4727,4846,"steal power from your father?"],[4921,5005,"Yeah, but at the end of the day,"],[5005,5096,"we're all family."],[5188,5359,"I heard it was all his idea,"],[5359,5509,"and he's the one who controls his father."],[5568,5676,"Be careful."],[5822,5880,"Henry,"],[5980,6089,"don't worry about it."],[6164,6231,"Okay?"],[6231,6322,"What's the worst thing he could do?"],[7832,7982,"Max, it's Alice."],[7982,8053,"Can we talk?"],[8053,8133,"Alice?"],[8254,8416,"Max's wife?"],[8416,8529,"It's about us."],[8529,8650,"Emma said that we should talk."],[8942,9050,"Yes,"],[9050,9171,"I have been..."],[9171,9363,"looking forward to seeing you, too."]],"22":[[0,162,"It's about us."],[162,321,"Emma said that we should talk."],[442,579,"I have been..."],[579,792,"looking forward to seeing you, too."],[792,838,"Really?"],[838,988,"I thought you'd hate to see me."],[988,1084,"No,"],[1084,1176,"no way."],[1351,1442,"Say, why don't we meet up..."],[1501,1649,"sometime next week?"],[1668,1768,"Okay, let's do it."],[1810,1860,"Great."],[1960,2068,"Oh, and..."],[2068,2164,"Alice..."],[2260,2427,"I don't use this phone often."],[2502,2635,"Let me give you my main number."],[2723,2798,"No problem."],[3991,4168,"I knew you'd come back for this phone."],[4466,4512,"Thank you."]],"23":[[112,158,"Max,"],[262,346,"I have something for you."],[521,658,"The woman you said you met yesterday..."],[688,821,"she sounded different than I expected."],[821,921,"So I did some digging."],[1113,1267,"I can't believe my mother still likes this woman."],[1322,1388,"I'm sorry, Max."],[1388,1514,"The evidence is undeniable."],[1543,1702,"She did have an affair with her boss."],[1743,1891,"We need to handle this carefully."],[2210,2293,"Henry, I want you to follow up"],[2293,2377,"on this information."],[2419,2548,"And I need you to keep this information"],[2548,2615,"under wraps."],[2615,2749,"Strictly family matter."],[2749,2806,"Understood."],[2806,2984,"I'll do everything I can to uncover the truth."],[3036,3086,"Thanks, Henry."],[3661,3770,"No, I'm really, really"],[3770,3903,"looking forward to seeing you."],[3903,4026,"It's been so long."],[4099,4237,"I can't wait either."],[4429,4475,"And..."],[4475,4575,"Emma said that you're..."],[4608,4704,"planning the wedding, right?"],[4775,4884,"Yes."],[4884,4992,"And I never stopped"],[4992,5138,"thinking about you, Alice."],[5188,5271,"Why don't we just meet today?"],[5401,5476,"I'm at..."],[5476,5609,"Greensdale Mall right now."],[5651,5780,"That sounds great!"],[5780,5989,"I'll be there as soon as I can."],[6035,6114,"Great."],[6210,6377,"So many years have passed, Max."],[6423,6564,"I'm so happy I found you again."]],"24":[[208,246,"Alice?"],[433,487,"Max!"],[692,775,"What are you doing here?"],[775,878,"You shopping for a hot date?"],[992,1188,"As a matter of fact, yes..."],[1188,1234,"I am."],[1476,1618,"Well, I hope he's worthy of you."],[1730,1789,"I think so."],[1918,1968,"You know what,"],[2064,2152,"I got a card for this mall."],[2227,2273,"Take it."],[2318,2414,"Use it for whatever you want."],[2540,2610,"No,"],[2610,2696,"I... I can't do that."],[2723,2769,"Please."],[2861,2969,"For all the help that you gave me."],[3265,3303,"Okay."],[3507,3570,"Thank you."],[3628,3670,"Sure."],[4984,5080,"Alice?"],[5167,5267,"What are you doing here?"],[5355,5434,"I'm shopping."],[5434,5563,"Linda, what does it look like?"],[5588,5697,"Shopping?"],[5697,5793,"Of course!"],[5793,5889,"And I'm sure"],[5889,6087,"the only thing you can afford here..."],[6222,6322,"is that iced coffee!"],[6628,6810,"Here are your bags, Miss."],[6902,6965,"When you're ready,"],[6965,7065,"please pay with a card."],[7065,7144,"Thank you, Lucy."],[7265,7303,"What?"]],"25":[[0,104,"Thank you, Lucy."],[104,150,"What?"],[262,337,"Hold on, hold on!"],[437,638,"You can't afford these!"],[871,934,"Yes, I can."],[1059,1213,"These are designer!"],[1355,1393,"And?"],[1580,1634,"Whatever."],[1634,1693,"Just..."],[1693,1855,"Don't ask me to cover you later."],[1981,2052,"You know,"],[2052,2152,"actually..."],[2152,2223,"Linda,"],[2223,2431,"I bet you couldn't afford these."],[2431,2560,"You don't think I can?"],[2865,2915,"Please."],[3495,3649,"And here's your receipt for..."],[3649,3987,"$19,999."],[3987,4087,"I'm sorry, how much?"],[5088,5242,"$20,000!"],[5292,5467,"Linda, what the hell did you buy?"],[5467,5526,"Tom, it's..."],[5638,5772,"It's just a shopping bill."],[5893,5989,"Yes, it's a lot, but..."],[6051,6189,"I had to save face!"],[6189,6285,"Stay where you are."],[6285,6348,"I'm coming to find you."]],"26":[[70,162,"Linda,"],[162,350,"what's the meaning behind this?"],[350,529,"It's all a trick, babe!"],[529,692,"She made me pay for it!"],[692,784,"Excuse me?"],[825,900,"Alice,"],[938,1005,"you"],[1005,1063,"conned"],[1063,1213,"Linda into paying for your shit?"],[1213,1413,"I didn't con anyone, okay?"],[1413,1584,"She paid before I had a chance to."],[1634,1793,"You scam artist!"],[1835,1993,"Well, I want my money back."],[2281,2364,"Don't you touch her."],[2606,2677,"Who the hell are you?"],[2819,2919,"I'm her husband."],[3123,3269,"Now back off,"],[3269,3415,"if you don't want any trouble."],[4738,4863,"I should've been here sooner."],[4979,5121,"Alice, I'm sorry."],[5121,5292,"I'm so sorry"],[5292,5442,"I left you four years ago."],[5442,5520,"I've..."],[5597,5819,"really been regretting it every day since."],[5922,6030,"It's okay."],[6090,6272,"I'm just glad you're here now."],[6828,6926,"Alice?"],[7007,7236,"That's probably her husband."],[7236,7365,"I'll leave them be."]],"27":[[600,717,"Come on in."],[1026,1167,"Max, why don't you live at home?"],[1288,1405,"Well, I um..."],[1405,1610,"been traveling a lot to work lately."],[1860,1981,"I guess I just..."],[2206,2410,"I'm used to hotels."],[2410,2585,"It's..."],[2585,2752,"cozy."],[2752,3044,"I do try to make it feel like home."],[3228,3345,"Oh..."],[3345,3557,"Alice, I'm so sorry."],[3645,3716,"Let me help you."],[3799,3870,"I'm fine."],[3999,4099,"Since we..."],[4099,4208,"barely know each other,"],[4208,4360,"I think I need more time."],[4946,5055,"Alice?"],[5518,5613,"Alice."],[5730,5855,"Alice, Alice, Alice."],[6001,6243,"Are you playing hard to get..."],[6243,6398,"just to seduce me?"]],"28":[[104,162,"Hi,"],[162,308,"can I get a towel, please?"],[642,713,"Alice!"],[1017,1096,"Max!"],[1201,1272,"Hi."],[1730,1868,"Max, what are you doing here?"],[1960,2085,"Alice, it is..."],[2085,2160,"so good to see you."],[2344,2439,"You're drunk."],[2698,2840,"It must be because of his wife."],[2952,3082,"Let's... get you home."],[3165,3274,"Come on."],[3274,3349,"I'll take you."],[3687,3795,"Careful, just..."],[3795,3899,"go this way."],[3899,4045,"And then we're gonna go to your..."],[4045,4158,"room over here."],[4158,4258,"Careful, careful, careful."],[4688,4754,"Alice..."],[4942,5050,"Max, we shouldn't...."],[5155,5217,"I know..."],[5467,5588,"But I've missed you."],[6151,6256,"Good night, Max."],[6881,7044,"What am I doing?"],[7044,7236,"Why do I like him more than my own husband?"]],"29":[[75,262,"Max, I saw your wife with another man!"],[262,367,"She went into a hotel!"],[675,779,"Oh, I..."],[917,1063,"didn't realize you were with Alice."],[1451,1580,"What's going on, Henry?"],[1689,1922,"I saw Max's wife."],[1922,2006,"I thought you should know."],[2102,2214,"So she is cheating on him?"],[2327,2431,"Yeah."],[2431,2554,"She's arrogant enough to cheat"],[2554,2641,"during the divorce."],[3119,3174,"I should go."],[3336,3378,"Wait,"],[3378,3537,"Alice, I'm sorry for the intrusion."],[3537,3583,"I..."],[3762,3870,"Alice, please, don't go!"]],"30":[[137,229,"Oranges?"],[229,312,"Actually, that's not me."],[312,458,"That's at the house in the country."],[613,684,"How about this?"],[684,785,"Max and Alice..."],[859,1005,"two hearts yearning for love."],[1121,1184,"If only they knew"],[1184,1326,"how perfect they are for each other."],[1459,1576,"I wouldn't be able to do this"],[1576,1634,"without you."],[2047,2114,"Alice,"],[2114,2206,"I need to ask you something."],[2289,2392,"It's about Max..."],[2481,2556,"Yeah."],[2556,2602,"What is it?"],[2711,2844,"I see how you two"],[2844,2986,"could be happy together."],[3032,3165,"Help him get the divorce soon"],[3165,3286,"and do it for both of you."],[3532,3657,"I have a husband."],[3699,3782,"He has a wife."],[3782,3928,"I'm here on a job."],[3928,4054,"To help him get a divorce, I'd..."],[4141,4191,"Henry,"],[4191,4302,"please don't suggest something"],[4302,4375,"like that again."],[4375,4441,"Let's just..."],[4441,4546,"keep this professional."],[5351,5413,"Ally."],[5551,5716,"This is for the exceptional job"],[5716,5839,"you did last night."],[5839,6006,"It is truly well-deserved."],[6122,6331,"I love it!"],[6331,6393,"Put it on me."],[7273,7332,"And..."],[7603,7691,"this is ready."],[7745,7887,"Now I have all I need."],[7887,8116,"We're gonna get a lot of money."],[8116,8208,"A lot!"],[8829,8867,"Uh..."]],"31":[[346,400,"I'm sorry."],[400,521,"I didn't mean to interrupt."],[604,667,"You weren't..."],[667,767,"interrupting, really."],[767,829,"We were just..."],[963,1188,"Actually, I'm here on business."],[1363,1463,"As you know,"],[1463,1735,"Max commissioned me to handle his divorce..."],[1735,1793,"file."],[1897,2089,"Oh, he should give me what I asked for."],[2152,2248,"According to the terms,"],[2248,2389,"I am entitled to half his property."],[2460,2577,"If this divorce goes public,"],[2577,2731,"his company's stock will tank,"],[2731,2873,"and we'll see who loses out then."],[3157,3311,"I understand your position, Ally,"],[3311,3445,"but Max is firm on this,"],[3445,3586,"and he's willing to fight for what's right."],[3687,3745,"Also,"],[3745,3908,"he knows about the affair you're having."],[4763,4842,"Hello, I'm..."],[4842,4992,"I need to file a divorce case..."],[5255,5355,"Sorry, I don't take"],[5355,5531,"cheap cases like yours."],[5576,5676,"But... but I need help."],[5776,5926,"I handle high-profile cases,"],[5926,6078,"not common ones."],[6389,6456,"I can help you."],[6589,6679,"Thank you so much!"],[6723,6824,"I'm Alice."],[6827,6902,"What's your name?"],[6902,6986,"Mr. Thompson Brown."],[7044,7125,"I'm one of the board members"],[7125,7199,"at Legend Group."]],"32":[[45,108,"Lovely to meet you."],[150,208,"Good to meet you."],[283,462,"Mr. Brown, I apologize for any"],[462,554,"misunderstanding."],[554,704,"Ally doesn't normally act like this."],[742,817,"I came here..."],[900,1017,"to assess if your firm"],[1017,1126,"was worthy of our business."],[1355,1455,"I didn't expect to be met with"],[1455,1561,"such arrogance,"],[1605,1718,"especially from a lawyer!"],[1718,1780,"Mr. Brown?"],[1780,1864,"Enough, Ally!"],[1864,2068,"You've made a grave error in judgment."],[2068,2335,"You need to apologize to Mr. Brown right now!"],[2485,2593,"You may be the board member"],[2593,2673,"of the Legend Group."],[2673,2819,"But I am the wife of the CEO."],[2819,3019,"So why should I give a shit about you?"],[3073,3123,"Wow,"],[3194,3345,"I'll show you what I can do!"],[3345,3411,"Just you wait!"],[3507,3566,"Please!"]],"33":[[12,162,"I've decided that in the future,"],[162,342,"I will seek your services alone."],[387,504,"Not this law firm,"],[688,754,"but you alone."],[813,959,"Actually, I'm not a lawyer."],[959,1092,"I'm just a marriage investigator."],[1142,1230,"That's quite all right."],[1230,1397,"I'm sure you'll get along great with our lawyers."],[2193,2327,"You have made..."],[2327,2498,"good progress on this case, Alice."],[2498,2615,"I... I'm impressed."],[2648,2698,"Thank you."],[2973,3073,"I apologize"],[3073,3224,"if I'm overstepping here, but..."],[3299,3403,"I was wondering if you'd..."],[3403,3566,"be interested in meeting my son, Michael."],[3603,3762,"He's a... a fine young man."],[3816,3841,"Well..."],[3841,4008,"I heard what you were about to suggest,"],[4045,4112,"Thompson."],[4170,4389,"I must advise against it."],[4458,4641,"Ally is married,"],[4688,4838,"and your son..."],[4838,4959,"is not the type of person"],[4959,5134,"she should be involved with anyway."]],"34":[[54,129,"I assure you,"],[129,229,"Michael is..."],[229,359,"a gentleman who would treat Alice"],[359,500,"with the utmost respect."],[500,671,"I suggest only an introduction,"],[671,756,"strictly professional."],[756,850,"I know..."],[850,1055,"my daughter-in-law's value,"],[1109,1272,"and I won't have her"],[1272,1508,"entangled in your son's affairs."],[1747,1789,"Ally,"],[1868,1939,"we should go."],[2223,2369,"Thank you, Mr. Brown."],[2369,2565,"I really appreciate the consideration, but..."],[2565,2719,"I really should respect"],[2719,2844,"my mother-in-law's wishes."],[2902,2990,"Of course, Alice."],[3724,3958,"A missed opportunity, indeed."],[4200,4266,"Ally..."],[4312,4421,"there are things about our family"],[4421,4512,"that you don't know,"],[4546,4663,"especially Mr. Brown"],[4663,4788,"and his son..."],[4788,4842,"Michael."],[4946,5009,"He's..."],[5071,5167,"not a good man."],[5292,5326,"Why?"],[5326,5417,"What makes you say that?"]],"35":[[279,432,"Michael went abroad after failing"],[432,621,"to seize control of family business."],[696,796,"But now that he's back,"],[796,994,"he's looking to expand his reach."],[1105,1322,"And your connection to Max..."],[1372,1685,"makes you a valuable pawn in his games."],[2110,2193,"That's awful."],[2331,2525,"I refuse to be taken advantage of."],[2652,2799,"I really thought Mr. Brown was different."],[3057,3136,"Guess I was wrong."],[3136,3220,"Thank you, Emma."],[3340,3499,"Stay vigilant, Ally."],[3724,3778,"Now,"],[3837,3895,"tonight,"],[3949,4012,"dress well."],[4049,4262,"I've arranged a special"],[4262,4417,"family dinner for us."],[4521,4617,"And..."],[4617,4779,"Max will be there too."],[4896,4950,"Okay."],[5055,5167,"I'll be there. Thank you, Emma."]],"36":[[525,767,"So, Ally, have you had a chance to"],[767,909,"meet with Max yet?"],[909,1021,"Yes, we've met."],[1080,1163,"He's been very..."],[1297,1401,"enthusiastic."],[1472,1568,"Well, that's good to hear."],[1701,2056,"It's important that our family is united."],[2056,2143,"Right."],[2143,2193,"Yes."],[2569,2632,"What?!"],[2756,2902,"The warehouse is on fire?"],[2982,3057,"Shit!"],[3174,3244,"I need to go."],[3286,3474,"You stay here and wait for Max, okay?"],[3474,3528,"Okay."],[3624,3682,"God."],[4108,4208,"What is this traffic, Henry?"],[4208,4354,"We've been sitting here for like 15 minutes."],[4462,4512,"You know what?"],[4583,4692,"I'm gonna walk the rest."],[4692,4742,"I'll see you there."],[5030,5142,"Guess it's just me."],[5380,5463,"Alice!"],[5530,5622,"Oh, Max!"]],"37":[[162,263,"Alice!"],[263,496,"Oh, Max!"],[496,728,"I was beginning to think you got lost."],[788,842,"Not at all."],[950,1038,"It's lovely..."],[1038,1130,"to see you again."],[1176,1343,"I hope I haven't been keeping you waiting."],[1343,1547,"No, no, you haven't."],[1547,1672,"It's nice to see you too."],[1747,1860,"And I'm sorry about..."],[1939,2014,"the other night."],[2173,2227,"It's okay."],[2356,2454,"It wasn't your fault."],[2500,2585,"Besides, that's why"],[2585,2711,"my mother gave us a chance"],[2711,2873,"to get to know each other more, right?"],[2873,2936,"Yeah."],[3036,3179,"Thank you for making this work."],[3311,3378,"Sure."],[3503,3641,"What should we have?"],[3891,4016,"I tell you what,"],[4016,4162,"let's enjoy a drink,"],[4162,4258,"and then get out of here."],[4300,4437,"There's something..."],[4437,4587,"I want to show you."],[4708,4771,"Okay."],[4833,4879,"Great."],[6531,6602,"Mom,"],[6677,6723,"where are you?"],[6723,6905,"I can't seem to find you or Ally."],[6986,7161,"I'm dealing with the warehouse."],[7161,7298,"She might've left."],[7298,7419,"Next time, then."],[7419,7536,"I see."],[7653,7777,"Well, it's probably for the best."],[7903,8005,"Wasn't really in the mood"],[8005,8103,"to see her tonight anyway."]],"38":[[312,629,"Well, I thought we could have our own..."],[629,825,"private dinner here."],[1042,1172,"What do you think?"],[1267,1438,"It's beautiful, Max."],[1655,1943,"But why do you keep bringing me to hotels?"],[1956,2135,"Alice, I..."],[2218,2344,"I understand that..."],[2344,2498,"the last time wasn't..."],[2594,2731,"the right time,"],[2731,2940,"since I hadn't proposed..."],[3003,3073,"yet."],[3395,3478,"So..."],[3478,3616,"will you marry me?"],[3778,3908,"Max, um..."],[3908,4079,"this is all really sudden."],[4079,4195,"I... I need time."],[4500,4554,"Of course."],[4859,4954,"But..."],[5088,5271,"know that my feelings for you are genuine."],[5643,5864,"I know this is really frustrating for you."],[5918,5985,"I want you to know that"],[5985,6210,"I really do wanna make this work between us."]],"39":[[650,932,"What the fuck was that? Huh?"],[1080,1201,"I don't understand you."],[1280,1359,"You left..."],[1505,1634,"You left your stuff here..."],[1822,1931,"to seduce me,"],[2006,2060,"didn't you?"],[2327,2389,"Didn't you?"],[2606,2686,"You're nothing like"],[2686,2781,"what I imagined."],[2781,2844,"Max, I..."],[2923,3032,"I need time. I..."],[3065,3190,"I can't force myself."],[3190,3265,"I'm sorry."],[3265,3411,"Shut your mouth."],[3482,3631,"Just save your lies,"],[3661,3716,"okay?"],[3787,4083,"All you women are exactly the same."],[4145,4287,"Now,"],[4287,4383,"we can finish..."],[4466,4550,"what you started."],[4884,4934,"Never!"],[4963,5125,"You weren't like this before!"],[5125,5305,"You fucking bitch!"],[5672,5868,"You can't escape me, Alice!"]],"40":[[229,367,"I can't do this anymore."],[508,617,"I wanna divorce."],[759,871,"Ally, are you sure?"],[921,1116,"You were once so confident."],[1184,1280,"Why can't you"],[1280,1390,"try and work things out?"],[1647,1739,"I just can't."],[1776,1939,"The marriage isn't what I hoped for."],[2043,2118,"Sorry, Emma."],[2277,2435,"I understand your feelings, but..."],[2481,2688,"divorce is a serious step."],[2894,3048,"Are you certain you can't find a way"],[3048,3244,"to cultivate these feelings again?"],[3353,3386,"No."],[3549,3653,"I need to move on,"],[3724,3837,"for my own sake."],[4229,4308,"You know what?"],[4354,4475,"Ally keeps going behind my back"],[4475,4600,"and setting up dinners with my mom."],[4662,4763,"I can't stand that woman."],[4925,5096,"You know, sometimes I think how nice it would be"],[5096,5246,"if I were married to a woman like Alice."],[5417,5534,"You know someone who understands me,"],[5622,5768,"who connects with me on a deeper level."],[6006,6089,"You know what, man?"],[6143,6214,"Forget her."],[6331,6473,"Alice is a great woman and all, but..."],[6573,6669,"she's got a husband,"],[6727,6815,"and you have a wife..."],[6936,7011,"You need to..."],[7073,7152,"face reality."],[7665,7803,"Maybe it's time to end the charade."]],"41":[[713,788,"Hello, Mom."],[859,1088,"Max, Ally has agreed to the divorce."],[1088,1230,"It's going to be a clean break."],[1413,1534,"Really? That's great news."],[1642,1732,"How'd you get that gold digger"],[1732,1856,"to suddenly change her mind?"],[1935,2154,"She's never a gold digger, Max."],[2185,2327,"I want you to know that."],[2327,2487,"Yeah, yeah, yeah. Whatever you say, Mom."],[2677,2877,"Henry, Ally finally decided to divorce."],[2932,2969,"What?"],[3040,3148,"That's unbelievable!"],[3199,3265,"Let's celebrate!"],[3361,3478,"—Cheers! —Cheers!"],[4141,4191,"Mom?"],[4237,4320,"Mom, I'm home."],[4608,4838,"Fuck, this woman is so annoying!"],[4854,5019,"She came to my mom's house!"],[5034,5121,"What are you doing here?"],[5288,5430,"I told you to leave me alone."],[5497,5632,"I wanna move on with my life."],[5751,5839,"Have you no shame?"]],"42":[[54,213,"I wanna move on with my life."],[446,538,"Yeah, you've got no shame?"],[617,794,"Because see, on the surface, it seemed like..."],[821,950,"you would go to divorce,"],[992,1130,"and now you're here trying to seduce me!"],[1167,1301,"What are you talking about?"],[1351,1480,"I'm not trying to seduce you."],[1618,1725,"I'm done with your lies."],[1906,2022,"Not lying."],[2022,2110,"I came here to rest."],[2110,2256,"Emma said that I could rest here."],[2610,2740,"Save it for someone who cares."],[2919,2998,"I'm done with your games."],[3303,3500,"I'm not playing any games, Max."],[3987,4105,"That voice sounded..."],[4158,4214,"different."]],"43":[[721,950,"Alice, do you know that we've lost..."],[950,1205,"every one of our clients because of you?"],[1384,1496,"No, you can blame"],[1496,1664,"Mr. Thompson Brown for that."],[1664,1739,"Actually,"],[1739,1897,"no, I would blame Ally..."],[1897,1972,"for that!"],[1972,2252,"Hey, why don't you give me Max's divorce case?"],[2252,2519,"At least in my hands, I could save this law firm."],[2519,2615,"Oh,"],[2615,2790,"you know, I highly doubt that,"],[2790,2915,"plus Max wouldn't agree to that."],[3090,3294,"I already talked to him,"],[3294,3435,"and he already agreed."],[3553,3720,"Well, if that's the case,"],[3720,3962,"then I'll wait for him to confirm it with me."],[3962,4016,"Thank you."],[4233,4371,"Oh, Ally,"],[4371,4521,"do you see my work phone anywhere?"],[4521,4717,"I must have missed like 10 calls."],[4717,4850,"Why don't you..."],[4850,5023,"handle your own shit!"]],"44":[[750,855,"Alice, my wife is someone"],[855,963,"that we cannot trust."],[1042,1176,"Last night was just..."],[1176,1259,"so disappointing."],[1292,1401,"She came into my mom's home,"],[1493,1638,"and she tried to seduce me."],[1710,1789,"That's awful."],[1847,1980,"I'm really sorry, Max."],[2164,2248,"I have to ask you."],[2348,2414,"Did you..."],[2414,2648,"pass off the case to my boss,"],[2648,2706,"Steven?"],[2706,2781,"No."],[2781,2844,"No, why?"],[3015,3082,"No reason, I guess."],[3082,3148,"They just..."],[3148,3336,"wanted more information from me."],[3420,3570,"I can't stand that woman."],[3645,3778,"I mean, she probably got a certificate"],[3778,3953,"from the lawyer just to exploit me."],[4070,4179,"I can't comment on that."],[4291,4433,"But what I can say is that"],[4433,4625,"there are good lawyers and bad lawyers,"],[4625,4775,"and I would never do that to you."],[5192,5280,"That woman is nothing"],[5280,5384,"compared to you, Alice."],[5672,5726,"Max,"],[5834,5955,"I really don't wanna hurt you."],[6006,6151,"I can't be what you want me to be."],[6202,6327,"Let's just..."],[6327,6456,"try to finish this..."],[6456,6593,"and move on..."],[6623,6756,"with our lives amicably."],[7294,7377,"I see."]],"45":[[166,271,"Alice,"],[271,475,"I've lost so much money,"],[475,667,"and my firm is dying because of you!"],[717,975,"If I can't be happy, neither can you."],[975,1067,"You're gonna pay!"],[1197,1292,"Thanks for meeting me here again."],[1330,1372,"Of course."],[1447,1505,"You parked nearby?"],[1564,1697,"Oh no, I was just gonna..."],[1768,1847,"Oh, it's good, I..."],[1847,1943,"I parked right down this way."],[2002,2074,"Alice!"]],"46":[[129,208,"Max!"],[208,283,"Max, are you okay?"],[283,346,"Oh my god."],[346,404,"I'm gonna call."],[533,625,"No, my phone's broken..."],[625,696,"Okay, stay with me."],[696,771,"Don't worry."],[771,905,"Okay, stay with me."],[905,1055,"Stay with me..."],[1055,1117,"Max."],[1776,1835,"Alice?"],[1985,2035,"Max!"],[2160,2223,"You're awake."],[2364,2427,"How do you feel?"],[2527,2631,"Groggy."],[2761,2882,"What happened?"],[2882,3069,"You were in an accident."],[3069,3210,"You need to thank your wife,"],[3240,3503,"who carried you two blocks to get help."],[3699,3828,"You did that for me?"],[3862,4012,"You saved me too."],[4124,4279,"It's just a mild concussion"],[4279,4379,"from the crash."],[4379,4575,"You may experience symptoms such as"],[4575,4758,"headaches, dizziness,"],[4758,4913,"and some memory loss,"],[4913,5077,"but... this is all normal."],[5267,5380,"You hear that, Alice..."],[5480,5580,"I got a concussion."],[5672,5814,"Might be a little bit slow and stupid"],[5814,5905,"for the rest of my life."],[6001,6093,"Is that so?"],[6177,6239,"Yeah,"],[6239,6427,"I might need you to take care of me."],[6648,6815,"Well, if that's the case,"],[6815,6901,"then I will."],[7223,7353,"Don't you worry,"],[7353,7682,"this accident will not influence your..."],[7682,7774,"Pang!"],[7774,7882,"...sex life,"],[7882,7982,"or make you an idiot."],[8116,8258,"Actually, he's..."],[8258,8354,"not my husband..."],[8354,8437,"Oh, pardon me!"]],"47":[[125,188,"Sir!"],[271,371,"I've looked into the car accident."],[421,538,"We've managed to identify the car,"],[538,717,"but the police haven't found the driver yet."],[717,779,"Keep on it, Henry."],[817,867,"I only need you to"],[867,973,"look into and find out who did this."],[1026,1080,"Of course, sir."],[2173,2239,"Hello?"],[2239,2318,"Max,"],[2318,2418,"if you introduce me"],[2418,2570,"as the CEO's wife and board member"],[2570,2702,"at the upcoming business dinner,"],[2702,2865,"plus give me 20 million,"],[2865,2965,"I promise to divorce you."],[3011,3061,"Fine."],[3153,3269,"But this is going to be the last favor."]],"48":[[371,475,"Pleasure meeting you."],[475,646,"This is my wife, Ally."],[646,796,"She's the CEO of Legend Group,"],[796,915,"and she's the woman,"],[915,1071,"the chairwoman of the whole board."],[1096,1188,"Pleasure to meet you."],[1405,1493,"Ally,"],[1493,1618,"could you tell us about your company's"],[1618,1722,"current investment strategy?"],[2110,2185,"Well..."],[2331,2373,"It's..."],[2373,2548,"Or you could tell us anything at all..."],[2686,2767,"about the company."],[3061,3218,"If you don't have anything to say about that,"],[3303,3445,"maybe you have something to say about this."],[3657,3787,"It wasn't just me."],[3787,3908,"It was Ally"],[3908,4070,"who asked me to hit Alice and Max."],[4270,4337,"No!"],[4404,4529,"I had nothing to do with that!"],[4587,4784,"That... that's defamation! I..."],[4842,4946,"Why are you looking at me?"],[4946,5005,"It wasn't me!"],[5005,5038,"What?"],[5075,5125,"Henry!"],[5150,5267,"I... I swear!"],[5267,5367,"I... That wasn't..."],[5367,5447,"You guys!"],[5447,5551,"I'm being framed!"],[5551,5672,"Let me go!"],[5672,5793,"Let me go!"],[5851,5918,"No!"]],"49":[[75,154,"Alice!"],[221,325,"I have something for you."],[417,542,"The police recovered it from Ally."],[613,658,"Here you go."],[729,821,"My work phone."],[821,979,"I've been looking everywhere for this."],[1080,1207,"What are all these missed calls?"],[1284,1543,"Was Ally using my phone to call Max?"],[1989,2070,"—Hello? —Hello?"],[2223,2310,"Hold on..."],[2310,2373,"Wait..."],[2556,2658,"—IT'S YOU! —IT'S YOU!"],[2969,3090,"Why are you calling from her phone?"],[3186,3276,"I have something to tell you."],[3315,3445,"Meet me at Moonfall Lodge Restaurant."]],"50":[[567,621,"Boss."],[696,859,"I found out the truth about your wife."],[959,1038,"Henry,"],[1038,1130,"please, not now."],[1130,1247,"I'm supposed to be meeting Alice here."],[1297,1405,"Actually, sir,"],[1405,1519,"you're gonna wanna look at this,"],[1568,1672,"and you..."],[1672,1755,"should cherish her."],[1981,2160,"Do not mention this woman to me again."],[2264,2423,"The woman I care about is Alice."],[2523,2673,"You should know that by now, alright?"],[2765,2907,"I can't believe I'm still tied to this woman."],[3841,3928,"Alice?"],[4241,4316,"Not Ally?"],[4542,4700,"Alice Smith is..."],[4700,4796,"is the woman I married."],[4796,4879,"Not Ally?"],[5084,5205,"Alice."],[5205,5314,"Alice is my wife?"],[5434,5538,"Alice Smith?"],[5764,5834,"The woman I married..."],[5834,5926,"the name is Taylor."],[6043,6202,"It should be Ally Taylor."],[6243,6385,"She used her mother's last name"],[6385,6485,"after she lost her father."],[6531,6756,"And your wife's first name isn't Ally,"],[6756,6848,"it's Alice."],[6915,7115,"And also, she was in your class in college,"],[7115,7219,"but you never paid attention to her!"],[7298,7486,"You've known her for a long time."],[9759,9889,"It's really you!"],[9905,10016,"It's really you!"]]}