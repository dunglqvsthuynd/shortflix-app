saw the way you looked at Rosy."],[3532,3732,"Like you loved her."],[3828,4037,"It was just a contract, sweetie."],[4037,4183,"An act."],[4183,4379,"And I am so sorry for getting your"],[4379,4437,"hopes up."],[4437,4567,"So what, you're just going to go"],[4567,4738,"back to Tess now?"],[5088,5221,"You're sure?"],[5221,5522,"Okay, send over the footage right now."],[6001,6189,"Daddy, where are you going?"],[6189,6281,"Rosy's in trouble."],[6873,7061,"You said one fifty an hour?"],[7061,7211,"Yeah, unless you want to..."],[7211,7365,"add on a little special treat."],[7469,7674,"I can do any of those things to her?"],[7891,7991,"Great."],[8108,8320,"Put me down for two, four and uh..."],[8546,8692,"six."],[8692,8846,"We're going to have some fun tonight."],[8871,9092,"No, no! - Sweetheart"]],"53":[[25,95,"Hey!"],[137,283,"Let her go!"],[283,487,"Hey, what the hell, man?"],[487,608,"You think you can do what you want,"],[608,742,"rich boy?"],[742,975,"Well, you're in my territory now."],[975,1276,"And here, there's no rules."],[2218,2427,"You might be a big shot"],[2427,2656,"in your world, but in my world,"],[2656,2831,"you're just a paycheck."],[2936,3061,"No. No."],[3503,3632,"Look at that."],[3632,3820,"Pretty little thing, ain't she?"],[3820,3966,"Nothing like starting them out young."],[3966,4108,"Especially since her daddy won't be"],[4108,4233,"there to protect her any longer-"],[4233,4337,"Hey, Mitch."],[4738,4859,"Look at me."],[5321,5442,"Hey!"],[5580,5880,"Somebody, call an ambulance!"],[5955,6256,"You shouldn't have come after me."],[6381,6664,"I couldn't not come after you."],[6664,6831,"Because I love you,"],[6831,6931,"Rosy Dolores."]],"54":[[392,684,"You don't even know my real name."],[684,892,"I don't care."],[1142,1326,"Tad..."],[1326,1572,"this week, it was a fantasy."],[1572,1872,"We belong in different worlds."],[1901,2018,"And Lily..."],[2018,2173,"she deserves a mother she"],[2173,2318,"can be proud of."],[2335,2419,"No."],[2485,2615,"She needs a mother"],[2615,2777,"she can love."],[2777,2965,"That's not me."],[2965,3186,"I need to focus on finding"],[3186,3265,"my daughter."],[3340,3641,"My real daughter."],[3687,3903,"I'm sorry..."],[4137,4421,"I have to go."],[4421,4721,"Before you do..."],[4929,5113,"just tell me."],[5113,5413,"Do you love me too?"],[6443,6744,"I'm never in love."],[6798,7098,"Especially with a guy like you."],[7349,7482,"I'm sorry."],[8362,8662,"Detective Reinhardt..."],[8821,8871,"No!"]],"55":[[120,358,"No!"],[2761,2944,"Do I have to wear this dress?"],[2944,3048,"It's uncomfortable."],[3048,3211,"It's designer."],[3211,3420,"And yes, you do."],[3420,3632,"Society Magazine is covering your"],[3632,3816,"father's hotel signing tonight."],[3891,4004,"You wouldn't want to look like"],[4004,4158,"someone that just walked in off the"],[4158,4325,"street, now, would you?"],[4371,4462,"What's wrong with people"],[4462,4571,"from the street?"],[4579,4867,"They don't belong with people like us."],[4904,5055,"I wish Rosy was here."],[5075,5326,"You little brat!"],[5326,5530,"Rosy's gone,"],[5530,5684,"and I'm your mommy now."],[5759,5826,"Got it?"]],"56":[[12,212,"You'll never be my new mommy!"],[212,462,"I want Rosy, not you."],[462,600,"I'm your new mommy now,"],[600,759,"whether you like it or not!"],[759,867,"Let go of me!"],[950,1172,"You will not embarrass me."],[1217,1472,"You will be a good girl until your father"],[1472,1559,"and I are married."],[1655,1739,"And then it's off to"],[1739,1872,"boarding school for you."],[1964,2164,"Let's get rid of this ridiculous bunny."],[2164,2331,"It's time to grow up."],[6022,6151,"Oh, my God."],[6448,6564,"Lily is my daughter."]],"57":[[300,462,"Tonight, I am pleased to"],[462,592,"announce the new owner"],[592,729,"of the Parc Meridian Hotel Group,"],[729,892,"Tad Williams."],[1096,1247,"Once these papers are signed, Tad,"],[1247,1376,"it's all yours."],[1488,1597,"That's not the only"],[1597,1776,"thing that's his, Daddy."],[1818,2118,"I've decided to give Tad another try."],[2193,2323,"He's going to be spending a lot more"],[2323,2531,"time here now that he owns this hotel."],[2590,2806,"That's wonderful news."],[2806,3048,"We think so, too."],[3048,3186,"What do you say, Tad?"],[3186,3520,"Ready to sign on the dotted line?"],[3899,4079,"Wait!"],[4079,4137,"Rosy!"]],"58":[[41,246,"What is she doing here?"],[246,546,"I need to talk to Tad and Lily."],[575,829,"Get any closer and I'll tell everyone"],[829,967,"who you really are."],[992,1222,"Tad will lose his hotel,"],[1222,1418,"and that little girl will never look at you"],[1418,1526,"the same way again."],[1576,1881,"Will Lily ever forgive me if she knows"],[1881,2077,"who I really am?"],[2185,2423,"That's what I thought."],[2423,2585,"Now, go."],[2585,2723,"Quietly."],[2740,2894,"Don't worry."],[2894,3119,"I'll take good care of Lily."],[3169,3240,"No!"],[3732,3970,"I will take care of Lily."],[4124,4333,"Because I'm her mother."],[4458,4617,"What?"],[4617,4775,"Lily..."],[4863,4971,"you're my daughter."]],"59":[[37,112,"Tad..."],[208,316,"seven years ago,"],[316,617,"you and your wife adopted a baby girl."],[713,938,"She had a heart- shaped birthmark"],[938,1013,"on her neck."],[1134,1384,"And the most adorable little rolls"],[1384,1568,"you've ever seen."],[1714,2014,"And that baby girl was mine."],[2306,2531,"She was Lily."],[2840,3094,"I always knew you were my mommy."],[3144,3286,"This is ridiculous!"],[3286,3440,"She's lying."],[3891,4112,"I have proof, right here."],[4112,4383,"This is obviously fake."],[4383,4612,"She's just doing anything she can to"],[4612,4713,"get Tad back."],[4750,4888,"You're pathetic."],[4888,4938,"And you're"],[4938,5130,"embarrassing yourself."],[5130,5221,"No!"]],"60":[[825,992,"You made my mommy cry!"],[992,1146,"You little brat."],[1197,1351,"What did I say to you about"],[1351,1497,"causing a scene?"],[1543,1839,"Time to teach you a lesson."],[1839,2018,"Like I said, it's time for you"],[2018,2072,"to grow up."],[2122,2260,"No!"],[3261,3390,"Are you crazy?"],[3445,3541,"It's time for you to get"],[3541,3661,"what you deserve."],[3757,4012,"Don't touch my daughter or the"],[4012,4183,"mother of my child."]],"61":[[104,404,"You really believe her?"],[462,646,"She's playing you."],[646,821,"She's a prostitute."],[821,984,"And Tad paid her to"],[984,1134,"fake their relationship!"],[1172,1263,"Someone like Tad"],[1263,1438,"doesn't deserve this hotel."],[1438,1530,"Wait."],[1530,1780,"If anyone deserves this hotel,"],[1801,1893,"it's Tad."],[2035,2331,"When I lost my daughter,"],[2331,2631,"I was tormented, wondering"],[2706,3078,"who had her and if she was safe."],[3078,3286,"If she was loved."],[3345,3516,"And now I know."],[3516,3753,"And I could not imagine"],[3753,4054,"a man half as good as Tad"],[4079,4295,"to raise my baby girl."],[4654,4900,"That's a sweet story."],[4900,5092,"But it doesn't change the fact"],[5092,5234,"they lied to you, Daddy!"],[5276,5497,"Go ahead and rip up the contract."]],"62":[[0,250,"Go ahead and rip up the contract."],[371,500,"No."],[583,713,"No?"],[1272,1430,"No."],[1430,1655,"Tad, I'm happy to sign my hotel"],[1655,1755,"over to you."],[1755,1956,"Did you hear what I just said?"],[1968,2189,"You can't sell this hotel to Tad."],[2344,2489,"Actually, I can do whatever I want."],[2489,2644,"I own this hotel, not you."],[2673,2731,"But..."],[2765,3007,"they faked their relationship just so"],[3007,3165,"Tad wouldn't have to be with me."],[3178,3315,"And can you blame them?"],[3707,3845,"Go ahead, Tad."],[3845,4074,"Sign the papers and the hotel is yours."],[4379,4671,"Now, Tess, I believe you're wanted"],[4671,4729,"in the kitchen."],[4758,4938,"After all, there's a necklace you have"],[4938,5046,"to pay off."],[5455,5572,"Good luck, son."],[5572,5668,"And congratulations"],[5668,5822,"on your beautiful family."],[6694,6790,"Wait."],[6861,6973,"This says your daughter was born"],[6973,7082,"in January."],[7119,7269,"I was born in March."]],"63":[[759,938,"They doctored your birth certificate"],[938,1180,"to make it harder for me to find you."],[1359,1589,"Your real birthday is"],[1622,1960,"January 29th at 7:05 AM."],[2047,2110,"You were born"],[2110,2248,"during a snowstorm."],[2306,2448,"A snowstorm?"],[2448,2544,"I like that."],[2861,2927,"So,"],[3073,3236,"let's try this again."],[3557,3782,"I love you"],[3782,3912,"Rosy Dolores."],[4108,4325,"No, you love"],[4454,4571,"Sarah Clarke."],[4913,5055,"Sarah."],[5055,5105,"I like it."]]}