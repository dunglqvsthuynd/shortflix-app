n't have to play the hero."],[5935,6114,"In this story,"],[6114,6268,"there isn't one."],[6627,6752,"Rosy..."],[7374,7645,"What are you looking for,"],[7645,7745,"Rosy Dolores?"]],"44":[[475,671,"Rosy, I almost didn't believe you."],[671,817,"You're not into anything illegal"],[817,900,"now, are you?"],[900,1038,"Would you care if I was?"],[1197,1238,"Nope."],[1238,1334,"I told you."],[1334,1497,"I want you to step up the search"],[1497,1634,"for my daughter to full time."],[1697,1822,"How long will this buy me?"],[1822,1981,"About another week."],[2027,2193,"I'll have another $50,000 on Friday."],[2193,2339,"Another $50,000?"],[2360,2464,"I need to find her."],[2464,2698,"Steven, this is my only chance."],[3332,3465,"Oh, can I help you, sir?"],[3465,3578,"The woman who just left."],[3578,3682,"What was she doing here?"],[3682,3778,"She's a client."],[3778,4083,"That's privileged information."],[4558,4637,"What..."],[4725,4796,"was she doing here?"],[4796,4988,"She's looking for her daughter, sir."]],"45":[[0,95,"Her daughter?"],[95,191,"Her daughter was taken"],[191,304,"from her at birth."],[304,487,"She's hired me to look for her."],[504,613,"And..."],[613,746,"have you found anything?"],[1146,1217,"The convent"],[1217,1397,"where she says she gave birth at."],[1455,1543,"Sacred Heart."],[1584,1747,"And before they could investigate."],[2093,2252,"The place burned down."],[2252,2410,"Any files they may have had"],[2410,2535,"were incinerated."],[2535,2690,"Does Rosy know this?"],[2690,2898,"She's not paying me to deliver"],[2898,2998,"bad news."],[3032,3282,"But she is paying you to find her"],[3282,3361,"daughter, right?"],[3365,3532,"I am a businessman."],[3532,3832,"Something that you surely understand."],[3887,4183,"Now, if you will excuse me."],[4346,4646,"I am closed for lunch."],[5088,5267,"Rosy, look!"],[5267,5488,"It's us as a family."],[5505,5580,"Lily,"],[5580,5751,"you know we're just pretending,"],[5751,6001,"right? In just two days,"],[6001,6168,"you go back to your life"],[6168,6368,"and I go back to mine."],[6443,6589,"I know, I hoped you could"],[6589,6673,"be my mommy."],[7503,7711,"Lily, what happened to your neck?"]],"46":[[200,358,"Is it that bad?"],[358,517,"Am I ugly?"],[517,817,"No, no, of course not."],[1096,1309,"Where did you get that scar?"],[1309,1568,"I've had it ever since I was little."],[1568,1722,"It's from a biopsy."],[1722,2022,"They usually biopsy birthmarks."],[2027,2077,"Lily, did-"],[2077,2369,"did your birthmark look like this?"],[2369,2506,"Yes it did!"],[2506,2744,"Could Lily be my daughter?"],[2744,2977,"Is your birthday in January?"],[2977,3111,"January?"],[3111,3395,"No, I was born on March 13th"],[3395,3616,"in Mercy Hospital in New York City."],[3616,3807,"Rosy, your daughter was born"],[3807,4033,"in January in the broom closet of a"],[4033,4133,"backwoods convent."],[4204,4346,"Lily's not yours."],[4346,4479,"No matter how much you"],[4479,4625,"wish she was."],[4625,4767,"Your real daughter is out"],[4767,4967,"there, somewhere, waiting for you."],[5017,5238,"And you need to find her."],[5238,5334,"Why, Rosy?"],[5334,5480,"Oh, I just want to make sure I get you"],[5480,5572,"a birthday present."],[5726,5872,"Thanks, Rosy."],[6915,7102,"This a bad time?"],[7102,7403,"Come on in."],[7444,7599,"Listen..."],[7599,7749,"about- - Rosy."],[7749,7987,"I know about your daughter."],[7987,8124,"My? - Your daughter."],[8124,8337,"The one taken from you at birth."],[8437,8550,"How?"]],"47":[[0,196,"How? - Does it matter?"],[196,296,"It matters!"],[342,454,"That's my business!"],[454,625,"Wait, wait, wait."],[625,742,"Don't walk away from me, not"],[742,792,"over this."],[792,988,"I want to help you find her."],[988,1259,"Help me? Why would you help me?"],[1338,1630,"Because I..."],[1630,1805,"I can only imagine"],[1805,2106,"what it would feel like to lose Lily."],[2110,2352,"It would- - Destroy you."],[2352,2489,"Exactly."],[2489,2619,"Tell me about her."],[2806,3165,"She was the most beautiful thing I'd"],[3165,3224,"ever seen."],[3236,3507,"And losing her was the worst"],[3507,3682,"moment of my entire life."],[3687,3862,"That's why you agreed to the deal."],[3862,4112,"I would do anything to find her."],[4112,4412,"Then let me help you."],[4550,4754,"I promise..."],[4754,4863,"I will find your daughter."]],"48":[[3995,4129,"What are you doing here?"],[4129,4266,"Oh, I thought we could"],[4266,4429,"have a little chat."],[4429,4617,"Where are Tad and Lily?"],[4617,4767,"Looks like they're looking"],[4767,4917,"at schools for Lily."],[4942,5084,"Isn't that sweet?"],[5084,5242,"Seems like they're planning on sticking"],[5242,5384,"around after all."],[5442,5743,"Too bad you won't be around."],[5826,5989,"Rosy Dolores."],[5989,6197,"The most sought after escort"],[6197,6318,"in the city."]],"49":[[8,150,"I have to say, it's kind of"],[150,396,"impressive that Tad would hire someone"],[396,542,"just to stay away from me."],[571,671,"Kind of makes me want"],[671,775,"him even more."],[775,942,"And what about the little girl?"],[942,1067,"You planning on telling her?"],[1067,1209,"Or should I show her?"],[1209,1368,"You wouldn't."],[1376,1572,"I would."],[1572,1735,"You think a world like this"],[1735,1885,"belongs to you?"],[1922,2156,"You're nothing but a common whore."],[2156,2444,"Tad Williams isn't your fiancé, and Lily"],[2444,2556,"isn't your daughter!"],[2581,2731,"What do you want from me?"],[2731,3098,"Leave here right now and go quietly."],[3128,3340,"They won't be surprised anyway."],[3340,3470,"Prostitutes are"],[3470,3674,"notoriously untrustworthy."],[3707,3991,"Can I, at least, leave them a note?"],[3991,4237,"Not going to happen."],[4245,4491,"Your taste of the good life is over."]],"50":[[212,483,"Rich boy finally got sick of you, huh?"],[483,600,"I knew it was just a matter of time"],[600,767,"before he finally saw you for what"],[767,817,"you really are."],[842,992,"A mangy mutt."],[1013,1076,"Mitch."],[1380,1568,"I know a lot of