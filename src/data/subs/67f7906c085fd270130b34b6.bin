,7248,"It can be whatever you want it to be."],[8871,9000,"Hey!"],[9000,9150,"That's my mommy!"]],"5":[[325,454,"Hey!"],[454,625,"That's my mommy!"],[734,788,"Hey, kid,"],[788,863,"wait!"],[1042,1209,"Hey, Mommy!"],[1209,1267,"Hey, hey, hey!"],[1267,1368,"What's going on?"],[1368,1505,"That's my mommy!"],[1935,2198,"Lily, honey, we've been over this."],[2335,2481,"Your mommy's right here."],[2652,2806,"Always in your heart."],[2806,2965,"I mean, my real mommy."],[2965,3174,"The one that gave birth to me."],[3174,3340,"The adoption agency said Lily's"],[3340,3470,"mother died in childbirth."],[3470,3607,"She can't keep hoping"],[3607,3745,"to find her again."],[3745,3983,"Sweetie, your real mom is gone."],[3983,4116,"You know that."],[4116,4279,"But that lady has the same birthmark"],[4279,4416,"I used to have."],[4954,5100,"Sweetie, a lot of people"],[5100,5192,"have birthmarks."],[5192,5317,"And you remember why you got"],[5317,5442,"yours removed, right?"],[5442,5605,"To make sure it wasn't dangerous."],[5605,5801,"Well, we should tell that lady to get hers"],[5801,5980,"removed, too."],[6364,6664,"Something tells me she'll be just fine."],[6794,6927,"Let's go."],[7478,7553,"Louis."],[7553,7665,"We're going to be late."],[7665,7828,"Park Meridian, and step on it."],[8696,8896,"Hello?"],[8896,9125,"You might want to stop wasting time."],[9125,9300,"I charge by the minute."],[9401,9505,"Hello?"]],"6":[[279,458,"Word on the street is"],[458,658,"you made quite the lucrative business"],[658,734,"for yourself since you"],[734,821,"left me, Rosy."],[842,1001,"$10 a minute."],[1138,1322,"Clearly, I've been undercharging"],[1322,1438,"for you."],[1655,1914,"Let me go, Mitch."],[1914,2173,"I don't work for you anymore."],[2173,2293,"You think you can just walk"],[2293,2473,"away from me?"],[2477,2644,"That's not how this works,"],[2644,2873,"my sweet little Rose."],[2873,3082,"You're my prized pony."],[3082,3203,"And I can't just have my prized"],[3203,3399,"pony trotting off now, can I?"],[3908,4129,"I don't belong to you."],[4129,4429,"You're disgusting."],[4587,4746,"You ungrateful bitch!"],[4746,4963,"I made you what you are and"],[4963,5071,"everything you have,"],[5088,5301,"you owe to me."],[5359,5492,"You?"],[5551,5768,"That Rolex on your wrist?"],[5768,6031,"Your mansion on the east end?"],[6031,6285,"Everything you own,"],[6285,6456,"my body paid for!"],[6698,6956,"And what a great body it is."],[6956,7257,"I'm done with you, Mitch."],[7307,7478,"The only way you'll ever leave me"],[7478,7653,"is in a body bag."],[7932,8195,"You're just a little whore."],[8195,8375,"And if I killed you,"],[8375,8675,"no one would ever miss you!"],[8867,9017,"Brad."],[9079,9242,"Tess."],[9384,9505,"Sorry we're late."],[9505,9655,"Bad traffic."],[9655,9822,"You can make it up to me later"],[9822,10126,"over dinner, perhaps."],[10151,10331,"I've missed you, Tad."]],"7":[[108,212,"Should we get down to business?"],[212,396,"Yes, I'm eager to discuss your offer"],[396,513,"to buy this hotel."],[521,671,"It looks very promising."],[917,1151,"Not so fast, missy."],[1151,1455,"Time for you and I to have a little chat."],[1618,1810,"I know you're the reason your"],[1810,1931,"father dumped me,"],[1935,2160,"you little brat."],[2160,2414,"Maybe he just realized"],[2414,2615,"he deserves someone..."],[2615,2719,"better than you."],[2761,2915,"There is no one better than me,"],[2915,3148,"you little..."],[3303,3490,"sweet thing."],[3490,3607,"You can't keep me away from"],[3607,3791,"your father forever."],[3832,4033,"And when I get him back,"],[4033,4183,"which I will,"],[4183,4375,"you're going to boarding school"],[4375,4546,"in Switzerland."],[4608,4817,"And you can kiss bye-bye"],[4817,5046,"to your little life together."],[5117,5384,"You might be daddy's little girl,"],[5384,5476,"but you're too young to"],[5476,5647,"understand the power"],[5647,5797,"of a woman."],[6006,6193,"You know that little rule?"],[6231,6427,"Not sample what I'm selling?"],[6481,6648,"I'm about to break it."],[6673,6823,"From now on, I take"],[6823,6973,"everything you make."],[6981,7127,"And you can kiss that search"],[7127,7303,"for your little daughter,"],[7353,7428,"goodbye!"]],"8":[[734,946,"Never underestimate"],[946,1084,"the power of a mother!"],[2185,2298,"It's her..."],[2506,2740,"She has my eyes."],[2994,3061,"Where the hell do"],[3061,3136,"you think you're going?"],[3199,3378,"I need to see that little girl."],[3378,3607,"I think she's my daughter!"],[3607,3899,"That little girl is Lily Williams,"],[3899,4058,"daughter of billionaire"],[4058,4200,"Tad Williams."],[4287,4558,"There is no way you're her mother."],[4558,4671,"I just need to see if she"],[4671,4779,"has a birthmark."],[4779,4892,"A birthmark?"],[4892,5067,"What kind of sicko are you?"],[5067,5234,"You won't get within an inch"],[5234,5347,"of that little girl"],[5347,5401,"ever!"],[5434,5572,"Actually,"],[5572,5689,"I will."],[5689,5930,"Security!"],[5985,6114,"No! Stop!"],[6118,6281,"I need to see her!"],[6281,6523,"As I expected, your offer is solid."],[6523,6677,"Let me run it by my lawyer and we can"],[6677,6798,"settle things up on Friday."],[6798,6990,"But, you know, I'd be inclined to sign"],[6990,7219,"everything over to you right now"],[7282,7457,"if you just got back with my Tessy."],[7457,7657,"I'd love to have you as a son-in-law."],[7716,7841,"Keep the hotel in the family."],[7937,8087,"I'll work on him, Daddy."],[8204,8404,"Over dinner tonight, right?"],[8404,8554,"I'll make us a reservation."],[8554,8700,"Something romantic."],[8963,9063,"You don't understand,"],[9063,9180,"that's my daughter!"]],"9":[[4,87,"You don't understand,"],[87,204,"that's my daughter!"],[204,296,"Oh, right, and I'm the"],[296,425,"Queen of England."],[446,563,"I'm serious!"],[563,725,"Get off me!"],[971,1126,"What is going on here?"],[1126,1242,"I'm so sorry, sir."],[1242,1422,"We were just getting rid of her."],[1422,1639,"How did trash like her"],[1639,1789,"even get in here?"],[1805,1968,"We're looking into that."],[1968,2173,"Daddy, I think you should fire all of"],[2173,2289,"them for letting people from the"],[2289,2565,"street just wander into our hotel."],[2656,2756,"After all,"],[2781,2952,"there are children here."],[3328,3536,"You didn't actually think that"],[3536,3737,"someone would pay for you, did you?"],[3803,3966,"At this hotel?"],[4045,4175,"Get her out of here."],[4195,4308,"Right away, Miss Thorne."],[4346,4525,"There's no birthmark."],[4525,4662,"She's not my daughter."],[4700,4817,"I was wrong."],[4817,5025,"Okay, I'm going."],[5050,5155,"Wait!"],[5155,5280,"Mommy, you can't go!"]],"10":[[4,145,"Mommy, you can't go."],[233,375,"Mommy?"],[467,571,"That's right."],[571,729,"She's my daddy's fiancée,"],[729,846,"and my new mommy."],[846,963,"Right, Daddy?"],[963,1084,"Uh."],[1547,1668,"You see..."],[1668,1793,"Daddy couldn't get back together"],[1793,1956,"with you even if he really, really"],[1956,2052,"wanted to."],[2052,2181,"Because he's engaged..."],[2181,2298,"to her."],[2298,2519,"To her?"],[2519,2740,"There's no way he'd get engaged to"],[2740,2857,"someone as low class"],[2857,3040,"as this woman."],[3044,3261,"If you can even call her a woman."],[3340,3532,"Then why does she have his coat?"],[3762,3941,"I don't understand."],[4612,4913,"You. You can't be serious!"],[5063,5188,"Promise me, Daddy,"],[5188,5326,"that you'll never get back together"],[5326,5405,"with Tess."],[5534,5659,"I am serious."],[5697,5822,"Tess,"],[5843,6143,"this is my fiancée, Rosy."],[6243,6348,"Rosy Dolores."],[6418,6589,"That name sounds fake."],[6631,6931,"I can assure you, it's perfectly real."],[7061,7357,"Just go with it, please."],[7620,7707,"Oh no."]],"11":[[283,367,"I'm sorry."],[367,542,"Is this woman bothering you?"],[542,767,"Let me just take her off your hands."],[767,942,"Sometimes she forgets her place."],[942,1222,"Think she can talk to guys like you."],[1222,1472,"Don't touch her."],[1472,1605,"Fuck, man."],[1605,1764,"Don't tell me what to do."],[1764,1910,"She belongs to me."],[1910,2227,"Rosy belongs to nobody but herself!"],[2243,2293,"Ha!"],[2327,2515,"That's what you think?"],[2515,2815,"She's nothing but a lowly whore."],[2902,3032,"I knew it."],[3032,3178,"I tell you what, man."],[3178,3319,"You want her so bad?"],[3319,3432,"Why don't you pay me for her,"],[3432,3549,"rich boy?"],[3782,3899,"It’s ok."],[4012,4250,"Don't insult my fiancée!"],[4250,4387,"Fiancée?"],[4387,4517,"That's right."],[4517,4633,"I'm his..."],[4633,4817,"fiancée."],[4896,5088,"And, um..."],[5088,5167,"this man..."],[5167,5292,"is bothering me."],[5292,5380,"No!"],[5380,5618,"This stupid bitch is lying to you."],[5618,5722,"Mr. Thorne,"],[5722,5864,"do you mind if I"],[5880,6022,"handle this myself?"],[6056,6164,"By all means."],[6164,6297,"This hotel will be yours on Friday,"],[6297,6435,"after all."],[6435,6735,"Get this man out of here"],[6760,6952,"and make sure he never steps foot"],[6952,7032,"in this hotel"],[7032,7294,"or any other Meridian property"],[7294,7415,"ever again!"],[7440,7578,"Of course."],[7578,7728,"And after you're done escorting him"],[7728,7932,"out, make sure you drop off your badge"],[7932,7999,"at the desk."],[7999,8087,"What?"],[8087,8316,"You humiliated my fiancée."],[8316,8437,"So you're fired."],[8437,8737,"But I've worked here for years!"],[8758,8900,"Then I'd like to clean house."],[8900,9134,"Mr. Thorne, I would like a full"],[9134,9288,"audit of your staff."],[9330,9634,"This is not the type of hospitality"],[9634,9934,"I expect for my hotel employees."],[9943,10080,"Of course."],[10410,10497,"You can't hide behind a"],[10497,10623,"rich man forever."],[10681,10844,"Mark my words."],[10844,11040,"You're a dead woman."],[11106,11177,"Dead!"]],"12":[[0,204,"Well, I guess congratulations are"],[204,296,"in order."],[296,433,"As much as I wish it would have worked"],[433,596,"out between you and my daughter,"],[604,829,"I'm glad you found someone special."],[829,971,"Both of you."],[971,1076,"Come on, Tess."],[1076,1251,"Let's leave these lovebirds alone."],[1597,1864,"I don't know who you are"],[1864,2106,"or where you came from,"],[2106,2210,"but I'm going to find out"],[2210,2360,"the truth about you,"],[2360,2573,"Rosy Dolores!"],[2598,2802,"Just you wait."],[3103,3290,"Thank you for standing up for me."],[3290,3415,"But..."],[3465,3574,"I'm going to go."],[3574,3695,"Wait."],[3770,3912,"I wasn't joking."],[3966,4133,"Pretend to be my fiancée."],[4133,4275,"Just until Friday."],[4358,4475,"Why?"],[4475,4708,"It'll get that woman off my tail."],[4871,5071,"Yeah, she's delightful."],[5280,5497,"I'm sorry, but I can't."],[5626,5918,"I have other things I have to focus on."],[5918,6218,"I'll pay you $100,000."],[6218,6368,"That could pay for a full time"],[6368,6535,"investigation into my daughter."],[6911,7207,"Do you know who I am?"],[7294,7595,"Do you know what I am?"],[7645,7770,"You're the kind of woman"],[7770,7945,"who looks like she could use a break."],[8124,8266,"Aren't you?"],[9009,9146,"Okay."],[9267,9380,"I'm in."]],"13":[[154,396,"Yay, mommy!"],[571,658,"Lily, sweetie."],[658,829,"This is only make believe."],[829,959,"Just until Friday."],[959,1121,"I know that."],[1334,1405,"Now."],[1488,1601,"Where should I send"],[1601,1676,"for your things?"],[1726,1931,"My things?"],[1931,2035,"Your clothes."],[2035,2156,"Personal items."],[2156,2414,"Oh, this is all I have."],[2414,2619,"But I don't understand."],[2648,2882,"You'll live with us for the week."],[2923,3090,"Me and Lily."],[3178,3253,"Come on."],[3278,3432,"This is going to be fun!"],[3716,3899,"Welcome to your new life."],[4550,4733,"Here are your clothes."],[4733,4850,"You will receive a hot meal"],[4850,4934,"three times a day."],[4934,5121,"And showers are on Fridays."],[5159,5347,"Welcome to your new life."],[5347,5538,"Where is my baby?"],[5576,5776,"What did you do with my baby?"],[5818,5964,"She's somewhere she will be well"],[5964,6035,"take