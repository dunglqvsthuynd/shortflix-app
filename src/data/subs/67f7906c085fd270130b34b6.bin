or"],[2252,2356,"sentimental reasons."],[2460,2752,"Your secret is safe with me."],[2752,2894,"And trust me."],[2894,3032,"I need this to work just"],[3032,3140,"as much as you do."],[3140,3257,"Great."],[3257,3424,"Then it's time to start pretending"],[3424,3578,"that we are in love."],[3657,3841,"And how do we do that?"],[3974,4087,"Well,"],[4137,4379,"I need to be able to touch you."],[4379,4542,"Like, how?"],[4625,4808,"Like this."],[4979,5109,"And like..."],[5234,5321,"this."],[5509,5789,"And maybe even like..."],[5789,5876,"this."],[5876,5968,"No!"],[5993,6122,"No kissing."],[6122,6206,"What?"],[6206,6356,"I don't kiss anyone, ever."],[6356,6510,"Not even when you're in love?"],[6602,6744,"I'm never in love."],[6827,6952,"Well, you haven't met"],[6952,7036,"a guy like me before."]],"16":[[316,658,"I have met a million guys like you."],[779,1080,"And trust me, if I were to fall in love,"],[1138,1438,"it wouldn't be with a guy like you."],[1730,2031,"Okay, there is one more thing."],[2156,2306,"Lily and I..."],[2306,2606,"we are a package deal."],[2656,2781,"So you need to be able to pretend"],[2781,2894,"to be her mother."],[2936,3061,"Is that a problem?"],[3061,3361,"Pretend to be her mother..."],[3436,3591,"Obviously, if you were her real"],[3591,3695,"mother, you would have had to have"],[3695,3866,"her when you were, what, 16?"],[3866,4104,"Wait, how old is Lily?"],[4129,4212,"I'm seven."],[4237,4358,"Seven years old."],[4358,4517,"That's exactly how old my"],[4517,4617,"daughter would be."],[4617,4850,"But she's not yours, Rosy."],[4850,5017,"You need to focus on finding"],[5017,5117,"your real daughter."],[5117,5230,"And this guy's money"],[5230,5417,"is the key to that."],[5551,5851,"Of course I'll be your mother."],[6285,6464,"Oh! - It's a baby girl."],[6464,6594,"A girl!"],[6769,7069,"Now, I have a meeting to get to."],[7407,7574,"Lily..."],[7574,7716,"you know what to do."],[7841,7987,"We're going shopping, Mommy."]],"17":[[12,120,"Shopping?"],[166,467,"What's wrong with what I have on?"],[588,788,"Trust me, when I'm done with you,"],[788,1009,"no hotel manager will ever talk down"],[1009,1088,"to you again!"],[2677,2811,"This is the most beautiful thing"],[2811,2890,"I've ever seen."],[2948,3144,"You should definitely try it on."],[3249,3541,"I couldn't wear something like this."],[3541,3716,"Of course you can!"],[3716,3962,"It would look perfect on you."],[3962,4129,"Clothes like this"],[4129,4462,"aren't made for people like me."],[4462,4583,"That's right."],[4583,4746,"They don't."],[4838,4950,"How can I help you?"],[4963,5213,"Yes, we're looking for two cocktail"],[5213,5359,"dresses, three sundresses,"],[5384,5547,"a hat, sunglasses and"],[5547,5684,"five pairs of shoes."],[5822,5947,"I don't think we have what you're"],[5947,6068,"looking for."],[6068,6222,"What are you talking about?"],[6222,6310,"You have, like,"],[6310,6427,"a million dresses here."],[6493,6619,"We don't have anything here"],[6619,6794,"for your mommy, sweetie."],[6819,6948,"Not for people like her."],[7203,7344,"You're better off at the discount"],[7344,7478,"rack at Goodwill."],[7515,7741,"That is where you got this hideous"],[7741,7982,"outfit from, isn't it?"],[8078,8220,"Well..."],[8220,8445,"get the fuck out!"]],"18":[[66,208,"Excuse me?"],[208,329,"You heard me."],[329,479,"Unless you're sartorially"],[479,608,"deaf and blind."],[608,775,"Her outfit isn't hideous."],[775,984,"I think it looks nice on her."],[1030,1230,"You see what you're teaching your child?"],[1230,1393,"Dressing like that."],[1393,1618,"In fact, there's a dress code"],[1618,1693,"policy here."],[1743,1976,"And you're violating it."],[1976,2043,"Me?"],[2068,2193,"You're showing more skin"],[2193,2298,"than I am."],[2406,2669,"This is Valentino couture."],[2669,2927,"It's an entirely different story."],[2927,3153,"Do you know how much this cost?"],[3153,3390,"$15,000."],[3495,3628,"There's a difference between looking"],[3628,3866,"elegant like me and cheap like you."],[3958,4129,"Do you know how many lives"],[4129,4237,"you could change with that"],[4237,4295,"kind of money?"],[4329,4471,"Why would I want to change anyone's"],[4471,4617,"pathetic little life?"],[4788,4863,"How did you even"],[4863,5013,"find this store, anyway?"],[5013,5184,"My daddy owns it."],[5376,5538,"What kind of lies are you spewing"],[5538,5676,"to this child?"],[5689,5797,"Making her think that"],[5797,5989,"Tad Williams is her father."],[6039,6168,"You probably don't even know"],[6168,6327,"who her real father is."],[6510,6623,"Come on, Lily."],[6623,6735,"Let's go."],[6735,6931,"Does your daughter know who you are?"],[6977,7161,"That you're a prostitute?"]],"19":[[12,141,"What's a prostitute?"],[141,237,"Sweetie,"],[262,475,"it's when a woman who sells her body-"],[475,563,"Stop talking!"],[592,809,"Right now. We're leaving, okay?"],[809,925,"Just let us go!"],[925,1238,"Oh, people like you make me sick!"],[1251,1347,"Why don't you just go and get"],[1347,1426,"a regular job?"],[1468,1589,"Selling your body?"],[1630,1864,"You are a disgrace!"],[2110,2344,"Don't you have any shame?"],[2573,2673,"Please."],[2673,2915,"I'm a hard worker and I need the"],[2915,3078,"money to find my daughter."],[3115,3190,"If you can't even"],[3190,3324,"keep track of your daughter,"],[3324,3436,"why should I trust you"],[3436,3528,"with my schedule?"],[3570,3737,"You want a job?"],[3799,3916,"Go to college."],[5230,5351,"Oh, hey."],[5509,5797,"You want some quick money?"],[5797,5935,"I can help."],[6035,6272,"I'm not ashamed of who I am."],[6335,6519,"But you should be."],[6673,6769,"Come on, Lily."],[6769,6827,"That's from..."],[6827,7023,"that's from the Children's line."],[7023,7123,"You stole it!"]],"20":[[91,350,"What? This is my coat."],[350,554,"And you expect me to believe that?"],[554,767,"This coat cost $1,000."],[842,1021,"Don't touch her!"],[1021,1259,"A whore and a thief."],[1259,1413,"Oh, I should have known."],[1413,1714,"We didn't steal it, it's my coat."],[1718,1901,"That's couture."],[1901,2147,"No prostitute could afford to pay that"],[2147,2248,"for her child."],[2314,2435,"Give us the coat back."],[2435,2665,"It's freezing outside!"],[2665,2815,"Then go give someone a quickie"],[2815,2969,"in the alley to pay for a new one."],[3040,3207,"How much do you charge?"],[3207,3340,"$5.00?"],[3399,3574,"It's going to take a lot of quickies"],[3574,3728,"to pay for that coat."],[3824,4087,"Hand it over, now!"],[4366,4537,"This might ruin my deal with Tad"],[4537,4738,"and cost me everything."],[4746,4938,"But I can't let this little girl freeze"],[4938,5042,"outside in the cold."],[5555,5855,"We will not hand over this coat."],[5972,6177,"You don't want to do that. Trust me."]],"21":[[0,129,"You don't want to do that,"],[129,237,"trust me!"],[237,337,"Ow!"],[496,754,"You broke my arm, you crazy bitch!"],[754,959,"You haven't seen crazy."],[959,1259,"Oh, I am calling the cops!"],[1422,1634,"If I cause a scene at Tad's boutique,"],[1634,1797,"he could cancel our deal."],[1801,1985,"But I can't let this little girl"],[1985,2102,"go outside without a coat"],[2102,2252,"in the middle of winter."],[2252,2464,"I'm sure Mr. Williams will reward"],[2464,2698,"me handsomely for stopping a"],[2698,2886,"shoplifter at his store."],[3040,3436,"And I'm sure he will love the publicity"],[3440,3557,"this will bring."],[3595,3787,"Prostitutes frequenting"],[3787,3928,"his store?"],[3928,4170,"That'll be great for his brand."],[4170,4366,"Let's go, Lily."],[4366,4491,"We're leaving,"],[4491,4667,"with the coat."],[5096,5326,"Get to my Broadway store..."],[5326,5367,"now!"]],"22":[[37,296,"Thanks for standing up for me in there."],[296,421,"It's my fault."],[421,521,"If you hadn't been with"],[521,625,"me, none of this"],[625,746,"would have happened."],[1021,1226,"If I hadn't been with you,"],[1226,1443,"I wouldn't have a coat right now."],[1605,1668,"Why was that woman"],[1668,1826,"so mean to you?"],[1997,2122,"Well, sometimes"],[2122,2360,"people are pretty on the outside"],[2360,2498,"and ugly on the inside."],[2598,2736,"I'd rather be ugly on the outside"],[2736,2898,"and pretty on the inside."],[3011,3278,"Lucky for you, you are pretty on"],[3278,3507,"the inside and the outside."],[4308,4441,"Perfect."],[4441,4637,"Let's get you some hot chocolate."],[4637,4859,"I know the best place."],[5701,5772,"Oh!"],[5772,5930,"Mr. Williams, I didn't realize"],[5930,6072,"you were coming in today."],[6089,6247,"I would have laid out all the finest"],[6247,6339,"pieces for you."],[6339,6523,"Oh, that won't be necessary."],[6623,6823,"I understand that you accosted"],[6823,6990,"my daughter in this store today?"],[7036,7111,"What?"],[7111,7207,"I would never."],[7269,7382,"And I would've known if your"],[7382,7499,"daughter had come in here today."],[7857,7920,"Clearly not."]],"23":[[16,120,"I didn't realize she"],[120,187,"was your daughter, sir."],[187,337,"So if she was just some poor"],[337,550,"kid off the street, ripping her coat off"],[550,638,"her would be okay?"],[658,775,"I thought it was stolen."],[775,938,"So what if it was?"],[938,1117,"I would rather let a kid in need"],[1117,1309,"walk out of here with an overpriced"],[1309,1484,"coat, than let them freeze in the cold!"],[1547,1705,"This is a misunderstanding."],[1760,1901,"You have to understand"],[1901,2122,"that the woman that she was with,"],[2122,2185,"she was-"],[2185,2235,"Was what?"],[2360,2527,"She was"],[2527,2702,"a whore."],[2902,3028,"That whore"],[3028,3194,"is my fiancée!"],[3390,3691,"And now this store is out of business."],[3757,4033,"And that's too bad, because she and"],[4033,4166,"my daughter were prepared to spend"],[4166,4400,"a fortune in here today!"],[4421,4558,"And at twenty-five percent,"],[4646,4783,"could have bought yourself"],[4783,5084,"ten more of those hideous shirts."],[5146,5296,"Pack up everything,"],[5296,5380,"this store is now closed."],[5822,5935,"What?"],[5935,6210,"No. No, no, no, no, no."],[6310,6427,"No!"]],"24":[[179,237,"You're right."],[237,371,"This is the best hot chocolate"],[371,429,"in the city."],[492,688,"I can't believe it's from a corner store."],[721,1030,"Well, sometimes the best things"],[1030,1176,"aren't the most expensive."],[1209,1368,"That's not what Tess thinks."],[1438,1651,"What's the deal with Tess?"],[1651,1822,"She and my dad dated for a bit."],[1897,2010,"Then he dumped her."],[2110,2193,"She said she's going"],[2193,2381,"to win him back and then send me"],[2381,2498,"off to boarding school."],[2540,2727,"What? Why?"],[2727,2857,"So she can be alone with"],[2857,2915,"my daddy"],[2952,3044,"without me."],[3044,3215,"Who wouldn't want to be around"],[3215,3345,"you all the time?"],[3432,3670,"If you were my daughter,"],[3670,3816,"I would want to be around you"],[3816,4149,"every single minute of every single day."],[4237,4483,"Your daddy is very lucky to have you."],[4888,5025,"Thank you, Rosy,"],[5025,5209,"for the best day ever."],[5526,5622,"Tad..."],[5622,5951,"You created quite the scene"],[5951,6031,"in my store today."],[6089,6181,"I can explain."]],"25":[[37,271,"Explain how you stood up"],[271,337,"for my daughter?"],[412,642,"If she hadn't been with someone"],[642,725,"like me,"],[763,909,"they never would have given her a"],[909,971,"hard time."],[971,1088,"You're right."],[1088,1255,"And nine out of ten women"],[1255,1376,"would have given that woman"],[1376,1530,"my daughter's coat off her back."],[1530,1609,"What you did in there?"],[1609,1885,"Well, that is the kind of thing that a"],[1885,1997,"mother would have done."],[1997,2139,"You sure you don't have a kid"],[2139,2189,"of your own"],[2189,2314,"lying around somewhere?"],[2318,2369,"I-"],[2369,2556,"I'm joking."],[2556,2652,"Listen,"],[2652,2802,"Tess wants to have dinner"],[2802,2877,"with us tonight."],[2877,3123,"I think she wants to scope you out."],[3165,3390,"Which is why I want you to wear..."],[3557,3666,"this."],[3887,4187,"It belonged to my late wife, Marilyn."],[4258,4542,"It was her favorite piece of jewelry."],[4542,4713,"I can't wear this."],[4713,5013,"You can, and you will."],[5042,5217,"We have to sell this."],[5217,5338,"And when Tess sees you"],[5338,5551,"wearing this, well, she will believe"],[5551,5684,"that our engagement is real."],[5759,5901,"Well, what if something happens"],[5901,6022,"to it? I-"],[6039,6227,"It looks super expensive."],[6360,6531,"Actually,"],[6531,6694,"it's priceless."],[6819,7119,"But I trust you, Rosy."],[7353,7565,"You don't even know me."],[7565,7749,"But I'm getting to."],[8512,8687,"That birthmark!"],[8687,8846,"It's exactly the same as what"],[8846,8946,"Lily used to have!"]],"26":[[191,337,"That birthmark!"],[337,592,"No, it can't be."],[592,754,"The adoption agency said Lily's"],[754,892,"mother died in childbirth."],[950,1113,"You okay?"],[1113,1192,"Yeah."],[1192,1297,"Fine."],[1597,1789,"I can't wear this outfit."],[1789,2039,"And the shopping trip was a disaster."],[2043,2206,"Yeah, which is why"],[2206,2339,"I brought you this."],[2485,2635,"That's the dress."],[2635,2840,"Oh no, it's too expensive!"],[2840,3023,"It is barely enough."],[3144,3349,"What you're doing for me and Lily?"],[3411,3611,"Well, I cannot tell you how much"],[3611,3720,"I appreciate it."],[3799,3912,"We both do."],[4079,4375,"Speaking of..."],[4700,4833,"Your first payment."],[4909,5021,"Right."],[5180,5292,"Umm..."],[5359,5488,"I have to take this,"],[5488,5605,"but I'll see you tonight."],[5605,5689,"Yeah. - Okay."],[5689,5910,"This is just business, Rosy."],[5939,6085,"You're not falling for him,"],[6085,6235,"and he's not falling for you."],[6310,6531,"Focus on what's important,"],[6531,6677,"finding your daughter."]],"27":[[75,221,"Why aren't you dressed yet?"],[221,337,"Dinner's in an hour!"],[337,412,"Lily,"],[412,688,"this place, it's the most expensive"],[688,800,"restaurant in the city."],[838,1138,"The plates alone cost $200!"],[1205,1347,"I can't even pronounce"],[1347,1505,"most of these dishes."],[1518,1647,"Who am I kidding?"],[1647,1793,"I can't do this."],[1793,1939,"Yes you can,"],[1939,2147,"because I'm going to help you."],[2402,2544,"Hello?"],[2544,2686,"I'd like to order room service."],[2781,3003,"Everything on the menu."],[3003,3136,"Merci beaucoup!"],[3395,3482,"Dinner napkin."],[3757,3899,"Dinner napkin."],[4016,4104,"Salad fork,"],[4104,4212,"dinner fork,"],[4212,4454,"fruit fork and..."],[4454,4667,"I'm not sure what this fork is."],[4667,4796,"You can just get rid of it."],[5167,5397,"And bon appétit."],[7620,7707,"Wait."]],"28":[[79,279,"How did you learn how to do all this?"],[329,487,"My old nanny."],[487,550,"She took care of me"],[550,713,"when my mom died."],[1142,1443,"Wow, she's beautiful."],[1539,1710,"My dad has never been the same"],[1710,1868,"since she died."],[2039,2243,"Well..."],[2243,2477,"losing someone can"],[2477,2673,"change you."],[2673,2836,"Have you ever lost someone, Rosy?"],[3144,3261,"Yes."],[3278,3524,"My daughter."],[3524,3757,"But I'm hoping,"],[3757,3883,"very soon,"],[3883,4087,"I'll find her again."],[4170,4375,"I'm sure you will."],[4375,4596,"And when you do,"],[4596,4742,"she's going to be the luckiest girl"],[4742,4888,"in the world to have you as"],[4888,5025,"a mom."],[5697,5834,"Oh my God, Lily!"],[5834,5905,"What?"]],"29":[[129,237,"Oh my God!"],[237,287,"What?"],[287,462,"I'm going to be late!"],[2932,3044,"Who is that?"],[3044,3148,"I believe I've seen"],[3148,3299,"her in a movie before."],[4358,4441,"Wow."],[4441,4579,"You look beautiful."]],"30":[[279,592,"He gave her his late wife's necklace?"],[617,917,"Time for this bitch to go down!"],[917,1226,"So, Rosy, tell me about yourself."],[1263,1514,"You suddenly came out of nowhere."],[1889,2060,"What does he see in her?"],[2060,2327,"He never looked at me that way."],[2327,2515,"I've been around."],[2565,2744,"I'm sure you have."],[2802,3044,"The funny thing is, I couldn't find a"],[3044,3361,"record of a Rosy Dolores anywhere."],[3636,3987,"Well, I'm not high society or anything."],[4049,4316,"Then how did you and Tad meet?"],[4316,4471,"On the street."],[4583,4788,"The street?"],[4854,5034,"That's right."],[5034,5271,"My car nearly hit her."],[5559,5809,"Daddy, you can't possibly sell your"],[5809,6022,"hotel to him while he's engaged to"],[6022,6206,"someone he met on the street."],[6243,6310,"Sir,"],[6377,6635,"I hope that you would trust my taste"],[6635,6690,"in women."],[6702,6994,"After all, I did date your daughter,"],[7082,7140,"didn't I?"],[7190,7344,"And Rosy looks perfectly"],[7344,7449,"respectable to me."],[7449,7549,"We'll see about that."],[7845,8003,"I hope you don't mind, Rosy."],[8003,8237,"I took the liberty of ordering for you."],[8237,8362,"You have eaten"],[8362,8516,"lobster before, right?"],[8516,8746,"This wasn't on the room service menu."],[8746,8817,"What do I do?"]],"31":[[0,179,"Don't tell me you haven't had lobster"],[179,291,"before, Rosy."],[337,442,"Of course!"],[504,588,"Go on,"],[613,709,"eat it."],[813,888,"Right."],[2535,2673,"Oh!"],[2873,3174,"Oh my God, I am so sorr-"],[3624,3732,"You said you met her"],[3732,3841,"on the street, Tad."],[3883,3962,"That tracks."],[4012,4195,"Okay, you know what?"],[4195,4362,"Don't!"],[4441,4558,"It's okay."],[4558,4742,"I will never eat here again!"],[4979,5246,"Daddy, wasn't he one of our regulars?"],[5246,5530,"Looks like Rosy just lost us a client."],[5530,5672,"Maybe you should find someone else"],[5672,5830,"to buy your hotel."],[5964,6210,"If I just cost Tad this deal, our contract"],[6210,6318,"will be over."],[6318,6523,"And I'll never find my daughter."]],"32":[[158,346,"I'm so sorry."],[433,579,"Don't worry, my dear."],[579,825,"That man was an asshole."],[825,1026,"He always sent his dishes back."],[1105,1217,"You know, I've never had much of"],[1217,1405,"a taste for lobster, myself."],[1468,1564,"They used to call them"],[1564,1768,"cockroaches of the sea."],[1793,1947,"I think I'll pass."],[1947,2135,"You should feel free to do so as well."],[2135,2252,"Daddy, do you know how"],[2252,2435,"expensive these lobsters are?"],[2477,2606,"These are pearl lobsters"],[2606,2761,"from the West Pacific."],[2761,2840,"Well, maybe you should have"],[2840,2927,"checked with everyone before"],[2927,3061,"ordering for them."],[3870,3970,"Oh my God."],[3970,4170,"You just can't get out of your own"],[4170,4283,"way, can you?"],[4312,4475,"If you'll all excuse me."],[5705,5860,"I know you're not who you say you"],[5860,6051,"are, Rosy Dolores."],[6056,6293,"In fact, I know what you're hiding."]],"33":[[0,204,"I'm not hiding anything."],[204,304,"Oh, come on."],[342,546,"There's no way that Tad would choose"],[546,684,"someone like you"],[684,863,"over someone like me."],[950,1117,"You obviously have"],[1117,1251,"something over him."],[1305,1534,"Is it so hard for you to believe he might"],[1534,1643,"just like me more?"],[1793,1956,"The richest man in the country?"],[2039,2239,"Yes, it is."],[2252,2527,"Even in that dress, it's clear you are"],[2527,2698,"just a tacky nobody."],[2840,2952,"The only thing that's"],[2952,3257,"tacky here is your personality."],[3261,3345,"Oh."],[3345,3395,"Now, if you'll"],[3395,3507,"excuse me, I have to go"],[3507,3682,"dry off the water some bitch"],[3682,3803,"spilled on me."],[3803,4024,"Don't you walk away from me."],[5334,5492,"Whoops!"],[5492,5747,"I hope that necklace wasn't expensive."],[5747,5851,"That necklace belonged"],[5851,5930,"to Tad's wife!"],[5930,6031,"You knew that!"],[6031,6160,"Oh, well."],[6160,6335,"I guess you can kiss"],[6335,6531,"your engagement goodbye."]],"34":[[20,208,"Our deal is going to be over."],[208,412,"I'm never going to find my daughter."],[487,621,"The necklace!"],[679,875,"Go fetch, bitch!"],[921,1201,"Good luck finding all of those pearls,"],[1201,1359,"Rosy Dolores."],[1434,1572,"Why would you do that?"],[1572,1735,"You know how much this necklace"],[1735,1851,"meant to Tad."],[1851,2010,"Yes, and it should have been around"],[2010,2260,"my neck, not yours."],[2481,2644,"My father owns this hotel."],[2644,2777,"If you help her,"],[2777,2911,"you're fired."],[3144,3407,"I can't wait to see Tad's face"],[3407,3636,"when he realizes you ruined his"],[3636,3803,"precious wife's necklace."],[3866,4041,"I didn't break the necklace."],[4041,4129,"You did."],[4129,4312,"And who's he going to believe?"],[4312,4558,"Me or some whore he just picked"],[4558,4688,"up off the street?"],[4817,4975,"Oh my goodness!"],[4975,5163,"Rosy, you clumsy fool!"],[5201,5401,"I can't believe you just broke"],[5401,5597,"Tad's priceless necklace."]],"35":[[246,354,"I saw her do it."],[354,500,"I think she was planning on selling"],[500,654,"the pearls all across the city."],[688,892,"I know how much this means to you."],[892,1126,"So that's why I'm helping out."],[1209,1509,"I'm so sorry, Tad."],[1551,1664,"I should probably go."],[1664,1851,"Yes, I think that would be"],[1851,2035,"for the best, Rosy Dolores."],[2064,2143,"You don't belong here."],[2143,2243,"Wait!"],[2794,3061,"Rosy didn't do this."],[3061,3190,"Yes, she did."],[3253,3553,"We all saw her, didn't we?"],[3682,3766,"No."],[3766,4020,"You did, Tess, because you're"],[4020,4179,"petty and jealous."],[4208,4391,"And you can't stand the fact that I am"],[4391,4537,"finally happy."],[4717,4867,"I didn't break the necklace."],[4867,4971,"She did."]],"36":[[8,187,"How would you like to pay for the repair,"],[187,308,"by cash or check?"],[1017,1163,"Daddy, what are you doing?"],[1163,1334,"She will pay for the necklace herself."],[1334,1505,"And not with a credit card"],[1505,1609,"tied to my account."],[1609,1718,"All of my money is"],[1718,1835,"tied to your account."],[1835,1981,"Well, I guess you better get a job"],[1981,2118,"at this hotel"],[2118,2248,"washing dishes."],[2248,2419,"Starting today."],[2581,2731,"Daddy, please!"],[2731,2952,"No, I have realized I have spoiled you."],[2952,3169,"I've ruined you. But no