{"1":[[104,304,"Rosy, Rosy, baby."],[304,404,"When are you gonna let me"],[404,533,"marry you?"],[563,696,"You're my fifth marriage"],[696,867,"proposal this week."],[1167,1372,"Come on, baby."],[1372,1497,"Let me make an honest woman"],[1497,1580,"out of you."],[1722,2022,"I am an honest woman."],[2047,2369,"And I don't need saving."],[2581,2694,"Come on."],[5492,5680,"Any luck finding her?"],[5680,5935,"Rosy, you are in here every week."],[5935,6097,"My answer is the same,"],[6097,6306,"not yet."],[6306,6477,"It's been seven years."],[6477,6614,"It's like looking for a needle"],[6614,6777,"in a haystack."],[6794,7069,"Then keep looking."],[7069,7303,"I will do whatever it takes to find"],[7303,7403,"my baby girl."],[7403,7624,"I mean, if only you had a picture"],[7624,7778,"or something."],[7778,7920,"She was ripped away"],[7920,8020,"from me at birth."],[8183,8341,"But I told you, she has a heart-"],[8341,8479,"shaped birthmark on her neck,"],[8504,8675,"just like me."],[9017,9250,"Just keep looking, okay?"],[9250,9484,"I don't care what it costs."],[9484,9872,"I won't stop until I find my daughter"],[9980,10155,"and whoever has her."],[10518,10631,"I don't understand why we're even"],[10631,10719,"here, Daddy."],[10719,10856,"I told you, Lily, I'm"],[10856,11019,"buying Park Meridian hotel"],[11019,11106,"from Tess's father."],[11131,11236,"Promise me, Daddy,"],[11236,11394,"that you'll never get back together"],[11394,11482,"with Tess."],[11503,11644,"I hate Tess."],[11644,11803,"She never eats."],[11874,12145,"You're the only lady in my life, sweetie."],[12145,12445,"And you always will be."],[12454,12508,"Now,"],[12508,12645,"why don't you take a look out the"],[12645,12808,"window and take in the sights."],[12833,12971,"I love this city."],[12971,13050,"And you will too."]],"2":[[304,442,"She's beautiful."],[613,692,"Beautiful?"],[692,813,"She's a hooker."],[813,967,"Don't say that, Louis."],[967,1159,"Right. Sorry, boss."],[1159,1267,"But she is."],[1280,14