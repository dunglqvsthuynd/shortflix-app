{"1":[[1906,2114,"Fuck baby, that feels so good."],[2131,2235,"Oh?"],[2235,2410,"You haven’t even got to the best part."],[4129,4262,"All right, Stepmom."],[4262,4383,"He’s all yours."],[4879,5000,"Eden?"],[5242,5363,"Babe."],[5426,5547,"Where’d you go?"],[9442,9555,"No way."],[9555,9659,"What the fuck happened"],[9659,9743,"last night?"],[9743,9884,"Why is Cathey in my bed?"],[10648,10752,"Cain."],[10885,11031,"You slept with my stepmom?"],[11036,11207,"You disgusting piece of shit!"],[11207,11327,"No, no, no, Eden."],[11336,11457,"Please listen to me."],[11582,11674,"I have no idea"],[11674,11765,"what happened last night."],[11765,11886,"I swear."],[12224,12395,"Eden, thank god you’re back!"],[12395,12533,"Your husband, he..."],[12587,12687,"assaulted me."],[12704,12808,"What?"],[12808,12929,"No, I didn’t!"],[12962,13083,"Cain Hunter."],[13104,13225,"I want a divorce."],[13396,13526,"Wait, you..."],[13538,13701,"You gave me a drink last night,"],[13701,13817,"and then..."],[14026,14193,"Wait, you two set me up?"],[14222,14339,"Why?"],[14852,14973,"You cheated."],[14977,15123,"That's all the court needs to hear."]],"2":[[233,400,"Three years, Eden."],[579,679,"And I did everything"],[679,763,"that you asked for."],[763,884,"Everything."],[892,1026,"And now you want to divorce me?"],[1172,1259,"My stepdaughter"],[1259,1393,"deserves a man with power."],[1426,1547,"Not..."],[1597,1718,"whatever you are."],[2519,2623,"You,"],[2623,2744,"Mr. Fuckup,"],[2752,2873,"were never good enough for me."],[3603,3724,"Fine."],[4237,4358,"You want a divorce?"],[4587,4708,"You got it."],[4871,4996,"I've never seen anybody"],[4996,5192,"so happy to be broke."],[5251,5372,"What?"],[5380,5522,"Oh, I take everything."],[5538,5709,"You walk away with nothing."],[5709,5901,"No, no, that's not happening."],[5930,6026,"Boys,"],[6026,6147,"make sure he agrees."],[6297,6373,"Fuck."],[6373,6498,"The hard way."],[7987,8053,"Eden Chandler,"],[8053,8174,"you didn't just set me up."],[8274,8425,"You took everything from me."],[8775,8925,"Eden Chandler!"],[8925,9117,"I swear on my fucking life!"],[9150,9250,"One day I'm gonna have"],[9250,9376,"you begging on your knees"],[9376,9576,"for what you did to me!"],[10560,10681,"That car..."],[10927,11048,"That’s the Godfather’s car."],[11895,11974,"The Bourne Syndicate,"],[11974,12070,"they run this city."],[12212,12328,"And the Godfather..."],[12687,12808,"he’s the king of every mafia"],[12808,12929,"on this side of the Atlantic."],[13459,13584,"Mr. Hunter,"],[13621,13776,"the Godfather wishes to see you."]],"3":[[842,971,"Don Ludwig."],[971,1088,"Mr. Hunter’s here."],[1968,2135,"Look at me, son."],[2798,2915,"Your eyes..."],[2994,3115,"they’re red like mine."],[3211,3340,"Of course, my son."],[3495,3616,"You're my grandson."],[3691,3812,"Grandson? No."],[3912,4066,"No way, I’m an orphan."],[4074,4191,"Not anymore."],[4487,4629,"Wait, but..."],[4713,4817,"I know you have questions."],[4817,5021,"But now is not the time."],[5034,5155,"Why not?"],[5284,5401,"I'm getting old,"],[5509,5634,"and I'm going to need an heir."],[5905,6031,"And as my grandson,"],[6047,6214,"I can think of no better person"],[6214,6389,"than you to inherit my throne."],[6527,6685,"So, Cain Hunter,"],[6685,6831,"would you like to take your place"],[6831,6952,"as my underboss"],[7086,7161,"and succeed me"],[7161,7282,"as the next Godfather?"]],"4":[[187,358,"You think I have what it takes?"],[521,642,"Not yet."],[763,975,"If you want to inherit the throne,"],[1071,1388,"you must first survive ten trials."],[1472,1593,"Only then"],[1626,1747,"will you be fit to lead the"],[1747,1901,"Bourne Syndicate."],[2068,2189,"Or..."],[2231,2439,"You can take a one time offer"],[2494,2686,"of $1 billion."],[2890,3007,"Walk away."],[3007,3190,"Live your life in bliss."],[3269,3405,"But you can never be"],[3405,3528,"part of this life again."],[4416,4554,"A billion dollars..."],[4608,4808,"or ten trials to become the head of"],[4808,4942,"the Bourne Syndicate."],[5117,5351,"Have you come to a decision, my boy?"],[6056,6177,"Yes sir."],[7386,7536,"A billion dollars?"],[7686,7845,"It’s pretty decent compensation"],[7845,7999,"for you abandoning me as a child."],[8571,8687,"But I want more."],[9025,9142,"I want to be your underboss."],[9309,9430,"Or more precisely,"],[9551,9672,"the new Godfather."],[9859,9980,"My boy."],[10047,10206,"Your ambition is even greater"],[10206,10326,"than I imagined."],[10456,10573,"I like it."],[10739,10814,"That is called"],[10814,10935,"the Eye of Power."],[10994,11207,"It's the only one of its kind."],[11248,11353,"Wear it,"],[11353,11540,"and you'll be treated as a VIP"],[11540,11720,"at every Bourne Syndicate"],[11720,11807,"establishment."],[12053,12149,"So what's next?"]],"5":[[12,158,"If you want to be initiated,"],[221,446,"you must first face the ten trials."],[529,650,"They'll be dangerous,"],[771,921,"and I won't be there to help you."],[1088,1334,"But with each one you pass,"],[1388,1589,"you’ll gain money,"],[1589,1693,"power,"],[1730,1851,"women."],[2147,2348,"Anything your heart desires."],[2469,2585,"So what's first?"],[2648,2819,"Maria will fill you in."],[2919,3094,"But first, I need you to come to me."],[3290,3415,"I want to show you something."],[3762,3966,"Look into my eyes."],[4842,4959,"What did you do to me?"],[4959,5209,"Our eyes are the Eyes of Rom."],[5259,5392,"And I have awakened them"],[5392,5518,"in you with my blessing."],[5547,5684,"Use them well."],[6456,6656,"Your first trial is simple, Mr. Hunter."],[6723,6802,"The Leonard family"],[6802,6936,"is hosting a charity auction"],[6936,7052,"at our auction house."],[7094,7278,"And the Godfather wants you there"],[7278,7361,"as VIP."],[7394,7515,"I've already put you in our system."],[7574,7728,"Just show up with your signet ring"],[7728,7845,"and they should let you through."],[7941,8062,"Okay, okay."],[8137,8304,"But what's the actual test?"],[8304,8433,"The Godfather wants you to win"],[8433,8587,"auction item 15."],[8646,8758,"But the money,"],[8758,8879,"that part's on you."],[8888,8979,"What?"],[8979,9125,"Come on, but I'm dead broke."],[9167,9280,"Exactly."],[9280,9401,"That's the whole point."],[9601,9722,"In that case,"],[9793,9951,"please make a stop at my old house."],[10076,10231,"Isn’t that where your ex lives?"],[10272,10372,"It is."],[10422,10543,"But I got a plan."],[10660,10839,"I'm going to need a little favor from you."]],"6":[[212,350,"Good luck, Boss!"],[1142,1217,"Oh!"],[1689,1801,"Wait."],[1801,1956,"I can see through her clothes?"],[2181,2323,"The power of the Eyes of Rom"],[2323,2448,"is X-ray vision?"],[2660,2781,"Cain Hunter."],[2823,2944,"What are you doing here?"],[2998,3119,"You and Eden are divorced"],[3119,3207,"remember?"],[3207,3278,"We are."],[3290,3411,"You know? That's true."],[3482,3550,"But I was her"],[3550,3640,"lawfully wedded husband"],[3640,3700,"and that gives me"],[3700,3838,"a legal right to her assets,"],[3838,3858,"so..."],[3987,4158,"All I want is $100 million"],[4158,4279,"and I'll be on my way."],[4542,4692,"$100 million?"],[4713,4829,"Are you insane?"],[4871,4942,"Out."],[5055,5138,"Now!"],[5138,5263,"I'm not here to argue with you."],[5263,5384,"I'm going to speak with Eden."],[5522,5593,"Wait."],[6393,6514,"Cain."],[6564,6648,"You better not be trying"],[6648,6760,"anything funny."],[6965,7048,"You seemed to enjoy"],[7048,7182,"having your way with me."],[7298,7478,"Maybe I should return the favor."]],"7":[[100,246,"If Eden finds out about this,"],[246,383,"she’ll never forgive you."],[429,625,"I’m still technically your mother-in-law."],[684,800,"We shouldn't."],[867,988,"Really?"],[988,1109,"That's not what you said last night"],[1109,1230,"in bed."],[1430,1551,"Stop!"],[2298,2419,"Cain you disgust me."],[2452,2669,"Look who decided to join the party?"],[2719,2815,"Let go of her."],[2815,2952,"I will."],[2952,3123,"If you..."],[3123,3349,"If you give me a $100 million."],[3349,3440,"No way."],[3474,3624,"Best I can do is 1 million."],[3728,3849,"Take it or leave it."],[3870,3953,"Wow."],[3953,4070,"You hear that?"],[4124,4208,"You helped her with her"],[4208,4362,"twisted plan to divorce me."],[4362,4529,"And you're still only worth"],[4529,4700,"a measly $1 million."],[4713,4833,"Shut up!"],[5505,5626,"Last chance."],[5705,5822,"Let Cathey go,"],[5972,6064,"or my men will turn you"],[6064,6210,"into Swiss cheese."]],"8":[[108,150,"What are you going to do,"],[150,271,"you're going to shoot me?"],[312,408,"Go ahead."],[408,533,"If anyone's not leaving this room"],[533,654,"alive, it's you guys."],[1205,1401,"Okay, wait, wait, wait."],[1401,1455,"What?"],[1505,1626,"You scared, baby boy?"],[1718,1881,"Then let my step-mom go!"],[2961,3244,"Do I look scared to you, Eden?"],[3244,3353,"Cain, you're insane."],[3353,3470,"Yeah, yeah."],[3470,3670,"I'm insane, a total nutjob!"],[3670,3762,"And you?"],[3762,3883,"You’re a Chandler."],[3895,4041,"The precious heir to your family's"],[4041,4233,"multi-billion dollar fortune."],[4287,4567,"You see, I'm an orphan, Eden."],[4567,4683,"A simple commoner"],[4683,4892,"with no money or power."],[4925,5088,"What do I have to lose?"],[5309,5367,"I'll gladly"],[5367,5497,"walk back into hell if it means"],[5497,5643,"taking you down with me."],[5947,6068,"Fine."],[6331,6514,"I'll give you what you want."],[6619,6681,"My family's"],[6681,6827,"money is mostly from investment."],[6831,7057,"It's not like I actually have"],[7077,7215,"$100 million on me"],[7215,7336,"right now."],[7407,7545,"Well, then, how much do you have?"]],"9":[[462,575,"20 million?"],[729,834,"Deal."],[2131,2289,"I need a favor."],[2289,2344,"Can you hook me up"],[2344,2527,"with some fake TNT props?"],[4587,4700,"Whose car is that?"],[5518,5605,"I don't know."],[5605,5709,"Never seen someone like that"],[5709,5801,"in our circle."],[6106,6181,"Cain?"],[6802,6952,"What the hell are you doing here?"],[6952,7065,"You begged us for money,"],[7065,7211,"and you got it."],[7211,7378,"Now just leave Eden alone already."],[7444,7574,"Are you deaf, Cain?"],[7574,7791,"She asked you a question."],[7791,7941,"What are you doing here?"],[7941,8062,"You know, the last time I checked,"],[8062,8224,"this wasn't Chandler territory."],[8345,8491,"I got just as much right to be here"],[8491,8637,"as you do."],[8725,8792,"Fuck you!"],[8792,8992,"Shut up, you little shit!"],[8992,9175,"No one talks to Aunt Cathey like that."],[9351,9501,"Oh really?"],[9526,9697,"Joseph Chandler."],[9884,10060,"Firstborn son of the Chandler clan."],[10139,10322,"You should have been the family heir."],[10427,10514,"Yet here you are,"],[10514,10635,"just another one of your sister's"],[10635,10806,"little henchmen."],[10994,11102,"You fucking bastard!"]],"10":[[1272,1484,"Hey Cain."],[1484,1643,"Let me clue you in."],[1643,1835,"This is a Bourne Syndicate"],[1835,1935,"auction house,"],[1935,2068,"and a small fry like you"],[2068,2181,"doesn't belong anywhere"],[2181,2260,"near this place."],[2369,2552,"Yeah. Where's your invite?"],[2573,2769,"He doesn't have one."],[2769,2865,"And even if he did,"],[2865,3044,"it's not like it's a VIP pass."],[3044,3207,"He'd have to take the regular line"],[3207,3365,"like everybody else."],[3365,3524,"What a fucking embarrassment."],[3812,3941,"Bourne's gonna kick this loser"],[3941,4054,"out of the auction."],[4054,4133,"I know."],[4133,4254,"He's done for."],[5188,5313,"Welcome in, sir."],[5313,5476,"Honored to have you."],[6218,6464,"Hold it, Cain."],[6464,6569,"You're a fucking liar."],[6569,6619,"And I'm not going to let you"],[6619,6710,"cheat your way"],[6710,6848,"into a Bourne Syndicate auction."],[7052,7144,"I know this guy."],[7144,7240,"Alright?"],[7240,7374,"He's a sorry-ass orphan"],[7374,7511,"who married his way into the family,"],[7511,7711,"but we kicked him out already."],[7711,7991,"He's a nobody now."],[7991,8099,"Really?"],[8099,8183,"Yes, really."],[8274,8387,"He doesn't even have an invite,"],[8387,8591,"let alone a VIP pass."],[8591,8654,"What are you calling me,"],[8654,8783,"a fraud?"],[8783,9084,"Bingo."],[9084,9259,"Sounds like he's calling you guys out"],[9259,9359,"for letting me in."],[9401,9576,"Doesn't that make you feel a bit..."],[9576,9701,"insulted?"],[9701,9780,"What? No, that’s..."],[9780,9868,"not what I meant."],[9972,10093,"All I'm saying is"],[10093,10264,"he's not a real VIP guest."],[10527,10706,"My brother is right."],[10706,10873,"Cain Hunter is a liar"],[10873,11036,"through and through."],[11140,11323,"I know all about this scumbag,"],[11323,11436,"and nothing about him"],[11436,11628,"says VIP."],[11703,11774,"You guys are welcomed"],[11774,11874,"to check me if you'd like."],[11874,12074,"No need, Mr. Hunter."],[12074,12220,"We know who you are."],[12220,12270,"What?"],[12504,12550,"No, no."],[12550,12583,"I'm sorry."],[12583,12662,"If you just give him"],[12662,12741,"a background check,"],[12741,12804,"you'll see that"],[12804,12929,"this guy is full of shit."],[12929,13079,"Ma'am,"],[13079,13204,"if you continue to harass"],[13204,13338,"our VIP guest,"],[13338,13467,"we'll have to take you around back"],[13467,13634,"and beat some sense into you."],[13897,14043,"What the hell happened?"],[14043,14235,"How did a screw up like Cain"],[14235,14397,"became a Bourne Syndicate VIP"],[14397,14489,"overnight?"],[14489,14589,"Mr. Hunter,"],[14589,14689,"how do you suggest we"],[14689,14814,"deal with these two?"]],"11":[[75,287,"Go ahead, teach him some manners."],[454,754,"Oh, wait, wait, wait."],[784,975,"Screw you, Cain."],[1038,1121,"I'll end you!"],[1121,1205,"I didn't mean anything that I said."],[1205,1313,"I take it all back."],[1313,1505,"I take it all back. I’m sorry."],[1881,2027,"So that's what it feels like"],[2027,2122,"to have power."],[2227,2410,"I can get used to this."],[2510,2644,"Do we have a blacklist"],[2644,2744,"here at Bourne?"],[2744,2869,"Of course, Mr. Hunter."],[2869,2944,"Okay, well, make sure"],[2944,3003,"that they're on it,"],[3003,3078,"cause I don't ever want to"],[3078,3207,"see their faces again."],[3340,3482,"As you wish, sir."],[3599,3703,"That's too far, Cain."],[3703,3878,"They'll never recover from this."],[3878,4008,"How dare you blacklist"],[4008,4133,"Arianna and Joseph."],[4149,4312,"You heartless monster."],[4312,4471,"They’re family for Christ's sake."],[4471,4625,"Oh, were they treating me"],[4625,4771,"like family just now?"],[4888,4975,"Okay, if you guys are gonna"],[4975,5055,"treat me like dirt,"],[5055,5142,"don't come crying to me"],[5142,5288,"when I bury you in it."],[5288,5488,"Cain, you're overreacting."],[5488,5576,"Come on."],[5576,5697,"Everyone knows"],[5697,5868,"the only certainties around here"],[5868,6131,"are death, taxes,"],[6131,6189,"and the power"],[6189,6335,"of the Bourne Syndicate."],[6335,6414,"So?"],[6456,6673,"So, if Bourne blacklists them..."],[6715,6794,"They’re as good as dead."]],"12":[[66,129,"Well, maybe you should've"],[129,237,"thought of that"],[237,354,"and came to my defenses"],[354,408,"when they were busy"],[408,550,"calling me a liar."],[550,592,"Still,"],[592,754,"you can't just ruin their lives."],[859,967,"I mean, come on."],[967,1159,"They barely did anything to you."],[1159,1426,"Take them off the blacklist now"],[1426,1526,"and apologize."],[1526,1589,"No."],[1651,1830,"They should be apologizing"],[1830,1922,"to me."],[1960,2118,"Eden, what's going on?"],[2969,3019,"Come on, babe,"],[3019,3157,"it's almost time for the auction."],[3157,3240,"Sorry."],[3240,3445,"I need to take care of something first."],[3549,3616,"Him?"],[3849,3970,"Eden, I'm your fiancé."],[3970,4191,"Let me handle this."],[4191,4283,"Besides,"],[4283,4450,"I'm real tight with Bourne."],[4475,4675,"If you want anything done,"],[4675,4842,"I know a guy who knows a guy."],[4842,4921,"Really?"],[4921,4996,"You know the people"],[4996,5113,"who run the show?"],[5113,5196,"Of course."],[5196,5284,"Eileen Crowe,"],[5284,5455,"head of the auction house."],[5455,5580,"She's a good friend of mine."],[5680,5872,"Well, for starters,"],[5872,6064,"I want my piece of shit"],[6064,6181,"ex-husband gone."],[6385,6564,"He just snuck his way over here"],[6564,6773,"and claiming to be some sort of VIP."],[6973,7273,"So you're Eden's ex-husband."],[7286,7440,"The guy who lived it up,"],[7440,7528,"off the Chandlers' money"],[7528,7716,"before they tossed him to the curb."],[7832,7932,"You're telling me"],[7932,8266,"that a scrub like you just somehow"],[8266,8470,"became a Bourne Syndicate"],[8470,8658,"VIP guest?"],[9054,9309,"Get your filthy hands off of me."],[9409,9613,"Hold it! Buster."],[9613,9780,"I'm calling Eileen Crowe"],[9780,9930,"right now."],[9930,10151,"You could not be more dead."],[10535,10643,"Hello?"],[10643,10781,"Yes, Miss Crowe?"],[10781,10806,"Yes."],[10806,10940,"We have a situation"],[10940,11065,"at the auction house."],[11065,11123,"Some"],[11123,11319,"nobody's forcing his way"],[11319,11428,"into the venue"],[11428,11678,"claiming to be a VIP guest."],[11678,11941,"Did you say VIP guest?"],[11941,12012,"That's right."],[12012,12066,"Keep him there."],[12066,12216,"I'll be there in three minutes sharp."],[12604,12779,"Everyone stop what you're doing!"],[12779,12871,"The underboss is here and"],[12871,13004,"we're going to welcome him."]],"13":[[137,329,"Don't worry, sweet cheeks."],[329,496,"Eileen Crow will be here"],[496,638,"in three minutes."],[638,855,"Your ex is done-zo."],[855,1005,"You're the best, Michael."],[1005,1126,"I know."],[1126,1317,"I'll be expecting a little"],[1317,1451,"reward tonight."],[1847,2006,"Enjoy my sloppy seconds."],[2006,2202,"What the fuck did you just say?"],[2248,2364,"I..."],[2364,2556,"I said enjoy..."],[2556,2798,"my sloppy seconds."],[3048,3144,"God."],[3144,3374,"Eden was right."],[3374,3645,"You are a piece of shit."],[3645,3820,"Look here. Asshole."],[3820,3899,"This auction"],[3899,4116,"is for the top elites of this city."],[4116,4254,"And any nobody"],[4254,4416,"who barges on in here"],[4416,4525,"is just begging"],[4525,4633,"to get smacked."]],"14":[[20,208,"Eden tossed you a lifeline"],[208,404,"and asked you to apologize,"],[404,646,"and you threw it back in her face."],[646,796,"Oh well."],[796,996,"I don't accept help from people"],[996,1105,"who frame me for cheating"],[1105,1343,"just to divorce me."],[1343,1447,"And as for me barging in,"],[1447,1509,"why don't you ask"],[1509,1589,"your friend Miss Crowe"],[1589,1714,"what she thinks about that?"],[1822,1906,"Because the truth is,"],[1906,2168,"this auction doesn't start till I walk in."],[2448,2648,"Oh."],[2648,2806,"This is good."],[2806,3048,"You're about to get smoked."],[3048,3228,"Cain Hunter."],[3228,3449,"This Hunter guy is crazy."],[3449,3561,"Does he even hear the words"],[3561,3691,"coming out of his mouth?"],[3691,3841,"Cain, you better take that back"],[3841,3983,"before Bourne's people"],[3983,4108,"will make you disappear"],[4108,4275,"from the face of the earth."],[4275,4416,"They wouldn't dare."],[4416,4654,"Oh, but I would."],[4654,4792,"Yeah?"],[4792,4921,"Well,"],[4921,5009,"good luck with that,"],[5009,5080,"Michael."],[5230,5380,"I'll have you know"],[5380,5559,"that this might be Bourne's venue,"],[5559,5701,"but it's the Leonard family"],[5701,5880,"who sponsored this auction."],[5910,5964,"God."],[5964,6097,"Is that supposed to impress me?"],[6143,6193,"Wait."],[6193,6331,"That's not all."],[6331,6627,"We got Eileen Crowe herself"],[6627,6815,"to serve as the auctioneer."],[6911,7111,"Miss Crowe is relying on us"],[7111,7319,"for this auction to go smoothly."],[7344,7503,"And if your stupid ass"],[7503,7636,"doesn't fuck this up,"],[7686,7786,"then the Leonard family"],[7786,7945,"will become the newest members"],[7945,8133,"of Bourne Syndicate."],[8195,8316,"Wow."],[8316,8425,"If that happens,"],[8425,8491,"the Leonard family"],[8491,8654,"is gonna be unstoppable."]],"15":[[4,141,"I gotta say"],[141,237,"that Eden Chandler"],[237,383,"knows what she's doing."],[383,450,"Getting with Michael"],[450,642,"was a real stroke of genius."],[642,713,"I know you're all"],[713,825,"praying on my downfall"],[825,888,"because you think"],[888,1030,"I'm some fake VIP guest"],[1030,1263,"who lied to get in here."],[1263,1384,"Unfortunately, I'm gonna have to"],[1384,1564,"disappoint you."],[1564,1818,"Look at all of you."],[1818,1922,"Kissing up to this jerk"],[1922,2106,"just to get a leg up on everyone else."],[2256,2423,"What's the problem with that?"],[2423,2552,"The problem with that"],[2552,2765,"is that you're siding with the wrong guy."],[2815,2840,"The person"],[2840,2994,"you should be kissing up to..."],[3069,3144,"is me."],[3236,3536,"Oh!"],[3653,3745,"Say that again"],[3745,3812,"and you'll become"],[3812,3945,"the newest mortal enemy"],[3945,4099,"of every powerful person"],[4099,4212,"in this city."],[4212,4404,"Do I look like I give a shit?"],[4700,4838,"You got 60 more seconds"],[4838,4925,"to get your insults in,"],[4925,5105,"so keep them coming."],[5105,5176,"Because after that,"],[5176,5251,"I'm gonna let Miss Crowe"],[5251,5409,"tell you who I really am."],[5409,5555,"60 seconds."],[5555,5718,"Too bad you won't last that long."],[5768,5943,"You did it to yourself, Cain."],[5943,6193,"You only have your own ego to blame."],[6235,6364,"Security."],[6648,6727,"Yes, sir."],[6965,7215,"Stop right there."]],"16":[[1167,1247,"Eileen Crowe,"],[1247,1326,"Bourne Syndicate’s"],[1326,1409,"head of acquisitions,"],[1409,1564,"at your service, sir."],[2177,2289,"Wait."],[2289,2444,"What is going on?"],[2444,2615,"Sorry I'm late, sir."],[2615,2740,"Apologies."],[2740,2831,"It's okay."],[2831,2919,"Come on."],[3307,3374,"Still want to try"],[3374,3507,"and get an apology out of me?"],[3507,3586,"Oh. You little—"],[3586,3724,"You still want to question"],[3724,3791,"my decision"],[3791,4058,"to blacklist your siblings?"],[4058,4120,"Ms. Crowe."],[4120,4220,"What are you doing"],[4220,4337,"backing this filthy—"],[4337,4437,"Silence!"],[4504,4562,"Oh!"],[4842,4975,"Did you just hit me?"],[4975,5100,"I sure did,"],[5100,5221,"and I'll do it again."],[5221,5372,"I don't know if you're blind or deaf"],[5372,5447,"or just dumb,"],[5447,5492,"but anyone"],[5492,5626,"who messes with Mr. Hunter"],[5626,5718,"is dead meat."],[5764,5860,"Miss Crowe,"],[5860,5968,"there's obviously"],[5968,6143,"some mistake here."],[6143,6373,"Cain is just my fiancee's"],[6373,6485,"low life ex."],[6660,6898,"He's not just Eden's ex-husband."],[6898,7044,"Do you have any idea"],[7044,7261,"who Mr. Hunter really is?"],[7261,7349,"It's okay."],[7349,7453,"Eileen."],[7453,7586,"Don't waste your time on them."],[7741,7836,"Come on, let's go."],[7836,8028,"Right this way, Mr. Hunter."],[8295,8500,"No, no, that's not possible."],[8500,8696,"Fucking scumbag!"],[8733,8863,"No way."],[8863,8913,"This has to be"],[8913,9042,"some kind of sick joke."],[9042,9167,"I mean, this is madness."],[9167,9250,"Relax."],[9250,9305,"Alright?"],[9305,9555,"Cain can't keep this up forever."],[9555,9659,"Sooner or later,"],[9659,9763,"he'll crack."],[9763,9889,"And then, we'll expose him."]],"17":[[58,237,"There are two VIPs here tonight."],[237,408,"Cain is one of them,"],[408,675,"but the other is Annalise Hurst,"],[675,863,"the sole Heiress to the Hurst fortune."],[1042,1146,"Michael,"],[1146,1297,"I didn't know that you had ties"],[1297,1434,"to the Hurst family."],[1434,1543,"Well,"],[1543,1605,"let's just say"],[1605,1826,"I have friends in high places."],[1830,1931,"Well,"],[1931,2064,"what are we waiting for?"],[2064,2252,"Go to the Hurst and find out"],[2252,2394,"how Cain faked his way"],[2394,2565,"into the Bourne Syndicate auction."],[2623,2698,"On it."],[2769,2844,"Cain."],[2844,3007,"You underestimated me."],[3065,3274,"I'm not gonna let some peasant"],[3274,3574,"get VIP status, so easily."],[3670,3807,"Cain might have them fooled"],[3807,3912,"for now,"],[3912,4091,"but we'll see who gets the last laugh."],[4362,4671,"Excuse us, VIP has been closed."],[6352,6431,"Mr. Hunter"],[6431,6544,"we've blacklisted"],[6544,6673,"Ariana and Joseph Chandler"],[6673,6773,"from the venue."],[6773,6969,"But are you sure that's enough?"],[6973,7057,"They're minor figures."],[7057,7169,"We could take it a step further"],[7169,7248,"if you'd like."],[7248,7369,"There's no need."],[7369,7520,"We've already sent the message."],[7595,7686,"By the way, I should,"],[7686,7811,"thank you, Miss Crowe."],[7891,8062,"You really saved my skin back there."],[8083,8208,"That's my job, sir."],[8208,8287,"I know,"],[8287,8404,"but still, I'd prefer"],[8404,8470,"if we kept things"],[8470,8679,"a little bit more low-key."],[8725,8804,"No one knows that"],[8804,9017,"I'm next in line to be the Godfather and,"],[9084,9234,"I prefer to keep it that way."],[9246,9413,"But...why?"],[9413,9584,"Sir, if you reveal your identity,"],[9584,9676,"the entire city"],[9676,9822,"would never question you again."],[9851,10039,"Let's just keep it under wraps."],[10039,10101,"If anyone asks,"],[10101,10155,"just tell them"],[10155,10385,"I won the VIP at a raffle or something."]],"18":[[0,100,"I want people to think"],[100,291,"I'm just an ordinary guy."],[291,525,"I'm sorry, but may I ask why?"],[525,767,"Because I'm not strong enough yet."],[767,988,"I still haven't earned the underboss title."],[988,1080,"If I tell people now,"],[1080,1209,"they're only gonna respect me"],[1209,1330,"as the Godfather's lackey,"],[1330,1393,"not for anything"],[1393,1539,"that I've actually done."],[1539,1647,"Does it really matter?"],[1647,1906,"Of course it does."],[1906,1964,"Power is"],[1964,2068,"a double-edged sword."],[2068,2185,"Ms. Crowe."],[2185,2323,"It comes with great responsibility,"],[2323,2506,"but we can just as easily die by it"],[2506,2702,"if we don't use it wisely."],[2702,2819,"Listen, just."],[2819,2986,"Just do as I say."],[2986,3065,"My only goal today"],[3065,3219,"is to win auction piece number 15"],[3219,3345,"and pass the Godfather's test."],[3345,3516,"Nothing else is important."],[3516,3699,"As you wish, Mr. Hunter."],[3699,3853,"I will take my leave then."],[3853,3991,"The Hurst heiress is due to arrive,"],[3991,4112,"and I'll be welcoming her in."],[4379,4546,"She's finally showing her face."],[5764,5885,"Mr. Hunter."],[6010,6085,"I'm William Worth."],[6085,6239,"My family's in the hospitality industry."],[6239,6348,"Please take my business card."],[6348,6402,"Mr. Hunter"],[6402,6448,"Henry Kent here."],[6448,6594,"Looking forward to working with you."],[6594,6664,"Please. Please. Sir."],[6664,6815,"...all your banking needs, sir."],[6815,6948,"Please, sir."],[6977,7057,"Please."],[7582,7711,"Look how fast the elites"],[7711,7870,"turn into a bunch of groupies."],[7899,8087,"Patience, honey buns."],[8087,8295,"Once they find out Cain is a fraud,"],[8295,8466,"they'll be our groupies instead."]],"19":[[821,959,"Just as I thought."],[959,1259,"Cain isn't a real VIP guest at all."],[1284,1422,"Really?"],[1422,1530,"100%."],[1530,1601,"A buddy of mine"],[1601,1747,"dug up the invite list."],[1747,1956,"Cain Hunter isn't even on it."],[1956,2077,"I knew it."],[2077,2214,"And you know what else he said?"],[2214,2369,"He said that Cain is only here"],[2369,2515,"because he won an"],[2515,2848,"authentic VIP guest experience"],[2848,2973,"in a raffle."],[3073,3236,"So it was just pure luck."],[3395,3445,"God."],[3445,3653,"It all make sense now."],[3653,3782,"I knew a screw up like him"],[3782,3891,"couldn't have any real pull"],[3891,4029,"on the Bourne Syndicate."],[4029,4129,"Let's go. Gang."],[4129,4258,"We've got a fraud to bust."],[4642,4775,"Listen,"],[4775,4909,"you have the wrong guy."],[4909,5067,"I'm nobody important, okay?"],[5067,5188,"Oh, please."],[5188,5263,"No average Joe"],[5263,5380,"could have Eileen Crowe"],[5380,5480,"bending over backwards"],[5480,5538,"for him."],[5538,5597,"Exactly."],[5601,5759,"Come on, Mr. Hunter."],[5759,5876,"Just give us a chance."],[5976,6114,"Look at you."],[6114,6252,"Soaking up the spotlight"],[6252,6477,"like a wannabe star."],[6477,6631,"Do they know that you're only here"],[6631,6873,"because you won some stupid raffle?"],[7102,7228,"Bad news. Buddy."],[7261,7374,"Once a fuck-up."],[7374,7549,"Always a fuck-up."],[7549,7657,"No matter how many times"],[7657,7799,"you get people to love you."],[7799,7987,"You will always be a trashy,"],[7987,8124,"low-class"],[8124,8354,"nobody."],[8354,8437,"Mr. Leonard."],[8437,8637,"What exactly are you insinuating?"],[8637,8804,"This man here"],[8804,8888,"is a fraud!"]],"20":[[12,91,"Listen up."],[91,283,"Cain Hunter's been lying to you."],[283,471,"He's not a VIP guest."],[471,684,"He's not even from an elite family."],[684,984,"He's just a crooked swindler!"],[1046,1138,"That's right."],[1138,1263,"He's only here because"],[1263,1614,"he won a VIP experience package"],[1614,1697,"in a raffle."],[1981,2173,"We caught you red-handed."],[2173,2314,"Oh, you probably hate me"],[2314,2498,"so fucking much right now."],[2585,2681,"But go ahead."],[2681,2777,"Say your piece."],[2777,2894,"I'll give you a chance."],[2894,3069,"What more is there to say?"],[3069,3136,"I'm a nobody."],[3136,3319,"I said just as much to everyone here."],[3420,3586,"But thank you for clearing things up"],[3586,3737,"for the less bright among us."],[3737,3933,"You fucking fraudster!"],[3933,4066,"You almost had us."],[4066,4233,"No wonder I've never heard of him."],[4233,4362,"I thought he was some badass,"],[4362,4475,"top-secret underboss!"],[4475,4692,"Turns out he's just some fucking loser"],[4692,4871,"who got lucky at a fucking raffle!"],[4871,4988,"Thank you, Mr. Leonard."],[4988,5188,"He would've had us completely fooled"],[5188,5288,"before you came along."],[5301,5476,"Give me back my business card."],[5476,5572,"I don't associate"],[5572,5676,"with scammers like you."],[5847,6018,"You're so busted."],[6018,6147,"Dude."],[6147,6314,"You mad? Hmm?"],[6360,6485,"What are you gonna do?"],[6485,6573,"You're gonna hit me?"],[6669,6731,"You know, Michael."],[6731,6915,"I can't tell if you're an asshole or..."],[7007,7119,"just an idiot."],[7119,7286,"Shut your face, Cain."],[7286,7486,"Your 15 minutes of fame are over."],[7486,7599,"Yeah."],[7599,7695,"We can't help you,"],[7695,7782,"unless you stop"],[7782,7912,"digging your own grave."],[7949,8028,"That's fine by me."],[8028,8204,"I didn't ask for your help anyway."],[8204,8441,"Cain! You're not a real VIP,"],[8441,8637,"so stop acting like one."],[8908,9054,"It's time to face reality."],[9054,9259,"You know what?"],[9259,9384,"I think you're the ones"],[9384,9563,"who need a reality check."],[9776,10076,"It's too much talk, not enough action."],[10093,10185,"Let's go."],[10185,10318,"Come at me like a real man."],[10352,10485,"Unless..."],[10627,10802,"You don't have the balls,"],[10802,10885,"that is."]],"21":[[0,129,"You don't get it."],[129,233,"Do you, Caine?"],[321,513,"I'm the Leonard family heir"],[513,684,"and you're some broke loser"],[759,1005,"who your wife dumped."],[1005,1134,"I don't need"],[1134,1455,"to stoop to throwing hands with you."],[1455,1593,"So then how do you suggest"],[1593,1705,"we settle this?"],[1705,1851,"Well, this is an auction."],[1851,2006,"We're here to spend, right?"],[2006,2118,"I'll make a bet with you."],[2156,2227,"Whoever spends"],[2227,2331,"the most money here"],[2331,2498,"will officially be the top dog."],[2556,2711,"And if I win,"],[2711,2886,"you're on your knees"],[2886,3098,"kissing my shoes."],[3253,3415,"Cain's dirt poor,"],[3415,3532,"and you come from"],[3532,3661,"a family of billionaires."],[3661,3828,"He'd have to be a lunatic"],[3828,3958,"to agree to that."],[4095,4183,"Deal."],[4462,4575,"No Cain!"],[4575,4683,"Walk away from this."],[4683,4796,"I'm not letting you"],[4796,4929,"spend my $20 million"],[4929,5067,"at a charity auction."],[5130,5305,"Your money?"],[5305,5417,"I mean it's mine now."],[5501,5643,"Don't worry, babe."],[5643,5805,"We'll show this schmuck"],[5805,5851,"the difference"],[5851,6043,"between the proletariat"],[6043,6160,"and the bourgeoisie."],[6277,6385,"Well, you heard him."],[6385,6460,"We made a bet."],[6460,6564,"Fair and square."],[6564,6831,"And when this fuck loses,"],[6831,6927,"I want to make sure"],[6927,7023,"that he doesn't run out"],[7023,7165,"on his end of the bargain."],[7194,7269,"Don't worry, Mr. Leonard."],[7269,7399,"We've got your back."],[7461,7595,"A commoner making a bet"],[7595,7745,"with the Leonard family heir."],[7757,7920,"Cain is on a suicide mission."],[7970,8041,"Yeah, Cain."],[8041,8145,"Don't break the piggy bank"],[8145,8233,"trying to keep up with us."]],"22":[[1071,1146,"Ms. Hurst."],[1146,1272,"Welcome to the Bourne Syndicate"],[1272,1372,"charity auction."],[1451,1572,"This is the item I'll be selling."],[1714,1830,"Thank you."],[1830,1931,"Please follow me."],[4175,4283,"Before we proceed,"],[4283,4412,"I would like to inform you all"],[4412,4554,"that Ms. Annalise Hurst"],[4554,4725,"has brought a personal item"],[4725,4854,"to today's auction."],[4863,4934,"It will be sold along"],[4934,5113,"with the other auction items"],[5113,5238,"to raise money for charity."],[5267,5401,"Is that the one from Ms. Hurst?"],[5538,5701,"I don't care how much it cost."],[5701,5901,"I'm bidding top dollar on that one."],[5989,6085,"All right, everyone,"],[6085,6181,"without further ado,"],[6181,6318,"let's commence the auction."],[6343,6489,"Item number one."],[6489,6652,"An authentic Chinese vase"],[6652,6769,"from the Ming dynasty."],[6769,7069,"Starting at 100,000."],[7269,7357,"300,000."],[7649,7949,"700,000."],[7987,8099,"What's the holdup Cain?"],[8212,8345,"Pockets running empty already?"]],"23":[[8,137,"I don't see you bidding either."],[187,408,"Hey, Eden said you were an orphan."],[408,475,"Right?"],[542,663,"I figured you'd have more sympathy"],[663,763,"for people in need."],[825,1005,"I guess you're not as magnanimous"],[1005,1076,"as I thought."],[1130,1330,"Well, Mr. Leonard."],[1380,1468,"You're not exactly"],[1468,1630,"a philanthropist yourself."],[1651,1747,"God, it's a shame, really."],[1747,1881,"All those billions in assets,"],[1881,1943,"and you can't even"],[1943,2072,"make one tiny little donation"],[2072,2168,"to charity."],[2193,2306,"Oh, please."],[2306,2398,"I'm just waiting for you"],[2398,2519,"to make your move."],[2519,2585,"As soon as you"],[2585,2686,"bid on something,"],[2686,2761,"I'm going to buy it out"],[2761,2852,"from under you."],[2852,2982,"Is that so?"],[2982,3290,"Item number 15,"],[3307,3440,"an untitled"],[3440,3641,"contemporary piece"],[3674,3870,"starting at $50,000."],[3991,4154,"What the fuck?"],[4191,4341,"That thing's an abomination."],[4341,4416,"Ms. Crowe,"],[4416,4600,"get that crap off the stage."],[4637,4771,"Who let that in here?"],[4846,5030,"It's an insult to the refined taste"],[5030,5176,"of everyone in this crowd."],[5176,5380,"Yeah, what is this? A joke?"],[5380,5463,"Ms. Crowe,"],[5463,5630,"I know this is for charity,"],[5630,5772,"but we can't just be selling"],[5772,5935,"amateur kids drawings."],[5935,6064,"Again."],[6064,6256,"The starting price is $50,000."],[7186,7332,"100,000."]],"24":[[337,579,"Look at this loser trying so hard"],[579,633,"to buy back"],[633,875,"what little remains of his dignity."],[950,1096,"What did he just bid?"],[1096,1217,"100,000?"],[1388,1543,"That's probably his entire net worth."],[1543,1664,"Jesus, Cain."],[1755,1839,"Of all things,"],[1839,1993,"that's what you're going to bid on?"],[2014,2139,"I made my move."],[2173,2289,"The ball's in your court now."],[2289,2398,"I told you."],[2398,2510,"I'm not going to let you go home"],[2510,2652,"with anything today."],[2677,2919,"Not even trash like this."],[3048,3349,"200,000."],[4713,4854,"Don't cry. Okay?"],[4854,4934,"Here."],[5096,5238,"Take this."],[5492,5572,"Thanks."],[5572,5718,"What's your name?"],[6093,6256,"500,000."],[6256,6368,"1 million."],[6452,6598,"1 million is chump change"],[6598,6719,"to the Leonard family."],[6719,6823,"But for Cain..."],[6823,6969,"that would put a massive dent"],[6969,7040,"in his wallet."],[7040,7203,"This is hard to watch."],[7203,7303,"Cain should know better"],[7303,7432,"than to go up against Michael."],[7432,7553,"Backing out already,"],[7553,7649,"shit stain?"],[7695,7782,"Not yet."],[7895,7962,"2 million."]],"25":[[62,179,"Michael, stop!"],[179,279,"Don't waste your money"],[279,429,"on that hideous painting."],[429,462,"Yeah,"],[462,558,"think about it."],[558,671,"2 million?"],[671,809,"You could buy a fucking racehorse"],[809,871,"with that."],[967,1092,"What's wrong? Michael?"],[1092,1138,"I thought"],[1138,1305,"that you were just getting started."],[1426,1626,"I am sick of your shit, Cain."],[1626,1835,"2 million is pocket change for Michael."],[1835,1881,"Okay?"],[1881,1972,"But he happens to be"],[1972,2110,"financially literate."],[2110,2206,"Unlike you."],[2206,2364,"Yeah, but Michael did just say that"],[2364,2448,"whatever I bet on"],[2448,2531,"he was gonna buy out"],[2531,2635,"from underneath me."],[2773,2932,"Who's the shit stain now?"],[2932,3007,"What the fuck"],[3007,3115,"did you just say to me?"],[3115,3174,"Never mind."],[3174,3257,"It's fine."],[3299,3365,"I guess your funds"],[3365,3465,"just aren't as robust"],[3465,3582,"as you say they are."],[3620,3716,"Don't fall for it,"],[3716,3795,"Michael."],[3795,3928,"He's trying to rile you up."],[4133,4300,"Oh, you almost had me."],[4350,4437,"But,"],[4437,4621,"this is a charity auction."],[4621,4750,"Not Sotheby's."],[4788,4942,"I'm not going to lose my cool"],[4942,5055,"over number 15 here."],[5184,5317,"I see."],[5317,5618,"So you're throwing in the towel."],[5822,5905,"You know what?"],[5968,6010,"Fuck!"],[6010,6076,"You!"],[6076,6139,"Cain!"],[6189,6348,"First, I'm gonna outbid you,"],[6348,6548,"and then, I'm gonna shred that painting"],[6548,6748,"right in front of your goddamn face!"],[6790,6861,"5 million."]],"26":[[0,216,"5 million for that god-awful painting?"],[216,379,"Michael Leonard is losing it."],[383,471,"For real."],[471,613,"He may be the Leonard family heir,"],[613,675,"but he can't keep"],[675,867,"spending their money like water."],[867,971,"That's it?"],[971,1067,"I thought you were going to"],[1067,1159,"put up more of a fight."],[1288,1438,"6 million."],[1438,1768,"6 million for that piece of garbage?"],[1768,1931,"Who even is this Cain Hunter guy?"],[1931,2018,"Maybe he really is"],[2018,2177,"some kind of hot shot after all."],[2177,2318,"For fuck sake, Cain!"],[2427,2656,"Just put an end to this already?"],[2660,2806,"Well, it's a charity auction."],[2806,2973,"What better place to spend big?"],[3053,3165,"Wait."],[3165,3345,"Are you against charity?"],[3345,3574,"Against giving back to those in need?"],[3707,3933,"Get off your high horse already."],[3933,3995,"We all know"],[3995,4129,"where your money came from."],[4137,4366,"Yeah, but now I'm donating it."],[4366,4500,"To charity."],[4500,4558,"Whatever."],[4558,4650,"Just..."],[4650,4771,"let it go, Cathey."],[4963,5105,"6 million."],[5105,5263,"Going once."],[5384,5580,"Going twice."],[5580,5705,"You bastard!"],[5705,5935,"Wait."],[5935,6043,"I, uh..."],[6043,6126,"7 million!"],[6485,6702,"7 million from Mr. Leonard."],[6715,6856,"Any other offers,"],[7032,7127,"Mr. Hunter?"],[7332,7632,"10 million."],[7882,7987,"What?"]],"27":[[12,212,"10 million?"],[212,371,"Hunter's out of his damn mind."],[387,538,"I'd wipe my ass with that painting."],[538,717,"He's dropping 10 million on it?"],[754,992,"10 million?"],[992,1159,"That's eight figures."],[1393,1501,"Don't."],[1576,1764,"Cain came back earlier"],[1764,1876,"and threatened us"],[1876,2106,"into giving him $20 million."],[2106,2189,"What?"],[2189,2248,"I'm telling you,"],[2248,2373,"he's a psycho."],[2373,2635,"You have to stop now."],[2656,2752,"Otherwise he'll go up"],[2752,2877,"to $20 million"],[2877,3061,"without batting an eye."],[3061,3103,"Michael,"],[3103,3324,"I know $20 million is nothing to you."],[3324,3353,"Okay?"],[3353,3440,"But think about how much"],[3440,3495,"you would regret it"],[3495,3624,"if you spent all that"],[3624,3799,"on that worthless painting."],[4108,4195,"Fine."],[4195,4366,"You can have your shitty painting."],[4416,4554,"You better watch your back."],[4554,4671,"Fucker."],[4692,4884,"That's a strange way of admitting defeat,"],[4884,4959,"but okay."],[5050,5184,"10 million."],[5184,5397,"Going once,"],[5397,5638,"going twice."],[5663,5784,"And sold,"],[5784,5939,"to Mr. Caine Hunter."],[6669,6802,"Alright, let's continue."],[6981,7086,"What?"],[7086,7323,"My painting just sold for 10 million?"],[7399,7486,"Who's the buyer?"]],"28":[[0,187,"It was purchased by Mr. Cain Hunter."],[187,246,"Ma'am."],[437,600,"Cain Hunter..."],[846,971,"Don't cry. Okay?"],[971,1055,"Here."],[1055,1172,"Take this."],[1413,1509,"Thanks."],[1509,1597,"What's your name?"],[1597,1714,"Cain."],[1714,1801,"Cain Hunter."],[2202,2331,"We're going to the auction."],[2331,2485,"I have to meet him in person."],[2769,2952,"Starting at $100,000."],[2952,3069,"300,000."],[3069,3253,"700,000."],[3278,3428,"How much did we spend?"],[3428,3532,"Around 3 million."],[3607,3812,"Cain is still the top spender of the day"],[3812,3874,"so far."],[3874,3978,"Fuck!"],[3978,4062,"Stupid."],[4062,4183,"Fucking charity auction."],[4183,4229,"They're not even"],[4229,4346,"selling anything good."],[4346,4496,"Everything here is trash."],[4496,4642,"What are we going to do?"],[4642,4792,"Auction is almost over."],[4808,5067,"Michael that bet you made with Cain is—"],[5067,5150,"Chill out."],[5150,5230,"Okay?"],[5230,5342,"He's not going to make a scene"],[5342,5426,"with all the big names here."],[5505,5726,"And sold to bidder number three"],[5726,6043,"at $380 million."],[6085,6210,"Congratulations."],[6210,6356,"All right, everyone."],[6356,6443,"That concludes"],[6443,6577,"today's charity auction."],[6577,6823,"Thank you so much for attending."],[7102,7178,"We deeply"],[7178,7307,"appreciate your support."],[7307,7386,"Bourne Syndicate,"],[7386,7482,"as promised,"],[7482,7565,"will be donating"],[7565,7741,"all proceeds to charity."],[7741,7845,"We pride ourselves"],[7845,7987,"on our transparency,"],[7987,8141,"and every single donor"],[8141,8266,"would know precisely"],[8266,8395,"where their funds are going."],[8750,8817,"Michael."],[9013,9075,"Don't tell me"],[9075,9213,"you forgot about our bet?"]],"29":[[0,95,"Whoever spends the most"],[95,216,"gets to be top dog,"],[216,312,"and the..."],[312,471,"loser has to lick his shoes."],[471,542,"Remember?"],[688,750,"Shut up!"],[750,850,"Loser."],[850,905,"You're nothing"],[905,1021,"without your ex-wife's money."],[1055,1142,"Oh, well, that’s"],[1142,1222,"between me and her."],[1222,1347,"But the fact still remains"],[1347,1605,"that you only spent $3 million"],[1605,1739,"at the auction today."],[1797,1960,"Come on, don't be a sore loser."],[2106,2298,"What do you want me to do?"],[2298,2431,"Not much."],[2431,2623,"Right. You wouldn't dare."],[2623,2794,"I just want you on your knees."],[2986,3086,"Kissing my feet."],[3165,3311,"Good one, Mr. Hunter."],[3311,3407,"It's a howler."],[3407,3553,"Oh, I'm dead serious."],[3553,3632,"What do you mean"],[3632,3795,"kiss your feet?"],[3795,3887,"You heard me."],[4074,4166,"Mr. Hunter."],[4391,4533,"Isn't that just going"],[4533,4708,"a little too far, don't you think?"],[4708,4884,"Oh, not at all."],[4884,5000,"Mr. Leonard, you're man of your word."],[5000,5055,"Are you not?"],[5171,5313,"He's just here on a stupid"],[5313,5509,"VIP experience package."],[5509,5689,"He's not even one of us."],[5689,5759,"He's a fraud."]],"30":[[0,116,"Exactly."],[187,258,"Cain Hunter,"],[258,387,"you might've lucked your way"],[387,642,"into being Bourne's VIP for a day."],[713,859,"But you're not immune forever."],[867,938,"Cathey."],[1055,1184,"Don't make me do it to you again."],[1184,1288,"Ms. Crowe."],[1288,1397,"Us elites of the city"],[1397,1455,"are all here"],[1455,1614,"because we love and respect"],[1614,1826,"Bourne Syndicate's authority."],[1893,2147,"But we don't respect him."],[2285,2339,"Michael Leonard,"],[2339,2464,"do you have any idea"],[2464,2581,"who you're talking to?"],[2581,2648,"Ms. Crowe,"],[2648,2777,"he might be your VIP"],[2777,2911,"but he has no right"],[2911,3040,"to treat Michael like this."],[3094,3224,"I don't have the right?"],[3224,3303,"No you don't."],[3303,3374,"Michael is the one"],[3374,3524,"who made the bet in the first place,"],[3599,3691,"and now he's backing out"],[3691,3770,"just because he lost."],[3770,3828,"And you,"],[3828,3883,"all of you."],[3883,3978,"You don't think"],[3978,4066,"that I have the right?"],[4066,4366,"You think I'm going too far?"],[4387,4550,"I don't care."],[4579,4700,"You might have luck on your side,"],[4700,4771,"but you're still a"],[4771,4950,"stupid screw up loser."],[5100,5226,"Cain I was married to you."],[5226,5380,"I know you're nothing special."],[5430,5609,"And there's no way in hell"],[5609,5739,"you're getting the Leonard's heir"],[5739,5960,"to kneel to a nobody like you."],[6018,6064,"Miss Crowe,"],[6064,6231,"with all due respect."],[6231,6318,"Caine has been nothing"],[6318,6485,"but disrespectful to me"],[6485,6648,"and the entire Leonard clan."],[6648,6848,"And we are not just gonna let that slide."],[6886,7061,"Are you challenging Bourne's authority?"]],"31":[[0,166,"I wouldn't dare."],[166,316,"But."],[316,458,"I'm not gonna take anything"],[458,554,"from some"],[554,684,"no name fraud"],[684,859,"and let him walk all over me either."],[867,942,"Same here."],[942,1088,"Yeah. Screw Cain Hunter."],[1088,1267,"The only VIP we're gonna listen to"],[1267,1397,"is Annalise Hurst."],[1397,1497,"We don't give a damn"],[1497,1701,"about some fake VIP."],[1764,1997,"So if I can prove to you"],[1997,2085,"that I'm the real deal,"],[2085,2264,"with real power,"],[2264,2381,"you'll submit to my authority?"],[2515,2736,"Sure, but not until you prove it."],[2736,2886,"My family has been"],[2886,3011,"in control of this area"],[3011,3136,"for a century."],[3136,3182,"There's been"],[3182,3311,"five generations of Leonards"],[3311,3374,"that have gotten us"],[3374,3482,"to this point."],[3516,3570,"You're nothing"],[3570,3712,"but a screw up,"],[3712,3841,"and a nobody."],[3841,3920,"The only person"],[3920,4070,"that gives a fuck about you"],[4070,4145,"is Eileen Crowe"],[4145,4329,"for some reason."],[4350,4567,"If you're the real deal,"],[4567,4679,"why don't you show us something"],[4679,4796,"we haven't seen before?"],[4925,5005,"Oh please,"],[5005,5150,"you would faint from the shock."],[5163,5321,"Shut up, Cain!"],[5372,5505,"All you do is talk the talk,"],[5505,5626,"as if any of us"],[5626,5747,"would ever believe you!"],[5780,5868,"Fine."],[5989,6056,"If that's what you want,"],[6056,6181,"we'll give it to you."],[6239,6331,"Eileen."],[6585,6681,"Tell them who I am."]],"32":[[0,212,"If you think Mr. Hunter is just here"],[212,296,"on a VIP"],[296,483,"experience package,"],[483,700,"you're wrong."],[700,988,"He leaked that fake intel on purpose"],[988,1197,"to see who would fall for it."],[1197,1451,"Mr. Hunter is actually"],[1451,1564,"Bourne Syndicate's"],[1564,1801,"ultimate guest of honor."],[2310,2394,"What?"],[2394,2448,"No way."],[2448,2565,"So there's"],[2565,2727,"two VIPs here tonight?"],[2781,3023,"The first one's Ms. Annalise Hurst."],[3023,3169,"That I know. But."],[3169,3357,"You're saying the second one is..."],[3357,3503,"this guy?"],[3503,3687,"He's on par with the Hurst heiress?"],[3757,3878,"Mr. Hunter, what would you like"],[3878,3995,"to do with them?"],[3995,4062,"Like I said,"],[4062,4262,"power cuts both ways,"],[4262,4316,"and it's time"],[4316,4416,"they felt the blade."],[4416,4600,"No, you..."],[4600,4679,"you can't."],[4679,4817,"Michael Leonard."],[4833,4946,"Your family has had"],[4946,5176,"five generations of power and privilege."],[5201,5321,"Today, it ends with you."],[5321,5384,"No, I..."],[5830,5964,"I try to warn you, Leonard,"],[5964,6118,"but you just wouldn't listen."],[6306,6393,"I..."],[6431,6619,"I destroyed my family's empire."],[6940,6965,"No."],[6965,7052,"That's impossible."],[7052,7157,"You're lying."],[7157,7228,"There's no way"],[7228,7394,"that you can ruin any of us."],[7394,7553,"Nothing..."],[7553,7665,"is impossible."],[7665,7786,"On your knees."],[7957,8158,"Apologize to Mr. Hunter now."],[8462,8700,"I'm sorry."],[9034,9129,"Some man you've found."]],"33":[[0,79,"Babe, I didn't—"],[79,296,"Don't call me that."],[300,425,"You're the one who divorced me"],[425,521,"after you set me up,"],[521,646,"and you called me a cheater."],[742,896,"You hired people to beat me up,"],[896,1084,"and you took all my assets."],[1084,1213,"You called me a screw up"],[1213,1322,"in front of everyone"],[1322,1530,"and told them I had no right to be here."],[1618,1718,"You got Michael"],[1718,1822,"to make a bet with me"],[1822,1893,"so you could try"],[1893,2056,"to make me look like a fool."],[2147,2227,"I didn't."],[2227,2494,"Take a good long look around you,"],[2494,2527,"harlot."],[2656,2957,"You're the only fool here."],[3257,3361,"Why didn't you tell me"],[3361,3524,"that you were a VIP?"],[3524,3628,"Would you have believed me"],[3628,3703,"if I did?"],[3791,3912,"Don't you ever"],[3912,4074,"put your hands on her again."],[4154,4220,"All you ever do"],[4220,4358,"is push your wife around."],[4575,4696,"What kind of man are you?"],[4738,4850,"Shut your mouth!"]],"34":[[33,246,"Would you stop slapping me?"],[246,354,"Would you stop"],[354,567,"being a dumb bitch?"],[567,763,"Babe you got it all wrong."],[763,905,"I'm on your side."],[905,1092,"I wanted to see you succeed too."],[1151,1305,"I told you to stop calling me that."],[1397,1618,"Eden Chandler, you disgust me."],[1701,1805,"We're through."],[1805,1951,"We've gone our separate ways."],[2068,2127,"Mr. Hunter,"],[2127,2218,"what about the rest of them?"],[2339,2456,"Wait, Mr. Hunter."],[2456,2540,"No."],[2540,2727,"It's just a misunderstanding."],[2744,2873,"Misunderstanding?"],[2873,2990,"Yeah, it was..."],[2990,3111,"it was the Chandlers"],[3111,3207,"and Michael Leonard."],[3207,3269,"They're the ones that came"],[3269,3357,"after you."],[3357,3453,"Not us."],[3453,3666,"Mr. Hunter, if I may."],[3666,3828,"You're a rich, young,"],[3828,3903,"and powerful."],[3903,3983,"You can let this go"],[3983,4137,"just this once, right?"],[4149,4287,"Yes, of course."],[4287,4404,"You'll give us a pass,"],[4404,4491,"this once."],[4491,4650,"Right, Mr. Hunter?"],[4650,4738,"Mr. Hunter,"],[4742,4954,"I'd like to sincerely apologize."],[5084,5334,"I hope we can still collaborate"],[5334,5430,"in the future."],[5430,5547,"Anything you want,"],[5547,5672,"we can get it for you."],[5672,5851,"Money, women..."],[5851,5955,"yachts."],[5968,6143,"Kays have it all."],[6164,6222,"It's all just"],[6222,6339,"a misunderstanding."],[6339,6393,"Is it?"],[6393,6544,"Yes. Of course."],[6544,6706,"Business!"],[6748,6898,"Well, then..."],[7052,7198,"Unfortunately, for you,"],[7198,7407,"I'm not the live and let live type."],[7628,7728,"It's time for you dipshits"],[7728,7832,"to go bankrupt."]],"35":[[354,554,"Cain. You're crazy."],[554,754,"You're a lunatic!"],[905,988,"I might not be able"],[988,1142,"to stop you now,"],[1142,1309,"but I swear to God,"],[1309,1480,"Bourne can't save you forever!"],[1676,1826,"As soon as Mr. Hunter"],[1826,1901,"gives the order,"],[1901,2139,"we can have you all disappear."],[2356,2419,"Mr. Hunter."],[2419,2477,"Don't you think"],[2477,2581,"that's a bit overboard?"],[2581,2648,"How so?"],[2690,2781,"Well, like we said,"],[2781,2944,"it was all a misunderstanding."],[2944,3082,"And we're even willing"],[3082,3136,"to offer something"],[3136,3232,"to make up for it."],[3232,3395,"You think I need your money?"],[3395,3499,"Yeah."],[3499,3645,"Between the four of us,"],[3645,3778,"we covered the entire market"],[3778,3845,"in the city."],[3845,3978,"Dining, leisure,"],[3978,4154,"fashion, hospitality,"],[4154,4279,"you name it!"],[4279,4421,"Not to brag, Mr. Hunter."],[4458,4529,"But,"],[4529,4646,"we hold all the cards"],[4646,4825,"as far as industry is concerned."],[4913,5025,"And you're not the dealer."],[5067,5159,"You sure about that?"],[5159,5226,"You're not high enough"],[5226,5296,"on the ladder."],[5296,5392,"William Worth."],[5392,5518,"Oh, please, Ms. Crowe."],[5518,5709,"I respect Bourne's authority,"],[5709,5784,"But this man..."],[5893,6010,"is just another VIP"],[6010,6118,"at an auction house."],[6118,6181,"I don't care"],[6181,6272,"if he got in on a"],[6272,6352,"raffle ticket."],[6352,6473,"He's not one of us."],[6473,6556,"He doesn't have the power"],[6556,6673,"to do anything in the city."],[6673,6823,"You think we'll let anyone"],[6823,6986,"be VIP at Bourne?"],[6986,7127,"You still don't know who he is,"],[7127,7261,"do you?"],[7261,7298,"He could be the"],[7298,7440,"president for all I care."]],"36":[[25,137,"Worth is right."],[137,246,"There's no way Hunter"],[246,383,"can just take us out."],[383,500,"I'm a Kay."],[500,629,"My family's got investments"],[629,771,"in every sector."],[771,950,"You can't get rid of us that easily."],[950,1109,"Is that supposed to be a challenge?"],[1109,1217,"Oh, no, not at all."],[1217,1405,"But, we're standing our ground."],[1405,1505,"Cain Hunter."],[1505,1701,"You might be a VIP today,"],[1701,1801,"but you do not speak"],[1801,1901,"for Bourne Syndicate"],[1901,2031,"or its true power"],[2031,2135,"Don Ludwig Bourne."],[2177,2306,"Is that so?"],[2306,2398,"Mr. Worth?"],[2398,2523,"Of course."],[2523,2652,"You're new to our world."],[2652,2848,"You barely scratch the surface"],[2848,2969,"of what goes on behind the scenes"],[2969,3094,"in families like ours."],[3094,3244,"Taking down a family empire"],[3244,3449,"is not as easy as it looks."],[3495,3624,"What are you trying to say?"],[3624,3703,"I'm saying"],[3703,3874,"you may have the upper hand today."],[3874,4029,"We'll come back stronger than ever."],[4066,4187,"When we do,"],[4187,4300,"we will make you pay"],[4300,4408,"for the things you did."],[4425,4500,"That's right."],[4500,4592,"We're not like you,"],[4592,4892,"relying on a woman to be VIP."],[4904,5021,"If this was a real fight,"],[5021,5088,"any one of us"],[5088,5150,"could take you down"],[5150,5313,"100 times over."],[5313,5388,"Are you sure?"],[5388,5451,"Of course."],[5451,5526,"Hell."],[5526,5609,"You've got all the power."],[5609,5676,"Prove it."],[5676,5868,"Tell Bourne to bankrupt me now."],[5868,5947,"It's the first time"],[5947,6060,"I've ever heard anyone asked"],[6060,6202,"to be financially ruined."],[6373,6489,"May I, Mr. Hunter?"],[6489,6656,"Go ahead."],[6656,6706,"Call Maria."],[6706,6794,"Tell her I want the Worths"],[6794,6861,"to go bankrupt"],[6861,6977,"in the next three minutes."]],"37":[[212,362,"Who's Maria?"],[408,529,"Never heard of Maria"],[529,692,"among Bourne's higher ups."],[696,867,"I'll give you this much."],[867,913,"You're really"],[913,996,"committed to the act."],[1001,1226,"Oh, it's not an act."],[1226,1305,"You'll see."],[1305,1438,"I’ve issued the order, sir."],[1455,1522,"Miss Crowe,"],[1522,1693,"the Worths have billions in assets"],[1693,1876,"scattered across the country."],[1885,1981,"I don’t think you can hurt us,"],[1981,2089,"much less take us down"],[2089,2181,"in three minutes."],[2243,2377,"That's enough, Cain!"],[2377,2598,"We all got here through years"],[2598,2719,"of hard work!"],[2719,2777,"Three minutes"],[2777,2994,"to destroy an entire empire?"],[2998,3157,"That’s crazy!"],[3157,3282,"Even for the Godfather"],[3282,3424,"of Bourne Syndicate."],[3424,3482,"You're right."],[3482,3561,"I'd be surprised"],[3561,3732,"if it took him more than 30 seconds."],[3770,3845,"William Worth,"],[3845,4037,"you're making a big mistake."],[4095,4191,"You'd better apologize"],[4191,4295,"to Mr. Hunter right now"],[4295,4450,"before you end up like Michael Leonard."],[4450,4550,"No."],[4550,4696,"I'm standing my ground."],[4696,4788,"Excuse me?"],[4788,4942,"You better drop the act, Ms. Crowe."],[4942,5080,"Stop covering for Hunter."],[5080,5171,"Or else, you're going to have more"],[5171,5313,"to deal with than just the Worths."],[5313,5497,"You'll have to deal with the Kays too."],[5497,5605,"And us."],[5605,5784,"Miss Crowe, again."],[5784,5876,"Cain's just"],[5876,6114,"a VIP at your auction house."],[6114,6231,"Sure."],[6231,6302,"Bourne's powerful,"],[6302,6535,"but is one VIP enough to take"],[6535,6631,"all of us down?"],[7440,7574,"Bad news, Mr. Worth."],[7574,7720,"There's been a hostile takeover."],[7720,7849,"Our stocks are plummeting."],[7849,7991,"We're gonna go bankrupt."],[7991,8062,"Mr. Worth?"],[8091,8153,"You there?"]],"38":[[37,296,"Did Worth really just go bankrupt?"],[296,433,"Cain Hunter."],[579,671,"Who are you?"],[671,809,"What?"],[809,955,"Worth went bankrupt?"],[955,1105,"How’s this even possible?"],[1272,1401,"Bastard I'll kill you!"],[1447,1509,"Guards!"],[1509,1643,"Stand down!"],[2594,2644,"No!"],[2644,2794,"Who is this Cain Hunter."],[2794,2973,"I think you know well enough."],[2973,3011,"No."],[3115,3190,"It can't be."],[3190,3290,"He's not some"],[3290,3470,"top-level underboss or something"],[3470,3520,"right?"],[3520,3607,"But he just destroyed"],[3607,3716,"the Worths."],[3716,3799,"Anybody who'd move money"],[3799,3945,"around that fast"],[3945,4066,"has to be the Godfather"],[4066,4183,"of Bourne Syndicate."],[4183,4325,"The Godfather?"],[4900,5071,"What's wrong with my fiancé"],[5071,5280,"putting a few CEOs in their place?"]],"39":[[567,871,"Cain Hunter is my savior"],[871,1030,"and the love of my life."],[1030,1205,"That should give him every right"],[1205,1376,"to do whatever he wants to."],[1376,1443,"What?"],[1443,1659,"He's engaged to the"],[1659,1789,"Annalise Hurst?"],[1789,1851,"I didn't know"],[1851,2014,"he had ties to the Hurst family."],[2014,2227,"When were you—"],[2227,2310,"Cain!"],[2448,2598,"How did you end up like this?"],[2731,2798,"Ms. Hurst."],[2798,2890,"Have we met?"],[3157,3299,"We've met before, Cain."],[3299,3395,"Mr. Hunter."],[3395,3520,"The painting you purchased"],[3520,3670,"was created by Annalise"],[3670,3795,"based on an experience"],[3795,3937,"she had as a child."],[4070,4262,"You're that girl in the alleyway?"],[4262,4396,"That's right. Cain."],[4396,4633,"You finally remembered."],[5167,5292,"Wait."],[5292,5355,"Is that?"],[5355,5513,"I had them prepare a few things"],[5513,5601,"for you, Cain."],[5601,5680,"A small thank you"],[5680,5872,"for your donation to charity,"],[5872,6097,"and a special engagement gift"],[6097,6206,"just for you."],[6264,6406,"First, a brand new"],[6406,6627,"Pagani Zonda HP Barchetta"],[6627,6911,"valued at $17 million."],[7111,7290,"Next, the deed to a mansion,"],[7290,7603,"valued at $30 million."],[7611,7778,"And finally, a small cash gift"],[7778,8008,"of $5 million."],[8008,8174,"So, Mr. Hunter and Annalise"],[8174,8341,"can enjoy every minute"],[8341,8475,"of their time together."],[8804,8925,"Do you like it?"],[8925,8979,"It's all yours."]],"40":[[191,258,"Wait."],[258,379,"So Cain Hunter..."],[500,646,"is Annalise Hurst’s"],[646,742,"Fiancé."],[742,800,"Wow."],[1021,1101,"That's a hefty"],[1101,1205,"engagement gift."],[1217,1338,"What’s on that cart"],[1363,1488,"is worth more than"],[1488,1564,"my family owns."],[1584,1756,"So, it’s the Hursts who were"],[1756,1868,"backing you the whole time."],[2185,2310,"No wonder you took my family down"],[2318,2439,"in just three minutes."],[2623,2744,"The Worths are done for."],[3090,3353,"Mr. Hunter I was wrong!"],[3616,3832,"I’m sorry!"],[4108,4225,"What about you three?"],[4258,4379,"We're sorry too!"],[4421,4529,"We’re so sorry."],[4529,4675,"Please just give us another chance!"],[4804,4892,"Ruin them."],[5000,5080,"Tell Maria that you're going"],[5080,5246,"to handle the asset transfer with her."],[5255,5392,"As you wish, Mr. Hunter."],[5422,5559,"No, no, no, no, no, no, no!"],[5559,5684,"Please! Please!"],[5684,5776,"Please!"],[5776,5889,"No, no, no!"],[6022,6072,"All right."],[6072,6222,"Well, that's done."],[6364,6448,"I believe you and I"],[6448,6577,"have some things to discuss."],[6602,6723,"Whenever you're ready Cain."],[6756,6848,"Right this way."]],"41":[[275,396,"Hold on!"],[738,850,"Did you need something,"],[859,971,"Miss Chandler?"],[980,1113,"So you're only a VIP today"],[1113,1234,"because you are"],[1259,1430,"Hurst’s fiancé?"],[1576,1697,"You see, that..."],[1755,1918,"is none of your business."],[2027,2218,"Stop trying to look cool."],[2252,2389,"You're a fucking leech."],[2502,2706,"First, you leech off us Chandlers,"],[2706,2848,"and now you're sucking up to"],[2848,2969,"the Hurst’s?"],[3040,3219,"All you ever do is live off"],[3219,3336,"other people's scraps."],[3445,3553,"You're a failure."],[3561,3678,"Logaria."],[4287,4458,"I don't know who you are,"],[4458,4637,"but I will not let you talk about"],[4637,4758,"my Cain like that."],[4825,4942,"Unless..."],[4984,5163,"you want to end up bankrupt, too?"],[5217,5363,"Just drop it, Cathey."],[5605,5672,"You haven't answered"],[5672,5793,"my question."],[5893,6055,"Did you get the VIP invite"],[6055,6143,"from Annalise?"],[6172,6277,"That..."],[6343,6448,"is none of your business."],[6448,6506,"Cain!"],[6552,6794,"I know, I hurt your fragile male ego"],[6794,6915,"when we got divorced."],[7086,7190,"But it was your fault,"],[7190,7265,"and you know it."],[7273,7369,"Excuse me?"],[7378,7469,"When you showed up today,"],[7469,7590,"all powerful..."],[7611,7720,"for a second,"],[7728,7887,"I thought, you finally got"],[7887,7974,"your life together."],[8333,8441,"Guess you are a disappointment"],[8441,8516,"after all."],[8671,8817,"Oh, you're one to talk."]],"42":[[41,241,"It doesn't matter!"],[262,462,"Because you're still a loser."],[571,763,"All you do is hide behind powerful"],[763,905,"and strong women like me"],[905,988,"and Annalise!"],[1376,1522,"You make me sick."],[1522,1614,"You know what?"],[1614,1760,"Suit yourself."],[1760,1935,"Because we're done."],[1935,2043,"Let's go."],[2043,2243,"Miss Annalise!"],[2281,2569,"You’re an heiress of the Hurst fortune."],[2660,2761,"Do you really want to"],[2761,2915,"marry down for this fuckup?"],[3040,3199,"Are you saying you know what's best"],[3199,3345,"for me, better than I do?"],[3482,3545,"I just..."],[3545,3720,"Then I suggest you stay out"],[3720,3874,"of Hurst business."],[4183,4341,"At least until your assets"],[4341,4542,"look a little more promising."],[4696,4942,"Take care, Miss Chandler."],[4979,5184,"Fucking pretentious assholes."],[5217,5417,"Screw Annalise Hurst."],[5655,5768,"Might be pretentious"],[5768,5905,"assholes, but they do have"],[5905,6018,"funds to back it up."],[6118,6264,"My baby girl."],[6264,6427,"Cain is screwing you over."],[6427,6627,"Well, I say we give it right back to him."],[6690,6844,"What are a few more insults"],[6844,7040,"for a strong, independent"],[7040,7136,"woman like me."],[7186,7328,"I'm the reason"],[7328,7528,"Chandler family is what it is today."],[7553,7636,"That's right."],[7799,7887,"You could take Cain out"],[7887,8020,"without even trying."],[8020,8195,"Just wait Cain Hunter."],[8195,8370,"The Chandler’s era is coming,"],[8370,8633,"and when it does, I'm stomping you"],[8633,8812,"and the Hursts into the ground"],[8812,8879,"for good."]],"43":[[517,604,"And that's what happened"],[604,738,"at the charity auction, sir."],[784,871,"They insulted"],[871,1017,"our new underboss,"],[1017,1138,"and all we did was"],[1138,1292,"take out their stocks?"],[1413,1589,"We should have ended their line."],[1751,1910,"How did it feel, my son?"],[1947,2131,"I'm starting to see the appeal."],[2156,2277,"This power, it's..."],[2435,2556,"it's intoxicating."],[2598,2752,"And rightly so."],[2794,2961,"And this is only the beginning."],[3023,3174,"So did I pass the test?"],[3240,3378,"With flying colors."],[3436,3557,"And as a reward,"],[3574,3753,"I've given you 10% of the shares"],[3753,3874,"of the Bourne Syndicate."],[3933,4120,"I've also given you an assistant."],[4166,4354,"And I hear she's quite the looker."],[4608,4846,"Congratulations, Mr. Hunter."],[4846,5025,"But most importantly..."],[5096,5217,"There's more?"],[5480,5638,"This..."],[5638,5885,"is the secret to my success."],[5968,6306,"This is the ace up our sleeve."],[6339,6460,"And tonight,"],[6485,6669,"I'm going to pass this onto you."]],"44":[[87,208,"What is this power?"],[279,358,"This..."],[367,517,"is A Call Beyond."],[554,721,"Learn to use this skill"],[775,938,"and you can bypass the limits,"],[938,1126,"put on our mortal coils."],[1180,1359,"Wait, so if I learn it,"],[1422,1543,"I get super powers?"],[1555,1676,"Yes. My son."],[1714,1868,"This is the power that has made"],[1868,2018,"the blood of the Bourne triumph"],[2018,2152,"for centuries."],[2198,2318,"With this power,"],[2369,2615,"you will be unstoppable."],[2902,3007,"Please."],[3036,3219,"Don Ludwig, I want to learn it."],[3319,3449,"Do you know why I have waited"],[3449,3570,"so long to show you?"],[3624,3695,"No."],[3753,3928,"Because I wanted to be sure"],[3945,4074,"that you wouldn't be seduced"],[4074,4266,"by the temptations of this world."],[4366,4508,"And that you wouldn't be tempted"],[4508,4629,"by greed,"],[4662,4775,"or lust."],[4775,4854,"Thus,"],[4892,5067,"manage this immense power."],[5367,5572,"You've passed the first test."],[5572,5751,"You have shown your heart is pure."],[5839,5955,"That you are not swayed"],[5955,6076,"by corruption,"],[6126,6252,"or money."],[6268,6414,"A rare disposition."],[6569,6690,"And because of this,"],[6715,6877,"this blessing shall be bestowed"],[6877,7102,"upon you, my child."],[7173,7340,"I've lived a long life,"],[7340,7503,"and seen many things."],[7582,7741,"Many have come to me in the past"],[7741,7937,"begging to be godfather."],[8028,8241,"But all they saw was wealth"],[8241,8354,"and power."],[8400,8521,"But you,"],[8537,8704,"you've stayed true to your heart."],[8746,8871,"That's a rare thing."],[8938,9121,"And I will teach you everything I know."],[9180,9351,"Just promise me one thing."],[9438,9622,"Never turn your back on"],[9622,9801,"that noble heart of yours."],[12858,13029,"Cain Hunter, you’ve learned your skill"],[13029,13167,"in but a day."],[13167,13288,"I can sense it."],[13300,13538,"You will be my next heir."],[13580,13759,"I won't let you down, Don Ludwig."],[13822,13943,"Good."],[13993,14097,"Now..."],[14097,14280,"are you ready for your second trial?"]],"45":[[58,162,"Yes."],[162,283,"I'm ready, Don."],[296,446,"The Bourne Syndicate owns a"],[446,579,"jewelry company"],[579,746,"called Chalice Gems."],[792,934,"I'm putting you in charge."],[1126,1242,"But first,"],[1272,1480,"you'll have to resolve a crisis."],[1480,1601,"What is it?"],[1910,2031,"It's in the dossier."],[2231,2327,"Take a look."],[2385,2515,"After the charity auction,"],[2535,2740,"Michael Leonard and Eden Chandler"],[2740,2857,"established a coalition"],[2857,2969,"to try and take down"],[2969,3090,"Bourne syndicate."],[3094,3190,"They're trying to convince"],[3190,3374,"every elite family in Hemwick"],[3374,3465,"to join them."],[3478,3582,"There's no way we’re letting them"],[3582,3699,"destroy us, right?"],[3737,3883,"Well, there's a problem, sir."],[3899,4045,"As of today, all of our main"],[4045,4137,"jewelry suppliers"],[4137,4258,"have been cut off."],[4266,4337,"Not one of them"],[4337,4458,"will work with us anymore."],[4475,4637,"So we're facing a real"],[4637,4792,"raw ore shortage."],[4800,4921,"Interesting."],[5050,5176,"Seems like Eden is dead-set"],[5176,5292,"on targeting me."],[5422,5505,"Now there must be something"],[5505,5601,"only I can do."],[6035,6156,"Evening, boss."],[6156,6297,"My name is Amelia Vacario."],[6297,6406,"I'm the CEO and lead"],[6406,6523,"designer of Chalice Gem."],[6577,6727,"Starting today, I will also be"],[6727,6844,"your personal assistant."],[6881,6940,"Do you have a minute"],[6940,7061,"to talk about our strategy?"],[7115,7236,"I do."],[7253,7382,"Meet me at Don Ludwigs."],[7557,7674,"Don did you just"],[7674,7807,"get a multi-millionaire CEO"],[7807,8033,"to be my personal assistant?"],[8062,8183,"That's right."],[8312,8454,"Your reward for passing"],[8454,8575,"your first trial."],[8742,8913,"Now go forth and conquer."],[8950,9129,"I await your success."],[9167,9338,"I won't let you down, Don Ludwig."]],"46":[[12,162,"Here at Chalice Gems,"],[166,283,"we have ten"],[283,433,"top-notch jewelry designers"],[437,625,"working at six retail boutiques"],[625,738,"with hundreds of staff."],[796,934,"Our assets are estimated to be"],[934,1151,"at approximately $1 billion."],[1172,1292,"1 billion?"],[1372,1422,"That's more than"],[1422,1564,"the Chandlers’ whole net worth."],[1664,1789,"Can’t believe one of our subsidiaries,"],[1789,1910,"is worth that much."],[1918,2147,"Yes, and now it’s all yours."],[2177,2306,"Sign on the dotted line,"],[2306,2464,"and 100% of the shares"],[2464,2585,"will go to you."],[3032,3186,"Thank you, Amelia."],[3299,3378,"I think I have a good idea"],[3378,3499,"what's going on here."],[3532,3703,"You can run the daily operations"],[3703,3795,"like you normally do."],[3812,3928,"Thank you, Mr. Hunter."],[3933,4133,"I'll take great care of Charlice Gems."],[4258,4325,"But I..."],[4325,4450,"You're worried about the"],[4450,4600,"Leonard-Chandler coalition,"],[4600,4683,"aren’t you?"],[4683,4779,"Yes, sir."],[4779,4875,"As it stands,"],[4875,4954,"Leonard has a monopoly"],[4954,5084,"on all quarries in the area."],[5109,5259,"From raw ore to processed stone,"],[5280,5401,"it's all in his hands."],[5401,5522,"See, the Chandlers mainly"],[5522,5651,"work in fine jewelry."],[5655,5805,"And now they have the Leonard family"],[5805,5960,"with their ore and mining suppliers"],[5960,6047,"to back them up."],[6281,6427,"No wonder Eden wanted to leave me"],[6427,6556,"for Michael so badly."],[6589,6694,"And right now,"],[6694,6869,"we would need ten kilograms of rock,"],[6869,7061,"gems, and stones to keep up operations."],[7132,7261,"If we don't resolve the deficit,"],[7286,7403,"and fast,"],[7403,7457,"they're going to poach"],[7457,7578,"all of our clients."],[7716,7862,"Tell me where we can get new ore."],[7882,7987,"Mr. Hunter..."],[8020,8195,"If we want that much all at once,"],[8224,8320,"we need to try our luck"],[8320,8487,"at an underground gemstone dealer."],[8562,8692,"Then that's where we'll go."]],"47":[[16,175,"Mr. Hunter, we can't."],[208,379,"They're notorious for ripping off"],[379,454,"their buyers."],[483,608,"It's practically a gambling front,"],[625,771,"and the odds are not in our favor."],[804,855,"But..."],[855,942,"Besides,"],[992,1159,"half their roughs are still fully enclosed"],[1159,1280,"in rock matrices."],[1284,1447,"It's impossible to tell"],[1447,1572,"which stone is a priceless"],[1572,1693,"diamond or a dud."],[1764,1951,"It is impossible for most."],[2022,2110,"Not for me."],[2110,2227,"What do you mean, sir?"],[2268,2385,"Even the best tomography"],[2385,2506,"scanners on the market,"],[2556,2656,"have trouble determining"],[2656,2798,"just what's inside those rocks."],[2973,3090,"I can."],[3194,3324,"Do you mean you can..."],[3353,3432,"see?"],[3432,3553,"Inside the stone?"],[3599,3720,"That's right."],[3724,3845,"If that's true..."],[4037,4141,"you’ll dominate"],[4141,4270,"the precious gems market."],[4946,5067,"I know I will."],[5155,5276,"But I want more."],[5426,5551,"What I want is to take over"],[5551,5689,"the entire Bourne Syndicate"],[5689,5822,"and become the next Godfather."],[5847,5968,"I see."],[6022,6143,"In that case, sir,"],[6164,6285,"let's go to a gem show."],[6352,6448,"Not just any gem show."],[6448,6577,"We're going to the one owned by"],[6577,6694,"Michael Leonard."],[6698,6781,"You want to go to"],[6781,6911,"a Leonard operation?"],[6986,7119,"It's the biggest one around, isn't it?"],[7248,7353,"Let the Leonards try"],[7353,7474,"to sell me a dud,"],[7490,7674,"and we'll turn it into a priceless piece."],[7887,8016,"Show the Chandlers exactly"],[8016,8095,"who’s in charge."]],"48":[[526,650,"Eden."],[650,840,"You've been up all night."],[840,960,"You should get some rest."],[986,1066,"I can't."],[1066,1186,"Come on."],[1243,1383,"You're going to ruin your body"],[1383,1556,"if you keep pulling these all nighters."],[1603,1720,"Rather do that than lose to"],[1720,1826,"Bourne Syndicate."],[1860,1986,"We have to expand and attack them"],[1986,2110,"now while they’re down."],[2263,2440,"It's all that Cain Hunter’s fault."],[2580,2703,"How on earth did he end up"],[2703,2823,"with the Hurst heiress?"],[2986,3103,"Babe."],[3136,3336,"Our wedding is coming up."],[3403,3503,"I want to make you"],[3503,3696,"a full bridal jewelry set"],[3696,3846,"so everybody knows that"],[3846,3990,"you're my wife."],[4030,4113,"Uh-huh."],[4160,4276,"Well,"],[4326,4446,"I was thinking,"],[4470,4553,"why don't we check out"],[4553,4673,"my family's gem show?"],[4813,5026,"We did just get a new batch of"],[5026,5293,"high-quality rough stones in."],[5456,5680,"Might be worth"],[5710,5826,"trying our luck?"],[5890,6033,"See if we can get you"],[6080,6330,"an emerald set."],[6576,6656,"You think we can get"],[6656,6800,"natural emerald?"],[6800,6950,"They're so rare and...."],[6950,7100,"gem shows are such a gamble."],[7133,7240,"Don't worry."],[7240,7400,"I had an expert go over the shipment."],[7426,7546,"One of the stones,"],[7580,7700,"is rumored..."],[7743,7950,"to have triple-A grade..."],[8006,8123,"emeralds."],[8156,8276,"Ultra rare."],[8410,8526,"Well then."],[8526,8630,"That’s decided."],[8630,8753,"Let's go to the rock show."],[9296,9416,"Not right now."],[9480,9600,"Get me the emeralds,"],[9600,9716,"and then..."],[9760,9880,"we’ll talk."],[9960,10120,"It’s a deal."]],"49":[[709,846,"Is that Chalice Gems?"],[913,1088,"The one run by Bourne Syndicate?"],[1105,1217,"I didn’t know Amelia Vicario"],[1222,1388,"came to places like this."],[1480,1609,"Must be getting desperate."],[1659,1776,"We've been icing them out."],[1839,1989,"If she doesn't get new materials,"],[1997,2118,"and fast,"],[2177,2356,"Chalice is going out of business."],[2439,2635,"So she's trying her luck gambling"],[2644,2806,"for the uncut gems."],[2869,2990,"She’s such an idiot."],[3023,3123,"She's bleeding money"],[3123,3282,"straight into your hands."],[3290,3499,"And what's mine is yours."],[3557,3745,"You’re going to get all of"],[3745,3895,"Bourne's jewelry clients."],[5055,5176,"Cain?"],[5438,5634,"What’s Cain doing at the gem show?"],[5814,5939,"And why is Amelia Vicario,"],[5947,6089,"the CEO of Chalice Gems,"],[6097,6197,"following him around"],[6197,6289,"like a puppy?"],[6289,6406,"Cain Hunter."],[6448,6569,"Our favorite loser"],[6577,6698,"fuckup."],[6831,6906,"I didn't think"],[6906,7027,"I'd have the misfortune"],[7036,7207,"of seeing your face today."],[7403,7532,"Is there a problem,"],[7532,7674,"Mr. Leonard?"],[7682,7828,"Careful, Vicario."],[7849,8062,"This is Leonard territory."],[8103,8241,"And I can't believe that you would"],[8245,8412,"be fooled by this guy too."],[8579,8700,"How dare—"],[9013,9163,"Mr. Leonard, you're not trying to steal"],[9171,9284,"another one of my women"],[9284,9363,"from me, aren't you?"]],"50":[[45,158,"I wonder how your"],[162,266,"fiancé feels about that."],[271,392,"No,"],[412,558,"babe, it's not like that."],[604,800,"I just hate his face so much!"],[825,934,"This has nothing to do with"],[934,1067,"Amelia Vicario."],[1096,1184,"Well..."],[1184,1317,"aren't you a womanizer?"],[1447,1580,"First Annalise Hurst,"],[1584,1751,"and now Amelia Vicario?"],[1814,1922,"You know, I don’t believe that"],[1922,2106,"my women are any of your business."],[2139,2260,"Miss Chandler."],[2298,2452,"You know Vicario is one of my"],[2452,2594,"biggest rivals in the market."],[2627,2765,"You obviously got together"],[2769,2911,"with her to get a rise out of me!"],[3073,3174,"Look Eden, you can believe"],[3174,3274,"whatever you want."],[3399,3507,"But I would double-check"],[3507,3611,"the confidence levels"],[3611,3741,"on your intel sources if"],[3741,3849,"I were you."],[4312,4433,"You dirty dog."],[4533,4675,"Are you still staring at my woman?"],[4675,4700,"Mister..."],[4700,4775,"No!"],[4779,4900,"What?"],[4954,5075,"Of course not."],[5088,5209,"Come on, babe."],[5213,5301,"We have real"],[5301,5426,"important people to see."],[5718,5780,"Boss,"],[5784,5985,"Michael clearly has no respect for you."],[6018,6189,"Maybe we should rough him up."],[6210,6327,"Teach him a lesson."],[6327,6398,"Nah."],[6435,6498,"Let's let him think"],[6498,6619,"he has the upper hand for now."],[6669,6823,"Because when he leaves today..."],[6998,7140,"He's going to be in tears."],[7190,7311,"Come on."],[7970,8091,"Mr. Hunter."],[8091,8245,"The Leonard Gem show has both"],[8249,8462,"facet roughs and cabbing roughs."],[8508,8650,"Now, might I suggest we go"],[8650,8783,"to the cabbing roughs first?"],[8812,8913,"We've a much higher chance"],[8913,9046,"of finding high-end gems there."],[9104,9225,"Half of the stuff in the facet roughs"],[9225,9292,"are fake."]],"51":[[20,141,"Half of the stuff in the facet roughs"],[141,216,"are fake."],[250,367,"Yeah,"],[383,504,"but I can tell, remember?"],[600,674,"C'mon."],[1038,1267,"That is a genuine Ruby,"],[1267,1405,"but the inclusions make it"],[1405,1530,"practically worthless."],[1931,2072,"Oh, Amethyst."],[2072,2193,"Good clarity too."],[2281,2448,"It's a shame only half of it’s real"],[2485,2577,"it’ll only be worth, like,"],[2577,2698,"20 or 30k."],[2898,3107,"Ooh, black fire opal,"],[3165,3332,"with good coloring throughout."],[3378,3465,"That's a shame,"],[3465,3578,"there’s a crack running down"],[3578,3691,"the middle."],[3691,3841,"It’ll be too brittle to process."],[3849,3970,"Hey! What do you mean,"],[3970,4095,"a crack down the middle?"],[4120,4304,"You got X-ray vision or something?"],[4950,5121,"That says raw amber,"],[5176,5296,"but it’s a rare orange diamond."],[5296,5476,"That's worth millions of dollars!"],[5492,5613,"Amelia, buy that raw amber"],[5622,5714,"for me would you?"],[5714,5860,"Mr. Hunter, raw amber is"],[5860,5968,"one of the cheapest gems"],[5968,6051,"on the market."],[6076,6193,"We don’t need that."],[6197,6314,"Well, what's the harm?"],[6318,6339,"Come on."],[6339,6523,"It's only $20,000."],[6585,6706,"Let's buy it just for fun."],[6735,6827,"If you insist, sir."],[7557,7661,"A pleasure"],[7661,7832,"doing business with you, sir."],[7928,8074,"Enjoy your raw amber."],[8112,8153,"But boss..."],[8153,8229,"Amelia."],[8279,8400,"Quick question."],[8425,8495,"How much are orange"],[8495,8616,"diamonds going for right now?"],[8637,8721,"Orange diamond?"],[8779,8883,"That’s one of the rarest colors."],[8904,9034,"I haven't seen them in ages."],[9054,9129,"If I had to guess."],[9129,9263,"I'd probably say on par"],[9267,9409,"with pigeon-blood rubies."],[9413,9522,"Just give me a number."],[9526,9655,"It's hard to say."],[9676,9847,"Every orange diamond is unique,"],[9847,10005,"but the largest 200 carat piece"],[10010,10155,"just sold for 100 million at auction."],[10210,10343,"Okay, you better hold"],[10343,10464,"a good grip on that rock,"],[10510,10564,"because you're holding"],[10564,10719,"$100 million right there."]],"52":[[0,91,"Boss."],[91,246,"You think this is orange diamond?"],[262,383,"Yea, there’s no doubt about it."],[450,567,"You know, on second thought,"],[588,692,"I don't think Leonard’s Sellers"],[692,775,"have any idea what"],[775,875,"their goods are worth."],[921,984,"Maybe we should go"],[984,1101,"check out the cabbing roughs."],[1121,1184,"Come on."],[1493,1593,"Mr. Leonard,"],[1622,1780,"interested in this one, eh?"],[1785,1889,"That's right."],[1889,2018,"I've had my eye on this rock"],[2018,2139,"for a while now."],[2318,2485,"Just look at the shape."],[2519,2640,"That color."],[2711,2844,"It’s going to make a great set of"],[2844,3007,"triple grade A emeralds."],[3007,3128,"I'm telling you."],[3136,3269,"That's right, Mr. Leonard."],[3269,3365,"And we can do the rough cuts"],[3365,3486,"for you right here."],[3490,3653,"What a beaut!"],[3703,3841,"I can't wait to see what a"],[3841,4087,"$15 million emerald looks like."],[4091,4216,"That's not something you see"],[4216,4275,"every day."],[4291,4433,"All thanks to Mr. Leonard."],[4433,4554,"Isn't that right?"],[4554,4708,"I want it cut right now."],[4984,5071,"Careful!"],[5071,5176,"Okay?"],[5176,5305,"I don't want you to break that"],[5305,5426,"triple grade A emerald."],[5634,5755,"It's for my fiancée."],[5764,5910,"Aw, thanks Micheal."],[6151,6272,"Boss!"],[6285,6385,"It seems like..."],[6385,6598,"Michael just found himself a huge"],[6598,6723,"triple-A grade emerald."],[6723,6844,"Do you want to go see?"],[7761,7924,"Ms. Vicario..."],[7932,8053,"Mr. Hunter."],[8179,8350,"Are you here to pick up my scraps?"],[9171,9309,"$20,000?"],[9505,9626,"Fuck, man."],[9868,9997,"For a piece of trash like this,"],[9997,10135,"I'll give it to you on the house."],[10485,10589,"Is that a promise?"]],"53":[[12,191,"Mr. Leonard, did I just hear you say"],[191,346,"you want to give us the amber for free?"],[496,608,"Sure, sure, buddy."],[608,729,"Well, I want that in writing."],[788,892,"I mean, we wouldn't want you to go"],[892,1030,"back on your word later."],[1063,1159,"Really Cain?"],[1159,1338,"You don't have 20k on you?"],[1363,1484,"What an embarrassment."],[1534,1651,"Hold on."],[1651,1789,"You're serious about this?"],[1789,1947,"Well, far be it from me"],[1947,2131,"to refuse such a desperate"],[2131,2423,"and pathetic cry for help."],[3203,3307,"Here you go."],[3307,3424,"Alms for the poor."],[4154,4225,"Boss."],[4225,4404,"He’s trying to humiliate you."],[4441,4562,"Sit tight."],[4562,4637,"He’ll get his payback"],[4637,4738,"in just a bit."],[5184,5317,"Thank you, Mr. Leonard."],[5384,5505,"Come on let’s keep looking."],[6193,6314,"No way."],[6427,6594,"They're charging 15 million"],[6594,6752,"for a rock with nothing in it?"]],"54":[[141,367,"Is 15 million outside"],[367,462,"your comfort zone?"],[500,696,"Take your 20 grand wonders"],[696,855,"and leave the triple-A grade"],[888,1005,"to the big boys."],[1005,1134,"Please, Michael."],[1201,1326,"Unlike you, I have the funds."],[1326,1463,"Remember our little bet at the auction?"],[1480,1551,"You—"],[1551,1714,"I wasn't the one on my knees."],[1830,1901,"Hey."],[1906,2006,"Hey, I'm just smarter"],[2006,2127,"with my investments."],[2147,2264,"I prefer not to spend"],[2264,2427,"$50 million on a rock"],[2427,2673,"you can find on the side of a highway."],[2731,2894,"What did you say about my rock?"],[2936,3057,"How dare you!"],[3174,3311,"You don't know gems, do you?"],[3336,3461,"Looks like we've got a case"],[3461,3599,"of the sour grapes."],[3870,3983,"Too bad, Cain."],[4029,4116,"This bad boy..."],[4229,4350,"is mine,"],[4358,4487,"and I'm going to have it cut,"],[4525,4633,"and polished,"],[4633,4763,"and made into a wedding set"],[4763,4884,"for my woman."],[4925,5005,"You just remember"],[5005,5125,"to keep your mouth shut"],[5155,5301,"when you see what's inside."],[5342,5455,"I'll keep my eyes peeled."],[5588,5709,"Come on."],[5993,6122,"The roughs in this area"],[6122,6272,"are much more premium."]],"55":[[20,141,"Boss."],[171,387,"Don't tell me this is the one you want."],[404,508,"Why don't we take another loop"],[508,592,"around the show?"],[592,713,"This one's a no-go."],[713,846,"It's been here for years."],[913,971,"They mined it"],[971,1092,"because the red on the top"],[1092,1209,"looked promising."],[1213,1393,"But tons of experts have looked at it."],[1413,1547,"It's cracked all the way through."],[1701,1881,"Top of the morning to you boss."],[2002,2089,"This one right here"],[2089,2239,"is going for a really,"],[2260,2406,"really great price right now."],[2460,2715,"Originally it valued at 20 million."],[2836,3019,"And well, you heard the lady."],[3028,3278,"So now it's going for only $5 million."],[3465,3678,"That, my friend, is a steal."],[3678,3753,"Please."],[3753,3924,"You'd have to be an idiot to buy that."],[4004,4175,"So, I'm an idiot, then?"],[4237,4300,"I didn't"],[4300,4416,"mean you, boss,"],[4421,4504,"but I mean"],[4504,4629,"it is a very poor specimen."],[4683,4788,"Well,"],[4788,4854,"I guess I'll have to"],[4854,4959,"be the idiot this time."],[5142,5263,"Buy it."],[5263,5384,"Are you sure?"],[5388,5509,"I'm more than sure."],[5668,5734,"It's time we teach"],[5734,5855,"Michael Leonard a lesson."],[6135,6297,"Don't worry, Eden."],[6297,6552,"I have a great eye for gems."],[6573,6652,"We'll get you that"],[6652,6769,"emerald wedding set."],[6777,6898,"Well, let's hope so."],[6923,7044,"Because if I get my emerald,"],[7136,7232,"you’re getting it tonight."],[7232,7353,"Really?"],[7411,7532,"Score!"],[7824,7941,"Well, well, well."],[7941,8066,"Look what the idiot dragged in."]],"56":[[4,150,"Michael, is that rock really that bad?"],[212,362,"It may be priced at 5 million,"],[362,492,"but it's practically worthless."],[533,709,"We've had a ton of experts look over it"],[709,834,"and they've all said the same thing."],[871,992,"It's terrible."],[1026,1213,"So Cain just gives you free money."],[1372,1493,"Why don't we let him"],[1493,1614,"fool around with that rock?"],[1722,1864,"I can't believe he convinced Vicario"],[1864,1989,"he knows what he's doing."],[2047,2168,"What a dumbass."],[2231,2427,"Chalice Gems is on it’s last legs."],[2560,2723,"Slim pickings, Cain?"],[2861,2940,"Don't want to pick out"],[2940,3032,"any more rocks?"],[3065,3203,"Just the two is more than enough"],[3203,3324,"to keep us in business."],[3399,3566,"I'd hate to give you a heart attack"],[3566,3732,"by taking more of your precious stock."],[3858,3978,"Oh, I can't believe it."],[4062,4141,"Miss Vicario,"],[4141,4275,"are you sure you trust this guy?"],[4371,4475,"Because I think you're crazy."],[4475,4542,"If you think he's going to"],[4542,4646,"pick anything good for you."],[4742,4946,"Chalice Gems is going to go belly-up."],[4967,5096,"That's between me,"],[5096,5288,"and Mr. Hunter, Mr. Leonard."],[5321,5409,"Well,"],[5409,5559,"you know, if you ever need anything."],[5622,5739,"I'm always happy to help."],[5985,6202,"Thanks, but no thanks."],[6252,6443,"I'd rather stick with Mr. Hunter."],[6448,6569,"If he says we buy"],[6569,6690,"for 5 million,"],[6715,6815,"50 million"],[6815,7007,"or even 5 billion,"],[7007,7161,"then that's what I'll do."],[7403,7545,"Hell, if he told me to sell,"],[7586,7728,"I’d do it without batting an eye."],[7807,7928,"Oh, you."],[7970,8041,"Michael!"],[8137,8258,"Don’t bother."],[8671,8842,"Cain Hunter is just a useless"],[8842,8921,"screw-up who has to"],[8921,9071,"kiss up to women,"],[9117,9205,"to get anywhere."]],"57":[[12,133,"What did you say?"],[212,333,"Say that again"],[346,571,"and I'll cut your tongue out."],[579,696,"What, am I wrong?"],[825,930,"Cain is just a loser,"],[930,1080,"through and through."],[1297,1393,"Why else would he be"],[1393,1543,"weaseling his way to you?"],[2235,2310,"Boss."],[2310,2535,"Don’t waste your time with them."],[2569,2694,"Look, they’re almost done"],[2694,2815,"with Leonard's Rock."],[2986,3103,"All right! Then enough."],[3103,3136,"All right?"],[3169,3286,"My sugar booger"],[3286,3403,"needs her emeralds."],[4129,4237,"Boss,"],[4237,4346,"if they really get"],[4346,4479,"the triple-A grade emerald,"],[4500,4621,"we’re in deep trouble."],[4637,4888,"Not only will it be the raw material,"],[4888,5017,"but it'll also be good"],[5017,5138,"publicity for Chandler."],[5150,5271,"They’ll steal all our clients!"],[5313,5434,"Don't worry."],[5434,5551,"They're not getting anything"],[5551,5672,"out of that rock."],[5709,5834,"Lady Luck isn’t that kind"],[5834,5922,"to the undeserving."],[6076,6222,"I didn’t know you read fortunes, too."],[6239,6293,"Let's just say"],[6293,6435,"my eyes are sharper than most."],[6473,6594,"What I’m seeing is that you will"],[6598,6715,"strike it rich,"],[6756,6852,"and they won't."],[7937,8058,"No..."],[8162,8237,"No!"],[8237,8358,"Is it actually emerald?"],[8400,8550,"No!"]],"58":[[37,158,"No! What?"],[179,271,"There's a huge crack"],[271,392,"right down the middle!"],[392,513,"It's all the way through the rock."],[538,638,"And the green wasn’t"],[638,775,"coming from an emerald at all."],[821,905,"It would have been worth"],[905,1046,"more as a paperweight!"],[1092,1213,"Now it's useless."],[1263,1380,"Michael got screwed?"],[1405,1526,"Let me see."],[1914,2093,"Is that your priceless"],[2093,2218,"triple-A grade Emerald?"],[2431,2594,"It's uglier than concrete."],[2610,2727,"15 million."],[2740,2907,"It's too ugly to even be a bookend."],[3057,3215,"Oh, Mr. Leonard."],[3311,3445,"You poor thing!"],[3599,3732,"I'd be quaking in my boots"],[3732,3849,"if I were you."],[3995,4129,"I could say the same thing"],[4129,4245,"about you, Vicario."],[4383,4517,"Why don't we cut that open"],[4517,4600,"and see what kind of"],[4625,4750,"shit is in there, huh?"],[4750,4888,"Yeah, that's right."],[4925,5038,"I want to see you try and come up"],[5038,5155,"with something valuable"],[5171,5292,"out of that shit rock."],[5417,5572,"Maybe it’s even worse than ours."],[5580,5693,"Maybe."],[5693,5743,"But at least"],[5743,5935,"we didn't spend 15 million on it."],[5997,6147,"Fuck you, Vicario!"],[6147,6227,"Shut up!"],[6373,6556,"Just show us your rock."],[6785,6906,"One at a time."],[6923,7040,"We wouldn’t want Mr. Leonard"],[7040,7157,"passing away from shock,"],[7157,7278,"now would we?"]],"59":[[412,554,"That's not amber."],[621,767,"That's an orange diamond!"],[1080,1347,"That's going to rack up in the millions!"],[1526,1647,"Quick question."],[1676,1743,"How much are orange diamonds"],[1743,1864,"going for right now?"],[1885,2006,"Orange diamond?"],[2006,2131,"That's one of the rarest colors."],[2156,2281,"I haven't seen them in ages."],[2306,2377,"If I had to guess,"],[2377,2469,"I'd probably say..."],[2469,2560,"on par with pigeon-blood"],[2560,2619,"rubies."],[2652,2773,"Just give me a number."],[2773,2898,"It's hard to say."],[2923,3069,"Every orange diamond is unique,"],[3094,3236,"but the largest 200 carat piece"],[3236,3407,"just sold for 100 million at auction."],[3461,3599,"Okay, you better hold"],[3599,3716,"a good grip on that rock"],[3757,3920,"because you're holding $100 million"],[3920,4041,"right there."],[4575,4696,"No way!"],[4729,4804,"You really knew"],[4804,4934,"it was orange diamond inside."],[4959,5096,"I'm not in the habit of lying."],[5213,5330,"Oh my gosh."],[5363,5455,"Oh my gosh!"],[5455,5584,"Boss, I believe you now!"],[5797,5918,"Oh wait..."],[5960,6147,"It was on the house too."],[6297,6606,"Thank you very much Mr. Leonard."],[6606,6815,"We just made 100% profit."],[6869,7007,"That's not fair!"],[7027,7207,"I just spent 15 million"],[7207,7415,"picking out a rock and it was a bust."],[7461,7574,"But they just nicked a"],[7574,7749,"priceless diamond for free?"]],"60":[[842,1051,"Thank you so much, Mr. Leonard."],[1051,1142,"Chalice gems"],[1142,1263,"was in a rough patch."],[1317,1530,"You just airlifted us to the next quarter."],[1551,1672,"That's impossible."],[1710,1830,"Eden Chandler."],[1851,1968,"You may think you're smart..."],[2152,2302,"teaming up with Michael Leonard"],[2302,2452,"to take down Bourne Syndicate."],[2477,2619,"But Mr. Hunter knew"],[2619,2815,"about your scheme all along."],[2836,2952,"You..."],[3040,3257,"Why do you always get in my business?"],[3278,3436,"Why are you always blaming me?"],[3520,3653,"If you didn't set me up back then,"],[3657,3807,"you would be standing by my side"],[3807,3958,"right now, reaping the benefits."],[4154,4270,"How's that body holding up,"],[4270,4375,"Leonard?"],[4446,4621,"I still have to cut my cabbing."],[4658,4742,"You might want to grab a chair"],[4742,4863,"for this one."],[5092,5146,"One day,"],[5146,5292,"your luck is going to run out."],[5347,5613,"And that day is today."],[5659,5885,"There is no way."],[6014,6135,"That, that piece of crap,"],[6189,6393,"has anything valuable in it."],[6427,6564,"Well, the rock doesn't care"],[6564,6669,"what you think,"],[6669,6740,"Mr. Leonard."],[6886,7077,"See I’m its master, and I"],[7077,7198,"say that it's going to have something"],[7198,7319,"incredible in it."],[7515,7599,"You want to bet?"],[7678,7795,"What are we betting?"],[7870,7987,"That stupid"],[7987,8070,"blood diamond"],[8070,8191,"you just got?"],[8208,8350,"Is that even yours to give away?"],[8379,8491,"Of course it is."],[8491,8562,"The real question is,"],[8562,8696,"what can you offer me?"],[8829,8963,"I mean, no offense, Mr. Leonard,"],[8963,9109,"but nothing in your coffers"],[9109,9250,"can hold up to an orange diamond."],[9380,9534,"Our diamond is worth well over"],[9534,9655,"$100 million."],[9793,9959,"You better give us an equivalent offer."],[9959,10039,"Do it Michael!"],[10093,10239,"If we win, it's a free"],[10239,10360,"$100 million."],[10502,10652,"Yeah, you're right."],[10689,10873,"If we get that orange diamond,"],[10902,11027,"we make back everything"],[11027,11152,"that we lost with the emerald,"],[11194,11311,"and at the auction."],[11528,11682,"Are you ready to test your luck?"]],"61":[[33,112,"Cain."],[154,296,"We’ve had countless"],[296,487,"experts go over that five mil"],[487,575,"rock in your hand."],[742,863,"And they all agree"],[925,1034,"it's worthless."],[1076,1251,"Well then what’s the harm?"],[1280,1409,"Just a friendly little wager"],[1409,1509,"as long as you have something"],[1509,1576,"to put up."],[1593,1714,"I do."],[1764,1893,"Let me give the head of my family"],[1893,1960,"a call."],[1989,2110,"Suit yourself."],[2736,2848,"It's your lucky day,"],[2848,2969,"Cain Hunter."],[3103,3165,"I'll wager"],[3165,3403,"my family's new emerald mine."],[3440,3528,"Okay?"],[3528,3649,"It's valued at"],[3649,3816,"well over $100 million."],[3837,3953,"Mr. Leonard,"],[3953,4070,"are you sure?"],[4408,4546,"Boss."],[4546,4729,"Leonard's Emerald mine is the biggest"],[4729,4879,"on this side of the Atlantic."],[4879,5034,"It's worth every cent of that"],[5038,5155,"hundred million."],[5209,5317,"So if we get that mine,"],[5317,5384,"we won't have to worry"],[5384,5505,"about our supply chain anymore?"],[5797,5918,"Deal."],[6076,6197,"We'll take it."],[6360,6519,"No going back on your word now,"],[6519,6556,"Hunter."],[6589,6702,"Wait, wait, wait."],[6702,6823,"Hold on."],[6823,6944,"Come on, Cain."],[6977,7094,"Man up."],[7094,7190,"Let's shake on it."],[7190,7240,"Shut up!"],[7378,7499,"I'm no coward."],[7507,7632,"I want the terms of our bet"],[7632,7807,"to be put in writing."],[8091,8358,"No, Mr. Hunter you can’t!"]],"62":[[37,191,"Away Vicario."],[266,400,"Men are talking business here."],[1088,1255,"There, contract."],[1272,1393,"Sign it."],[1693,1822,"If Cain Hunter’s ore"],[1822,1914,"fails to produce a piece"],[1914,2085,"worth more than 50 million USD,"],[2085,2181,"then Michael Leonard,"],[2398,2515,"hereby wins the wager"],[2515,2623,"and will gain possession"],[2623,2761,"of Cain Hunter’s orange diamond."],[2761,2882,"That's what it says."],[2973,3161,"And if Cain Hunter’s ore"],[3161,3336,"produces a piece worth 50 million"],[3336,3470,"USD or higher,"],[3470,3574,"then Cain Hunter"],[3574,3732,"hereby wins the wager"],[3753,3862,"and will gain possession"],[3862,4012,"of the Leonard Emerald Mine."],[4112,4233,"Okay."],[5513,5588,"Come on,"],[5588,5739,"let's see what’s inside."],[6118,6235,"Cain Hunter."],[6243,6356,"You think you've won,"],[6356,6498,"but you've got that wrong."],[6702,6873,"I'll make you eat your words."],[6927,7044,"Really?"],[7065,7152,"I hope that you didn't"],[7152,7273,"forget what happened last time"],[7294,7424,"or the time before that."],[7599,7716,"I mean now that I think about it,"],[7716,7874,"you've lost a lot of money"],[7878,7966,"trying to one up me."],[7966,8128,"Oh, you!"],[8145,8308,"Open her up!"],[8341,8441,"Cain Hunter!"],[8441,8621,"You are going to lose,"],[8621,8742,"today!"],[9918,10018,"Wait."],[10018,10135,"That shade of red!"],[10293,10402,"That's..."],[10402,10518,"Is that painite?"],[10581,10702,"What?"],[10869,10985,"That's impossible!"]],"63":[[62,154,"Yes."],[179,283,"Yes!"],[283,408,"We've struck it rich."],[429,613,"Chalice gems is saved!"],[746,867,"Oh!"],[1063,1255,"That’s painite alright!"],[1255,1426,"Something that big has got to be over"],[1426,1551,"$1 billion."],[1618,1785,"That's more than what most"],[1785,1914,"underground families have"],[1914,2010,"combined."],[2014,2131,"No."],[2147,2268,"I don't believe you!"],[2285,2460,"No! That's impossible."],[2473,2585,"Every expert said"],[2585,2740,"that there was nothing in there."],[2794,2932,"How could it have painite!"],[2932,3190,"One of the world's rarest gems!"],[3228,3328,"Sounds like you need to hire"],[3328,3432,"new experts."],[3432,3528,"First they screwed you out of"],[3528,3656,"15 million, and then"],[3656,3766,"they let a billion dollar rock"],[3766,3933,"go for pennies on the dollar."],[4012,4245,"We owe you big, Mr. Leonard!"],[4279,4350,"You just gave"],[4350,4571,"Chalice Gems a huge boost."],[4738,4897,"It's going to be easy peasy,"],[4897,5013,"lemon squeezy"],[5013,5167,"to take down Chandler now."],[5926,6156,"That’s what I call a slap in the face."],[6331,6423,"Ms. Vicario,"],[6423,6502,"I'll let you handle"],[6502,6623,"the Leonard acquisition."],[6631,6723,"Yes, sir."],[6981,7107,"And fuck you."],[7682,7870,"Mr. Hunter, Chalice Gems"],[7870,8070,"jewelry crisis is all but resolved."],[8108,8241,"Money has been raking in"],[8241,8383,"ever since investors heard that"],[8383,8537,"we got Leonard's emerald mine."],[8591,8637,"Your wedding"],[8637,8800,"preparations are going swimmingly."],[8812,8958,"The engagement gift has been given"],[8958,9084,"to Miss Annalise Hurst."],[9084,9259,"And RSVPs have been sent out"],[9259,9409,"to all the biggest families"],[9409,9526,"in North America."],[9542,9663,"Good."],[9688,9838,"Congratulations, Mr. Hunter"],[9838,9993,"You have passed the second test."],[10047,10135,"You are only"],[10135,10272,"a few steps away from becoming"],[10272,10389,"the next Godfather of"],[10389,10464,"Bourne Syndicate."],[10514,10635,"As it should be."],[10869,10965,"Come on,"],[10965,11123,"let's go see Don Ludwig."],[11182,11332,"I’m ready for my next challenge."],[11344,11486,"Yes, Mr. Hunter."]]}