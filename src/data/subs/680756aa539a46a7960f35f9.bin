{"1":[[1343,1413,"Yes!"],[2147,2285,"Your deployment's tomorrow."],[2344,2489,"I'm still worried."],[2489,2569,"Don't worry."],[2627,2719,"I'm gonna be back,"],[2719,2827,"and I'm gonna be safe and sound."],[2827,2915,"The first thing we're gonna do"],[2915,2986,"is get married."],[3023,3115,"I'll be waiting."],[4833,5000,"Oh my god, I missed you!"],[5184,5334,"I missed you."],[5334,5430,"I missed you so much."],[5497,5576,"Oh my god,"],[5576,5722,"it's so good to see you!"],[5722,5860,"So good to see you."],[5901,6014,"I missed you a lot."],[6135,6260,"I can't wait to go home together."],[6260,6335,"Yeah."],[6335,6423,"Where are we going for dinner?"],[6448,6573,"I'm so sorry to interrupt,"],[6573,6723,"but have you seen Ace?"],[6752,6902,"He was supposed to come out with you."],[6902,6990,"Ace?"],[6990,7132,"He's been back for a month."],[7165,7286,"He didn't tell you?"],[7357,7424,"What?"],[7628,7707,"Call him up."],[7707,7786,"You'll see."],[7899,7966,"Let's go."],[8262,8491,"Ace came back a month ago?"],[8521,8721,"But he hasn't been answering my calls."],[9246,9338,"Ace, open up!"],[9338,9459,"I know you're in there!"],[9542,9597,"Ace!"],[9680,9743,"Ace!"]],"2":[[145,254,"Ace, what are you doing?"],[333,446,"Who is that woman?"],[880,1009,"Ace, open the door!"],[1188,1259,"Who the hell are you,"],[1259,1393,"and what do you want with Ace?"],[1393,1493,"I need to see him."],[2127,2185,"Ace!"],[2306,2389,"Explain!"],[2406,2460,"Look, I don't know what"],[2460,2585,"you want me to say, I..."],[2736,2836,"It's over."],[2957,3065,"I got myself a new girl."],[3140,3257,"It's time for you to move on."],[3299,3453,"What do you mean it's over?"],[3536,3712,"I waited for you for three years."],[3712,3849,"You said we were gonna get married"],[3849,3987,"when you came back and now you're just"],[3987,4137,"telling me to move on?"],[4175,4283,"I was just fooling around"],[4283,4350,"that whole time."],[4350,4521,"I didn't mean any of it."],[4567,4733,"Besides, I was never in love with you"],[4733,4833,"like I am with Sally."],[4833,4979,"She's the one, all right?"],[4979,5063,"It's not you."],[5096,5263,"I don't believe you."],[5263,5438,"No, I demand that you come out here,"],[5438,5572,"and talk to me face to face!"],[5572,5718,"You owe me that at least!"],[5718,5843,"That's the problem with you, isn't it?"],[5910,6010,"You're always demanding this,"],[6010,6072,"demanding that."],[6072,6235,"If Elena's not happy, nobody's happy."],[6235,6435,"You're a spoiled rich heiress."],[6473,6552,"And"],[6552,6690,"no guy wants a woman like that."],[6690,6819,"Can't you understand that?"],[6940,7057,"Just fuck off."],[7186,7365,"My dad was right about you."],[7532,7695,"I never should have fallen for you."],[7695,7866,"I hate you, Ace Atkins!"],[8963,9104,"Did you really have to be so cruel?"],[9138,9255,"I mean, I feel like you probably"],[9255,9351,"could have told her the truth."],[9351,9480,"She's not gonna leave you."],[10397,10535,"That's what I'm afraid of."],[10652,10735,"I love her."],[10923,11052,"Just gotta let her go."],[11423,11582,"Let's get you into that wheelchair."]],"3":[[1793,1989,"I want you to end things with Elena."],[1989,2127,"The engagement is off."],[2127,2323,"Take this money as your compensation."],[2573,2669,"Mr. Pearson, I..."],[2736,2898,"obviously always have had"],[2898,3078,"a lot of respect for you."],[3078,3294,"Quite frankly, I have no interest"],[3294,3345,"in your money."],[3345,3528,"All I need is a chance to talk to Elena."],[3528,3611,"That's all I'm asking for-"],[3611,3703,"What can you possibly"],[3703,3820,"do for Elena?"],[3820,4008,"When you can't even stand on your own!"],[4066,4233,"All you'll do is break her heart!"],[4287,4429,"I'll never let my little girl"],[4429,4592,"marry a one-legged cripple."],[4642,4754,"If you really love her,"],[4754,4867,"leave her alone!"],[7486,7640,"Thanks for doing this, Sally."],[7640,7757,"I really appreciate it."],[7932,8070,"We'll start physical therapy"],[8070,8166,"in 10 minutes."],[8166,8304,"I'll go get the equipment."],[8692,8800,"I love you, Elena."],[8917,9013,"Forget about me."],[9092,9234,"You'll find happiness again."]],"4":[[225,412,"Early this morning, Carter Pearson,"],[412,596,"CEO of Pearson Healthcare,"],[596,700,"was fatally shot"],[700,892,"by a gunman on Fifth Avenue."],[892,1009,"Police suspect the attack"],[1009,1088,"may be related"],[1088,1192,"to the wave of insurance"],[1192,1301,"policy changes"],[1301,1393,"that Pearson Healthcare"],[1393,1539,"is preparing to implement."],[1539,1776,"For now, the gunman remains at large."],[1776,1989,"While Elena Pearson, the victim's daughter,"],[1989,2152,"is set to take over as CEO."],[3311,3407,"Clean that up."],[4104,4216,"Good morning, gentlemen."],[4216,4346,"I've called this emergency meeting"],[4346,4416,"to make an important"],[4416,4554,"announcement."],[4554,4746,"I will be continuing to advance"],[4746,4863,"healthcare reform."],[4996,5117,"The goal"],[5117,5263,"is to ensure all patients"],[5263,5563,"receive fair insurance coverage."],[5563,5668,"And to make healthcare more"],[5668,5789,"affordable for everyone."],[5918,6001,"My plan."],[6331,6510,"To hell with your shit plan!"],[6510,6631,"You're giving away our profits"],[6631,6785,"to these poor people!"],[6785,6923,"I reject it!"],[6923,7115,"Uncle Huston, poor healthcare policies"],[7115,7336,"have led to my father's death."],[7336,7457,"My plans are implemented"],[7457,7599,"to correct these wrongs."],[7678,7824,"No matter what you say,"],[7824,7949,"I will never,"],[7949,8108,"ever change my mind."],[8162,8245,"Oh really?"],[8345,8445,"You think you can control"],[8445,8562,"the entire group?"],[8662,8762,"I'm not the only one against"],[8762,8892,"this bullshit plan."],[13363,13459,"Looks like you all need some"],[13459,13571,"more training still."],[13613,13734,"Got a long way to go."],[14018,14114,"Will the healthcare heiress"],[14114,14189,"be able to bring about"],[14189,14280,"meaningful reform,"],[14280,14497,"or will she be next on the assassin's list?"],[14618,14693,"Hey Josh, can you bring me"],[14693,14839,"my head set and my jacket please?"],[14956,15010,"Ace,"],[15065,15177,"you're the CEO of the company."],[15223,15323,"You can totally assign someone else"],[15323,15432,"to handle Elena's case."],[15561,15724,"So you heard the news too, huh?"],[15724,15844,"You think anyone's gonna protect her"],[15844,15957,"like I would, Josh?"],[16170,16253,"I'll handle it."]],"5":[[379,471,"Elena,"],[471,600,"today,"],[600,742,"you're going to follow my plan"],[779,938,"to increase healthcare prices."],[988,1067,"Or we"],[1067,1284,"will vote to dismiss you as CEO."],[1284,1393,"Simple as that."],[1393,1514,"Without the board's approval,"],[1514,1680,"you have no right to dismiss me."],[2794,2911,"Have you lost your mind?"],[2911,3094,"Forcing a signature's illegal!"],[3094,3278,"No one here will testify against me."],[3278,3478,"Just sign the damn paper."],[3578,3757,"Are you all gonna let him do this?"],[3757,3895,"Elena, you're asking us to throw"],[3895,4108,"money away on those lowlifes."],[4108,4195,"Don't blame us because"],[4195,4316,"we're not picking your side."],[4988,5059,"Let's go, guys."],[5059,5125,"Come on."],[6510,6652,"Get your hands off of her."],[6781,6869,"No way."],[6869,7002,"That voice."],[7002,7123,"It can't be him."]],"6":[[20,166,"It can't be him."],[1155,1343,"Long time no see, Ms. Pearson."],[1618,1755,"I'm your personal bodyguard."],[1818,1939,"It's been three years."],[2018,2131,"I've missed you, Elena."],[2185,2285,"You're my what?"],[2298,2410,"Jesus, Elena."],[2444,2519,"Could you do something about"],[2519,2615,"your bodyguard?"],[2677,2815,"You stupid or something?"],[3128,3265,"You insult my boss again,"],[3265,3332,"you're gonna be the one"],[3332,3482,"that needs some fucking healthcare."],[3566,3724,"Okay, everyone out"],[3724,3820,"of my boardroom!"],[4279,4396,"Well, leave!"],[4396,4466,"Or you're fired!"],[4466,4625,"I don't give a shit you're my uncle."],[4671,4754,"There's only one way"],[4754,4950,"to deal with people like you, Elena."],[4950,5113,"And that's to get rid of them."],[5113,5330,"Just like I got rid of your father."],[5743,5843,"What are you doing here?"],[5955,6081,"No one told me anything about"],[6081,6247,"needing a personal bodyguard."],[6402,6527,"Well, Ms. Pearson."],[6598,6706,"Mr. Atkins."],[6790,7023,"I'm Oliver, the family butler."],[7023,7152,"Miss,"],[7152,7378,"Mr. Ace Atkins is the most"],[7378,7561,"sought after bodyguard"],[7561,7699,"in America."],[7699,7857,"Now as per the contract,"],[7857,8045,"he will"],[8045,8212,"provide you protection"],[8212,8437,"24 hours to ensure"],[8437,8616,"your safety at all times."],[8704,8762,"No."],[8979,9146,"I won't have him as my bodyguard."]],"7":[[8,212,"I won't have him as my bodyguard."],[212,266,"Oliver,"],[337,567,"you can get me literally anyone else."],[567,663,"Anyone but him."],[663,984,"Ma'am, I urge you to rethink this."],[984,1146,"With him around,"],[1146,1267,"your safety is"],[1267,1455,"practically guaranteed."],[1539,1618,"Oliver, can you leave us"],[1618,1697,"alone for a minute?"],[1697,1826,"I need to talk to him."],[1864,1956,"Yes, Ma'am."],[2327,2510,"Ace, what are you doing here?"],[2510,2585,"I was just making sure"],[2585,2711,"that you were safe."],[2711,2882,"Healthcare CEOs are on high alert"],[2882,3065,"right now and, well,"],[3240,3386,"I was worried about you."],[3386,3536,"We broke up three years ago."],[3536,3620,"You cheated on me."],[3620,3707,"You don't have the right"],[3707,3837,"to be worried about me."],[3916,4116,"The last thing I need right now"],[4116,4329,"is you being my bodyguard."],[4383,4491,"The contract's already signed,"],[4491,4729,"so I'll just cover the termination fee."],[4771,4854,"Now go."],[4854,4979,"I don't really understand why"],[4979,5205,"you're refusing all of this help."],[5480,5563,"Are you afraid you're gonna"],[5563,5722,"fall in love with me again?"]],"8":[[12,95,"Are you afraid you're gonna"],[95,254,"fall in love with me again?"],[287,454,"Why is my heart beating so fast?"],[513,633,"You're delusional."],[725,809,"Elena."],[1176,1301,"The rational thing to do is"],[1301,1409,"to think of your safety"],[1409,1601,"right now, so just let me protect you."],[1697,1839,"Only an idiot"],[1839,1976,"would entrust their safety to someone"],[1976,2060,"who cheated on them"],[2060,2193,"while they were engaged."],[2248,2323,"Let go!"],[2752,2857,"Take me home."],[3207,3294,"Elena!"],[3678,3753,"Asshole."],[3807,3912,"You broke my heart,"],[3912,3987,"and now you come back"],[3987,4166,"into my life like it's nothing?"],[4713,4859,"That's odd."],[4859,4963,"I turned off the lights"],[4963,5121,"when I left the house, right?"],[5780,5864,"Someone broke in."],[5947,6039,"The killer?"]],"9":[[1685,1864,"Why so surprised, princess?"],[1935,2110,"Didn't you know you were gonna be next?"],[2423,2519,"No."],[2519,2598,"I don't wanna die."],[2598,2765,"Please, someone help me."],[6694,6835,"Ace, oh God!"],[7123,7273,"I thought I was gonna die!"],[7340,7399,"You're not gonna die."],[7399,7478,"You're safe."],[7570,7640,"Are you hurt?"],[7640,7745,"You all right?"],[7770,7849,"You saved me."],[8053,8116,"Ace."],[8437,8516,"You're bleeding."]],"10":[[229,446,"He might be an asshole, but damn,"],[446,613,"he's even hotter than he used to be."],[742,930,"She still got that same glow."],[930,1088,"God, I missed her."],[1272,1338,"Do you remember"],[1338,1484,"the last time that we..."],[1664,1780,"were in the bathroom?"],[2944,3057,"Ace, harder."],[3153,3278,"Yes, ma'am."],[3820,4004,"That guy got you in the leg too, right?"],[4004,4091,"I should"],[4091,4200,"wrap that up."],[4208,4270,"No, no, no."],[4358,4496,"He tried to stab me"],[4554,4667,"in the leg and he missed."],[4667,4783,"It's fine."],[4783,5050,"I saw the knife go straight into your leg."],[5384,5530,"Ace, is there something wrong?"],[5530,5647,"My leg is fine."],[5693,5747,"Okay?"]],"11":[[1989,2085,"Oh!"],[2085,2168,"my..."],[2406,2598,"Am I interrupting?"],[2598,2711,"No, uh..."],[2711,2827,"No."],[2827,2973,"Ace, uh,"],[2973,3199,"cut himself and"],[3199,3274,"I was just helping him"],[3274,3353,"dress the wound."],[3595,3774,"Mr. Atkins, I..."],[3774,3887,"brought your luggage up."],[3887,3966,"Great."],[4083,4245,"Wait, he's not staying with me."],[4333,4475,"Yes, Ms. Pearson."],[4512,4583,"Of course."],[4633,4767,"That's exactly what a"],[4767,4975,"personal bodyguard does."],[4975,5167,"The contract clearly states"],[5246,5338,"that Mr. Atkins"],[5338,5538,"must remain by your side"],[5538,5885,"24/7 to ensure your safety."],[5947,6131,"Oliver, it's not just about the contract."],[6131,6218,"I, I can't."],[6360,6544,"I can't let my ex-boyfriend"],[6544,6735,"live with me as my bodyguard."],[6815,6944,"You must understand."],[7023,7336,"You might very well be the next target."],[7419,7707,"If you fail to understand this,"],[7707,7887,"then I shall have to tender"],[7887,8083,"my letter of resignation."],[8145,8229,"Okay, fine."],[8337,8462,"Oliver, you win."],[8541,8650,"Brilliant."],[8721,8883,"Mr. Atkins,"],[8883,9046,"from here on out,"],[9046,9363,"Ms. Pearson's safety is in your hands."],[9851,9993,"I would take a bullet for her."]],"12":[[867,942,"You're"],[942,1059,"the first door on the left."],[1096,1192,"You can stay there."],[1284,1330,"Elena-"],[1330,1434,"Ace, let's just address"],[1434,1551,"the elephant in the room."],[1655,1797,"We broke up three years ago"],[1797,1893,"and that's that."],[1989,2143,"Now, if you're going to be staying here,"],[2143,2327,"we need to establish some boundaries."],[2427,2598,"So here's how it's gonna go."],[2598,2727,"You're gonna do your job"],[2727,2848,"as my bodyguard,"],[2848,2973,"and I'm gonna live my life."],[3044,3136,"Nothing else."],[3244,3332,"Is that clear?"],[3457,3541,"Crystal."],[3695,3816,"I'll go unpack my stuff."],[5105,5230,"Is this his wallet?"],[6331,6452,"You said you never loved me."],[6452,6564,"So why do you have a photo"],[6564,6710,"of me inside your wallet?"],[7486,7574,"I checked the house."],[7574,7657,"It's all clear."],[7724,7816,"Safe to sleep."],[7857,7987,"Great, thanks."],[8058,8191,"I'm gonna go to bed now."],[10802,10885,"Shit."],[11665,11749,"Sorry."],[11857,11957,"I thought you were in danger."],[12053,12208,"Just hand me that towel."]],"13":[[425,600,"It's not like I haven't seen you before."],[1288,1426,"Be professional."],[1426,1576,"I'm still your boss, remember?"],[2135,2218,"Yes, Ma'am."],[4391,4554,"You've changed a lot, Elena."],[4646,4767,"And after all these years,"],[4767,4942,"I still feel the same about you."],[6523,6723,"Ace, I have some scar cream for you."],[6723,6827,"Yeah, just hold on a second."],[6827,6898,"One minute."],[7415,7499,"Hey, what's up?"],[7653,7736,"Hey."],[7887,7945,"Just..."],[8020,8174,"I have something for the scars."],[8283,8366,"I can put it on."],[8475,8550,"Great."],[9501,9651,"I'm surprised that you still..."],[9922,10089,"show this much care for me still."],[10222,10347,"Get over yourself."],[10493,10668,"I'm just helping you because I'm nice."],[10785,10935,"Elena, calm yourself."],[10935,11211,"He's just a stupid ex with a hot body."],[11319,11403,"Okay."],[11732,11803,"Done."],[11895,11995,"Thank you."],[12550,12741,"Okay, what is with you and this blanket?"],[12812,13017,"I saw that guy get you in the leg."],[13179,13288,"My leg is fine."],[13400,13580,"I'm just sitting, so I sit."],[13722,13817,"I call BS."],[13817,13901,"Let me see it."]],"14":[[567,667,"What if I'm..."],[746,905,"hiding something under there?"],[984,1222,"Maybe I'm hiding a boner."],[1255,1393,"Wanna see it?"],[2248,2369,"You're not my boyfriend anymore."],[2369,2469,"You're my bodyguard."],[2585,2761,"We should keep things professional."],[3023,3115,"Good night."],[3361,3465,"Good night."],[3728,3845,"You're right, Elena."],[3953,4079,"I'm just your bodyguard."]],"15":[[437,508,"Elena,"],[604,700,"I want you to put this on."],[700,834,"It's lightweight."],[834,950,"You won't even feel it."],[1001,1126,"I'm not wearing that."],[1126,1234,"You can either do it yourself,"],[1234,1409,"or I could strip your clothes off for you,"],[1534,1634,"and I can do it."],[1634,1856,"And if you ask me, I prefer the latter."],[1856,2002,"Okay, I can do it myself."],[2756,2840,"May I?"],[2907,3015,"No, I got it."],[4792,4884,"Why does he have to be"],[4884,5075,"so damn attractive?"],[5130,5213,"Too tight?"],[5296,5380,"No."],[5526,5593,"Okay,"],[5638,5726,"I have to go."],[5726,5818,"I'm late for work."],[5968,6047,"Yes, Ma'am."]],"16":[[358,492,"I'm assuming the assassination"],[492,596,"didn't go as planned?"],[617,784,"That idiot calls himself a hit man,"],[784,967,"he can't handle a defenseless woman?"],[1142,1276,"Chad,"],[1276,1426,"I'm leaving this to you."],[1426,1534,"Seduce Elena,"],[1534,1659,"get her under your thumb,"],[1659,1872,"and Pearson Healthcare is ours."],[1872,1968,"Consider it done."],[2615,2694,"Jesus, Chad,"],[2694,2748,"how many times"],[2748,2852,"have I told you to knock?"],[2973,3057,"What do you want?"],[3161,3357,"You owe me dinner, remember?"],[3357,3457,"I remember."],[3545,3695,"But I'm swamped with work"],[3695,3824,"and planning a funeral,"],[3824,3983,"so can we take a rain check?"],[3983,4041,"Let me handle"],[4041,4145,"the funeral preparations."],[4308,4387,"You've been working too hard"],[4387,4517,"since your father passed."],[4517,4642,"This is how people get burned out."],[4642,4763,"You need to take some time off"],[4763,4884,"to relax."],[5659,5743,"Yeah."],[5864,5910,"You know what?"],[5910,5993,"Let's do dinner."],[6473,6556,"Great."]],"17":[[867,971,"Sir,"],[971,1088,"this"],[1088,1213,"is a table for two."],[1451,1601,"Why don't you go sit over there?"],[3741,3870,"I'm Ms. Pearson's bodyguard."],[3870,3966,"I got to"],[3966,4091,"keep a tight perimeter around her"],[4091,4175,"at all times,"],[4175,4308,"but thanks for checking in."],[5292,5430,"Oh, don't let me interrupt."],[5430,5559,"You guys haven't ordered yet."],[5559,5622,"Go ahead."]],"18":[[350,442,"'82 Lafite,"],[525,654,"your favorite."],[654,809,"I found a collector who was willing"],[809,950,"to sell it to me."],[950,1071,"Here, have a taste."],[1472,1618,"Hey, I find it kind of rude, Chad,"],[1618,1743,"that you're not offering me a drink."],[1743,1851,"I am attending this dinner"],[1851,1981,"with the two of you, aren't I?"],[2085,2156,"Well,"],[2206,2310,"Mr. Atkins,"],[2377,2519,"seeing that you're Elena's bodyguard,"],[2519,2660,"I didn't find it appropriate for you"],[2660,2811,"to be drinking on the job now."],[3078,3174,"My apologies."],[3365,3449,"Elena."],[3778,3928,"I know how tough it's been for you,"],[4016,4162,"and I want you to know that"],[4162,4254,"I'm here for you,"],[4362,4429,"always,"],[4571,4733,"and that my heart belongs to you."],[5075,5184,"Sorry, Chad, I..."],[5242,5321,"I'm not really in the mood"],[5321,5455,"to talk about all that."],[5643,5722,"Can we eat?"],[5768,5855,"I'm starving."],[5922,5972,"Yeah."],[6001,6060,"Sam."],[6256,6414,"The mango salad."],[6731,6819,"Oh, hey, Sam."],[6819,6911,"Sorry about that."],[6998,7148,"She actually doesn't like mangoes."],[7148,7232,"Do you mind bringing out"],[7232,7353,"another plate without them?"],[7403,7532,"He still remembers?"],[7590,7778,"I'll see what I can do about that."],[8141,8283,"Wait, didn't"],[8283,8350,"you two just meet?"],[8350,8475,"How would he know that you"],[8475,8579,"don't like mangoes?"]],"19":[[0,120,"How would he know that you"],[120,225,"don't like mangoes?"],[371,583,"Well, we actually go way back."],[583,729,"And I know a hell of a lot more about her"],[729,821,"than just her preference"],[821,892,"of mangoes."],[892,1013,"He's my bodyguard."],[1013,1209,"Of course, Oliver told him everything"],[1209,1355,"that he needed to know."],[1355,1497,"I'll just pick around the mangoes."],[1960,2122,"Okay, something's definitely going on"],[2122,2281,"with Elena and her bodyguard."],[4821,4942,"What was that tonight?"],[5042,5159,"If I didn't know any better,"],[5159,5313,"I'd think you might be jealous of Chad."],[5405,5509,"Maybe you're just seeing things"],[5509,5668,"the way you want to see them."],[5834,5939,"You ever think about that?"],[5997,6101,"How could I forget?"],[6185,6335,"Right, you shattered my heart."],[6531,6639,"Elena, come on. - Just save it."],[6735,6840,"Just go home."],[6840,6952,"I have funeral preparations"],[6952,7044,"to make anyway."],[7474,7565,"I'm sorry, Elena."],[7682,7895,"I was just trying to give you a better life."],[7978,8162,"I didn't think it would hurt you this much."]],"20":[[371,454,"Elena."],[608,688,"Elena?"],[688,809,"Dad,"],[809,909,"you're back."],[2068,2152,"Dad!"],[2335,2419,"What's going on?"],[2502,2585,"Ace."],[2698,2894,"It's fine, I'm here, okay?"],[2894,2977,"You're safe."],[3123,3311,"I had a dream about my dad."],[3511,3699,"One second, he was smiling at me."],[3699,3841,"And then, the next..."],[4721,4971,"I just doubt myself sometimes."],[5130,5217,"Do you really think that"],[5217,5430,"I can make a change in this industry?"],[6218,6327,"You're the strongest woman"],[6327,6435,"I've ever known,"],[6552,6685,"and I think that you can do anything"],[6685,6794,"that you set your heart on."],[6940,7061,"Besides, I'm gonna be right here"],[7061,7244,"the whole time supporting you,"],[7244,7369,"protecting you."],[7565,7699,"Protecting me?"],[7924,8078,"Do you really think I can trust you"],[8078,8245,"after what you've put me through?"],[8554,8754,"Our relationship, that is in the past,"],[8963,9205,"but I would protect you with my life."],[9205,9309,"I'd die for you."],[9463,9613,"I need you to understand that."],[9776,9897,"So you would die for me,"],[9897,10080,"but you won't love me?"]],"21":[[75,196,"So you would die for me,"],[196,379,"but you won't love me?"],[2523,2644,"Stay with me."],[2902,2965,"You said you wanted to"],[2965,3090,"keep things professional."],[3353,3516,"You're my bodyguard,"],[3603,3707,"and I'm scared."],[3991,4162,"Stay with me,"],[4162,4316,"so I can feel safe."],[6060,6214,"If only I could stay by your side"],[6214,6331,"like this forever."]],"22":[[400,513,"What are we doing here?"],[558,658,"I'm going to teach you some basic"],[658,796,"self-defense techniques."],[859,1030,"You know, just in case."],[1030,1163,"Always gotta be prepared."],[1267,1476,"What I mean is in case I die first,"],[1476,1626,"and you're still in danger,"],[1626,1701,"you can"],[1876,1985,"fight your way out."],[2173,2273,"First case scenario."],[2852,2986,"What would you do"],[2986,3082,"if someone had you against"],[3082,3178,"a wall like this?"],[3828,3974,"No, all the pushing in the world"],[3974,4091,"won't do anything."],[4212,4337,"Try putting your hand on a more"],[4425,4537,"vulnerable place."],[4667,4750,"That one there."],[4946,5059,"And that one there."],[5121,5230,"Push as hard as you can."],[5726,5809,"Right."],[5809,5897,"Nice."],[6202,6302,"All right."],[6302,6402,"Second scenario."],[6589,6727,"What if somebody"],[6952,7069,"had you like this?"]],"23":[[58,196,"What if somebody"],[350,467,"had you like this?"],[688,859,"It's just self-defense training."],[859,1013,"Don't let it get to you, Elena."],[1176,1272,"What's your move?"],[1614,1960,"I'd go for the more vulnerable part,"],[1960,2189,"like stomping on the foot."],[2515,2594,"Very nice."],[2594,2773,"You're a very fast learner, aren't you?"],[2869,2998,"Okay,"],[2998,3098,"third scenario."],[3165,3244,"You ready?"],[3315,3399,"All right."],[4116,4262,"Someone's got you like this,"],[4346,4475,"starts choking you."],[4658,4750,"You got to be quick."],[4829,4984,"Like this?"],[4984,5067,"No."],[5159,5255,"Use your hips."],[5338,5422,"What?"],[5472,5663,"Use your hips to thrust me off of you,"],[5663,5793,"as hard as you can."],[6218,6373,"Ace, are you okay?"],[6373,6502,"Did I hurt your leg?"],[6502,6552,"No, I'm fine."],[6552,6652,"What was that sound?"]],"24":[[116,233,"You didn't hurt my leg."],[308,383,"It's fine."],[383,462,"That was a good job."],[575,667,"No, you're hurt."],[738,825,"Let me see. - I'm fine."],[825,942,"That was good work though,"],[942,1046,"seriously."],[1046,1130,"Ace,"],[1130,1209,"the new security equipment"],[1209,1288,"just arrived."],[1288,1405,"Can you come check it out?"],[1405,1472,"Yeah, sure."],[1472,1543,"Thanks, Josh."],[1705,1789,"Good job today."],[1893,1976,"Seriously."],[2585,2744,"That sound was weird."],[3219,3378,"Ace is hiding something from me."],[3520,3595,"Hi."],[3661,3762,"Elena, right?"],[3791,3891,"I'm Josh."],[3949,4158,"I used to serve with Ace in the military,"],[4158,4320,"but now we're colleagues."],[4320,4471,"He talks about you a lot."],[4471,4587,"Hi, Josh."],[4754,4896,"I'm sorry, can I ask,"],[4971,5113,"is there something going on"],[5113,5251,"with Ace's leg?"]],"25":[[79,241,"Huh, leg?"],[241,346,"No,"],[346,467,"not that I know of."],[467,583,"You know,"],[583,800,"Ace's been single for years now."],[800,992,"Everyone here knows that"],[1080,1184,"there's someone he's never been able"],[1184,1263,"to forget,"],[1263,1497,"and that person is you, Elena."],[1718,1830,"You're mistaken."],[1830,1876,"He..."],[1910,2010,"he doesn't love me,"],[2072,2118,"at all."],[2118,2181,"If you knew him,"],[2181,2248,"then you would know"],[2248,2439,"that he broke up with me three years ago."],[2506,2585,"You know,"],[2585,2761,"I might be just an outsider,"],[2761,2932,"but I know Ace."],[3023,3094,"Maybe some things"],[3094,3194,"aren't what they seem."],[3378,3566,"Alright, I gotta go check up on Ace"],[3566,3682,"and the new equipment."],[3682,3837,"It was nice meeting you, Elena."],[4041,4175,"Maybe some things"],[4175,4308,"aren't what they seem."],[4308,4437,"What does that even mean?"],[4592,4658,"Yeah, thanks, Josh."],[4658,4779,"Everything looks great."],[4779,4900,"Okay, thanks."],[5230,5317,"Ace,"],[5384,5513,"Elena asked about your leg."],[5755,5843,"What'd you say?"]],"26":[[200,296,"What'd you say?"],[296,379,"Don't worry."],[379,479,"I didn't say a word."],[600,650,"But"],[696,775,"honestly, man,"],[859,992,"I think she still cares about you."],[992,1151,"Maybe it's time you tell her the truth."],[1151,1272,"I appreciate your input, Josh,"],[1272,1384,"but I think I know what's best"],[1384,1497,"for Elena and I."],[1559,1726,"Might wanna deal with that prosthetic"],[1726,1814,"soon though."],[1814,1981,"It's overdue for a replacement."],[1981,2085,"If you keep stalling,"],[2085,2185,"you're going to damage the nerves"],[2185,2277,"in your leg, man."],[2335,2477,"You know that a new prosthetic"],[2477,2627,"would take about three weeks."],[2673,2777,"I'm still on the job."],[2777,2907,"I can't leave Elena alone."],[2907,3078,"I think that would be very"],[3078,3174,"irresponsible of me."],[3174,3307,"Don't you think, Josh?"],[3307,3424,"Man,"],[3424,3545,"you're one hell of a romantic."],[3545,3628,"You know that?"],[3628,3749,"Yeah, well, that makes one of us."],[3749,3841,"Why don't you"],[3841,3974,"get the hell out of here, all right?"]],"27":[[100,200,"Almighty God,"],[279,367,"in your mercy,"],[367,500,"turn the darkness of death"],[571,746,"into the dawn of new life,"],[746,884,"and the sorrow of parting"],[950,1130,"into the joy of heaven,"],[1130,1288,"through our Savior Jesus Christ,"],[1326,1463,"who died,"],[1463,1609,"rose again,"],[1609,1789,"and lives for evermore."],[1860,1931,"Amen."],[2339,2456,"My deepest condolences."],[2565,2777,"May your father rest in peace."],[2777,2877,"Your father knew that"],[2877,2977,"your reckless reforms"],[2977,3132,"were tearing his company apart,"],[3174,3307,"he'd never rest in peace."],[3386,3490,"He was your brother."],[3570,3695,"If you had even a shred"],[3695,3782,"of affection for him,"],[3782,3916,"you would never say something"],[3916,4083,"like that at his funeral!"],[4129,4225,"You know, Uncle Huston,"],[4225,4316,"I've always wondered,"],[4316,4446,"you've been far angrier"],[4446,4562,"about the healthcare reforms"],[4562,4742,"than my own father's murder."],[4825,4929,"Could it be that you had something"],[4929,5046,"to do with his death?"],[5201,5288,"That"],[5288,5426,"is outrageous slander."],[5492,5613,"How dare you accuse me"],[5613,5734,"of murdering my brother"],[5734,5830,"at his funeral?"],[6748,6848,"Sorry for your loss."]],"28":[[838,938,"That's enough."],[1472,1697,"This was my father's favorite."],[1697,1876,"I got it for him for his birthday,"],[1876,2114,"but he didn't even get a chance to drink it."],[3161,3249,"I'm right here."],[3336,3453,"I'm not going anywhere."],[4258,4341,"Good night."],[4562,4642,"No."],[4846,4975,"Don't go."],[5422,5638,"Can you promise,"],[5638,5864,"you won't leave me again?"],[5864,6051,"I promise,"],[6051,6189,"I'll never leave you again."],[6285,6373,"Josh said that"],[6373,6519,"there's someone in your heart,"],[6719,6835,"someone that you can't forget."],[6835,6961,"Is that someone me?"]],"29":[[75,221,"Tell me, Ace."],[905,1005,"Yes."],[1109,1338,"That someone is you,"],[1338,1451,"and it always has been."],[1451,1543,"If you love me,"],[1543,1730,"then why did you break up with me?"],[1730,1856,"Look, it's been a long day."],[1856,2097,"I don't think"],[2097,2243,"we should talk about it."],[2293,2406,"I'm just gonna end up hurting you."],[2406,2615,"But you did hurt me!"],[2740,2827,"Three years ago,"],[2827,3023,"I waited for you to come back"],[3023,3115,"and marry me,"],[3115,3395,"and then you left me for another woman!"],[3395,3553,"You broke my heart,"],[3620,3678,"and then you just"],[3678,3812,"waltzed back in my life"],[3812,3978,"like nothing happened!"],[3978,4108,"Just look, okay? - No!"],[4108,4200,"No!"]],"30":[[2777,2990,"Oh my God, I drank too much."],[3069,3178,"Did we"],[3178,3307,"sleep together?"],[3395,3486,"Hungry?"],[3595,3728,"Made you breakfast."],[3858,3978,"Last night,"],[4095,4204,"did we..."],[4258,4400,"You were drunk,"],[4400,4562,"very drunk, I took care of you,"],[4604,4717,"and that was it."],[4717,4921,"He's not gonna mention the kiss?"],[5021,5117,"Jerk."],[5301,5409,"Well,"],[5409,5509,"thank you"],[5509,5572,"so much"],[5572,5768,"for taking such great care of me,"],[5768,5922,"Mr. Bodyguard."]],"31":[[538,663,"You've been far angrier"],[663,788,"about the healthcare reforms"],[788,950,"than my own father's murder."],[1051,1126,"Haven't you dealt with"],[1126,1238,"that bitch Elena yet?"],[1276,1380,"She's starting to suspect"],[1380,1447,"I had something to do"],[1447,1551,"with her father's death."],[1551,1659,"She's hard to handle."],[1755,1889,"That bodyguard of hers"],[1889,2027,"is practically glued onto her."],[2027,2110,"I can never get her alone"],[2110,2218,"to make any real progress."],[2281,2456,"This will not do."],[2548,2686,"She's been lobbying aggressively"],[2686,2777,"within the company."],[2777,2907,"Some of the board are starting"],[2907,3040,"to support her reforms."],[3040,3157,"If she keeps this up,"],[3240,3395,"I'll get pushed out of the company."],[3445,3566,"What do you want me to do?"],[3749,3853,"The company's annual gala"],[3853,3933,"is this weekend."],[3987,4116,"Elena will undoubtedly use it"],[4116,4283,"to rally more support from the board."],[4283,4379,"What you are going to do"],[4416,4567,"is invite her to go as your date,"],[4567,4675,"and then you're going to propose"],[4675,4783,"to her publicly."],[4829,4925,"Tell her she'll get more support"],[4925,4975,"from the board"],[4975,5125,"if she's married with a husband."],[5125,5238,"We can use the engagement"],[5238,5388,"to shift public focus"],[5442,5547,"away from reform."],[5588,5747,"Kill two birds with one stone, I like that."],[5747,5926,"Exactly, the media will be there,"],[5926,6035,"and she won't reject you in"],[6035,6139,"front of everyone."],[6185,6277,"There's no way she'd risk"],[6277,6356,"tanking the company's"],[6356,6477,"stock prices again."]],"32":[[262,325,"Elena,"],[450,600,"I was hoping I would be able"],[600,759,"to escort you to the company dinner"],[759,842,"this weekend."],[1080,1222,"I told you, Mr. Vega's been"],[1222,1343,"chasing Ms. Pearson."],[1343,1451,"He's been at it for ages."],[1451,1643,"His persistence is kind of impressive."],[2527,2606,"Chad, I-"],[2606,2706,"Elena, trust me,"],[2848,2990,"I can help you win over a couple more"],[2990,3061,"board members"],[3061,3186,"for the healthcare reform plan."],[3611,3699,"Yeah!"],[3745,3903,"Yes, I would love to go to dinner."],[3983,4116,"Great, see you later."]],"33":[[1505,1593,"How do I look?"],[1755,1851,"You look beautiful."],[1939,2002,"You know, I don't know if"],[2002,2147,"you had to dress so"],[2147,2214,"formally."],[2339,2498,"Are you jealous?"],[2581,2761,"I just don't think that, that guy"],[2869,3019,"deserves"],[3190,3278,"all of this."],[3691,3803,"Oh, speak of the devil."],[3983,4070,"Beautiful."],[4166,4250,"Elena, we should get going."],[4250,4341,"We're gonna be late."],[4416,4512,"And..."],[4512,4571,"Ace!"],[4650,4775,"Remember your place."],[4775,4925,"Okay there, sport?"],[4925,5030,"You're the bodyguard."],[5184,5359,"So make sure you keep a professional"],[5359,5438,"distance"],[5438,5593,"between you and your employer, yeah?"]],"34":[[200,329,"Elena's healthcare reform plan"],[329,508,"might have some short-term losses,"],[617,817,"but I believe the long-term benefits"],[817,955,"far outweigh the"],[955,1126,"small drawbacks."],[1217,1343,"Forget about that for a moment."],[1343,1509,"What we're really curious about"],[1509,1714,"is how far you two have gotten."],[1872,2097,"Given the company's current PR crisis,"],[2097,2248,"announcing a wedding might"],[2248,2460,"actually help repair its image."],[2460,2590,"Elena,"],[2590,2786,"Chad seems like an excellent match."],[2844,3061,"Oh, Mr. and Mrs. Hans,"],[3061,3219,"you're mistaken."],[3219,3303,"Chad and I aren't- - Thank you for"],[3303,3378,"your blessing,"],[3378,3541,"and we'll seriously consider it."],[3937,4170,"Our company has faced"],[4170,4358,"challenges recently,"],[4358,4466,"but"],[4466,4675,"on this special night,"],[4675,5009,"our new CEO, Ms. Elena Pearson,"],[5009,5176,"would like to say a few words."],[5538,5714,"Before Ms. Pearson says anything,"],[5830,5943,"I have a surprise for her."]],"35":[[8,187,"I have a surprise for her."],[187,458,"Elena, I have loved you for so long."],[1843,1956,"Will you marry me?"],[1956,2352,"Marry him! Marry him! Marry him!"],[2352,2623,"Marry him! Marry him! Marry him!"],[2623,2786,"Marry him!"],[2786,3073,"Marry him! Marry him! Marry him!"],[3073,3290,"Chad, stand up, what are you doing?"],[3290,3374,"I don't-"],[3499,3541,"Come on,"],[3541,3653,"let's go, we're leaving."]],"36":[[521,658,"What the hell are you doing?"],[658,750,"Storming out like that"],[750,829,"in front of all those guests,"],[829,980,"do you realize how bad you're making"],[980,1076,"the company's image look?"],[1076,1176,"Oh, really?"],[1176,1280,"So what, you're gonna just"],[1280,1351,"marry that guy"],[1351,1501,"to save the company's image?"],[1501,1597,"That's ridiculous."],[1597,1856,"Who I marry is none of your business."],[1897,1989,"We're over, Ace,"],[1989,2106,"you're just my bodyguard."],[2106,2281,"You don't get to interfere with my life."],[2327,2435,"You don't mean that."],[2540,2623,"You don't love that guy."],[2623,2777,"You barely fucking know him."],[2777,3003,"Who I love is none of your concern."],[3165,3311,"Don't pretend to care about me,"],[3311,3382,"Ace Atkins,"],[3382,3503,"when you push me away"],[3503,3699,"over and over again!"],[3699,3874,"Even if I'd said yes to Chad's proposal,"],[3874,4004,"you would have nothing to do with it,"],[4004,4124,"and you couldn't stop me."],[5125,5205,"Elena!"],[5205,5330,"Elena, where are you?"],[5643,5747,"Elena, are you in there?"],[6164,6302,"Tell him you're busy,"],[6302,6460,"make him leave."]],"37":[[16,154,"Tell him you're busy,"],[154,312,"make him leave."],[2498,2652,"I'll be out in a minute."],[2802,2936,"Are you sure you're okay?"],[3282,3390,"Yeah, I'm fine, just..."],[3440,3528,"just go."],[5163,5234,"Ace,"],[5263,5376,"you're a bastard."],[5401,5555,"Okay, all right, I'm sorry about that."],[5555,5722,"But that guy doesn't fucking deserve you."],[5722,5805,"Oh, and you do?"],[5926,6060,"You abandoned me,"],[6060,6218,"we were supposed to get married."],[6368,6544,"You have no right to say that to me."],[6614,6752,"What do you think's going on here?"],[6827,7011,"Do you think that I"],[7011,7082,"don't love you?"],[7082,7173,"I mean, do you have any"],[7173,7257,"fucking idea how much-"],[7257,7298,"Elena!"],[7399,7494,"Who's in there with you?"],[7494,7586,"How much what?"],[7586,7691,"What are you saying?"]],"38":[[0,125,"How much, how much what?"],[125,241,"What are you saying?"],[241,308,"Elena!"],[450,533,"What do you think?"],[988,1167,"What are you two doing in here?"],[1167,1226,"I could ask you"],[1226,1368,"the same question, Chad."],[1434,1509,"You told me it was just"],[1509,1614,"a date to the gala,"],[1614,1705,"and then you go and pull that"],[1705,1839,"stunt out there?"],[1839,2031,"Proposing in front of everyone?"],[2031,2081,"What-"],[2081,2168,"Have you lost your mind?"],[2168,2306,"Elena, I have been pursuing you"],[2381,2477,"for so long,"],[2477,2581,"and you never rejected me."],[2631,2786,"So, that has to mean"],[2840,2957,"that you feel the same way."],[2986,3061,"What?"],[3136,3257,"I haven't said anything."],[3257,3345,"You need to go out"],[3345,3461,"and tell the people the truth!"],[3461,3566,"What's the difference?"],[3661,3762,"Everybody already thinks"],[3762,3908,"that you're my fiancée now."],[3949,4120,"Since you never rejected me,"],[4120,4245,"it's clear that you like me."],[4245,4416,"It's only natural for us to be together."],[4416,4625,"Hey, don't step closer."],[4625,4767,"And who the hell are you?"],[4825,4992,"You're just a fucking bodyguard!"],[5155,5230,"Don't think I don't see"],[5230,5296,"what's happening."],[5376,5543,"Acting all on your high horse,"],[5543,5647,"but deep down,"],[5647,5718,"you're just a slut"],[5718,5855,"sleeping with your bodyguard."]],"39":[[404,517,"Bravo."],[517,654,"Bravo, you two are the perfect pair"],[654,759,"of adulterers."],[759,896,"Hey, this must be nice, huh?"],[921,1055,"Living with your boss,"],[1055,1201,"sleeping with her on the side."],[1201,1301,"Shut the fuck up."],[1301,1426,"What's the matter, struck a nerve?"],[1451,1634,"Elena, you have the"],[1634,1776,"audacity"],[1776,1956,"to accuse me"],[1956,2114,"of damaging the company?"],[2160,2302,"Take a look in the mirror."],[2373,2448,"You're the CEO,"],[2448,2577,"sleeping with your fucking bodyguard."],[2577,2677,"You're the real disgrace"],[2677,2777,"of the Pearson Group."],[3324,3428,"You see that girl right there?"],[3428,3524,"There's no one in the world"],[3524,3666,"that I love more than her."],[3666,3803,"You're not gonna disrespect her."],[3803,3924,"You show your face around here again"],[3924,4020,"and I'm gonna fucking kill you,"],[4020,4116,"do you understand?"],[4116,4237,"Do you understand?"],[5313,5426,"You, you love me?"],[5814,5930,"Did you mean what you said?"],[6156,6327,"Ace, just tell me the truth."],[6364,6594,"That's all it takes for us to start over."]],"40":[[37,141,"No,"],[141,271,"Elena, I can't be with you."],[271,417,"I'm just a man with a"],[471,533,"prosthetic."],[533,617,"I'm not whole."],[617,738,"I'll never be enough for you."],[796,917,"I was just impulsive."],[917,1009,"I shouldn't have said that."],[1009,1092,"I'm sorry."],[1201,1330,"You're lying."],[1330,1501,"You still keep a photo of us"],[1501,1576,"in your wallet."],[1685,1797,"You'd risk your life for me."],[1797,2047,"You, you'd stay up all night to protect me."],[2047,2210,"That is not just a bodyguard"],[2210,2293,"doing his job."],[2293,2402,"That is something more"],[2402,2577,"and you know it."],[2577,2698,"Moments ago, right here,"],[2698,2811,"you said that you love me"],[2811,3032,"more than anyone else in the world."],[3032,3111,"Ace,"],[3365,3470,"why won't you admit that"],[3470,3591,"you still love me?"],[3699,3832,"Elena, look..."],[4229,4312,"Look,"],[4466,4596,"I'm here to guard you."],[4717,4813,"I'm your bodyguard."],[4963,5071,"I shouldn't have crossed the line,"],[5071,5188,"and I'm sorry."],[5305,5422,"Now,"],[5422,5509,"let's go."],[5593,5693,"Stay away from me."],[5789,5872,"Elena."],[6106,6268,"I'm sorry, Elena."],[6268,6398,"I can't hold you back."],[6398,6502,"You deserve better than"],[6502,6644,"a broken man like myself."]],"41":[[492,696,"Can't handle one woman."],[696,804,"Absolutely useless."],[804,938,"That bitch has been screwing"],[938,988,"her bodyguard"],[988,1071,"the whole damn time!"],[1071,1172,"What do you want me to do?"],[1213,1418,"God, that pathetic freaking loser!"],[1626,1718,"I'm gonna kill him."],[1881,1968,"It's only a matter of time."],[2031,2131,"If that's the case,"],[2206,2352,"there's only one option left."],[2444,2577,"We want Pearson Group."],[2631,2781,"We're going to have to eliminate her,"],[2857,3057,"just like we did her father."],[4308,4491,"You think you can fix everything"],[4491,4646,"with these little tricks?"],[4646,4783,"Won't work, Ace."],[4783,4967,"I made your favorite,"],[4967,5063,"French toast."],[5163,5292,"I've been up since six, making sure"],[5292,5442,"everything was perfect."],[5501,5588,"I know it's been a while,"],[5588,5734,"so I hope it tastes like"],[5876,6001,"how you remember it."]],"42":[[475,638,"Oliver, what are you-"],[638,746,"What are you doing here?"],[804,925,"This"],[925,1130,"is a signed first edition."],[1242,1455,"Mr. Atkins went through several"],[1455,1568,"of his connections"],[1568,1743,"to track that down"],[1743,1868,"for you,"],[1868,2085,"and while you were at your meetings,"],[2085,2264,"he took it upon himself"],[2264,2560,"to redecorate your entire office."],[3315,3482,"Do you really think gestures like these"],[3482,3632,"are gonna make me forgive you?"],[3987,4200,"I just want you to be happy."],[4200,4300,"Elena,"],[4346,4479,"whether you forgive me or not,"],[4479,4600,"doesn't really matter."],[4662,4754,"You have every right to hate me"],[4754,4859,"and to push me away"],[4859,4975,"if that's what you want,"],[5071,5226,"but please,"],[5226,5417,"just don't let this anger"],[5480,5601,"eat away at you."],[5672,5801,"It wasn't your fault."],[5801,5889,"None of it was."],[6072,6156,"It was mine."],[6268,6398,"Don't think you've won me over,"],[6398,6535,"I haven't forgiven you yet."]],"43":[[29,150,"Don't think you've won me over,"],[150,287,"I haven't forgiven you yet."],[500,621,"Go make me a coffee."],[692,800,"I have a meeting soon."],[925,1009,"Okay."],[1351,1526,"Ms. Pearson,"],[1526,1710,"if I may say,"],[1764,2089,"Mr. Atkins cares for you deeply."],[2089,2306,"And from the way you look at him,"],[2306,2623,"it's clear you feel the same way."],[2623,2907,"So why not just be together?"],[2907,3073,"Oliver, you don't understand."],[3073,3253,"Every time I take a step forward,"],[3253,3415,"Ace takes two steps back."],[3536,3687,"It's not that simple."],[3687,3920,"Well, then maybe you should"],[3920,4104,"take the lead?"],[4104,4275,"Valentine's Day is"],[4275,4421,"right around the corner."],[4475,4675,"Why not use the occasion to"],[4675,4800,"clear the air,"],[4800,4963,"and finally"],[4963,5084,"talk it through?"],[5380,5463,"Maybe."]],"44":[[900,1121,"Maybe you should"],[1121,1222,"take the lead?"],[1393,1534,"The first gift I ever gave Ace"],[1534,1668,"was a motorcycle,"],[1668,1772,"and he loved it."],[1868,1943,"Ace, stay here,"],[1943,2085,"I have a surprise for you."],[2531,2627,"All right,"],[2627,2761,"your order will be delivered tonight."],[2815,2894,"Thank you so much."],[2894,2982,"Thank you for shopping with us,"],[2982,3069,"Ms. Pearson."]],"45":[[4008,4091,"Josh."],[4091,4175,"Josh!"],[4195,4308,"Elena's been taken."],[4308,4421,"Activate the tracking system,"],[4421,4525,"get the cops involved."],[4567,4667,"I'm going after her."]],"46":[[1197,1305,"Who are you?"],[1305,1430,"Look, if this is about the company's"],[1430,1530,"healthcare reforms,"],[1530,1634,"then I promise you,"],[1634,1822,"I'm proposing a new plan."],[1822,1960,"It's set to pass on Monday,"],[1960,2089,"so please don't kill me."],[2089,2214,"Shut your mouth."],[2360,2494,"This isn't about healthcare,"],[2494,2619,"you got it all wrong."],[2619,2711,"What?"],[3386,3582,"My uncle hired you?"],[3582,3753,"He paid you to kill my dad?"],[3753,3849,"Ding, ding, ding, ding,"],[3849,4029,"took you long enough to figure out."],[4104,4229,"Daddy's little girl is"],[4258,4337,"so clever."],[4525,4675,"Now sign the damn thing,"],[4675,4875,"or I'll put a hole in your head!"],[5125,5251,"Okay, I'll sign."],[5334,5505,"But you have to let me go after."],[5538,5668,"Good."],[5668,5755,"Sign it,"],[5801,5893,"then you're"],[5893,5985,"free to go."],[6018,6143,"He's lying."],[6143,6318,"As soon as I sign, he'll kill me."],[6318,6473,"Think, Elena, think."],[6498,6577,"Hurry up."],[6719,6873,"Don't try anything stupid or"],[6956,7052,"I'll break your legs"],[7052,7169,"before you can escape."],[8358,8420,"No,"],[8420,8533,"I don't wanna die."],[8533,8687,"Please, Ace, save me."]],"47":[[187,383,"Now that this job is completed,"],[383,454,"I can"],[454,563,"I can never have to worry about money"],[563,688,"ever again."],[913,996,"Good job."],[2811,2882,"Drop your weapon,"],[2882,3007,"or I'll blow her brains out!"],[3119,3269,"No, Ace, don't do it!"],[3328,3486,"Drop your weapon!"],[4145,4216,"Good job."],[4216,4371,"Close your eyes and walk toward me."]],"48":[[984,1067,"No!"],[1605,1689,"No!"],[1705,1789,"No!"],[2139,2273,"Are you crazy?"],[2273,2398,"He had a gun pointed at you,"],[2398,2606,"and you still went after him!"],[2606,2744,"I thought I lost you."],[2811,2948,"It's gonna be okay."],[3224,3332,"I knew exactly what he was doing"],[3332,3516,"when he asked me to close my eyes."],[3516,3599,"It's over."],[4562,4646,"Who sent you?"],[4700,4796,"Talk!"],[4959,5080,"Okay, just get me a medic,"],[5080,5176,"I don't wanna die!"],[5176,5251,"You're gonna get some help"],[5251,5342,"as soon as you give me some"],[5342,5501,"fucking answers, so talk!"],[5709,5814,"It was Huston!"],[5939,6056,"He paid me to kill Carter,"],[6143,6268,"and kidnap Elena."],[6331,6414,"There's proof."],[6414,6477,"Where?"],[6477,6635,"My left jacket pocket,"],[6635,6744,"just check it!"],[7228,7428,"Kill that idiot, Carter Pearson,"],[7428,7653,"and the five million dollars is yours."]],"49":[[112,216,"Why would he murder"],[216,291,"his own brother?"],[291,379,"My father's been nothing"],[379,471,"but kind to him."],[1076,1184,"The cops are on the way."],[1280,1368,"Everything's fine."],[1368,1501,"Ace, I don't understand."],[1601,1722,"Huston was the company's"],[1722,1872,"second largest shareholder."],[1872,2035,"What more could he possibly want?"],[2152,2364,"Why would he murder my father,"],[2540,2711,"and in front of me, too?"],[2740,2923,"I'm gonna have to live with that image"],[2923,3082,"scarred into the back of my mind"],[3082,3219,"for the rest of my life!"],[3274,3411,"Some people just want more,"],[3470,3536,"and it's never enough."],[3536,3695,"They're just greedy and they're monsters"],[3695,3774,"and you never have to think"],[3774,3924,"about them again, okay?"],[3924,4008,"It's over."],[4120,4266,"It's over."],[4608,4767,"I wanna go home."],[4767,4913,"Okay, let's go."],[4913,5042,"Okay."]],"50":[[696,871,"Ace, pull over."],[871,1021,"What's wrong?"],[1021,1151,"Your arm, it's bleeding."],[1209,1305,"Didn't you notice?"],[1338,1418,"No, I didn't notice."],[1418,1505,"It must have happened"],[1505,1605,"during the fight."],[1655,1785,"You're unbelievable."],[1964,2039,"It's fine."],[2156,2281,"Just pull over right up there."],[2281,2352,"It's fine."],[2352,2456,"No, I'll take care of it."],[2456,2565,"We'll stop for a bit."],[3745,3874,"Ace, why did you cheat on me"],[3874,3983,"all those years ago?"],[4229,4300,"Elena, come on."],[4300,4454,"Tell me the truth or I swear"],[4454,4567,"I will wrap this bandage"],[4567,4662,"around your arm so hard,"],[4662,4800,"you can't feel it."]],"51":[[312,450,"Okay, look, I screwed up,"],[521,642,"but that's in the past."],[700,892,"I just wanna move forward, okay?"],[1001,1096,"Ace, be honest with me,"],[1096,1226,"do you still love me?"],[1355,1443,"Come on, don't"],[1443,1643,"try and dodge the question."],[1643,1751,"Today, you could have called"],[1751,1901,"for backup, but you didn't."],[1901,2097,"You charged right in to save me."],[2097,2235,"If you didn't care about me,"],[2435,2498,"you wouldn't have gone"],[2498,2602,"to such extremes."],[2831,2907,"I love you."],[2969,3082,"Always have, never stopped,"],[3082,3207,"not even for a second."],[3328,3470,"I believe you this time."],[3591,3687,"We'll start fresh."],[3816,3941,"I love you, Elena."],[3941,4054,"I've always loved you."],[4095,4195,"Come here."]],"52":[[200,358,"Today we're here to talk about"],[358,542,"my healthcare reform strategy."],[542,717,"You can't even handle"],[717,892,"your personal life!"],[892,975,"The news came out,"],[975,1155,"and this company's stock prices fell"],[1155,1359,"another five points,"],[1359,1514,"and yet you still think you can"],[1514,1634,"push through reforms."],[1701,1851,"I'm the first to object."],[1851,1997,"Elena, do you know how"],[1997,2118,"the other healthcare companies"],[2118,2264,"are mocking us?"],[2264,2327,"They're saying that we're"],[2327,2423,"spineless idiots"],[2423,2590,"because we let a woman become"],[2590,2698,"the CEO."],[2907,3057,"Uncle Huston,"],[3057,3228,"if my scandals are causing"],[3228,3436,"such problems for the company,"],[3436,3636,"how do you plan to account"],[3636,3737,"for the damages"],[3737,3928,"that your actions have caused?"],[4012,4233,"Like hiring someone to kill my father?"]],"53":[[4,225,"Like hiring someone to kill my father?"],[600,709,"That's slander."],[754,875,"Your father was killed"],[875,971,"by an angry citizen"],[971,1113,"who was dissatisfied with the current"],[1113,1259,"healthcare system."],[1259,1451,"What does that have to do with me?"],[1822,2022,"Kill that idiot, Carter Pearson,"],[2022,2260,"and the five million dollars is yours."],[2677,2865,"I testify that Huston Pearson paid me"],[2865,3007,"to kill Carter Pearson,"],[3061,3178,"and then he paid me to"],[3178,3345,"try to kill Elena Pearson."],[3941,4116,"I hereby declare"],[4116,4237,"that Huston Pearson"],[4237,4408,"is immediately stripped"],[4408,4629,"of all his duties within this group."],[4629,4783,"You murdered my father,"],[4783,4921,"and tried to kill me!"],[4921,5080,"You need to pay for your crimes!"]],"54":[[0,145,"You need to pay for your crimes!"],[145,275,"Who do you think you are?"],[346,483,"Do you think you can kick me out"],[483,625,"of Pearson Group?"],[625,759,"I gave everything"],[759,846,"to this company."],[921,1005,"Why should you,"],[1005,1209,"the daughter of that idiot, Carter Pearson,"],[1209,1359,"inherit this company?"],[1413,1543,"What is wrong with increasing"],[1543,1659,"the claim denial rate?"],[1714,1868,"This company's profits doubled"],[1868,2106,"because I developed AI technology"],[2106,2293,"that increased our claim denial rate"],[2293,2427,"to 40 percent,"],[2427,2569,"the highest in the industry,"],[2631,2844,"and that old fool, Carter,"],[2844,3065,"he dared to yell at me over this."],[3065,3219,"He deserved to die!"],[3219,3370,"Every accomplishment"],[3370,3461,"you've made"],[3461,3641,"has been riding off of the coattails"],[3641,3778,"of struggling people"],[3778,3920,"and my father's life,"],[3920,4120,"and you show no remorse for them!"],[4179,4291,"You're a monster!"],[4517,4621,"Don't move!"],[4967,5067,"Raise your hands!"],[5288,5401,"Huston Pearson,"],[5401,5459,"you're under arrest"],[5459,5538,"for first-degree murder."]],"55":[[2018,2127,"Now, does anyone else have"],[2127,2223,"anything to say?"],[2515,2585,"Great."],[2652,2802,"All those in favor"],[2802,2957,"of implementing my healthcare"],[2957,3136,"reform strategy,"],[3136,3215,"raise your hand."],[5034,5121,"Very well."],[5180,5422,"It seems the majority has voted yes."],[5459,5593,"I declare that the healthcare"],[5593,5730,"reform plan,"],[5730,5839,"with the slogan,"],[5839,6101,"deliver, declare, and disclose,"],[6164,6302,"has officially passed,"],[6335,6502,"and will be implemented"],[6502,6619,"immediately."]],"56":[[66,191,"Cheers!"],[221,504,"Congratulations on the huge success"],[504,663,"of the healthcare reform."],[663,759,"Bring it in, guys."],[1017,1142,"Congrats, you two."],[1142,1230,"Looks like"],[1230,1297,"you guys are officially"],[1297,1368,"back together?"],[1426,1609,"Should I be planning a reunion party?"],[1609,1747,"That's enough."],[1747,1931,"Oh, Ms. Pearson,"],[1931,2114,"if your father could see you now,"],[2114,2318,"he'd be so proud!"],[2644,2831,"Thank you so much, guys."],[2831,3028,"If it hadn't been for you,"],[3028,3153,"I don't think my healthcare"],[3153,3299,"reform plan would've passed."],[3382,3516,"Especially you, Ace."],[3716,3795,"I don't know"],[3795,3924,"what I would've done without you."],[4179,4295,"Well, I'll..."],[4346,4537,"always be your rock."],[4729,4842,"Cheers!"],[4842,4954,"Heck yeah."]],"57":[[875,950,"Hey."],[1013,1080,"Hey."],[1242,1338,"Were you looking for me?"],[1409,1497,"Josh is out there drinking"],[1497,1589,"like a wild animal,"],[1589,1672,"and"],[1789,1926,"he's trying to make everyone join him."],[1985,2122,"Oliver's keeping an eye on him."],[2281,2389,"I don't have any time to waste"],[2389,2498,"on that stuff,"],[2585,2702,"I guess I have to"],[2877,3040,"reserve all my energy for you."],[3340,3478,"Mr. Atkins,"],[3528,3657,"your duties as a bodyguard"],[3657,3807,"are officially over."],[3928,4099,"What's next on your agenda?"],[4099,4212,"I have a few ideas."],[7432,7499,"What's wrong?"]],"58":[[191,271,"What's wrong?"],[367,500,"Nothing, just..."],[942,1071,"I don't know if we're in the right"],[1209,1388,"place, or if it's the right time."],[1388,1472,"What?"],[1593,1714,"After everything we've been through,"],[1714,1951,"Ace, I thought we were past this."],[1951,2060,"I know, but I..."],[2206,2281,"But what?"],[2594,2773,"I just, I, I don't think"],[2773,2869,"we should rush into this."],[2869,2994,"I think we should think this through,"],[2994,3073,"okay?"],[3140,3236,"You're a jerk."],[3837,3908,"Fuck."]],"59":[[16,171,"God, what an asshole?"],[171,350,"Why does he keep pushing me away?"],[3211,3274,"Ace?"],[3319,3374,"Ace!"],[3403,3482,"It's okay."],[3536,3578,"Ace!"],[3578,3678,"It's okay, he's dead."],[3699,3782,"It's over."]],"60":[[58,196,"Oh my God!"],[196,337,"Ms. Pearson,"],[337,500,"I'm going to call an ambulance!"],[1205,1351,"Is he gonna be okay, doctor?"],[2122,2189,"Doctor,"],[2460,2594,"don't tell Elena about..."],[2819,2932,"my prosthetic leg."],[3103,3174,"All right."],[3219,3332,"I'll respect your wishes."],[3724,3824,"Fortunately,"],[3824,4049,"the bullet didn't hit any vital organs."],[4129,4308,"His physical condition is"],[4308,4496,"excellent, so he should recover"],[4496,4575,"quickly."],[4575,4671,"Thank you, doctor."],[4792,4879,"By the way, there's a"],[4917,5038,"a police officer waiting for you"],[5038,5138,"in the reception room."],[5205,5359,"Okay, I'll go there now then."]],"61":[[58,150,"Officer, what's going on"],[150,291,"with the assassin?"],[291,408,"Why would someone try and kill me"],[408,492,"when Huston's already"],[492,608,"been apprehended?"],[988,1142,"According to our investigation,"],[1142,1242,"Chad Vega, one of"],[1242,1363,"your company's executives,"],[1363,1572,"has been involved in a long-term"],[1572,1780,"illegal financial crime with Huston."],[1889,2022,"The killer was hired by him."],[2106,2168,"What?"],[2277,2456,"Chad was in cahoots with Huston?"],[2502,2681,"10 minutes ago, we apprehended"],[2681,2831,"Chad at his residence."],[2857,2986,"You can rest assured that"],[2986,3148,"with Huston's testimony,"],[3148,3399,"all related individuals have been arrested."],[3399,3482,"You're safe."],[3578,3712,"Considering your bodyguard"],[3712,3837,"was injured,"],[3837,4037,"the police are gonna offer you protection"],[4037,4158,"until the trial is over."],[4320,4408,"You can rest."],[4546,4704,"I'm gonna pick up Ace's clothes"],[4704,4833,"and I'll be back tomorrow morning."]],"62":[[83,166,"Ace?"],[1292,1430,"Dear Elena,"],[1430,1597,"the bodyguard mission is complete,"],[1597,1751,"and you're no longer in danger."],[1751,1881,"So it's time for me to leave."],[1956,2097,"Just wanted to say goodbye,"],[2097,2281,"and I wish you all the best."],[2364,2431,"Ace."],[2498,2598,"What the hell?"],[2686,2806,"You're leaving me again?"],[2907,2982,"I won't let you leave"],[2982,3140,"without an explanation."],[5605,5714,"It's her,"],[5714,5910,"the woman that Ace cheated on me with."]],"63":[[37,204,"So you're a physical therapist?"],[354,496,"That's your daughter and husband?"],[496,579,"Yes."],[704,896,"I am so sorry I deceived you"],[896,1021,"three years ago."],[1021,1217,"You didn't date Ace, so why did you"],[1217,1363,"help him deceive me?"],[1363,1551,"This involves Ace's privacy,"],[1551,1739,"and I'm not at liberty to disclose"],[1739,1901,"that information."],[1901,2010,"But Elena,"],[2010,2256,"I assure you, Ace did not betray you."],[2256,2389,"Then why?"],[2494,2631,"Why did he lie to me?"],[2631,2752,"Make me hate him"],[2752,2873,"and break up with me?"],[2940,3082,"I think you're supposed to"],[3082,3236,"uncover the truth for yourself."],[3378,3616,"But I think that deep down,"],[3616,3899,"Ace really wants you to know everything."],[3899,4108,"He's just too afraid to tell you."]],"64":[[483,546,"Elena,"],[608,684,"what are you doing here?"],[684,809,"Josh, Ace isn't at the hospital,"],[809,963,"and he just left me a note."],[963,1059,"Do you know where he is?"],[1096,1163,"What?"],[1330,1434,"Does he know how important it is"],[1434,1630,"to recover properly after his surgery"],[1630,1735,"for his new prosthetic leg?"],[2081,2268,"What do you mean, prosthetic leg?"],[2427,2527,"Fuck, man."],[2640,2748,"I wasn't supposed to say that."],[2748,2977,"Josh, what do you mean, prosthetic?"],[3019,3094,"All right."],[3261,3407,"Three years ago,"],[3407,3603,"Ace's leg was blown off during combat."],[3603,3682,"Your father"],[3753,3916,"told him that a disabled person"],[3916,4004,"would only burden you,"],[4104,4337,"so he pretended to cheat on you,"],[4337,4429,"and broke up with you."],[4508,4592,"Later,"],[4592,4733,"after he got his prosthetic leg,"],[4800,4988,"he still felt like a disabled person."],[4988,5155,"He thought a great girl like you"],[5155,5280,"deserved better,"],[5280,5530,"so he avoided you at critical moments."],[5901,6081,"Go check out the rehabilitation center."],[6139,6252,"He's getting his new prosthetic leg"],[6252,6352,"fitted right now."],[6352,6468,"Go find him, Elena."],[6544,6690,"Ace, you jerk."],[6731,6852,"How could you keep something"],[6852,6973,"so important from me?"],[7007,7165,"This time, I won't let you go."],[7165,7323,"I won't let you walk away again."]],"65":[[112,258,"Fortunately, you came in time."],[312,408,"The old prosthetic didn't do"],[408,546,"too much damage to the nerves."],[600,717,"With treatment,"],[717,829,"you should recover naturally."],[896,1080,"This one is newly made for you,"],[1080,1197,"try it."],[1197,1280,"Thanks."],[4612,4688,"This is the secret"],[4688,4833,"you've been keeping from me?"],[5000,5088,"This is why you've been"],[5088,5201,"pushing me away?"],[5288,5359,"What are you doing here?"],[5422,5492,"You shouldn't be here."],[5492,5626,"You need to leave."]],"66":[[45,133,"This is why you've been"],[133,246,"pushing me away?"],[458,554,"Elena,"],[646,788,"you shouldn't be seeing me like this."],[788,921,"I need you to leave right now."],[921,1101,"Why wouldn't you just tell me?"],[1205,1451,"Do you really think that little of me?"],[1547,1680,"That I'm just a shallow,"],[1680,1822,"unsupportive partner?"],[1822,1881,"How was I supposed to"],[1881,2052,"tell you this, Elena, how..."],[2089,2223,"I mean, why would a guy like me"],[2277,2373,"be able to be with"],[2439,2548,"a perfect woman like you?"],[2727,2786,"Huh?"],[2840,2944,"When I can't even do"],[2944,3069,"half the things I was able to"],[3132,3199,"three years ago."],[3199,3274,"I mean, you don't know how"],[3274,3349,"this feels, okay?"],[3349,3528,"I mean, just fucking look at me, Elena!"],[3528,3670,"I can't even stand up straight!"],[3670,3766,"But I love you!"],[4012,4149,"Ace, can't you see?"],[4316,4571,"No matter how you feel about yourself,"],[4571,4817,"I've always loved you, always!"],[5313,5417,"Elena, come on, why?"],[5417,5701,"Just, just stop pushing me away!"],[5872,5930,"Ace Atkins,"],[5930,6085,"you listen to me right now."],[6402,6589,"You have left me"],[6589,6727,"so many times."],[6806,6948,"You can't keep running from me."],[7052,7190,"I am here to stay."],[7340,7399,"Got it?"],[7482,7670,"I love you so much, I'm sorry."],[7716,7824,"I'm sorry."]],"67":[[650,788,"Nothing feels uncomfortable?"],[863,1009,"Come on, don't try and be tough."],[1042,1138,"No, this one's"],[1226,1284,"more comfortable"],[1284,1413,"than the last one actually."],[1413,1476,"So,"],[1539,1659,"you know, I wouldn't blame you"],[1659,1864,"if you didn't wanna do this."],[1864,2002,"I'm disabled and"],[2068,2227,"I might"],[2227,2410,"become a burden to you when we're older."],[2410,2535,"Have you thought about that?"],[2698,2823,"If you ever say something"],[2823,2990,"so pessimistic again,"],[2990,3161,"I will twist your ear off."],[3278,3461,"I love Ace Atkins,"],[3528,3720,"the person, not the leg."],[3770,3878,"So what if you're missing a leg?"],[3878,4054,"I will love you all the same."],[4129,4204,"Would you leave me"],[4204,4308,"if I was missing a leg?"],[4617,4796,"No, no, of course not."],[4913,5034,"I'll always be by your side."],[5134,5284,"Then let me do the same."],[5484,5701,"I am choosing you, okay?"],[5997,6056,"Got it."]],"68":[[296,396,"Ms. Pearson."],[550,709,"Your compensation clause for critical"],[709,921,"illness saved my daughter's life."],[1026,1088,"Thank you."],[1284,1363,"Ms. Pearson,"],[1363,1476,"your healthcare reform plan"],[1476,1618,"has been a great success,"],[1618,1743,"making you the most popular"],[1743,1851,"CEO in the US."],[1926,2018,"What made you insist on"],[2018,2093,"healthcare reform"],[2093,2214,"despite everyone's doubts?"],[2335,2481,"I was able to overcome"],[2481,2602,"many obstacles,"],[2627,2794,"and achieve reform success,"],[2794,2927,"partly due to great planning,"],[2961,3219,"but also because of my fiancé,"],[3290,3382,"Ace Atkins."],[3553,3720,"His love helped me overcome"],[3720,3845,"all difficulties."]]}