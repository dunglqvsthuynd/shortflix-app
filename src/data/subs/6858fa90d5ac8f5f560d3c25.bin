[3103,3182,"It's daddy."],[3203,3328,"Why don't you go ahead and pick that up"],[3336,3432,"for me, hon?"],[3649,3787,"Hey, Cass, I have to work late today,"],[3807,3916,"won't be home for dinner."],[3958,4137,"William Stein."],[4175,4479,"I don't care how busy you are,"],[4487,4804,"but you better be back in 30 minutes."],[4884,5217,"The laundry isn't done, it's piling up,"],[5251,5430,"the dishes aren't done,"],[5497,5734,"and your wife needs you."],[5743,5872,"That's a command."],[5918,6168,"And don't even think about showing up"],[6177,6327,"without flowers and cake."]],"57":[[16,204,"And don't even think about"],[212,437,"showing up without flowers and cake."],[675,779,"Chance! Hey, you cannot"],[779,863,"speak to your father"],[871,955,"like that. Do you hear me?"],[996,1130,"I'm sorry, but I had to."],[1201,1322,"I had to tell him you're"],[1322,1397,"not feeling well."],[1434,1639,"So he'll come here and take care of you."],[1747,1951,"Don't worry. We're all here for you."],[2072,2135,"Thanks, hon."],[2202,2348,"It's okay, Mom. Don't cry."],[2389,2577,"Your eyes will make you puffy."],[2827,2936,"Why don't we take a selfie, huh?"],[2948,3073,"Smile for the camera."],[3219,3340,"I wanna, I want to, too."],[3349,3382,"Come here."],[3578,3611,"Ready?"],[3699,3837,"Three, two, one."]],"58":[[892,1242,"I'm sorry, babies. I'm sorry"],[1251,1384,"I couldn't protect you back then,"],[1384,1522,"but I think,"],[1605,1997,"I need to move on, for you and for me."],[2477,2786,"Hey, Cass. What's going on?"],[3165,3294,"Hey, I did the laundry and"],[3294,3561,"I put the dishes away."],[3570,3703,"I stopped by and got LEDs"],[3703,3774,"on the way home-"],[3782,4129,"I'm fine. I'm just,"],[4266,4441,"I'm happy."],[4500,4608,"I'm really really"],[4617,4783,"happy. I'm just thrilled"],[4783,4900,"to be married to you"],[4909,5067,"and to have the kids."],[5125,5196,"I'm happy to be married"],[5196,5305,"to you too, Cass."],[5555,5705,"Oh my God, you actually got them."],[5705,5830,"Yeah, yeah I got"],[5839,5955,"them for you. I heard you were sad."],[5964,6122,"I thought they might cheer you up."],[6164,6285,"Wow, I..."],[6285,6331,"they look,"],[6556,6710,"I mean they look fancy."],[6869,7052,"How much did those cost?"],[7052,7240,"Don't worry about that."],[7248,7436,"I got them for you."],[7436,7615,"They're gonna look great"],[7615,7716,"on your desk."],[7716,7878,"You and your sappy romantic heart."],[8008,8095,"Seriously, though, how much,"],[8108,8195,"how much were they?"],[8299,8395,"Cass,"],[8508,8604,"about the money,"],[8712,8808,"Um..."],[8938,9034,"There's something I've actually,"],[9109,9205,"I've been meaning to tell you."],[9492,9705,"Mommy, mommy, Chance flushed"],[9705,9864,"my Barbie again!"],[9930,10185,"All right, hon. Be right there."]],"59":[[437,500,"You asked why Cassandra"],[500,571,"hates you?"],[671,750,"Look at that."],[834,880,"What's this?"],[1055,1280,"That is a design that Cassandra made"],[1288,1443,"seven years ago in fashion school."],[1472,1626,"She even won some big award."],[1664,1760,"But then they decided"],[1760,1897,"to accuse her of plagiarism,"],[1906,1985,"they took away the prize"],[1993,2118,"money and they expelled her."],[2127,2344,"And to top it all off,"],[2352,2469,"the industry blacklisted her."],[2573,2752,"I mean, she told me a little bit about this,"],[2761,2948,"but what does it gotta do with me?"],[2977,3128,"It has everything to do with you"],[3136,3228,"because the person that"],[3236,3407,"accused her is Aurelia Lombard."],[3440,3536,"And guess what?"],[3536,3737,"She reported it using your name."],[3774,3824,"What?"],[3937,3970,"What?"],[3987,4104,"How did she even know Aurelia?"],[4179,4287,"That is as far as I got."],[4788,5013,"Horace, cut all financial"],[5021,5180,"support off to Aurelia Lombard."],[5217,5334,"Not a single cent more."],[6256,6356,"If I could have everyone's"],[6356,6435,"attention, please."],[6477,6589,"I would like to introduce you"],[6589,6681,"to our new client,"],[6773,6977,"famous fashion designer,"],[6977,7165,"Mrs. Aurelia Lombard."]],"60":[[329,538,"You must be Cassandra Mortensen."],[633,867,"I, yeah, hi, sorry, have we met before?"],[938,1105,"Let's just say I've had my eye on you"],[1117,1217,"for quite some time."],[1276,1426,"Can I have Miss Mortensen's"],[1434,1555,"exclusive contract please?"],[2039,2160,"Here's the deal."],[2248,2377,"You'll have full creative control."],[2456,2560,"And of course it comes with"],[2560,2702,"a very nice paycheck."],[2765,2861,"Oh, yeah."],[2940,2994,"Yeah, it does,"],[3028,3157,"Half a million?"],[3265,3361,"I first saw you from one of"],[3370,3503,"your designs seven years ago"],[3541,3691,"and I've been waiting to see"],[3691,3845,"what else you can do."],[4129,4179,"Thank you."],[4262,4429,"Thank you, I really appreciate this."],[4504,4575,"If you're free tonight,"],[4583,4721,"we can talk more about it over dinner."],[4733,4808,"Yes, absolutely."],[4829,4896,"You know what?"],[4896,5017,"I know this great place nearby."],[5084,5163,"Actually, I was hoping for"],[5163,5284,"something more private."],[5321,5388,"Maybe your place?"],[5743,5768,"Yeah."]],"61":[[433,604,"Cass, a four course meal?"],[613,684,"I thought we were"],[684,742,"supposed to be thrifty."],[796,842,"We are."],[892,1155,"We are, but this is a $500,000 deal,"],[1163,1313,"thats- Stop! That's a lot."],[1338,1413,"That's a lot of money."],[1422,1468,"It's a big deal."],[1522,1672,"$500,000 and your mom's"],[1672,1793,"rate is sell out."],[1801,1885,"Did you hear that, kids?"],[1897,2056,"Stop, stop, you're making fun of me,"],[2064,2198,"but it's a lot of money."],[2223,2298,"You can't deny that."],[2444,2523,"How much money did"],[2523,2602,"you make last year, mister?"],[2640,2744,"It was a bad month."],[2752,2869,"I only made like eight or"],[2869,2982,"nine million, I think?"],[3249,3428,"Stop, hey kids, listen to this."],[3436,3503,"Your dad is"],[3503,3578,"daydreaming again."],[3712,3816,"Who do you think you are,"],[3816,3933,"Killian Steinmall?"],[4291,4329,"Ooh."],[4462,4571,"Cass, I need to tell you something."],[4842,4917,"She's here."]],"62":[[20,120,"She's here."],[208,300,"Okay, all right, all right,"],[300,371,"game time everybody."],[517,558,"How do I look?"],[567,663,"Do I look like you'd do a"],[671,750,"deal with me, like business?"],[796,867,"Yeah, you look,"],[1000,1051,"Cass,"],[1051,1272,"you look gorgeous, all right?"],[1443,1463,"Okay."],[2227,2469,"Hey, Ms. Lombard, hi."],[2519,2644,"Hi, welcome."],[2998,3082,"This is my husband."],[3140,3378,"Will, and our kids, Chance and Charity."],[3403,3549,"Hi, Chance. Hi, Charity."],[3620,3745,"Some strawberry cake for you."],[3820,4054,"Well, that's really, that's really sweet."],[4149,4208,"How'd you know?"],[4216,4316,"That's actually their favorite."],[4396,4466,"Because,"],[4742,4875,"I'm their biological mother."],[5096,5234,"You're..."]],"63":[[279,354,"Why'd you come back?"],[487,596,"You stopped sending me money."],[692,754,"Figured it was your way"],[754,825,"of saying something."],[863,917,"Well, you're wrong."],[971,996,"Still."],[1134,1263,"I'd say it's worth watching"],[1263,1334,"you play pretend with"],[1343,1618,"your new girl, William Stein."],[1622,1747,"You destroyed Cassandra's"],[1747,1864,"career under my name."],[1931,2022,"Why did you do that?"],[2060,2168,"Is that what she told you?"],[2364,2469,"And you believed her?"],[2602,2677,"Wow, Killian."],[2736,2836,"You've really lost it."],[3140,3294,"She's very talented, yes,"],[3324,3616,"but she did steal my work."],[3737,3807,"Cassandra?"],[3887,3987,"Stole from you?"]],"64":[[75,225,"Cassandra?"],[271,354,"Stole from you?"],[479,579,"You gotta be kidding me."],[696,855,"I designed those heels when I was"],[863,988,"pregnant with Chance and Charity."],[1026,1222,"I was inspired by my own experiences."],[1326,1468,"Has Cassandra ever been pregnant?"],[1514,1626,"Why did you come back Aurelia?"],[1768,1856,"Just to get rid of my wife?"],[1997,2118,"I have no problem with her."],[2235,2314,"If I hated her,"],[2314,2469,"do you really think I would offer her"],[2469,2598,"an exclusive contract?"],[2640,2840,"I just wanted to say I'm sorry"],[2840,3002,"for leaving you and the kids."],[3111,3349,"And I want to be their mother again."],[3632,3712,"You lost the right"],[3712,3828,"to call yourself their mother"],[3828,3928,"at the moment that you made"],[3928,4054,"them sick and blackmailed them"],[4054,4200,"just so you could see me again."],[4200,4333,"This is your last warning,"],[4333,4487,"Aurelia. If I ever catch"],[4496,4617,"you near my wife,"],[4725,4892,"I'm gonna make you disappear."]],"65":[[250,717,"It's been an hour. Where did they go?"],[792,942,"Mommy, are you scared"],[942,1071,"daddy is going with her?"],[1138,1401,"Mommy, if daddy gets something wrong,"],[1518,1597,"well,"],[1605,1743,"I'll find the new man for you."],[2001,2264,"Alright, you little rascals."],[2331,2515,"Who's been talking?"],[2577,2698,"It's the claw!"],[3716,3820,"I mean, if you're wondering,"],[3878,3962,"it wasn't much of a conversation."],[4070,4166,"But..."],[4250,4346,"I know this dinner probably"],[4354,4525,"doesn't sit well with you anymore, so,"],[4767,4863,"I got you your favorite."],[5259,5376,"Thank you."],[5734,5905,"So,"],[5997,6143,"what did you guys talk about?"],[6377,6464,"She said she wanted to come back"],[6473,6598,"and be a mother to the kids."],[6664,6856,"Like I'd ever trust her again."],[7190,7311,"If Chance and Charity are okay with it,"],[7545,7703,"I'm good if she wants to be back."],[7782,7907,"Part of their lives, you know?"],[7987,8083,"Cassie,"],[8153,8320,"why are you so trusting?"],[8408,8533,"Aren't you worried that we'd leave you?"],[8683,8742,"No."],[8871,9079,"Come on, Will."],[9125,9234,"You're mine."],[9288,9413,"And the kids are mine."],[9634,9776,"We're family, we're not"],[9776,9976,"going anywhere. I know that."]],"66":[[133,208,"Hey Cass, what are you up to"],[208,283,"this weekend?"],[296,554,"I might have to work overtime."],[554,667,"There's a design contest"],[667,779,"for a benefit auction."],[779,921,"And I'll make an extra $5,000"],[921,1067,"if I make it in."],[1092,1276,"Ah, um,"],[1276,1476,"well the kids actually have a baking thing"],[1476,1551,"that I was hoping that"],[1551,1626,"you could come and-"],[1626,1889,"Don't worry, Mommy, um, it's,"],[1947,2147,"um, just focus on getting that $5,000,"],[2264,2427,"Daddy will take us. Okay bye."],[2448,2531,"Bye!"],[2548,2761,"Woah, what was that?"],[2769,2857,"I thought you wanted"],[2857,2948,"both Mommy and Daddy"],[2948,3090,"to come to your school today."],[3098,3290,"I canceled a really big meeting"],[3299,3457,"to go to this thing."],[3495,3699,"It was a million dollar trade deal."],[3753,3937,"A good man always supports"],[3937,4058,"his wife's career,"],[4058,4212,"that's what you said."],[4325,4446,"Oh, man."],[4466,4729,"I know what I said, sweetheart, okay?"],[4825,4963,"But this contract"],[4963,5188,"is worth a million dollars."],[5188,5476,"And your mom's, what, $5,000?"],[5534,5680,"Tell me which number's bigger."],[5743,5910,"Well, it's our loss anyways."],[5985,6210,"So, if we're all okay with it,"],[6210,6373,"you better be."],[6552,6694,"What am I gonna do with you gremlins?"],[6890,7023,"Seriously."],[7315,7474,"I know, right?"],[7486,7649,"Yeah, I wish my kids"],[7649,7791,"went to St. Bridgette's."],[7832,7991,"They're having a baking party today"],[7999,8187,"with all the moms and dads."],[8216,8375,"St. Bridgette's?"],[8375,8466,"That's Chance and Charity's"],[8466,8721,"elementary school."]],"67":[[4,171,"St. Bridgette's?"],[171,254,"That's Chance and Charity's"],[254,433,"elementary school."]],"68":[[454,592,"It's so cold in here."],[1272,1347,"Then leave."],[1968,2110,"Finally she's gone."],[2264,2369,"Why is she always here?"],[2414,2619,"I don't like her, I hate her!"],[2660,2752,"I don't know buddy, but I"],[2752,2861,"don't like her either."],[2961,3036,"Hey,"],[3078,3253,"let's focus on doing this cake, all right?"],[3319,3428,"Mommy really needs it."],[3486,3732,"Daddy, I'm making this strawberry cake"],[3732,3832,"for Mommy."],[3891,4137,"I wish Mommy would be here now."],[4779,4900,"Kids are inside, you're"],[4900,4988,"not gonna say hi?"],[5059,5163,"Did not realize you would"],[5163,5309,"be here today."],[5409,5605,"Well, Killian told me, so I came."],[5714,5834,"They're my kids, after all."],[6010,6202,"Yeah, yes."],[6368,6589,"They're great kids, it's good"],[6598,6690,"you wanna spend time with them."],[6765,6994,"Oh no, I'm not spending time,"],[7019,7144,"I'm taking them back."],[7240,7307,"And my husband."]],"69":[[196,296,"Is that why you tracked"],[296,375,"me for this project?"],[408,583,"So you can, you can ruin my family?"],[675,846,"Sure, that's how you wanna spin it."],[925,1117,"But I wonder which one you'll pick,"],[1209,1422,"your career or your family?"],[1488,1630,"Oh, both."],[1797,1856,"I choose both."],[1897,2027,"I am going to get this deal"],[2043,2177,"and I'm going to keep my family."],[2260,2398,"Yeah, we'll see about that."],[4212,4250,"It's Friday."],[4350,4466,"This isn't due until Monday."],[4587,4808,"Yeah, but I try to get all my work done"],[4817,4925,"before the weekends so I"],[4934,5059,"can spend time with my family."],[5213,5330,"I'm taking them to the aquarium Saturday."],[5459,5597,"Oh, too bad."],[5714,5768,"I was planning on taking"],[5776,5939,"them on a cruise on Saturday."],[6056,6156,"I guess it's up to them."],[6260,6389,"Greasy, aquarium pizza,"],[6410,6519,"or my private beach with"],[6519,6639,"my personal chef."],[6940,7015,"I know my kids."],[7207,7303,"It's not gonna work on them."],[7586,7640,"Yeah, we'll see."]],"70":[[337,429,"If you had to choose one."],[583,642,"An aquarium"],[734,855,"or a cruise to a private island."],[863,967,"Which one would you choose?"],[1034,1155,"I mean the cruise obviously."],[1163,1280,"I knew it."],[1343,1455,"God, I'm screwed, I'm so screwed."],[1463,1547,"There's no way the kids are"],[1547,1626,"choosing me over that."],[1693,1755,"Are you more scared of"],[1764,1889,"losing the kids or your husband?"],[2072,2135,"I don't know."],[2243,2335,"It's the real answer."],[2615,2690,"I just feel like it's not"],[2690,2819,"my place to interfere."],[2986,3132,"Like seriously, who am I to stop the kids"],[3140,3265,"from seeing their biological mom,"],[3265,3374,"really?"],[3503,3607,"It's so cold in here."],[4104,4225,"Screw that guy for putting"],[4225,4341,"me in this position."],[4379,4466,"Screw him."],[4621,4692,"I'm blocking him."],[4729,4829,"I'm gonna block him right now,"],[4829,4896,"right now. - Yes."],[4950,5034,"Honestly good for you."],[5096,5180,"If he doesn't show up with"],[5180,5242,"a good enough apology,"],[5251,5338,"you should just break up with him."],[5447,5480,"Yes."],[5518,5580,"Oh my God, wait, I can"],[5588,5768,"throw you a huge singles party."],[5814,5930,"My friend Valentina knows"],[5930,6022,"all of these beautiful"],[6031,6131,"Latino men, wait,"],[6131,6231,"I can text her right now."],[6281,6368,"I know she has some pictures."],[6398,6510,"Oh yeah, and they all know how to salsa."],[6619,6681,"It's so fun."],[6710,6777,"And they can cook really"],[6777,6852,"good food too."],[6877,6894,"Ooh."],[6923,6940,"Yeah."],[7161,7198,"Spicy."]],"71":[[291,362,"Huh."],[458,633,"That's weird, I can't see Cassie's post."],[650,750,"She usually posts around lunch."],[1042,1084,"That's strange."],[1163,1284,"I can see her post right now."],[1351,1409,"Look."],[1584,1710,"She just posted 20 minutes ago,"],[1760,1864,"OMG I love sushi."],[2014,2102,"Do you think she blocked you?"],[2139,2243,"No way, no way."],[2477,2623,"Oh my God, she did block me."],[2848,2973,"She can always unblock you."],[3057,3286,"No, I need to talk to her now."]],"72":[[25,175,"I need to talk to her now."],[300,358,"Looking for me?"],[442,467,"No."],[729,834,"Oh, come on, Killian."],[971,1067,"We were married once."],[1163,1263,"That was just for the kids,"],[1263,1351,"and I'm very grateful"],[1359,1459,"that you were able to give"],[1468,1639,"birth to both Chance and Charity."],[1755,1893,"But you're never gonna be their mother."],[1964,2064,"Killian, do you even know how"],[2072,2231,"awful it was being pregnant?"],[2431,2569,"Do you know how many times I"],[2577,2794,"fainted? How many times I threw up?"],[2861,2998,"Do you know how it feels"],[2998,3094,"waking up in the middle of"],[3103,3182,"the night to check on them"],[3190,3315,"and them not being there?"],[4170,4362,"I came back to be a real mother this time."],[4575,4792,"So on my birthday, on Saturday, all"],[4800,4971,"I want is to spend a day with them."],[5138,5246,"Will you at least give me that?"],[5860,5960,"I heard you wanted your"],[5968,6160,"kids to go to St. Bridgette's."],[6218,6335,"Here's the application materials."],[6493,6560,"All fees waived."],[6756,6881,"Oh, oh, thank you, Miss Lombard,"],[6890,7090,"but I can't possibly-"],[7098,7307,"Oh no, thank you for sharing your"],[7315,7465,"experiences during your pregnancy."],[7561,7649,"It's been very,"],[7832,7853,"useful."],[7941,8128,"Thank you. Thank you so much."]],"73":[[767,938,"Cass, did you really block me?"],[996,1034,"Did I?"],[1151,1276,"Sorry, my finger must have slipped."],[1326,1380,"Really?"],[1484,1580,"Yeah, really."],[1772,1947,"Okay, well, can you unblock me then?"],[1993,2060,"I don't know, we'll see."],[2268,2293,"Okay."],[2469,2581,"Cass, what's, what's going on?"],[2752,2877,"Are you and the kids free this weekend?"],[3078,3345,"We, me and the kids, we"],[3353,3457,"actually have something planned"],[3478,3570,"on that day, right kiddos?"],[3916,3970,"Yeah."],[4225,4300,"You wanna tell me what it is?"],[4491,4763,"My parents, yeah, my parents"],[4763,4892,"wanna have them"],[4900,5021,"for the day, that's all."],[5201,5351,"Okay, well,"],[5534,5684,"tell them I say hi."],[5784,5826,"Wait."],[6005,6181,"Can you, can you unblock me first?"]],"74":[[41,229,"Can you, can you unblock me first?"],[1013,1172,"Unicorns can grant wishes."],[1222,1451,"Magical unicorns quietly"],[1459,1776,"grant wishes to all the bears."],[1922,2081,"To all the fun friends."],[2102,2277,"Daddy, Momma looks kind of sad."],[2310,2485,"Does she think we lied to her?"],[2556,2644,"No, Charity."],[2744,2986,"I think it's the time of month where"],[2994,3199,"we have to buy her chocolates, Daddy."],[3315,3403,"Nice try kiddo."],[3516,3624,"But you know that excuse"],[3632,3778,"only works once a month, right?"],[4066,4133,"Go to bed."],[4166,4233,"Goodnight."],[4437,4496,"Goodnight, Charity."],[4879,5000,"Goodnight, Chance."],[6418,6539,"Good morning, ma'am. Where to?"],[6606,6723,"Yeah, could you just follow"],[6723,6835,"that car right there?"],[6844,7019,"Just wherever they go, just, follow them."],[7136,7307,"Oh, are we really doing this?"],[7319,7390,"Yeah."],[7415,7478,"Alright, buckle up."]],"75":[[2702,2840,"I was thinking"],[2857,3082,"I'm gonna take you to a hotel or something."],[3199,3282,"Not the ferry docks."],[3632,3778,"We can go back, I've seen enough."],[4058,4179,"Man, cheating on you."],[4400,4500,"With the kids there too."],[4692,4750,"You need a tissue?"],[5251,5559,"No, no, no, I'm fine. I'm not gonna cry."],[5751,5834,"I'm just gonna party."],[5955,6160,"All night, I'm gonna party."],[6406,6577,"Abby, hey. Remember how we were"],[6585,6756,"talking about going to a singles' party?"],[6936,6994,"How about tonight?"]],"76":[[446,542,"Why don't you just give me"],[542,638,"your digits, huh?"],[679,788,"That's my wife, you're not"],[788,875,"getting shit, pal."],[905,1009,"Who the hell are you?"],[1096,1259,"Get your sleazy hands off my mommy!"],[1443,1530,"Mommy?"],[1743,1814,"Oh."],[1943,2093,"She said she was single, okay?"],[2147,2243,"This was a singles' night."],[2389,2464,"I'm outta here."],[2594,2631,"Come on."],[3616,3749,"Drop the act, Mrs. Stein."]],"77":[[83,175,"Just leave me alone."],[241,429,"Mommy, are you mad at us?"],[563,679,"No, sweetie, I'm not mad."],[950,1184,"She's definitely mad at us, Charity."],[1380,1559,"You know what?"],[1739,1822,"So what if I am?"],[1997,2156,"I mean, first the baking day,"],[2156,2302,"and now the cruise,"],[2310,2456,"with Aurelia"],[2565,2660,"behind my back."],[2794,2907,"I think I have every right to be mad."],[3002,3082,"Oh yeah?"],[3144,3294,"How do you know that?"],[3361,3516,"Were you following us all day?"],[3599,3674,"Just save it."],[3782,3874,"We're done."],[4700,4913,"Mommy, we didn't go on a cruise,"],[4913,5042,"we stayed here and made"],[5042,5150,"all your favorite dishes."],[5201,5334,"What is all this?"]],"78":[[95,187,"What is all this?"],[308,446,"OMG, I want sushi."],[629,742,"That's what you posted the"],[742,850,"day that you blocked me."],[871,1000,"We made everything for you."],[1046,1217,"Fish, mussels..."],[1255,1334,"Clam chowder..."],[1443,1484,"oysters."],[1572,1785,"Mommy, here's a surprise for you."],[1785,1864,"Oh."],[2010,2089,"Come here."],[2598,2794,"Mommy, we got four jelly fish."],[2802,3119,"One for each of us. Daddy said it"],[3128,3395,"means we will always be together."]],"79":[[241,579,"Mommy, we saw Aurelia today."],[692,834,"She tried to talk to us,"],[834,946,"but we totally ignored her"],[955,1092,"and we went straight to the fish."],[1422,1651,"And Mommy, all we wanted"],[1651,1893,"to do is to, is to cook for you."],[1964,2147,"You guys, Aurelia is your"],[2147,2298,"biological mother."],[2344,2498,"If you wanna see her, you can."],[2498,2602,"That's totally fine,"],[2602,2706,"you just have to let me know, ok?"],[2706,2806,"I hate her."],[2877,3032,"I don't like her a bit."],[3094,3219,"Even though she's my real"],[3228,3415,"mother, she never reads to me."],[3457,3611,"She never hugs me,"],[3611,3787,"she never asks about my day."],[3899,4029,"But you do, Mommy."],[4204,4391,"I wish you were my real mommy."],[4596,4671,"I love you guys."],[4758,4925,"I will always love you guys, okay?"],[5075,5155,"I don't know how much"],[5155,5246,"you drank last night,"],[5255,5455,"but this should help."],[5568,5689,"Cass, you are their real mom."],[5864,6089,"They love you, and you love them."],[6222,6297,"That's all that matters."]],"80":[[221,266,"Cass!"],[329,375,"Cass!"],[412,517,"Look, I know I've been on"],[517,642,"your nerves lately, alright?"],[713,838,"I got you something special"],[838,896,"to make up for it."],[1334,1455,"Will, we don't have money"],[1463,1576,"to waste on things like this."],[1584,1622,"You know that."],[1659,1793,"No, no, no, no, no, no."],[1860,1951,"We got this down at the beach,"],[1956,2043,"we strung it ourselves."],[2047,2114,"It's free."],[2231,2306,"Okay."],[2502,2598,"Put it on me."],[3970,4137,"It looks beautiful on you, Cass."]],"81":[[371,458,"Oh, go away."],[546,629,"I'm still mad at you."],[725,792,"It wasn't that expensive-"],[792,867,"No, it..."],[884,963,"Not about the necklace."],[1021,1067,"Will..."],[1155,1230,"You lied to me about"],[1230,1313,"where you were today."],[1326,1443,"It was supposed to be a surprise."],[1472,1568,"I hate surprises!"],[1789,1947,"I appreciate this. I do."],[1947,2139,"It's awesome. Thank you."],[2339,2489,"Just please, no more lies."],[2756,2798,"From now on,"],[2923,2986,"only the truth."],[3249,3328,"Promise?"],[5355,5492,"I have to tell her."],[5555,5643,"She said if I lie to her again,"],[5643,5743,"she's gonna leave me."],[5847,5914,"So what's your plan?"],[6022,6106,"Because in my experience,"],[6106,6197,"women don't exactly take"],[6206,6293,"it too well when you go"],[6293,6364,"back on your word."],[6410,6489,"Well, what would you do?"],[6531,6594,"Easy."],[6610,6694,"I'd hit her with something"],[6694,6810,"hard first. That way,"],[6819,6911,"when you tell her that"],[6911,7006,"you're Killian Steinmal,"],[7015,7169,"it's not gonna seem like such a big deal."],[7290,7394,"Something? Like what?"]],"82":[[83,191,"Something? Like what?"],[225,362,"Uh, you like, um..."],[371,496,"Oh no, Cassandra, I had been"],[496,608,"diagnosed with a rare"],[617,704,"and terminal illness and"],[704,813,"I only have ten days to"],[821,913,"live, but hey, good news!"],[913,992,"I'm a billionaire!"],[1030,1201,"I'm gonna fucking strangle you!"],[1292,1447,"Oh man, look at you,"],[1447,1622,"Killian Steinmal."],[1630,1764,"You know, you're a ruthless businessman,"],[1764,1893,"but you're completely lost"],[1893,1997,"when it comes to your own wife."],[2064,2206,"She got one thing over you, finally."],[3282,3457,"Hey Cass, are you free tonight?"],[3616,3770,"Let's meet at the Apex Club at seven."],[3803,3870,"Sure."],[4108,4191,"So, what are you gonna do?"],[4225,4433,"I'm gonna tell her the truth."],[4466,4542,"Everything."]],"83":[[817,967,"Heading out to dinner?"],[1167,1347,"I told you not to ever come here again."],[1430,1509,"Leave."],[1518,1693,"Never even bought me a cup of coffee."],[1776,1901,"But he spends millions on you."],[2010,2127,"Guess he must really love you."],[2181,2285,"I don't know what you're talking about."],[2348,2473,"Austrian mother of pearl necklace."],[2577,2715,"Sold at auction two weeks ago."],[3261,3315,"12 million."],[3624,3799,"Oh no, no, no, no, no, no."],[3807,3916,"We got this down at the beach."],[3924,4049,"We strung in ourselves it was free."],[4149,4254,"Okay, you know what?"],[4262,4358,"I think I'm just gonna ask"],[4358,4446,"him about that myself."],[4479,4550,"Thank you very much."],[5605,5701,"Cassandra Mortensen."],[5889,5985,"Do you really know who this man is?"],[6089,6126,"Yes."],[6202,6381,"His real name is Killian Steinmal."]],"84":[[29,212,"His real name is Killian Steinmal."],[291,446,"Killian Steinmal, head of"],[446,604,"Steinmal Enterprises."],[713,813,"You don't know what you're talking about."],[1009,1138,"He likes to keep a low profile,"],[1138,1234,"so most people"],[1234,1422,"don't usually know who he is."],[1493,1651,"But you're not most people, are you?"],[1764,1860,"You're his wife,"],[1972,2089,"but he kept you in the dark on this."],[2239,2360,"And those two kids you're"],[2369,2556,"treating like your own, they know too."],[2673,2802,"They know who their father is."],[2890,3057,"But they didn't tell you."],[3103,3224,"All because Killian Steinmal"],[3224,3345,"asked them to."],[3632,3757,"And you trust them completely."],[3924,4045,"But you really think they"],[4054,4187,"feel the same way about you?"],[4245,4329,"Killian"],[4450,4554,"Steinmal?"],[4938,5004,"So it was him."],[5255,5380,"He's the one who framed"],[5380,5534,"me for plagiarism."],[5722,5830,"He's the one who ruined"],[5830,5955,"my entire career."],[6118,6189,"Oh, that."],[6302,6506,"Yeah, I'm sorry about that."],[6619,6748,"We had just gotten married"],[6748,6881,"and he threw a little fit."],[6986,7090,"So he pulled that stunt to"],[7098,7207,"get me back on his good side."],[7403,7528,"Sorry for dragging you into it."]],"85":[[408,638,"Cass, I'm sorry for lying to you, but"],[646,721,"I had to make sure that"],[729,838,"you were gonna be good to the kids."],[1071,1259,"I've fallen in love with you."],[1405,1622,"I wanna spend the rest of my life with you."],[1805,1893,"When you said you hated"],[1901,2018,"Killian Steinmall,"],[2085,2181,"that scared me."],[2348,2439,"I'm not scared anymore."],[2669,2802,"Will you forgive me?"],[4358,4462,"Cass, there's something I-"],[4471,4579,"I want a divorce."],[4742,4800,"What?"],[4863,4904,"Why?"],[4909,5004,"You know why."],[5080,5171,"Killian Steinmal."],[5401,5505,"A chauffeur?"],[5680,5809,"Five grand a quarter?"],[5901,6026,"Really? You got your kids."],[6051,6368,"You got your parents, even, to lie for you."],[6423,6569,"Do you actually trust me that little?"],[6698,6773,"You seriously think"],[6773,6848,"I'm just here for the money?"],[6877,6977,"Cass no, I was there."],[6986,7111,"Whoa, whoa, whoa, let's not forget."],[7182,7328,"You destroyed my career."],[7357,7474,"Aurelia did that, I had no-"],[7474,7603,"Okay, and how the hell am I"],[7611,7749,"supposed to believe that?"],[7845,7957,"After everything that you've"],[7957,8041,"lied to me about?"],[8062,8141,"No."],[8345,8541,"What's the matter, Killian?"],[8729,8817,"You scared I'm gonna take you"],[8825,8913,"for everything that you own?"],[9021,9079,"Fine."],[9175,9338,"Let me make your nightmares come true."],[9392,9522,"I am divorcing you"],[9522,9659,"and I am taking half of"],[9667,9776,"everything that you have."]],"86":[[70,141,"You know, I knew it."],[179,271,"I always knew that he was"],[271,346,"a fucking asshole."],[375,412,"Yeah."],[433,517,"Girl, you could do so much better."],[525,709,"Honestly, leave him."],[738,875,"Just leave him and don't look back."],[884,1055,"No, no, no way in hell I'm looking back."],[1076,1134,"No."],[1217,1388,"Screw Killian Steinmall."],[1418,1497,"Screw that guy!"],[1514,1605,"I'm taking half of everything."],[1622,1843,"I mean everything that he has."],[1851,1918,"He's gonna wake up tomorrow,"],[1926,2014,"half the toilet's gonna be gone."],[2035,2139,"I'm going to have it."],[2173,2214,"Yeah."],[2227,2373,"You know what, he fucking deserves it."],[2381,2427,"Yes!"],[2427,2502,"Let's see if that bitch"],[2502,2577,"still wants him after that."],[2660,2798,"How soon do you think until he marries her?"],[2802,2827,"No."],[2836,2882,"I bet it's the same day."],[2890,2936,"No, no, no, no, no, no, no."],[2944,2973,"I bet it is."],[2982,3069,"I bet it's right then and there."],[3078,3140,"Okay, Cassandra?"],[3165,3215,"Cassandra."],[3274,3370,"We're not talking about"],[3370,3457,"him anymore, okay?"],[3532,3628,"Yeah."],[3645,3724,"You're rich now."],[3774,3887,"Yes, I'm taking everything."],[3895,3983,"You could buy me a Lamborghini."],[4012,4124,"Wait, wait, I want to go to Venezuela."],[4133,4204,"Venezuela, they have all"],[4212,4329,"these beautiful natural wonders."],[4337,4446,"The waterfalls, the jungle."],[4471,4579,"Sweaty hot guys."],[4708,4808,"I can't wait!"],[5201,5342,"Cassie, Cassie, wait."],[5392,5476,"You can't leave."],[5547,5672,"Please, I'll give you everything."],[5780,5860,"We're done,"],[6010,6064,"Killian."],[6068,6122,"No."],[6181,6256,"You can't leave."],[6264,6331,"Not tonight."],[6343,6393,"It's not safe."],[6539,6673,"Who says I'm the one leaving?"],[6810,6927,"Those are your things."],[6952,7052,"So congratulations, you"],[7052,7148,"were able to go back to"],[7157,7294,"your butler where it is safe."]],"87":[[87,241,"So congratulations you are able to go"],[250,417,"back to your butler where it is safe."],[508,538,"Hmm?"],[567,608,"Mm-hmm."],[721,892,"I have way more stuff than this."],[934,1096,"No! Mom! Dad didn't mean it!"],[1117,1363,"I don't want Daddy to leave!"],[1689,1876,"You know what? You guys, you don't..."],[1876,2022,"you can stay with your daddy if you want to,"],[2022,2168,"but I am staying here."],[2198,2302,"We're staying with you!"],[2489,2681,"It's not our fault. You lied to her!"],[2932,3144,"We're staying with you, Mommy."],[3153,3311,"Plus we can always find a new dad"],[3311,3365,"anywhere."],[3374,3687,"We could find any man if you want."],[3712,3903,"Alright, alright, alright."],[3903,4087,"You two, you can stay with me if you want."],[4116,4187,"Yay!"],[4204,4275,"Yay!"],[4358,4475,"It is a school night though, so"],[4483,4642,"let's go ahead and get you ready for bed."],[4742,4875,"Wait, can I stay too?"],[5017,5201,"Hello? Is this security?"],[5309,5693,"Yes, there is a masked, strong, scary"],[5701,5809,"mass murderer"],[5830,5985,"in this house. Can you get him out?"],[6043,6110,"Right now!"],[6410,6760,"Oh! And I'm done being a Steinmal."],[6806,6948,"I'm changing my name to"],[6956,7244,"Chance Julian Mortensen."],[7265,7428,"Then my name is going to be"],[7428,7620,"Charity Mortensen."],[7657,7816,"We're done being Steinmals."],[8095,8320,"Yeah, what they said."],[8370,8466,"What?"],[8512,8696,"They're just playing around. They're kids."],[8967,9088,"Oh my God."]],"88":[[513,684,"Hey, Cass we're out of d-"],[2318,2452,"I need you, Cass."],[2581,2773,"Oh, good God, you're lovesick."],[2831,3115,"Okay, let's just take this"],[3115,3261,"and put that there"],[3269,3432,"and get you into something nice"],[3440,3520,"because there's a"],[3520,3603,"benefit auction tonight"],[3611,3849,"and it's at Cass's old school place,"],[3858,3999,"so maybe you're gonna"],[3999,4083,"bump into her."],[4091,4158,"Who knows?"],[4220,4337,"I'm not going to that, man."],[4366,4483,"If Cass sees me there,"],[4491,4583,"she's going to make me sign"],[4583,4696,"the divorce papers."],[4796,4879,"Tell you what..."],[4950,5251,"if that happens, if it happens,"],[5409,5480,"I'm going to throw you the"],[5480,5568,"largest singles party."],[5597,5743,"I know this girl, Valentina."],[5780,6035,"She knows these excellent Latinas,"],[6060,6202,"which, speaking of which, I'll show you."],[6277,6427,"Okay, yeah? Uh-huh."]],"89":[[0,171,"Oh my goodness, they're just the most-"],[179,200,"No!"],[221,333,"Dude, I'm not doing that."],[358,408,"Dude."],[462,571,"Get that shit out of here."],[642,888,"Dude, you don't want some margaritas,"],[896,1026,"a little bit of, you know?"],[1055,1217,"Come on, come on, wait a minute."],[2202,2273,"Ew."],[2385,2494,"Didn't expect everyone's"],[2502,2656,"favorite cheater to show up."],[2719,2840,"Why are you here?"],[2886,2982,"Oh, I'm here because"],[2990,3119,"I passed all the prelim stages."],[3128,3178,"Why are you here?"],[3378,3516,"Your dad donated another house."],[3532,3628,"Or no, no, no, don't tell me."],[3657,3912,"He bought off the judges again, right?"],[3920,4012,"Shut up."],[4054,4154,"We all remember how you"],[4154,4245,"cheated on your design."],[4291,4429,"No, I think I've made it very clear"],[4437,4679,"that I did not cheat, actually."],[4779,4904,"I do, however, remember"],[4913,5117,"everything you stole in college."],[5134,5259,"Right, senior year it was those"],[5259,5338,"heels from Jimmy Choo,"],[5438,5530,"a purse from Versace,"],[5538,5709,"Did you even glue anything on yourself?"]],"90":[[0,120,"Did you even glue anything"],[120,208,"on yourself or?"],[216,283,"Whatever."],[312,575,"Your design is probably shit anyways."],[633,754,"My father's investors are"],[763,863,"going to fight tooth and nail"],[871,959,"over what I made."],[1042,1188,"I'll just tell them not to bid on yours."],[1501,1614,"Miss Mortensen."],[1630,1743,"Ooh, ooh."],[1789,1951,"I hear you're going through a divorce."],[2081,2256,"Yeah, just putting my trash"],[2256,2360,"in the dumpster."],[2369,2464,"Feel free to take it out."],[2556,2623,"Oh, I will."],[2644,2686,"Hmm."],[2711,2794,"If I can have everyone's"],[2794,2869,"attention, please."],[2902,3065,"Designers, please come up to the stage."],[3090,3224,"We will be starting shortly."],[3607,3682,"Firstly, I'd like to"],[3691,3845,"introduce a very special guest,"],[3870,4079,"the CEO of Steinmal Industries,"],[4095,4283,"Mr. Killian Steinmal."],[4804,4984,"Oh my God, is that Killian Steinmal?"],[5401,5526,"Dang, he's hot."],[5588,5668,"Didn't know he was going"],[5668,5734,"to be here tonight."],[5759,5922,"It's Aurelia Lombard's ex-husband, right?"],[5976,6089,"Probably here for her."],[6151,6297,"What a kind and caring man."]],"91":[[37,175,"I have here untitled number"],[183,337,"seven, that is untitled number seven."],[387,529,"Going at 30,000."],[550,675,"Do I hear 30,000? 30,000."],[692,930,"35,000. 35,000. 40,000. 40,000."],[963,1209,"Do I hear 45,000? 45,000. 55,000."],[1217,1363,"Do I hear 55,000? 55,000?"],[1388,1643,"Going once? Going twice? Sold!"],[1697,1901,"Congratulations, Miss Chrissy Anderson."],[2419,2540,"Coming up next we have number"],[2548,2694,"eight, Lost Wedding Slippers."],[2731,2898,"A unique take on a classic"],[2907,3111,"design starting at 30,000."],[3136,3236,"Do I hear 30,000?"],[3244,3478,"30,000?"],[3591,3920,"Oh, would you look at that? What a shame."],[4041,4229,"30,000, 30,000, 30,000, 30,000."],[4237,4291,"One million."],[4667,4733,"One..."],[4979,5125,"One million! One million! One million!"],[5163,5238,"Do I hear one million?"],[5263,5451,"Going once, going twice, sold!"],[5513,5780,"Congratulations, Mr. Killian Steinmal"],[5797,6018,"and congratulations to Ms. Cassandra"],[6026,6197,"Mortensen, who designed this piece."],[6869,6998,"Oh Mr. Steinmal, did you need something?"],[7032,7207,"Yeah. Yeah, I just want to say something."]],"92":[[129,258,"Hello everybody."],[275,408,"I, uh, just want to come up here and"],[417,517,"say a few words"],[517,617,"before we move on tonight."],[721,821,"I first off want to say how"],[821,905,"honored and privileged"],[913,1009,"I feel to have purchased"],[1017,1163,"this beautiful piece of art from"],[1205,1380,"Miss Cassandra Mortensen."],[1418,1559,"I have long admired your"],[1643,1818,"bravery and your creativity."],[1931,2047,"You're really something special."],[2089,2335,"Mr. Steinmal, how can you say that?"],[2385,2585,"She copied your wife's designs."],[2610,2769,"Those are false accusations."],[2882,2977,"And I would like to publicly"],[2977,3073,"apologize for"],[3082,3182,"our lack of oversight."],[3307,3449,"And Miss Mortensen, I want to"],[3457,3607,"personally apologize to you."],[4195,4371,"Steinmal Enterprises will"],[4371,4483,"continue to support"],[4491,4637,"Cassandra Mortensen in her"],[4637,4792,"creative endeavors."],[4879,5025,"And furthermore, we will be"],[5034,5167,"setting up a 20 million dollar"],[5176,5301,"college scholarship fund"],[5301,5417,"in her name to help"],[5417,5547,"support the other talented"],[5547,5651,"students at this school."],[5722,5843,"Thank you, Miss Mortensen."],[6289,6473,"And if anyone has a problem with that,"],[6552,6802,"then I'd be happy to conduct a thorough"],[6810,6927,"investigation into what happened"],[6936,7011,"seven years ago."],[7273,7374,"Thank you, everybody."]],"93":[[233,350,"How about that, Cass?"],[408,533,"Do you think you're some"],[533,667,"sort of hero right now?"],[717,925,"Oh, saving the damsel in distress, really?"],[942,1042,"No, I wouldn't have even"],[1042,1163,"been in that situation"],[1172,1334,"if it wasn't for you in the first place."],[1393,1459,"So thank you."],[1480,1597,"But the man I loved was"],[1597,1701,"William Stein, not..."],[1739,1810,"not you."],[1868,1947,"Cassandra?"],[2018,2114,"Is that you?"],[2243,2356,"Whoa, oh my God, Preston?"],[2394,2464,"Yes."],[2481,2552,"What are you, I thought"],[2552,2610,"you were in Italy."],[2619,2681,"What are you doing here?"],[2690,2798,"Well, I'm back now"],[2798,2894,"just for you, Cass."],[2952,3069,"Well, it's really good to see you."],[3086,3157,"Yes, same."],[3445,3561,"Do you want to go get dinner?"],[3574,3703,"Absolutely, let's go."],[3716,3766,"Ok!"],[3778,3970,"Ow! -Oh, are you okay?"],[4012,4079,"Let me see."],[4391,4479,"I have something."],[4529,4825,"I'm always ready for this situation."],[4925,5059,"There you go, boom."],[5100,5317,"And that doesn't look good."],[5326,5401,"Let me drive you home."],[5472,5547,"That's enough."],[5726,5834,"I'll drive my wife home."],[6748,6890,"Let me go or I'm going to scream."],[6898,7040,"I'll shut you up if you do."],[7244,7382,"Promises, promises."],[7394,7453,"Mmm."],[7599,7799,"Ah, what an awful young man."]],"94":[[604,788,"Hey, let me put some Neosporin on that."],[825,900,"We're out."],[963,1046,"Well hang tight."],[1101,1259,"I'll go pick some up, okay?"],[1284,1355,"Okay."],[2214,2439,"Alright, they were out of Neosporin, but..."],[2781,2898,"But these should work."],[3345,3624,"Yeah, let's go ahead and change that."],[4800,5055,"There we go, much better."],[5467,5568,"What's so funny?"],[5697,5922,"Cass, I know you don't like Killian Steinmal,"],[5939,6106,"but every day I come back to"],[6114,6227,"Killian Steinmal's house,"],[6235,6468,"I still feel like I'm Will Stein."],[6589,6844,"I do the dishes, I do the laundry."],[6873,6973,"Every night before I go to"],[6981,7111,"bed, all I think about is you."],[7182,7357,"I want us back, Cass."],[7407,7574,"I'll give you everything you want,"],[7574,7753,"if you let me."],[8049,8149,"So what do you say?"],[8266,8350,"Will you take your"],[8350,8475,"William Stein back?"]],"95":[[367,483,"So what do you say?"],[600,779,"Will you take your William Stein back?"],[1076,1267,"Wow, great timing, thanks for that."],[1359,1447,"No."],[1493,1743,"We forgot to pay the bills last week."],[1843,2018,"At least the emergency light came on."],[2243,2360,"I will go call the utilities."],[2373,2423,"Wait."],[2556,2698,"Kiss me first."],[4158,4295,"Does this mean I'm forgiven?"],[6256,6348,"What is it?"],[6460,6660,"Charity, we gotta start thinking about"],[6664,6769,"baby names."]],"96":[[287,396,"Hey, Cassandra."],[417,638,"I think it's time for you to have this now."],[1384,1463,"Oh..."],[1639,1805,"No, I still can't accept that,"],[1805,1897,"it's too much."],[1926,1997,"No, Cass."],[2052,2131,"Keep it."],[2198,2277,"It's yours now."],[2419,2556,"It's not like Killian can't"],[2556,2694,"give you everything else."],[2781,2911,"And I'll give you anything you want."],[2919,3111,"And we'll have a big wedding for you too."],[3148,3236,"I'll tell everybody that"],[3244,3415,"you're the new Mrs. Steinmal."],[3436,3582,"It'll be the wedding of the century."],[3749,4041,"Your parents must be very proud of you."],[4245,4320,"Actually,"],[4320,4592,"my mom passed when I was younger."],[4600,4783,"And I don't speak to my father anymore,"],[4783,4879,"but..."],[4913,5121,"They're not coming to the wedding."],[5301,5568,"Well, don't you worry about that."],[5709,5814,"You got us now."],[6423,6535,"Mr. Killian Steinmal,"],[6535,6681,"head of Steinmal Enterprises,"],[6681,6823,"has just announced a wedding date"],[6823,6948,"for his marriage to"],[6948,7027,"Ms. Cassandra Mortensen"],[7027,7194,"It'll be the wedding of the century."],[7349,7465,"Don't worry."],[7536,7686,"We'll ruin her."]],"97":[[346,550,"Chance, did you get a bloody nose again?"],[563,684,"Let's tell mommy."],[696,813,"No, mommy and daddy"],[813,955,"are busy with the wedding."],[975,1188,"Plus, we should start thinking about it too."],[1222,1343,"Whose side do we sit on?"],[1351,1480,"I want to sit with mommy."],[1505,1609,"Then it's a deal."],[1630,1797,"We'll sit on mommy's side."],[2014,2181,"Chance, are you happy that"],[2189,2344,"they're finally getting a wedding?"],[2394,2481,"Of course I am."],[2523,2602,"Me too."],[3328,3520,"Mommy, look, Chance is so happy."],[3561,3699,"He just fell over."],[4662,4788,"What'd the doc say?"],[4963,5105,"He said that it might be..."],[5326,5422,"might be leukemia."],[5518,5630,"Um. But they're still waiting"],[5630,5751,"on some results."],[5980,6076,"We have the results."],[6552,6619,"It's accute"],[6619,6698,"lymphocytic leukemia."],[6873,6936,"No."],[7140,7444,"No, no, no, that's not, he was fine."],[7453,7507,"He was running"],[7507,7565,"around. - Just"],[7590,7803,"let me take Killian to go run some tests"],[7828,7903,"to see if he's a match"],[7903,7995,"for a blood transplant."],[8020,8295,"And I can call a few hospitals to see"],[8312,8400,"if we can't get Chance"],[8400,8500,"on a waiting list."],[8554,8737,"Well, we should check Charity too,"],[8742,8825,"right?"],[8829,9013,"Statistically, there is a higher chance"],[9021,9134,"for siblings to be a match."],[9146,9180,"Yeah."],[9250,9342,"Okay, thank you."]],"98":[[141,221,"Did it work?"],[229,354,"Charity wasn't a match either."],[362,442,"We're still waiting on another"],[450,563,"response from the other hospitals."],[604,717,"Is there anything else we can do?"],[813,925,"There's another option."],[1276,1401,"Have another baby with me."],[1518,1572,"And we can try an"],[1580,1751,"umbilical cord stem cell transfer."],[1872,1989,"Go to hell, Aurelia."],[2164,2331,"What do you think, Dr. Jordans?"],[2406,2531,"Cord blood therapy has had higher"],[2540,2719,"success rates for higher risk patients."],[3244,3470,"No, no, no. I'm never having"],[3478,3611,"a baby with you again, Aurelia."],[3770,3978,"I wouldn't be so sure."],[3987,4112,"Think it over, Killian."],[4200,4346,"But don't take too long."],[4346,4491,"Chance is waiting."],[4713,4788,"Turns out they do need"],[4796,4988,"their real mother, after all."],[5864,5968,"But Miss Lombard,"],[5968,6081,"your child won't be a match"],[6089,6181,"with Chance. Aren't you scared"],[6181,6268,"they'll find out"],[6277,6414,"you're not their biological mother?"],[6539,6677,"Who cares if it doesn't work?"],[6677,6790,"Charity wasn't a"],[6798,6977,"match either. They'll never know."]],"99":[[262,458,"On such short notice, I'm"],[467,563,"glad you've made your choice."],[650,813,"In vitro only, that's my offer."],[871,984,"I'll give you anything."],[1063,1276,"This isn't a business deal, Killian."],[1368,1518,"You don't get to name your price."],[1576,1664,"I do."],[1797,2072,"All I'm interested in is being your wife."],[2093,2289,"How about money, shares, status,"],[2289,2385,"anything?"],[2519,2656,"I'm not interested in money."],[2765,3065,"All I'm interested in is you."],[4483,4775,"No, Mommy, I don't want it,"],[4775,4904,"I don't want it."],[4913,5105,"I just want to sleep."],[5251,5397,"Okay, that's all right."],[5672,5726,"Do you want me to"],[5726,5814,"read you a bedtime story?"],[6047,6110,"Okay."],[7774,7870,"How's he doing?"],[7920,8337,"Ah you know, not much of an appetite,"],[8337,8416,"but other than that,"],[8416,8546,"he's being really brave, so."],[8641,8762,"He's a good kid,"],[8879,9180,"but he is still in high risk."],[9213,9313,"His white blood cell count"],[9313,9526,"is very abnormal."],[9634,9813,"I'm so sorry, but you and Killian"],[9813,9876,"are going to have to"],[9876,10005,"make a decision soon."],[10130,10214,"I'm sorry."]],"100":[[262,371,"Yeah, I'm bringing some extra"],[371,454,"sweaters for Chance."],[479,646,"I know he gets chilly at night, so..."],[896,967,"Fuck me."],[1184,1288,"I told you two, I never"],[1288,1384,"wanted to see you again."],[1476,1514,"Leave."],[1568,1680,"Going out on a date with your"],[1680,1785,"billionaire husband?"],[1822,1968,"Well, your sister can't even move."],[1993,2014,"Ugh."],[2110,2223,"You're the shameless one."],[2252,2389,"I bet you even set her up."],[2540,2598,"What do you want?"],[2660,2781,"Give us 30 million for"],[2781,2923,"Vanessa's medical bills,"],[3019,3090,"or you'll be sorry."],[3219,3290,"Wow."],[3311,3436,"In your dreams, will I give you"],[3436,3611,"30 million dollars."],[3611,3678,"Leave!"],[3720,3887,"30 million is nothing for you, Cassandra."],[3987,4074,"You're about to marry into"],[4083,4195,"one of the richest families."],[4300,4362,"What about Vanessa?"],[4454,4625,"We can't marry her off when she's like that,"],[4671,4775,"and it's all your fault."],[4829,4996,"I don't know what you're talking about,"],[5004,5146,"nor do I particularly care."],[5184,5313,"Now, I have asked you two"],[5313,5442,"to leave twice now."],[5451,5693,"And if you don't, I am calling the cops."],[5726,5768,"Got it?"],[5997,6039,"Get out."],[6610,6744,"And you're wrong."],[6898,7040,"I'm not marrying into the Steinmal family."],[8120,8229,"Well, I appreciate that, Doctor,"],[8229,8337,"thank you."],[8445,8571,"No, thank you."],[8933,9021,"I just got off the phone with"],[9021,9088,"Asia and Europe."],[9163,9255,"They don't have a match yet,"],[9263,9446,"but they're going to let us know"],[9455,9526,"when they find one."],[9809,9897,"Just sign it."],[10085,10143,"Please."]],"101":[[312,487,"No Cass, I'm not signing this."],[554,625,"Are you kidding me?"],[633,734,"After everything we've been through"],[742,859,"to throw this all down the drain?"],[963,1230,"We have to save Chance, okay?"],[1255,1388,"You having another baby with Aurelia"],[1397,1493,"is the best chance we have"],[1493,1605,"for that right now."],[1614,1710,"And let you go?"],[1718,1885,"Absolutely not, I'm not letting you go-"],[1885,1985,"Ok, so you're just gonna"],[1985,2114,"let Chance suffer, then?"],[2127,2193,"Because what?"],[2202,2285,"Because you're too stubborn"],[2285,2377,"to lose me?"],[2389,2469,"Think about what this is"],[2469,2565,"like for him right now."],[2598,2698,"We can't trust Aurelia,"],[2698,2802,"you know what she's like."],[2811,2911,"Okay! So what can we do?"],[2977,3061,"Seriously, tell me right now"],[3061,3115,"what we can do."],[3123,3203,"Give me another choice."],[3207,3332,"We sit here and we wait-"],[3340,3449,"We wait. Wait, wait, wait for what?"],[3457,3499,"The doctor said-"],[3507,3582,"Wait for what?"],[3591,3753,"Wait for him to not be able to walk again?"],[3782,3953,"Wait for him to be on a respirator? No!"],[3962,4120,"I'm not doing that."],[4800,4850,"Hey baby."],[4875,5013,"What time is it?"],[5075,5255,"And what are you guys talking about?"],[5309,5497,"We were just talking about..."],[5680,5772,"Your birthday."],[5993,6139,"I think we should do a big party."],[6197,6256,"Yeah?"],[6364,6481,"What do you want for the theme?"],[6519,6710,"Superheroes or fighter jets."],[6810,6986,"I want fairy tales, Mommy,"],[7052,7173,"because you and Charity"],[7182,7357,"are the prettiest princesses"],[7365,7449,"in the world."],[8074,8166,"And you're our little prince."],[8391,8566,"You're our favorite little hero, okay?"]],"102":[[300,371,"Hmm..."],[429,579,"you know, I heard that"],[588,784,"it's somebody's birthday today."],[834,1117,"It's my birthday, I'm turning eight today."],[1242,1334,"Me too."],[1468,1647,"You come here."],[1785,1956,"Wow, all right, I think since"],[1964,2077,"you're both turning eight today,"],[2106,2243,"we should all make a wish together"],[2252,2348,"and blow out the candle in three,"],[2348,2398,"ready?"],[2427,2560,"One, two, three."],[2848,2927,"Good job."],[2948,3094,"All right, what do you guys wish for, hmm?"],[3140,3345,"I wish to grow up faster."],[3420,3578,"And I wish mom and dad will"],[3578,3699,"be together forever."],[3845,3995,"I know that I'm sick"],[3995,4204,"and I might not be there,"],[4245,4320,"but..."],[4408,4713,"I want you to be my mom in my next life."],[4800,5067,"Mommy, will you be my mommy?"],[5263,5513,"Yeah, baby, I'll love you forever, okay?"],[5647,5993,"Hey, there's a brand new train over there,"],[6001,6097,"I wonder who got that?"],[6268,6327,"Yeah."],[6431,6585,"Wow, well, I have a birthday"],[6594,6735,"present for you guys too, okay?"],[6781,6881,"I'll be right back."],[7753,7849,"We're celebrating my kid's"],[7849,7945,"birthdays today,"],[7962,8120,"So whatever it is you're planning?"],[8204,8291,"Don't."]],"103":[[0,158,"So whatever it is you're planning?"],[241,329,"Don't."],[342,450,"Last chance, Cassandra."],[554,692,"Or we're showing this"],[692,905,"to your precious husband."],[967,1117,"Footage from the hotel"],[1126,1297,"when you were sleeping around."],[1501,1680,"See if he still wants you after he finds out"],[1680,1864,"what a big slut bag you are."],[1889,1993,"Wow, actually, thank you."],[2001,2039,"Yeah, fine."],[2072,2168,"Go ahead and do that."],[2177,2302,"Maybe it'll make him divorce me faster."],[2344,2464,"So thanks, help me out there."],[2510,2698,"Oh, drop the tough girl act, Cassandra."],[2765,2961,"You're done for."],[4938,5017,"You know what?"],[5046,5159,"I bet he's calling them"],[5167,5351,"right now to cancel your wedding."],[5693,5789,"Oh, you're done?"],[5834,5947,"See, I told you,"],[5947,6064,"Cassandra is nothing"],[6072,6202,"but a money hungry whore."],[6260,6368,"I don't care about her past."],[6710,6844,"I love Cass for who she is."],[6852,6948,"She's my wife now and..."],[7169,7278,"Have one of our trade partners"],[7278,7374,"deal with them."],[7449,7486,"What?"],[7486,7561,"I never want to see them"],[7561,7665,"in this country ever again."],[7665,7749,"What are you doing?"],[7824,8028,"You can't! Get off of me."],[8049,8233,"Cassandra, I'm gonna get you back."]],"104":[[191,321,"You're not divorcing me?"],[513,604,"God, Killian, Chance-"],[813,921,"What is this?"],[930,1071,"DNA results for you and the kids."],[1163,1405,"This is 99.99%."],[1701,1768,"That means..."],[1868,1906,"Yeah."],[1997,2110,"That means those two twins"],[2118,2210,"that you lost that night,"],[2273,2381,"at the hospital,"],[2535,2619,"it's Chance and Charity."],[2977,3140,"Seven years ago, I got drugged"],[3165,3311,"at the same bar,"],[3370,3457,"same hotel."],[3607,3703,"I thought it was"],[3703,3799,"Aurelia that I slept with,"],[3799,3883,"but"],[4033,4141,"I think it was you."],[4170,4216,"Oh."],[4375,4479,"Wait, what, this isn't..."],[4900,4979,"Killian..."],[5330,5417,"It's really them."],[5559,5643,"Killian."],[5759,5880,"We're gonna get through this"],[5880,6014,"together, all right?"],[6314,6402,"Yeah."],[6402,6527,"But first..."],[6919,7011,"First what?"],[7173,7290,"We need to have another baby."],[7365,7465,"For Chance, right?"],[7507,7599,"Of course."],[7870,7953,"What?"],[8091,8195,"I don't smell that bad, do I?"],[8437,8550,"No, stop."],[8666,8800,"Oh, God, no, sorry, I just had a wave"],[8808,8938,"of nausea for some reason."],[9346,9459,"Ooh, yeah."],[9713,9826,"Wait a second."],[9909,10076,"Cass that night, are you,"],[10105,10206,"are you pregnant?"],[10960,11056,"Am I?"],[11056,11248,"Oh my God, you are pregnant!"]],"105":[[204,346,"Aurelia Lombard, with a"],[354,521,"willful kidnapping of two children,"],[571,688,"assault and battery,"],[696,880,"is sentenced to 30 years in prison."],[1038,1230,"Hey,"],[1230,1384,"why don't you go get me some water?"],[1505,1630,"I'm thirsty."],[1751,1931,"I'm pregnant with"],[1931,2147,"Killian Steinmal's babies,"],[2206,2385,"a boy and a girl."],[2544,2660,"They're twins."],[2911,3078,"I'm going to read them a bedtime story."],[3194,3336,"Did you hear what I said?"],[3645,3891,"Did you think I'm going"],[3891,4191,"to go easy on you?"],[4279,4441,"Just because you're crazy?"],[4821,4863,"Now go."],[5905,5947,"Water."],[6202,6256,"Water."],[6519,6639,"Can I get some water?"],[8558,8679,"Let's welcome the bride."],[12120,12216,"Those are some pretty nice heels"],[12216,12324,"you got on."],[12399,12575,"Any idea which famous"],[12583,12725,"designer might have designed them?"],[12754,12942,"Ooh, I don't know."],[12942,13167,"I do know they were not cheap."],[13209,13434,"Okay, let's exchange the rings."],[14285,14539,"Ew, Chance, it's all covered with spit."],[14664,14806,"They better deal with it, Charity."],[14864,15044,"We're not doing this all over again."]]}