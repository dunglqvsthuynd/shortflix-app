{"1":[[12,91,"Push!"],[300,479,"Yep, her blood pressure is dropping."],[800,955,"Yep, come on, push!"],[1013,1217,"We're losing her, we're losing her!"],[1234,1317,"Cassandra!"],[1330,1418,"I can't believe"],[1418,1580,"you got yourself knocked up."],[1689,1885,"You're a skank and a disgrace."],[1918,2060,"I'm telling you dad,"],[2060,2177,"I heard she got blackout drunk"],[2177,2293,"at some party and woke up"],[2293,2452,"at a motel two towns over."],[2489,2594,"You have to do something about her"],[2602,2806,"before she ruins my reputation"],[2811,3007,"whoring herself out like that."],[3048,3240,"You loose, immoral brat."],[3303,3457,"You need to get rid of that bastard child"],[3457,3699,"right away before anyone else finds out."],[3699,3778,"Do you hear me?"],[3791,3924,"What about your bastard child"],[3924,4070,"right there?"],[4070,4241,"You didn't bat an eye"],[4241,4433,"having her behind mom's back."],[4437,4600,"So how about this? You get rid of yours"],[4608,4758,"and then I'll get rid of mine."],[4771,4925,"Get out and stay out."],[4988,5100,"Cassandra Mortensen,"],[5134,5217,"I'm disowning you."],[5255,5330,"Great."],[5463,5613,"Exactly what I wanted to hear."],[5914,6014,"Push!"],[6598,6815,"Congrats Mama, it's a boy and a girl."],[6911,6990,"They're beautiful."],[7006,7111,"And they both have the same"],[7111,7194,"heart-shaped birthmark"],[7194,7290,"on their collarbone,"],[7290,7507,"just like you."],[8817,8896,"Have you found the woman"],[8896,9054,"from that night yet?"]],"2":[[254,412,"Where are my babies?"],[458,538,"I'm sorry, ma'am."],[558,667,"They both had fatal"],[667,863,"congenital birth defects."],[934,1017,"They didn't make it."],[2569,2648,"Here you go."],[2656,2756,"The babies as promised."],[2790,2919,"The mother thinks they're dead."],[2919,3040,"Can I have the money now?"],[3428,3549,"Thank you so much for coming."],[3557,3670,"I hope you enjoy and let me know"],[3670,3774,"if you need anything."],[3774,3816,"Thank you."],[3816,3883,"Yeah, thank you."],[4325,4391,"Mr. Simons?"],[4396,4479,"Hey, uh, hi,"],[4521,4754,"so I was the top sales employee"],[4754,4942,"again this month."],[5142,5271,"Yep, so I was just, you know,"],[5276,5551,"I was wondering if I could"],[5618,5747,"get those commission payouts"],[5755,5980,"and bonuses for the past few months,"],[5980,6118,"please?"],[6364,6452,"Marry me."],[6598,6806,"I will pay in cash right now."],[6865,7011,"Oh, yeah."],[7077,7190,"Not to reject you or anything,"],[7194,7286,"because I would never do that."],[7290,7378,"I would, that'd be crazy."],[7386,7540,"I don't think that my husband"],[7549,7745,"would be too happy about that."],[7753,7803,"What?"],[7882,7957,"Yeah."],[8033,8087,"You're married?"],[8241,8420,"Prove it, or you are fired"],[8742,8863,"for lying to me."],[9580,9663,"Dammit!"],[9705,9822,"How the heck am I supposed"],[9822,9905,"to find a husband?"]],"3":[[387,525,"Here's the posters they put up this week,"],[533,646,"Mr. Steinmal."],[717,900,"Help wanted. Seeking mother."],[909,1151,"Compensation $5 million."],[1192,1368,"Chance Julian Steinmal."],[2886,2965,"You rascal!"],[3002,3073,"What were you thinking?"],[3082,3236,"Putting these up all over the city."],[3261,3307,"What?"],[3345,3420,"Money talks."],[3465,3545,"Come on, Dad."],[3586,3707,"You're going on 35"],[3707,3953,"and you still haven't found a mommy for us."],[4016,4241,"All the kids at school make fun of us"],[4250,4441,"because you, obviously,"],[4441,4650,"can't get a girl."],[4717,4863,"Another word out of you, Chance, and"],[4884,5030,"there's no allowance for you for a month."],[5067,5221,"Every kid grows up with either"],[5221,5438,"lots of love or lots of money."],[5455,5626,"If you're not willing to give me either,"],[5634,5851,"I don't want you to be my daddy anymore."],[6135,6348,"Chance, hold on, wait for me."],[6414,6523,"Are you kidding?"],[6681,6769,"Go get them."],[6936,7069,"And never mind Chance."],[7161,7273,"Just bring Charity."],[7328,7515,"Charity!"],[7770,7849,"Grab my hand!"],[7941,8020,"Charity, come on!"],[8124,8204,"Hey, what's going on?"],[8420,8525,"Hey, what is going on?"],[10485,10602,"What is wrong with you?"],[10610,10689,"You're trying to kidnap kids"],[10698,10789,"in the middle of broad daylight?"],[10814,10881,"That's insane."],[10990,11069,"Mommy!"],[11086,11127,"Mommy!"],[11156,11177,"Oh."],[11240,11398,"Daddy, we finally found her."],[11440,11628,"We finally found Mommy."],[12124,12216,"Daddy."]],"4":[[100,229,"So, um..."],[529,696,"I'm really sorry about"],[754,809,"that."],[838,946,"I didn't realize you were their dad."],[950,1042,"I didn't know. I'm sorry."],[1096,1355,"Don't worry. It's a classic rom-com meet."],[1384,1480,"Cute."],[1534,1668,"Don't worry, mommy."],[1668,1826,"I can buy you a drink myself."],[1835,2001,"Ooh, wow. Thank you so much, bud."],[2018,2243,"Um, just one thing."],[2252,2427,"Why do y'all keep calling me mommy?"],[2439,2656,"Because I see mommy in my dreams"],[2656,2740,"all the time."],[2761,2890,"You look just like her."],[2902,3144,"Me too. I got the same dreams too."],[3165,3328,"Because we're twins."],[3374,3691,"Twins? Mine were fraternal twins too."],[3749,3874,"Where're my babies?"],[3941,4045,"I'm sorry, ma'am."],[4045,4149,"They both had fatal"],[4149,4304,"congenital birth defects."],[4421,4508,"They didn't make it."],[4683,4888,"Anyway, Mommy,"],[4925,5042,"what are you looking for"],[5042,5138,"in a future husband?"],[5188,5288,"Chance, knock it off."],[5330,5409,"Hey now."],[5422,5576,"Adults shouldn't butt in"],[5576,5722,"when kids are talking."],[5772,5926,"How about this guy over here?"],[5951,5993,"Whoa!"],[5997,6076,"Oh my God."],[6160,6381,"Six feet tall. Handsome."],[6410,6564,"Great career."],[6585,6794,"Two amazing kids."],[6827,7240,"But never spends time around any woman."],[7282,7378,"Yeah, isn't that"],[7378,7520,"just your dad in that picture?"],[7520,7632,"I'm actually six foot two."],[7649,7724,"Chance!"],[7749,7891,"Stop it right now or you're grounded."],[7949,8112,"Okay, stop. Don't ground him."],[8137,8283,"They're having fun, clearly."],[8283,8379,"It's not a big deal."],[8379,8541,"It's okay, Mommy."],[8541,8779,"Daddy actually never grounds us."],[8796,8988,"He just pretends to be scary."],[9038,9129,"Oh yeah, Charity,"],[9138,9234,"what do you know about"],[9235,9334,"disciplining kids?"],[9351,9455,"Do you have any kids?"],[9597,9688,"That's what I thought."],[9713,9914,"Okay? Chance, Charity, let's go."],[9930,10185,"Wait. Uh, what if we got married?"]],"5":[[37,321,"Then if... if we were married"],[321,446,"I would be okay disciplining them,"],[446,592,"because they'd be mine."],[625,792,"There you are, you skank."],[846,988,"I've been looking all over for you."],[1030,1172,"I maxed out my cards"],[1172,1326,"buying you clothes and shoes"],[1334,1534,"and you, you block my number?"],[1785,1981,"Excuse me for just a second. I'll be, um,"],[2022,2122,"be right back."],[2152,2419,"Hmm, I knew it. She's just after my money."],[2481,2652,"All right, we'll go back and wait."],[2940,3002,"Hm..."],[3103,3194,"Cassandra,"],[3207,3340,"I finally found you."],[3361,3541,"You're acting like you haven't seen me"],[3541,3699,"in 3 years."],[3732,3945,"It's been what, like 3 days?"],[4045,4366,"Besides, you are a married man."],[4504,4646,"Act like it."],[4679,4888,"Wait a minute. You know I was married?"],[4896,4975,"Mm hm."],[4984,5155,"And you still spent my money?"],[5163,5397,"Yeah. Revenge."],[5442,5630,"Oh! Also, I did send everything I got"],[5630,5839,"directly to your wife, so um,"],[5939,6143,"I hope she loves designer."],[6898,7061,"Okay, so um..."],[7182,7261,"Anyway."],[7328,7499,"About that marriage. Think about it?"],[7849,7949,"Chance, Charity,"],[7978,8070,"why don't the two of you"],[8070,8170,"go get some ice cream?"],[8237,8320,"Yes!"],[8546,8721,"Sure, I'll marry you."],[8733,8817,"Yeah?"],[8817,8900,"But just to be clear,"],[8900,9096,"I don't have a dime to my name."]],"6":[[25,162,"Are you sure about that?"],[171,367,"Because your suit you're wearing looks"],[379,533,"like really nice actually."],[592,742,"I'm the driver for a CEO."],[788,900,"I only make like eight,"],[900,1000,"nine grand a month."],[1013,1280,"Eight or nine? That's not too bad."],[1288,1447,"That's significantly more than I make, so..."],[1455,1672,"Uh, I mean more like"],[1680,1860,"eight or nine grand quarterly."],[1926,1964,"Oh!"],[1976,2093,"And it fluctuates a lot."],[2093,2160,"I only make like"],[2173,2360,"two, three thousand a month."],[2394,2594,"I mean that's not bad. That's fine."],[2619,2723,"Where are you living right now?"],[2731,2806,"New Parklands."],[2940,3019,"In a"],[3032,3186,"one bedroom, one bed,"],[3186,3294,"one bathroom apartment."],[3319,3449,"Yeah, it's just barely big enough"],[3449,3549,"actually for me and the twins."],[3566,3803,"Sorry, did you just say New Parklands?"],[3866,3962,"Come on!"],[3999,4170,"No, that's literally the heart of the city."],[4187,4362,"Those places go for what?"],[4371,4583,"A couple thousand per square foot?"],[4604,4750,"Even the smallest ones are like,"],[4750,4896,"two thousand square feet."],[4896,5084,"Even if you were the CEO yourself,"],[5092,5188,"you probably still couldn't afford"],[5188,5317,"to live there. Come on."],[5338,5492,"Yeah, no, you're right."],[5492,5576,"New Parklands is crazy."],[5576,5697,"That's crazy!"],[5701,5860,"It is. I know, I'm sorry."],[5868,5980,"I, I just do this thing"],[5980,6143,"when I get nervous I just start lying."],[6272,6373,"I do that."],[6402,6506,"No, I do that too, seriously."],[6514,6598,"I, I, I..."],[6619,6781,"I work in sales. I literally"],[6781,6915,"lie to customers for a living."],[7015,7148,"No, actually though, I'm,"],[7157,7311,"I'm kidding."],[7344,7482,"It's really, it's about..."],[7545,7615,"About what?"],[7665,7882,"It's all about hard work, not giving up."],[7882,8003,"So..."],[8074,8128,"Keep working hard."],[8128,8354,"Maybe you'll get to live there one day."],[8420,8508,"I- - Anyway,"],[8508,8679,"I am Cassandra."],[8804,8946,"Officially introducing myself."],[8950,9100,"I sell shoes for a living."],[9188,9392,"I make about three thousand a month"],[9401,9513,"but I make commission."],[9522,9609,"So, you know..."],[9613,9722,"I could help out with the kids expenses."],[9726,9847,"Stuff like that."],[9847,9943,"Uh-huh. Well..."],[9959,10055,"Okay, actually,"],[10172,10293,"don't say anything."],[10293,10402,"A good saleswoman"],[10402,10514,"always give their customer"],[10514,10731,"ample time to think things over. So,"],[10769,10877,"no rush."],[10931,11140,"Think about my offer, okay?"]],"7":[[70,200,"Why won't you marry her?"],[200,400,"I'm not gonna drink my milk anymore"],[400,567,"if you don't marry her."],[633,846,"Sure. Have it your way."],[938,1026,"Ms. Margaret!"],[1526,1651,"There. Happy?"],[1710,1822,"And what is it with you two"],[1822,1910,"and this fascination"],[1910,1997,"with this woman anyway?"],[1997,2135,"You don't even know her."],[2160,2260,"Don't you remember what happened"],[2260,2385,"to you when you were little?"],[2427,2585,"Your old nanny that I had to fire"],[2585,2686,"gave you sleeping pills"],[2686,2790,"and tried to kidnap you."],[2848,2948,"Daddy had to pay a fortune"],[2948,3061,"just to get you back."],[3098,3240,"Do you really want that to happen again?"],[3524,3670,"No, no, no, no, no. Charity."],[3678,3891,"Charity, I'm so sorry. Did daddy scare you?"],[3899,4237,"No, I'm hungry. I really wish I could eat"],[4237,4504,"milk and cereal right now."],[4554,4738,"Well, it's sitting there"],[4738,4821,"right in front of you."],[4821,4959,"Why don't you just have some right now,"],[4959,5025,"okay?"],[5025,5326,"No! Chance just said we can't eat anymore"],[5334,5551,"if you're not marrying her."],[5659,5826,"Chance, I told you to stop"],[5834,5972,"dragging your sister into this."],[6018,6260,"Which one will you choose? Your pride"],[6268,6631,"or my sister who's starving to death?"],[6639,6815,"Argh, you kids!"],[6923,7040,"Alright, alright, alright,"],[7048,7140,"I'll marry her."],[7173,7253,"Okay?"],[7298,7374,"Happy?"],[7490,7591,"There's just one condition"],[7591,7745,"that we have to follow."],[7778,8012,"We cannot let her know that we're rich."],[8028,8103,"Okay?"],[8149,8233,"I have to make sure that she's"],[8241,8483,"gonna treat you guys good first. Deal?"],[8579,8746,"Well then, that's a deal."],[9284,9388,"You little rascals."],[9659,9897,"Chance, do we have to pretend to be poor"],[9909,9976,"right now?"],[9984,10256,"I've still got left a few million dollars"],[10276,10514,"left from our birthday present."],[10560,10752,"And I still want to buy her"],[10752,10965,"a huge diamond tiara."],[10973,11123,"No, no, silly."],[11136,11469,"That's not enough to get mommy anything."],[11582,11720,"First, let's get focused on"],[11728,11986,"getting mommy and daddy married."],[12053,12387,"Then she'll get all of daddy's money and"],[12395,12629,"that will be a lot more than we have."],[13108,13300,"Hello? Who is this?"],[13380,13709,"This is, uh, Ki... William Stein."],[13709,13976,"Okay, and who would that be?"],[14022,14147,"Your husband."],[14172,14339,"You might wanna save this number."]],"8":[[613,692,"Oh, come on."],[721,792,"Dude, seriously?"],[884,1026,"I mean, you are the richest"],[1026,1126,"bachelor in Winchester."],[1126,1272,"I mean, you can marry anybody"],[1288,1455,"and you're letting your kids choose."],[1564,1801,"Crazy how one night at a bar seven years ago"],[1810,1981,"can completely change your life around."],[2022,2077,"I should have never"],[2085,2227,"dragged you out for drinks, man."],[2277,2323,"I mean,"],[2323,2427,"you wouldn't have gotten drugged"],[2427,2623,"and knocked up a stranger."],[2911,3078,"A little over two grand a month"],[3078,3169,"with two kids?"],[3232,3324,"Girl, that does not sound"],[3324,3411,"too stable to me."],[3457,3591,"How do you know that he's not using you?"],[3641,3716,"He's pretty cute."],[3762,3983,"And the kids, Abby,"],[3983,4141,"they're a boy and a girl."],[4166,4295,"Fraternal twins."],[4383,4650,"They remind me of my babies."],[4892,5113,"Cass, you can't say that out loud ever,"],[5113,5205,"okay?"],[5255,5330,"He's just gonna think you're trying"],[5330,5455,"to replace the kids you lost,"],[5455,5597,"he won't trust you."],[5630,5672,"Yeah."],[5747,5872,"Anyway, where's the ring?"],[5926,6014,"Any honeymoon plans?"],[6064,6189,"Come on, we can't afford any of that."],[6260,6306,"Girl, no."],[6335,6452,"Stand up for yourself, okay?"],[6573,6719,"Tell him you wanna go shopping right now."],[6740,6852,"Shopping?"],[6902,6981,"Text him."],[7027,7161,"If he's not spending his money on you,"],[7169,7261,"he's just gonna be spending it on"],[7261,7328,"someone else."],[7411,7524,"You know what?"],[7603,7845,"There is a little something that I want."],[8425,8575,"Gold digger."],[8616,8679,"I knew it."],[8708,8854,"She's showing her true colors now."]],"9":[[50,200,"I do think this is really pretty."],[241,337,"Affordable too."],[362,425,"Um, okay."],[508,654,"Yeah, I'll take both."],[925,1034,"So..."],[1101,1201,"You're picking something out"],[1201,1292,"for the kids."],[1322,1397,"Yes."],[1397,1534,"I, I wanted a gift for them."],[1551,1605,"You know,"],[1605,1780,"it's my first time being a mom and all."],[1789,1864,"Wanted to..."],[1885,1989,"go with a bang."],[2097,2281,"That'll be $1,200, please."],[2460,2623,"$1,200?"],[2698,2756,"For..."],[2836,2932,"Can I get a discount?"],[2944,3019,"I did get two."],[3023,3107,"Buy one, get one..."],[3148,3240,"Uh, no."],[3253,3407,"We don't do that around here."],[3566,3641,"Come on."],[3678,3753,"Work with me here."],[3766,3849,"I actually work here too,"],[3849,3920,"right around the corner."],[3920,4003,"Leto's Luxury Shoes."],[4012,4095,"Ever heard of it?"],[4104,4162,"So you,"],[4195,4304,"you throw me a bone here,"],[4379,4496,"I'll hook you up next time"],[4496,4575,"you come in to the shop."],[4575,4708,"Yeah, I'll throw in a free pair"],[4708,4758,"of heel protectors."],[4767,4850,"How about that?"],[4954,5121,"It's only $1,200."],[5155,5317,"I mean, if you can't afford it,"],[5326,5463,"you don't need to waste my time."],[5559,5672,"Are you taking them or not?"],[6010,6060,"Yeah."],[6081,6131,"Yeah."],[6218,6285,"I'm taking them."],[6297,6410,"I'll take them."],[6956,7127,"They do do discounts right now."],[7161,7328,"Uh, birthdays, holidays, stuff like that."],[7336,7407,"Although it's not my birthday,"],[7407,7632,"so that's a long shot. But-"],[7678,7749,"Mommy."],[7766,7895,"Mom, you could pick one."],[7912,8187,"We'll take care of it like a gift for you."],[8220,8329,"Thank you."],[8575,8742,"What about this one over here?"],[8750,8888,"It looks nice, doesn't it?"],[8992,9113,"Of course it's nice."],[9134,9313,"It's $150,000."],[9434,9864,"$150,000 for that?"],[9918,10222,"My mom would like to try it on, please."],[10360,10431,"Oh."],[10443,10627,"If you can't afford to buy it,"],[10643,10794,"you can't afford to try it on."],[10831,10990,"I couldn't be held responsible if"],[10998,11227,"you damaged such a precious piece."],[11265,11336,"Hmm."],[11473,11540,"Daddy,"],[11540,11753,"could you please buy it for mommy?"],[11849,12041,"Okay, sweetheart. I'll buy it."],[12174,12274,"Wait a second..."],[12537,12687,"I'm so sorry, Charity."],[12696,12858,"I seem to have left my wallet at home."],[12887,13234,"Sir, if you'd like some other options,"],[13234,13334,"there's a good will"],[13334,13450,"right around the corner."],[13467,13621,"That might be more of your scene."],[13801,13963,"You're doubting my father,"],[13984,14197,"because you think he can't afford it."],[14239,14351,"What's going on here?"],[14385,14572,"Mr. Richard, sir."],[14614,14727,"Hello, Mr. Richard."],[14843,14998,"My wife here was"],[14998,15140,"looking at the rings over there,"],[15148,15298,"and this locket it right here,"],[15298,15415,"but I seem to have forgotten"],[15415,15519,"my wallet at home."],[15519,15724,"You guys do discounts for birthdays, right?"],[15844,16095,"It just so happens to be my birthday today."],[16191,16349,"I was hoping..."],[16424,16554,"to get that discount."]],"10":[[12,87,"Okay, you know what? Will,"],[87,162,"let's just go."],[162,262,"Alright, if this was half"],[262,333,"off, we couldn't afford it,"],[333,458,"let alone some birthday discount."],[471,529,"Uh, Killian."],[558,638,"What?"],[663,729,"What was that?"],[759,871,"Uh, uh, ah. - What?"],[1042,1121,"The necklace, everything is free."],[1121,1159,"Don't worry about it."],[1159,1347,"You don't have to pay. No. No. No."],[1359,1522,"We'll even throw in the, uh, rings"],[1522,1626,"for the kiddos."],[1685,1735,"Yes."],[1768,2097,"Oh! Uh, you enjoy your birthday, right?"],[2106,2177,"Free?"],[2189,2273,"Yes!"],[2360,2460,"Thank you so much."],[2469,2556,"Thanks, Charity."],[2556,2706,"You have yourself a fantastic birthday."],[2715,2827,"Oh, well, thank you. - Yeah."],[2840,2932,"Thank you. - Yes."],[2973,3053,"Thank you."],[3057,3140,"Hope to see you soon."],[3169,3232,"What was that?"],[3357,3549,"Sir, what the hell?"],[3624,3757,"How could you give away all of that"],[3766,3853,"for free, Richard?"],[4145,4329,"Are you the stupidest person"],[4329,4483,"in this entire mall?"],[4508,4675,"That was Killian Steinmal,"],[4683,4892,"the wealthiest man in all of Winchester."],[4921,5075,"You know, when the recession happened,"],[5075,5292,"he kept this entire company alive."],[5309,5422,"And your salary."],[5438,5609,"I could give him the whole damn store!"],[5609,5784,"Everything for him!"],[5868,6010,"She'll be right with you, sir!"],[6439,6614,"Oh my God! We got all of that for free."],[6614,6681,"He just gave us all."],[6681,6781,"That is quite the birthday discount"],[6794,6894,"if I've ever seen one."],[6915,7044,"I'm gonna come back every year."],[7044,7198,"It's settled."],[7298,7486,"Wait. Why'd you take that off?"],[7561,7665,"Well, it's expensive."],[7761,7957,"I wanna keep it in pristine condition"],[7987,8083,"for when Charity grows up."],[8083,8233,"I think she's gonna love it one day."],[8233,8283,"Right?"],[8362,8445,"Yeah."],[8445,8712,"It was only $150,000. I got it for you."],[8746,8829,"Keep it."],[8829,9175,"Did you just say only $150,000?"],[9342,9451,"What do you think you are?"],[9451,9547,"Some sort of billionaire?"],[9547,9609,"That was crazy."],[9617,9709,"That was a crazy statement."],[9784,9838,"Anyway,"],[9893,10035,"who wants to see what I got for you two?"],[10043,10110,"Me!"],[10110,10235,"Yes, yes, yes! Alright!"],[10343,10510,"Alright, it's right in here. Ready?"],[10660,10802,"Necklaces. Here, I'll put them on you guys."],[10802,10848,"Ready?"],[10940,11056,"Ready?"],[11056,11148,"Thank you."],[11186,11269,"Nice."],[11440,11669,"That birthmark on his collarbone."],[11782,11957,"One for Charity."],[12028,12099,"Yes."],[12278,12512,"Oh, Charity has the birthmark, too."],[12700,12887,"Congrats, Mama. It's a boy"],[12887,13083,"and a girl. They're beautiful."],[13142,13221,"And they both have"],[13221,13321,"the same heart-shaped birthmark"],[13329,13492,"on their collarbone, just like you."],[13684,13797,"They both have"],[13797,14030,"the heart-shaped birthmark."],[14047,14406,"So, where'd you get the kids?"]],"11":[[25,183,"Where'd you get the kids?"],[613,742,"From their mom, what do you think,"],[750,846,"I popped them out?"],[988,1055,"Right."],[1222,1472,"Right, so where, where is their mom now?"],[1534,1634,"Ah."],[1710,1830,"The ex-wife."],[2139,2302,"She moved to Europe after the divorce"],[2310,2439,"and became a fashion designer."],[2527,2677,"Stop it, Cassandra,"],[2715,2861,"of course they have a mom."],[2865,3103,"Your bio kids died seven years ago."],[3799,3849,"Hi."],[3853,3924,"Miss Mortensen?"],[3933,3999,"You booked an appointment"],[3999,4074,"with us today"],[4074,4237,"to look at a 3 bedroom apartment?"],[4262,4421,"Yeah, sure, sure yeah, we'll be,"],[4421,4508,"we'll be right over."],[4667,4867,"Ooh, alright."],[4867,5013,"Who wants to go see our new apartment?"],[5096,5188,"You? - Our new..."],[5213,5422,"our new, wait, wait, wait, wait, hold on."],[5551,5655,"Our new apartment?"],[5676,5905,"Like the four of us living together?"],[5960,6051,"Yeah."],[6068,6193,"Come on, what's the point of being married"],[6193,6306,"if we're not sharing expenses?"],[6393,6573,"Trust me. It's much cheaper"],[6573,6685,"to rent as a couple."],[6740,6915,"But I am going to try to talk the realtor"],[6915,7086,"down a little bit, price-wise."],[7094,7286,"I'm going to need all three of your helps,"],[7286,7361,"alright?"],[7361,7570,"Listen up. Anytime she asks you any question."],[7578,7707,"This is what I'm gonna need."],[7716,7882,"I'm gonna need all of you to be like"],[7882,8045,"Hmm, I don't know."],[8045,8137,"I've got to think about that."],[8137,8220,"I'm not sure."],[8224,8383,"Stuff like that to talk her down."],[8391,8483,"Got it? Thumbs up."],[8529,8621,"Got it?"],[8666,8808,"Alright, let's go."],[9346,9496,"What'd you think about the apartment?"],[9496,9701,"Uh yeah, I mean it's okay."],[9763,9909,"It's just the master bedroom"],[9909,10055,"is a little small for us."],[10214,10422,"Alright, you said it was 4000 a month?"],[10435,10739,"Right, that's just a bit out of our budget."],[10777,10831,"Right?"],[10902,10956,"Will?"]],"12":[[62,254,"Oh right, right, yeah. - Yeah"],[262,446,"Yeah. It's what, 800 square feet?"],[500,596,"I mean how the hell is anyone"],[596,742,"supposed to live in a place like that?"],[779,1013,"Yeah, the living room is smaller"],[1013,1159,"than the guest bathroom at home."],[1205,1363,"And the kitchen doesn't even have"],[1363,1488,"a private chef."],[1655,1780,"It's a three bedroom"],[1805,2089,"for 4,000 right in Winchester City."],[2193,2277,"If you're gonna act like that,"],[2285,2531,"then I'm sorry, but I can't help you."],[2606,2665,"Nobody can."],[2836,2915,"Have a great day."],[2940,3082,"No, I..."],[3378,3691,"I told you guys to be nitpicky, not insane."],[3816,3974,"Great, great, that's awesome."],[3983,4099,"We just, we don't have a place to live."],[4099,4158,"But that's okay."],[4158,4408,"We can, we can pitch a tent, right?"],[4658,4871,"Don't worry at all, Mommy."],[4921,4992,"We have tons of houses"],[4992,5092,"all over the world."],[5134,5309,"Like in France and-"],[5342,5480,"Okay buddy."],[5538,5747,"I told you those are monopoly houses"],[5764,5905,"not real houses, right?"],[5989,6143,"We can't actually live there,"],[6143,6352,"this is real life."],[6506,6685,"Hey, I was looking at some properties too,"],[6694,6827,"actually, you wanna go check them out?"],[6898,6965,"Yeah?"],[6973,7157,"What, yeah, yeah, let's go."],[7165,7261,"Yes!"],[7665,7761,"Didn't even buy it."],[7761,7937,"Come on kids, let's go."],[8062,8191,"Whoa."],[8383,8604,"Wow, okay, so..."],[8633,8875,"This is a four bedroom"],[8875,9054,"for only $3,000 a month?"],[9063,9263,"Uh, it's $2,000, actually."],[9392,9517,"Was someone murdered here?"],[9526,9693,"Why is it so cheap?"]],"13":[[83,421,"So why is it only $2000 a month?"],[446,575,"Uh..."],[608,813,"It's my ex-boss's place."],[842,967,"He's renting it out to us."],[975,1038,"He's very picky"],[1038,1159,"about who he rents it out to."],[1167,1401,"Let's see, they have to be married."],[1443,1655,"No single renters."],[1714,1914,"No one over the age of 34."],[1935,2081,"They have to have kids,"],[2143,2239,"twins specifically,"],[2264,2364,"a boy and a girl."],[2423,2602,"Yeah, yeah, that's it."],[2648,2752,"And we check all those boxes,"],[2761,2840,"so that's why he's giving us"],[2840,2927,"such a good deal on it."],[2973,3061,"Yeah."],[3086,3161,"Wow."],[3311,3361,"Wow."],[4133,4316,"And we get all of this?"],[4379,4512,"Uh huh, yeah, yeah."],[4550,4667,"All, all ours."],[4713,4963,"We get to move in here today, if we want."],[5271,5430,"I mean, new homes, new beginnings,"],[5430,5530,"I guess."],[5563,5638,"I'm gonna go ahead,"],[5638,5718,"I'm gonna make you guys"],[5718,5864,"something super special for dinner."],[5968,6056,"Yeah."],[6197,6389,"Come on, Dad, let's help Mommy."],[6456,6589,"Where's Charity at?"],[8454,8671,"Look at that teamwork. Hold on."],[9843,10072,"Thank you, Mommy, it tastes so good"],[10072,10206,"and looks so good."],[10251,10339,"Wow."],[10414,10510,"These do look good."],[10514,10618,"Ah, ah, ah, ah, ah, ah, ah,"],[10627,10702,"Ah, ah. Sit!"]],"14":[[0,58,"Sit."],[108,308,"Those are for the kids, okay?"],[433,483,"Just..."],[529,709,"whatever they don't finish,"],[717,892,"I'm gonna whip up and turn to a pasta."],[917,1009,"All right, trust me, it's gonna be good."],[1071,1126,"You sure?"],[1151,1184,"Yes."],[1209,1276,"I'm sure."],[1459,1526,"See?"],[1614,1772,"I told you they wouldn't eat it all."],[1897,1981,"Cass, I didn't know"],[1981,2068,"you could cook so good."],[2089,2223,"I can do more than just cook."],[2318,2606,"Sowing, home repairs, change a tire."],[2669,2731,"I can do it all."],[2940,3086,"Where'd you learn to do all that?"],[3153,3265,"What did you have a job or something?"],[3311,3465,"Not exactly, no."],[3553,3682,"Okay, if you wanna learn any life skills,"],[3707,3837,"all you have to do is,"],[3916,4058,"A. have your mom die"],[4058,4158,"when you're really young,"],[4158,4358,"B. have your dad remarry,"],[4358,4537,"and C. have that person he remarries,"],[4537,4758,"be an evil, evil stepmother."],[4800,4950,"Just do all of that and I guarantee"],[4950,5117,"you will have life skills"],[5155,5355,"faster than you think."],[5401,5538,"Mommy, that's what happened"],[5538,5684,"with Cinderella, right?"],[5689,5926,"Does that mean you're Cinderella?"],[5972,6222,"And that's the same thing that happened"],[6235,6373,"to Prince Charming."],[6389,6627,"Does that mean you're Prince Charming?"],[6715,6956,"Honestly, yeah, when you put it like that,"],[6965,7044,"that kinda is us."],[7111,7182,"I mean, no, seriously,"],[7190,7265,"I have my thing with the shoes"],[7265,7407,"and you're a driver."],[7507,7582,"That's cute."],[7866,8007,"Alright, Prince Charming,"],[8007,8112,"I'm gonna go get the dishes."],[8116,8199,"Ah no,"],[8270,8400,"you sit down, princess."],[8533,8700,"I'll be doing the dishes around here."]],"15":[[196,287,"Oh, Mr. Simons."],[400,525,"Hi, I, I,"],[579,742,"marriage certificate right here,"],[742,892,"so I am married."],[900,963,"Ooh!"],[975,1059,"Can I have my commission?"],[1067,1151,"You're married?"],[1159,1213,"Yep."],[1247,1305,"Ah."],[1313,1351,"Mm hm."],[1405,1518,"That's even better."],[1668,1864,"A secret fling."],[1885,2077,"I like my relationship..."],[2131,2239,"spicy."],[2356,2652,"Say yes to me, and you get your commission"],[2715,2819,"and then some."],[2902,3007,"Behave yourself, Mr. Simons."],[3007,3119,"I'm recording the whole thing"],[3119,3232,"right here. - Ooh!"],[3232,3319,"If my husband sees that,"],[3328,3403,"he's not gonna be happy."],[3507,3582,"Oh, yeah?"],[3670,3816,"I heard that he's some driver."],[3899,3999,"He has two kids."],[4124,4275,"Putos mocosos."],[4446,4575,"Why don't you pick the real..."],[4696,4754,"winner?"],[4917,5063,"So we are meant to be."],[5401,5480,"We were meant to be?"],[5593,5747,"What are you, some kind of wacko"],[5755,5947,"fucking, fortune teller?"],[5993,6185,"So what? You are a poor taxi driver."],[6243,6489,"I don't need to read you star sign"],[6598,6794,"to know that you are dying in poverty."],[6931,6981,"Huh."],[7052,7232,"Funny, I'm a bit of a fortune teller myself."],[7286,7461,"And right now, my fortune"],[7520,7682,"is saying your future looks pretty grim."],[7774,7887,"Because in about five minutes,"],[7895,8033,"I'm gonna beat the shit out of you"],[8070,8216,"and you're gonna lose your job."]],"16":[[58,104,"You are lying!"],[367,513,"I need to make a phone call."],[884,1021,"Holler if you need anything, alright?"],[1388,1534,"You never get your commission now."],[1564,1655,"You are fired!"],[1664,1876,"And I'm suing you for my medical bills."],[1914,2085,"Just you wait, Cassandra."],[2102,2260,"I'll ruin you."],[2602,2848,"Hey boss, what's up?"],[3002,3078,"What?"],[3144,3261,"I am fired?"],[3374,3528,"Wait, wait! No, no, no!"],[3899,3983,"Are you actually a fortune teller?"],[3991,4112,"Because that was insane."],[4141,4308,"No, I dabbled in it here and there."],[4316,4354,"Oh?"],[4362,4441,"To make ends meet."],[4500,4700,"Wow, that's crazy. Well,"],[4750,4984,"could you tell me when"],[4992,5138,"that $80k is going to hit my account?"],[5146,5296,"Because I could use that right now."],[5342,5476,"Let me show you a magic trick."],[5734,6001,"I'd say you'd see it right..."],[6172,6281,"about..."],[6335,6402,"now."],[6448,6619,"Check your bank account."],[6769,6894,"Okay, I'll check my bank-"],[7178,7261,"Oh my God, it's all there."],[7286,7407,"The $80K, it's in my bank account."],[7415,7628,"It's right, it is right there!"],[7665,7711,"What?"],[7749,7895,"I can't believe you're so excited"],[7895,8012,"over a mere $80k."],[8053,8350,"Um, did you just say a mere $80k?"],[8433,8502,"That is so much money."],[8502,8562,"Do you have any idea"],[8575,8646,"how much money that is?"],[8767,8942,"Ah, we've struck gold, Will!"],[9225,9317,"Yeah."]],"17":[[83,191,"Who knew your wife was working"],[196,400,"under one of my family businesses?"],[429,575,"I'll get her job all sorted out."],[625,742,"Thanks, bro."],[792,975,"Know you treat her awfully well"],[975,1146,"for one of those contract marriages?"],[1309,1447,"Oh, don't tell me"],[1447,1601,"you caught feelings for her."],[1789,1931,"Oh, you still got that scar, huh?"],[2085,2177,"Tell you what,"],[2198,2352,"drop by the hospital at some point"],[2352,2448,"and I'll get dermatology"],[2448,2623,"to fix it up right for you."],[2665,2831,"Sure, thanks."],[3153,3328,"No way. You moved in with him?"],[3407,3545,"Okay. How's married life, girl?"],[3574,3749,"Stop. Stop, It's not like that, okay?"],[3757,3845,"It's a contract marriage."],[3849,3970,"We don't even sleep in the same bedroom."],[4020,4225,"Oh my God, jeez, Cass, come on."],[4254,4329,"Don't tell me you're too shy"],[4329,4425,"to make a move."],[4500,4658,"You really have to get back out there."],[4667,4792,"I mean, you literally"],[4792,4913,"haven't been with anyone else"],[4921,5004,"since that one guy"],[5004,5109,"from like seven years ago."],[5167,5242,"Come on."],[5392,5480,"Do you really not remember"],[5480,5593,"anything at all?"],[5680,5747,"Nothing?"],[5789,5860,"Please."],[5914,6031,"With how drunk I was that night,"],[6031,6160,"I can't even remember his face."],[6264,6339,"Damn."],[6360,6539,"Okay, I mean, there's one thing about him"],[6548,6719,"I remember, but it's small. It's minor."],[6748,6890,"Oh my God, tell me what is it?"],[6965,7102,"He had like, um,"],[7253,7357,"like a scar."],[7424,7582,"Right at the bottom of his abs."],[7820,7966,"This is fucking weird."],[7970,8007,"Oh!"],[8495,8579,"Hey, uh,"],[8771,8863,"where are the kids?"],[8871,8946,"Why are you looking at-"],[8958,9113,"The kids are asleep? - Oh, sorry."],[9171,9275,"The kids, yeah,"],[9275,9463,"I just read them a bedtime story"],[9463,9592,"and yeah, they're asleep."],[9642,9705,"Cool."],[9713,9776,"Um..."],[9955,10080,"You know, I'm just gonna go to bed."],[10089,10172,"I'm gonna go to the guest room."],[10226,10276,"Okay."],[10297,10339,"Great."],[10343,10377,"Okay."],[10377,10427,"Sleep tight."],[10643,10764,"Okay."],[10844,10948,"Both go to the right."],[11002,11052,"Yeah?"],[11156,11248,"Alright, one, two, three."],[11257,11307,"Okay."],[11340,11403,"Wait."],[11490,11653,"He's such a straight-laced man."],[11665,11845,"He doesn't even know how to flirt."],[11870,12062,"And that's his wife."],[12228,12387,"Seems like he needs our help."],[12445,12550,"Again."]],"18":[[58,104,"Yeah. - I'm going to go"],[104,200,"this way. - Yeah."],[200,262,"Mommy!"],[300,350,"Hi."],[408,588,"Mommy, can we sleep with you tonight?"],[638,788,"Yes, please Mom."],[829,950,"Chance, Charity, what are you doing?"],[950,1092,"I just read you your bedtime story."],[1092,1259,"You need to be asleep."],[1272,1397,"Will, you know what?"],[1534,1689,"Why don't I just take the big bed with them"],[1689,1826,"and you can go to the guest room tonight?"],[1839,2085,"Alright, that sounds good. Thanks."],[2102,2160,"No worries."],[2193,2389,"No! Daddy, you too!"],[2464,2565,"I can't do that."],[2565,2752,"I have to be up early tomorrow, guys."],[2765,2869,"Go to bed with mom, okay?"],[2877,3148,"Daddy, just this once. Daddy, please."],[4099,4254,"I'll leave once they fall asleep."],[4291,4358,"It won't be long."],[5551,5672,"Come on, Charity."],[5868,5976,"If Daddy gets cold,"],[5976,6131,"he'll snuggle up with Mommy."],[6131,6272,"Just like a real couple."],[6306,6373,"Yeah."],[9013,9284,"Holy shit. Those pecs."],[9476,9684,"And those abs."],[9751,9922,"Oh, I cannot be having those thoughts"],[9922,10009,"about him."],[10122,10360,"Wait, how come he has a scar there too?"]],"19":[[350,446,"What are you doing?"],[542,721,"Cassandra, what are you doing here?"],[779,896,"This wasn't a part of the deal."],[896,1042,"We were supposed to put the kids to sleep,"],[1042,1167,"not be sleeping here..."],[1213,1301,"together."],[1309,1438,"What am I doing?"],[1547,1676,"You are under my blanket"],[1676,1851,"right now, mister."],[2043,2118,"Oh."],[2168,2235,"Chance!"],[2248,2289,"Oh, okay."],[2298,2377,"Get in here right now!"],[2385,2485,"Stop yelling at them,"],[2485,2627,"they were probably cold."],[2765,2836,"Besides,"],[3028,3123,"you're my husband now."],[3219,3332,"That means I can do"],[3332,3507,"whatever I want with you,"],[3545,3778,"including sleeping in the same bed."],[3837,4003,"Are you trying to take advantage of me"],[4003,4079,"right now?"],[4120,4358,"I think they're gonna kiss."],[4483,4592,"All right, you two."],[4637,4725,"Let's get some breakfast"],[4725,4846,"in those bellies."],[5146,5217,"Let's go."],[5359,5551,"This mattress is so uncomfortable."],[5647,5826,"I can't sleep on this."],[6268,6356,"Horace."],[6485,6702,"Yeah, you remember that $90,000 mattress?"],[6806,6944,"Send one to my new place."],[6986,7069,"Thanks."],[8074,8283,"Um, what is all this?"],[8404,8495,"Um..."],[8546,8704,"This is an old mattress"],[8704,8829,"that I found downstairs."],[8846,8963,"I figured I'd try to salvage it"],[8971,9109,"because we're trying to save money"],[9109,9205,"where we can, right?"],[9225,9280,"Yeah."],[9359,9509,"Yeah, cool, lucky find, awesome."],[9751,10014,"Oh, whoa, is this a Constantine?"],[10168,10389,"These watches are like 200 grand."],[10397,10552,"Why do you have a watch this expensive?"]],"20":[[0,145,"And why do you have a watch that expensive?"],[166,362,"Uh, sorry about that."],[371,513,"This is actually fake."],[567,692,"I still wear it because"],[692,767,"I'm a chauffeur"],[767,855,"and I have to look the part,"],[863,1005,"but this is only like 50 bucks."],[1071,1234,"It's only 50 bucks?"],[1447,1668,"Oh man, it looks really real."],[1697,1810,"Mm hmm."],[1993,2110,"Oh, you have to get me one."],[2168,2331,"Yes, yes, yeah, I have this friend,"],[2331,2423,"her birthday's coming up,"],[2423,2560,"and she's obsessed with watches."],[2585,2686,"Usually the fakes are, like,"],[2686,2777,"crazy expensive, though."],[2777,2927,"Please, please... - Uh,"],[2927,3119,"Cass, I don't think that's a good idea."],[3128,3249,"I mean, this is a fake watch."],[3249,3378,"You don't wanna give your friend"],[3378,3424,"a fake watch."],[3436,3553,"But I'm not going to get her one,"],[3553,3678,"I'm going to get her five."],[3687,3862,"Yeah, yeah, yeah, I'll send you the money."],[3862,3978,"Okay, don't even worry about that."],[3978,4162,"Just take care of getting the watches."],[4191,4283,"Doesn't even have to be a Constantine."],[4283,4358,"Anything that they have,"],[4358,4604,"Rolex, whatever, she loves them all."],[4642,4846,"If they look as good as this does,"],[4888,5017,"she's gonna love it."],[5130,5251,"Thank you!"],[5438,5584,"Uh huh. - Yeah!"],[5768,5926,"One, two."],[6122,6256,"All right, so you guys go ahead"],[6256,6423,"and take this, get some ice cream."],[6435,6573,"Yay!"],[6610,6794,"I'll meet you guys there, okay?"],[7520,7640,"Welcome to Leto's Luxury Shoes,"],[7640,7728,"can I help-"],[7874,8141,"Cassandra, what are you doing here?"],[8153,8245,"Can't believe you're working"],[8245,8375,"customer service."],[8425,8566,"How the mighty's fallen."],[8612,8725,"You should have told us."],[8742,8842,"That way we could have laughed"],[8842,8954,"in your face sooner."],[9004,9117,"I bet you're regretting going"],[9117,9284,"no contact with us when you did."],[9342,9559,"You know what, yeah, I do regret that."],[9588,9830,"I wish I had left that hellhole sooner."],[9905,10022,"That's what I wish."]],"21":[[29,154,"Yeah, right. - Yeah."],[166,383,"Dad just bought me a new villa last week."],[437,513,"Jealous?"],[629,800,"Excuse me, ma'am."],[855,996,"Are you going to purchase anything?"],[1017,1088,"Because the door"],[1088,1197,"is right over there if not."],[1197,1297,"Feel free to use it."],[1343,1601,"Of course I'm going to buy something."],[1735,1935,"And I want you to serve me."],[2273,2369,"Personally."],[2548,2619,"Hmmm."],[2673,2823,"Quick! Charity! Call Daddy!"],[2848,2990,"Tell him mommy's getting bullied!"],[3032,3144,"Come on!"],[3407,3457,"Okay,"],[3457,3624,"these are from our curated collection,"],[3624,3770,"I think you'll really like them."],[3858,3958,"Get down."],[3999,4158,"I want you to put them on my feet."],[4521,4671,"Sure thing, ma'am."],[4913,5080,"Aww, look at you."],[5163,5317,"We came from the same family,"],[5326,5467,"went to the same fashion school."],[5559,5676,"And now look at us."],[5722,5918,"I'm a hot couture designer and"],[5972,6151,"you're putting on my shoes for me."],[6231,6343,"Like a little maid."],[6381,6552,"Ow! Vanessa!"],[6623,6669,"Ow."]],"22":[[41,212,"Ow! Vanessa!"],[283,329,"Ow."],[417,500,"Get me something else."],[558,650,"I don't like them."],[1013,1184,"Right away, ma'am."],[1918,2110,"These might be more to your taste."],[2143,2327,"These are handcrafted in Italy,"],[2356,2615,"typically reserved for VIP clients."],[2660,2836,"This pink pair in particular"],[2836,3048,"is a one of a kind unique design."],[3119,3207,"So..."],[4191,4312,"That's more like it."],[4333,4433,"Yeah, you like them?"],[4491,4612,"We do also have those in purple."],[4625,4763,"They are also part of our premium collection"],[4763,4921,"with a price tag to match."],[4929,5055,"$8,000."],[5146,5201,"Of course,"],[5201,5338,"that shouldn't be a problem for you."],[5363,5576,"Right? You are a hot couture designer."],[5622,5860,"Of course I have the money."],[5939,6005,"I'll just pick"],[6005,6160,"whichever pair I like more."]],"23":[[12,133,"So which ones do you like?"],[141,358,"Just give me one second, okay?"],[633,725,"What are you doing?"],[750,871,"I'm just, I'm helping."],[980,1109,"There. Okay, I just sent a poll"],[1109,1242,"to our entire high school. Ready?"],[1276,1401,"Ran into Vanessa Mortensen"],[1409,1526,"at Leto's Luxury Shoes."],[1534,1626,"Help her decide between"],[1626,1818,"these two pairs of ultra high-end heels."],[1818,1968,"She can't afford them both."],[2027,2064,"Oh my God,"],[2064,2185,"the results are already coming in."],[2185,2344,"People are already voting. That's crazy!"],[2469,2556,"They love them."],[2581,2648,"Vanessa."],[2660,2790,"Oh, you really should get both."],[2790,2973,"Unless you really can't afford them."],[3390,3507,"Money's not a problem."],[3520,3591,"Awesome."],[3653,3737,"Pack them up."],[3832,3920,"Great, so"],[3962,4116,"that'll be $8,000 for the purple pair and"],[4116,4325,"$10,000 for those pink ones right there."],[4366,4450,"Awesome. How would you like to pay?"],[4450,4521,"Cash or card?"],[5088,5196,"Great. That was more"],[5196,5347,"than a month's worth of commission for me."],[5347,5442,"Thank you so much."],[5480,5555,"I really do hope"],[5555,5714,"to see you again here soon."],[5930,6039,"Get out of my way."],[6343,6519,"Hey, are you okay? You okay?"],[6527,6673,"I'm fine. I'm fine."],[7203,7361,"Let go of me, you psycho!"],[7374,7707,"You can threaten me. Harass me."],[7732,7862,"Even assault me."],[7874,7999,"But you touch these kids again,"],[8020,8220,"and I will kill you, bitch!"],[8379,8508,"What are you gonna do about it?"],[8508,8591,"I'm the customer."],[8591,8742,"I can do whatever I want."],[8775,8983,"You better back off or I'll get you fired."]],"24":[[25,216,"You better back off or I'll get you fired."],[246,350,"Yeah, go ahead."],[400,521,"I already got my commission"],[529,646,"and my bonus payout anyway."],[658,788,"What is that supposed to mean?"],[842,975,"That means..."],[1347,1534,"I don't have to hold back."],[2202,2431,"Just you wait, Cassandra Mortensen."],[2848,2969,"Hi, baby hi."],[2990,3065,"Hey, are you okay?"],[3065,3123,"You're okay."],[3123,3299,"I'm totally fine, Mommy."],[3470,3578,"What are you doing here?"],[3595,3749,"Charity told me that there was a damsel"],[3753,3928,"in distress in here but..."],[4262,4504,"Looks like Ms. Damsel has it under control."],[4533,4646,"I'm sorry."],[4721,4854,"I let Chance get hurt today."],[4963,5096,"How you doing buddy?"],[5134,5397,"I'm fine, daddy. It doesn't hurt anymore."],[5463,5638,"See. He's alright."],[5722,5939,"One more thing. I uh..."],[6035,6293,"I kinda quit my job. Just now."],[6314,6473,"What? Why'd you do that?"],[6535,6635,"You're the kind of person"],[6635,6790,"who got married just to get her bonus."],[6790,6919,"Why'd you quit so fast?"],[7023,7144,"She went after the kids."],[7178,7323,"Will, that's where I draw the line."],[7661,7903,"I got bullied a lot when I was their age."],[7995,8091,"I don't want that for them."],[8112,8183,"Well, I mean there's plenty"],[8183,8299,"of other jobs out there, right?"],[8420,8475,"Hey."],[8612,8775,"I'll pick up some more hours in the meantime."],[9046,9288,"Here. You can use this for now."],[9843,9897,"I'm the guy."],[9897,10039,"Let me take care of things for a bit."],[10105,10251,"Oh wow."],[10256,10439,"So mysterious. So cool."],[10447,10623,"Acting like a CEO over there."],[10698,10810,"I know, right?"],[10919,11036,"I might just treat myself"],[11036,11177,"to a fancy dinner tonight."],[11227,11294,"Hey."],[11302,11365,"I'm kidding."],[11373,11457,"Don't get carried away."],[11482,11544,"I'm kidding."],[11565,11628,"Don't."],[11665,11807,"That was really sweet. Thank you."]],"25":[[125,342,"So much for three years of work."],[421,546,"I guess I never really kept much"],[546,667,"at the shoe store."],[688,767,"What's this?"],[925,975,"Nothing."],[980,1088,"No, it's just something I"],[1092,1251,"scribbled when I was bored at work."],[1351,1551,"Cassandra, these are professional."],[1580,1735,"You have a real talent for this."],[1780,1947,"Why don't you work at a fashion studio?"],[2047,2260,"I did go to fashion school, you know,"],[2360,2590,"best in the country, actually."],[2640,2894,"But, uh,"],[2923,3136,"senior year somebody stole my designs and"],[3211,3424,"I got kicked out for plagiarism."],[3499,3607,"Blacklisted from all the major"],[3607,3720,"fashion houses."],[3841,3908,"What?"],[3920,4016,"It was like seven years ago."],[4024,4124,"I am over it, I promise,"],[4162,4245,"it's done."],[4270,4333,"Oh, damn."],[4333,4491,"I mean, every time you talk about your life,"],[4500,4654,"it just gets worse and worse, you know?"],[4704,4825,"Okay, and what are you getting"],[4825,4929,"so worked up about?"],[4996,5138,"It's my life, I'm fine with it."],[5205,5505,"Besides, I might not have ever met you."],[5543,5793,"Or the kids, if I was still in school."],[5793,5889,"You know?"],[5910,5939,"You know,"],[5939,6039,"there's gotta be some company"],[6039,6135,"out there that doesn't care"],[6135,6256,"about your education."],[6431,6506,"How about YS House?"],[6648,6723,"YS House?"],[6806,6869,"Yeah."],[6898,7073,"Why don't you try your luck there at least?"],[7194,7394,"Hey, what's the worst that could happen?"],[8262,8462,"Horace, call the director"],[8462,8562,"down at YS House"],[8562,8687,"and set an appointment up"],[8687,8908,"for a Miss Cassandra Mortensen."],[8954,9025,"Oh, sir,"],[9038,9159,"I didn't know they were hiring."],[9221,9325,"They're hiring now."]],"26":[[221,308,"Oh my God."],[471,521,"Will?"],[654,884,"Will, I got the job at YS House, I got it!"],[1576,1655,"You guys are my lucky charms,"],[1676,1755,"you know that?"],[1818,2022,"Should be thanking their dad, not them."],[2127,2360,"I think somebody is jealous."],[2414,2485,"Me?"],[2498,2627,"Oh, you're talking about me?"],[2702,2848,"You're jealous, jealous,"],[2848,2977,"jealous, jealous!"],[2990,3115,"You're jealous!"],[3123,3261,"Oh my God."],[3799,3870,"Thank you."],[3899,4012,"You're welcome."],[4387,4542,"Are you sure your boss is cool"],[4542,4671,"with you taking his car like that?"],[4746,4946,"Hey boss, sorry for running late."],[4975,5046,"Traffic."],[5142,5201,"Boss?"],[5359,5459,"Sorry, I thought you said"],[5459,5584,"you were a driver."],[5593,5764,"Ha ha ha ha ha, good one, boss."],[5818,6076,"This is Horace, the CEO's assistant."],[6181,6493,"That's right. I, I am the CEO's assistant."],[6523,6644,"Yes, and I'm the driver."],[6652,6727,"And you are the driver."],[6735,6769,"Yeah."],[6769,6869,"Of course, well I guess"],[6869,7065,"I'll let you drive, then."],[7082,7282,"Yeah, let me drive us to work."],[7307,7432,"You can sit in the back seat."],[7453,7632,"I'll sit in the back, you drive."],[7724,7786,"William."],[7795,7995,"Yes, that's my name, yeah."],[8183,8295,"You're gonna have such a good first day."],[8512,8612,"What are we doing?"],[8612,8821,"Play along, just play along."],[9200,9401,"Hey, wait, wait, wait, you didn't like,"],[9501,9705,"pull any strings to get me into YS House?"],[9772,9884,"Pull strings? - Yeah."],[9897,10064,"Come on Cass, the only thing"],[10064,10168,"I know how to pull is a..."],[10235,10393,"is a clutch."],[10485,10610,"No, you got the job because"],[10610,10681,"you're good enough."],[10739,10810,"Alright?"],[10890,10948,"Let's go."]],"27":[[20,141,"So this is the new space,"],[141,283,"this is the conference room."],[304,417,"And here is the common space"],[417,529,"for everbody else."],[638,713,"Hi everyone,"],[713,838,"my name is Cassandra Mortensen."],[838,975,"I'm starting today."],[1021,1205,"Cassandra Mortensen."],[1330,1639,"Wow. Didn't expect you to show up here."],[1789,1881,"Vanessa?"],[2001,2131,"What are you doing here?"],[2139,2314,"That's what I should be asking you, bitch."],[2356,2477,"Of course I'd end up working with"],[2485,2702,"my college dropout, cheating sister."],[2756,2927,"That's right. Her sister plagiarized"],[2927,3069,"her senior project and got kicked out."],[3136,3211,"No wonder she works"],[3211,3357,"at that shitty boutique at the mall."],[3428,3595,"If any of you have a problem"],[3595,3666,"with me being here,"],[3666,3795,"take it up with the hiring manager"],[3795,3999,"because I am not leaving."],[4024,4158,"Get a room, ladies."],[4183,4358,"Mr. Larold is coming in soon."],[4383,4571,"Cassandra, I want you sitting in"],[4604,4742,"to learn how we run things around here,"],[4742,4813,"okay?"],[4979,5171,"Mr. Larold is our newest client."],[5188,5330,"He's worked with all the top fashion houses"],[5330,5434,"in France."],[5442,5572,"So just stay out of the way,"],[5572,5726,"and don't mess this up for everyone, hm?"],[6523,6731,"To be honest, I'm a bit disappointed"],[6731,6919,"with your designs today."],[6919,7098,"I expected better."],[7182,7336,"Sir, my designs are based off"],[7336,7515,"Monet's water lilies, the colors-"],[7515,7724,"Yes, yes, yes, Monet."],[7753,7912,"It's always flowers"],[7912,8033,"and pictures with you people."],[8058,8162,"Don't you know anything else"],[8162,8299,"about France?"],[8445,8587,"I have something else, sir."],[8600,8725,"Shut it, idiot."],[8758,8942,"I'd like to see it."],[9013,9142,"But I'm warning you."],[9234,9330,"Don't disappoint me."],[9359,9647,"Um, this piece I call Out Of The Cannon."],[9818,10080,"Out Of The Cannon? Hmm."],[10206,10514,"My apologies, sir. My sister, she's new."],[10523,10648,"She technically shouldn't even be here"],[10648,10704,"because she was kicked"],[10705,10764,"out of fashion school"],[10764,10844,"for plagiarism."],[10985,11065,"Oh."],[11123,11190,"Really?"],[11215,11390,"No, no. I never plagiarized."],[11524,11686,"Although this is actually"],[11695,11886,"inspired by other people's work."]],"28":[[287,550,"This is inspired by other people's work."],[784,930,"The Parisian street artists."],[1046,1155,"Sometimes the best art"],[1155,1317,"isn't found in a museum."],[1393,1584,"It's all around you, especially in a city"],[1584,1780,"as unique and vibrant as Paris."],[1818,1939,"I feel like it's important"],[1939,2110,"for people to stop and take a look"],[2110,2264,"at what's going on around them."],[2298,2473,"Out of the cannon."],[2498,2615,"The spray can."],[2644,2815,"That is a fantastic idea."],[2890,3015,"The best one I've heard all day."],[3082,3186,"Why wasn't it with the others?"],[3261,3361,"Oh, that's my fault."],[3395,3490,"I turned it in late."],[3516,3599,"That's all right."],[3624,3774,"You obviously know French culture."],[3849,4141,"You don't also happen to know wines, do you?"],[4287,4366,"Well, let's just say"],[4366,4500,"I have quite the collection."],[4500,4671,"And you know, a glass of wine here or there"],[4671,4909,"helps me with a little inspiration."],[5050,5142,"At last!"],[5142,5259,"Someone who understands me!"],[5309,5526,"Quite the collection, huh, Cass?"],[5609,5672,"Well, how about this?"],[5680,5764,"How about you have Mr. Larold"],[5780,5864,"over tonight?"],[5872,5972,"We'll all tag along to see"],[5972,6177,"where you get all your inspiration from."],[6231,6464,"I'm sure you'd love to have us over, right?"],[6481,6756,"Oh, well, the thing is-"],[6785,7002,"That is a brilliant idea."],[7052,7307,"I'd love to see how you work, Cassandra."],[7365,7532,"Oh, so it's settled!"],[7553,7661,"I'll see you at six."],[7945,8045,"I would love to see"],[8045,8153,"how you pull this one off,"],[8153,8400,"in your shitty one-bedroom shack."]],"29":[[266,379,"Will! Hey!"],[392,575,"Mommy! Daddy is on a work trip,"],[583,725,"did you need anything?"],[763,934,"Alright, Chance, Charity."],[967,1080,"Listen up!"],[1146,1234,"Here's the deal."],[1259,1463,"Mommy has got a really,"],[1463,1634,"really big client,"],[1634,1701,"who wants to come over"],[1701,1776,"to our house tonight"],[1776,1935,"at 6 PM, with a lot of people"],[1935,2064,"and they're expecting"],[2064,2193,"fancy wine and dinner."],[2252,2344,"Guess what?"],[2373,2473,"We don't have any of that."],[2473,2623,"So, I'm going to need your help right now."],[2623,2706,"I'm gonna need your help."],[2706,2852,"Whenever everybody shows up tonight"],[2852,2952,"I'm gonna need you to pretend"],[2952,3044,"like nobody's home."],[3044,3115,"And I'm gonna need you to"],[3115,3190,"not open the door"],[3190,3382,"under any circumstances."],[3507,3574,"Got it?"],[3628,3745,"Okay, thank you."],[3916,4124,"Does Mom need our help again?"],[4216,4354,"Yes indeed, Charity."],[4396,4525,"And we're not six anymore,"],[4546,4658,"we're seven."],[4671,4838,"It's time to get to work."],[5384,5626,"Hello, Mrs. Margaret."],[5663,5955,"Our new mommy needs your help."],[6573,6669,"Alright, everyone."],[6694,6781,"Attention, please."],[6802,6965,"We only have one hour to work,"],[6965,7102,"so let's get to work."],[7707,7811,"Come on, come on!"],[8195,8337,"Everything over $10K"],[8337,8495,"on the top shelf!"],[8495,8712,"Sparkling and rosé on the side,"],[8712,8854,"And don't even bother with anything"],[8854,8913,"under $2K."],[8921,8992,"Got that?"],[9004,9205,"Where did you want this antique?"],[9205,9342,"Bowls and plates in the kitchen,"],[9342,9405,"of course."],[9421,9555,"Where would you like this Matisse?"],[9555,9676,"Under the Andy Warhol."],[9676,9763,"Next to the Japanese"],[9763,9851,"watercolor."],[9851,9947,"Got that?"],[10068,10318,"Mom's going to be very surprised."],[10318,10464,"She's going to love it."],[11073,11290,"Man, it looks like nobody's"],[11298,11436,"home, and I don't have my keys, so..."],[11532,11703,"Welcome home, Mommy."]],"30":[[279,417,"Hell, let's do it."],[2147,2331,"Cass, what is this, a Home Goods?"],[2506,2719,"Please, a fake Matisse?"],[2823,3111,"It's real, daddy got it in an auction."],[3169,3324,"Don't lie, rat."],[3345,3482,"Lying makes you ugly."],[3607,3678,"Well..."],[3699,3832,"where's your wine collection"],[3832,3962,"for Mr. Larold?"],[4033,4362,"Oh, Mr. Larold, a pleasure to meet you."],[4404,4512,"Mommy mentioned you have a"],[4512,4667,"great taste in wine."],[4725,5000,"Feel free to look around and tell me"],[5000,5176,"if there's something you like."],[5313,5430,"What is all this?"],[5526,5626,"You just slapped a bunch of"],[5626,5776,"fake labels on these, didn't you?"],[5801,5968,"I can't even pronounce half of them."],[6014,6089,"That's not-"],[6097,6264,"That's right, Mr. Larold."],[6364,6690,"This is Leroy Corton-Charlemagne."],[6781,7178,"And this one is Château Lafite."],[7178,7336,"1988."],[7386,7657,"This one, of course, is Romanée Conti."],[7699,7945,"Vintage limited edition,"],[7945,8337,"sold at auction for $18,000."],[8370,8495,"You're a dirty little liar,"],[8495,8596,"just like your stepmom."],[8596,8737,"Hey, watch it, Vanessa."],[8804,9096,"Oh, and you're the ugly witch"],[9096,9334,"who has no idea what you're talking about."],[9334,9547,"Oh, let me change that. Monster!"],[9713,9843,"Why, you-"],[9843,9972,"I can't believe it."],[10089,10260,"This is the real deal."]],"31":[[12,104,"Cassandra!"],[183,400,"I didn't realize you had such a collection."],[404,504,"Yeah. - It's incredible."],[575,725,"They still seem a bit fancy"],[725,942,"for a casual gathering like this."],[996,1155,"Don't worry Mr. Larold."],[1213,1422,"Mom picked out this one special."],[1438,1622,"We actually have plenty more"],[1622,1751,"in storage."],[1922,1976,"May I?"],[1993,2077,"Of course."],[2097,2289,"How did the kids just pull this off?"],[2323,2469,"Did Will put them up to this?"],[2794,3048,"Uh, so exciting."],[3670,3749,"Yes, enjoy."],[3766,3878,"Excuse me."],[4350,4517,"Where did you guys get this?"],[4608,4875,"Me and Charity won it at a raffle."],[4896,4988,"Raffle."],[5009,5180,"We... there was a promotion"],[5180,5480,"at the mall and they just gave it to us."],[5626,5743,"Come on Cassandra!"],[6060,6172,"Yeah, coming!"],[6760,6810,"Cheers."],[6861,6948,"Cheers!"],[7061,7148,"Thank you guys."],[7223,7328,"So fun."],[7490,7649,"Cassandra, would you like strawberry"],[7649,7745,"or mango cake?"],[7770,7828,"Oh, thank you."],[7828,7949,"I'm actually allergic to mango"],[7949,8095,"but I would love a strawberry slice."],[8128,8237,"All the desserts and everything,"],[8237,8295,"I hope you enjoy."],[8304,8541,"And your help here..."],[9088,9246,"Hey sis! Got you some"],[9246,9446,"strawberry cake for ya."],[9459,9567,"Great party."],[9676,9751,"Thanks."],[10072,10193,"See, I thought so."],[10222,10343,"I thought you might like it."],[10385,10564,"I'm so glad this was suggested today."]],"32":[[87,233,"Cassandra, can I borrow you"],[233,333,"for a moment?"],[513,742,"I love your Andy Warhol!"],[800,909,"Yes, yes, yes."],[909,1042,"You know, I do love pop art."],[1051,1197,"I do. I love bright colors"],[1197,1288,"and everything like that."],[1288,1530,"So, I will go show it to you right now."],[1539,1647,"Oh, wonderful!"],[1872,2035,"How did you produce such a..."],[2043,2127,"It's rare!"],[5067,5276,"Oh my God! Chance, Charity!"],[5434,5568,"Someone call an ambulance!"],[5647,5784,"Okay, okay."],[5897,5989,"Okay, okay."],[6064,6168,"Help! - Oh my God, Chance!"],[6352,6439,"Charity, oh my God."],[6452,6623,"I know what happened. Now, follow me."],[6631,6740,"Can you save my babies, please?"],[6748,6840,"Yes, I know your husband."],[6840,6969,"Come with me."],[7995,8183,"It was a severe allergic reaction."],[8183,8254,"I mean,"],[8266,8316,"good thing you brought them"],[8316,8366,"here in time,"],[8366,8458,"because it could have been"],[8458,8554,"a whole lot worse."],[8633,8762,"They're allergic to mango,"],[8762,8883,"did you not know that?"],[8942,9125,"No, I had no idea. This is all my fault."],[9134,9238,"Oh my God. I'm so-"],[9238,9355,"You know what? Um..."],[9421,9517,"Just..."],[9647,9701,"Take this."],[9701,9834,"I don't care how much it costs."],[9834,10014,"Just, I want the best for them, please."],[10080,10151,"Okay."],[10231,10289,"I will."],[10306,10389,"Thank you."],[10748,10894,"Come on."]],"33":[[196,329,"How are the kids? Are they alright?"],[329,458,"They are gonna be fine."],[458,604,"They just need a good night's rest"],[604,725,"and some meds for the next few days."],[725,809,"I promise."],[809,909,"How about Cassandra?"],[909,980,"How's she doing?"],[996,1088,"She is shaping up"],[1088,1230,"to be more of a parent than you are."],[1263,1326,"But,"],[1363,1522,"I don't think she's after your money."],[1543,1701,"So just go in there"],[1701,1822,"and tell her the truth."],[1868,2043,"Now. You got it."],[2865,3007,"Chance."],[3032,3153,"Chance!"],[4095,4258,"I was just tying my shoe."],[4425,4587,"Yeah. You can go back to bed."],[4713,4888,"Hey, I'm..."],[5009,5188,"I'm so sorry."],[5305,5388,"This is my fault."],[5388,5513,"I should have been more careful."],[5513,5572,"I know that."],[5572,5705,"I'm literally allergic to mango"],[5705,5864,"and I didn't know that they were,"],[5864,6005,"but I should have thought."],[6005,6118,"I should have been thinking"],[6118,6206,"and I'm so sorry-"],[6206,6473,"No, Cass. Don't worry about it."],[6473,6631,"Seriously, you didn't know."],[6631,6865,"It's my fault for not telling you."],[6956,7119,"What happened to your arm?"],[7152,7261,"It's nothing. It's a scratch."],[7261,7411,"I got it on the way over here, I think."],[7411,7507,"I don't even know."],[7507,7624,"No, we're already here."],[7624,7741,"Let's get it taken care of. Joel!"],[7757,8033,"Stop! Spend another $300? No!"],[8091,8212,"We have neosporin at home."],[8212,8362,"Cass, why are you so selfless?"],[8441,8546,"It's the kids."],[8717,8908,"I don't know. Ever since I met them,"],[8908,9046,"I just felt like this instinct"],[9046,9154,"to protect them."],[9238,9330,"I think it's because"],[9330,9421,"I grew up without a mom,"],[9421,9522,"and I just, I really don't want them"],[9522,9663,"to have to go through what I did."],[9688,9751,"You know?"],[9801,9909,"Cass."],[10022,10122,"There's something I need to..."],[10143,10306,"I've been meaning to tell you."],[10435,10573,"About who I really am."]],"34":[[158,291,"I'm actually like, really famous."],[412,592,"Like, newspaper headlines,"],[592,759,"magazine covers."],[775,934,"Wikipedia page type famous."],[934,1105,"God, I knew this was too good to be true."],[1105,1255,"Don't tell me you're like a felon"],[1255,1397,"or an ex-con or something, right?"],[1422,1476,"What?"],[1476,1568,"Oh my God, that's why"],[1568,1705,"your ex moved to another country."],[1960,2097,"Seriously, Cass?"],[2189,2248,"Oh no."],[2273,2369,"What, you think I'd really"],[2369,2494,"be walking around like this"],[2494,2602,"if I was a felon?"],[2602,2715,"Cass, are they okay?"],[2715,2852,"I came as quickly as I could."],[2861,2961,"Thanks so much for coming."],[2961,3057,"Yeah, yeah, they're fine."],[3057,3169,"Thank you for being here."],[3178,3282,"Oh, okay."],[3357,3411,"Well, guess what?"],[3411,3516,"I did some digging."],[3549,3670,"Okay, turns out that YS House"],[3670,3787,"you just got hired at?"],[3799,4037,"It's owned by Steinmal Enterprises."],[4058,4229,"Yeah, that Steinmal!"],[4229,4433,"Like, Killian Steinmal."],[4587,4679,"Why the tone?"],[4729,4946,"He is public enemy number one."],[4954,5071,"I don't know if Cass told you-"],[5080,5176,"Hold on, hold on, hold on,"],[5176,5342,"hold on, hold on just a second."],[5417,5551,"Isn't Killian Steinmal..."],[5680,5930,"The biggest bachelor in all of Winchester?"],[5980,6106,"He's hot."],[6185,6356,"Handsome, philanthropist-"],[6356,6569,"Yeah, that's all for PR, okay?"],[6569,6673,"You don't know the half"],[6673,6748,"of what he's done."],[6748,6915,"Abby, I don't want to think about..."],[6940,7015,"that."],[7240,7349,"Anyway, sorry,"],[7349,7457,"what were you about to say?"],[7540,7686,"I..."],[7753,7853,"You know what?"],[7853,7991,"Don't, don't worry about it."],[8045,8137,"I'm actually..."],[8162,8279,"I'm just gonna head out, I need to catch"],[8279,8437,"a breath of fresh air, okay?"],[8512,8616,"I'll be back."],[8779,8888,"Okay, well spill it!"],[8908,9142,"Was he about to confess?"],[9280,9346,"Okay."],[9376,9530,"I don't know, but I think he was"],[9530,9680,"about to kiss me, earlier."]],"35":[[454,633,"Turn that crap off, man."],[834,1034,"I need you to help me with something."],[1117,1226,"I need you to figure out"],[1226,1426,"why Cassandra hates Killian Steinmal."],[1451,1622,"And why is this suddenly my issue?"],[1622,1697,"I'm busy."],[1722,1860,"Piss off, Joel. I'm not like you."],[1951,2110,"Sure, man. Sure."],[2122,2223,"You know, the irony is,"],[2223,2394,"is that there are so many people"],[2394,2464,"that would kill to be"],[2464,2548,"in her shoes right now."],[2556,2677,"And you just happen to be"],[2677,2790,"with the one person"],[2790,2923,"who can't stand the real you."],[2923,3078,"So make sure your story's straight,"],[3078,3178,"William Stein."],[3753,3870,"You know, they kind of look like you"],[3870,3983,"when you were little?"],[4300,4408,"How old are they again?"],[4796,4909,"Seven."],[5263,5476,"And their birthday"],[5476,5768,"matches exactly, so..."],[6151,6327,"Fate's cruel like that sometimes."],[6473,6535,"Yeah."],[6581,6685,"I guess so."]],"36":[[300,588,"Cass, stop drawing whatever crap that is"],[588,734,"and deliver this immediately."],[759,846,"It's for the CEO."],[921,1034,"The CEO?"],[1184,1343,"You mean Killian Steinmal?"],[1393,1534,"Aw, Cass! Don't tell me"],[1534,1714,"you're already trying to suck up up to him."],[1743,1876,"It's never going to happen."],[1910,2001,"The guy doesn't date,"],[2060,2223,"especially not washed up losers"],[2223,2352,"like you."],[2369,2531,"Just get this to him safely, okay?"],[2540,2656,"It's an auction piece."],[2702,2815,"Screw it up and you're done."],[3199,3382,"Kissing up to Killian Steinmal."],[3574,3716,"If it wasn't my job,"],[3716,3874,"that painting would be in a ditch somewhere."],[3883,3953,"That's where that would be."],[3953,4054,"Oh, yeah."],[4141,4254,"Screw it."],[4279,4387,"Screw that guy."],[4387,4496,"God!"],[5121,5309,"That's weird."],[5334,5522,"I could've sworn I didn't hit him."],[5822,6076,"Oh, my head, oh!"],[6385,6489,"Why'd you hit me?"],[6535,6735,"This is paint."],[6861,7165,"Oh my God! This man is faking right now!"]],"37":[[133,387,"Ow, my leg! Oh, my knee's broken."],[408,571,"My leg. I think it's broken."],[571,688,"Oh, your leg. Oh my God."],[688,796,"Yeah."],[800,1005,"Ooh, I'm sorry. Do you need an ambulance?"],[1005,1126,"Let me call an ambulance for you."],[1126,1226,"Yeah."],[1384,1476,"Yeah, that'd be great. -Yeah?"],[1476,1559,"Thanks. - Give me your phone."],[1559,1701,"Sorry about that. - Ow ow ow."],[1701,1843,"I'll take a picture for insurance too."],[1843,1989,"Thank you. - Yeah."],[2022,2089,"Hey!"],[2102,2223,"Hey, hey-hey! What the fuck?"],[2231,2306,"That was my phone."],[2323,2377,"Yeah."],[2894,3119,"That's what I thought, scammer."],[3549,3712,"Hm."],[4116,4350,"Babe. Babe, you're never going to guess"],[4350,4487,"what just happened."]],"38":[[50,187,"Killian, you're married?"],[246,383,"Why didn't you say anything?"],[392,684,"Sweetheart, we were so worried about you."],[717,880,"I mean, you never dated."],[880,971,"And the only person"],[971,1146,"you were close to was Jules."],[1146,1251,"So we thought-"],[1251,1409,"And you never once said anything"],[1409,1501,"about the twins' mom"],[1501,1626,"and now you're suddenly married?"],[1630,1926,"Oh, Pete, we have to do something for them."],[2010,2189,"So, how long have you two been together?"],[2252,2385,"Have you planned a honeymoon?"],[2406,2540,"You know, we still have"],[2540,2715,"that gorgeous resort in Bali."],[2723,2948,"Or in Paris. Or Italy."],[3044,3161,"We literally just bought"],[3161,3340,"our seventh vineyard."],[3415,3624,"Daddy, it's mommy!"],[3858,3953,"Oh, Killian, wait, wait, no!"],[3966,4149,"We're not really dressed for this."],[4149,4362,"I need to put on makeup and change."],[4379,4483,"No, no, no, no, no."],[4517,4708,"Mom, Dad, you need to stop."],[4708,4913,"She thinks I'm Will Stein."],[4913,5059,"Killian Steinmal's driver."],[5059,5184,"You lied to her?"]],"39":[[45,171,"You lied to her?"],[212,479,"Killian, marriage is built on trust."],[500,713,"Save the lecture, Dad. Okay?"],[775,900,"You two need to change."],[938,1005,"Please?"],[1284,1393,"Parents to the rescue?"],[1459,1576,"Parents to the rescue."],[2360,2631,"Okay. I guess no one's home."],[3053,3199,"Mommy! - Mommy!"],[3261,3357,"Whoa!"],[3461,3607,"Uh, Will."],[3724,3799,"Kids?"],[3858,3987,"You look pretty."],[4133,4308,"What're you doing here? Isn't this..."],[4421,4704,"Isn't this Killian Steinmal's house?"],[5192,5317,"Mm hm."]],"40":[[41,183,"So what you're saying..."],[212,412,"is you're his chauffeur"],[475,571,"but your entire family"],[571,688,"works for the Steinmals?"],[688,775,"Correct."],[775,930,"So mad when I insulted him."],[1105,1301,"Uh, Will..."],[1380,1555,"Are they..."],[1555,1851,"Yeah, this is my mother, Sarah."],[1889,2010,"She's the nanny"],[2010,2089,"and the housekeeper."],[2089,2202,"She's raised..."],[2248,2423,"three generations of Steinmals."],[2435,2615,"This is Peter, this is my father,"],[2656,2882,"he's a gardener."],[2882,3065,"Wow, I was not expecting"],[3065,3194,"to meet your parents today."],[3244,3420,"Uh, hi, I'm Cassandra."],[3470,3657,"So nice to meet you, I am Will's wife."],[3749,3949,"Oh, Pete! She said wife!"],[3949,4133,"She really is his wife!"],[4275,4379,"Don't worry about them."],[4379,4496,"They are just very excited"],[4496,4637,"that I decided to settle down."],[4654,4788,"Oh, Cassandra, we're so happy"],[4788,4909,"for the two of you."],[4909,5125,"Come with me. I have something for you."],[5125,5196,"Oh!"],[5259,5351,"What is this?"],[5359,5488,"It's a gardening outfit,"],[5497,5626,"and a gardening broom."],[5647,5793,"I've never used one of these before."],[5839,5964,"This is the best you could come up with?"],[6026,6151,"Do you wanna check on this?"],[6177,6222,"Yes."],[6222,6302,"Come on."],[6339,6402,"Stop."],[6435,6723,"Cassandra, I have something for you."],[7190,7424,"This has been in the Steinmal family"],[7424,7557,"for generations."],[7578,7736,"Now it's yours."],[7995,8066,"You know,"],[8066,8233,"this is a Steinmal family heirloom."],[8233,8433,"I can't take this. That's too much."]],"41":[[87,329,"This has been in the Steinmal family"],[329,504,"for generations."],[617,763,"Now it's yours."],[763,859,"Mom!"],[896,1071,"I know you and Mrs. Steinmal"],[1071,1267,"are good friends,"],[1288,1447,"but you can't just be handing her stuff out"],[1447,1543,"to everyone."],[1576,1701,"Put it back."],[1789,1926,"Back."],[2256,2414,"So, Cassandra."],[2506,2635,"What do you do?"],[2702,2865,"I work at YS House."],[2923,3007,"Uh, it's actually"],[3007,3128,"part of Steinmal Enterprises."],[3136,3261,"I'm a designer's assistant."],[3340,3528,"An assistant? Killian!"],[3641,3732,"I mean..."],[3745,3837,"William."],[3928,4062,"You can do better than that."],[4104,4241,"She should have her own line."],[4241,4304,"We can give her"],[4304,4425,"one of the other fashion houses."],[4433,4537,"Make it hers."],[4633,4746,"Give me a what now?"],[5117,5292,"Dad, you're so funny."],[5355,5467,"Sorry about that, Cass."],[5488,5689,"That was just a joke. You know how dads are."],[6031,6118,"Right."],[6202,6381,"Yeah, sure I do, yeah."],[6710,6848,"So, where do you guys stay?"],[6848,7002,"Do you live here? Or..."],[7161,7215,"We... - We..."],[7215,7365,"live in the basement. - live in the attic."],[7365,7394,"We..."],[7394,7553,"live in the attic. - live in the basement."],[7640,7791,"It's very avant garde."],[7828,8128,"It's kind of a basement attic thing."],[8224,8391,"It's a family affair."]],"42":[[154,437,"Yeah, so this is where I grew up."],[563,738,"There used to be a bed right here"],[738,900,"but now we use it for storage."],[1067,1180,"I mean, I get it."],[1180,1338,"It was the same for me growing up."],[1480,1701,"We're going to make it, Will."],[1805,1935,"Tell your parents we're gonna"],[1935,2185,"get them a house with a big yard."],[2385,2619,"Nobody should live like this."],[2723,2894,"You're so sweet, Cass."],[3132,3278,"Cassandra."],[3307,3420,"Mr. Steinmal..."],[3420,3582,"I just got back with everything."],[3582,3716,"Beef Wellington tonight?"],[3724,3916,"Mr. Steinmal?"]],"43":[[8,191,"Mr. Steinmal?"],[696,863,"There's that laugh again."],[938,1067,"You're so funny."],[1067,1126,"You know,"],[1126,1338,"when the Steinmals are out of the house,"],[1338,1501,"me and the rest of the staff"],[1501,1609,"love to joke around."],[1609,1685,"No, I know."],[1685,1835,"That seems to be a recurring joke."],[1843,1968,"I get it though. I totally do."],[1976,2131,"Sometimes when I'm alone, I like to pour"],[2139,2356,"myself a glass of wine and lounge."],[2364,2602,"Pretend I'm one of those rich housewives."],[2798,2998,"Oh! Oh, anyways. I almost forgot."],[3011,3157,"The reason I came here. Um..."],[3161,3290,"I came here to bring a painting"],[3290,3403,"to Killian Steinmal."],[3403,3520,"It's an abstract piece."],[3520,3599,"Yes."],[3599,3699,"Yes. Worth like..."],[3699,3849,"Something stupid like a million bucks or"],[3858,4020,"something for a painting, but um..."],[4066,4129,"I'll show you."],[4154,4208,"Okay."]],"44":[[133,250,"Here it is."],[875,1009,"Oh my God."],[1009,1176,"Oh my God. No no no no no..."],[1184,1380,"This was, this was fine when I left the office."],[1380,1443,"I swear."],[1443,1530,"I don't know what hap- Oh my..."],[1530,1639,"It's okay, Cassie."],[1676,1789,"Well, wha..."],[1814,1931,"Well..."],[1956,2031,"Oh, God."],[2331,2435,"Shit."],[2740,2907,"Vanessa, hey..."],[2923,3015,"Well, Cass?"],[3015,3123,"Did you get the painting there"],[3123,3228,"in one piece?"],[3228,3365,"I came here just to make sure you didn't"],[3365,3461,"screw it up."],[3474,3557,"Can you let me in?"],[3557,3674,"Yeah."],[4433,4629,"And the evil witch is back."],[4738,4909,"Oh. You brought"],[4909,5034,"your loser husband with you."],[5075,5226,"Were you two planning on robbing the place"],[5234,5397,"while Mr. Steinmal's gone?"]],"45":[[0,62,"Shut up."],[62,175,"He's a chauffeur."],[254,342,"Yeah, whatever."],[563,709,"Well, Cass, where's the painting?"],[1288,1338,"Cassandra!"],[1463,1597,"I told you to keep this safe."],[1605,1714,"Do you have any idea how"],[1714,1810,"much this piece costs?"],[1897,1968,"You're definitely"],[1968,2072,"getting fired for this."],[2097,2235,"Mind your manners, young lady."],[2277,2369,"I don't want you yelling"],[2369,2469,"in my house."],[2502,2585,"Excuse me?"],[2585,2694,"Your house?"],[2744,2894,"Who the hell do you think you are?"],[2902,3048,"She's the Steinmals' nanny"],[3048,3190,"and housekeeper."],[3199,3365,"She's been with this family for decades."],[3390,3461,"Show some respect."],[3624,3770,"Another lowly servant."],[3828,3908,"Great."],[4016,4116,"Well, Cass, that painting"],[4116,4208,"was ten million."],[4254,4412,"How are you going to pay that back?"],[4441,4525,"She won't."],[4562,4671,"This painting's fake."],[4746,4829,"Shut up, bum."],[4888,4967,"What do you know about art?"],[4979,5063,"I know enough."],[5113,5217,"I know the real painting"],[5226,5384,"is sitting in this house right now."],[5434,5568,"Mom, should we go bring it out for her?"],[5680,5755,"Let's go."],[6473,6564,"How rude."],[6598,6694,"I don't like that girl."],[6723,6923,"How could she yell at Cassandra like that?"],[6931,7006,"Later. We need to get"],[7006,7178,"Cassandra's painting taken care of now."],[7253,7344,"Look at you."],[7353,7515,"All doting and sweet."],[7565,7636,"Look at you."],[7636,7724,"All doting and sweet"],[7724,7836,"over your daughter-in-law."],[8199,8333,"You haven't picked up a paintbrush in years,"],[8333,8412,"have you?"],[8412,8600,"Good thing an artist never forgets."]],"46":[[880,1000,"This is the real painting."],[1151,1205,"What?"],[1288,1334,"How?"],[1359,1472,"Bringing a fake painting"],[1472,1568,"into Killian Steinmal's"],[1576,1710,"house, one that he already owns."],[1735,1843,"You should be thanking Cassandra,"],[1843,1910,"your client's"],[1918,1997,"could've gotten in"],[1997,2068,"serious trouble for this."],[2369,2535,"You won't be so lucky next time."],[3211,3303,"I'll help you appreciate"],[3303,3370,"your inner light."],[3474,3620,"And love yourself as I love you."],[3883,3953,"Daddy,"],[4070,4316,"isn't it curious how many things"],[4325,4479,"went bad in mommy's work?"],[4554,4708,"Me and Charity thought about it."],[4758,4959,"I think it's more than just an accident."],[6468,6573,"I'm gonna talk to the company."],[6581,6685,"I'll make sure she gets fired."],[6698,6773,"No."],[6773,6873,"Don't."],[6990,7215,"She's my sister, I'll handle it."]],"47":[[12,141,"Vanessa Mortensen."],[196,250,"Oh?"],[296,367,"What?"],[525,588,"Oh!"],[654,709,"What the-"],[738,763,"Oh!"],[846,1000,"Cassandra, have you lost your mind?"],[1026,1071,"Me!"],[1130,1238,"I'm the crazy one?"],[1267,1447,"It has been seven years!"],[1501,1714,"Vanessa, why can't you just leave me alone?"],[1751,1830,"Because the world deserves"],[1839,2014,"to know how pathetic you are."],[2039,2106,"Is that it?"],[2260,2360,"Or are you just scared?"],[2444,2606,"Scared of what I can become."],[2861,2952,"Scared of who I am."],[3153,3336,"Face it, Vanessa, at the end"],[3336,3436,"of the day you're just"],[3445,3582,"jealous because you are nothing"],[3591,3799,"more than the other woman's kid."],[3999,4062,"Really?"],[4170,4304,"And you think I'm jealous of you?"],[4458,4629,"You're a weak, pathetic bitch"],[4637,4800,"who's always begging for love."],[4888,5025,"Too bad dad doesn't love you."],[5092,5271,"Your baby daddy doesn't love you."],[5288,5413,"And your stupid, dead babies"],[5413,5580,"never will either."],[5597,5680,"Don't you dare"],[5709,5843,"talk about my babies!"],[6060,6202,"News flash, Cass."],[6218,6335,"The twins are alive."],[6402,6535,"And you're never gonna find them."]],"48":[[421,679,"So, any background on Cassandra?"],[759,1038,"Mr. Steinmal, it's awful."],[1180,1284,"Ms. Steinmal's mother died"],[1284,1380,"when she was young,"],[1476,1555,"and her father did okay"],[1555,1639,"with his business,"],[1664,1901,"but all his money has gone to"],[1910,2039,"his new wife and their daughter."],[2114,2202,"From what I can tell,"],[2268,2444,"she's been an outsider her entire life."],[2719,2848,"They're not good people, Sir."],[3349,3478,"You said Mortensen, right?"],[3541,3645,"Didn't they want in with"],[3645,3732,"Steinmal Enterprises?"],[3791,3903,"They reached out to you,"],[3903,3995,"but you rejected them."],[4045,4266,"Huh. Call him again."],[4341,4462,"Set up a meeting for tomorrow"],[4471,4604,"at 2 pm at the Apex Club."],[4612,4721,"I'll deal with them personally."],[4859,4938,"Yes, sir."]],"49":[[216,275,"Mom!"],[279,446,"Look what Cassandra did to me this time!"],[479,575,"You have to punish her!"],[608,817,"Oh my God, that crazy bitch!"],[875,1038,"I'll tell your father about this."],[1088,1222,"How dare her hurt my baby."],[1614,1685,"Really?"],[1714,1893,"Drinking on a week night again?"],[1931,2022,"What now?"],[2052,2281,"No, no, no, no, no, I'm celebrating!"],[2394,2489,"Vivian."],[2510,2656,"We closed the deal with"],[2656,2781,"Steinmal Enterprises."],[2844,2986,"We're going to their private club,"],[2986,3048,"all of us."],[3174,3249,"Really?"],[3282,3428,"Ah, Vanessa, did you hear that?"],[3465,3611,"You have to make a good impression."],[3666,3824,"Go put on your best dress."],[3874,4024,"You're going to knock him dead."],[4058,4204,"Oh, Mom, of course!"],[4279,4404,"I'll tell him all about"],[4404,4529,"William and Cassandra."],[4583,4763,"Their careers are over."],[4975,5092,"I love you guys."],[5238,5417,"Dad, seriously? Get a mint."],[5426,5563,"Uh, yeah."]],"50":[[266,362,"Did you bring the wine?"],[383,554,"Don't worry, Dad, I've got it."],[604,775,"We have to make a good first impression."],[1059,1238,"Honored to meet you, Mr. Steinmal."],[1493,1618,"Wrong guy, Dad."],[1643,1839,"That's Cassandra's husband, William,"],[1860,1935,"the loser."],[1972,2139,"He's the Steinmal's driver."],[2268,2394,"Ugh, what is his"],[2394,2506,"chauffeur doing in here"],[2519,2640,"hanging out with the guests?"],[2652,2723,"Ugh."],[2827,2932,"We brought some wine."],[2973,3148,"Open it up before he gets here."],[3774,3874,"Cheap label."],[4045,4099,"No need."],[4133,4233,"How dare you!"],[4320,4466,"I'm an honored guest of"],[4466,4550,"Mr. Killian Steinmal."],[4637,4750,"His assistant, Horace,"],[4763,4938,"personally handed me an invitation."],[5013,5125,"You'd better watch your mouth."],[5221,5367,"Dad, don't waste your time on him."],[5434,5526,"He'll be regretting it"],[5534,5701,"once he's jobless and homeless"],[5709,5805,"within the next hour."],[5935,6014,"Oh, really?"],[6168,6214,"I'll wait."],[6506,6823,"Horace, when's Mr. Steinmal arriving?"],[6927,7040,"We brought some great wine."],[7194,7286,"Mr. Steinmal?"],[7440,7536,"He's sitting right there."],[7866,8053,"Allow me to formally introduce myself."],[8345,8458,"I am Killian Steinmal."],[8566,8671,"Cassandra's husband."],[8754,8817,"What?"],[8871,8954,"You're a liar!"],[8958,9092,"Hey, hey, hey, sit."],[9180,9263,"Sit, sit, sit."],[9317,9426,"Or I'll have him throw you out."]],"51":[[546,738,"I'm, I'm really sorry, sir,"],[746,930,"for the confusion earlier, please."],[955,1159,"Oh, no, no, no, no, no, no, no."],[1280,1351,"I'm fine."],[1363,1434,"I'm fine."],[1518,1622,"I'm more worried about how you"],[1630,1768,"three have been treating my wife."],[1918,2114,"I'm sorry Mr. Steinmal."],[2323,2419,"Is that so?"],[2673,2748,"Are you hungry?"],[2823,2865,"Huh?"],[2890,2965,"You hungry?"],[2998,3065,"Here."],[3215,3278,"For you."],[3653,3699,"No."],[3712,3787,"Clean it up and maybe I'll"],[3795,3912,"forgive you for what you've done."],[4116,4233,"Vanessa, is it?"],[4254,4375,"Are you too good to clean that up?"],[4491,4667,"Oh, are you not hungry anymore?"],[5038,5105,"I mean how do you think"],[5105,5167,"Cassandra felt"],[5176,5288,"her entire life?"]],"52":[[0,103,"How do you think Cassandra felt"],[110,223,"her entire life?"],[316,383,"That's different."],[453,640,"Sir, you can't expect my daughter to-"],[660,786,"Oh, are you going to pick it up?"],[906,1083,"Please, sir, just let us go."],[1270,1370,"Vanessa won't do it again."],[1396,1440,"Isn't that right-"],[1456,1556,"Victor, Victor, Victor."],[1650,1786,"More empty promises."],[1943,2096,"You're finished here in Winchester."],[2146,2236,"What do you mean?"],[2246,2313,"My company?"],[2320,2436,"Yeah, your company."],[2480,2530,"Finished."],[2626,2690,"Check the news."],[2873,3026,"Yeah, I want you three out of the state."],[3213,3300,"In your own words,"],[3300,3413,"you guys are all three now,"],[3423,3523,"jobless and homeless."],[3893,3993,"And, uh,"],[4136,4216,"one more thing."],[4240,4366,"Any of you even utter a word"],[4373,4523,"about my identity to my wife,"],[4550,4740,"then they're going to be"],[4740,4893,"paying you a visit."],[5256,5370,"Nice suit, Victor."]],"53":[[704,834,"I need to talk to you."],[913,992,"Same place."],[1046,1151,"I'll meet you there in thirty."],[1601,1705,"I need a favor."],[1722,1830,"Remember the woman with the baby"],[1839,1914,"seven years ago?"],[1943,2185,"That skank somehow landed a rich CEO."],[2210,2377,"Now I really want to ruin her."],[2423,2489,"Rich."],[2527,2598,"How rich?"],[2640,2802,"Killian Steinmal rich."],[2857,2965,"No way."],[3073,3174,"Killian Steinmal?"],[3365,3474,"How could they have even-"],[3607,3691,"If Steinmal finds out"],[3691,3824,"we pawned off her twins-"],[3866,4070,"What? There's no twins, OK?"],[4079,4162,"As far as she's concerned,"],[4162,4258,"they're dead."],[4279,4375,"And you're not going to"],[4375,4479,"say anything about it."],[4533,4662,"But I already told her."],[4696,4896,"By accident, it just slipped out."],[4904,5067,"But you can still help me, right?"],[5138,5255,"Please, just help me."],[5305,5392,"Shut her up."],[5497,5680,"Make sure she never talks again."],[5743,5801,"No, no, no."],[5809,5935,"Please, you don't have to do that."],[5943,6026,"I won't fuck up again."],[6035,6093,"I swear. Please."],[6160,6181,"Please."],[6197,6314,"Please, no, you-- you want money?"],[6322,6460,"Get off me, bitch!"],[6468,6548,"Please, no. Please, please, please."],[6556,6598,"I swear."],[6606,6698,"Please. I won't do it again."],[6706,6769,"Please."]],"54":[[1463,1530,"General Hospital,"],[1530,1622,"how can I direct your call?"],[1776,1835,"Hi."],[1835,2068,"I am looking for a maternity ward nurse"],[2077,2185,"by the name of Miss Joy."],[2335,2410,"She helped me out when I"],[2419,2531,"gave birth seven years ago."],[2552,2627,"Um..."],[2677,2819,"I just have some questions for her."],[2886,3057,"Miss Joy, she quit right"],[3065,3199,"around that time, seven years ago."],[3378,3603,"Okay, do you have any way"],[3603,3757,"of contacting her?"],[4375,4529,"Do you remember anything at all?"],[4650,4896,"Seven years ago, twins,"],[497