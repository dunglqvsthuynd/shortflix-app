{"1":[[600,721,"Oh my God, did you hear?"],[804,909,"There's supposed to be"],[909,1126,"a mysterious VIP passenger"],[1172,1393,"on the Hawkeye 42's maiden flight today."],[1422,1530,"I heard he's the secret"],[1530,1655,"Maple Airlines investor"],[1655,1797,"everyone's been talking about."],[1805,1885,"He's supposed to be"],[1885,2022,"the richest man in the world."],[2081,2160,"Which seat will he be in?"],[2206,2268,"1A."],[2293,2389,"Oh my God."],[2431,2577,"Can I book him as my sugar daddy?"],[2623,2715,"I'd never have to work again!"],[2740,2890,"Oh please, we all know"],[2890,3061,"that I'm the Marilyn Monroe"],[3061,3178,"of this cabin crew."],[3219,3361,"If anyone's gonna bag this secret"],[3361,3495,"billionaire's attention,"],[3536,3628,"it's me."],[3682,3832,"Well, maybe he's not a boobs guy,"],[3832,3970,"maybe he's an ass guy."],[4888,4979,"Ready, ladies?"],[5000,5117,"Not yet, Evelyn."],[5313,5467,"Well, takeoff is in 30 minutes,"],[5513,5709,"So I would focus more on getting ready"],[5747,5885,"and less on gossip."],[6247,6439,"Why does Evelyn have to be our lead?"],[6439,6548,"She's probably going to try"],[6548,6698,"and bag that secret billionaire"],[6698,6819,"for herself."],[7874,8033,"Welcome, Mr. Jett Hawkings."],[8033,8174,"What's with the spectacle?"],[8174,8316,"I told you I could get here on my own."],[8316,8462,"It's our job to keep you safe, sir."],[8491,8662,"You're our airline's top investor."],[8700,8812,"Sylvia, the whole idea was"],[8812,8946,"for me to disguise myself"],[8946,9100,"as ground crew so I could observe"],[9100,9292,"our airline's service quality."],[9305,9371,"Escorting me"],[9371,9451,"like I'm the goddamn president"],[9451,9522,"of the United States"],[9572,9705,"isn't exactly helping."],[9734,9851,"I apologize."],[9884,10001,"Here's your ticket, sir."],[10497,10694,"Better not see anyone following me."]],"2":[[809,1038,"Welcome aboard Maple Airlines."],[1038,1184,"Sorry for running late, just, you know,"],[1184,1351,"typical LA traffic."],[1910,2164,"That guy is not the VIP passenger."],[2164,2348,"Not a chance. He's nothing but a filthy"],[2348,2481,"grounds crew worker."],[2882,3148,"Excuse me, sir? You can't sit here."],[3265,3370,"And why is that?"],[3432,3591,"This is first class."],[3645,3757,"Economy is back there"],[3757,3878,"in the main cabin."],[3995,4183,"It's okay. I like where I'm sitting."],[4366,4454,"Give me a break."],[4487,4592,"With the dirt rags you're wearing?"],[4733,4884,"I like what I'm wearing."],[4950,5221,"First class is for the social elites,"],[5221,5463,"millionaires and CEOs."],[5518,5689,"But you? You're nothing"],[5689,5860,"but a washed-up grounds crew worker."],[5914,6047,"You belong out there."],[6072,6239,"Handling baggage."],[6297,6456,"Miss, you really shouldn't judge"],[6456,6627,"other people by what they're wearing."],[6669,6773,"Now, if you don't believe me,"],[6773,6969,"you can check the booking records."],[7065,7228,"The booking records will confirm"],[7228,7319,"that this seat"],[7319,7419,"is reserved for our most"],[7419,7590,"distinguished passenger."],[7636,7811,"Maple Airlines' top investor."],[7991,8133,"That's exactly right."],[8224,8350,"Oh, when you get a chance,"],[8350,8516,"I would love a cup of coffee."],[8541,8696,"Just black. Thanks."],[8963,9205,"Tyler! Get over here!"],[9405,9601,"We have a low-life grounds crew worker"],[9601,9688,"who snuck on the plane"],[9688,9801,"without a ticket."],[9855,9968,"What did you just call me?"],[10005,10114,"He's sitting in first class"],[10114,10310,"and refusing to leave."],[10410,10514,"Chill out, Claire."],[10539,10673,"I'll take care of it."],[11148,11290,"Hey, you ordered the coffee, right?"],[11311,11378,"I did."],[11415,11482,"Thanks!"]],"3":[[1238,1334,"Fucker!"],[1363,1518,"That is why we don't serve coffee"],[1518,1643,"to minimum wage dirtbags!"],[1676,1764,"Well, you tried to spill"],[1764,1901,"the coffee on me first."],[1918,2085,"Where are your manners?"],[2085,2268,"That's it. Enough playing games."],[2268,2369,"Where is your ticket?"],[2398,2527,"Word of advice:"],[2569,2719,"ask nicely next time."],[3478,3607,"Where's my ticket?"],[3691,3766,"Doesn't look like"],[3766,3908,"there will be a next time."],[3933,4166,"See this, folks? Just another wannabe"],[4166,4366,"trying to scam his way into first class."],[4387,4529,"Just kick him off the plane."],[4529,4654,"Shh. We got this. Thank you."],[4654,4750,"Time's up, buddy."],[4767,4938,"Listen. I have a ticket."],[4938,5063,"How else would I have gotten"],[5063,5130,"on the airplane?"],[5130,5238,"I mean, look at this."],[5246,5347,"You have, single handedly,"],[5347,5467,"turned First Class"],[5467,5643,"into a first-grade Junkyard!"],[5643,5709,"You are the one who tried"],[5709,5800,"to spill coffee on me."],[5800,5904,"\"You're the one who tried to-\""],[5904,5964,"No, listen."],[5964,6122,"This is gonna be one of two ways."],[6151,6385,"Either you lick this shit up,"],[6423,6589,"or I'll have airport security"],[6594,6781,"remove you from this plane."],[6873,7203,"Got it, Mr. \"Ask me nicely\"?"],[7265,7457,"And you think airport security's gonna"],[7457,7665,"listen to you over me?"],[7778,7912,"Of course they will."],[7941,8141,"FAA regulations state when you enter a"],[8141,8237,"vessel that is larger"],[8237,8383,"and heavier than air,"],[8383,8646,"and has wings, right, with an engine"],[8666,8850,"that propels you into the sky,"],[8850,8975,"we are in charge."],[8983,9125,"So, yes."],[9138,9280,"Who the hell do you think you are?"],[9321,9459,"I own this airline."]],"4":[[25,70,"That's it."],[70,175,"Enough playtime. Let's go."],[175,258,"Get out."],[1126,1251,"And who do you think you are"],[1251,1351,"to touch me?"],[1564,1685,"You..."],[1743,1910,"You're like a ninja or something?"],[1910,2052,"That's it. We gotta get him out of here."],[2056,2193,"I'm calling airport security."],[2214,2318,"This flight attendant is"],[2318,2435,"assaulting a passenger."],[2515,2619,"And Maple Airlines say they've"],[2619,2781,"best service in the industry."],[2952,3082,"Give me that phone."],[3082,3261,"That video needs to be deleted."],[3294,3415,"Not a chance."],[3415,3541,"The public deserves to know"],[3541,3666,"about your abusive service."],[3695,3749,"She's right."],[3749,3908,"This needs to be documented."],[4008,4137,"Delete that video..."],[4241,4354,"or you'll all be banned"],[4354,4504,"from Maple Airlines."],[4504,4646,"For life!"],[5163,5330,"Ma'am. You have to see this."],[5647,5747,"What on earth?"],[5809,5930,"Contact the pilot for that flight"],[5930,6051,"and tell them to delay takeoff."],[6093,6197,"I'm going on board."]],"5":[[0,108,"You don't understand."],[196,342,"That man snuck on board"],[342,433,"without a ticket."],[442,558,"He's a stowaway."],[575,667,"That's right, folks."],[667,829,"For all we know, he could be"],[829,1005,"trying to hijack this plane."],[1038,1217,"Ok? This is for your own safety."],[1217,1317,"He's been pulling our leg"],[1317,1413,"this whole time?"],[1443,1518,"Kick him out."],[1526,1693,"Yeah, fuck that guy."],[1722,1860,"Ah, the last thing I need is some hobo"],[1860,1989,"derailing my travel plans."],[2106,2206,"Attention passengers."],[2235,2293,"Welcome aboard"],[2293,2531,"Maple Airlines Flight 451."],[2581,2623,"Due to some"],[2623,2773,"unforeseen circumstances,"],[2777,2919,"we're going to be delaying takeoff."],[2977,3057,"But hang tight."],[3061,3165,"We'll be in the air shortly."],[3194,3349,"We really appreciate your patience."],[3440,3532,"God damn it."],[3545,3595,"This fucking"],[3595,3724,"ticketless fuck is going to make me"],[3724,3845,"miss my connecting flight."],[3883,4062,"Somebody call airport security."],[4091,4191,"What a shit show."],[4220,4383,"This guy should be kicked out to TSA."],[4479,4650,"Calm down."],[4763,4967,"Ladies and gents, I have a ticket."],[4992,5067,"Okay?"],[5392,5559,"If you can't show us the ticket,"],[5580,5718,"then you can't be on this flight."],[5851,5955,"It's time to go."],[6222,6410,"Keep your hands off my property."],[6498,6756,"Sorry, but we're at capacity."],[6756,6931,"No room for dead weight like you."],[6952,7032,"Dead weight?"],[7152,7378,"Oh, I think you two are the dead weight"],[7378,7590,"on my property."]],"6":[[58,150,"What property?"],[175,396,"You're poor, your property is trash."],[538,600,"I'm warning you."],[784,984,"Which is why this"],[984,1184,"is going out the window."],[2877,3044,"How would a dirt poor laborer like you"],[3044,3165,"even afford a guitar?"],[3303,3440,"You probably stole it"],[3440,3549,"from one of the passengers."],[3858,3991,"This was a gift"],[4124,4346,"from my late wife."],[4412,4629,"Maple Airlines is named after her."],[4700,4867,"Do you realize whose honor"],[4867,4988,"you've disgraced?"],[5038,5305,"Sure, a lot of people are named Maple."],[5326,5488,"You can claim whatever you want,"],[5530,5689,"doesn't change the fact that you"],[5755,5897,"and this piece of junk"],[5897,6031,"belong in the garbage."],[6189,6327,"Well, one thing's for sure."],[6377,6577,"This guitar is nowhere near as valuable"],[6594,6719,"as all of the time we have wasted"],[6719,6877,"trying to get you off this flight."],[6952,7082,"The sooner this guitar"],[7082,7240,"gets smashed, the better."],[7319,7457,"See, we're doing you"],[7457,7607,"a favor by smashing it-"],[7607,7757,"Don't you dare!"],[8028,8120,"Look, I don't care...."],[8183,8287,"who any of you are."],[8358,8475,"Do you want money?"],[8529,8829,"I have plenty, but more than that,"],[8925,9134,"who I am makes me a"],[9134,9380,"nightmare for people like you."],[9730,9822,"Airport security?"],[9859,10055,"I've got a passenger stirring up trouble"],[10055,10285,"in Maple Airlines flight 451."],[10306,10497,"Yes, send someone now."],[10606,10723,"Are you threatening us?"],[10735,10898,"We work for Maple Airlines,"],[10956,11136,"owned by the richest man"],[11136,11315,"in the world, Jett Hawkings."],[11369,11536,"You are so dead."],[11553,11682,"I'm Jett Hawkings."],[11711,11832,"Wait till these dimwits find out"],[11832,11941,"I'm their boss."]],"7":[[41,208,"This guitar better not be broken."],[262,383,"Because if it is..."],[396,492,"You'll what?"],[525,671,"Beg me for money to buy a new one"],[671,767,"because you can't afford it"],[767,980,"on your dirt-poor salary?"],[1255,1376,"I won't be the one begging."],[1505,1559,"You will."],[1647,1772,"Who's the one stirring up trouble?"],[1805,1910,"That man with the guitar!"],[1947,2127,"He snuck on board without a ticket"],[2127,2285,"and he threatened a flight attendant."],[2327,2489,"Sir, I'm gonna have to ask you"],[2489,2660,"to take your hands off the guitar case."],[2681,2844,"He could be hiding a bomb in there."],[2919,3111,"Maybe he's trying to blow up the plane."],[3136,3299,"Oh my God, quick! Check the case!"],[3311,3470,"Hurry up before we all die!"],[3516,3661,"Sir, I'm not gonna ask twice."],[3728,3853,"Get your hands off the case."],[4029,4216,"None of you hold rank high enough"],[4216,4358,"to search my belongings."]],"8":[[0,154,"He's nothing but a"],[154,329,"bottom-feeding ground staff!"],[354,575,"We're all literally leagues above him."],[725,871,"If you would like to see"],[871,1017,"my late wife's handiwork,"],[1096,1284,"I would gladly open my case"],[1288,1434,"and show you all."],[1455,1618,"Don't fall for it! It's a trap!"],[1651,1760,"Don't fucking trust him!"],[1760,1881,"He's a terrorist!"],[2677,2811,"What's all this fuss about?"],[2852,2932,"Ma'am..."],[3832,4120,"Sir, I'm Evelyn, lead flight attendant."],[4179,4308,"Here at Maple Airlines,"],[4308,4416,"we take the proper handling"],[4416,4554,"of our passenger's belongings"],[4554,4679,"very seriously."],[4717,4884,"And I can assure you nothing else"],[4884,5021,"will happen to your guitar."],[5188,5347,"Isn't she the top lead flight attendant"],[5347,5447,"at our airline?"],[5505,5659,"I'm undercover, so it's best not to"],[5659,5851,"cause a scene, reveal my identity."],[6076,6231,"You seem trustworthy."],[6331,6398,"Unlike..."],[6548,6614,"you."],[8153,8333,"Watch out, Tyler!"]],"9":[[329,475,"This is the customer service"],[475,679,"our airline is so well known for?"],[850,913,"You,"],[950,1101,"judge those beneath you,"],[1130,1305,"when you act like monsters yourselves."],[1359,1443,"My bad."],[1493,1539,"You know,"],[1539,1614,"you're more than welcome to"],[1614,1810,"file a compensation claim for it."],[2064,2168,"Deadline's Friday."],[2214,2398,"But of course the airline's conclusion"],[2398,2552,"may very well be that"],[2552,2802,"the rickety-dink old guitar"],[2836,3007,"might be completely"],[3007,3169,"worthless."],[3203,3332,"That's for you."],[3578,3653,"That's what I thought,"],[3737,3824,"baggage boy."],[5234,5576,"My wife handcrafted this guitar"],[5576,5697,"with exquisite"],[5697,5847,"1980's Cuban mahogany."],[5947,6026,"For me."],[6164,6306,"Let me remind you,"],[6322,6610,"the company you work for,"],[6673,6815,"is named after her."],[6915,7015,"Why’s he so serious?"],[7015,7161,"Is he really related to the owner"],[7161,7269,"of this airline?"]],"10":[[104,258,"She was a saint,"],[287,417,"offering jobs to the homeless,"],[417,533,"giving them a second chance."],[563,646,"But you..."],[663,717,"Get your dirty"],[717,796,"fingers off me, please."],[838,913,"You,"],[959,1109,"arrogant, stuck up pricks,"],[1146,1301,"think you get to decide"],[1326,1447,"who's first class,"],[1497,1593,"who's econ class."],[1605,1743,"But you can't even discern the values"],[1743,1901,"that this company was built upon."],[2068,2122,"You both"],[2139,2248,"are a disgrace to humanity."],[2515,2660,"Security!"],[2677,2773,"Here!"],[2831,2957,"This baggage boy is trying"],[2957,3123,"to kill a flight attendant."],[3169,3440,"Good God! Somebody tackle that man!"],[3474,3632,"Sylvia, I give you ten seconds"],[3632,3828,"to get here. Right now."],[3903,4129,"Sylvia... Stone?"],[4195,4416,"Uh, she's V.P. of Maple Airlines,"],[4433,4625,"only second to Jett Hawkings."],[4679,4813,"God, you just won't stop pretending."],[4813,4884,"God, you just won't stop pretending."],[5067,5317,"When Sylvia Stone gets here,"],[5347,5555,"with my ticket showing who I am,"],[5584,5789,"you'll all cower in fear."],[5805,6043,"Are you all watching this clown show?"],[6106,6260,"This grounds crew worker"],[6260,6468,"couldn't even shine Miss Stone's shoes,"],[6489,6669,"let alone get her on the phone."],[6735,6835,"Don't believe that man!"],[6886,6986,"Throw him out!"],[7002,7082,"Throw him out!"],[7086,7182,"Throw him out!"],[7190,7399,"Throw him out! Throw him out!"],[7407,7607,"Throw him out! Throw him out!"],[7620,7853,"Throw him out! Throw him out!"],[8337,8516,"Did someone piss off my boss?"]],"11":[[0,133,"Oh my God, that's the V.P."],[187,387,"She, like, runs shit here."],[429,571,"Claire is beyond fucked."],[734,784,"Explain this."],[905,1051,"Miss Stone,"],[1051,1197,"this baggage boy"],[1197,1317,"snuck into first class"],[1317,1418,"without a ticket."],[1430,1547,"He's delayed the flight"],[1547,1676,"and we're having him removed."],[1797,1914,"Having him removed?"],[1931,2010,"Is this how you treat"],[2010,2127,"first class passengers?"],[2352,2473,"Take a good look at the nightmare"],[2473,2606,"you've created for us."],[3199,3290,"Great work, everyone."],[3303,3432,"Thanks to you, our company's stocks"],[3432,3603,"have lost over a billion dollars"],[3603,3762,"in the past 20 minutes."],[3778,3916,"Don't blame me!"],[3945,4091,"Blame this fraud"],[4091,4283,"who snuck on board without a ticket"],[4283,4396,"and insisted on sitting"],[4396,4517,"in first class."],[4621,4742,"Who says he doesn't have a ticket?"],[4984,5130,"Sir, you dropped your ticket"],[5130,5259,"just before boarding."],[5380,5572,"I wanted to make sure you received it."],[5751,5847,"So..."],[5847,6076,"you, you're really the chief."]],"12":[[104,387,"So you're really the chief?"],[592,800,"That's what they call me."],[892,963,"Chief."],[988,1159,"The CEO, Mr. Hawkings, only"],[1159,1351,"ever uses his alias on documents"],[1351,1493,"to keep a low profile."],[1580,1697,"Look."],[1793,1918,"First class."],[2010,2177,"Well now that I've proven I belong"],[2177,2310,"in your, oh-so-precious"],[2310,2444,"first class,"],[2460,2635,"not that I care about status,"],[2719,2836,"I do expect reparations"],[2836,2911,"to be made."],[3028,3148,"Reparations?"],[3203,3395,"What the hell did you do to him?"],[3541,3636,"I'm so sorry."],[3657,3878,"I'm so sorry."],[3941,4120,"Sir, I made a mistake."],[4149,4262,"Oh, good heavens."],[4416,4571,"I told you what would happen"],[4571,4742,"if you judge people by their covers."],[4871,5096,"You two broke my wife's guitar."],[5276,5359,"She gave that to me"],[5359,5488,"the day the airline opened."],[5518,5789,"I made a terrible mistake."],[6156,6427,"Sir, I'm so sorry."],[6452,6589,"It's all our fault."],[6614,6781,"No. No, this isn't your fault."],[6794,6877,"You don't have to worry."],[6877,7094,"No, no. I'm their team leader"],[7094,7278,"and I have to take responsibility."],[7294,7411,"Now, this girl Evelyn"],[7411,7520,"has the right kind of leadership"],[7520,7665,"I value in our company."],[7720,7857,"I am friends with the owner"],[7857,8074,"of the best music repair shop in LA."],[8137,8362,"And if you're willing to trust me,"],[8362,8537,"I can ask him to piece"],[8537,8675,"you guitar back together."],[9359,9501,"You dimwits are fired."],[9513,9638,"And I'll see to it that you never work"],[9638,9738,"for another airline company"],[9738,9834,"ever again."],[9880,10122,"Effective immediately, your employment"],[10122,10360,"with Maple Airlines has been terminated!"],[10385,10577,"Please. Give us another chance."],[10581,10673,"Please."],[10719,10827,"No, no, no, no, no."],[10827,10977,"Please, out of my way."],[11006,11123,"Please!"],[11232,11348,"No."],[11361,11528,"No, no."],[11578,11636,"No, no, no, no."],[11636,11749,"Please."],[11749,11932,"Off."],[12032,12162,"Give me another chance."],[12162,12399,"No. Tyler, please. No."]],"13":[[16,246,"I am so sorry about the ordeal, sir."],[325,450,"Please enjoy the rest of your flight."],[508,579,"Thank you, Sylvia."],[1426,1639,"That was intense."],[1647,1839,"If the Chairwoman came to personally"],[1839,1989,"give him his ticket,"],[2014,2310,"that old bag boy might actually be"],[2310,2515,"the mystery VIP passenger."],[2573,2752,"You really think so?"],[2831,3032,"Why would a billionaire be wearing"],[3032,3219,"a ground crew uniform?"],[3278,3520,"Huh. It all makes sense now."],[3570,3666,"That old geezer really"],[3666,3812,"almost had me fooled."],[3891,4058,"What are you talking about?"],[4120,4208,"Ms. Stone only came"],[4208,4371,"because she saw the viral moment."],[4404,4517,"She's here to protect"],[4517,4642,"the airline's reputation"],[4642,4838,"and stop the stocks from plummeting."],[4879,5071,"That's the only reason why she fired"],[5071,5263,"Claire and gave that guy a ticket."],[5313,5634,"There is no way he is the VIP passenger."],[5901,6139,"Welcome aboard, sir."],[6402,6477,"Welcome."],[6477,6635,"Morning. - Morning."],[6723,6919,"Is that Dickson?"],[6919,7052,"Isn't that Maple Airlines'"],[7052,7232,"new General Manager?"],[7257,7578,"Oh, so he's the mystery VIP passenger."]],"14":[[104,421,"So he is the mystery VIP passenger."],[462,563,"Yes, I agree."],[563,750,"That makes way more sense."],[971,1172,"Holy fuck me."],[1230,1372,"What are you two chatting about"],[1372,1451,"over here?"],[1497,1618,"We're getting ready for takeoff,"],[1618,1793,"so you should return to your seats."],[2268,2394,"Ladies and gentlemen,"],[2394,2523,"we are getting ready for takeoff,"],[2523,2665,"Please return to your seats"],[2665,2911,"and fasten your seatbelts. Thank you."],[5125,5288,"Ladies and gentlemen, welcome"],[5288,5526,"to our Maple Airlines Flight 451"],[5526,5659,"with service to John F. Kennedy"],[5659,5780,"International Airport."],[5809,5897,"We have now reached"],[5897,6076,"an altitude of 20,000 feet"],[6076,6268,"and cabin service will begin shortly."],[6268,6423,"Thank you so much for your patience."],[6652,6769,"Fuck me."],[6823,6915,"These flight attendants"],[6915,7002,"just keep getting hotter."],[7011,7136,"Jesus Christ."],[7298,7407,"Mr. Dickson?"],[7432,7469,"Yeah."],[7486,7657,"That's Evelyn Grant, Maple Airlines'"],[7657,7795,"Flight Attendant of the Year."],[7920,8045,"Not only is she beautiful,"],[8070,8229,"she is damn good at her job."],[8249,8458,"Yeah, whatever. Shut the fuck up, okay?"],[8470,8558,"Why don't you do yourself a favor?"],[8558,8683,"Why don't you call her over here?"],[8704,8892,"See how good at her job she really is."]],"15":[[229,329,"Excuse me, miss."],[517,633,"Yes, how can I help you?"],[750,930,"Yeah, my um..."],[963,1197,"my seatbelt's a little tight."],[1226,1372,"You think you can..."],[1426,1618,"You think you could losen it for me?"],[1739,1851,"Of course."],[2339,2419,"Sir?"],[2469,2590,"If you could just"],[2602,2731,"keep still, please?"],[2790,3069,"Yeah, sure, I could do that."],[3374,3611,"Sir, please keep your hands to yourself."],[3624,3728,"Listen close, honey."],[3728,3858,"I'm the General fucking Manager"],[3858,3966,"of Maple Airlines."],[4033,4200,"So if you don't obey my wishes,"],[4216,4316,"you're fucking fired."],[4346,4450,"Oh, fuck."],[4550,4612,"Oh, yeah."],[4654,4696,"Help!"],[4704,4800,"Oh, just so fucking-"],[4800,4925,"Someone help, please!"],[4975,5084,"Help, please, someone!"],[5184,5255,"Fuck!"],[5388,5447,"Since when does being"],[5447,5526,"General Manager"],[5526,5676,"give you the right to sexually harass"],[5676,5764,"your staff?"],[5985,6147,"I'm sorry, but who the fuck are you?"]],"16":[[0,129,"Who the fuck are you?"],[162,246,"Don't change the topic."],[304,375,"I asked you a question."],[479,558,"What makes you think"],[558,663,"you can harass her?"],[667,771,"Look bud,"],[825,950,"you're pushing 60,"],[959,1192,"still lugging around 50 pound bags"],[1192,1330,"for a fucking living."],[1393,1501,"So stop lecturing me"],[1501,1664,"on how to lead my life"],[1664,1897,"and mind your own fucking business!"],[1981,2177,"Anybody who harasses anyone"],[2177,2306,"on my plane,"],[2310,2494,"that is my damn business."],[2535,2610,"You know what, fucker?"],[2677,2798,"Give me the money."],[2973,3082,"Here's $5,000."],[3174,3382,"Now go back to where you belong"],[3382,3503,"and sit next to the toilet"],[3503,3582,"in economy class"],[3582,3670,"where you fucking belong!"],[3828,3974,"Now, that's power, baby."],[3983,4062,"Like that?"],[4070,4133,"I know you want to be"],[4133,4304,"with a real man, like me."],[4350,4479,"God, you look so beautiful."],[4479,4525,"Come here-"],[4671,4817,"Oh my- What the fuck?"],[4959,5100,"If you go back to economy,"],[5117,5280,"I'll give you $500,000."]],"17":[[392,429,"You know who you're"],[429,538,"fucking messing with?"],[554,621,"I do."],[658,813,"I'm messing with a toxic, abusive"],[813,925,"manager who harasses"],[925,1046,"his employees."],[1051,1121,"Wake up, Gramps."],[1130,1188,"You're a fucking"],[1188,1305,"minimum wage worker."],[1317,1547,"Not some heroic crusader for fucking"],[1547,1659,"justice or whatever the fuck"],[1659,1776,"you think you are."],[1826,2089,"Sir, Mr. Dickson,"],[2110,2239,"he's the General Manager."],[2239,2414,"He's very powerful and it's not worth"],[2414,2540,"getting into a fight with him."],[2648,2736,"Powerful man, huh?"],[2736,2819,"Yeah."],[2911,3123,"All I see is a pathetic,"],[3123,3299,"weak, insecure coward."],[3307,3399,"Have you looked at yourself"],[3399,3486,"in the mirror, old man?"],[3524,3599,"I think you're talking about your own"],[3599,3707,"ugly ass!"],[3757,3920,"Sir, I,"],[3945,4074,"I really appreciate the effort"],[4083,4346,"but I don't want you to get fired."],[4379,4450,"I'll just..."],[4554,4696,"I'll resign once we land."],[4779,4896,"You won't have to resign."