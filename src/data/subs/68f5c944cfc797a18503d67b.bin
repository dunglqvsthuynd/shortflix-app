2,3309,"What-"],[3570,3757,"What did you just make me swallow?"],[3757,3974,"Something to ensure your obedience."],[3974,4062,"What?"]],"44":[[0,91,"What?"],[191,329,"Without the antidote,"],[329,571,"you'll die within 3 days from heart failure."],[571,738,"You poisoned me."],[738,814,"This is what happens"],[814,967,"when you don't do what I say."],[967,1309,"Bring me Marco's dead body in 3 days"],[1309,1530,"exchange for the antidote."],[2723,2831,"Here is the Heart of Rose"],[2831,2969,"set you requested, Don."],[3178,3436,"It's worth almost five million, Don."],[3436,3695,"You really spoil Donna Morelli."],[4091,4241,"What happened to you?"],[4241,4358,"Look like you've seen a ghost."],[4358,4575,"Oh. No, nothing, I just-"],[4575,4775,"I just had a nightmare."],[4775,4871,"So..."],[5246,5384,"Wow."],[5534,5630,"What-"],[5630,5755,"What is this?"],[5755,5847,"It's so pretty."],[5951,6068,"Wait. Is this for me?"],[6068,6185,"Yeah."],[6185,6281,"A little gift."],[6377,6527,"Marco."],[6635,6752,"Thank you."],[6944,7057,"I gotta handle a few things,"],[7057,7152,"but"],[7152,7253,"why don't you try that on?"],[7419,7590,"Okay."],[7590,7778,"Make sure you're taking care of yourself."],[7778,7878,"If you have any more nightmares,"],[7878,7957,"you let me know."],[7957,8062,"I'll ask Alex to call the doctor"],[8062,8233,"to get you some meds."],[8429,8512,"Marco..."],[8512,8729,"He's actually quite considerate."],[8779,8888,"You find anything?"],[8888,9063,"The informant will be here tomorrow."],[9063,9225,"Good."],[9225,9321,"The Morellis better not be"],[9321,9451,"hiding anything from me."]],"45":[[32,110,"Yes!"],[663,888,"You have one day left."],[888,975,"After that,"],[975,1259,"it's either his life or yours."],[1259,1397,"Got it?"],[1397,1551,"Got it."],[1810,1931,"What a shit."],[1931,2110,"Boss, what happened?"],[2110,2260,"Oh, nothing."],[2260,2419,"Who are you talking to?"],[2419,2498,"No one."],[2498,2590,"No, I was just-"],[2590,2719,"I was watching Super Bowl."],[2719,2823,"It gets boring"],[2823,3007,"sitting around here, so..."],[3007,3140,"Damn, I need to find a way"],[3140,3353,"to get rid of these two."],[3353,3470,"Hey."],[3470,3632,"You guys haven't seen your family"],[3632,3791,"in a while, have you?"],[3933,4029,"Of course, you know,"],[4029,4191,"how about I give you some time off?"],[4191,4379,"And you guys can go visit your family."],[4379,4558,"We have to ensure your safety."],[4558,4612,"Oh, please."],[4612,4800,"I'm plenty safe here."],[4800,4904,"You're the boss."],[4904,5038,"As long as Layla doesn't get it."],[5038,5105,"Sure."],[5105,5188,"I'll talk with her."],[5188,5280,"No worries."],[6093,6147,"I guess"],[6147,6322,"I can't put it off any longer."],[6614,6756,"Oh God."],[6756,6902,"Please let this work."]],"46":[[325,437,"Hey."],[437,533,"What were you doing?"],[533,642,"Oh, nothing."],[642,721,"I was just doing a"],[721,859,"little prayer before dinner."],[859,1009,"But come. Come, please."],[1009,1071,"Have a seat."],[1071,1197,"I made all these for you."],[1197,1313,"You made this?"],[1313,1430,"Of course."],[2056,2164,"Thank you"],[2164,2369,"for taking such a good care of me."],[2369,2498,"Who are you?"],[2715,2869,"Who am I?"],[2869,3132,"I'm Bianca Morelli, of course."],[3132,3294,"Your"],[3294,3445,"fiancée."],[3445,3570,"You're something."],[3695,3828,"Let's eat."],[4170,4341,"It's really good."],[4341,4554,"Here. Let me cut your steak for you."],[4554,4725,"I'm not much of a gentleman,"],[4725,4859,"but I can cut my own steak."],[4859,5025,"Oh."],[5025,5117,"Forget for my memory,"],[5117,5347,"I've prepared a surprise for you."],[6431,6560,"I'll get it."]],"47":[[0,100,"I'll get it."],[191,417,"Oh."],[600,754,"You"],[754,867,"take a drink."],[867,1155,"I don't feel like drinking tonight."],[1155,1238,"Oh,"],[1238,1505,"but it's my gift to you."],[2373,2481,"What are you doing?"],[2481,2619,"Getting to know you."],[2656,2819,"He is testing me."],[2819,3028,"What does he mean by this?"],[3499,3595,"But you really"],[3595,3712,"know me so well."],[3832,3978,"And"],[3978,4208,"you really should try this."],[4208,4408,"It's a 1993 Romanée-Conti."],[4408,4587,"Hmm."],[4587,4767,"I don't like French wine."],[4767,4867,"Fine."],[4867,5030,"But you must like this."],[5480,5543,"Oh."],[5543,5680,"This woman is insane."],[5960,6202,"Oh."],[6289,6373,"What's that?"]],"48":[[0,241,"Oh."],[329,412,"What's that?"],[412,558,"Nothing."],[558,784,"It's- just a girl thing."],[784,925,"When are you gonna"],[925,1038,"stop lying to me?"],[1038,1217,"What?"],[1351,1484,"This is the investigation"],[1484,1580,"on Donna."],[2122,2252,"They tried to play me."],[2252,2477,"Don, you want me to..."],[2477,2577,"No!"],[2577,2698,"Use your brain."],[2698,2857,"The wedding is imminent."],[2857,2955,"It doesn't benefit us"],[2955,3057,"if we expose her right now."],[3057,3182,"We need the Morellis."],[3182,3324,"They need us too."],[3324,3516,"So what you're saying is..."],[3516,3641,"Play along."],[3641,3737,"But"],[3737,3845,"the Morellis will pay"],[3845,3970,"for what they've done here."],[4062,4320,"Tell me the truth."],[4454,4535,"I, uh..."],[4542,4704,"You poison me?"]],"49":[[0,162,"You poison me?"],[458,542,"No!"],[542,729,"No, I didn't."],[729,867,"Then what's in the bottle?"],[867,1151,"Umm."],[1151,1413,"Speak! Isabella."],[1413,1518,"You..."],[1518,1701,"You know?"],[1701,1939,"Don't try to change the subject."],[1939,2052,"What's in the bottle?"],[2052,2202,"It's not poison."],[2202,2314,"Then what is it?"],[2314,2485,"It's just... it's.."],[2485,2690,"It's some sedatives."],[2690,2848,"And what?"],[2848,2973,"Viagra."],[2973,3090,"What?"],[3090,3199,"I mean, think about it."],[3199,3370,"I had the drink too."],[3370,3528,"Viagra doesn't work on women."],[3528,3703,"You know what, forget it, okay?"],[3703,3878,"I am not the bad guy."],[3878,3974,"And everyone is"],[3974,4129,"forcing me to try-"],[4129,4250,"Everybody ask...?"],[4250,4446,"What are you talking about?"],[4446,4592,"Hey."],[4592,4712,"Are you okay?"],[4763,4914,"Are you okay?"],[5789,6001,"Don, I found..."],[6067,6177,"It can wait."]],"50":[[1426,1614,"Oh, hey, good morning."],[1722,1847,"Get dressed."],[1847,1993,"We need to talk."],[2769,2948,"-Last night... -Last night..."],[2948,3057,"-You first. -You first."],[3057,3219,"I will go first then."],[3219,3379,"We'll just get over with, yeah?"],[3379,3649,"Okay, umm."],[3649,3803,"I'm not Bianca."],[3803,3933,"It's just like you discovered."],[3933,4074,"My name is Isabella Caruso."],[4074,4166,"There, I said it."],[4166,4304,"There's nothing left to hide."],[4433,4554,"This is my last day."],[4554,4671,"Last day for what?"],[4671,4821,"I had a deal with Luca."],[4821,4971,"Luca?"],[4971,5075,"What deal?"],[5484,5613,"This is the real poison"],[5613,5705,"that Luca gave me."],[5705,5843,"Luca?"],[5843,5985,"He was really..."],[6293,6556,"And I really advise that you be careful with him."],[6556,6673,"Because you know, I'm selfish"],[6673,6794,"and I value my own life,"],[6794,6886,"but never enough to"],[6886,7090,"harm someone just to better myself."],[7090,7186,"I never planned to"],[7186,7311,"use the poison."],[7311,7524,"Last night, it was..."],[7524,7632,"It was just about"],[7632,7778,"enjoying myself one last time"],[7778,7949,"before my time ran out."],[7949,8120,"I just"],[8120,8329,"wanted you and..."],[8329,8475,"I mean, I have to admit"],[8475,8671,"you were pretty good."],[8671,8796,"What am I? Some kind of"],[8796,8904,"fucking whore to you?"]],"51":[[0,125,"What am I? Some kind of"],[125,233,"fucking whore to you?"],[233,387,"No, I..."],[387,500,"I mean, come on,"],[500,570,"you have to admit"],[570,729,"you had fun last night too."],[729,800,"I mean..."],[800,1009,"What are you talking about?"],[1009,1176,"This is a fucking joke to you?"],[1176,1322,"I'm the head of the Romano Family."],[1322,1401,"For Christ's sake."],[1401,1459,"Oh, you know,"],[1459,1572,"I like you choking me."],[1572,1705,"So don't stop."],[1705,1901,"Oh, what the fuck?"],[2686,2836,"Boss."],[2836,2882,"You can stop"],[2882,3078,"calling her boss, Layla."],[3078,3232,"I know she's not Bianca."],[3232,3470,"You're right. She's not Bianca."],[3574,3787,"You've got some nerve, Romano."],[3787,3949,"What did you do to our boss?"],[3949,4045,"I gotta admit"],[4045,4250,"you're loyal to the Morelli family,"],[4250,4371,"even to a fake."],[4537,4717,"What happened to our boss?"],[4717,4888,"Hey, calm the fuck down."],[4888,5075,"You calm the fuck down!"],[5075,5180,"Don't forget"],[5180,5358,"it was you that lied to me first."],[5467,5680,"Made me marrying an imposter."],[5680,5834,"Wait, Romano."],[5834,6068,"What if she's not an imposter?"],[6068,6197,"What?"]],"52":[[0,233,"What if she's not an imposter?"],[233,354,"What do you mean?"],[354,467,"What if"],[467,592,"Isabella is the real"],[592,721,"Morelli heir?"],[721,863,"Unbelievable."],[863,1005,"Still lying?"],[1005,1142,"Haven't you ever wondered"],[1142,1376,"why she looks exactly like our boss?"],[1376,1518,"They're twins."],[1518,1634,"When they were little,"],[1634,1814,"their mother got tired of the gang wars,"],[1814,2006,"had a fight with their father"],[2006,2160,"and left the family."],[2160,2248,"Took little Isabella"],[2248,2394,"to a small village."],[2394,2565,"It's a real nice story, cute."],[2565,2719,"Like a little fairy tale."],[2719,2852,"Too bad it's bullshit!"],[2852,3007,"Believe it or not."],[3007,3211,"We're taking our boss back."],[3278,3357,"Silvio."],[3528,3628,"You can't take her."],[3628,3695,"We're engaged."],[3695,3778,"Even if she dies,"],[3778,3916,"she's still my fiancée."],[3916,4049,"You asshole!"],[4250,4325,"We're calling off"],[4325,4454,"the engagement."],[4454,4550,"Let's go."],[5246,5372,"Don. Are you alright?"],[5372,5518,"Should we pursue them?"],[5518,5613,"No."],[5613,5716,"And I don't want anybody"],[5716,5847,"to find out about this."],[6081,6235,"Layla,"],[6235,6377,"are we really calling off the engagement"],[6377,6468,"with the Romanos?"],[6468,6589,"We'll discuss that later."],[6589,6648,"Saving the boss"],[6648,6744,"is the top, right?"],[7098,7175,"Damn it."],[7253,7407,"The plan failed."]],"53":[[0,200,"The plan failed."],[200,371,"Sir, it wasn't a total failure."],[371,521,"Without the bride,"],[521,583,"the wedding is off."],[583,692,"But it's a shame."],[692,779,"Thought I could take out"],[779,888,"Marco in the process."],[1113,1292,"Seems I spoke too soon."],[1292,1488,"Opportunity is finally come."],[1488,1689,"Very well, sir."],[2840,2936,"Marco."],[2936,3040,"Drowning your sorrows in alcohol"],[3060,3140,"isn't like you."],[3180,3328,"People change."],[3328,3495,"Did you"],[3495,3582,"fall for her?"],[3582,3787,"Bullshit."],[3787,3924,"I heard she's not Bianca."],[3924,4087,"I thought I had ordered that"],[4087,4204,"information sealed."],[4204,4412,"I saw Layla take her away."],[4412,4596,"She seems unconscious."],[4596,4737,"What happened exactly?"],[4821,4900,"She's dead."],[4900,5109,"The Morelli people took her away."],[5109,5296,"Is that what you wanted to hear?"],[5323,5415,"She's dead?"],[5672,5922,"What are you doing, Marco?"]],"54":[[0,183,"What are you doing, Marco?"],[450,554,"You had some dust"],[554,658,"on your shoulder."],[792,884,"Thanks."],[975,1071,"You know,"],[1071,1251,"she really is dead."],[1251,1338,"Doctor said,"],[1338,1488,"she was poisoned."],[1488,1780,"Now, who do you think"],[1780,1960,"could poison her?"],[1960,2060,"Maybe it was someone"],[2060,2173,"seeking revenge."],[2173,2311,"First, the assassination,"],[2311,2500,"and now poisoning."],[2500,2686,"Marco, I think,"],[2686,2894,"we have a snake in our own family."],[2894,3065,"I think so, too."],[3065,3269,"If you need my help,"],[3269,3407,"let me know."],[3441,3540,"Of course."],[3641,3749,"Thank you, brother."],[3912,4012,"Have a good night."],[4112,4241,"Don't drink too much."],[4241,4387,"My brother."],[4387,4504,"I'll try."],[4662,4850,"Why didn't you expose him?"],[4850,4963,"Luca is a snake,"],[4963,5067,"but he's smart."],[5067,5146,"We gotta catch him"],[5146,5284,"when he least expects it."],[5284,5422,"Understood."],[5422,5522,"And"],[5522,5680,"find out how that girl is."],[5680,5839,"And give help we can provide."],[5839,5968,"Whatever the cost."],[5968,6147,"You got it, Don."],[7032,7127,"What's wrong with her?"],[7127,7219,"Doc?"],[7273,7365,"Oh, it is bad."],[7365,7520,"Fucking bad."],[7520,7678,"Am I really about to become the next"],[7678,7928,"boss of the Morelli family?"],[7928,8099,"Can't handle all the responsibilities,"],[8099,8249,"so many responsibilities-"],[8249,8341,"Silvio,"],[8487,8608,"are you staging a coup?"],[8608,8746,"-Boss. -Boss."]],"55":[[0,141,"-Boss. -Boss."],[208,412,"Boss. Are you really alive?"],[412,596,"Do I look dead?"],[596,729,"I mean, I may be able to"],[729,842,"fake being a boss."],[842,946,"But I can't fake death."],[946,1163,"God, for a boss being okay."],[1163,1280,"Wait!"],[1280,1488,"You alright?"],[1488,1555,"Why were you"],[1555,1701,"shaking your head earlier?"],[1701,1818,"Yeah, you know..."],[1818,1968,"Doctor, I'm curious too."],[1968,2142,"Luca said that I'd die of heart failure"],[2142,2323,"within three days without the antidote."],[2323,2410,"The thing is..."],[2410,2515,"Luca?"],[2515,2652,"Luca did this to you?"],[2652,2777,"I'm gonne kill that fucking cripple."],[2777,2869,"Idiot!"],[2869,3019,"Isabella just woke up."],[3019,3161,"You want to go throw your life away?"],[3161,3240,"Hey guys, stop."],[3240,3378,"You're giving me a headache."],[3378,3507,"Come on, doctor."],[3507,3574,"Really why?"],[3574,3728,"How am I alive?"],[3728,3899,"The thing is"],[3899,4037,"that medicine was a fake."],[4037,4137,"What?"],[4137,4212,"Like your boobs."],[4212,4336,"Bitch!"],[4336,4491,"Why'd you know it's fake though?"],[4491,4617,"Actually,"],[4617,4754,"the drug was from one of"],[4754,4875,"my failed experiment."],[4875,4988,"-What? -What?"]],"56":[[0,100,"So you're saying you sold"],[100,196,"fake medicine?"],[196,350,"And fake boobs?"],[350,504,"Don't twist my words."],[504,696,"I don't sell fake medicine."],[696,784,"I only sell fake boobs."],[784,1088,"Someone from my lab stole the medicine"],[1088,1197,"without my knowledge."],[1197,1309,"So you're telling me"],[1309,1463,"that Luca bought fake boo-"],[1463,1539,"I mean,"],[1539,1910,"Luca bought fake medicine from you?"],[1910,2072,"What a fucking moron."],[2314,2410,"Boss."],[2410,2565,"It's very strange."],[2565,2656,"There's been no movement"],[2656,2806,"from the Morelli side at all."],[2806,3019,"They're trying to cover up her death."],[3019,3219,"The plan continues as scheduled."],[3219,3345,"By the way,"],[3345,3549,"the guy who brought our drug,"],[3549,3737,"he wants the remaining payment."],[3737,3958,"And now he's asking for 10 million."],[4129,4233,"10 million?"],[4233,4375,"Wasn't it just 1 million?"],[4375,4506,"He somehow found out that"],[4506,4708,"the drug was used on the Morelli leader."],[4708,4853,"And he's turning to expose us"],[4853,4979,"if we don't pay up."],[5125,5214,"Damn it!"],[5284,5551,"Fine, just pay him."],[5551,5730,"Just pay him."],[5730,5851,"Find this guy he mentioned"],[5851,5968,"and bring him to me."],[5968,6106,"And"],[6106,6252,"spread the news,"],[6252,6385,"my wedding is in a week."],[6385,6464,"Your Wedding?"],[6502,6569,"To beat"],[6569,6690,"Luca is definitely gonna come after me"],[6690,6806,"when he sees this."],[6806,6936,"We'll catch him off guard at the wedding."],[6936,7032,"And the bride?"],[7032,7186,"And I wonder what happened to her."],[7186,7403,"The Morelli family's been very quiet."],[7403,7603,"She may really be dead."],[7603,7757,"That woman is toughest person"],[7757,7924,"I've ever met."],[7924,8083,"Can't believe she would just..."]],"57":[[87,172,"You know..."],[258,412,"Life's so comfortable here."],[412,575,"I almost don't want to go back to my life"],[575,754,"as an ordinary teacher."],[754,842,"You can't."],[842,963,"Layla,"],[1051,1151,"I don't belong"],[1151,1292,"in the mob world."],[1292,1443,"Yeah, you do."],[1443,1664,"I teach elementary kids, Layla."],[1664,1755,"Do you remember"],[1755,1926,"what I told you?"],[1926,2093,"You were born for this."],[2177,2256,"Wait,"],[2256,2373,"what do you mean?"],[2540,2719,"We've kept something from you."],[3057,3224,"Hello, I'm Bianca Morelli."],[3224,3403,"But you already knew that."],[3403,3624,"What you don't know is that"],[3716,3856,"I have a twin sister."],[3916,4229,"And since my father has passed,"],[4366,4475,"I'm calling on everyone to"],[4475,4600,"help me locate them."],[4600,4733,"Omg, that's my mom."],[4733,4808,"We were separated"],[4808,4921,"when we were 2 years old."],[4921,5013,"But my mother"],[5013,5134,"should look about the same."],[5134,5221,"And my sister"],[5221,5363,"has a heart-shaped scar"],[5363,5559,"on her left thigh."],[5647,5780,"For anyone who can"],[5780,5930,"find my sister and mother,"],[5930,6172,"I'm offering $5 million."],[6398,6527,"I'm..."],[6527,6631,"a Morelli...?"]],"58":[[0,125,"A Morelli...?"],[125,241,"Yes."],[241,425,"You're the heir to the Morelli family,"],[425,575,"so the next Donna."],[575,738,"Oh!"],[738,921,"Oh god!"],[921,1030,"I'm destined"],[1030,1201,"to be a crime boss."],[1201,1343,"Do you think being in the mob"],[1343,1505,"is only about crime?"],[1505,1651,"You know, the ancestors"],[1651,1780,"of the Morelli family"],[1780,2060,"have also supported charitable causes."],[2060,2218,"We arguably help out the poor"],[2218,2314,"more than the government."],[2385,2502,"These records"],[2502,2610,"show all the good"],[2610,2756,"that your ancestors have done."],[3211,3386,"We advocate for peace,"],[3386,3591,"at least we tried to."],[3591,3766,"But more importantly,"],[3766,3903,"we post terrorism."],[3935,4010,"Wow."],[4079,4250,"This is actually kind of"],[4250,4416,"changing my perspective."],[4416,4650,"The Morelli family is your home."],[4650,4829,"So you have to protect it."],[5521,5576,"Yeah."],[5876,5993,"Alright, thanks."],[6068,6227,"I just got news that the"],[6227,6356,"Romano's getting married."],[6356,6556,"The ceremony is soon."],[6715,6794,"Married?"],[6923,7015,"To whom?"],[7015,7107,"Probably still thinks"],[7107,7278,"Isabella died from the poison."],[7278,7499,"Must be another woman."],[7499,7703,"Oh."],[7703,7766,"Okay."],[7766,7895,"He moved on"],[7895,8028,"pretty fucking quickly, huh!"],[8103,8299,"Fuck it. Let's go."],[8299,8412,"But only just to see"],[8412,8587,"who he picked. Okay?"]],"59":[[617,779,"That woman is dead."],[779,971,"So who's this bride?"],[971,1201,"We haven't gotten any information."],[1239,1335,"Useless!"],[1418,1539,"Spread the word."],[1539,1668,"The plan starts now."],[1668,1739,"It's time for"],[1739,1851,"Marco to step down."],[2369,2569,"Thank you for being here"],[2569,2640,"and for supporting the Romanos."],[2744,2857,"Today"],[2857,2969,"is a very important day"],[2969,3044,"for our family,"],[3044,3290,"for myself, and also"],[3290,3440,"for my dear brother,"],[3440,3520,"Luca."],[3732,3887,"What does Don Romano"],[3887,3958,"mean by that?"],[3971,4032,"Yeah, but..."],[4062,4279,"He mentioned his brother specifically."],[4279,4508,"Marco. Don't keep us in suspense."],[4508,4662,"Where's the bride?"],[5000,5121,"Fuck this wedding!"],[5889,5997,"There's no bride."],[6281,6481,"Then I'm ending this wedding right now."]],"60":[[0,200,"Then I'm ending this wedding right now."],[200,379,"So you're finally dropping the act."],[379,554,"I've been pretending"],[554,738,"to be the good brother"],[738,880,"far too long."],[880,984,"Did you ever think of me"],[984,1117,"as an older brother?"],[1117,1313,"Why should the Romanos fall into your hands?"],[1313,1426,"Because I'm crippled?"],[1426,1605,"Do I need to remind you?"],[1605,1714,"If it weren't for you,"],[1714,1868,"I wouldn't be like this!"],[1891,2114,"I have always seen you as my brother"],[2114,2260,"and I'm grateful for you."],[2260,2369,"Fuck your gratitude."],[2369,2556,"Hand the Romanos over to me."],[2556,2727,"You sure this is what you want?"],[2798,2861,"Yes."],[2861,3011,"But even if you don't,"],[3011,3148,"after today,"],[3148,3390,"the Romanos will be mine."],[3578,3699,"Damn, shoot out."],[3699,3795,"Okay."],[3966,4083,"Looks like Marco is in trouble."],[4083,4179,"Damn it."],[4179,4396,"Only I get to deal with that asshole."],[4437,4554,"Layla, Silvio."],[5159,5271,"Donna Morelli."],[5434,5534,"What did you do?"],[5534,5726,"The Romanos are changing hands."],[5726,5855,"Die, bitch!"],[5855,5968,"Boss!"],[6085,6185,"Marco!"],[6185,6327,"Give up!"],[6350,6548,"Your people should already be dead."],[6585,6719,"Who said that?"]],"61":[[79,204,"Who said that?"],[321,379,"You."],[379,475,"Don."],[475,554,"With Donna's help, we've"],[554,734,"eliminated all the traitors."],[734,892,"You're all gonna die."],[892,1009,"Yeah, I don't think so."],[1209,1326,"You..."],[1438,1572,"Impossible!"],[2202,2364,"I thought you were dead."],[2364,2535,"Well, sorry to disappoint."],[2535,2686,"Not only am I alive,"],[2686,2761,"but I'm here to crash"],[2761,2865,"your little wedding."],[2865,3048,"No, there was no bride."],[3048,3165,"This was all an elaborate setup"],[3165,3286,"to expose Luca."],[3286,3395,"Forget all that."],[3395,3541,"I can't believe it."],[3541,3670,"I am so glad you're alive."],[3670,3828,"I have missed you so mu-"],[3828,3958,"Right, you jerk."],[3958,4108,"Come on."],[4108,4191,"Oh."],[4191,4316,"Layla, Silvio."],[4316,4429,"Let's go party and"],[4429,4571,"find some hot guys."],[4662,4842,"Yeah, Donna Morelli."],[5013,5217,"Stop! Don't go!"],[5701,5864,"Still tripping me up, huh?"]],"62":[[341,500,"Where is she?"],[500,638,"On a wedding day?"],[742,930,"Why is Isabella not out here?"],[1226,1347,"Don Romano, bad news."],[1347,1447,"Your fiancée, she..."],[1447,1564,"She ran away."],[1564,1685,"What?"],[1685,1822,"Ran away?"],[2047,2175,"We are having a baby?"],[2274,2410,"We are having a baby!"],[2431,2610,"She ran away with my child?"],[2669,2729,"That's it."],[2729,2940,"Grab your gun and call our people."],[3699,3807,"Hey."],[3807,3928,"Why are we drawing guns"],[3928,4033,"on my wedding day?"],[4033,4191,"Isabella."],[4245,4354,"I thought you ran away."],[4412,4537,"Ran away?"],[4567,4758,"Come on. It was just a little joke."],[4925,4996,"Thank goodness."],[4996,5088,"Finally a wedding where"],[5088,5196,"no one has to get shot."],[5205,5300,"You look"],[5400,5488,"perfect."],[5568,5651,"Come on."],[5651,5755,"Let's go get married."],[5800,6026,"Well, smeone's in a rush."],[6026,6239,"Only to avoid any more surprises."],[7111,7253,"THE END"]]}