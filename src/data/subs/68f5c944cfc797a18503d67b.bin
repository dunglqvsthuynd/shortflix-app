you talking about?"],[4362,4462,"That's impossible."],[4462,4579,"If the Donna of Morelli"],[4579,4658,"had died,"],[4671,4792,"we'll know for sure."],[4850,4913,"You're right."],[4913,5013,"Bianca has died."],[5251,5351,"Because"],[5372,5442,"she will soon"],[5442,5538,"be reborn"],[5568,5718,"as Bianca Romano."],[6026,6118,"Luca,"],[6227,6343,"is this some kind of joke?"],[6381,6498,"Sorry, maybe I..."],[6498,6631,"I got proof"],[6719,6861,"that Bianca is dead."]],"23":[[0,95,"I got proof"],[95,212,"that Bianca is dead."],[233,329,"Antonio."],[329,392,"Damn it!"],[392,500,"What's he doing here?"],[700,804,"Didn't you learn your lesson"],[804,888,"last time?"],[921,1034,"Last time you tricked me."],[1034,1146,"Now, I have proof"],[1146,1272,"that you're an imposter."],[1393,1472,"Oh, yeah?"],[1501,1593,"How can you prove it?"],[1593,1634,"Damn it!"],[1643,1801,"The fucking report's not here still."],[1818,1897,"Oh,"],[1910,1981,"little Tony,"],[1981,2056,"don't tell me you've"],[2056,2231,"fallen for me again."],[2289,2373,"Shut up!"],[2373,2465,"How have none of you noticed"],[2465,2540,"the attitude-"],[2540,2741,"the demeanor of this Donna Morelli is"],[2741,2940,"clearly different than the one before?"],[3599,3689,"She certainly doesn't"],[3689,3845,"act like the Bianca we know."],[3858,3924,"That's right."],[3924,4004,"Donna Morelli used to be"],[4004,4137,"so cold and distant."],[4137,4287,"I hardly ever saw her smile."],[4287,4362,"Bianca,"],[4362,4508,"would you care to explain?"],[4508,4662,"Yeah, explain."],[4662,4829,"I..."],[5109,5267,"You're right."],[5326,5422,"You're right."],[5451,5659,"I'm not the same Bianca as before."]],"24":[[0,208,"I'm not the same Bianca as befor."],[208,322,"The Bianca that you knew"],[322,648,"was cold, ruthless, distant,"],[648,871,"especially to her subordinates."],[992,1247,"But I've had a change of heart."],[1263,1413,"Ever since I fell in love"],[1413,1559,"with this man,"],[1559,1793,"the old Bianca has died."],[1881,1993,"This is the new me."],[1993,2177,"Everyone, this is"],[2177,2339,"clearly Bianca speaking."],[2339,2560,"Sure she's warmer now"],[2560,2690,"as a person, but..."],[2690,2849,"she's still clearly"],[2849,3157,"the same competent leader."],[3482,3561,"What? You think everyone's"],[3561,3687,"gonna fall for this act?"],[3709,3866,"Where the fuck is Alo?"],[4283,4475,"I suggest you get lost,"],[4487,4612,"you power-hungry"],[4612,4729,"little Tony."],[4746,4875,"You're a fake."],[4929,5004,"Marco,"],[5004,5401,"seems our future sister-in-law's identity"],[5422,5543,"is still in question-"],[5543,5663,"No, I think someone here"],[5663,5822,"is just trying to cause trouble."],[5822,6147,"I swear the woman in front of you is a fraud."],[6147,6214,"Oh."],[6256,6314,"Okay."],[6314,6485,"We're just supposed to take your word for it."],[6485,6635,"Look who's getting desperate."],[6635,6881,"Even daring to disrupt the alliances"],[6881,6994,"between the Morelli"],[6994,7165,"and the Romano families."],[7165,7332,"You keep saying she's a fake."],[7332,7444,"Do you have any proof?"],[7444,7507,"Proof"],[7540,7745,"is on the way."],[7978,8033,"Marco."],[8053,8133,"Marco,"],[8133,8199,"if you have"],[8199,8412,"any doubt about my identity then..."],[8445,8612,"feel free to call off the engagement."],[8612,8762,"Don, you mustn't..."],[8804,8896,"Oh!"],[8896,8983,"Get this scumbag"],[8983,9092,"the hell out of here."],[9305,9384,"Boss."],[9563,9713,"I have the DNA test report."],[9793,9927,"This is the proof"],[9927,10072,"I was talking about."]],"25":[[0,171,"This is the proof"],[171,287,"I was talking about."],[287,408,"What's that?"],[421,529,"This is a DNA report"],[529,633,"comparing her"],[633,721,"to Bianca."],[746,817,"What?"],[959,1151,"What exactly are you trying to do?"],[1163,1251,"Don Romano,"],[1259,1376,"it would be an honor"],[1376,1568,"for you to expose this imposter."],[1580,1664,"Wow."],[1664,1818,"What a thrilling show."],[1951,2014,"I'm doomed."],[2031,2097,"I'm done for."],[2118,2206,"Fuck!"],[2223,2318,"It's over."],[2348,2431,"Don Romano."],[2431,2519,"It's only fitting"],[2519,2598,"that you are the one"],[2598,2761,"who exposes this fraud."],[2781,2886,"I thought about that,"],[2886,2948,"but you know,"],[2948,3057,"I'm not the director."],[3057,3165,"Rest assured."],[3165,3249,"Cut the crap."],[3274,3336,"Oh,"],[3336,3411,"if you think it's fake,"],[3411,3545,"why are you so nervous?"],[3657,3753,"Don Romano."],[4291,4421,"You see it, Don Romano."],[4508,4650,"Is this a fucking joke?"],[4892,5055,"99% match."],[5096,5163,"No, that..."],[5171,5342,"That's impossible."]],"26":[[196,291,"Take a look."],[291,492,"This is Bianca Morelli,"],[492,638,"our boss."],[638,738,"What is going on?"],[738,867,"That scared me to death."],[867,963,"I figured Antonio"],[963,1055,"might try something,"],[1055,1213,"so I had someone tamper"],[1213,1334,"with the results in advance."],[1363,1447,"What?"],[1447,1614,"Then why'd you look so scared earlier?"],[1614,1764,"For dramatic effects."],[2001,2152,"I swear, this is impossible."],[2168,2235,"There's gotta be"],[2235,2369,"something wrong with the report."],[2369,2556,"Your people were the ones"],[2556,2673,"that brought in the problem."],[2711,2836,"Alo, what is going on?"],[2836,2907,"Oh."],[2907,3078,"Seems like someone ran off."],[3111,3215,"Useless!"],[3232,3286,"No."],[3286,3395,"She has to die."],[3395,3465,"If she doesn't,"],[3465,3607,"then it gonna be me."],[3682,3782,"You bitch!"],[3782,3853,"I'll expose you"],[3853,3941,"for what you are."],[4083,4200,"Are you out of your mind?"],[4408,4466,"Boss,"],[4479,4579,"this shouldn't be a problem"],[4579,4688,"for someone like Bianca."],[4688,4771,"Right, Marco?"],[5159,5259,"Bianca's a black belt"],[5259,5351,"at the end of the day."],[5351,5447,"Come on, Izzy."],[5447,5559,"You can do this."],[5593,5689,"Bitch!"],[5697,5814,"You're fucking me over!"],[7094,7165,"Fuck!"],[7178,7303,"You!"],[7757,7825,"No."]],"27":[[1088,1167,"He's dead."],[1167,1276,"What?"],[1301,1384,"What? He's dead?"],[1384,1522,"He's really dead?"],[1522,1659,"Get a grip."],[1676,1785,"You're Bianca."],[2235,2318,"Well done."],[2327,2464,"That piece of shit deserved it."],[2515,2606,"Now, where were we?"],[3370,3457,"And with that,"],[3470,3566,"I'd like to officially"],[3566,3695,"announce the engagement"],[3712,3928,"between Bianca Morelli and myself."],[3945,4079,"Wedding will take place in a month."],[5009,5092,"Marco Romano,"],[5092,5209,"why do you always get everything?"],[5209,5313,"I'm the oldest son of"],[5313,5405,"the Romano family."],[5405,5492,"If weren't for these legs,"],[5492,5601,"I would be done."],[5634,5714,"Sir,"],[5809,5914,"please spare me."],[6256,6356,"Why should I?"],[6377,6489,"That Bianca today was"],[6489,6606,"definitely a fake."],[7019,7132,"If she were a fake,"],[7152,7259,"would Antonio be dead?"],[7269,7365,"She is a fake."],[7365,7461,"That woman today"],[7461,7528,"is named Isabella."],[7528,7699,"I swear on my life."],[7699,7803,"I heard Layla call her"],[7803,7953,"Isabella at the Molly Manor."],[7953,8037,"Isabella?"],[8058,8145,"Yes, sir."],[9046,9129,"Well done."],[9188,9259,"I will serve you well"],[9259,9376,"from now on, sir."],[10147,10251,"Useless people"],[10251,10347,"have no value to me."]],"28":[[145,254,"Isabella,"],[254,437,"welcome to the Romano family."],[437,675,"I am Don Marco's assistant, Alexander."],[688,770,"Shall I show"],[770,892,"you around the house?"],[892,1026,"Uh, yeah."],[1026,1149,"I mean, as long as you're not afraid"],[1149,1259,"that I'm gonna stab you."],[1347,1488,"Oh, that is not funny."],[1514,1626,"Okay. Oh!"],[1626,1772,"I said it's not fucking funny!"],[1772,1968,"If Romano tells me to stab somebody,"],[1968,2047,"I stab him."],[2047,2139,"Don't fucking joke!"],[2152,2239,"Okay."],[2239,2348,"Take a chill pill."],[2381,2431,"I mean,"],[2431,2494,"God, why can't you be"],[2494,2652,"more like sunglasses at night, guy?"],[2652,2690,"Huh?"],[2706,2811,"My apologies."],[2886,2977,"Please follow me."],[3586,3687,"Oh my god!"],[3728,3816,"These are the founders"],[3816,3924,"of the Romano family."],[3924,4024,"Great men."],[4062,4208,"Just like your grandfather."],[4229,4291,"Yep."],[4366,4562,"Yep, yep, they were great."],[4854,4996,"These will be your quarters."],[5050,5180,"If you have any questions,"],[5180,5338,"feel free to ask one of the servants."],[5338,5468,"Don Romano will be with you"],[5468,5551,"very shortly."],[5551,5643,"Thanks."],[6664,6794,"Oh my God."],[6794,6965,"Pretending is exhausting."],[7415,7524,"Layla, where'd you go?"],[7524,7699,"Oh, sorry, I forgot to mention."],[7699,7807,"I'm on my way back"],[7807,7920,"to Morelli already."],[7966,8058,"What?"]],"29":[[0,41,"Uh."],[41,100,"Don't worry,"],[100,296,"I left Joey and Mick there to protect you."],[296,412,"Just keep playing the role"],[412,567,"of Bianca and you'll be fine."],[567,825,"Just don't blow the cover"],[825,963,"until the wedding is over."],[963,1059,"Unless you can get him"],[1059,1155,"to fall in love with you."],[1180,1217,"God!"],[1217,1343,"But that's impossible!"],[1343,1418,"Eh,"],[1418,1551,"I thought the same thing."],[1551,1800,"Considering Bianca was a bit more his type"],[1800,1878,"than you are."],[1878,2022,"Okay, Layla, come on!"],[2022,2193,"Look, I've got the brains,"],[2193,2281,"the body"],[2281,2447,"and the looks to match. Okay?"],[2447,2585,"So just watch win that man over."],[2990,3086,"Reverse psychology"],[3086,3199,"always works."],[3265,3315,"At least now"],[3315,3432,"she'll be invested."],[3553,3728,"I mean, how dare they doubt me?"],[3778,4012,"I, Isabella Caruso,"],[4012,4241,"will win over Marco Romano."],[4241,4346,"Isabella?"],[4350,4542,"Did you just call yourself Isabella?"],[4562,4650,"Shit!"],[4650,4725,"Yes."],[4725,4913,"Yes, no, that's just my nickname"],[4913,5180,"after Queen Isbella of Spain."],[5180,5363,"Yeah, my grandfather"],[5363,5467,"wanted me to be"],[5467,5609,