{"1":[[829,971,"Surprise! Simon!"],[1317,1409,"Oh my God!"],[1559,1643,"Damn it!"],[1705,1851,"Sorry guys, meeting's over."],[2189,2252,"What the hell"],[2252,2352,"are you doing here?"],[2352,2464,"Honey."],[2464,2585,"Did you forget?"],[2656,2790,"It's baby making day."],[3115,3244,"You're fucking embarrassing me"],[3244,3319,"and my job."],[3319,3370,"I just..."],[3370,3528,"I wanted to surprise you..."],[3549,3716,"Surprise!"],[3866,4002,"Oh, Simon Parker."],[4024,4204,"How dare you cheat on me?"],[4312,4412,"Damn!"],[4412,4525,"Crazy woman!"],[4525,4592,"And you."],[4625,4733,"You whore!"],[4896,5000,"Bitch! Stop!"],[5000,5055,"Forget it."],[5055,5171,"Just let her go."],[5351,5480,"I want a divorce."],[5609,5689,"God."],[5772,5914,"Isabella, wait, wait..."],[6227,6318,"Isabella."],[7857,7929,"Isabella."],[8024,8112,"Come back!"]],"2":[[20,175,"She looks just like her."],[221,379,"Exactly the same."],[379,492,"Same image."],[913,1046,"Who are you?"],[1076,1209,"Oh God. Help!"],[1401,1493,"Shut up!"],[1493,1589,"I'll free you"],[1605,1764,"if you shut the hell up."],[1835,1893,"Yeah?"],[1947,1981,"All right."],[2544,2656,"Hey, look, look."],[2715,2831,"I know I'm pretty but"],[2831,2965,"I don't have any money."],[3207,3236,"Well..."],[3236,3424,"Actually, I'm not that pretty."],[3424,3516,"You know I mean,"],[3586,3682,"my boobs are fake,"],[3695,3749,"and... and..."],[3774,3983,"and my skin is plastic."],[3983,4129,"I mean, basically everything"],[4129,4229,"be a surgical so..."],[4320,4375,"Okay,"],[4425,4491,"you want money?"],[4504,4587,"You want money, right?"],[4617,4679,"Look, look."],[4679,4821,"Just go after my husband."],[4833,4925,"He's a doctor"],[4925,5042,"at Greenfield Hospital."],[5042,5150,"You can go after him."],[5167,5305,"Simon, you betrayed me."],[5321,5442,"This is revenge."],[5467,5597,"We don't want your money,"],[5630,5739,"and we don't want your body either."],[5739,5784,"What do we look like?"],[5893,5993,"Then what do you want?"],[6