{"1":[[312,475,"It's the state's pre-lims"],[475,717,"for this year's Math Olympiad."],[759,921,"Only one candidate"],[921,1092,"will make it to national level."],[1092,1184,"Who will it be?"],[1205,1405,"The last question on the test this year"],[1405,1614,"is of the utmost difficulty."],[1614,1830,"An unsolvable mathematical model"],[1830,2039,"could change microchip technology"],[2039,2106,"forever."],[2106,2385,"No student has yet to attempt"],[2385,2660,"or even turn in their tests."],[2660,2773,"It is that hard."],[2936,3065,"Down to the last minute."],[3065,3257,"Can no one really solve this problem?"],[3265,3411,"I told you, Reeds."],[3411,3507,"These are high schoolers."],[3507,3578,"They're not going to be able"],[3578,3678,"to solve a problem"],[3678,3795,"that baffles the entire"],[3795,3916,"microchip industry."],[3916,4200,"We are falling behind in microchip tech"],[4200,4320,"and I am tired of outsourcing"],[4320,4412,"to other countries."],[4437,4604,"That is exactly why we need"],[4604,4738,"to give young blood a chance."],[4738,4842,"And your answer is what?"],[4842,4979,"These teenagers?"],[5013,5084,"And as you well know,"],[5084,5238,"Apollo Tech is number one in tech"],[5238,5317,"in the United States."],[5317,5442,"I can't see any of these kids"],[5442,5568,"being able to solve this."],[6026,6093,"All done."],[6861,6986,"Zosha Sanchez"],[6986,7107,"is the first to finish."],[7419,7507,"So you're the girl"],[7507,7636,"from West Virginia, right?"],[7707,7891,"The state with all the dumb hillbillies?"],[8028,8108,"You sure you don't want to"],[8108,8229,"double check your answers?"],[8266,8366,"There's no need for that."],[8400,8479,"She says she's done."],[8479,8541,"Just take it."],[8687,8871,"What can a farm barbie"],[8871,8983,"amount to anyway?"],[8983,9196,"I bet her answer sheet is blank."],[9230,9384,"The test questions were indeed"],[9384,9463,"beyond the level"],[9463,9576,"of this state competition."],[9576,9730,"But if I were you,"],[9730,9830,"I would log my answers"],[9830,9914,"in immediately."],[9914,9993,"It might just change"],[9993,10126,"the trajectory of our future."],[10402,10456,"Okay."],[10556,10652,"What a joke."],[10677,10898,"Not even Apollo Tech researchers"],[10898,11090,"can solve this math model."],[11090,11190,"How can she?"],[11302,11440,"Must have been a blank test."],[11724,11820,"Wait."],[11911,11999,"She solved it."]],"2":[[16,108,"She solved it."],[158,208,"Quick."],[208,300,"Put it in the system."],[421,604,"A microchip mathematical model."],[604,713,"Answers submitted."],[738,834,"Analyzing."],[863,925,"Okay."],[925,1063,"Someone handed in their answer."],[1063,1155,"Hold on."],[1188,1380,"No one's been able to solve this."],[1380,1534,"Even if somebody handed in an answer,"],[1534,1647,"it's probably just a blind guess."],[1647,1893,"I give you a 99.9% chance"],[1893,2039,"this answer is wrong."],[2039,2181,"Analysis complete."],[2193,2277,"Solution"],[2277,2348,"correct."],[2606,2690,"Correct!"],[2723,2877,"We found the genius"],[2877,2961,"we've been looking for."],[2961,3103,"He could save the microchip industry."],[3103,3178,"He could save the entire"],[3178,3311,"mathematical world."],[3311,3353,"Come on."],[3353,3374,"Quick."],[3374,3436,"Look him up."],[3436,3616,"Find out what Ivy League college"],[3616,3674,"he goes to."],[3799,3883,"It's a girl."],[4229,4262,"No."],[4262,4404,"There's no way."],[4446,4558,"This is just a hillbilly girl."],[4558,4621,"There's no way"],[4621,4742,"she solved this math problem."],[4763,4888,"It doesn't matter where she's from."],[4925,5013,"She can be the key"],[5013,5088,"to the next breakthrough"],[5088,5184,"in our technology."],[5201,5301,"We must find her."],[5363,5426,"Now."],[5488,5543,"Mom!"],[5543,5605,"Mom!"],[5605,5676,"I did it!"],[5714,5843,"I actually did it!"],[6014,6214,"The last question in Math Olympiad,"],[6214,6318,"I solved it!"],[6318,6460,"You mean the microchip"],[6460,6560,"modeling problem"],[6560,6740,"that nobody solved for decades?"],[6902,7048,"Oh, Zosha."]],"3":[[12,246,"I'm so proud of you."],[738,875,"Here are the shoes I've mended."],[1134,1276,"Mom, you're the best."],[1322,1426,"It's all thanks to you"],[1426,1551,"for taking me under your wings"],[1551,1609,"and passing down"],[1609,1730,"your math knowledge to me."],[1739,1935,"Zosha, you are my only family."],[1935,2118,"Of course I'd do anything for you."],[2398,2489,"I knew you would never"],[2489,2781,"turn into that horrible Becky Caine."],[2827,2973,"You mean your former protégé?"],[3032,3148,"The youngest math professor"],[3148,3236,"at Princeton?"],[3445,3499,"Yeah."],[3949,4004,"Yeah."],[4141,4245,"I've succeeded."],[4537,4629,"Professor, is this your new"],[4629,4746,"microchip math model?"],[4783,4871,"Yes."],[5067,5226,"Well, this advances our technology"],[5226,5376,"by at least a decade."],[5434,5518,"Whoever has this"],[5518,5734,"will surely win the Nobel Prize."],[5893,5997,"In three days,"],[5997,6097,"I will hold a conference"],[6097,6181,"announcing to the world"],[6181,6268,"that we no longer need"],[6268,6418,"to rely on foreign suppliers"],[6418,6594,"for the best microchips."],[6639,6810,"This changes everything."],[7841,7932,"Hello, everyone."],[7974,8116,"I am proud to announce"],[8116,8216,"my latest"],[8216,8366,"mathematical discovery."],[8404,8616,"I am confident that it will advance"],[8616,8758,"microchip technology"],[8758,8888,"in strides."],[8888,8958,"Stop!"],[9038,9200,"I call fraud."],[9250,9300,"What?"],[9325,9438,"Margaret Harmon"],[9451,9647,"stole my research results."]],"4":[[37,125,"It can't be."],[145,329,"Margaret Harmon is well respected"],[329,429,"in Silicon Valley."],[450,667,"Her work has been monumental."],[667,834,"Only one of a few women."],[938,1121,"Becky, you're my student."],[1121,1259,"How can you accuse me of this?"],[1259,1472,"This is my graduate thesis."],[1472,1593,"It has been certified"],[1593,1818,"by five academic journals."],[2014,2081,"No!"],[2139,2369,"You stole and patented my work"],[2369,2469,"before I could?"],[2498,2590,"It's my work."],[2590,2727,"Of course I can patent it."],[2765,2902,"I have a witness too."],[2952,3165,"Yes, I am the director"],[3165,3319,"of science and technology,"],[3319,3553,"and I attest, Miss Becky Caine"],[3553,3753,"did submit her thesis to me"],[3753,3870,"three days ago."],[3891,4012,"So, it's true."],[4041,4120,"Margaret Harmon"],[4120,4262,"stole her student's work!"],[4358,4550,"You're stripped of your position,"],[4550,4625,"Harmon."],[4696,4758,"No."],[4771,4846,"No, no, no, no."],[4846,4929,"I, I, I..."],[4971,5100,"This is my work!"],[5100,5176,"I didn't..."],[5530,5597,"You don't belong"],[5597,5764,"in the Math Hall of Fame anymore."],[5818,5901,"I do."]],"5":[[70,296,"This is, this is my work!"],[296,450,"I didn't plagiarize anything."],[450,563,"This is- - Security!"],[625,696,"Throw her out."],[696,771,"It's my life!"],[771,850,"It's my work!"],[850,884,"It's..."],[884,963,"No!"],[1005,1238,"Please, I didn't plagiarize anything!"],[1305,1405,"This is mine!"],[1584,1839,"No, I don't understand, please!"],[1901,2081,"No, I don't understand!"],[2715,2857,"You should be honored"],[2857,2961,"that I'm using your work"],[2961,3069,"to climb to the top."],[3123,3345,"I'm inheriting your math legacy,"],[3357,3445,"professor."],[3482,3678,"No, it's my life's work!"],[6177,6577,"Sine cosine cosine sine."],[6610,6861,"Cosine cosine sine."],[6906,6969,"Sine."]],"6":[[0,417,"Sine cosine cosine sine."],[417,821,"Cosine cosine sine sine."],[859,946,"Sine."],[1201,1322,"Do you like math?"],[1397,1455,"Yep,"],[1514,1693,"have no ma nor pa,"],[1730,1922,"but I found this math textbook"],[1922,2047,"in the trash."],[2114,2306,"It's the one thing none of the bullies"],[2306,2448,"will take away from me."],[2544,2719,"That is all I have, too."],[2961,3111,"What's your name, little one?"],[3265,3407,"My name's Zosha."],[3486,3574,"Zosha?"],[3837,3949,"How about you and me"],[3949,4120,"become a family from now on?"],[4721,4833,"If it wasn't for you,"],[4833,4950,"I probably would have died"],[4950,5042,"on the streets."],[5109,5276,"After the first round of the exam,"],[5276,5492,"Zosha Sanchez is in first place"],[5492,5597,"for the national Math Olympiad."],[5726,5797,"Oh, Zosha."],[6022,6177,"I'm so proud of you."],[6318,6548,"Zosha Sanchez is in first place"],[6548,6652,"for the national Math Olympiad."],[6685,6902,"Zosha Sanchez..."],[6977,7123,"from West Virginia?"],[7173,7219,"What is this,"],[7219,7453,"a tractor princess competition now?"],[7599,7753,"Advisor Margaret Harmon."],[7791,7920,"That old hag again?"],[8141,8262,"What if this hillbilly brat"],[8262,8400,"really is a math genius?"],[8512,8637,"They'll prove that I'm really an idiot"],[8637,8800,"and take away my Nobel Prize."],[8908,9013,"I can't let that happen."],[9401,9567,"Yes, tell the press that"],[9567,9755,"Zosha Sanchez cheated"],[9755,9855,"at the competition."]],"7":[[696,817,"The results of the Math Olympiad"],[817,896,"are being contested."],[896,1001,"They say you cheated,"],[1001,1109,"Zosha Sanchez."],[1109,1176,"Are you going to"],[1176,1276,"accept the rematch?"],[1288,1413,"Did you cheat?"],[1438,1601,"Leave my daughter alone."],[1601,1718,"Mom, don't worry."],[1718,1814,"I got this."],[1947,2085,"I'm going to prove to the world"],[2085,2306,"what a real math genius looks like."],[2306,2494,"And prove that Becky Caine"],[2494,2598,"is the real cheat."],[3057,3128,"Damn it."],[3153,3269,"Academics are questioning"],[3269,3353,"the results."],[3365,3428,"They want to know"],[3428,3516,"how a small-town girl"],[3516,3641,"from the middle of nowhere"],[3641,3728,"finished first."],[3757,3887,"They think we helped her cheat."],[3953,4058,"They want a rematch."],[4095,4220,"Then let's host a rematch."],[4387,4562,"We can live stream the entire thing."],[4562,4637,"We can even have"],[4637,4763,"in-person judges present."],[5463,5613,"I'll be a judge for the rematch."],[5647,5776,"Becky Caine?"],[5943,6126,"The youngest Nobel Prize winner"],[6126,6247,"in mathematics."],[6247,6435,"Becky Caine, it's an honor."],[6519,6610,"Okay then."],[6627,6744,"Looks like it's settled."],[6773,6869,"We'll host a rematch."],[6869,7019,"Becky, you'll be our head judge."],[7098,7240,"Let's see if Zosha Sanchez"],[7240,7353,"really is a genius."]],"8":[[392,513,"You can do this, Zosha."],[617,725,"I believe in you."],[1109,1418,"Long time no see, my dear professor."],[1609,1739,"Oh, what is that stench?"],[1856,1943,"It's you!"],[1989,2248,"It's you, you thief!"],[2289,2431,"Mom!"],[2431,2619,"Mom, careful of your heart."],[2844,2990,"And you're that low-down fraud"],[2990,3153,"that nixed my mother's research."],[3165,3211,"But the one"],[3211,3315,"who committed plagiarism"],[3315,3499,"is the old hag you're holding up."],[3578,3770,"I hear you're a stinky janitor"],[3770,3983,"at some backwater high school now,"],[3983,4045,"Margaret."],[4129,4220,"How pathetic."],[4241,4316,"What matters is"],[4316,4587,"what's in our heads and our hearts."],[4713,4846,"And yours is black."],[4946,5167,"A farm girl and a janitor."],[5167,5255,"What a pair."],[5284,5380,"I can't tell"],[5380,5492,"who's going to embarrass"],[5492,5609,"whom more?"],[5684,5768,"Ignore her, Mom."],[5768,5926,"She's incapable of distinguishing"],[5926,6081,"between real intellect"],[6081,6143,"and memorized"],[6143,6256,"elitist talking points."],[6256,6352,"Isn't that right,"],[6352,6527,"Miss Overpriced Diploma?"],[6560,6719,"You could try to talk smart,"],[6735,6852,"but the whole world believes"],[6852,6990,"Margaret is the one"],[6990,7136,"who stole my research."],[7152,7357,"I'll prove her innocence."],[7357,7524,"Then they'll think you're a cheat, too."],[7586,7782,"Even if you're really a genius,"],[7782,7899,"no one is going to believe you."],[7953,8074,"I have a Nobel Prize."],[8137,8233,"And you're still wearing"],[8233,8420,"donation rags from Goodwill."],[8521,8754,"You should quit while you still can."],[8812,8888,"She's right."],[9004,9104,"Zosha, I'm just gonna"],[9104,9246,"drag you down so you..."],[9288,9480,"No, no, no, Mom."],[9522,9638,"I want you to witness me"],[9638,9751,"taking back everything"],[9751,9864,"that belongs to you."],[9955,10043,"Oh!"],[10085,10193,"I forgot to mention."],[10239,10347,"I'll be head judge"],[10347,10481,"at today's contest."],[10660,10748,"I'm so sure she's gonna"],[10748,10877,"rig the contest against you."]],"9":[[41,187,"I shouldn't have come here with you."],[346,508,"I'm just going to drag you down."],[563,729,"They all think I'm a fraud."],[1084,1151,"Hey, Mom."],[1288,1351,"You're not."],[1559,1730,"I must win this contest."],[1764,1872,"Only then will I prove"],[1872,2102,"that Becky Caine stole Mom's research"],[2102,2202,"and will be able to afford"],[2202,2298,"Mom's surgery."],[2323,2402,"Welcome to"],[2402,2598,"the National Math Olympiad."],[2652,2794,"The judges we have here today"],[2794,2952,"are esteemed professors"],[2952,3123,"from top Ivy League universities,"],[3140,3290,"including the one and only"],[3290,3440,"Professor Becky Caine,"],[3486,3574,"Nobel Prize winner"],[3574,3737,"for her work on microchip technology"],[3737,3812,"ten years ago."],[3953,4133,"I look better in-person, don't I?"],[4191,4329,"The contest begins."],[4341,4558,"Let's invite the first two contestants up."],[5910,5985,"Incorrect."],[5993,6064,"Incorrect."],[6564,6690,"Get off the stage!"],[6744,6848,"These are our nation's"],[6848,6990,"future experts?"],[7065,7207,"I'm so disappointed."],[7294,7449,"Don't worry, Professor Caine."],[7449,7545,"There's one more."],[7590,7707,"The answer's infinity."]],"10":[[12,83,"There's one more."],[129,254,"You mean that farm barbie"],[254,371,"from hillbilly town?"],[396,467,"The one who's going to"],[467,600,"a community college?"],[650,792,"What's a girl doing in math anyway?"],[792,917,"I mean, is the circumference"],[917,1030,"of her breast bigger"],[1030,1163,"than the pig she feeds?"],[1184,1338,"That's the only number I care about."],[1393,1680,"Margaret Harmon and Zosha Sanchez,"],[1718,1893,"you're about to fall into my trap."],[1939,2056,"I'll make sure you both"],[2056,2218,"never return to the arenas"],[2218,2369,"of math and science."],[2373,2519,"Please welcome the math genius"],[2519,2644,"from West Virginia,"],[2669,2886,"Zosha Sanchez."],[3253,3353,"Enjoy the show."],[5084,5221,"I will show the world"],[5221,5380,"what small town girls are made of."]],"11":[[58,246,"I don't care about my dreams anymore."],[358,567,"I only care about your future, Zosha."],[946,1151,"That's your so-called genius?"],[1176,1280,"Look at her shoes."],[1301,1468,"She belongs at a swamp,"],[1468,1655,"not at a national contest."],[1701,1881,"I checked her SAT score."],[1881,2181,"It's just 584 out of 800."],[2181,2298,"That's not genius at all."],[2364,2535,"Oh, that is a C-minus."],[2569,2752,"I only want C's when it's a cup size."],[2752,2911,"well, heck, D's are even better."],[3357,3457,"The poor can only attend"],[3457,3532,"community college"],[3532,3691,"because they're morons."],[3691,3778,"Just give up"],[3778,3991,"and go back to milking cows."],[4066,4187,"Poor loser."],[4229,4458,"She can't even get to the real university."],[4458,4733,"Poor people don't have great genes."],[4833,5013,"They're meant to work on farms"],[5013,5263,"and wear rags like hers forever."],[5288,5463,"The bottom rungs of the society"],[5463,5634,"should stay at the bottom."],[5655,5834,"Don't bring your cow dung stench here."],[5980,6106,"I told you, Zosha."],[6151,6310,"You're too dumb and poor"],[6310,6456,"to compete on this stage."],[6531,6627,"You can't even get into"],[6627,6727,"the Ivy League like me."],[6806,6965,"I don't need to buy my way to prestige"],[6965,7069,"when I have the brains."]],"12":[[54,212,"I don't need to buy my way to prestige"],[212,304,"when I have the brains."],[304,425,"I'd rather spend the money"],[425,558,"on Mom's heart surgery."],[625,767,"What's a woman doing"],[767,863,"going to school anyway?"],[863,967,"She should just drop out."],[967,1146,"Marry her hillbilly cousin,"],[1146,1251,"pop out seven kids"],[1251,1368,"like the rest of her town."],[1401,1463,"You should say that"],[1463,1601,"to the woman sitting next to you."],[1664,1860,"Uh, Professor Becky Caine"],[1860,1981,"is an exception."],[1997,2189,"She has a Nobel Prize."],[2385,2469,"The double standards"],[2469,2765,"you so-called elitist academics hold."],[2765,2940,"I'm so happy I'm not a part of your group."],[2940,3244,"I am just here to win the prize money"],[3244,3370,"to take care of my mom."],[3370,3528,"Okay, don't try distracting us,"],[3528,3678,"Zosha Sanchez."],[3678,3778,"Explain."],[3824,3978,"Someone with low scores like that"],[3978,4058,"could have never"],[4058,4195,"solved this math problem."],[4241,4425,"Did someone help you cheat?"],[4425,4567,"Is it your mentor?"],[5046,5100,"No."],[5100,5230,"They're going to attack her"],[5230,5313,"because of me."],[5543,5634,"If you're so curious"],[5634,5718,"about my test scores,"],[5718,5860,"you should check out"],[5860,5980,"my entire high school record."],[6064,6322,"I get exactly 73% on everything."]],"13":[[412,646,"Zosha, I heard your mother's ill"],[646,775,"and you need money."],[800,892,"What do you want?"],[992,1284,"I could help you with the money, but..."],[1334,1488,"you can't score higher than me"],[1488,1576,"on anything."],[1605,1743,"I want to be valedictorian."],[1793,2006,"That money can really help mom."],[2143,2218,"It's a deal."],[2252,2519,"How about I score exactly 73%"],[2519,2581,"on everything"],[2581,2790,"and 584 on SATs?"],[2961,3011,"Fine."],[3578,3849,"I get exactly 73% on everything."],[4191,4312,"Pull up her school records."],[4629,4967,"Every test score, every assignment,"],[4984,5201,"everything is exactly 73%."],[5380,5584,"Is she manipulating her scores?"],[5584,5697,"I've never seen"],[5697,5943,"such precise scoring before."],[5972,6214,"She must be a real genius to do that."],[6598,6627,"Damn it."],[6627,6744,"She's showing off her smarts."],[6752,6840,"I can't let anyone think"],[6840,6931,"she's smarter than me."],[6977,7228,"Let me show you what real skill is."],[7269,7394,"And I don't need to cheat like you"],[7394,7440,"to do it,"],[7440,7536,"Becky Caine."]],"14":[[12,141,"And I don't need to cheat like you"],[141,200,"to do it,"],[200,308,"Becky Caine."],[383,538,"Did she just accuse Professor Caine"],[538,604,"of cheating?"],[629,709,"We weren't mentored"],[709,867,"by the same teacher for nothing."],[867,921,"Wait."],[921,1092,"She's your underclassman?"],[1397,1593,"Not only is she my underclassman,"],[1614,1780,"but our mentor is here too."],[1805,1897,"Is that..."],[1960,2097,"That's Margaret Harmon."],[2352,2460,"Becky's right,"],[2506,2631,"everyone's gonna attack Zosha"],[2631,2702,"because of me."],[2752,2794,"That's right."],[2869,3032,"Not only is Margaret Harmon"],[3032,3278,"the one who taught me all of my math,"],[3278,3516,"but she saved me from my orphan life."],[4045,4120,"I love it."],[4437,4550,"She is my mother."],[4692,4971,"Your adoptive mother is the fraud"],[4971,5150,"who was stripped of all of her honors"],[5150,5384,"for plagiarizing Dr. Caine's thesis?"],[5426,5563,"Like mother, like daughter."],[5563,5663,"It's like I was saying."],[5689,5818,"Women should just stay at home,"],[5818,5922,"popping out babies,"],[5922,6047,"making sandwiches."],[6122,6214,"That's why they need to"],[6214,6335,"cheat to get ahead."],[6356,6552,"How dare she show her face again."],[6552,6727,"Absolutely detestable."],[6727,6861,"What an embarrassment."],[6898,7040,"Get her off the stage!"],[7211,7411,"Leave my daughter out of this!"]],"15":[[8,196,"Leave my daughter out of this."],[246,417,"Hello again, Professor."],[437,571,"I'm surprised you'd be arrogant enough"],[571,658,"to come back."],[750,871,"And this time,"],[900,1167,"to help your trailer trash daughter cheat."],[1167,1305,"I didn't cheat."],[1313,1418,"And I'm not here"],[1418,1589,"to help anyone cheat either."],[1589,1747,"Drop the act."],[1776,2072,"We all know how you stole my research"],[2072,2281,"trying to win a Nobel Prize."],[2281,2373,"And now you're helping"],[2373,2452,"your daughter cheat"],[2452,2648,"after you've done it once already."],[2648,2840,"You have no shame."],[2840,2944,"You're both frauds"],[2944,3132,"and you will be punished."],[3290,3353,"Wait."],[3374,3511,"Zosha Sanchez's mentor"],[3511,3661,"is Margaret Harmon?"],[3661,3791,"The once renowned mathematician."],[3791,3916,"The computer scientist."],[3916,4062,"I remember her previous work."],[4062,4149,"A greatly advanced"],[4149,4291,"microchip technology before."],[4325,4466,"With her abilities,"],[4466,4579,"I wouldn't be surprised"],[4579,4725,"if she helped Zosha cheat"],[4725,4863,"to solve the supposedly"],[4863,5013,"unsolvable math problem."],[5100,5238,"So we've been fooled."],[5405,5547,"Zosha Sanchez really isn't"],[5547,5659,"a genius after all."]],"16":[[16,116,"You're both frauds"],[116,304,"and you will be punished."],[375,504,"It's just us alright?"],[571,679,"We'll be okay."],[679,767,"Okay?"],[767,850,"I'm okay."],[946,1059,"Mom, I'm okay."],[1747,1922,"No wonder she was able to solve"],[1922,2110,"this impossible math problem."],[2110,2227,"She cheated."],[2256,2377,"Shame on you!"],[2402,2560,"We don't want them here!"],[2560,2744,"Drop out now!"],[2752,2848,"Drop out!"],[2852,2927,"Drop out!"],[2940,3023,"Drop out!"],[3032,3115,"Drop out!"],[3123,3215,"Drop out!"],[3219,3315,"Drop out!"],[3328,3574,"Oh, isn't this scene familiar?"],[3611,3691,"Drop out!"],[3703,3753,"Drop out!"],[3762,3974,"Margaret Harmon is a fraud."],[3974,4187,"She stole her students' work."],[4571,4696,"Poor girl can't even prove"],[4696,4771,"that she deserves to"],[4771,4929,"go to a real university."],[4942,5080,"Yeah, farmhouse brat."],[5080,5221,"Run back to the hills."],[5221,5392,"Your hillbillies don't deserve to stand"],[5392,5497,"where we stand."],[5768,5897,"As head of the math department"],[5897,6018,"at CalSTEM,"],[6018,6231,"I represent all of the contestants."],[6231,6506,"We hereby call for Zosha Sanchez"],[6506,6656,"to drop out!"]],"17":[[16,254,"You may be the best in a trailer park,"],[266,367,"but even the dumbest of us"],[367,450,"Ivy League"],[450,608,"are leagues above you."],[638,775,"If we can't solve it,"],[775,917,"there's no way she could've."],[925,1096,"It's unfair that this sob story cheated"],[1096,1267,"at the National Math Olympiad."],[1284,1376,"She couldn't even get here"],[1376,1534,"on diversity acceptance."],[1534,1730,"She had to cheat her way here."],[1747,1826,"You're all so sore"],[1826,1956,"for losing someone like me."],[2227,2352,"You cheat!"],[2665,2777,"You may dress nicer,"],[2777,2948,"but you all have no class."],[2948,3023,"Cheater!"],[3057,4008,"Cheater!"],[4020,4254,"I'm not interested in holding rank"],[4254,4396,"amongst you superficial"],[4396,4491,"brand lovers,"],[4491,4675,"but I won't let you call my mom a fraud."],[4813,4954,"So watch this, Becky Caine."],[5067,5221,"Systems activate"],[5221,5447,"unsolvable math problem number two."],[5447,5584,"Micrometer technology's"],[5584,5739,"three hardest math problems."],[5739,5864,"Question hash two."],[5864,6081,"Difficulty increased by 100 times."],[6081,6185,"Let's make a bet."],[6185,6310,"Let's see who can solve"],[6310,6531,"the next unsolvable math problem"],[6577,6685,"fair and square."]],"18":[[0,158,"And when I beat you, Becky Caine,"],[158,250,"you will give back"],[250,375,"what you owe my mother."],[375,483,"Her Nobel Prize"],[483,654,"and all of her research funding."],[684,800,"I think that's a great idea."],[817,867,"You can watch"],[867,1030,"the great Professor Caine at work."],[1030,1071,"True,"],[1121,1226,"you haven't published"],[1226,1297,"in 10 years."],[1317,1455,"Winning against this brat"],[1455,1609,"on national television"],[1609,1751,"would make for a great comeback."],[1847,1972,"I can't let everyone realize"],[1972,2223,"I'm actually just a rich idiot."],[2285,2339,"I know"],[2339,2464,"you're going to be jealous"],[2464,2581,"because Margaret's portrait"],[2581,2673,"was replaced with mine"],[2673,2815,"in the Math Hall of Fame,"],[2823,2977,"but how could I lower myself"],[2977,3148,"to compete against the likes of you?"],[3169,3215,"True."],[3215,3324,"You know Becky is"],[3324,3490,"much too important for this."],[3499,3620,"Yeah, we'll see if you can even"],[3620,3766,"solve the problem first,"],[3782,3933,"but if you can't,"],[3933,4179,"you and your mother will be exiled"],[4179,4350,"from math and science forever."],[4400,4579,"No, Zosha, think of your career."],[4579,4713,"You can't take that risk."],[4804,4846,"Deal."],[4942,5034,"Trust me, Mom."],[5080,5242,"I believe in all the math you taught me."],[5576,5705,"Boo!"]],"19":[[12,91,"Do you even know"],[91,229,"what you're talking about?"],[271,517,"You know that male mathematicians"],[517,700,"have struggled with these equations"],[700,796,"for ages."],[796,984,"Each problem is significantly"],[984,1138,"more difficult than the last."],[1138,1230,"The first problem"],[1230,1434,"took Ivy League math professors"],[1434,1555,"decades to solve."],[1555,1639,"The second problem"],[1639,1847,"would have taken Einstein centuries."],[1847,1931,"Precisely."],[1931,2085,"If the first problem you solved"],[2085,2185,"was basic mode,"],[2185,2385,"then the second problem is God-Tier."],[2385,2531,"It's a hundred times more difficult"],[2531,2665,"than the first problem."],[2665,2882,"How can a girl handle that?"],[2940,3069,"Our rivals across the sea"],[3069,3278,"just recently solved the second problem."],[3278,3495,"So how do you, a high schooler"],[3495,3728,"with no money and no resources,"],[3728,3812,"solve it?"],[3849,4004,"Zosha Sanchez."],[4037,4099,"You really think"],[4099,4237,"someone dressed like you"],[4237,4346,"could solve this?"],[4346,4571,"And your name will go down in history?"],[4679,4783,"That's what she gets"],[4783,4979,"for punching higher than her weight."],[4979,5134,"Go back to being a clown"],[5134,5276,"at your town rodeo!"],[5309,5438,"You know, I don't care about"],[5438,5568,"being in any Hall of Fame."],[5651,5734,"But my abilities"],[5734,5839,"aren't for a cheat like you"],[5839,5910,"to decide."],[5910,6047,"How dare you call me a cheat!"],[6047,6168,"You know, you'd do anything"],[6168,6281,"for fame and glory."],[6289,6473,"But I would never sink down"],[6473,6556,"to your level."],[6573,6852,"You don't even have the brains"],[6852,7036,"to know whether I'm correct or not."],[7036,7240,"I am here thanks to my mother."],[7278,7361,"So why don't we bring out"],[7361,7465,"the second math problem?"],[7494,7657,"That might be against the rules."],[7657,7749,"Let her have it."],[7807,7891,"I want to watch her fail"],[7891,7982,"in front of everyone."],[8041,8195,"Here's your second problem, Zosha."]],"20":[[20,246,"And the second problem is"],[250,458,"Strong Goldbach's Conjecture?"],[579,788,"This problem requires expertise"],[788,950,"in number theory, topology,"],[950,1142,"and mathematical modeling to solve."],[1142,1376,"There is no way she can solve it."],[1376,1564,"Weak Goldbach's Conjecture"],[1564,1760,"wasn't solved until 2013."],[1760,2068,"Goldbach came up with it in 1742."],[2068,2264,"Strong Goldbach's Conjecture"],[2298,2523,"remains unsolved even today."],[2552,2673,"It took the world 300 years"],[2673,2848,"just to solve the easy version of this."],[2848,2919,"Yes."],[2919,3044,"Now if this can be proven,"],[3044,3111,"it will change"],[3111,3282,"computer science and cryptology"],[3282,3357,"forever."],[3370,3666,"Zosha Sanchez, you can still give up now."],[3707,3816,"You just have to admit"],[3816,3953,"on national television"],[3974,4124,"that you're a fraud,"],[4158,4266,"and apologize to me."],[4304,4400,"I wouldn't be so quick"],[4400,4554,"to your own demise, Professor."],[4683,4913,"I will soon be the only person"],[4934,5138,"to solve Goldbach's Conjecture."],[5505,5647,"I will make math history"],[5647,5805,"and prove that you're a cheat."]],"21":[[154,296,"Oh, you've got nothing on me."],[329,542,"But, but when you fail, just remember,"],[558,742,"you brought this upon yourself."],[859,1001,"Stupid girl."],[1001,1167,"This problem is impossible."],[1167,1380,"I'll have you and your precious mother"],[1380,1639,"exiled from math forever."],[1805,1993,"Can Zosha really solve this?"],[2018,2118,"We both tried proving"],[2118,2273,"Strong Goldbach's Conjecture."],[2273,2352,"I mean, even with the help of"],[2352,2510,"nationally recognized mathematicians,"],[2510,2602,"I don't know about this one."],[2602,2715,"This might be, um..."],[2727,2806,"Hopeless."],[2902,2994,"Wait, wait!"],[3023,3107,"She's working!"]],"22":[[183,417,"She's so dumb, she's falling asleep!"],[417,550,"No wonder she was able to"],[550,784,"solve this impossible math problem."],[784,905,"She cheated!"],[1463,1584,"Margaret, your student is"],[1584,1780,"just as arrogant as you are."],[1780,1881,"Claiming she can prove"],[1881,2072,"Strong Goldbach's Conjecture?"],[2102,2273,"When no one's ever done it before?"],[2377,2481,"It's okay, Zosha."],[2560,2690,"Strong Goldbach's Conjecture"],[2690,2794,"is nearly impossible."],[2831,2890,"You don't have to"],[2890,2994,"force yourself for me."],[3065,3219,"Zosha Sanchez,"],[3236,3332,"drop out and leave"],[3332,3499,"if you're not going to solve anything."],[3499,3724,"We're not here for some clown show."],[3766,4045,"Go back to your farm and hump your bull."],[4045,4175,"I'd pay to see that."],[4291,4562,"The real show starts now."]],"23":[[1159,1230,"Damn it!"],[1297,1493,"She can't actually be solving it, right?"],[1651,1772,"She's actually solving it."],[1826,1993,"No, no, it can't be, it can't be."],[1993,2223,"No one's solved this in like 300 years."],[2223,2310,"Don't let her fool you."],[2310,2585,"She, she's just writing gibberish on screen."],[2615,2844,"Stop embarrassing yourself, Sanchez."],[2844,2936,"We can all see through"],[2936,3061,"your scam act."],[3098,3361,"Fraud is a serious criminal offense."],[3361,3490,"I'll have you arrested."],[3507,3687,"You know, I agree with you,"],[3687,3762,"Professor Caine."],[3803,3912,"Frauds like you"],[3912,4074,"who stole my mother's research"],[4074,4200,"and published it as their own,"],[4200,4383,"that is indeed a crime."],[4416,4517,"I dare you to call the police"],[4517,4683,"because the one who should be arrested"],[4683,4767,"is you."],[4767,4904,"Okay, who said anything"],[4904,5013,"about calling the police?"],[5013,5213,"I'm just giving you a chance to hurry up."],[5263,5359,"You all doubt me."],[5409,5601,"My test scores, my grades."],[5651,5739,"You think that my mom"],[5739,5834,"helped me cheat."],[5834,6031,"But Margaret Harmon is the one"],[6031,6139,"who adopted me."],[6181,6268,"She taught me how to be"],[6268,6410,"a good mathematician"],[6431,6544,"and a good person."],[6564,6677,"She is no fraud."],[6802,6911,"I am so..."],[6969,7178,"proud to be your daughter."],[7336,7528,"And I am proud to be your student."],[8237,8425,"I will make math history today,"],[8491,8658,"and prove her innocence."]],"24":[[0,150,"That proof that she's working off of,"],[150,254,"that looks like the proof of"],[254,396,"Weak Goldbach's Conjecture."],[412,575,"Did somebody leak that to her?"],[617,700,"No, impossible."],[700,842,"That information is classified"],[842,917,"due to the impact that"],[917,1013,"it has on cryptography."],[1013,1172,"I mean, not to mention..."],[1347,1476,"She's going beyond that now."],[1530,1622,"She's solving it."],[1793,1876,"She's solving"],[1876,2031,"Strong Goldbach's Conjecture."],[2085,2281,"I mean, that, that has never been done."],[2281,2452,"Let's go watch history be made."],[2844,2915,"I solved it."],[2969,3069,"She really did it."],[3199,3370,"How, how could she?"],[3403,3570,"It must be Margaret Harmon."],[3570,3753,"They cheated together."],[3766,3899,"She wants revenge on me."],[3912,4074,"They're plotting to take everything"],[4074,4162,"away from me."],[4208,4308,"I can't believe it."],[4329,4408,"No one has solved"],[4408,4529,"Strong Goldbach's Conjecture"],[4529,4650,"in 300 years."],[4650,4821,"And Zosha has solved it."],[5113,5359,"Oh, you make me so proud,"],[5359,5484,"Zosha."],[5926,6051,"You did it."],[6210,6293,"You know,"],[6293,6477,"I don't really mind your insults."],[6477,6623,"You accused my mom of things"],[6623,6681,"she didn't do."],[6681,6802,"You called her a fraud"],[6802,6873,"and you stripped her"],[6873,7094,"of her positions and her honors."],[7094,7315,"I solved your math problems."],[7615,7786,"Now apologize to my mother."]],"25":[[208,316,"Apologize?"],[316,379,"To her?"],[500,575,"Never."],[625,663,"So what?"],[663,804,"You've submitted an answer."],[825,1030,"It has to be proven correct first."],[1055,1192,"It's just a bunch of symbols."],[1205,1330,"Anybody can fake that"],[1330,1468,"and everyone knows hillbillies"],[1468,1555,"are illiterate."],[1664,1843,"You're an esteemed math professor"],[1843,1985,"from which Ivy League again?"],[2039,2122,"Harvard."],[2185,2252,"Well, I guess"],[2252,2381,"they don't teach class over there."],[2502,2756,"Oh, and what do you know about class?"],[2756,2902,"You're just a high school brat"],[2902,3090,"from some backwater town."],[3090,3228,"High society"],[3249,3415,"is just an extra moonshine."],[3415,3516,"I'll bet my job"],[3516,3674,"that she wrote nonsense"],[3674,3924,"on her paper like an ignorant jackass."],[3999,4129,"I'll take that bet then."]],"26":[[62,187,"I'll take that bet then."],[258,513,"How can she be so confident?"],[529,663,"That proof,"],[663,792,"that is top secret proof"],[792,863,"of the weak version"],[863,996,"of Goldbach's Conjecture."],[996,1172,"It's classified information."],[1172,1238,"You're right,"],[1238,1384,"that is the classified proof."],[1409,1497,"I was part of the group"],[1497,1568,"of mathematicians"],[1568,1685,"that helped confirm it."],[1697,1814,"So, I remember."],[1868,2093,"Zosha Sanchez is guilty of"],[2093,2252,"stealing state secrets."],[2252,2369,"I know what it is now."],[2535,2694,"Margaret Harmon was there"],[2694,2827,"when we confirmed the proof."],[2827,2982,"It is she who leaked"],[2982,3144,"classified information"],[3144,3324,"to Zosha Sanchez."],[3353,3620,"Stop making up false accusations."],[3620,3762,"I wasn't even there."],[3845,4012,"Oh, come on, Margaret."],[4033,4154,"You plagiarized my thesis."],[4195,4371,"Stealing classified information"],[4371,4500,"is nothing to you."],[4500,4662,"They're both frauds!"],[4662,4863,"They can never be as smart as men."],[4863,5038,"Throw them in prison!"],[5038,5155,"Security!"],[5167,5251,"Hey, no, no, no."],[5251,5376,"I figured this problem out myself."],[5376,5476,"Do not touch my mother."],[5480,5634,"Do not touch my mom."],[5634,5764,"I figured it out myself."],[5764,5872,"I didn't plagiarize anything."],[5872,5939,"Mom!"],[5968,6035,"Mom!"]],"27":[[33,162,"I figured it out myself."],[162,283,"I didn't plagiarize anything."],[283,362,"Mom, Mom."],[362,496,"Please be gentle with my mother."],[496,554,"Please."],[554,779,"You cannot frame me without evidence."],[779,996,"Zosha, you're just a high school brat."],[996,1138,"No one's going to believe you proved"],[1138,1330,"Strong Goldbach's Conjecture"],[1330,1551,"when no one's done it for 300 years."],[1597,1718,"You're just afraid that"],[1718,1931,"I'm going to expose you for your crimes."],[1964,2118,"You're no math genius."],[2131,2210,"Look around,"],[2252,2377,"you're just a kid."],[2377,2519,"Here, let's ask the judges."],[2519,2652,"Do you believe her?"],[2677,2765,"Professor Walker?"],[2765,2848,"Professor Douglas?"],[2848,3061,"Not from a girl who can't even afford"],[3061,3174,"appropriate clothing"],[3174,3386,"to wear at a national contest."],[3386,3482,"All that moonshine"],[3482,3645,"has rotted her tiny brain."],[3645,3787,"No, of course not."],[3787,3883,"See, there's a reason"],[3883,4070,"my portrait's the one hung up on the wall."],[4283,4450,"All you ever learned from your mother"],[4450,4604,"is how to commit fraud."],[4671,4738,"Oh..."],[4975,5184,"I'll give you one last chance."],[5184,5376,"All you have to do is admit"],[5376,5463,"that Margaret leaked"],[5463,5613,"you classified information,"],[5613,5747,"and I'll spare you."],[5747,5901,"I'll never admit to your lies."],[6018,6126,"I can't save you."],[6126,6206,"I can't save you. - Mom"],[6206,6302,"Mom."],[6360,6519,"Report them to the FBI."],[6535,6648,"No, you'll cripple"],[6648,6865,"Zosha's career forever."],[6865,7057,"You have no right to speak here."],[7057,7257,"You already lost all your respect"],[7257,7432,"when you plagiarized Dr. Caine's thesis."],[7557,7707,"You two can't win against me."],[7736,7845,"I'm the world-renowned"],[7845,7949,"math genius now,"],[7949,8137,"after stealing your research."],[8158,8295,"Everyone believes me."],[8350,8441,"Crush them!"],[8512,8583,"Stop!"],[8637,8704,"Stop it!"]],"28":[[237,291,"Stop!"],[346,396,"Stop it!"],[729,984,"Mr. Jensen, the CEO of Apollo Tech."],[992,1084,"The biggest player"],[1084,1192,"in the microchip industry."],[1192,1280,"And Mr. Reeds,"],[1280,1372,"the organizer of"],[1372,1555,"the National Math Olympiad."],[1572,1672,"You are about to imprison"],[1672,1847,"the math genius of the century."],[1876,2022,"Math genius?"],[2064,2231,"She's hardly a math genius, she-"],[2281,2406,"You let her go immediately!"],[2840,2907,"Thank you."],[3165,3228,"Who are you?"],[3274,3315,"The leaders of"],[3315,3432,"the microchip industry."],[3453,3566,"They chose these problems"],[3566,3674,"for the Math Olympiad."],[3745,3874,"We'd love to have a genius like you"],[3874,3970,"at Apollo Tech."],[4091,4270,"Mr. Jensen, years ago,"],[4270,4383,"Margaret Harmon"],[4383,4533,"plagiarized my thesis."],[4558,4796,"Now, she's leaked the classified proof"],[4796,4946,"of Goldbach's Conjecture"],[4946,5063,"to her daughter, Zosha."],[5063,5263,"Report them to the FBI."],[5296,5451,"Please, look at the work."],[5472,5634,"It's exactly the same as the proof"],[5634,5755,"we confirmed back then."],[5784,5964,"It is indeed the same classified proof"],[5964,6089,"of Weak Goldbach's Conjecture."],[6089,6264,"Then it's time to call the FBI!"],[6264,6448,"In fact, it's gone far beyond the proof"],[6448,6619,"that we confirmed several years ago."],[6619,6660,"This is"],[6660,6790,"Strong Goldbach's Conjecture."],[6831,6952,"Zosha's solved it!"]],"29":[[4,129,"Zosha Sanchez is just"],[129,283,"a high school vagabond!"],[300,408,"And a girl!"],[408,538,"Look at her clothes!"],[617,821,"I promise my work is 100% sound."],[829,1001,"Okay, let's check it then."],[1001,1084,"Perhaps Ms. Caine here"],[1084,1167,"is unaware that"],[1167,1288,"checking a proof like this"],[1288,1497,"requires incredible computing power."],[1497,1693,"Power of 10 to the 18th."],[1726,1785,"Correct,"],[1810,1901,"we would have to take this"],[1901,1981,"to the nation's biggest"],[1981,2106,"supercomputer facility"],[2106,2173,"in order to confirm"],[2173,2331,"the accuracy of Zosha's work."],[2331,2502,"We could take all of the computing power"],[2502,2577,"in this room,"],[2577,2711,"and at best we could calculate"],[2711,2940,"perhaps 5% of the proof."],[3007,3132,"I thought that our goal here"],[3132,3240,"was to advance"],[3240,3399,"microchip technology."],[3399,3541,"If this proof doesn't do that,"],[3541,3728,"then isn't it kind of useless"],[3728,3807,"to our industry?"],[3841,3924,"I'm willing to submit"],[3924,4049,"my work to be tested."]],"30":[[8,137,"I'm willing to submit my work"],[137,221,"to be tested."],[221,337,"If your proof fails,"],[337,479,"that means you and your mother,"],[479,554,"Margaret Harmon,"],[554,696,"are both frauds."],[696,946,"And we'll have you both thrown in prison"],[946,1113,"for the rest of your lives."],[1205,1455,"Zosha, are you sure you want to do this?"],[1526,1668,"I'm 100% confident."],[1814,1926,"It was my mother's dream"],[1926,2010,"to work on this project"],[2010,2181,"before Becky Caine stole it."],[2260,2364,"I support this."],[2439,2565,"If Zosha's proof is correct,"],[2585,2673,"we'll have a math genius"],[2673,2727,"that could help us"],[2727,2844,"win the global chips war."],[2911,3057,"We should support young blood, Jensen."],[3165,3257,"Then let's do it."],[3374,3541,"And I will gather"],[3541,3670,"all of the computing power"],[3670,3832,"in Silicon Valley to check."],[3832,3887,"What?"],[3924,4145,"All the power of Silicon Valley?"],[4179,4237,"Well, that will overload"],[4237,4304,"the power grid"],[4304,4558,"and cause a city-wide blackout."],[4558,4783,"The financial ramifications of this"],[4783,4892,"are unfathomable."],[4925,5096,"Will this kid even be held accountable"],[5096,5180,"for all of that?"],[5251,5484,"The pressure is great, Zosha, but..."],[5551,5618,"it's okay."],[5722,5951,"I will be the person held accountable"],[5951,6093,"if Zosha's proof fails."]],"31":[[12,162,"I will be the person held accountable"],[162,254,"if Zosha's proof is-"],[254,316,"No, no, Mom."],[316,371,"You can't."],[392,513,"No. - Yes, Zosha."],[588,813,"You are my greatest pride."],[871,1146,"And our nation's greatest hope."],[1222,1272,"For years,"],[1272,1422,"our country has been lagging behind,"],[1422,1589,"and I do this for our country."],[1626,1772,"And for the women in STEM."],[1772,2010,"But most of all, I do it for you."],[2152,2306,"Because I believe in you, Zosha."],[2381,2456,"I do."],[2464,2552,"Margaret Harmon,"],[2552,2681,"you've already been exiled"],[2681,2831,"from the field of mathematics."],[2831,3036,"Why do we even care about you anymore?"],[3065,3190,"Well, what if I add my weight?"],[3265,3353,"I'll be held accountable"],[3353,3474,"if Zosha's proof fails."],[3499,3603,"And I'm in as well."],[3707,3858,"The CEO of Apollo Tech?"],[3966,4154,"If you back her up, too, then..."],[4270,4346,"Thank you."],[4433,4646,"Thank you for believing in Zosha."],[4788,4859,"Perfect."],[4904,5034,"I can get rid of you two"],[5034,5150,"once and for all."],[5188,5267,"Oh, and I just got"],[5267,5355,"the governor's approval"],[5355,5526,"to use all of the computing power"],[5526,5680,"from Silicon Valley"],[5680,5843,"to check Zosha's proof."],[5843,5914,"Amazing."],[5943,6051,"If I'm correct,"],[6051,6202,"I want Becky Caine's work"],[6202,6410,"to be re-examined for plagiarism."]],"32":[[0,104,"Okay, we don't even know"],[104,191,"if she's correct yet."],[191,321,"Let's not be talking about"],[321,492,"checking award-winning work."],[575,684,"The bet is still on."],[750,921,"Margaret Harmon and Zosha Sanchez"],[921,1067,"will be exiled from STEM"],[1067,1234,"if the proof fails."],[1272,1409,"Are you sure about this, Zosha,"],[1484,1593,"despite the consequences?"],[1710,1797,"Absolutely."],[1985,2102,"Fantastic."],[2260,2356,"All of the computer power"],[2356,2515,"from Silicon Valley will be transferred"],[2515,2702,"to the AI in this room"],[2702,2840,"in the next 10 minuites."],[3098,3203,"So is that a solution"],[3203,3274,"that would potentially"],[3274,3345,"work for you?"],[3411,3495,"Stop the meeting."],[3495,3611,"Yes!"],[3695,3812,"Nice, nice, nice."],[3924,4083,"Zosha Harmon is on the verge"],[4083,4275,"of the next great tech discovery."],[4287,4425,"But we need your computing power"],[4425,4521,"to finish the test."],[4554,4792,"If you agree, please hit the yes button."],[4792,4842,"Thank you."],[4842,5005,"The number one tech company in the world"],[5005,5080,"needs my help?"],[5080,5176,"Oh my gosh!"],[5192,5326,"A woman in STEM?"],[5326,5559,"Better microchips and GPUs,"],[5559,5701,"hells yeah!"],[5701,5776,"Yes!"],[5926,6139,"Everyone hit yes on chip advancement."],[6389,6481,"Oh my God."],[6560,6823,"This will change our industry forever."],[6873,6973,"It looks like even those"],[6973,7107,"outside of Silicon Valley"],[7107,7223,"are supporting this research."],[7273,7478,"The world believes in the work we do."],[7503,7595,"They understand how"],[7595,7728,"monumental it is."],[7761,7941,"Computing power acquired."],[7953,8037,"We may begin."],[8037,8170,"I won't disappoint them."]],"33":[[1976,2089,"You can do this, Zosha!"],[2089,2277,"Make all the women in tech proud!"],[2277,2331,"Yes!"],[2331,2439,"Go Zosha!"],[2456,2610,"Max my GPU!"],[2644,2731,"Zosha!"],[2736,2827,"Zosha!"],[2831,2927,"Zosha!"],[2948,3028,"Zosha!"],[3036,3103,"Zosha!"],[3115,3186,"Zosha!"],[3199,3274,"Zosha!"],[3274,3345,"Accelerate!"],[3349,3407,"Accelerate!"],[3411,3465,"Accelerate!"],[3470,3545,"Accelerate!"],[3545,3607,"Accelerate!"],[3611,3691,"Accelerate!"],[3995,4283,"Analysis 100% complete."],[5000,5109,"Did Zosha get it?"]],"34":[[33,283,"Congratulations, Zosha Sanchez."],[304,400,"You have proved"],[400,542,"Strong Goldbach's Conjecture."],[809,1009,"You've succeeded, my child."],[1063,1217,"No one's ever done it before."],[1251,1309,"We can create"],[1309,1368,"the greatest"],[1368,1484,"encrypted microchips"],[1484,1572,"in the world now!"],[1735,1897,"History has been made."],[1972,2122,"You've kept my dream alive"],[2122,2235,"all these years."],[2302,2473,"And now you've completed it."],[2798,2886,"Zosha!"],[2886,2990,"Yeah!"],[2990,3078,"Yes!"],[3078,3174,"Zosha!"],[3349,3465,"She did it!"],[3641,3728,"Impossible."],[3728,3966,"I won our bet, Becky Caine."],[4004,4129,"Now it's time"],[4129,4308,"to apologize to my mother."]],"35":[[183,300,"On national television?"],[362,454,"You wish."],[525,729,"I'm a Nobel Prize winner."],[763,888,"The youngest professor"],[888,971,"at Princeton."],[996,1255,"You're all nothing compared to me."],[1255,1434,"You stole my mother's research."],[1434,1530,"And you tried to frame me"],[1530,1605,"for cheating."],[1651,1751,"But you failed."],[1835,2173,"It is time to check Becky Caine's work"],[2173,2289,"in the last ten years."],[2344,2410,"The world will know"],[2410,2573,"who the real fraud is."],[2573,2761,"Who are you to check my work?"],[2811,2957,"You're just trailer trash."],[2969,3186,"That suave stench of yours"],[3186,3328,"will always be an embarrassment"],[3328,3411,"to academia."],[3449,3574,"They'd rather have me than you."],[3603,3691,"You're wrong."],[3732,3837,"In academia,"],[3837,4083,"we care about merit and honesty."],[4104,4241,"If you only got that Nobel Prize"],[4241,4333,"because you plagiarized"],[4333,4429,"Ms. Harmon's work..."],[4429,4675,"Then it's our turn to strip Becky Caine"],[4675,4854,"of her honors and her position"],[4854,4979,"in the Math Hall of Fame."]],"36":[[12,66,"You wouldn't."],[104,229,"You can't."],[283,475,"If she really stole Ms. Harmon's work"],[475,563,"then it would make sense"],[563,684,"why Becky Caine hasn't done"],[684,871,"anything ever since."],[880,1046,"The only thing she ever wrote,"],[1071,1242,"she plagiarized."],[1280,1422,"What you owe my mother,"],[1422,1572,"I will have you give it all back"],[1572,1680,"ten times over."],[1714,1822,"Zosha Sanchez,"],[1822,1922,"if you can solve"],[1922,2118,"Strong Goldbach's Conjecture,"],[2156,2293,"then we were wrong about you"],[2327,2419,"and we're sorry."],[2569,2740,"You indeed are a genius."],[2740,2894,"It was Becky Caine who told us"],[2894,3007,"to sabotage you."],[3007,3153,"You're all betraying me too?"],[3211,3495,"Hey, I helped you get that position"],[3495,3628,"at CalSTEM."],[3953,4033,"Bribing students"],[4033,4170,"to help take Zosha down"],[4170,4346,"seems a bit suspicious,"],[4346,4429,"Ms. Caine."],[4429,4546,"Check Becky's work."],[4550,4621,"Exactly."],[4650,4838,"If I had to check my proof,"],[4838,5034,"then it's only fair that she does too."]],"37":[[25,200,"If I had to check my proof,"],[200,392,"then it's only fair that she does too."],[404,558,"Check her work!"],[600,742,"Check her work!"],[779,921,"Check her work!"],[959,1080,"Check her work!"],[1121,1259,"You can all shut up!"],[1372,1443,"Remember!"],[1589,1764,"I'm in the Math Hall of Fame."],[1822,1968,"There's only one person"],[1968,2114,"in the entire country"],[2114,2248,"who has the authority"],[2248,2423,"to challenge my work."],[2448,2506,"Wait, does she mean"],[2506,2594,"the Director of"],[2594,2715,"Science and Technology?"],[2736,2877,"The highest government office"],[2877,2927,"in tech?"],[2973,3040,"Could it be..."],[3119,3219,"Thomas Opphen?"],[3257,3315,"That's right."],[3399,3461,"It's me."]],"38":[[75,150,"That's right."],[262,321,"It's me."],[371,437,"It's him."],[642,784,"He corroborated with Becky"],[784,967,"to steal my research ten years ago."],[1009,1159,"I call fraud."],[1209,1313,"Margaret Harmon"],[1322,1514,"stole my research results."],[1514,1647,"I have a witness too."],[1647,1860,"And I attest that Ms. Becky Caine"],[1860,2039,"did submit her thesis to me"],[2039,2135,"three days ago."],[2135,2202,"You don't belong"],[2202,2385,"in the Math Hall of Fame anymore."],[2385,2456,"I do."],[2711,2848,"You're just in time, honey."],[2886,3098,"And Charles, my top student."],[3161,3261,"Well, I saw you were"],[3261,3390,"in a little bit of trouble,"],[3415,3549,"so of course I had to come."],[3595,3787,"I can't believe you let that loser"],[3787,3945,"turn this crowd against you."],[4120,4195,"Yeah."],[4195,4329,"Zosha may have proved"],[4329,4512,"Strong Goldbach's Conjecture."],[4512,4575,"But, um..."],[4608,4808,"I've recorded her work on here."]],"39":[[54,212,"We can claim it as our own."],[283,437,"That proof is our nation's"],[437,617,"latest top secret discovery."],[617,809,"That can make the best microchips"],[809,880,"in the world."],[913,1034,"She's stealing"],[1034,1163,"just like how she stole"],[1163,1276,"Ms. Harmon's work."],[1493,1722,"I am the Director of Science and Tech"],[1722,1822,"and that means..."],[1822,1885,"newsflash,"],[1885,2006,"we can do whatever we want."],[2006,2298,"You are despicable, Becky Caine."],[2364,2565,"My mom taught you all her math,"],[2565,2677,"and you betrayed her."],[2719,2998,"Not only did you steal her thesis,"],[2998,3174,"but you'd sleep with an old man"],[3174,3340,"for fame and power?"],[3382,3453,"So what?"],[3495,3674,"You have nothing to your name."],[3732,3849,"Who are you to judge me?"],[3887,4037,"Oh, I've heard all about you."],[4062,4308,"Just an orphan from the boonies."],[4383,4637,"Young girls raised on pig slop"],[4637,4804,"in the swamps."],[4833,4950,"Born to be stepped on"],[4950,5050,"by the likes of us."],[5113,5188,"You see,"],[5246,5363,"we're the elite."],[5447,5547,"My boyfriend is"],[5547,5726,"the Director of all things STEM."],[5776,6014,"He is the law in our field."]],"40":[[25,262,"He is the law in our field."],[304,454,"You can't arrest me with him here."],[571,684,"You hear that, everyone?"],[700,804,"She got her position"],[804,1076,"by sleeping with an old white man."],[1247,1388,"She's no math genius at all."],[1651,1981,"You and your sickly, sickly mother"],[1981,2189,"are just a waste of space."],[2218,2335,"And there is no way"],[2335,2477,"I'm gonna allow you"],[2477,2635,"to win this competition."],[2848,3103,"Well, I think there's still"],[3103,3428,"one unsolvable math problem left."],[3474,3674,"And I challenge you, Becky Caine."]],"41":[[0,62,"She's right."],[100,179,"She already solved"],[179,254,"two of the unsolvable"],[254,329,"math problems."],[329,462,"That means that she can challenge"],[462,650,"any professor at any level"],[650,742,"to a math duel."],[817,909,"Do something."],[963,1021,"We can't let them"],[1021,1126,"expose us as frauds."],[1126,1247,"Don't worry, don't worry."],[1322,1451,"We got a little secret weapon."],[1705,1964,"Sure, we'll accept your math duel."],[2035,2089,"But you have to"],[2089,2273,"defeat my student first."],[2515,2723,"Charles is the top math student"],[2723,2869,"in all of Princeton."],[3015,3244,"See, because you're such a young punk,"],[3324,3528,"you have to defeat Becky's student first"],[3528,3695,"before you could ever get a chance"],[3695,3862,"to go up against the likes of her."],[3887,3945,"Yeah."],[3958,4054,"That's right, Zosha."],[4066,4175,"It's in the rule book."],[4220,4337,"You have to be careful, Zosha."],[4387,4471,"Charles has been crowned"],[4471,4658,"the youngest Math Olympiad winner"],[4658,4783,"since even before you,"],[4783,4900,"at age 10."],[4959,5046,"I remember him."],[5046,5142,"He's a legitimate genius."],[5142,5213,"He's only studying"],[5213,5267,"with Becky Caine"],[5267,5363,"and Thomas Opphen"],[5401,5563,"for the fame and connections."],[5563,5726,"Do not underestimate him."],[5772,5864,"Scared now?"],[5897,6081,"Can you handle a real genius?"],[6147,6272,"You can still back out now,"],[6331,6402,"but you and your mother"],[6402,6539,"will be exiled forever."],[6606,6802,"Sweetie, you don't have to"],[6802,6890,"do this for me."],[6952,7002,"No."],[7123,7190,"Let's begin."]],"42":[[29,100,"Let's begin."],[621,817,"So what if you've proven the"],[817,992,"Strong Goldbach's Conjecture?"],[1013,1217,"We are already on the last step"],[1217,1330,"of the third"],[1330,1547,"unsolvable microchip problem."],[1764,1914,"That's impossible."],[1956,2097,"The last problem encompasses"],[2097,2260,"a three-body operating model"],[2260,2452,"and two-dimensional foil technology,"],[2452,2619,"which proves that 3D"],[2619,2823,"can collapse into a 2D space."],[2823,3036,"Yes, it fulfills a total paradigm shift"],[3036,3157,"as a quantitative leap."],[3157,3249,"It's the ultimate weapon"],[3249,3345,"in quantum physics."],[3345,3457,"You couldn't have solved it."],[3457,3574,"That may be a shocker"],[3574,3695,"to you hobos,"],[3737,3832,"but it's nothing for us"],[3832,3987,"when the director of science and tech"],[3987,4099,"is on our side."],[4099,4329,"I get to direct research funding"],[4329,4487,"wherever I want in this country."],[4508,4683,"Ah, corruption at its finest."],[4683,4875,"You're just jealous because only we,"],[4875,5021,"the elite, have access"],[5021,5146,"to the best tech,"],[5167,5288,"the best libraries."],[5321,5568,"Only money can get you those things."]],"43":[[8,316,"Meanwhile, dirt poor people like you"],[316,454,"are a waste of space"],[454,550,"and should sink to"],[550,671,"the bottom of the ocean."],[671,921,"And looking at this farm barbie,"],[921,1042,"I doubt she can even pay"],[1042,1297,"for her own nice lead pencil."],[1401,1547,"Zosha Sanchez will never"],[1547,1768,"be able to afford any of this equipment."],[1789,1881,"Nobody has been able"],[1881,2014,"to figure out this problem,"],[2014,2085,"not even with"],[2085,2256,"the invention of supercomputers."],[2281,2456,"She don't got the brains."],[2711,2794,"It's perfect that"],[2794,2948,"this is being live streamed"],[2948,3082,"around the world."],[3103,3361,"We can prove that Ivy League elites"],[3361,3516,"are leagues above these"],[3516,3691,"swamp creatures."],[3749,3891,"Bottom feeders should always"],[3891,3987,"stay at the bottom."],[4245,4437,"And I'm about to prove to the universe"],[4437,4554,"that humble beginnings"],[4554,4783,"gave me exactly the skill"],[4783,4984,"to overthrow people like them."]],"44":[[50,271,"You think money is brain power,"],[271,454,"but my mom taught me what it takes"],[471,717,"to rise from the bottom to the top."],[717,1038,"We can do anything exponentially better."],[1076,1155,"Well said."],[1176,1330,"I came from humble beginnings too."],[1363,1463,"We believe in you, Zosha,"],[1463,1672,"over all of their fancy lab equipment."],[1701,1835,"That is just poor people's"],[1835,1931,"wishful thinking."],[1985,2131,"Dreaming they can one day"],[2131,2243,"soar to the top."],[2264,2344,"Hm."],[2489,2648,"Let's see Zosha Sanchez"],[2648,2877,"solve that third unsolvable problem."],[3011,3082,"Without the help"],[3082,3261,"of any fancy technology."],[3624,3724,"That's cheating."]],"45":[[37,129,"No!"],[154,266,"Too bad."],[371,517,"The duel has already begun."],[617,738,"If you drop out now,"],[754,934,"then that's considered your loss."],[1034,1146,"Those devices don't matter"],[1146,1238,"much to me at all."],[1347,1418,"Well, you're lucky."],[1418,1488,"You were able to even"],[1488,1651,"solve the second problem."],[1693,1793,"No woman has ever done"],[1793,1906,"better than that,"],[1906,2014,"and you certainly won't."],[2027,2318,"And you're just a dirt poor orphan."],[2344,2452,"I mean, it took our group"],[2452,2644,"with the greatest resources years"],[2644,2756,"just to get to the last step"],[2756,2836,"of the problem."],[2865,3007,"You won't be able to solve it"],[3007,3103,"in a millennium."],[3161,3299,"Yes, and especially"],[3299,3432,"without any computing power."],[3457,3574,"She may have lucked out"],[3574,3670,"on the first two problems,"],[3670,3887,"but this is way beyond her."],[3941,4079,"Poor people should never rustle"],[4079,4212,"the feathers of the wealthy"],[4212,4312,"and powerful."],[4350,4587,"Their field of view is so tiny."],[4612,4850,"And our powers so great."],[5159,5380,"Zosha Sanchez will never be able"],[5380,5543,"to solve this by hand."],[5543,5797,"Worse yet, this is an interdisciplinary"],[5797,5897,"math problem"],[5897,6026,"involving quantum physics,"],[6026,6097,"string theory,"],[6097,6310,"and Einstein's field equations."],[6310,6418,"A low-class hobo like her"],[6418,6585,"wouldn't know any of that."],[6719,6802,"Who says I don't?"]],"46":[[12,187,"Yes, we may be poor"],[187,304,"and we can't afford much,"],[304,467,"but that just made me more curious"],[467,571,"to learn everything."],[675,788,"Margaret, you taught her"],[788,892,"quantum physics too?"],[892,959,"No."],[1034,1121,"No, I didn't."],[1255,1326,"She must have learned it"],[1326,1397,"on her own."],[3257,3407,"And that's the greatest weapon"],[3407,3599,"against these stuck-up crybabies."],[3599,3816,"I know poor people are self-conscious"],[3816,4024,"about their low social status,"],[4024,4149,"but bluffing like this"],[4149,4320,"just brings you down even lower."],[4320,4517,"Is this really the best you've got?"],[4533,4688,"I mean, Jensen?"],[4688,4825,"Margaret Harmon?"],[4863,4988,"Sure they were good in their day,"],[4988,5192,"but now all they do is"],[5246,5384,"hang out with the likes of ..."],[5430,5605,"poor, broke, homeless girls."],[5668,5776,"She doesn't even look pretty"],[5776,5910,"in her dirty rags."],[5943,6039,"Well, let's face it,"],[6039,6164,"girls can't really do much,"],[6164,6348,"whether it's physical labor"],[6348,6552,"or cerebral calisthenics."],[6552,6673,"Well, this penniless girl"],[6673,6877,"is about to use a half-broken pencil"],[6877,7057,"to kick your ass in math."]],"47":[[25,116,"Let's race."],[116,291,"You got the balls challenge us,"],[291,412,"but I gotta tell you,"],[467,663,"it looks ugly on you."],[679,784,"Competing against you"],[784,967,"would just lower my status."],[967,1230,"I could take you out easily myself."],[1305,1347,"You?"],[1443,1543,"You're not good enough."],[1593,1710,"I'm not good enough?"],[1768,1847,"I'm about to prove"],[1847,1981,"the Mersenne's Conjecture"],[1981,2068,"in my work."],[2068,2210,"And it's the foundation of"],[2210,2498,"that last unsolvable math problem."],[2531,2669,"How about we compete on that?"],[2719,2894,"Charles is the number one"],[2894,3090,"math student in all of Princeton."],[3119,3253,"Your poor people math"],[3253,3453,"would just be baby talk to him."],[3499,3712,"Yeah, because penniless hobos"],[3712,3912,"don't have enough to even need counting."],[3912,4133,"I think five fingers is enough."],[4308,4454,"Mersenne's Conjecture"],[4454,4571,"is even harder"],[4571,4637,"than the previous"],[4637,4767,"unsolvable math problem."],[4900,5025,"What if Zosha loses?"],[5063,5209,"Zosha is still an inexperienced"],[5209,5313,"high school student."],[5313,5434,"I care less about the winning,"],[5447,5701,"but what if this cripples"],[5701,5851,"her intellectual curiosity?"],[5935,6118,"What if she never pursues math again?"],[6118,6293,"Uh, this should be nothing to you"],[6306,6435,"if you solve the previous"],[6435,6610,"unsolvable problem."],[6610,6894,"Or are you really afraid to admit"],[6915,7186,"that bottom feeders can truly never"],[7186,7328,"climb to the top?"]],"48":[[8,116,"Don't fall for it, Zosha."],[162,275,"They are trying to provoke you"],[275,425,"into this math duel, okay?"],[425,558,"This is a special challenge"],[558,663,"within the Math Olympiad"],[663,842,"with irreversible consequences."],[842,988,"I have never seen someone"],[988,1238,"lose a math duel and continue in STEM."],[1255,1409,"The ridicule and the trauma"],[1409,1526,"are so severe,"],[1547,1701,"you might as well be exiled."],[1730,1789,"The last girl"],[1789,1935,"I defeated in a math duel?"],[1985,2077,"We shaved her head"],[2077,2173,"in front of everyone."],[2173,2344,"Every high school girls'"],[2344,2452,"worst nightmare."],[2498,2644,"Having her head shaved"],[2644,2756,"in front of everyone."],[2777,2915,"And we live streamed it, too."],[2940,3065,"She was crying her eyes out"],[3065,3174,"when she ran out."],[3553,3628,"Zosha,"],[3657,3749,"don't put yourself"],[3749,3874,"under so much pressure."],[3928,4137,"You still have a long road ahead of you"],[4137,4325,"and so much more to accomplish."],[4325,4587,"Mom, I'm confident in the work"],[4587,4692,"that you taught me."],[4746,4871,"They insult our intellect"],[4871,4959,"for being poor,"],[4992,5121,"for being female."],[5150,5555,"They lie and cheat and steal our work."],[5609,5764,"I'm doing this for us, Mom."],[5847,5947,"I'm doing this"],[5947,6118,"for all of the women in STEM."],[6189,6360,"I'll beat these elitist menaces."]],"49":[[0,145,"I am not backing down."],[187,312,"You want to avenge your mother"],[312,454,"and take everything from me?"],[454,592,"I will have you shredded"],[592,859,"into unrecognizable pieces."],[859,913,"Becky Caine,"],[913,1105,"if I have to defeat your cronies first"],[1105,1226,"for you to return what you took"],[1226,1297,"from my mother,"],[1672,1772,"then I will do so."],[1864,1985,"We have the upper hand."],[2081,2198,"When you fail,"],[2218,2298,"we can ensure that"],[2298,2515,"you never get into any college."],[2556,2673,"Neither of you will work"],[2673,2798,"in STEM ever again."],[2852,2952,"No funding!"],[2994,3115,"No scholarships!"],[3115,3174,"Nothing!"],[3232,3378,"Not even if you beg."],[3503,3703,"And your sickly mom"],[3732,3883,"will die in the streets,"],[3883,4016,"dreams shattered."],[4062,4200,"Just like how you poor people"],[4200,4279,"should end up."],[4279,4354,"I will make you"],[4354,4508,"swallow those words!"],[4592,4696,"Just you watch."],[4713,4813,"Enough!"],[4896,5059,"Start the math duel."],[6189,6289,"What is that?"],[6310,6368,"Shameless!"],[6368,6498,"This is utterly shameless!"],[6498,6581,"Charles already has"],[6581,6769,"80% of the math proof completed."],[6769,6861,"That's cheating."],[6902,7073,"Zosha hasn't made any preparations"],[7073,7148,"ahead of time."],[7148,7265,"That's unfair!"]],"50":[[20,70,"Too bad,"],[108,241,"the math duel has already begun."],[271,437,"Uhm, if you want to give up now though,"],[437,600,"that would be considered your loss."],[600,784,"They're all cheating scumbags!"],[784,942,"We can only believe in Zosha now."],[1005,1084,"Otherwise, they will claim"],[1084,1201,"we really can't do math."],[1201,1255,"And that women"],[1255,1472,"are worthless and unintelligent."],[1472,1655,"You and Zosha will be exiled"],[1655,1797,"from math forever."],[1797,1922,"Zosha will never be able to"],[1922,2031,"fulfill her dreams."],[2089,2335,"My child, your math skills"],[2335,2556,"have long surpassed mine."],[2556,2669,"I can only support you"],[2669,2802,"from down below now."],[2802,2990,"I spent ten years working on this."],[2990,3136,"Give me another hour,"],[3136,3307,"and I'll finish this proof."],[3307,3403,"Wow."],[3478,3595,"What a long time."],[3595,3691,"You know nothing about"],[3691,3937,"what it means to be a top mathematician."],[3937,4024,"Poor girls like you"],[4024,4204,"can only admire us from down below."],[4204,4441,"I'm about to win the next Nobel Prize."],[4441,4508,"Just like the one"],[4508,4625,"your mother lost to us."]],"51":[[0,83,"Yes,"],[104,379,"one hour is definitely too much time."],[379,496,"Keep pretending,"],[496,675,"you're as pathetic as your mother."],[725,1021,"You're both pig cuddling boneheads"],[1055,1255,"with sappy women emotions."],[1255,1401,"Yeah, weaklings like you"],[1401,1647,"deserve to have your work stolen by us."],[1693,1830,"Your name will go down"],[1830,2102,"in the history books as a loser."],[2102,2310,"Then she can drop out of STEM"],[2310,2640,"and become a failure of a history teacher."],[2711,2819,"What I mean to say"],[2819,3003,"is one hour is more than enough time"],[3003,3073,"for me to prove"],[3073,3224,"Mersenne's Conjecture."],[3224,3370,"One hour wouldn't even be enough time"],[3370,3503,"for a weak farm girl like you"],[3503,3678,"to crack open a textbook."],[3678,3807,"I only need one minute."]],"52":[[25,100,"One minute?"],[100,300,"Yeah, Zosha is too naive."],[333,513,"She's losing for sure."],[513,621,"No way she can do this"],[621,788,"with no technology."],[800,1021,"No, she's just going to embarrass herself"],[1021,1201,"like her weak mother."],[1201,1284,"Like I said,"],[1284,1589,"women belong in the kitchen."],[1710,1830,"What you all don't realize"],[1830,2114,"is Mersenne Prime is just a key"],[2114,2185,"that I used to prove"],[2185,2352,"Strong Goldbach's Conjecture."],[3219,3324,"We were too rash."],[3399,3536,"We shouldn't let Zosha hinge so much"],[3536,3607,"on this duel."],[3607,3724,"We should believe in Zosha."],[3774,3928,"She can still prove everyone wrong."],[3928,4133,"I came from a small town, too."],[4133,4225,"You don't need to go to"],[4225,4320,"an Ivy League school."],[4320,4508,"Women are just as smart as men."],[4508,4579,"You're right."],[4637,4921,"If you did it once, so can Zosha."],[5221,5321,"Look at the screen!"]],"53":[[54,175,"Look at the screen!"],[629,834,"My math god, Archimedes,"],[834,950,"she's solving it!"],[1026,1088,"No."],[1155,1276,"No, I have to work faster."],[2477,2527,"No."],[2690,2761,"She solved it?"],[3140,3219,"She beat me?"],[3269,3365,"A girl?"],[3390,3503,"Oh, I'm sorry."],[3503,3645,"Have you not started yet?"],[3666,3987,"I spent ten years trying to solve"],[3987,4124,"the Mersenne's Conjecture."],[4175,4337,"My life's work..."],[4337,4450,"Just because you're slow"],[4450,4612,"doesn't mean other people can't solve it."],[4612,4738,"I would have done it faster,"],[4738,4921,"but I had to do it by hand, so ..."],[5192,5380,"Oh my God!"],[5426,5588,"Zosha Sanchez really proved"],[5588,5718,"Mersenne's Conjecture!"],[6227,6456,"She owned that elitist prick's ass!"],[6456,6639,"Down with Ivy League prep boys!"],[6664,6823,"Guess that tractor princess"],[6823,6923,"is smarter."],[6923,6981,"No!"],[7011,7132,"No, it must be wrong!"],[7132,7236,"It must be wrong!"],[7240,7323,"No, no, no, no, no,"],[7323,7415,"how could she beat Charles?"],[7415,7545,"He's actually a genius!"],[7590,7665,"Unlike me."]],"54":[[20,141,"Oh, give it up."],[141,308,"You won't find any flaws in my math."],[308,500,"No, I refuse to admit defeat!"],[533,621,"Okay, alright."],[621,709,"Let me walk you through it,"],[709,896,"since you can't seem to understand"],[896,1092,"something so basic."],[1155,1384,"I simply used my mother's"],[1418,1568,"harmonium mechanics"],[1568,1697,"to reverse engineer"],[1730,1901,"Mersenne's Conjecture."],[2118,2256,"Wait, wait, Becky?"],[2256,2344,"Shouldn't you know"],[2344,2419,"harmonium mechanics?"],[2419,2523,"Why doesn't your student know?"],[2565,2690,"Harmonium mechanics"],[2690,2873,"was in my mother's thesis"],[2873,3073,"that Becky stole ten years ago."],[3490,3703,"Well, that just about proves it."],[3753,3845,"Becky is guilty."],[3928,4037,"That doesn't prove anything."],[4037,4087,"It just proves"],[4087,4229,"that she beat one guy."],[4266,4471,"I proved that small town girls"],[4471,4767,"can beat narcissistic piles of lard"],[4767,4925,"with half a pencil."],[4925,5009,"Half a..."],[5213,5380,"half a pencil."]],"55":[[25,204,"What a useless piece of trash."],[237,362,"He belongs in a dumpster."],[533,633,"Geez."],[633,813,"He was incorrect on one problem"],[813,909,"and that's how you treat him?"],[1009,1063,"Careful."],[1063,1184,"You might end up just like him"],[1184,1347,"when you expose him, Becky Caine."],[1418,1530,"Well, Ms. Caine,"],[1530,1718,"Zosha has defeated your student"],[1718,1943,"who was an actual genius."],[1964,2231,"And now she gets to challenge you."],[2473,2665,"Shaking in your boots yet, Becky?"],[2690,2740,"No."],[2798,2848,"No."],[2861,2927,"There has to be something"],[2927,2965,"that I can do."],[2965,3161,"I can't let this tractor princess,"],[3161,3420,"this, this farm barbie get the best of me."],[3937,4079,"That was just one failure."],[4149,4266,"You want to challenge me?"],[4308,4383,"Fine."],[4504,4629,"I'll show you your place."],[4696,4800,"This foolish sheep"],[4800,4934,"is about to be devoured"],[4934,5071,"by a real wolf."],[5109,5155,"No."],[5188,5255,"I'm going to put you"],[5255,5342,"where you belong,"],[5342,5467,"behind bars!"]],"56":[[12,75,"No."],[95,154,"I'm going to put you"],[154,254,"where you belong."],[254,350,"Behind bars."],[1030,1176,"Zosha, you almost fainted."],[1247,1322,"Be careful."],[1322,1363,"No, Mom."],[1363,1443,"I'm, I'm okay."],[1468,1526,"No."],[1580,1755,"Zosha is already spent."],[1755,1885,"She solved the unsolvable"],[1885,1989,"math problem yesterday."],[1989,2077,"Today she has proved"],[2077,2239,"Strong Goldbach's Conjecture"],[2239,2394,"and Mersenne's Conjecture."],[2394,2515,"Both of these equations"],[2515,2698,"have been unsolved for centuries."],[2736,2823,"Imagine the toll"],[2823,2944,"that it's taken on her."],[2944,3069,"It would be unfair"],[3069,3219,"to continue this math duel."],[3219,3370,"According to math duel rules,"],[3370,3536,"a mathematician can only take on"],[3536,3716,"one math duel in a given month."],[3716,3832,"They're rigging the system"],[3832,3949,"against my daughter again."],[4004,4062,"So what?"],[4129,4375,"I am the director of science and tech."],[4433,4562,"I am the rules!"],[4604,4767,"And I demand that the two of them"],[4767,4917,"face off right now."]],"57":[[8,112,"Shameless!"],[125,291,"Weren't you all just calling her"],[291,504,"the small town math genius?"],[504,675,"Make her prove it then"],[675,880,"by facing off against Becky,"],[900,1067,"my little Nobel Prize winner."],[1255,1384,"Only because she stole it"],[1384,1480,"from my mother."],[1480,1693,"Oh, we're just giving the tractor princess"],[1693,1847,"a chance to prove herself."],[1876,2089,"She should be proud"],[2089,2239,"that pig slop like her"],[2239,2456,"can stand on the world stage"],[2456,2631,"against one of the elite."],[2890,3090,"I am concerned for you, Zosha."],[3203,3265,"Do you remember"],[3265,3415,"why I love math, Mom?"],[3461,3561,"It was how I met you."],[3595,3828,"And Becky Caine destroyed your life."],[3828,3937,"She stole your research"],[3937,4012,"and your legacy"],[4012,4129,"in the Math Hall of Fame."],[4216,4287,"You don't belong"],[4287,4458,"in the Math Hall of Fame anymore."],[4458,4546,"I do."],[4800,4913,"Winning back everything"],[4913,5030,"is my thanks to you"],[5030,5130,"for adopting me"],[5196,5351,"when you could barely feed yourself."],[5384,5488,"Math is universal."],[5518,5605,"An equalizer between"],[5605,5743,"all classes of people."],[5801,5951,"Take these cheating pricks"],[5951,6114,"off their high horses, Zosha."],[6181,6318,"Zosha."],[6339,6473,"Zosha."],[6493,6614,"Zosha!"],[6656,6731,"Zosha!"],[6731,7419,"Zosha!"],[7444,7582,"Zosha, I know you will never give up."],[7665,7778,"No matter what happens,"],[7778,7970,"I will always be with you."],[8045,8133,"Let's duel."]],"58":[[20,116,"No, you talk big"],[116,208,"like a man."],[262,337,"I tell you what,"],[371,458,"we'll gonna go easy"],[458,642,"on your puny little girl brain."],[642,709,"How about that?"],[754,846,"The next part of"],[846,1055,"the third unsolvable math problem?"],[1092,1188,"We race to find"],[1188,1343,"the next Mersenne Prime."],[1534,1580,"What?"],[1659,1785,"That's insanity."],[1810,1860,"The largest"],[1860,1976,"Mersenne Prime discovered"],[1976,2464,"is 2 to the 82,539,933"],[2464,2581,"minus 1."],[2610,2836,"That's twenty-five million digits."],[2836,2994,"Every single mathematician"],[2994,3111,"in the world would love to"],[3111,3178,"come up with"],[3178,3324,"the next Mersenne Prime."],[3324,3390,"They would go down"],[3390,3566,"into the Mathematics Hall of Fame."],[3566,3732,"Our competitors across the sea"],[3732,3816,"have used over"],[3816,4012,"two million supercomputers"],[4012,4095,"to try and do this"],[4095,4254,"and they still haven't gotten it."],[4254,4412,"How can Zosha"],[4412,4562,"with just one human brain?"],[4562,4808,"Why is finding the next Mersenne Prime"],[4808,4909,"so important?"]],"59":[[25,158,"In simple terms,"],[208,442,"Mersenne Primes are fundamental"],[442,667,"to supercomputing and encryption"],[667,817,"at the highest order."],[817,913,"Even if you don't care"],[913,1055,"about supercomputing,"],[1092,1280,"daily tasks such as internet functions,"],[1280,1559,"listening to MP3s, media processing,"],[1559,1772,"are all reliant on FFT"],[1772,1943,"algorithms that are sped up"],[1943,2106,"by Mersenne Primes."],[2106,2231,"What she means, everyone,"],[2231,2398,"is that it makes our CPUs"],[2398,2640,"and our GPUs super fast."],[2665,2844,"So if I'm going supersonic speed,"],[2890,3044,"finding the next Mersenne Prime"],[3044,3148,"will allow me to reach"],[3148,3340,"hypersonic speeds?"],[3340,3445,"Precisely, young man."],[3445,3582,"A breakthrough in Mersenne Prime"],[3582,3695,"is basically a breakthrough"],[3695,3832,"for the entire chip industry."],[3832,3966,"And almost everything is built"],[3966,4108,"on these microchips these days."],[4108,4258,"Your phones, your computers,"],[4258,4408,"your cat's automatic feeder."],[4408,4604,"Nobody can escape the influence."],[4604,4738,"That is chip technology"],[4738,4838,"in the modern age."],[4875,5009,"Finding the next Mersenne Prime"],[5009,5205,"is infinitely difficult."],[5263,5447,"Can Zosha even do it?"],[5480,5622,"What they don't realize is"],[5622,5784,"Opphen already gave me the answer."]],"60":[[37,166,"When I was working on"],[166,283,"Goldbach's Conjecture"],[283,367,"3 years ago,"],[367,521,"I was already halfway"],[521,767,"to finding the next Mersenne Prime."],[767,921,"And I've already given"],[921,1034,"the answer to Becky."],[1034,1313,"Zosha Sanchez will lose, for sure."],[1363,1609,"Prepare to get kicked back to your swamp"],[1609,1735,"to pick up pig shit."],[1776,1985,"It's the only thing your poor girl hands"],[1985,2127,"are good for anyway."],[2127,2210,"No, no."],[2210,2281,"What's going to happen"],[2281,2452,"is these elitist pricks"],[2452,2560,"who cheated"],[2560,2727,"and bought your way to power"],[2727,2882,"are going to fall from grace."],[2882,2986,"You're going to be doomed"],[2986,3169,"to a life of being a total loser."],[3257,3453,"You wouldn't talk to me that way"],[3453,3620,"if you knew that I've already found"],[3620,3753,"the next Mersenne Prime."],[3837,3920,"It's right here."],[3983,4091,"Is she cheating again?"]],"61":[[216,291,"Just one?"],[433,596,"Didn't you hear those idiots?"],[829,1005,"Over two million supercomputers"],[1005,1101,"can't find one"],[1101,1238,"and you've got nothing."],[1426,1526,"You should actually be grateful"],[1526,1668,"that you get to witness me"],[1668,1776,"making history."],[1897,2118,"You crave glory so much."],[2118,2414,"You cheat, lie, steal, probably murder."],[2460,2560,"I may be poor,"],[2560,2665,"but I will ensure"],[2665,2802,"that glory is the one thing"],[2802,2940,"that you never get."],[3069,3190,"Even if you came into my farm"],[3190,3299,"to pick up pigeon fodder."],[4112,4287,"Meet my Mersenne Prime."]],"62":[[91,254,"Meet my Mersenne Prime."],[496,571,"She's really"],[571,734,"found the next Mersenne Prime?"],[734,846,"A number that's over"],[846,980,"25 million digits?"],[1026,1184,"Zosha's a goner this time."],[1184,1338,"All you ever do is cheat!"],[1338,1468,"How can you even call yourself"],[1468,1580,"an honorable researcher?"],[1580,1805,"Okay, that sounds like a you problem."],[1818,1981,"If Zosha's really a math genius"],[1981,2089,"like you say she is,"],[2089,2189,"then she would already"],[2189,2310,"have one in her back pocket."],[2310,2364,"Well, yeah,"],[2364,2540,"that's how geniuses operate."],[2585,2711,"But apparently,"],[2756,2990,"Zosha Sanchez isn't the real genius."],[2990,3082,"She doesn't have time"],[3082,3169,"to calculate what"],[3169,3261,"two million computers"],[3261,3336,"couldn't calculate"],[3336,3478,"to find the next Mersenne Prime?"],[3486,3566,"Uh, tick-tock!"],[3607,3816,"Oh, time's up, sweetie."],[3816,3958,"Admit defeat"],[3958,4229,"and, uh, slap yourself a hundred times"],[4229,4312,"as an apology."],[4383,4491,"Maybe then I'll let you"],[4491,4642,"kiss my Nobel Prize."],[4800,5030,"You mean my Nobel Prize."]],"63":[[25,208,"You mean my Nobel Prize?"],[208,241,"I..."],[337,458,"May I borrow your iPad?"],[458,550,"This is the cheapest model"],[550,658,"from five years ago, though."],[700,892,"It's like one gigahertz tops."],[892,1017,"Might as well be a potato."],[1017,1121,"More than enough for me."],[1192,1343,"She just won't give up."],[1343,1393,"All right."],[1455,1605,"I'll let that brat play"],[1605,1768,"before we eat her alive."],[1830,1993,"Give me the next Mersenne Prime"],[1993,2122,"on the count of three,"],[2160,2344,"and I'll spare you and your mother."],[2427,2477,"Three!"],[2477,2548,"What mockery!"],[2548,2623,"Three seconds?"],[2623,2706,"She has no chance."],[2706,2790,"Two!"],[2790,2911,"She's working like lightning!"],[2911,2986,"Unbelievable!"],[2994,3123,"Can she really do it?"],[3511,3574,"One!"],[3574,3720,"Drag her off the stage!"],[3820,3874,"Done."]],"64":[[87,129,"Done."],[221,287,"My God!"],[375,575,"Is that the next Mersenne Prime?"],[992,1276,"And the next one at twenty-seven million"],[1276,1476,"and thirty-two million digits."],[1776,1989,"You're the pride of my life, Zosha."],[2010,2302,"No, she is the pride of the entire nation!"],[2690,2744,"No, no, no, no way."],[2744,2844,"I had to use Opphen's proof"],[2844,2932,"to get that part."],[2932,3015,"How could she find"],[3015,3178,"two Mersenne Primes?"],[3253,3395,"In three seconds?"],[3415,3574,"That took me three years!"],[3620,3712,"I know what it is."],[3745,3887,"She must just be a blind guess."],[3887,3991,"She could just toss out"],[3991,4083,"a bunch of digits"],[4083,4145,"and make it - Yeah."],[4145,4233,"look like something."],[4233,4325,"She's, she's, she's,"],[4325,4400,"she's cheating!"],[4400,4479,"You're cheating!"],[4521,4788,"All you farmhouse poor people do"],[4788,4859,"is cheat."],[4859,4921,"That's all you do"],[4921,5105,"because you're losers in real life."],[5105,5192,"You're just projecting"],[5192,5447,"because you can't stand losing."],[5488,5588,"Have you guys forgotten"],[5588,5663,"what I've accomplished"],[5663,5747,"so far?"],[5747,5918,"You mean unsolvable math problem"],[5918,5989,"number two?"],[5989,6056,"Yes!"],[6056,6168,"Because math builds"],[6168,6297,"on top of one another."],[6297,6448,"That's why I was able to calculate"],[6448,6560,"the next Mersenne Prime"],[6560,6677,"in the nick of time."],[6740,6840,"No, I cannot lose"],[6840,7119,"to this penniless pig slop feeder!"],[7190,7273,"You are the director"],[7273,7399,"of science and tech!"],[7399,7570,"You are the top dog!"],[7590,7695,"I didn't sleep with you"],[7695,7766,"for nothing!"],[7811,7962,"We can't let her expose us"],[7962,8020,"like this!"],[8095,8233,"Bringing out the big guns?"],[8274,8379,"I'll beat him, too."]],"65":[[16,108,"Ten years ago,"],[108,342,"Thomas Opphen and Becky Caine"],[342,513,"stole my mother's research."],[567,692,"I will avenge her"],[692,892,"and I will take back what belongs to her."],[892,1109,"Those morons that you just defeated?"],[1134,1351,"They are nothing compared to me!"],[1388,1476,"Do you even realize"],[1476,1555,"who you're talking to,"],[1555,1664,"Zosha Sanchez?"],[1664,1835,"He, he hails from a long line"],[1835,1997,"of nuclear physicists, okay?"],[1997,2102,"You mean mad scientists"],[2102,2285,"who create weapons of mass destruction"],[2285,2398,"to ruin humanity?"],[2398,2473,"Yeah, I think the world"],[2473,2581,"can live without you."],[2665,2865,"I am the director"],[2865,3036,"of science and tech!"],[3107,3303,"I hold the highest position"],[3303,3524,"in math and physics, okay?"],[3524,3728,"I am leagues above you."],[3778,3887,"You're so poor."],[3941,4204,"You eat what the pigs eat."],[4375,4500,"Yeah, yeah, yeah, yeah."],[4500,4658,"Teenage trailer trash just thinks"],[4658,4767,"they're so important"],[4767,4871,"that they know everything."],[5067,5146,"Okay, alright."],[5146,5246,"I don't need any of you"],[5246,5430,"to mansplain or talk down me"],[5430,5772,"because higher IQ beats higher status."],[5772,6026,"Higher status is more experience."],[6026,6156,"You mean more experience"],[6156,6260,"at cheating."],[6335,6406,"You know what?"],[6473,6573,"Why don't we solve"],[6573,6706,"Four Color Theorem?"],[6956,7061,"Let's race."]],"66":[[33,196,"You think Four Color Theorem"],[196,325,"is just that easy?"],[354,471,"At my current level,"],[471,663,"it would take me a year to complete."],[663,846,"And that is still faster"],[846,996,"than anyone else on earth."],[1013,1101,"I only need one hour."],[1101,1309,"You are just a rodeo clown drunk"],[1309,1451,"on your own moonshine."],[1501,1618,"It would take you that long"],[1618,1876,"just to write down the equation."],[1876,1997,"Oh, oh, oh, let me guess,"],[1997,2043,"let me guess."],[2043,2106,"You're just going to use"],[2106,2302,"all the computing power in this room"],[2302,2489,"to, to calculate the prime for you."],[2489,2535,"And we see"],[2535,2648,"right through your schemes."],[2648,2761,"Yeah, it must be that iPad"],[2761,2861,"the host gave her."],[2861,3053,"She's the real cheater."],[3053,3174,"That must be why she beat me."],[3274,3440,"Go ahead and check the iPad."],[3812,3903,"My gosh,"],[3903,4087,"this is barely one gigabyte of ram."],[4162,4225,"You're right,"],[4225,4295,"this thing is slower"],[4295,4446,"than a 2010 flip phone."],[4583,4679,"Like I said,"],[4700,4817,"might as well be a potato."],[4817,4934,"See, I don't need your"],[4934,5105,"double standards of hypocrisy."],[5180,5246,"It'll look ugly"],[5246,5409,"on my small town charm."],[5409,5543,"You still won't win."],[5630,5709,"It would take at least"],[5709,5985,"9,000 times more computing power."],[6026,6085,"And it would take"],[6085,6218,"another whole year."],[6247,6535,"But what if I used"],[6535,6819,"the Three Body Operating Model"],[6861,7015,"and 2-D Foil Technology?"]],"67":[[25,296,"But what if I used"],[296,588,"the Three Body Operating Model"],[588,742,"and 2-D Foil Technology?"],[742,796,"What?"],[884,1071,"That's math blasphemy."],[1142,1205,"No, it's not."],[1284,1526,"If I compress space modeling into 2-D,"],[1526,1685,"I don't need 9,000 times"],[1685,1772,"computing power."],[1772,1914,"That iPad is enough."],[1972,2160,"That, that's all abstract math."],[2160,2227,"Nobody has ever made"],[2227,2327,"that concrete yet."],[2327,2477,"That wouldn't be the breakthrough"],[2477,2560,"of the century."],[2590,2669,"It would be the breakthrough"],[2669,2752,"of the millennium."],[2836,2998,"Compressing to 2-D?"],[3098,3215,"That is crazy talk."],[3253,3415,"Current technology only allows"],[3415,3645,"to compress up to 10 times."],[3645,3757,"What are you, what are you saying?"],[3757,3845,"You have some sort of"],[3845,4004,"magical, mystical power"],[4004,4166,"now that created some new tech?"],[4166,4216,"Oh..."],[4216,4404,"I do."]],"68":[[20,154,"I do."],[154,221,"You forget that"],[221,400,"I advanced tech by a century"],[400,492,"just minutes ago."],[1689,1780,"Accelerate!"],[1780,1864,"Accelerate!"],[1864,1935,"Accelerate!"],[2206,2385,"Oh, Jesus Christ, no!"],[2402,2460,"We don't have enough"],[2460,2569,"computing power!"],[2690,2781,"We told you."],[2781,2936,"You don't even have the computing power"],[2936,3015,"to defeat me."],[3399,3628,"Please, I need your help."],[4863,5000,"You get caught rigging the system,"],[5000,5117,"you get banned!"],[5117,5280,"You need skills to own!"],[7882,8053,"The next millennium is here."]],"69":[[2231,2431,"My photon-level microchip."],[2477,2573,"It may be tiny,"],[2573,2731,"but its power is immense!"],[2731,2898,"Enough to power this entire city"],[2898,2973,"on its own!"],[3682,3958,"Power level over 9000!"],[4095,4195,"I did it, Mom."],[4300,4383,"I did it."],[4446,4650,"You did it, my child."],[4683,4913,"You did it when no one else could."],[4959,5205,"We have hypersonic microchips!"],[5205,5367,"No other country is even close!"],[5401,5530,"My potato has gone"],[5576,5734,"hyper speed!"],[5734,5822,"The whole country"],[5822,5976,"wanted to see you win, Zosha."],[6039,6101,"This!"],[6122,6222,"This right here!"],[6222,6398,"This is the American dream!"],[6398,6552,"We're all equal!"]],"70":[[196,504,"No, no, no, she's really a genius!"],[542,692,"She solved all three unsolvable"],[692,829,"microchip math problems!"],[909,1105,"I have to admit, Zosha Sanchez,"],[1105,1255,"you are good."],[1313,1451,"Now I might just have to hire you"],[1451,1559,"to come work for me."],[1659,1851,"Is that you both admitting defeat?"],[1914,2081,"He has been rigging the system"],[2081,2227,"against Zosha the entire time!"],[2260,2369,"You can't be serious."],[2398,2519,"You two worked together"],[2519,2698,"to steal Zosha's mother's research!"],[2761,2890,"Becky Caine is nowhere"],[2890,3019,"near the genius that you are."],[3019,3123,"Come to my side"],[3123,3194,"and I can give you"],[3194,3420,"all the riches and glory in the world."],[3762,3895,"How dare you betray me!"],[3937,4137,"I've been with you for ten years!"],[4341,4479,"I was only using you"],[4479,4642,"to steal research for me."],[4696,4838,"You are nothing compared"],[4838,5000,"to Zosha Sanchez!"],[5184,5267,"You are nothing"],[5267,5392,"but trash to me now!"],[5609,5822,"How does downfall feel, Becky Caine?"]],"71":[[25,208,"Forget Becky, Ms. Sanchez."],[208,421,"Let's discuss your future with me."],[458,596,"Now you don't want to be associated"],[596,729,"with that dirt poor mother."],[729,921,"She has nothing left to offer you."],[921,1001,"But I..."],[1034,1126,"I can give you"],[1126,1330,"access to the top research facilities"],[1330,1476,"and unlimited money."],[1576,1659,"I wouldn't blame you"],[1659,1768,"if you left me, Zosha."],[1893,2072,"I'm just a destitute janitor now."],[2156,2223,"Mom..."],[2285,2439,"I would never do that."],[2439,2531,"Do you, do you know"],[2531,2690,"why I go to public high school?"],[2690,2794,"And why I manipulate"],[2794,2877,"my test scores"],[2877,3053,"to only be 73%?"],[3053,3174,"I'm not interested"],[3174,3265,"in playing guessing games"],[3265,3349,"with you right now."],[3349,3536,"Because my mom adopted me."],[3536,3595,"She saved me"],[3595,3716,"from the streets as an orphan."],[3716,3974,"She gave me a whole new life."],[4016,4191,"I would give up anything for her"],[4191,4262,"to fulfill her dreams."],[4262,4433,"The ones that Becky Caine stole."],[4525,4763,"I would never abandon her."],[4863,4934,"I never knew"],[4934,5050,"you manipulated your"],[5050,5163,"test scores for me."],[5271,5467,"I would do it all over again, Mom."],[5534,5618,"Zosha..."],[5693,5805,"You know, I am so glad"],[5805,6089,"that Zosha Sanchez is not a traitor"],[6089,6231,"like that Becky Caine."],[6318,6460,"Zosha is the better woman."],[6531,6589,"Yeah."],[6589,6823,"It must be that small town charm."],[6852,7007,"Now it's time to strip Becky Caine"],[7007,7194,"of her honors and her position."]],"72":[[20,133,"No, no, you can't."],[287,396,"Just because you beat me,"],[437,604,"that doesn't mean that I stole anything."],[625,658,"Yeah?"],[658,750,"Where's your evidence?"],[838,938,"See?"],[963,1155,"You got nothing on me!"],[1192,1284,"But I do."],[1572,1651,"Look everyone,"],[1693,1764,"Margaret Harmon is trying"],[1764,1926,"to fabricate evidence now."],[1972,2089,"Did you not realize"],[2139,2277,"that there were security cameras"],[2277,2344,"in the office"],[2344,2515,"where you stole my research?"],[2515,2569,"No."],[2569,2736,"No, I already deleted the footage."],[2736,2882,"Those security cameras"],[2882,3103,"were backed up to the cloud."],[3199,3294,"If she didn't realize that,"],[3294,3390,"how could she even call herself"],[3390,3495,"a prodigy in tech?"],[3549,3762,"This math genius is worse"],[3762,3866,"than a preschooler."],[4012,4262,"My mom didn't want to expose you"],[4262,4325,"because she wanted"],[4325,4458,"to give you a second chance"],[4483,4662,"to right your wrongs."],[4863,5088,"This is your last chance, Becky Caine."]],"73":[[120,166,"I..."],[404,671,"I didn't do anything wrong."],[671,829,"Anybody would have done it."],[829,963,"All of the founding fathers"],[963,1076,"of Silicon Valley,"],[1076,1184,"they've done it!"],[1217,1384,"You are despicable!"],[1384,1555,"You do not deserve to be listed"],[1555,1664,"in the Math Hall of Fame."],[1664,1743,"No!"],[1743,1918,"Am I going to lose everything?"],[2164,2256,"Professor..."],[2323,2594,"I am so sorry."],[2627,2815,"Oh, you don't have to do this."],[2815,2932,"Please don't expose me."],[2932,3015,"You don't have to do this."],[3015,3132,"I'll do, I'll do anything."],[3132,3228,"Please forgive me."],[3228,3311,"Forgiveness."],[3357,3549,"I promise to make you proud, Professor."],[3883,4020,"You should be honored"],[4020,4129,"that I'm using your work"],[4129,4245,"to climb to the top."],[4308,4404,"I'm inheriting"],[4404,4608,"your math legacy, Professor."],[4717,4896,"I forgave you a long time ago."],[4950,5009,"You did?"],[5255,5417,"Then I get to keep everything!"],[5538,5605,"You should never"],[5605,5755,"have tried to frame Zosha."],[5826,5964,"Shame on that woman!"],[5964,6151,"Stealing someone else's research"],[6151,6310,"is the most despicable crime"],[6310,6418,"in academia!"],[6468,6669,"Let's exile her!"],[6719,6790,"No!"],[6790,6919,"You can't do that to me!"],[6919,7082,"I'm a Nobel Prize winner!"],[7082,7211,"I'm famous, damn it!"],[7211,7282,"No!"],[7449,7636,"Not anymore, Becky Caine."]],"74":[[116,296,"Not anymore, Becky Caine."],[800,892,"You don't belong"],[892,1055,"in the Math Hall of Fame anymore."],[1105,1184,"I do."],[1559,1722,"You have officially been removed"],[1722,1835,"from the Hall of Fame."],[1835,1985,"My portrait!"],[2010,2198,"My beautiful portrait!"],[2277,2402,"You'll pay for this."],[2865,2982,"Get over here and help!"],[2982,3161,"Don't you want her invention too?"],[3203,3386,"I invented this!"],[3457,3645,"She's starting to steal Zosha's work"],[3645,3728,"like she did mine."],[3966,4154,"Your invention will be ours."],[4187,4333,"See, this is why"],[4333,4400,"women are always"],[4400,4550,"having their inventions stolen."],[4550,4783,"You're just biologically weaker."],[4783,4892,"We are not!"],[4913,4984,"Come on!"],[4984,5150,"Take down these oppressors!"],[5201,5342,"I can't believe we lost"],[5342,5547,"to a couple of pig farmers."],[5547,5759,"No, I'm the best math genius in the world!"],[5759,5905,"I'm the Nobel Prize winner!"],[5905,6043,"I'm a winner!"],[6043,6110,"This,"],[6139,6264,"doesn't belong to you!"],[6556,6639,"No!"],[7032,7136,"Zosha."],[7778,7999,"I would like to proudly announce"],[7999,8133,"that the winner of this year's"],[8133,8291,"Math Olympiad is..."]],"75":[[33,162,"That the winner of this year's"],[162,325,"Math Olympiad is"],[346,425,"Zosha!"],[425,504,"Zosha!"],[504,583,"Zosha!"],[583,675,"Zosha!"],[675,763,"Zosha!"],[763,842,"Zosha!"],[842,934,"Zosha!"],[934,1017,"Zosha!"],[1017,1101,"Zosha!"],[1101,1222,"Zosha Sanchez!"],[1981,2214,"Zosha has solved all three"],[2214,2402,"unsolvable math models!"],[2485,2590,"Not only that,"],[2590,2698,"she has advanced"],[2698,2831,"microchip technology"],[2831,2969,"by at least a century"],[2969,3128,"with her brilliant device."],[3941,4033,"We did it, Mom!"],[4108,4225,"We won the prize money"],[4225,4341,"and now we can continue"],[4341,4612,"your research and your surgery."],[4612,4708,"Oh, Zosha,"],[4708,4913,"I don't care about these prizes."],[5009,5105,"Raising you"],[5105,5317,"was my greatest achievement."],[6731,6844,"Genius!"],[7907,8016,"Well, well!"],[8049,8183,"Zosha Sanchez!"],[8183,8341,"Oh, wow, here, let me."],[8612,8721,"Hello!"],[8725,8775,"Hello!"],[8858,9017,"Congratulations, you two."],[9059,9154,"You will be going to D.C."],[9154,9263,"to compete internationally"],[9263,9325,"this time."],[9396,9559,"Now, you do realize"],[9559,9672,"that our foreign competitors"],[9672,9805,"are going to be a little more difficult"],[9805,9872,"than anything you've had"],[9872,9972,"to handle so far."],[10001,10110,"I'll make all of you proud."],[10185,10485,"Ow, you will always be my girl genius."]]}