94,"Look, I said that..."],[3294,3395,"because I knew that"],[3395,3499,"if I did get you pregnant,"],[3499,3632,"there's no way I wouldn't"],[3632,3753,"want to raise the baby."],[3878,3991,"Molly, you're young,"],[4104,4212,"you're an intern,"],[4212,4387,"I know it would be hard, but..."],[4525,4587,"But do you really"],[4587,4721,"want to get an abortion?"],[4721,4884,"No, no,"],[4884,5034,"absolutely not."],[5184,5384,"I've always wanted to be a mom."],[5580,5722,"Are you not mad?"],[5885,6035,"How could I be mad?"],[6222,6393,"You made me a father."],[6514,6652,"You're carrying the"],[6652,6844,"heirs to my family name."],[7015,7273,"I'm really sorry that I kept this from you."],[7278,7399,"I'm sorry that you felt like"],[7399,7574,"you couldn't tell me."],[7699,8174,"If we do decide to keep the babies,"],[8174,8329,"then from now on..."],[8479,8604,"you should live with me."]],"21":[[60,166,"You'll be safe and"],[170,276,"you'll have everything"],[276,433,"that you could possibly need."],[900,1040,"You hear that, babies?"],[1216,1393,"Your dad is pretty cool."],[1550,1820,"But your mom is way cooler."],[2236,2326,"Thank you."],[2623,2670,"Hey."],[2670,2753,"Is she okay?"],[2800,2876,"Yeah. Shaken up,"],[2880,2956,"but, uh..."],[3133,3233,"she's pregnant."],[3376,3493,"You know, with twins."],[3620,3773,"And she's moving in."],[3930,4070,"Wait."],[4073,4256,"Bro, you went from celibate"],[4256,4373,"to co-parent real quick!"],[4390,4443,"Okay."],[4443,4576,"I knew you liked her."],[4653,4860,"I'm just taking responsibility..."],[4860,4930,"Alright?"],[4956,5190,"And don't tell anyone, okay?"],[5190,5426,"Not even your fiancée?"]],"22":[[3,223,"Okay. Don't call her that."],[243,366,"Brianna's the girl who saved me,"],[370,496,"nothing more."],[1103,1286,"At least I think  she is."],[2283,2386,"Mrs. Turner,"],[2476,2663,"this is Molly Maguire."],[2743,2846,"See to it that she has"],[2846,2953,"everything she needs"],[2956,3116,"and put her up in the guest bedroom."],[3143,3283,"Absolutely."],[3663,3823,"Thank you, Dr. Weston,"],[3843,4036,"and I promise I won't be a hassle."],[4060,4183,"Dr. Weston?"],[4256,4493,"We're at home, just call me Graham."],[4656,4750,"And if you really"],[4753,4903,"don't wanna be a hassle,"],[4936,5080,"promise me this."],[5203,5336,"You'll keep our little"],[5336,5463,"arrangement between us."],[5520,5653,"Yeah, of course, Dr-"],[5800,5883,"Graham."],[5996,6146,"No problem."],[6146,6203,"Okay."],[6316,6476,"Go get some rest, okay?"],[6663,6813,"He doesn't want me."],[6876,7020,"He's only letting me stay here"],[7023,7173,"because of the babies."],[7333,7483,"I can't be a free loader."],[7543,7710,"I need to make myself useful."],[10946,11023,"Molly!"]],"23":[[988,1163,"Molly, you should be resting."],[1217,1317,"You could have fallen."],[1317,1518,"What if you or the babies were hurt?"],[1622,1722,"You're right, I'm sorry,"],[1722,1810,"I just-"],[1885,2135,"I wanted to make you something,"],[2177,2327,"you know, to thank you for,"],[2460,2644,"well, you know, everything."],[3253,3428,"You made a huge mess."],[3578,3712,"I'll clean it."],[4325,4454,"Oh, that's delicious."],[4704,4888,"Dr. Weston."],[5255,5321,"Mrs. Turner,"],[5321,5522,"could you help me clean up in here?"],[5584,5634,"Oh, no, I can-"],[5634,5801,"I don't want Molly lifting"],[5801,5968,"another finger in this house."],[7219,7353,"I'll see you at the hospital, okay?"],[7353,7478,"Molly, wait."]],"24":[[20,137,"Molly, wait."],[254,429,"Sit. Eat."],[529,613,"Oh, no, no."],[613,734,"I'm like really gonna be late, okay."],[734,850,"No, you won't."],[1280,1405,"Come on, eat something."],[1497,1647,"It's okay."],[1822,1926,"Okay."],[2373,2519,"I'm gonna be right back."],[2519,2665,"You wait for me, okay?"],[3357,3440,"Bye."],[4279,4496,"Where did she go? I told her to wait!"],[4496,4704,"She left. It seemed urgent."],[5422,5501,"Molly!"],[5622,5789,"I told you to wait for me."],[5893,5997,"Can we talk about this later?"],[5997,6101,"I'm really gonna be late."],[6310,6385,"Graham, I..."],[6385,6510,"You're riding with me today."],[6594,6760,"Don't go running off alone."],[9296,9522,"Why is that annoying little intern"],[9522,9730,"in Dr. Weston's car?"],[10593,10677,"Brianna,"],[10748,10902,"your fiancé just showed up to work"],[10902,11061,"with another woman."],[11061,11215,"What?"],[11215,11373,"I'm getting on the first flight out."],[11498,11590,"Awesome."]],"25":[[442,688,"Your legs sore from last night, Molly?"],[1088,1292,"How much did he pay you?"],[1363,1468,"Oh God."],[1484,1672,"Did she see me with Dr. Weston?"],[1835,1976,"Don't know what you're talking about."],[1985,2152,"I have work to do, so."],[2160,2452,"It is not fair that a lowly"],[2452,2594,"little intern like you"],[2594,2736,"gets special privileges,"],[2736,2894,"while the rest of us are working harder"],[2894,3057,"and longer than you."],[3224,3349,"I work just as hard"],[3349,3474,"as everyone else here."],[3520,3641,"You think I don't know"],[3641,3762,"your dirty little secret?"],[3841,4079,"I saw you in Dr. Weston's car."],[4079,4275,"I know what you're doing,"],[4358,4562,"and now everyone else will know, too."],[4625,4733,"Hey everyone!"],[4813,4892,"Do you want to know why"],[4892,5121,"Molly Maguire gets special treatment?"],[5167,5401,"It's because she's in bed with the boss."]],"26":[[4,283,"Look, you've got it all wrong, okay?"],[304,346,"Uh-huh."],[346,471,"Dr. Weston,"],[471,592,"he saw that I was running late,"],[592,771,"and he gave me a ride, okay?"],[771,888,"That's it."],[917,1076,"Oh, come on."],[1076,1226,"We all see you following him"],[1226,1376,"around like a little puppy."],[1393,1447,"You're obviously"],[1447,1597,"trying to seduce him!"],[1618,1830,"As if Dr. Weston would ever"],[1830,1981,"look twice at a scrawny"],[1981,2152,"little intern."],[2318,2573,"See, girls like you are constantly"],[2577,2677,"throwing themselves"],[2677,2777,"at powerful men"],[2777,2919,"like Dr. Weston."],[2919,3