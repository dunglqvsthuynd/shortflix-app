900,"That's not my job."],[2900,3093,"You changed the schedule."],[3126,3300,"You forced Molly to do your dirty work."],[3303,3473,"And now you won't leave"],[3473,3546,"until the floor of"],[3546,3700,"every room is sparkling."],[3763,3903,"But I am a doctor,"],[3963,4200,"not some useless, lowly intern like her."],[4203,4360,"Molly's far from useless,"],[4520,4653,"and if you don't get back to work"],[4653,4786,"right now..."],[4786,4890,"You're fired."],[5113,5203,"Now."],[5533,5723,"Come on, let's go. We got work to do."]],"28":[[496,588,"Hey."],[638,688,"Hi."],[688,784,"Can I come in?"],[888,975,"Yeah."],[1297,1405,"How's the book?"],[1605,1743,"It's a slow-starter..."],[1764,1843,"Yeah?"],[3782,3883,"What are you doing?"],[3883,4074,"I'm massaging you."],[4116,4383,"You're hunched over at work all day."],[4383,4717,"It's not good for you, or the babies."],[6035,6131,"Does it feel good?"],[6235,6331,"Yeah."],[6435,6514,"Here."],[7778,7945,"Your skin is so soft."],[8254,8383,"Tell me what you like."],[9121,9271,"Tell me what you want."],[9401,9663,"I don't know if that first night was real,"],[9676,9805,"but this..."],[9897,10018,"This is."]],"29":[[258,404,"Tell me what you want."],[479,775,"I want him, but..."],[1001,1188,"He doesn't feel the same way."],[1605,1730,"Thank you,"],[1751,2089,"Dr. Weston. I feel so much better."],[2131,2356,"Why is she pushing me away?"],[2927,3086,"The next time someone"],[3086,3286,"is bullying you at work, or anywhere,"],[3286,3445,"you come to me."],[3545,3595,"Okay, well,"],[3595,3749,"I can't come to you every single time"],[3749,3916,"I have a problem, okay?"],[3916,4049,"People are going to start"],[4049,4241,"calling me teacher's pet,"],[4241,4458,"and I'm just using you to get ahead."],[4458,4621,"Look, Molly, I've read your notes."],[4688,4871,"I've seen you with your patients."],[4879,5209,"You're resourceful, you're hardworking,"],[5288,5384,"you're kind..."],[5434,5530,"You're going to make"],[5530,5630,"an amazing doctor."],[5697,5885,"Don't let anyone tell you otherwise."],[6281,6414,"Did I say something?"],[6544,6694,"No, no."],[7899,8083,"I don't think anyone has been"],[8083,8266,"so nice to me before."],[8412,8541,"My mom,"],[8612,8954,"she used to say that I was useless."],[9175,9421,"And my brother used to say that"],[9421,9588,"I was just, like, a waste of space."],[9763,9889,"She's been mistreated"],[9889,10014,"all her life,"],[10055,10285,"yet she's never lost her drive."],[10377,10510,"Molly, you don't deserve"],[10510,10648,"to be treated that way."],[11036,11277,"I hope you know that I will always"],[11277,11440,"be there for you,"],[11440,11603,"and fight for you..."],[11778,11916,"and our babies."],[12741,12867,"Her pajamas are frayed"],[12867,12996,"and scratchy..."],[13138,13292,"She must have really given"],[13292,13446,"all her money to her family."]],"30":[[120,279,"Hey, Mrs. Turner."],[358,546,"I want Molly to feel at home here."],[546,646,"Can you buy her a"],[646,750,"new set of pajamas?"],[754,955,"I noticed that she doesn't have much."],[955,1021,"Yes, sir."],[1021,1163,"I'll get on it right away."],[1163,1276,"Appreciate it."],[1368,1534,"He really likes her."],[1622,1760,"I'll buy her the sexiest"],[1760,1901,"thing I can find."],[1918,2135,"Then she'll really win him over."],[2973,3215,"Dr. Weston bought you a gift."],[3345,3482,"He specifically requested"],[3482,3745,"that you wear it for him tonight."],[3787,3908,"Thank you!"],[4354,4508,"That's so sweet."]],"31":[[376,516,"There's no way he wants me"],[520,660,"to wear something this sexy."],[2320,2423,"Hey."],[2426,2663,"Graham, hi! Um..."],[2743,2843,"I..."],[2900,3043,"I got your, um..."],[3263,3353,"pajamas."],[3426,3533,"You like them?"],[3936,4063,"Do you- do you..."],[4140,4263,"Do you really want me to,"],[4266,4390,"like, wear them?"],[4406,4650,"She's so used to living with so little."],[4723,4926,"I'll show her a better life."],[4946,5233,"Of course. You deserve them."],[5396,5473,"Okay."],[5620,5706,"Bye."],[6296,6383,"Yeah, I mean,"],[6383,6640,"he's done so much for me."],[6796,6940,"The least I could do is wear them."],[7676,7810,"Whoa, whoa, whoa!"],[7840,7996,"Not so fast, my friend!"],[8040,8123,"What?"],[8190,8300,"What's up, guys?"],[8373,8606,"We're hanging out tonight."],[8616,8790,"It's been far too long,"],[8790,8963,"and if I didn't know any better,"],[8966,9253,"I'd say you found yourself a girlfriend!"],[9313,9416,"Ah, come on..."],[9616,9793,"You're hiding her inside, aren't you?"],[10176,10270,"Don't scare her."],[11006,11213,"Welcome home, Dr. Weston."],[11430,11640,"I wore the pajamas you told me to wear."]],"32":[[8,212,"Welcome home, Dr. Weston."],[241,333,"I..."],[437,663,"I wore the pajamas you told me to wear."],[1280,1355,"Hey, hey,"],[1355,1576,"Close your eyes! Don't look!"],[3941,4112,"I'm sorry, I thought..."],[4258,4350,"Mrs. Turner,"],[4350,4441,"she gave me this,"],[4441,4763,"and said that it was from you."],[4783,4888,"It's okay."],[5205,5355,"Molly, you're shaking."],[6452,6569,"So..."],[6694,6865,"Did I embarrass you"],[6865,7036,"in front of your friends?"],[7186,7278,"No."],[7453,7595,"I just..."],[7745,7912,"I don't like seeing other men"],[7912,8037,"look at you like that."],[8487,8854,"Are you jealous, Dr. Weston?"],[9138,9238,"What if I am?"]],"33":[[33,126,"What if I am?"],[946,1020,"Why don't you change"],[1020,1170,"and go eat something?"],[2263,2346,"Ugh!"],[2476,2580,"Here's the deal."],[2646,2886,"You are both taking this to the grave,"],[2896,2990,"is that understood?"],[3060,3126,"No shot!"],[3126,3186,"We're not gonna talk about"],[3186,3320,"what just happened?"],[3413,3573,"I'm warning you guys..."],[3630,3746,"Well, you even got me"],[3746,3863,"wanting to settle down."],[3913,4070,"You seem to be doing good."],[4260,4370,"I'm doing this for the well-being"],[4373,4490,"of the babies."],[4573,4693,"They're the future heirs"],[4693,4813,"of the Weston name."],[4866,4956,"After they're born,"],[4956,5060,"my secret relationship"],[5063,5170,"with Molly will end."],[5286,5496,"I'm just a baby maker to him..."],[5590,5690,"I should have known"],[5690,5830,"he would never want me."],[6180,6283,"Look, I know you're not a serious"],[6283,6440,"relationship guy, but..."],[6443,6643,"that's a bit heartless, isn't it?"],[7006,7163,"What I mean is,"],[7163,7330,"after the babies are born,"],[7330,7446,"my relationship with Molly"],[7446,7563,"won't be a secret."],[7730,7873,"I'll introduce her to the public"],[7876,8060,"as the mother of my children, and,"],[8280,8386,"well, if she wants..."],[8770,8870,"my wife."]],"34":[[204,421,"He thinks I'm just some desperate,"],[421,571,"money-hungry gold-digger"],[571,742,"he can pay off and chase away"],[742,888,"after the babies are born."],[1084,1451,"I may be young, but I am not stupid."],[2164,2356,"Hey Mrs. Turner, did you..."],[2544,2652,"Where's Molly?"],[2694,2865,"She already left."],[2865,3148,"And, she wanted me to give you this."],[3528,3661,"She said she'd pay back the rest"],[3661,3795,"as soon as she can."],[4642,4904,"Molly? Molly, wait, wait!"],[5284,5363,"Dr. Weston,"],[5363,5447,"can I help you with something?"],[5447,5630,"Yeah. Why'd you leave an envelope"],[5630,5814,"of cash with Mrs. Turner?"],[5993,6085,"I am not a freeloader,"],[6085,6181,"okay, Graham?"],[6181,6356,"So I'm going to save up my money,"],[6364,6439,"and I'm going to pay off"],[6439,6514,"everything I owe you."],[6514,6606,"Once the babies are born"],[6606,6702,"I will be out of your hair."],[6702,6781,"Okay?"],[6881,7002,"Molly, wait!"],[7057,7123,"Dr. Weston,"],[7123,7219,"we need you in emergency surgery"],[7219,7315,"immediately!"]],"35":[[404,471,"Molly!"],[471,771,"Who? It's your mother."],[855,975,"I heard you moved a woman"],[975,1096,"into your house."],[1096,1217,"Why haven't you"],[1217,1343,"introduced her to me?"],[1372,1422,"Okay, Mom,"],[1422,1568,"I don't have time for this."],[1893,2118,"If he won't introduce me to his fiancée,"],[2118,2252,"I'll go meet her myself."],[2994,3094,"Oh God,"],[3103,3294,"I am so sorry, Ms..."],[3345,3666,"Weston. Graham's mother."],[3741,3862,"I came here to meet the"],[3862,3983,"good-for-nothing gold-digger"],[3983,4245,"who weaseled her way into his bed."],[4333,4441,"Oh God."],[4496,4587,"Did Graham tell her"],[4587,4733,"I'm only after his money?"],[4771,4954,"Did she come here to drive me away?"],[4963,5109,"Wait, I- I can't go home."],[5188,5372,"I'll beat this baby out of your belly!"],[5434,5563,"I have to stay here"],[5563,5697,"until the babies are born."],[5722,5843,"I mean, they won't survive"],[5843,6018,"if I'm forced to go back home."],[6035,6243,"You're her, aren't you?"],[6297,6381,"You're the woman"],[6381,6510,"who seduced my son."]],"36":[[4,83,"You're the woman"],[83,216,"who seduced my son."],[246,442,"No, no, I am..."],[596,692,"I'm the maid."],[775,905,"I'm just doing laundry."],[925,1117,"You touched me with dirty clothes?"],[1251,1343,"Ew."],[1426,1518,"Make yourself useful,"],[1518,1664,"and go fetch me some water."],[1701,1793,"Now!"],[1793,1864,"Yes, ma'am."],[1864,1976,"Of course, of course."],[2381,2473,"Hey."],[2615,2731,"Where on earth"],[2731,2848,"do you get your maids?"],[2977,3136,"It's good to see you, too, Mom."],[3307,3545,"So, where's this fiancée of yours?"],[3661,3828,"Here's your water, ma'am."],[4012,4166,"Looks like you already met her."],[4358,4487,"She's your fiancée?"]],"37":[[87,225,"She's your fiancée?"],[746,938,"You're marrying a maid?"],[938,1105,"A maid?"],[1105,1226,"No, I'm-"],[1343,1601,"Sir, can I talk to you for a second?"],[1818,1960,"You want me to leave after the twins"],[1960,2068,"are born, and I know that you are"],[2068,2177,"ashamed of me and your mother"],[2177,2285,"is never going to approve."],[2285,2456,"So, I will be the maid"],[2456,2527,"and then she never"],[2527,2598,"has to know the truth."],[2598,2765,"Okay, what are you talking about?"],[2765,2911,"Why would you think that?"],[2919,3011,"Mrs. Weston,"],[3011,3215,"I am so sorry for the trouble."],[3215,3286,"I will get you another"],[3286,3382,"glass of water."],[3382,3474,"Don't bother."],[3536,3691,"That's two sloppy mistakes"],[3691,3845,"in the span of a few minutes."],[3874,3991,"You're fired!"],[4099,4275,"Maybe it's better this way..."],[4412,4550,"I'll find a way to take care"],[4550,4688,"of the babies on my own,"],[4775,4871,"somehow."],[5384,5672,"She is not a maid. This is Molly,"],[5701,5872,"your future daughter-in-law,"],[5901,6093,"the mother of your grandchildren,"],[6164,6297,"and my fiancée."]],"38":[[25,225,"The mother of your grandchildren,"],[291,442,"and my fiancée."],[558,704,"I'm not casting you aside."],[704,888,"I want you here with me."],[900,1071,"My daughter-in-law?"],[1188,1368,"Mother of my grandchildren?"],[1818,1989,"Why didn't you tell me?!"],[2060,2360,"Molly, I spoke so horribly to you,"],[2360,2540,"I hope you can forgive me."],[2540,2681,"I thought you were a maid!"],[2681,2794,"Well, maybe you shouldn't"],[2794,2969,"speak to anyone horribly, Mother."],[2969,3111,"Including the maids."],[3199,3353,"I suppose you're right..."],[3353,3499,"but I can't believe"],[3499,3641,"you made your pregnant fiancée"],[3641,3787,"do housework!"],[3787,3858,"Okay, I-"],[3858,4058,"That's my fault, I was being careless."],[4058,4141,"I mean, Graham,"],[4166,4412,"he always tells me not to do that"],[4412,4521,"because of the twins, you know."],[4521,4625,"Twins?"],[4854,4938,"Oh."],[5005,5238,"We haven't got a minute to spare!"],[5255,5397,"I'm taking you shopping"],[5397,5618,"to make up for my indiscretion."],[5659,5897,"We have so much to discuss."],[5901,6177,"A wedding to plan. Must be quick!"],[6177,6402,"We don't want that baby bump to show."],[7415,7507,"Hey."],[7507,7686,"I'm back in town, baby."],[7686,7845,"Did you miss me?"]],"39":[[346,550,"Brianna's back."],[550,754,"She saved my life all those years ago."],[821,1042,"And she expects us to get married."],[1176,1388,"I don't know, maybe I owe her that."],[1559,1789,"It's the role of a lifetime."],[1801,2064,"I'll miss you everyday, but..."],[2314,2515,"I have to chase my dreams."],[3653,3753,"Why did you tell your mom"],[3753,3853,"that I'm your fiancée?"],[3933,4041,"I thought you were going to end it"],[4041,4170,"after the babies were born."],[4571,4729,"Look, I don't know"],[4729,4892,"what you think you heard,"],[4967,5113,"but my plan was always"],[5113,5263,"to ask you to marry me."],[5605,5826,"It's kind of spoiled now, isn't it?"],[6181,6277,"No."],[6502,6581,"You know,"],[6581,6694,"you remind me of someone."],[6919,7115,"A girl I met when I was a kid."],[7207,7428,"But it can't be."],[7511,7678,"Brianna saved me."],[7874,8045,"That girl, where is she now?"],[8245,8324,"She's..."]],"40":[[158,329,"That girl, where is she now?"],[533,613,"She's..."],[975,1242,"Come on, dear! Chanel is calling."],[2331,2502,"Thank you so much, Mrs. Weston."],[2590,2882,"Thank your fiancé, it's on him!"],[3807,4033,"Graham would look so good in this tie."],[4175,4308,"Excuse me."],[4308,4496,"How much is this tie?"],[4521,4792,"It's Italian silk. $2,000."],[4838,4988,"Oh, wow."],[5017,5176,"That's expensive."],[5288,5593,"But he's given me so much."],[5593,5814,"I'll take it."],[10276,10414,"Who is this..."],[10752,10860,"What are you doing?"]],"41":[[54,312,"Um, I-"],[517,600,"You shouldn't touch things"],[600,742,"that don't belong to you."],[804,921,"I'm- I'm sorry."],[1059,1163,"I didn't mean to upset you,"],[1163,1251,"I was..."],[1359,1468,"Molly?"],[1551,1634,"Molly."],[1693,1914,"Hey! Hey, Molly. Molly!"],[1914,2022,"Hey! Hey!"],[2606,2798,"Well, everything sounds good."],[2852,3078,"It's probably just low blood sugar."],[3232,3361,"This should help,"],[3361,3495,"along with some rest."],[3687,3787,"Thanks."],[4008,4162,"Well I'm gonna go back to my room."],[4162,4262,"Look, Molly,"],[4362,4650,"I didn't mean to scare you earlier."],[4688,4863,"No, no, it’s my fault."],[4863,5021,"I came to drop you off something"],[5021,5150,"and when I saw you weren't here,"],[5150,5284,"I should have just left."],[5434,5584,"What did you wanna bring me?"],[7077,7282,"You bought this for me?"],[7282,7444,"It's nothing, really, okay?"],[7444,7653,"After everything you've done for me."],[7653,7766,"I wanted to get you something more,"],[7766,7895,"but it's all I could, really,"],[7895,8166,"you know, like, afford right now."],[8804,9025,"Oh God, you hate it."],[9296,9355,"Okay, look,"],[9355,9480,"if you really think it's that hideous"],[9480,9697,"you can just, like, throw it away or..."]],"42":[[613,817,"I guess you like the tie, then?"],[1013,1176,"I'll wear it tomorrow,"],[1334,1530,"if you help me put it on."],[3974,4145,"Are you afraid of storms?"],[4491,4612,"Okay, it's really..."],[4612,4771,"it's really, really embarrassing."],[4942,5105,"When I was six,"],[5105,5271,"my parents left me alone,"],[5321,5655,"and there was this thunder"],[5655,5851,"and lightning all night..."],[6035,6135,"and I thought the house was"],[6135,6281,"like crumbling in around me,"],[6281,6389,"and I don't think"],[6389,6544,"I've ever been so scared."],[7344,7670,"Stay here tonight. With me."],[7887,8095,"You don't need to be afraid anymore."],[8224,8350,"So from now on,"],[8350,8558,"when there is a storm outside,"],[8671,8837,"I'm going to be by your side."],[8938,9054,"I promise."],[10064,10214,"You hear that, babies?"],[10322,10531,"Your dad's going to protect you."],[10623,10764,"He'll protect us."]],"43":[[996,1163,"I'm starting to show."],[1634,1743,"Nobody can know."],[2665,2765,"I'll head in first."],[2815,2902,"Molly, wait."],[3178,3307,"Can you check my tie?"],[3307,3436,"I think it's crooked."],[4066,4212,"Dr. Weston, I am your intern,"],[4212,4325,"okay? And look,"],[4358,4466,"anybody could see us!"],[4491,4650,"I wasn't..."],[4675,4813,"I will see you inside."],[6126,6210,"Graham!"],[6272,6548,"Brianna? What are you doing here?"],[6664,6798,"I missed you so much,"],[6798,6990,"I came straight from the airport."],[7298,7469,"That's the girl from the photo."]],"44":[[25,196,"That's the girl from the photo."],[417,571,"It's probably nothing."],[646,775,"I mean, if they were together,"],[775,909,"wouldn't he have told me?"],[1013,1159,"Come get coffee with me!"],[1159,1305,"We can go to our favorite place."],[1305,1426,"Brianna, I'm a doctor."],[1438,1576,"I can't just leave my shift."],[1576,1701,"It's good to see you, though."],[2018,2164,"Georgia was right."],[2181,2489,"He is seeing that skanky little intern."],[2581,2727,"But not for long."],[4095,4316,"Where did a broke bitch like you"],[4316,4542,"get new designer clothes?"],[4646,4738,"You get a check from"],[4738,4829,"your sugar daddy?"],[4963,5067,"You know what? Maybe you should"],[5067,5192,"mind your own business."],[5221,5359,"I mean, we wouldn't want to repeat"],[5359,5505,"what happened last time."],[5543,5764,"Aw, you gonna go cry to Dr. Weston?"],[5864,6056,"Nobodies like you"],[6097,6314,"love to ride the coattails of powerful"],[6314,6473,"men like Dr. Weston."],[6535,6698,"But now that Brianna's back,"],[6735,6840,"he won't have time"],[6840,6948,"for your pathetic ass."],[6956,7061,"Brianna?"],[7173,7244,"Oh, he didn't tell"],[7244,7344,"you he had a fiancée?"],[7478,7653,"Yeah. She just got back from abroad."],[7711,7903,"She is a famous actress,"],[7903,8062,"he's a famous surgeon"],[8066,8308,"and the heir to a billion-dollar"],[8308,8416,"family fortune."],[8541,8671,"A match made in heaven."],[8733,8850,"Yeah, you're lying,"],[8904,8975,"Because I'm his-"],[8975,9104,"You're his what?"],[9175,9380,"You are a worthless,"],[9380,9584,"talentless intern."],[9701,9897,"I mean, good for a fuck. Maybe."],[9951,10172,"But wife material?"],[10214,10297,"I think not."],[10356,10472,"But the babies..."],[10535,10673,"He wouldn't just abandon them,"],[10673,10748,"would he?"]],"45":[[62,112,"You know,"],[112,246,"Dr. Weston and Brianna"],[246,383,"were looking for a surrogate."],[417,533,"I mean, with her acting career,"],[533,667,"she can't afford to get fat."],[742,817,"And, you know,"],[817,955,"they said that if she ever"],[955,1071,"wanted to have kids,"],[1096,1309,"that he would arrange"],[1309,1526,"for some poor, desperate"],[1526,1785,"girl to have it for them."],[1901,2106,"That sounds an awful lot like you,"],[2106,2214,"doesn't it, Molly?"],[2256,2410,"Is he keeping me around"],[2410,2569,"to give Brianna babies?"],[2660,2848,"Would he really do that to me?"],[2998,3190,"You know, you even have"],[3190,3386,"a little mole right there,"],[3386,3503,"just like Brianna."],[3561,3687,"Perfect stand-in."],[3878,3933,"You know,"],[3933,4070,"you remind me of someone."],[4300,4491,"A girl I met when I was a kid."],[4738,4817,"You know what,"],[4817,4954,"when he finds out about this,"],[4954,5071,"he's gonna have you fired."],[5071,5163,"Oh, no."],[5180,5351,"See, I'm not getting fired."],[5372,5509,"I'm too essential."],[5584,5855,"You are a glorified oven."],[5926,6151,"Young, easy, replaceable."],[6231,6448,"I just hope the money was worth it."],[7107,7190,"Toodaloo!"],[7353,7432,"Jesus."],[7745,8020,"Don't overthink. Trust Graham."],[8020,8191,"He'll clear everything up."],[8433,8508,"Graham!"]],"46":[[36,273,"No, it can't be true."],[320,530,"Am I really just Brianna's stand-in?"],[586,726,"The babies."],[726,960,"How could he do this to our babies?"],[1883,2003,"Thank you."],[2233,2420,"Are you Molly Maguire?"],[2630,2830,"Stay away from Graham."],[2830,3033,"He wants you to leave us alone."],[3110,3213,"Where is he?"],[3276,3426,"I wanna hear it from him."],[3426,3633,"He's getting ready for our date tonight."],[3636,3743,"He wants everything"],[3743,3853,"to be perfect."],[4023,4156,"Thank God"],[4156,4293,"I brought my lip gloss."],[4320,4476,"Graham practically jumped"],[4476,4613,"the second he saw me and..."],[4786,4926,"wiped it all off."],[5203,5470,"You know what, I'll just call him."],[6846,6963,"Hi baby,"],[6976,7236,"your stupid little intern Molly"],[7290,7403,"is harassing me."],[7406,7823,"I think she's a little... unwell."],[7853,8006,"Do you wanna come get her?"],[8353,8513,"Ignore her."],[8516,8683,"I'll be waiting for you at the hotel"],[8683,8766,"my love."],[8833,9020,"He's done with you, Molly."],[9043,9250,"I am rich, beautiful,"],[9253,9363,"famous."],[9420,9573,"Experienced."],[9573,9730,"Everything you're not."],[9763,9883,"You know what?"],[9940,10113,"Graham may not love me,"],[10146,10373,"but he did teach me not to deal"],[10376,10513,"with bullshit like this"],[10513,10690,"from bullies like you."],[11730,11806,"Molly?"]],"47":[[41,91,"Molly?"],[150,287,"Help! Graham!"],[287,425,"Oh my God! Help!"],[704,779,"Oh Graham,"],[779,921,"thank God you're here!"],[921,1021,"What happened?"],[1021,1096,"I don't know,"],[1096,1205,"I ran over here when"],[1205,1317,"I saw her bending over"],[1317,1451,"and then she just passed out!"],[1451,1501,"Okay, Okay,"],[1501,1689,"give her space, she's pregnant."],[1785,2047,"Pregnant? But I'm your fiancée!"],[2106,2331,"Brianna, we both know that's not true."],[2444,2540,"You saved my life"],[2540,2635,"and I'll always be grateful,"],[2635,2827,"but don't ask me for more than that."],[3119,3349,"I pretend to kiss him,"],[3349,3532,"use AI to fake his voice,"],[3532,3745,"and that's still not enough?!"],[3774,3999,"Fine. You asked for it."]],"48":[[241,483,"105 degrees. She's burning up."],[500,654,"I'm gonna give her more ibuprofen."],[658,734,"Graham, you've already given"],[734,855,"her the highest dosage."],[863,963,"Her symptoms align"],[963,1067,"with Chorioamnionitis."],[1067,1138,"We need to put her on"],[1138,1263,"Fluoroquinolones now,"],[1317,1372,"even though it may"],[1372,1497,"put the babies at risk."],[1576,1685,"She would want me to protect"],[1685,1793,"the babies over everything,"],[1847,2052,"but I refuse to lose her."],[2164,2264,"We're gonna do everything"],[2264,2448,"that we can to save all three of them,"],[2548,2660,"but if it comes down to it,"],[2660,2811,"Molly takes priority."],[2919,3094,"No, I'm not taking it, okay,"],[3094,3257,"I wanna save the babies."],[3261,3407,"Okay, no medication,"],[3407,3603,"I promise, but you gotta stay still."],[3661,3812,"Your fever is getting worse."],[3916,4033,"We need to cool her down now"],[4033,4154,"or we're gonna lose her."],[4154,4279,"Not if I can help it."],[4279,4408,"Get an ice bath ready!"],[4808,5017,"It's okay, I got you."],[5217,5301,"Stay with me, Molly."],[5301,5518,"You're alright, I got you."],[6118,6297,"Hey, hey. It's okay."],[6348,6564,"This is the only way I can save your life."],[6936,7032,"I think your temperature"],[7032,7127,"is going down."],[7232,7336,"Thank God."],[7711,7820,"Hey, I got you, Molly."],[7820,7987,"I got you. I'm not going anywhere."]],"49":[[1059,1155,"Where am I?"],[1155,1351,"We're at the hospital."],[1351,1497,"Your fever broke."],[1722,1830,"Wait, you took the babies."],[1839,1947,"No, no, it's okay!"],[1947,2181,"It's okay, the babies are safe."],[2214,2323,"And so are you."],[2506,2690,"You saved them? You saved us?"],[2836,2915,"But how?"],[3078,3219,"Dr. Weston soaked in an ice bath"],[3219,3361,"with you all night"],[3361,3470,"to cool you down."],[3595,3757,"He must really care about you."],[4258,4358,"See that?"],[4446,4571,"Perfectly healthy."],[4754,4879,"I would do anything to keep you"],[4879,5005,"and our babies safe."],[5005,5117,"You know that."],[5985,6122,"Why do you do so much for me"],[6122,6252,"when you have a fiancée?"],[6456,6552,"What, Brianna?"],[6752,6865,"Look, our families always"],[6865,6977,"hoped that we'd get married,"],[6977,7178,"but I never felt that way about her."],[7828,8045,"You're the only girl I want to marry."]],"50":[[62,233,"Big talk for a guy"],[233,408,"who hasn't even proposed yet."],[575,750,"I thought that..."],[863,1109,"I thought that you were going to..."],[1355,1601,"take my babies and raise them with her."],[1655,1747,"What?"],[1835,1989,"Who told you that?"],[2047,2164,"Dr. Stone."],[2494,2644,"She said that"],[2819,3053,"Brianna couldn't risk getting fat"],[3053,3253,"because of her career, and..."],[3357,3541,"you promised her that you would"],[3541,3707,"get another woman pregnant"],[3757,3920,"and have her raise the babies..."],[3920,4087,"and that you..."],[4208,4354,"also promised her that"],[4354,4529,"you would marry her."],[4767,4896,"Never, Molly."],[5042,5467,"Those babies are ours, and only ours."],[5747,5851,"Close your eyes."],[5947,6043,"Just close them."],[7294,7444,"I want this."],[7795,7970,"I want a family."],[8241,8454,"And I want it with you."],[8821,9192,"You don't think I'm too young"],[9192,9567,"and reckless and stupid?"],[9663,10105,"I think you're sexy and strong"],[10105,10335,"and smart..."],[10502,10614,"and mine."],[10885,11027,"Molly, may I come in?"]],"51":[[62,208,"Molly, may I come in?"],[308,387,"Shh..."],[1046,1130,"I'm..."],[1138,1242,"I'm busy."],[1301,1468,"I'm resting."],[1468,1601,"Good girl."],[2281,2402,"I need a million dollars now"],[2402,2481,"or the debt collector"],[2481,2565,"is going to kick my ass."],[2565,2694,"She gets knocked up by a Weston"],[2694,2831,"and sends us practically nothing?"],[2831,2923,"We are not leaving here"],[2923,3094,"unttil we get that million dollar check."],[3107,3232,"And not ripped this time."],[3294,3445,"Obviously, Brian."],[3561,3778,"Mom? Brian? Wait..."],[3858,4012,"Did you guys come to visit me?"],[4012,4250,"No, we came to get our money."],[4254,4354,"Now that you're connected"],[4354,4454,"to Graham Weston,"],[4454,4671,"he should pay for your dad's surgery."],[4804,4967,"Dad's in critical condition, Molly."],[5088,5217,"Go get your baby daddy."],[5351,5509,"Let me go!"],[5584,5784,"You ungrateful child!"],[5801,5939,"You whore yourself out"],[5939,6056,"instead of helping your father."],[6056,6218,"Your boss doctor"],[6218,6381,"baby daddy shoul