{"1":[[638,746,"Excuse me?"],[971,1163,"I heard you can sell your blood here."],[1163,1368,"Yeah, you're in the right place, cutie."],[1443,1605,"And you guys will..."],[1676,1868,"pay double the going rate, right?"],[1939,2152,"You desperate for cash, sweetheart?"],[2331,2464,"Look, my dad is going blind"],[2464,2727,"and the insurance company"],[2727,2961,"they won't cover his medication."],[3132,3332,"Okay, there's no need to worry."],[3361,3557,"I'm a doctor, alright?"],[3624,3757,"I'm here to help you."],[4362,4612,"It's an aphrodisiac unlike any other."],[4612,4725,"And in a few minutes"],[4725,4838,"you are going to be begging"],[4838,4954,"to touch me."],[5167,5271,"Come back here!"],[5492,5751,"Hey! I'd pay a lot for a girl like you!"],[5922,5985,"Mom!"],[6006,6085,"Molly,"],[6085,6260,"where is the money for your dad?"],[6260,6343,"It's $1,000!"],[6343,6443,"Mom!"],[6464,6598,"Mom, call the police!"],[6623,6806,"A man is forcing me to sell myself!"],[6865,6990,"Don't be so dramatic."],[7032,7165,"Wait, does he pay well?"],[7178,7278,"Mom, please help!"],[7298,7394,"Hey, come back!"],[7474,7586,"Your mother called."],[7716,7836,"She wants to set up a date with the"],[7836,7941,"Harrington's daughter."],[8158,8241,"No."],[8324,8383,"But sir,"],[8383,8591,"she's beautiful, rich..."],[8604,8771,"It's not happening, alright?"],[8817,9017,"All those rich girls are the same."],[9705,9784,"Huh."],[9843,9964,"She looks just like..."],[10097,10293,"the girl who saved my life."],[10343,10527,"I was kidnapped, dumped,"],[10527,10873,"left for dead. Then she found me."],[11240,11469,"No... No, it’s not her."],[11519,11703,"Alright, Jennings, let's head out."],[12120,12287,"Help me! Please!"]],"2":[[33,191,"Help me! Please!"],[763,888,"Ma'am, who are you?"],[888,1059,"Dr. Weston, do you know this woman?"],[1059,1151,"Please help me."],[1151,1301,"They sprayed something on me."],[1355,1488,"Are you...?"],[2540,2665,"Can I take you home?"],[2752,2915,"This drug is a powerful"],[2915,3011,"aphrodisiac."],[3065,3169,"Am I feeling this because"],[3169,3274,"of the Crimson Rush,"],[3274,3624,"or because... I really want him?"],[3716,3858,"He's so handsome..."],[3933,4212,"Can we just, like, turn on the AC?"],[4212,4341,"It's just- I'm feeling really..."],[4487,4567,"hot."],[4612,4742,"Yeah, yeah."],[4854,5013,"I feel so much better."],[5059,5317,"But I still want him."],[5559,5689,"Don't take me home."],[5880,5993,"What if we..."],[6172,6302,"I don't-"],[6352,6452,"Touch me..."],[6585,6690,"Please."],[6752,6902,"God, she's beautiful."],[6977,7169,"This is a bad idea, but..."],[7223,7457,"Jennings?"]],"3":[[663,788,"I want this with you."],[1080,1163,"Hey, hey,"],[1226,1313,"slow down."],[1438,1555,"Tell me what you like."],[4667,4833,"I really need money..."],[5234,5321,"Wow."],[5480,5626,"So you're one of those, huh?"],[5843,5926,"What?"],[6056,6231,"I hate gold diggers."],[6635,6865,"I don't want to see you again, okay?"],[7278,7374,"Wait, I-"],[8074,8187,"I'm pregnant?"]],"4":[[25,145,"I'm pregnant?"],[913,1084,"Molly, get out here!"],[1242,1447,"Oh my God, she is going to kill me."],[2072,2202,"Is that a new phone?"],[2314,2485,"How were you able to afford that?"],[2515,2640,"What do you mean?"],[2640,2719,"You gave Mom a thousand bucks"],[2719,2802,"yesterday."],[2932,3086,"That was for Dad's medication!"],[3174,3303,"I worked five nights during midterms"],[3303,3432,"to afford that,"],[3453,3628,"and you just blew it on a new phone?"],[3628,3766,"Yeah! I need the newest tech"],[3766,3903,"if I'm going to be an influencer,"],[3903,3983,"Molly."],[4099,4329,"Move, you're blocking the light!"],[4496,4646,"I am returning this."],[4700,4938,"Mom! Mom!"],[4963,5096,"What?"],[5113,5276,"Molly is trying to ruin my career."],[5367,5484,"Why can't you ever"],[5484,5605,"support your brother?"],[5626,5759,"Could you not be selfish"],[5759,5985,"for one day in your goddamn life?"],[6026,6177,"Honey, are you okay?"],[6177,6402,"Mom, that was for Dad's medication!"],[6402,6564,"You idiot child,"],[6564,6669,"there's always going to be"],[6669,6773,"more than one bill to pay!"],[6773,7052,"What's all this damn yelling going on?"],[7090,7165,"Dad..."],[7240,7361,"wait, how's your eyes?"],[7382,7486,"Huh? My eyes?"],[7503,7653,"Your ungrateful daughter"],[7653,7736,"was just complaining about"],[7736,7895,"how much your medication costs,"],[7895,8070,"now that you can't see."],[8199,8425,"I'm sorry, Molly,"],[8425,8771,"I hate to be such a burden to you, dear."],[8783,8825,"Dad, Dad, Dad,"],[8825,8900,"don't say that, okay?"],[8900,9009,"Look, I'm starting my new"],[9009,9117,"internship today"],[9117,9342,"and I'm going to work really,"],[9342,9480,"really hard, and I will get you"],[9480,9617,"whatever you need, okay?"],[9734,9809,"You can't go until"],[9809,9922,"you clean the kitchen."],[9943,10018,"What? Mom!"],[10018,10060,"No, no, no,"],[10060,10126,"I'm gonna be late!"],[10126,10218,"Well then you should have gotten"],[10218,10443,"up earlier, you irresponsible brat!"],[10685,10814,"It's the least she can do."],[10814,10935,"We put up with her all these years"],[10935,11106,"and she's not even our real daughter."]],"5":[[296,538,"I can't believe we're working for the"],[538,671,"Dr. Graham Weston."],[684,834,"He's like one of the top surgeons"],[834,984,"in the world!"],[1005,1105,"He operates on all"],[1105,1226,"the most important people."],[1259,1401,"Presidents, and celebrities..."],[1584,1710,"Congratulations on getting"],[1710,1864,"an internship at Maple Leaf"],[1864,1964,"Regional Hospital,"],[1964,2072,"the most prestigious medical center"],[2072,2164,"in the country."],[2164,2285,"My name is Dr. Weston,"],[2285,2439,"this is Dr. Jones,"],[2439,2523,"and we'll be..."],[2702,2844,"One of you is missing."],[2923,3057,"She'll be right here, sir."],[3186,3345,"Late on the first day, huh?"],[3407,3545,"Tell her not to come."],[3908,4129,"Hi, I am so sorry."],[4425,4558,"What is he doing here?"],[4558,4729,"Molly, that's our boss, Dr. Weston."]],"6":[[20,154,"Dr. Weston,"],[233,375,"I'm so sorry. I'm your new intern"],[375,450,"Molly Maguire."],[487,592,"Well, you're late."],[642,771,"Who said you could stay?"],[859,1055,"I need this internship."],[1071,1180,"How else am I going to pay"],[1180,1292,"for Dad's medication?"],[1338,1451,"Dr. Weston,"],[1534,1659,"look, I really need this job,"],[1659,1789,"and I promise it won't happen again."],[1872,1968,"I'll do anything."],[2143,2406,"What the hell is she doing here?"],[2581,2694,"When I was thirteen,"],[2694,2811,"a girl saved me."],[2877,2994,"It hurts..."],[3065,3203,"I'm so thirsty..."],[3616,3824,"Drink this. I'll go get some help."],[4295,4512,"Molly has the same beauty mark."],[4796,4934,"We have a zero-tolerance"],[4934,5075,"policy for lateness,"],[5075,5171,"Miss Maguire."],[5234,5388,"If it happens again, you're out."],[6047,6222,"Oh my God, that was close!"],[6222,6418,"Dr. Weston despises lateness."],[6418,6531,"You're the only one he's ever"],[6531,6644,"made an exception for."],[6660,6781,"Don't do it again, though."],[6781,6977,"Nothing gets past him. Come on."],[7011,7119,"Then how am I going to"],[7119,7244,"hide my pregnancy?"]],"7":[[54,171,"Then how am I going to"],[171,287,"hide my pregnancy?"],[704,809,"Hey, hey,"],[875,1026,"we have to use protection."],[1146,1363,"I'm a doctor, you're young,"],[1418,1547,"I absolutely cannot"],[1547,1701,"get you pregnant, okay?"],[1701,1772,"Okay."],[2014,2181,"The condom must have broke."],[2243,2448,"He doesn't want kids. He can't know."],[2515,2640,"How am I gonna work with him"],[2644,2748,"and hide my pregnancy"],[2748,2852,"at the same time?"],[3111,3207,"Hey man,"],[3261,3428,"why'd you go so easy on that intern?"],[3549,3720,"You got a crush on her or something?"],[4091,4291,"She is the girl..."],[4504,4621,"from that night."],[4688,4842,"That's the girl you slept with?"],[4950,5050,"Damn."],[5234,5376,"Hundreds of interns"],[5380,5538,"have literally thrown themselves at you,"],[5543,5643,"and you haven't thought twice"],[5643,5743,"about any of them."],[5910,6031,"She must be special."],[6222,6381,"It was a mistake, okay?"],[6627,6735,"Sure it was."],[7207,7290,"Admin?"],[7340,7482,"Please put Molly Maguire"],[7486,7711,"on rotation with Dr. Weston."],[7849,7941,"Thank you."],[8174,8420,"Well, let's see who I'm with today."],[9484,9634,"Looks like you're with me, Maguire."]],"8":[[79,250,"Looks like you're with me, Maguire."],[275,442,"I will work really hard. I promise."],[442,550,"You better."],[692,892,"I expect the utmost professionalism."],[892,1084,"No slacking. You're my intern,"],[1084,1184,"I'm your attending."],[1413,1539,"Nothing more."],[1722,1776,"Yes, sir."],[1776,1901,"I wanna prove myself, okay?"],[1901,1997,"and I will do anything"],[1997,2097,"to be useful."],[2273,2352,"Okay."],[2477,2610,"I'll just keep my head down"],[2610,2744,"and do my job."],[2744,2811,"He'll never know"],[2811,2927,"I'm pregnant with his baby."],[2990,3082,"Maguire!"],[3436,3516,"Okay,"],[3557,3737,"her blood pressure is 70 over 40,"],[3737,3866,"so we're just gonna have to"],[3866,3995,"put an asterisk there to make sure"],[3995,4208,"it's okay. And then it's your left knee?"],[5597,5714,"Alright, sir."],[5714,5897,"We are going to get you in here"],[5897,6081,"nice and cozy, okay?"],[6172,6260,"Ready?"],[6327,6410,"Alright."],[6956,7186,"I didn't think she'd be so caring."],[7269,7382,"So patient..."],[7515,7686,"Almost off for the day,"],[7753,7907,"and then I just have to make it through"],[7907,8053,"my shift at the nightclub!"],[8083,8149,"Soon I'll have enough for"],[8149,8216,"the down payment"],[8216,8383,"on Dad's glaucoma surgery."]],"9":[[375,546,"I am so sorry, doctor."],[546,688,"It won't happen again."],[759,838,"Molly."],[1380,1476,"Yes?"],[1885,2131,"I can't stop thinking about that night."],[2214,2331,"As a medical intern,"],[2331,2431,"you should know not to leave"],[2431,2531,"a cut untreated."],[2781,2861,"Sit."],[4934,5042,"Thank you, Dr. Weston."],[5676,5759,"Knock, knock!"]],"10":[[54,141,"Knock, knock!"],[216,467,"Oh, please, don't let me interrupt."],[487,596,"No, I was just leaving."],[600,688,"I will see you tomorrow,"],[688,779,"Dr. Weston."],[1234,1409,"Not a word, Owen."],[1614,1780,"Where is that cutie pie"],[1780,1872,"waitress at?"],[2031,2252,"Baby girl, what's up?"],[2256,2389,"Come take a break with us!"],[2389,2473,"I know you're working"],[2473,2560,"so hard tonight."],[2660,2848,"Guys, you know I wish I could,"],[2877,3111,"but I have other tables to serve."],[3128,3307,"And 100 more dollars to make"],[3311,3511,"before I can afford that down payment."],[3524,3691,"Come on, I bet you have"],[3691,3866,"five minutes to spare!"],[3949,4187,"Yeah, come keep us company."],[4254,4371,"There's a lot more where"],[4371,4491,"this came from."],[4537,4621,"Well,"],[4700,4854,"can't say no to that."],[4963,5221,"Just a minute, okay, just a minute."],[5534,5751,"Can't have your dessert, until..."],[5843,5997,"you have your dinner first."],[6014,6231,"I can't drink, I'm pregnant."],[6393,6644,"Unfortunately, boys, I am on the clock."],[6765,6865,"I know..."],[6915,7119,"Don't act all high and mighty."],[7190,7340,"I know what girls like you really want,"],[7340,7624,"with your short skirt and your pigtails."],[7803,7957,"You're practically begging"],[7957,8120,"for guys like us"],[8124,8329,"to put money down your panties."],[8420,8521,"Now drink."]],"11":[[58,175,"Now drink."],[296,550,"No. I am not going to drink it, okay?"],[1263,1347,"The manager is going to"],[1347,1434,"kick you out."],[1434,1534,"Oh yeah?"],[1780,1914,"Who are they going to believe?"],[1943,2127,"Some no name waitress?"],[2127,2314,"Or the two highest paying members?"],[2335,2615,"Now, act like a good little girl..."],[2627,2769,"and play along."],[3432,3586,"You're gonna regret that."],[3757,3816,"Wait, no, no, no."],[3832,3920,"Please, I'm pregnant!"],[3920,4045,"Please don't hurt my baby!"],[4083,4270,"Shut up, you whiny little bitch!"]],"12":[[0,133,"Please don't hurt my baby!"],[196,387,"Shut up, you whiny little bitch!"],[1038,1088,"You okay?"],[1088,1155,"Did they hurt you?"],[1192,1305,"No, I'm fine."],[1317,1455,"I can handle it,"],[1455,1651,"this happens all the time here."],[1935,1989,"Here."],[2027,2127,"Thank you,"],[2127,2210,"Dr. Weston."],[2281,2377,"He doesn't know it,"],[2377,2515,"but he saved our baby."],[2615,2806,"Maybe it's time to tell him the truth."],[2877,3011,"Let's get you home, okay?"],[3123,3253,"Nah, pretty boy."],[3319,3453,"She's with us tonight."],[3582,3641,"You don't know who"],[3641,3728,"you're talking to, buddy."],[3795,3966,"Yeah, neither do you."],[4175,4295,"Oh, my arm!"],[4341,4517,"It's just a radial fracture."],[5117,5263,"Come on, let me see."],[5442,5563,"A broken ulna, that's going to"],[5563,5689,"take much longer to heal."],[5801,5918,"Weston, huh?"],[5968,6177,"Yeah, top analysts."],[6197,6289,"We got a seven-figure"],[6289,6381,"raise coming."],[6381,6489,"And we're gonna sue you"],[6489,6602,"for everything, asshole!"],[6602,6731,"Not anymore, you won't."],[6831,6927,"You're fired."],[6981,7077,"Both of you."]],"13":[[120,208,"You're fired."],[271,362,"Both of you."],[487,625,"Deal with these losers, will you?"],[654,788,"Gladly, Dr. Weston."],[871,971,"Weston?"],[971,1188,"Like Graham Weston? The heir"],[1188,1409,"of the Weston Corporation?"],[1430,1530,"Yeah. Maybe next time"],[1530,1647,"you'll think twice before"],[1647,1764,"harassing innocent girls."],[1801,1956,"Get 'em out of here. Come on."],[2623,2723,"You sure you're okay?"],[2723,2873,"Yeah, yeah, I'm fine."],[3282,3453,"How did you find me here?"],[3636,3841,"I overheard you"],[3841,4054,"say you work at a club every night"],[4058,4208,"after your hospital shifts."],[4308,4416,"I was worried."],[4508,4617,"I wanted to see what"],[4617,4729,"it is you're up to,"],[5050,5238,"and..."],[5288,5505,"what secrets you're hiding from me."],[5568,5714,"He's a world-renowned"],[5714,5751,"surgeon"],[5751,5860,"and the heir to the"],[5860,5960,"Weston Corporation."],[6031,6247,"I can't tell him that I'm pregnant."],[6277,6352,"He already thinks that"],[6356,6431,"I'm a gold-digger,"],[6431,6544,"what if he makes me"],[6548,6664,"get rid of the baby?"],[6973,7048,"Molly,"],[7278,7515,"back there with those men..."],[7770,7912,"Did I hear you say"],[7916,8066,"that you were pregnant?"]],"14":[[296,342,"No, I-"],[342,433,"I was just scared,"],[433,617,"I just said that."],[792,984,"But thank you, Dr. Weston."],[1096,1192,"I have to get back to work, okay."],[1317,1401,"Work?"],[1472,1568,"Yeah..."],[1568,1693,"You need money so badly"],[1693,1897,"you let men like that prey on you?"],[2031,2227,"Is this what you do every night?"],[2227,2385,"You get drunk and you sell yourself?"],[2464,2565,"Was the money I gave you"],[2565,2665,"not enough?"],[3007,3111,"Look, you don't get it-"],[3111,3274,"Maybe you should just quit"],[3274,3436,"the internship, Molly."],[3482,3591,"You'd make a lot more"],[3591,3707,"in a place like this."],[4375,4475,"You know what?"],[4537,4671,"What happened between us"],[4671,4808,"that night, Dr. Weston,"],[4963,5188,"I've never done that before, ever."],[5267,5430,"And that was my first time."],[7082,7190,"Hey Jennings,"],[7278,7382,"I need you to look into"],[7382,7490,"something for me."],[8833,8892,"Hello?"],[8896,9042,"Come home immediately!"],[9054,9196,"Your dad is getting worse."],[9196,9388,"He says he's in terrible pain!"],[9388,9467,"What?"],[9517,9626,"Okay, I'm on my way."]],"15":[[33,362,"So we tell her that the surgery"],[362,513,"is going to cost more"],[513,650,"because of complications,"],[671,813,"and then she'll have to accept"],[813,917,"the marriage to Holt."],[988,1280,"That's genius, Mom, that's genius!"],[1455,1730,"But isn't Mr. Holt too old to marry Molly?"],[1901,2139,"That's the whole point, dummy."],[2139,2369,"He's old and rich!"],[2369,2489,"When she marries him,"],[2489,2731,"we get the money for the surgery,"],[2731,2990,"and then when he tragically passes,"],[3028,3182,"we take the insurance payout."],[3182,3465,"Oh, I can picture it now..."],[3474,3657,"Story time:"],[3670,3812,"My sister married some"],[3812,3958,"90-year-old rando"],[3958,4091,"and stole his money."],[4454,4583,"I'm gonna go so viral."],[4617,4742,"I've wasted so much money"],[4742,4867,"raising that girl."],[4871,5021,"She's not even my real-"],[5217,5413,"Daughter!"],[5413,5643,"Oh, you're here. It's about time."],[5643,5809,"Your father has been screaming"],[5809,5980,"in agony for hours!"],[6151,6260,"The doctor says it's bad."],[6260,6377,"His surgery is going to"],[6377,6498,"cost twice as much."],[6498,6677,"Oh my God, Dad!"],[6706,6777,"No, no, no."],[6777,6861,"Let him rest."],[6861,7090,"We have important matters to discuss."],[7570,7836,"Molly, I have wonderful news."],[7891,8024,"You're engaged!"],[8141,8324,"Engaged? What?"],[8324,8508,"To who?"],[8508,8762,"To Mr. Holt! Isn't that wonderful?"],[8762,8863,"He's agreed to give us the money"],[8863,8983,"for Dad's surgery"],[8983,9109,"once you're his wife."],[9355,9551,"You mean the 90-year-old"],[9551,9813,"pervert neighbor Mr. Holt?"],[9993,10155,"He lives in the hospital now."],[10155,10231,"Well, great."],[10231,10410,"You'll be able to see him all the time."],[10535,10727,"I'm not marrying Mr. Holt!"],[10894,11086,"You'd just let your father die?"],[11219,11440,"I can't marry Mr. Holt, okay?"],[11878,11982,"I'm pregnant."]],"16":[[20,125,"I'm pregnant."],[467,629,"You're pregnant?"],[1063,1401,"You slut. You should be working day-and-night"],[1401,1555,"to pay for your father's surgery."],[1555,1885,"Instead you're partying and whoring yourself out!"],[1897,2081,"Do you even know who the father is?"],[2081,2202,"No, it's not like that, okay?"],[2339,2585,"I've worked myself to the bone for Dad."],[2736,2890,"What have you and Brian done?"],[3073,3286,"Tell her to abort it, Mom."],[3294,3603,"Mr. Holt will not marry a knocked-up slut."],[3649,3841,"I am not getting an abortion."],[3953,4162,"We're going to the hospital now!"],[4162,4275,"No, let me go, please!"],[4275,4421,"I want my baby, please!"],[4421,4617,"A hospital abortion is too expensive, Mom."],[4617,4879,"We have to take matters into our own hands."],[5080,5276,"Did that hurt? Good."],[5276,5480,"Now you know how your father feels."],[6318,6468,"You left work in the middle of your shift."],[6468,6569,"If you're calling with excuses,"],[6569,6690,"I don't wanna hear it."],[6690,6856,"Help me, please!"],[6894,7015,"Who's that, Molly?"],[7015,7215,"Your knight in shining armor?"],[7215,7390,"Good luck finding her!"],[7674,7761,"Dr. Weston,"],[7853,7991,"I looked into it, sir."],[8008,8170,"Miss Maguire never cashed your check."],[8270,8437,"I made a huge mistake."],[8562,8750,"She wasn't after my money."],[8750,9050,"We gotta go now."],[9659,9818,"No."],[9880,10005,"Little sister..."],[10314,10477,"See, this face is too important"],[10477,10552,"to be near a knife."],[10577,10723,"You’ll cost me my brand deals."],[10748,10910,"You ought to be ashamed of yourself,"],[10952,11194,"pregnant before marriage and by a stranger"],[11194,11482,"no less. I'll get rid of this child myself!"],[11553,11736,"Wait, no, please!"]],"17":[[33,225,"I'll get rid of this child myself!"],[296,517,"Wait, no, please!"],[517,654,"The father's not a stranger!"],[654,729,"Please!"],[796,971,"You liar. How would you know?"],[975,1197,"I bet you've been with dozens of men."],[1197,1380,"No, I'm not lying!"],[1434,1534,"That's exactly what a liar"],[1534,1639,"would say, right?"],[1697,1805,"Hold her down!"],[1810,1997,"I'll get rid of this baby myself!"],[1997,2110,"No, please!"],[2114,2385,"Please, the father is a Weston!"],[2410,2560,"Graham Weston. He's a doctor."],[2681,2852,"Graham Weston?"],[2857,2977,"The son of the"],[2977,3103,"richest man in America?"],[3236,3336,"You filthy liar."],[3336,3607,"I will beat this baby out of your belly!"],[3632,3774,"Get away from her!"],[4387,4508,"My money-maker!"],[4571,4729,"My influencer career!"],[4733,4804,"It's ruined!"],[4804,4934,"You touch her again,"],[4938,5080,"and that's not all I'll ruin."],[5342,5430,"Graham, you came."],[5467,5651,"How dare you attack my son,"],[5651,5747,"you freak!"],[5980,6076,"I wouldn't insult Dr. Weston"],[6076,6160,"if I were you."],[6214,6368,"His family is very powerful."],[6564,6723,"So this little bitch wasn't lying?"],[7011,7077,"Did they hurt you?"],[7077,7223,"I'm fine, just..."],[7515,7645,"Can you please"],[7645,7778,"have mercy on them?"],[7828,7941,"My dad is sick and"],[7941,8141,"we're all that he has."],[8274,8571,"If you're so rich... Pay us!"],[8575,8750,"You tainted my..."],[8754,8888,"my sister with your filthy,"],[8888,8996,"filthy child."],[9117,9250,"Did you say child?"]],"18":[[141,287,"Did you say child?"],[387,467,"Huh?"],[563,829,"You assaulted a pregnant woman?"],[992,1071,"I'm sorry."],[1071,1197,"I'm not the one that"],[1197,1322,"you should be apologizing to."],[1322,1426,"No, Molly is the one who"],[1426,1584,"should be apologizing!"],[1601,1810,"She's not deserving of your protection."],[1843,2027,"In fact, if you know it was good for you,"],[2027,2231,"you would get rid of her and the child!"],[2273,2464,"Why don't you just give us $1 million"],[2464,2610,"and be done with it!"],[3044,3157,"You said a million?"],[3332,3411,"Yes."],[3732,3812,"Yes!"],[4446,4842,"It's yours, if you get on your knees"],[4842,5034,"and you beg Molly for forgiveness."],[5138,5284,"I am her mother,"],[5284,5434,"she should be begging me!"],[5643,5847,"I'm so sorry! I'm so sorry!"],[5860,5943,"I shouldn't have touched you!"],[5943,6035,"I shouldn't have touched you!"],[6035,6160,"I'm sorry, I'm a monster!"],[6160,6285,"I'm a terrible mother!"],[6322,6406,"It's too late."],[6535,6694,"Oh no, you said-"],[6698,6898,"You won't get a cent from me"],[6898,