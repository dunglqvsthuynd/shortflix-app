{"1":[[588,817,"Jennifer Sullivan."],[817,1113,"You'll regret winning this case!"],[1593,1672,"Breaking news!"],[1672,1922,"There is a major fire in the city,"],[1922,2193,"the casualty count is still unknown."],[2193,2344,"Polices are investigating"],[2344,2494,"the cause of the fire."],[2538,2606,"No..."],[2723,2827,"Oh my god!"],[3123,3253,"Stop!"],[3403,3490,"There're my family!"],[3490,3616,"That's my mother."],[3616,3687,"That's my..."],[3687,3770,"Mom!"],[5847,5968,"Boss,"],[5968,6264,"her sister still alive."],[8666,9000,"Ms. Sullivan, this is May Sullivan's bill."],[9805,10185,"This is all too much, I can't handle this."],[10839,10925,"Hello."],[10925,11037,"Good morning, Mrs. Jones."],[11037,11186,"This is Ms. Sullivan."],[11386,11594,"Hello? Mrs..."],[11891,12016,"Hello?"],[12016,12191,"Mr. Jones. Hi, this is Ms. Sullivan."],[12191,12287,"No, no. Ms. Sullivan,"],[12287,12470,"please don't call me again!"],[12470,12583,"Hello?"],[12871,12988,"I have become someone"],[12988,13234,"people avoid like the plague."],[13288,13338,"Do you know"],[13338,13588,"what it's like to fall from heaven to hell?"],[13646,13947,"I do, because I'm in hell right now."],[14014,14089,"I can't!"],[14089,14189,"I can't let you in."],[14189,14272,"Okay!"],[14635,14789,"I'm sorry. I'm..."],[14789,15019,"Can I have a few days more"],[15019,15160,"to pay for my sister's bill?"],[15160,15361,"What are you talking about, Ms. Sullivan?"],[15361,15532,"Someone has already prepaid"],[15532,15632,"for two months."],[15632,15786,"Who did?"],[15786,16086,"That gentleman that just went down there."],[16086,16320,"—Do you not know him? —No."],[16320,16470,"—Thank you. —Yeah."],[16541,16691,"Wait!"]],"2":[[4,137,"Wait!"],[396,467,"Who are you?"],[467,642,"Ms. Sullivan."],[642,825,"If you wanna learn more,"],[825,1126,"please come to this address tomorrow."],[2210,2398,"Here you are."],[2398,2548,"Mr. Marks,"],[2635,2771,"do we know each other?"],[2882,2982,"I heard that you were the one"],[2982,3111,"who paid all the bills"],[3111,3311,"in the hospital for my sister."],[3349,3475,"Why would you do that?"],[3916,4062,"I'll be straightforward then."],[4120,4304,"You need money,"],[4304,4562,"and I need someone to be my spy."],[4562,4708,"Your spy?"],[4708,4929,"I'll pay you $1 million."],[4929,5025,"Permission?"],[5025,5226,"Your first one is already lined up."],[5226,5351,"Would you accept it?"],[5351,5568,"You're the second son"],[5568,5793,"of the Marks family."],[5793,5960,"You could have so many choices."],[5960,6071,"Why me?"],[6331,6523,"You're competent,"],[6523,6648,"and you're desperate."],[6648,6869,"And giving you a situation,"],[6869,7052,"there's no other way to make money,"],[7052,7173,"is there?"],[7674,7845,"Think about your sister."],[7845,8145,"Ms. Sullivan."],[9234,9388,"Your first mission will be"],[9388,9572,"going to Marks International"],[9572,9897,"and becoming Shane Marks'"],[9897,10172,"executive assistant."]],"3":[[663,963,"Hi! You're Ms. Sullivan."],[1017,1202,"You were referred to by my brother Isaac."],[1347,1402,"May I?"],[1402,1580,"Sure."],[1726,1885,"An international student"],[1885,2030,"who received a full scholarship"],[2030,2187,"to an Ivy League school,"],[2204,2358,"climbed her way to the top"],[2358,2439,"and became one of the"],[2439,2647,"most respected lawyers in her field."],[2719,2915,"So, what brings you"],[2915,3103,"to an assistant job interview?"],[3169,3269,"Well, Mr. Marks,"],[3269,3499,"if you've been reading the papers"],[3499,3649,"in the last weeks, you know that"],[3649,3895,"there's this big arson case in the city,"],[3895,4320,"and the victims are my family, and I..."],[4414,4507,"How are you holding up?"],[4608,4792,"Well, I'm…"],[4892,5388,"I... My law license has been suspended"],[5388,5747,"for some reason, and I really need the..."],[5747,5926,"the money to help my sister."],[5926,6217,"She's the only survivor of the fire."],[6217,6429,"I really need this job, Mr. Marks."],[6468,6677,"And one last question."],[6769,6898,"What is your relationship"],[6898,7017,"with my brother Isaac?"],[7311,7561,"Shane and Isaac are in competition."],[7561,7760,"He can't find out I'm involved."],[7760,7849,"Uh..."],[7957,8291,"Well, he's my ex-boyfriend."],[8391,8512,"We broke up a long time ago,"],[8512,8600,"but as soon as he heard of"],[8600,8808,"what happened, he reached out."],[8808,8975,"So. Yeah."],[8975,9238,"Well, thank you for your honesty."],[9238,9438,"I trust Isaac."],[9438,9676,"Well, that settles it."],[9676,9759,"Ms. Sullivan,"],[9759,9993,"welcome to Marks International."],[10076,10268,"Thank you, Mr. Marks."],[11795,12049,"You've finished your first mission."],[12049,12187,"I've wired you the money."],[12187,12411,"Thank you, Mr. Marks."],[12487,12716,"What is my second mission, then?"],[12716,12883,"You need the money so badly?"],[12883,12992,"Well, you know how badly"],[12992,13154,"I need the money. Yes."],[13154,13397,"And you will do anything for money?"],[13788,13882,"Of course."],[14084,14222,"Can you swim?"],[14268,14330,"No."],[14346,14498,"Jump in the pool,"],[14498,14715,"and I will give you 1 million."]],"4":[[3762,3991,"Looks like you really can't swim, can you?"],[4771,4982,"Didn't you say you are my ex-girlfriend?"],[5088,5349,"Is this my punishment for lying?"],[5530,5630,"Can you keep something"],[5630,5732,"between us?"],[5964,6165,"I need a secret girlfriend."],[6274,6520,"This is going to be my second mission?"],[6614,6995,"No, but you will get what you want."],[8387,8556,"I have a new mission for you."],[8762,8930,"Get rid of Shane's baby."]],"5":[[0,177,"Get rid of Shane's baby."],[671,913,"I said nothing illegal!"],[913,1184,"The baby is't born yet, so technically,"],[1184,1330,"it's not even murder."],[1330,1468,"You are smart."],[1468,1589,"If my father finds out"],[1589,1722,"that Shane has a baby,"],[1722,1885,"he will give all his shares"],[1885,2077,"of Marks International to Shane."],[2131,2283,"I will have no money"],[2302,2442,"and nothing to pay you."],[2485,2681,"Whether the baby's born or not,"],[2790,3097,"that is still a life, Mr. Marks."],[3123,3319,"If you can't promise me that,"],[3319,3520,"then I can't promise you"],[3520,3712,"that your sister's oxygen machines"],[3712,3841,"will be still on."],[4033,4136,"You know what to do."],[5234,5568,"This is our new island tourism project."],[5568,5805,"New Water Castle! Starting today,"],[5805,5997,"I will be staying at that hotel"],[5997,6235,"to monitor the construction."],[6235,6489,"We'll talk details later at the meeting."],[6635,6752,"Don't worry, Dad."],[6752,6885,"We can handle the project."],[7866,7912,"Do you think"],[7912,8041,"Dad will like these blueprints?"],[8153,8304,"God, you like a mosquito."],[8304,8650,"And just suck on Dad's so much!"],[8683,8783,"Just relax."],[8783,8938,"This project's important."],[8938,9041,"Is it that important?"],[9041,9313,"Just calm down. I got it."],[9576,9622,"What makes you think"],[9622,9772,"you can sit here with us?"],[10014,10189,"A bastard born to a maid."],[10301,10406,"Can't believe Dad even brought you"],[10406,10627,"back home to this family."],[11030,11153,"Is that your new assistant?"],[11368,11468,"She's pretty."],[11582,11746,"Don't you think Ruby will get jealous?"],[11770,11953,"—Well. —Shane!"],[12266,12312,"Ruby!"],[12312,12433,"Ruby...?"],[12433,12579,"—Hey. —Why did you come?"],[12579,12729,"I thought you looked a little peckish,"],[12729,12867,"so I thought I'd bring you up."],[12867,12962,"You didn't have to do that."],[12962,13038,"You're carrying our baby."],[13038,13138,"Oh, it's okay."]],"6":[[212,658,"If you can't do this, I can't promise you"],[658,913,"that your sister's oxygen machine"],[913,1067,"won't be turned off."],[1530,1609,"Mr. Marks!"],[1668,1756,"Did I scare you?"],[1772,1935,"No. What are you doing here?"],[1935,2072,"I came to bring you this."],[2072,2264,"I thought you've been working all day."],[2323,2498,"Thank you."],[3211,3286,"Excuse me, everyone,"],[3286,3420,"can I have your attention, please?"],[3490,3574,"I wanna thank you all"],[3574,3745,"for coming to our engagement party."],[3745,3895,"A quick announcement,"],[3895,4123,"my fiancé, Ruby, is pregnant!"],[4487,4608,"This is how you accomplish"],[4608,4764,"your mission, huh?"],[5303,5534,"Shane, you're so kind to me."],[5572,5672,"I can't."]],"7":[[16,254,"The Marks family is finally welcoming"],[254,412,"a new member."],[412,592,"I'm happy to announce that"],[592,809,"Marks International's new project,"],[809,1138,"the New Water Castle, will be overseen"],[1138,1301,"by my youngest son."],[1301,1378,"Ruby!"],[1442,1555,"You can't do this to me!"],[1643,1712,"You're married?"],[1712,1906,"You're engaged to Marks now?"],[1906,2010,"But what about me?"],[2047,2189,"What about our child?"],[2260,2335,"Who are you?"],[2335,2494,"Who am I?"],[2494,2588,"Didn't she tell you?"],[2719,2828,"I'm her boyfriend!"],[3445,3693,"If you don't believe me, get a DNA test."],[3693,3858,"This child is mine!"],[3858,3960,"Nonsense!"],[4083,4175,"Get them out!"],[4215,4412,"Who the fuck is this guy?"],[4412,4550,"You knew how excited"],[4550,4738,"I was about this grandson."],[4917,5056,"How could you embarrass me"],[5056,5125,"like this!?"],[5125,5313,"I had no idea this was happening, okay?"],[5313,5476,"I just found out. Just like you did!"],[5476,5743,"Get them out!"],[6300,6419,"Here you go."],[6585,6676,"What?"],[6756,6905,"You don't think you deserve it?"],[6971,7036,"Here..."],[7036,7115,"If..."],[7115,7334,"If you think I do, then yes."],[7449,7670,"Hey, don't try to play smart with me,"],[7670,7739,"okay?"]],"8":[[37,333,"Hey, don't try to play smart with me, okay?"],[859,970,"Mr. Marks,"],[1063,1363,"she's carrying a life inside her."],[1363,1557,"And with Keith showing up,"],[1570,1760,"you got the same result."],[1760,1935,"That solution"],[1935,2152,"will be a problem later on the line."],[2273,2387,"No, we won't."],[2502,2656,"You won't cause any problem."],[2656,2777,"You can't even take care"],[2777,2896,"of an unborn child."],[3044,3222,"And you wanna be the good guy?"],[3495,3622,"No, you're..."],[3712,3789,"You're right."],[3833,3953,"I'm not the good guy."],[4204,4448,"As a lawyer, I took on..."],[4571,4808,"cases that I shouldn't have taken."],[5005,5099,"And then I took money that"],[5099,5242,"I shouldn't have taken."],[5363,5497,"And now parents are dead."],[5718,5950,"And my sister's in the hospital because of it."],[6106,6247,"I should've been the one to die."],[6510,6644,"Don't do it again."],[6856,6958,"I won't."],[7504,7589,"Leave."],[7611,7726,"Go back to your boss."],[8108,8175,"Yes."],[8879,9023,"You be kind to others,"],[9146,9347,"and they just won't return the favor."],[10735,10873,"Mr. Marks?"],[10950,11102,"Mr. Marks, are you okay?"],[11198,11359,"Mr. Marks!"],[11945,12037,"I got you."]],"9":[[208,404,"We need to work with the Anderson family"],[404,621,"if we want this project to go smoothly."],[675,821,"If one of you manages"],[821,921,"to marry their daughter,"],[921,1063,"Sharon Anderson,"],[1063,1368,"I will give you 10% of the company's shares"],[1368,1505,"as a reward."],[1505,1583,"Shane!"],[1655,1851,"Did you hear that?"],[1851,1939,"How long would you are going to"],[1939,2152,"act like this over a woman?"],[2256,2489,"I heard you, Dad."],[2598,2756,"I don't wanna marry a woman I don't love."],[2761,2879,"Sentimental."],[2998,3153,"I will hand this project to..."],[3153,3445,"Shane. I'm so, so sorry."],[3499,3620,"Ruby, what are you doing here?"],[3620,3721,"Who let her in?"],[3983,4119,"Get her out!"],[4141,4441,"I know you've been really upset about..."],[4500,4597,"all of this."],[4813,4953,"Baby, I'm not worth it."],[5080,5330,"Somebody get this woman out!"],[5347,5587,"Shane had nothing to do with any of this."],[5587,5843,"It was... It's all my fault!"],[5989,6073,"Actually,"],[6168,6295,"it was Isaac."],[6560,6668,"He put me up to it."],[6670,6817,"He made me lie to Shane!"]],"10":[[20,321,"He made me lie to Shane."],[529,671,"It was!"],[671,846,"It was Isaac!"],[846,1084,"He told me that"],[1084,1251,"George really wanted a grandson,"],[1251,1405,"and that if I claimed"],[1405,1601,"the child of Shane's that"],[1789,2014,"I can make a lot of money."],[2421,2533,"It's my fault."],[2656,2736,"I'm sorry."],[2927,3128,"Shane, I'm so..."],[3128,3230,"Sorry."],[3461,3621,"Do you have any evidence of this?"],[3687,3883,"Actually, I..."],[4083,4239,"Written in Isaac's handwriting."],[4475,4788,"Dad, this is Isaac's signature,"],[4850,5080,"and the account numbers is ours as well."],[5196,5347,"Isaac,"],[5347,5482,"look what you've done!"],[5755,5837,"Isaac,"],[5894,6097,"is this true?"],[6097,6224,"How did this happen?"],[6310,6503,"I was the one who found Keith."],[6581,6743,"Isaac didn't know anything about it."],[6790,7065,"You be kind to others,"],[7065,7262,"and they just won't return the favor."],[7649,7812,"Did Isaac come to you himself?"],[7874,8094,"Or did he send someone to do his dirty work?"],[8110,8189,"It was..."],[8741,8837,"Was..."],[8849,8939,"Ms. Ruby,"],[9032,9149,"who are you to frame?"],[9172,9396,"I though I bought your silence."],[9880,9993,"Enough!"]],"11":[[50,183,"I said enough!"],[296,504,"Who do you think you are?"],[959,1001,"Looks like"],[1001,1238,"I should've beat you more as a kid."],[1238,1526,"You'd be different now!"],[1593,1768,"I don't have a son like you!"],[1768,1926,"Not like you!"],[1926,2077,"Yeah, Dad teach him a lesson."],[2077,2139,"You need to make sure"],[2139,2261,"he never does this again."],[2310,2452,"If I had known,"],[2452,2654,"I would've never let your mother keep you!"],[2781,2907,"You and your mother"],[2907,3090,"have been nothing but trouble!"],[3098,3190,"Then why did you keep me"],[3190,3455,"in the first place? Huh?"],[3766,3872,"Isaac,"],[3941,4137,"you're such a disappointment."],[4200,4282,"Tyler."],[4396,4564,"I'm giving the project to you."],[4600,4742,"Come, we need to talk."]],"12":[[2298,2389,"Here."],[2669,2749,"Come on!"],[2752,2869,"It's cold outside."],[2869,2994,"Father doesn't wanna see."],[3340,3446,"Piss off!"],[3503,3642,"Just fucking leave me alone."],[4917,5248,"Compared to the devil that Isaac is,"],[5325,5470,"Shane is an angel."]],"13":[[838,937,"Where is he?"],[1105,1184,"Did you want him"],[1184,1335,"to freeze to death overnight?"],[1413,1543,"You guys are brother after all."],[1543,1628,"My blood runs."],[1628,1796,"When are you gonna be like Shane?"],[1814,1916,"He was the only one"],[1916,2144,"bringing Isaac a blanket last night."],[2994,3206,"My room, now."],[4129,4191,"Mr. Marks,"],[4191,4370,"we have to drive you to the hospital now."],[4370,4451,"No!"],[4504,4595,"Yes."],[4675,4890,"There's a first aid kit in the second drawer."],[4912,5054,"Mr. Marks, please."],[5120,5182,"No!"],[5363,5521,"It won't kill me, okay?"],[6218,6335,"Okay."],[6423,6539,"Okay."],[6927,7082,"Okay, this is going to hurt."],[7112,7232,"Okay?"],[7699,7789,"I'm sorry."],[8533,8755,"Oh. These scars..."],[8842,8988,"what did the Marks family"],[8988,9122,"put him through?"],[9509,9580,"I'll get you..."],[9580,9741,"I'll get you some water now."]],"14":[[91,221,"That Ruby thing."],[379,518,"Someone's behind it all."],[664,752,"Yeah..."],[900,1027,"It must be Tyler."],[1338,1530,"Why can't it be Shane?"],[1881,2139,"No, no... Shane..."],[2139,2267,"Shane is different."],[2410,2524,"We're all like"],[2570,2819,"hyenas... Hiding in the dark,"],[2819,3061,"trying to pounce at any time."],[3116,3224,"What about Shane?"],[3435,3530,"He's..."],[3690,3843,"He's like a breath of fresh air."],[4054,4174,"Have you ever been wrong?"],[4323,4432,"Well, I'm..."],[4433,4642,"I'm a good judge of character."],[4662,4904,"So your next mission is gonna be"],[4904,5094,"to seduce the breath of fresh air."],[5207,5334,"No, Mr. Marks, you..."],[5334,5502,"You flatter me. No, I..."],[5502,5772,"I can't take that."],[6085,6245,"Don't tell me you fell in love with him!"],[6439,6595,"I sent you to spy on him."],[6769,6864,"And you?"],[7057,7198,"you fell in love with him!"],[7250,7574,"Mr. Marks, you've got it all wrong."]],"15":[[404,602,"We got rid of Isaac with just a Ruby."],[721,881,"Now the project is mine,"],[992,1167,"and when I married Sharon Anderson,"],[1238,1423,"he will forever be out of the Marks family."],[1480,1615,"Don't get ahead of yourself."],[1951,2106,"make sure there are no loose ends."],[2335,2414,"That doesn't sound like"],[2414,2552,"something you would say, Romeo."],[2744,2857,"To return the favor,"],[2930,3068,"do you want me to get rid of Jennifer?"],[3482,3650,"No, you don't have to worry about her..."],[6247,6364,"Hi, Sharon."],[6364,6510,"I'm Tyler Marks,"],[6510,6685,"the oldest son of the Marks family."],[6756,6925,"I really look forward to working with you."],[7098,7211,"I can't lie to you."],[7515,7799,"So, that's Sharon Anderson."],[7853,7912,"No wonder"],[7912,8142,"Isaac wants me to seduce Shane."],[8195,8329,"He wants to make sure"],[8329,8444,"Shane won't be in his way of"],[8444,8525,"marrying Sharon."]],"16":[[20,130,"I can't lie you."],[209,342,"As soon as you walked in,"],[371,496,"you caught my eye."],[553,731,"You're the shiniest diamond of the bunch."],[860,973,"Oh, boring."],[1150,1327,"You have a great taste in wine, Sharon."],[1360,1538,"That's from our very own March Winery."],[1750,1906,"So, where's Shane?"],[2083,2171,"Shane?"],[2505,2618,"Ouch! Excuse me?"],[2624,2741,"Watch way you're going!"],[3174,3403,"Oh, I know who you are!"],[3403,3655,"Isaac Marks, you're the second born"],[3655,3757,"Marks son."],[3816,3911,"Yeah, no wonder"],[3911,4091,"everybody likes you least."],[4137,4294,"That's none of your business, isn't it?"],[4294,4425,"It's very much my business,"],[4425,4510,"since you just spilled wine"],[4510,4628,"all over my dress."],[4655,4792,"It's an ugly one, anyways."],[4832,4925,"Excuse me?"],[4925,5042,"It's one of the kind."],[5042,5376,"Oh, many things are one of a kind."],[5376,5520,"It doesn't mean it's beautiful,"],[5520,5591,"does it?"],[5668,5780,"—I... —Hi, brother."],[6068,6235,"Of course I can pay for it."],[6235,6385,"I don't want anything from you."],[6414,6493,"Thanks."]],"17":[[618,709,"Over there,"],[729,834,"are going after Sharon."],[900,1005,"Aren't you run into something"],[1005,1192,"like them, too?"],[1263,1459,"No, I don't believe in using marriage"],[1459,1650,"as a way to get what I want."],[1797,1972,"No, if I'm going to get married,"],[1972,2049,"I want it to be because"],[2049,2239,"I'm in love with someone."],[2398,2520,"Shane, hi!"],[2794,2871,"Kill me!"],[2877,2965,"Excuse me..."],[3019,3265,"—Ouch... —Oh, you are okay?"],[3265,3488,"Yeah, I, I think I just twisted my ankle."]],"18":[[187,370,"Is that Shane's assistant?"],[396,513,"Is Ms. Anderson's jealous?"],[513,643,"I'm not jealous."],[900,1038,"There's something not right about her."],[1038,1278,"I heard that she pissed off the wrong person,"],[1278,1495,"and she got her whole family killed"],[1495,1584,"in a fire."],[1664,1797,"She's bad luck."],[1797,1881,"A lady should know"],[1881,1988,"not to talk about others"],[1988,2089,"behind their back."],[2089,2238,"Yeah, yeah, yeah..."],[2756,2901,"What are you doing?"],[3057,3226,"Those ones are ugly, anyways."],[3328,3478,"They don't get it with your dress."],[4204,4300,"There you go."],[4412,4527,"You can't get around much now."],[4654,4771,"Just..."],[4771,4846,"holler if you need anything."],[4846,4926,"I'll be right next door."],[5050,5247,"Thank you. Mr. Marks. Wait, wait."],[5247,5442,"You have..."],[5442,5580,"something on your cheek."],[5580,5709,"It's my Lipstick from before."],[5709,5830,"—Oh. —I'm sorry."],[5830,6014,"It's okay, I'll just take care of it."],[6014,6331,"No, it's kind of hard to take it off."],[6331,6573,"I just need a wet wipe,"],[6573,6852,"and I happen to have one in my purse."],[7036,7194,"—May I? —Okay."],[7194,7286,"Okay."],[7841,7991,"You have to close your eyes,"],[7991,8170,"I can't do it with your eyes on."],[8216,8324,"Okay."],[9442,9542,"There you go."],[9542,9622,"Thank you."]],"19":[[16,279,"I'm just gonnao go back to my room and,"],[279,371,"get some rest."],[371,525,"Okay?"],[1718,1851,"Oh my God!"],[1989,2165,"That was so great!"],[2377,2502,"I was only doing it for the mission,"],[2502,2598,"Mr. Marks."],[2644,2800,"I underestimated you."],[2840,3100,"It was a mission from you."],[3165,3499,"I must do it, no matter how hard it is,"],[3499,3595,"as you know."],[3595,3771,"Oh, it didn't even look hard."],[3791,3941,"You looked so smooth doing it."],[4012,4133,"Who would have thought that"],[4133,4433,"the great lawyer, Jennifer Sullivan,"],[4504,4833,"is so good at seducing men!?"],[5046,5305,"We are in in your family's hotel."],[5305,5472,"Aren't you afraid that"],[5472,5721,"they will find you conspiring with me?"],[5818,5858,"Heh?"],[5878,6036,"I like the danger."],[6196,6585,"What about you, Jennifer Sullivan?"],[6742,6827,"You're sick."],[6926,7072,"—Sick? —Uh-huh."],[7075,7184,"Oh..."],[7287,7511,"I like that, sick."],[7712,7928,"You should actually wear these."],[8008,8083,"Oh, Mr. Marks,"],[8083,8278,"you should save your generosity"],[8278,8476,"for Ms. Anderson."],[8476,8558,"And now she's probably"],[8562,8760,"walked out with Shane."],[8850,9022,"I would check on them."],[9038,9283,"Sharon's not the right one for Shane."],[9296,9461,"What are you doing, Mr. Marks?"],[9704,9784,"Jennifer?"]],"20":[[165,248,"Jennifer?"],[346,421,"Yes. What's..."],[421,620,"is everything alright?"],[633,684,"Yeah, yeah."],[684,813,"I forgot to ask."],[813,956,"Do you want dinner brought to your room?"],[984,1042,"Oh, no."],[1042,1226,"That's that's so thoughtful of you,"],[1226,1363,"but I..."],[1447,1614,"I'm, I'm fine."],[1614,1685,"Jennifer. What?"],[1685,1776,"What did you say?"],[1776,1889,"I said..."],[1943,2053,"Jennifer?"],[2227,2356,"Is everything okay?"],[2356,2580,"—Jennifer. —I said I'm fine."],[2609,2706,"I'm coming in."],[2706,2820,"No, no, no... I'm..."],[2820,2960,"I'm not dressed!"],[2994,3044,"Thank you so much"],[3044,3161,"for your thoughtful offer,"],[3161,3275,"though, I'm..."],[3332,3436,"I think the only thing I have to do"],[3436,3612,"is to go to bed and rest."],[3612,3908,"—I'm really exhausted. —Okay. Alright."],[3908,4074,"Well, get some rest."],[4074,4158,"If you don't feel better tomorrow,"],[4158,4304,"you don't have to come into work."],[4304,4391,"Thank you."],[4391,4546,"Good night."],[4576,4679,"Mr. Marks,"],[4679,4999,"if you don't stop doing this, I'll leave!"],[5105,5221,"You lost one before."],[5239,5380,"They look good on you."],[5380,5576,"Why you're even doing this?"],[5684,5872,"Just say that you are appreciated."],[6116,6221,"Good night."]],"21":[[1368,1555,"Tyler has really gone all out"],[1555,1689,"for Ms. Anderson."],[1789,1847,"Well,"],[1847,2043,"today is Sharon's birthday."],[2043,2344,"Then, what is Isaac gonna do now?"],[3378,3524,"Happy birthday, Sharon!"],[3732,3870,"It's very kind of you."],[3970,4200,"I have a very special surprise for you."],[4767,4934,"Be my wife, Sharon!"],[5013,5163,"Tonight can be both"],[5163,5501,"your birthday and our engagement party."],[5501,5784,"—Oh... —Listen,"],[5784,5881,"I got this diamond"],[5881,6076,"from an auction in London."],[6185,6307,"They had it shipped here overnight"],[6307,6423,"just for you."],[6423,6564,"I can get you a star from the sky"],[6564,6660,"if you'd like."],[6923,7173,"You'd have to pay for the star, right?"],[7607,7741,"Not now, Isaac!"],[7811,8083,"The Star of Hope,"],[8083,8391,"sold for $10 million at auction."],[8391,8470,"Why did I hear that"],[8470,8683,"you just took $10 million at..."],[8863,9117,"on that project last week?"],[9117,9300,"Sharon, don't listen to him."],[9463,9588,"Besides that,"],[9588,9759,"company money is my money, anyway."],[9868,10110,"So you admit that you..."],[10197,10251,"What's the word?"],[10251,10389,"Embezzled?"],[10472,10694,"You son of a bitch!"],[11248,11332,"Phew!"]],"22":[[16,145,"You son of a bitch!"],[880,975,"Tyler Marks,"],[1026,1163,"you are an embarrassment"],[1163,1292,"to your family."],[1292,1593,"But, Sharon, I really do love you!"],[1676,1830,"He doesn't. He's just using you!"],[1830,1947,"Can't you see that?"],[1947,2218,"Oh, he's finally right about something."],[2268,2356,"Our father,"],[2356,2665,"he promised each one of us brothers"],[2665,2723,"who are gonna marry you"],[2723,2806,"the best resources."],[2806,3065,"So who wouldn't wanna go for you, huh?"],[3065,3232,"Well, and Shane."],[3232,3370,"Oh, it's here too."],[3370,3624,"So, I guess it's time for you to choose"],[3624,3778,"between all three of us."],[3778,3866,"What? So,"],[3866,4216,"I'm a prize to be won by one of you?"],[4337,4846,"No. You are an angel investor,"],[4846,5167,"my most precious opportunity."],[5321,5534,"When people give me the time of day,"],[5534,5805,"it's because I'm a Marks and not Isaac."],[5864,6126,"I'm the most insignificant Marks."],[6126,6414,"Well, at least you're self-aware."],[6414,6673,"You need to know who you are, right?"],[6673,6923,"So, if you need to choose between"],[6923,7261,"the three of us, I would recommend myself."],[7586,7703,"Go on."],[7791,7937,"I need you the most."],[7937,8191,"You would change the course of my life,"],[8258,8454,"and you'll get the most out of it."],[8454,8662,"Oh, no. You think I need more money?"],[8767,8908,"Well, have you ever"],[8908,9192,"cultivated anything yourself, babe?"],[10010,10101,"When he marries Sharon"],[10101,10251,"and doesn't need me anymore,"],[10251,10410,"I will finally be free."],[10489,10723,"But why am I not happy right now?"]],"23":[[0,162,"Don't do it, Sharon!"],[162,325,"He's just using you!"],[946,1042,"Compared to Isaac,"],[1042,1263,"Shane seems so boring now."],[2031,2189,"Congratulations."],[2189,2364,"You made the right decision."],[2364,2585,"Don't let me down."],[2585,2861,"I wouldn't dare."],[2861,2998,"Isaac! You bastard!"],[3057,3207,"You're stealing my love."],[4479,4579,"Hang on!"],[5071,5213,"Where'd you get those?"],[5213,5276,"Ouch!"],[5338,5388,"Ms. Sharon,"],[5388,5505,"what are you doing?"],[5605,5773,"These are mine!"],[5997,6068,"These are mine."]],"24":[[150,232,"These are mine."],[308,429,"You took these from me,"],[429,521,"and now she has them."],[521,642,"Explain."],[829,892,"Do you think"],[892,1084,"there's only one pair of those earrings"],[1084,1134,"in the world?"],[1134,1351,"Don't think it's a coincidence."],[1430,1614,"And what if it is?"],[1685,1827,"Then show me."],[2139,2256,"But you'll apologize."],[2256,2389,"Show me first!"],[3053,3161,"Here you go."],[3399,3470,"You accused her"],[3470,3574,"without giving her a chance"],[3574,3666,"to explain herself."],[3666,3874,"I think you owe Jennifer an apology."],[4270,4433,"Just because you bought them"],[4433,4646,"doesn't mean they suit you."],[5159,5488,"Okay, I will apologize for her."],[5915,6011,"I'm sorry."],[6118,6172,"And, Shane,"],[6172,6302,"since when do you care so much"],[6302,6429,"about your assistant?"],[7082,7228,"I'm sorry for all that."],[7228,7353,"It's okay."],[8629,8776,"What are you doing here?"],[8929,9084,"You're bleeding."],[9180,9300,"Does it hurt?"]],"25":[[175,321,"You're bleeding."],[392,496,"Does it hurt?"],[550,821,"What are you worried now?"],[1155,1355,"Shane is..."],[1355,1539,"caring a lot about you."],[1605,1851,"Wasn't that was I supposed to do…"],[1851,2027,"what you told me to?"],[2085,2135,"Besides,"],[2135,2273,"Ms. Anderson is outside"],[2273,2327,"waiting for you."],[2327,2627,"So, what are you even doing here?"],[2811,3061,"So, you are jealous."],[3144,3232,"There's only business"],[3232,3311,"between Sharon and I."],[3311,3687,"Who you marry is nothing to do with me."],[3720,3883,"You're only my boss."],[4099,4304,"So, that's how you see me?"],[4412,4604,"I'm only your boss."],[4725,5005,"How else am I supposed to see you,"],[5005,5121,"Mr. Marks?"],[5309,5367,"Besides,"],[5367,5555,"this work relationship is almost over,"],[5555,5693,"isn't it?"],[5976,6147,"I decide when it's over."],[6147,6423,"I'm the one who's making the last call."],[6423,6548,"Alright?"]],"26":[[254,608,"I'm the one who's making the last call."],[2389,2506,"Hello?"],[2552,2811,"—Ms. Sullivan? —Yes."],[2811,2915,"May has been transferred"],[2915,3136,"from the ICU to the general ward."],[3324,3420,"What?"],[3545,3641,"May has been transferred"],[3641,3699,"to general ward."],[3699,3766,"No, there's..."],[3766,3970,"We have other critical patients"],[3970,4074,"whose needs are more urgent"],[4074,4154,"than May's."],[4154,4433,"No, no, there's gets to be a mistake."],[4433,4550,"I'm pretty sure that"],[4550,4867,"all her bills had to be paid."],[4867,5063,"Understand? Miss Sullivan,"],[5063,5330,"if this arrangement is unacceptable,"],[5330,5459,"you're welcome to transfer her"],[5459,5618,"to another hospital."],[5618,5818,"What, are you kicking us out?"],[5818,5968,"What are you even saying?"]],"27":[[1084,1388,"The subscriber you dialed is no answer."],[1388,1630,"Please redial later."],[2085,2285,"Okay, Isaac, come on."],[2961,3154,"Come on!"],[3194,3361,"Isaac Marks,"],[3440,3524,"now, my sister"],[3524,3770,"has been kicked out of the care center,"],[3770,3983,"and you're avoiding me."],[3983,4154,"Are you behind it at all?"],[4904,4963,"Mr. Marks!"],[4963,5096,"Jennifer, I called you so many times"],[5096,5167,"and you didn't pick up."],[5167,5255,"What happened?"],[5317,5447,"Is... It was..."],[5447,5580,"Did you need anything from me?"],[5580,5793,"I thought that this...this was my day off."],[5793,5960,"No, no, it's just that"],[5960,6143,"you seem down these past few days,"],[6143,6448,"and I just wanted to check in with you."],[6448,6527,"It's..."],[6790,6956,"It's my sister."],[7136,7315,"They're going to kick her"],[7315,7486,"out of the care center."],[7741,7866,"I'm sure that"],[7866,8053,"all the bills are paid, but..."],[8053,8195,"now, apparently, she..."],[8195,8379,"she's not allowed to stay in the structure."],[8379,8495,"I'm..."],[8591,8687,"I'm wondering, is..."],[8796,8929,"is my money any different"],[8929,9113,"than your money?"],[9113,9267,"Mr. Marks?"],[9267,9534,"Did you breach people's money?"],[9534,9747,"No. It's nothing. It's nothing..."],[9747,9801,"Well, it's..."],[9801,10089,"No, it's, it's nothing to you,"],[10089,10343,"but this means the world to me."],[10343,10543,"She's my sister."],[10873,10969,"I'm sorry."],[10969,11173,"I'm sorry, Mr. Marks."],[11661,11761,"Doctor Lee."],[11853,12028,"Hi, it's Shane Marks."],[12028,12187,"Listen, I just have a question for you."],[12187,12374,"Is there a young woman in your facility"],[12374,12491,"named May Sullivan?"],[12579,12813,"Can you make sure she gets proper care?"],[12925,13029,"Great."],[13029,13158,"Thank you so much."],[13158,13584,"I can't accomplish anything,"],[13584,13709,"no matter how hard I try."],[13709,14009,"And you are one call away, always."],[14009,14172,"It's no wonder why"],[14172,14322,"so many people want to marry into"],[14322,14397,"the Marks family."],[14397,14560,"I should probably try that too,"],[14560,14656,"for my own."],[14656,14785,"Someone's a little drunk right now."],[14785,15060,"—Maybe... —I am a little drunk."],[15102,15286,"I ain't Mr. Marks."],[15398,15540,"I am so sorry, and..."],[15632,15786,"I will work"],[15786,16045,"really hard to... to pay you back."],[16107,16349,"Everything, I promise."],[16389,16574,"—Let's get you inside. —Thank you, sir."]],"28":[[513,600,"I thought my daughter"],[600,825,"was going to marry your youngest son."],[917,1138,"I didn't expect it to be the second one."],[1138,1351,"Ms. Anderson certainly has the right"],[1351,1476,"to choose."],[1476,1701,"After the engagement party,"],[1701,1876,"I will hand the New Water Castle project"],[1876,2035,"over to Isaac."],[2068,2373,"Dad, you took away what belongs to me."],[2373,2585,"So don't blame me for this."],[2585,2765,"And as well as give him 10%"],[2765,2948,"of the shares of Marks International."],[2948,3249,"Well, my daughter deserves nothing less."],[3332,3465,"Where is Isaac?"],[3507,3628,"It's his engagement party,"],[3628,3799,"how can he be so late?"],[3799,4054,"I don't know, he's not answering either."],[4091,4314,"Seems like Isaac's not that interested"],[4314,4429,"in your arrangement."],[4533,4662,"Excuse me, guys."],[4813,5038,"—Isaac! —Sorry, I'm late."],[5038,5171,"Where have you been?"],[5171,5384,"I was just telling Mr. Anderson"],[5513,5580,"about my plan"],[5580,5753,"to give you 10% of the shares."],[5753,5868,"Excuse me, father."],[5868,5993,"I will actually leave."],[5993,6181,"Please go on with the preparations."],[6181,6272,"Excuse me."]],"29":[[50,246,"Please go on with the preparations."],[246,346,"Excuse me."],[533,600,"Let him..."],[600,738,"Let him go."],[738,1026,"Oh, that boy,"],[1026,1159,"very busy."],[1159,1292,"Please excuse him."],[1292,1427,"The New Water Castle project is"],[1427,1579,"very demanding."],[1583,1747,"Business first."],[1797,1914,"At the end of the day,"],[1914,2134,"this will be our joint project."],[2565,2648,"Jennifer!"],[2744,2944,"Can I talk to you?"],[3007,3128,"Mr. Marks."],[3128,3269,"What do you want?"],[3403,3620,"You finally got Ms. Anderson."],[3620,3840,"Why you're trying to ruin it?"],[4404,4575,"So, you are jealous."],[4796,4967,"Please don't flatter yourself."],[5234,5384,"Ran into some trouble yesterday,"],[5384,5572,"and I saw a lot of missed calls."],[5726,5772,"It's okay."],[5772,5897,"It's taken care of."],[5897,6085,"Jennifer, listen. I..."],[6168,6268,"What are you two doing?"]],"30":[[12,116,"What are you two doing?"],[237,367,"Ms. Anderson."],[792,955,"Trying to seduce my hus-"],[955,1142,"Hey, don't do this."],[1142,1305,"Isaac, look on me."],[1305,1398,"Don't make a scene at"],[1398,1530,"our engagement party."],[1597,1740,"Fine."],[2227,2385,"This engagement"],[2385,2551,"so over!"],[2919,2961,"Jennifer!"],[2961,3140,"What happened? Are you okay?"],[3140,3294,"I'm fine."],[3599,3645,"Do you know why"],[3645,3745,"Isaac would marry a woman"],[3745,3883,"who he doesn't even love?"],[4187,4341,"It's because of his mother."],[4575,4713,"She was a maid in our family back"],[4713,4859,"when we were living in Germany."],[4859,5205,"And one night, she slept with our father."],[5397,5697,"Cause my mother to die in depression."],[5755,5885,"My father knew that"],[5885,6097,"he did my mother wrong."],[6235,6418,"Cast her out of our family,"],[6418,6660,"making sure she never steps foot."],[6660,6827,"And then, what happened?"],[6886,7023,"She killed herself."],[7265,7503,"So Isaac can become a Marks."],[7599,7707,"Isaac,"],[7707,7899,"who's carrying the burden of his mother,"],[7982,8120,"he will do anything in his power"],[8120,8249,"to accept that inheritance,"],[8249,8437,"even if it's illegal."],[8437,8562,"Jennifer,"],[8608,8787,"when the time comes,"],[8904,9096,"you can pick his side or mine."]],"31":[[37,208,"Jennifer,"],[208,371,"when the time comes,"],[496,675,"you can pick his side or mine."],[1488,1626,"Yes, father!"],[1626,1722,"Excuse me."],[2135,2231,"Hey!"],[2389,2431,"What are you do-"],[2431,2602,"What were you talking about with Shane?"],[2602,2727,"I..."],[2802,2877,"What are you doing?"],[2877,2986,"Why doing this?"],[4959,5096,"Jennifer,"],[5213,5459,"I don't want you to be his assistant anymore."],[5609,5755,"Your mission is over."],[5805,5980,"No, no. What..."],[5980,6183,"What about my sister?"],[6183,6326,"She will get surgery tomorrow."],[6326,6535,"I've called the best doctors in town."],[6656,6902,"What will it cost me this time?"],[6902,7057,"Nothing."],[7261,7432,"I'm be sure that she will settle down."],[7432,7694,"Why are you being this kind to me suddenly?"],[7694,7799,"I..."],[8012,8270,"Jennifer, since we"],[8270,8541,"last talked about"],[8541,8675,"our working relationship"],[8675,8796,"being almost over,"],[8904,9217,"all I could think about was you,"],[9217,9409,"Jennifer Sullivan."],[9409,9538,"And..."],[9651,9847,"do you need a boyfriend?"],[9959,10068,"What?"],[10508,10645,"Isaac?"],[10685,10848,"Isaac! Wait!"]],"32":[[496,796,"May, we're finally getting the surgery."],[892,1080,"And all the bills are paid."],[1192,1338,"Now, the only thing you have to do for me"],[1338,1526,"is to wake up."],[1526,1718,"Can you do that?"],[1876,1964,"While you were sleeping,"],[1964,2114,"I had to go through"],[2348,2565,"so many terrible things."],[2715,3011,"But that is almost over."],[3290,3444,"Jennifer?"],[3474,3616,"Mr. Marks!"],[3616,3782,"Hi. Why are you here?"],[3782,3953,"I guess you'd be here."],[3953,4137,"I just wanna see how you're doing."],[4137,4291,"I went to go search for you last night,"],[4291,4496,"but all I could find was your phone"],[4496,4583,"in the garden."],[4813,4946,"Oh..."],[4946,5063,"Thank you."],[5063,5376,"I must've dropped it somewhere."]],"33":[[79,321,"This car was at the scene of the crime"],[321,421,"the night of the fire..."],[550,667,"But this..."],[667,804,"This is Isaac's car."],[804,934,"Rosen Corporation,"],[934,1126,"the company you persecuted,"],[1126,1426,"is a longtime partner of the Marks family."],[1426,1751,"It's likely Isaac Marks tried to get rid of you"],[1751,1906,"for the mutual benefit"],[1906,2077,"of their business partner."],[2077,2252,"Oh..."],[2252,2610,"Isaac Marks, I..."],[2706,2831,"I can't believe."],[3624,3757,"The baby is seven weeks along,"],[3757,3883,"and it's not very stable"],[3883,3999,"because you have been"],[3999,4183,"emotionally unstable."],[4291,4487,"You need to take care of yourself."],[4487,4708,"You cannot tire yourself out,"],[4708,4863,"and watch your diet. Okay?"],[4938,5142,"You can fire me now, Mr. Marks."],[5271,5321,"Fire you?"],[5321,5514,"You didn't do anything wrong."],[5601,5880,"I didn't know you were in a relationship."],[5880,6072,"I don't want a child"],[6072,6227,"of a shameful father."]],"34":[[62,191,"Jennifer."],[266,342,"You heard the doctor."],[342,567,"You shouldn't tire yourself out like that."],[567,742,"But I'll give you maternity leave."],[742,850,"What?"],[850,1117,"Why would you give me maternity leave?"],[1117,1313,"Why, are you not keeping the baby?"],[1313,1384,"That's..."],[1384,1514,"that's my own personal business."],[1514,1780,"Mr. Marks, could you please stop asking?"],[1780,1976,"Look,"],[1976,2035,"I don't want you"],[2035,2260,"to make any rash decisions right now."],[2260,2435,"Even though the father isn't a good man,"],[2435,2640,"you and the baby are innocent."],[2660,2765,"No."],[2765,3028,"But what if this is my enemy's baby?"],[3578,3657,"Mr. Marks?"],[3657,3703,"Yeah."],[3703,3832,"Excuse me."],[4562,4725,"Hi, Jennifer."],[4725,4813,"Where are you?"],[4813,4942,"Hmm, why are you not picking up"],[4942,5038,"your phone?"],[5038,5192,"Isaac Marks,"],[5355,5572,"I have some questions for you,"],[5572,5780,"and you're gonna answer them honestly."],[5780,6056,"Hmm... Where are you?"],[6118,6306,"If you tell me where you are, I will, um..."],[6306,6485,"answer all the questions you have."],[6485,6690,"Before you hired me to be your spy,"],[6815,7027,"did you already know that I prosecuted"],[7027,7190,"and made an enemy"],[7190,7323,"at the Rosen Corporation?"],[7424,7511,"Yes."],[7511,7695,"You were there the night of the fire?"],[7778,7937,"Yes."],[7937,8053,"The fire,"],[8053,8199,"are you behind it?"],[8199,8404,"No! Jennifer."],[8404,8579,"Then who is?"],[8692,8787,"If I'm gonna find out"],[8787,8963,"that you were the one behind the fire,"],[9013,9267,"and that you killed my parents,"],[9267,9401,"I promise"],[9401,9584,"that I'm going to come after you."],[9939,10080,"Jennifer, listen to me!"],[10080,10226,"Please!"]],"35":[[204,358,"Hey, what were you doing?"],[417,601,"Mr. Marks,"],[713,942,"could you help me finding a good doctor?"],[1030,1197,"I wanna get rid of the baby."],[1292,1380,"You sure?"],[1505,1597,"Yeah."],[1960,2089,"Jennifer, I have a proposal."],[2248,2406,"What do you mean?"],[2406,2519,"Don't get an abortion."],[2615,2886,"Keep the baby and I'll be the dad."],[3111,3249,"What? Mr. Marks,"],[3249,3403,"what are you talking about?"],[3403,3657,"No, I'm serious."],[3657,3845,"You and I, we get married,"],[3845,3987,"and we raise a kid together."],[4045,4291,"No, but it's not your kid."],[4291,4446,"I'll raise him as my own."],[4446,4512,"No, no, Mr. Marks,"],[4512,4700,"I think I really don't understand"],[4700,4884,"why you would be doing that."],[4971,5163,"What if it's because I like you?"],[5814,5968,"The Andersons are furious"],[5968,6101,"about what you did to Sharon"],[6101,6306,"and calling off the engagement."],[6306,6473,"What the hell happened?"],[6473,6619,"And the engagement is off."],[6619,6844,"I told you to work with the Andersons,"],[6844,7019,"but you can't even pick up a girl!"],[7069,7269,"I can manage this project well,"],[7269,7382,"even without the Anderson support."],[7382,7453,"Okay?"],[7453,7732,"You fool! You have nothing!"],[7824,8024,"God damn it!"],[8128,8258,"What are you doing here?"]],"36":[[45,191,"What are you doing here?"],[275,362,"Dad,"],[362,550,"Jennifer's pregnant."],[871,1051,"I came here today to tell you both"],[1051,1297,"that Jennifer's pregnant"],[1297,1413,"and I intend to marry her."],[1463,1559,"You said"],[1559,1735,"she's pregnant with your child."],[1735,1922,"You sure it's yours?"],[1922,2118,"Of course."],[2118,2268,"And it's different than it was last time,"],[2268,2635,"because Jennifer and I are actually in love."],[2915,3178,"And I intend to get a house"],[3178,3357,"with her and our child."],[3687,3816,"Shane's been quite busy,"],[3816,3945,"quietly having another child"],[3945,4108,"without us knowing."],[4354,4575,"I'm just worried that it's like Ruby."],[4892,5184,"Dad, it's different this time"],[5184,5380,"because Jennifer is actually"],[5380,5563,"carrying my child."],[6398,6602,"Another gold-digger!"]],"37":[[183,383,"I fell out with the Anderson"],[383,504,"just to be with you,"],[504,747,"and you are pregnant with his child?"],[867,942,"Weren't you the one"],[942,1084,"who sent me to seduce Shane?"],[1084,1180,"To seduce Shane?"],[1180,1213,"Yes."],[1213,1438,"But not to jump in his bed."],[1438,1618,"Was I supposed to do"],[1618,1764,"with the power of my mind?"],[1764,1939,"I don't know. You use your brain."],[1939,2135,"I don't know!"],[2410,2569,"Be honest to me,"],[2677,2848,"is that my child?"],[2952,3136,"It's Shane's."],[3370,3582,"Don't you think it's your baby,"],[3582,3703,"do you?"],[4041,4475,"Someone who lied to me."],[4592,4892,"Who insulted me."],[4938,5205,"And someone that's probably behind"],[5205,5492,"the death of my whole family."],[5563,5634,"Don't you think"],[5634,5880,"you're better than your brother, do you?"],[6126,6260,"You think..."],[6260,6393,"you're better than your brothers?"],[6393,6602,"—Yes, I am! —Fucking idiot!"],[7090,7390,"If you wanna know who the culprit is,"],[7432,7553,"the fucking fire,"],[7711,7928,"come to my room tonight."],[9054,9159,"Jennifer."],[9205,9285,"Why'd you cried?"],[9285,9476,"Mr. Marks, it's nothing."],[9476,9630,"It's just hormones."],[9630,9680,"Okay,"],[9680,9855,"you don't have to keep apologizing to me."],[9855,9937,"I understand."],[9938,10089,"I know."],[10112,10293,"Let me take care of you, okay?"]],"38":[[12,312,"If you wanna know who the culprit is,"],[350,533,"the fucking fire,"],[533,738,"come to my room tonight."],[900,1030,"Isaac?"],[1146,1292,"Isaac, what are you doing?"],[1447,1551,"Isaac?"],[1551,1722,"Stop it, stop it!"],[1722,1879,"Shane is waiting for me!"],[2097,2310,"Don't tell"],[2310,2469,"and talk about Shane in front of me!"],[2585,2806,"Hey! Isaac!"],[2877,2915,"Are you brain out?"],[2915,2998,"I'm pregnant!"],[2998,3278,"I'm pregnant! Isaac, stop!"],[3294,3503,"It's just excuses."],[3524,3661,"I'm pregnant!"],[3803,4041,"So fucking having those fucking excuses!"],[4846,4917,"Why?"],[5075,5246,"You don't want me anymore?"],[5246,5459,"Now that you're in Shane's bed."],[5534,5622,"It's the phone."],[5622,5780,"Isaac, it's the phone..."],[5780,5855,"Get off me..."],[5922,6076,"It's the hospital."],[6264,6381,"Hello?"],[6564,6648,"You can talk to me."],[6648,6873,"I'm the sister. Yes."],[6956,7147,"May is awake?"],[7578,7786,"Yeah..."],[7786,8183,"I'm coming right now! Yeah. Thank you..."],[8391,8641,"May, May is awake."],[8641,8825,"I'm sorry."],[9138,9280,"Let me drive you."],[9492,9534,"Don't!"],[9534,9676,"Don't touch me, Isaac!"]],"39":[[429,550,"May."],[550,721,"It's me!"],[721,867,"Jennifer."],[867,1101,"Yeah..."],[1101,1276,"Shh... It's okay, it's okay."],[1276,1614,"You woke up. You finally woke up! Shh..."],[1614,1739,"The patient just woke up"],[1739,1889,"and can't be too emotional."],[1889,2164,"Please, let's just give her some space."],[2227,2398,"Yeah, doctor."],[2494,2560,"Can I..."],[2560,2869,"Can I stay in tonight with her, please?"],[2869,3178,"I'm sorry, but we don't have overnight stays."],[3382,3649,"Doctor, please transfer her to a bigger room."],[3649,3707,"The sisters probably"],[3707,3853,"have a lot to catch up on."],[3924,4054,"—Sure. —Thank you."],[4054,4154,"Sure."],[5480,5651,"Mr. Marks,"],[5776,5951,"I think we're even for tonight."],[6364,6519,"Jennifer, I'm asking you one last time."],[6519,6660,"You can ask thousand times."],[6660,6819,"The answer is gonna be the same."],[6819,7015,"This baby is Shane's."],[7015,7173,"Look, I..."],[7173,7336,"I don't blame you for this."],[7336,7582,"Get rid of Shane, and as for the baby-"],[7582,7828,"I will keep the baby."],[7949,8087,"I've already promised Shane."]],"40":[[45,250,"I've already promised Shane."],[667,821,"Your sister just woke up,"],[821,963,"and you get rid of me."],[1134,1313,"Do you think you were set for life"],[1313,1451,"just being married to Shane?"],[1551,1685,"Mr. Marks,"],[1801,1906,"don't forget"],[1906,2128,"that if my sister recognizes you"],[2128,2306,"as the culprit of the arson,"],[2348,2531,"I will do everything"],[2531,2765,"that's in my power to send you to prison."],[2852,2965,"Good night."],[4138,4222,"Hey!"],[4330,4625,"Hey! What are you doing?"],[4788,4884,"May!"],[4884,4963,"Jennifer!"],[4963,5192,"Oh God, I'm sorry. Sorry, May."]],"41":[[0,75,"Hey!"],[75,250,"What are you doing?"],[296,408,"May!"],[458,579,"Oh God..."],[817,921,"Hey!"],[921,1051,"It's okay, he's gone."],[1126,1322,"—Hey, are you okay? —Don't touch me!"],[3015,3211,"Jennifer."],[3211,3411,"Why won't you believe me?"],[3678,3887,"If I would be behind all of this,"],[3887,4033,"why would I come back"],[4033,4183,"to save you?"],[4262,4562,"Well, my sister's unconscious again."],[4629,4929,"So you got what you wanted, didn't you?"],[5125,5376,"Unless..."],[5376,5584,"Unless you can tell me who the culprit is."]],"42":[[16,266,"Unless you can tell me who the culprit is."],[558,704,"I'm not sure yet."],[825,1038,"Then why were you there in the first place?"],[1317,1522,"All I can tell you is"],[1522,1750,"that it has something to do with me,"],[1768,2068,"and as soon as I know all the facts, I will..."],[2339,2640,"I will give you this justice you deserve."],[2731,2961,"I only believe"],[2961,3299,"in justice I earned myself."],[3299,3445,"Mr. Marks."],[4412,4587,"You stupid idiot."],[4587,4637,"You didn't know"],[4637,4821,"Jennifer was in the hospital?"],[4821,4988,"It's that damn Isaac!"],[4988,5071,"If he hadn't been there,"],[5071,5238,"her sister would be dead right now."],[5330,5409,"What?"],[5434,5530,"Don't tell me you're really starting"],[5530,5676,"to feel sorry for Jennifer now?"],[5676,5739,"I told you,"],[5739,5855,"I have my own plans with Jennifer."],[5855,6026,"I don't want you to touch her."],[6026,6189,"What about the fire?"],[6189,6352,"She's still looking into it, you know."],[6352,6677,"Okay, even though we caused the arson,"],[6677,6777,"it doesn't matter."],[6777,6835,"Okay?"],[6906,7136,"Isaac was there that day too, you know."],[7136,7232,"So?"],[7232,7353,"He didn't do it!"],[7545,7707,"You idiot!"],[7707,7907,"So long as Jennifer believes he did it,"],[7907,8158,"there's nothing he can do about it!"],[8354,8433,"Shane?"],[8433,8550,"I'm here."],[8708,8867,"Oh my God!"]],"43":[[279,350,"Jennifer,"],[350,462,"if something like this happens again,"],[462,650,"you need to tell me immediately."],[754,946,"I mean, did the police find anything?"],[1234,1301,"No, they didn't."],[1301,1409,"He was..."],[1409,1710,"He was really actually a professional."],[1751,2047,"He didn't leave any fingertips behind,"],[2047,2318,"and also security cameras"],[2318,2464,"at the hospital didn't"],[2464,2744,"catch his face, so no."],[2811,2927,"Who would wanna kill May?"],[2982,3082,"Must have had something to do"],[3082,3244,"with the arson, right?"],[3649,3837,"She must've seen a culprit."],[3941,4095,"No, no, she..."],[4095,4295,"She didn't see anything."],[4295,4458,"She was..."],[4458,4592,"She was only taking a bath,"],[4592,4813,"and then that's the reason why"],[4813,4892,"she's still alive."],[4892,4984,"She's..."],[4984,5226,"She hid underwater, yeah."],[5467,5593,"Jennifer,"],[5638,5834,"I'm gonna take better care of you,"],[5834,5935,"okay?"],[5997,6206,"What a shame to you."],[6206,6335,"You really are determined"],[6335,6460,"to marry a rich."],[6460,6539,"Ms. Sharon,"],[6539,6706,"if you slander my fiance's name again,"],[6706,6835,"I'm gonna have to get involved!"],[6835,7019,"Don't speak to me like that."],[7019,7173,"No one speaks to me like that!"],[7173,7294,"Not even Isaac."],[7386,7474,"you know, whatever,"],[7474,7661,"I have a meeting to go to."],[7945,8195,"Sharon and Isaac got into a big fight,"],[8195,8375,"and Isaac had to come back"],[8375,8571,"and apologize for her..."],[9046,9117,"Sure."]],"44":[[237,479,"Ah, to be young!"],[479,596,"Arguments only make"],[596,834,"your relationship stronger."],[1209,1355,"I'm happy to announce"],[1355,1668,"that Isaac is the new general manager"],[1668,1843,"of Marks International."],[1897,2032,"Thank you."],[2072,2185,"And the board of directors"],[2185,2289,"for trusting me."],[2419,2631,"Riding on this woman's coattails."],[2890,3011,"You three brothers"],[3011,3219,"ought to shake hands with each other."],[3219,3311,"You guys"],[3311,3520,"are the future of the Marks family!"],[3712,3887,"Congratulations."],[4058,4258,"Mr. Anderson."],[4608,4708,"Isaac."],[4708,4871,"Congratulations."],[5046,5217,"Good job, well done on your promotion."],[5217,5647,"Hey, you know, I just got promoted to father."],[7369,7500,"Jennifer,"],[7520,7638,"you're here."],[7678,7866,"Isn't it a little early"],[7866,8028,"to try on wedding gowns?"],[8028,8191,"Well."],[8191,8375,"Someone can't wait."],[8395,8566,"Mr. Marks, Mrs. Sullivan."],[8566,8767,"This is the best gown in our shop."],[8767,8967,"Would you like to try it on?"],[9914,10030,"What are you doing here?"]],"45":[[83,246,"What are you doing here?"],[246,425,"This gown isn't for you."],[467,663,"It's not fancy enough,"],[663,784,"and the bust isn't tight."],[784,888,"Doesn't Shane know your size?"],[888,1142,"Oh, Mr. Marks."],[1142,1372,"You're not alone in this shop, are you?"],[1372,1539,"If Ms. Anderson finds out..."],[1539,1726,"Then what?"],[1856,2052,"Then nobody of us will get"],[2052,2210,"what we want from our spouses."],[2260,2581,"It's a lose-lose situation."],[2744,3007,"I'm glad you know."],[3290,3461,"If you don't keep quiet,"],[3461,3770,"the Marks family, we'll be the news again,"],[3770,4024,"me and my sister-in-law"],[4024,4183,"getting caught together."],[4183,4295,"Why do you need to be so cruel"],[4295,4500,"with your own brother?"],[4500,4725,"And I'm still keeping his child."],[4813,4913,"Are you crazy?"],[4913,5230,"I can be crazier, do you wanna try that?"],[5230,5434,"You are exactly like your father."],[5501,5801,"I'm not like my father."],[5897,6014,"You are."],[6118,6244,"I'm not."],[6443,6523,"Jennifer."],[6523,6673,"—Are you ready? —Yes."],[6673,6840,"I'm ready."],[6881,7007,"I'm ready."]],"46":[[12,158,"Jennifer, are you ready?"],[158,250,"Yes."],[250,375,"I'm ready..."],[1413,1534,"Wow."],[1614,1756,"How do you like it?"],[1776,2014,"I'm fine with whatever."],[2531,2669,"What are we talking about?"],[2669,2806,"You're late."],[2936,3040,"Come on, let's go."],[3040,3140,"We're gonna go somewhere else."],[3140,3290,"I am not buying a wedding dress"],[3290,3507,"from the same place as this gold-digger."],[3782,3891,"I'm not going."],[3999,4166,"You're supposed to be a lady,"],[4225,4404,"but you don't talk like that."],[4500,4625,"Why you always fight with me"],[4625,4792,"when it comes to Jennifer?"],[5234,5397,"Sharon Anderson,"],[5397,5513,"when I proposed to you,"],[5513,5689,"I told you I don't love you."],[5789,5905,"If you want money"],[5905,6131,"or shares of the company,"],[6131,6297,"I will give them to you."],[6297,6598,"But in terms of love, there's nothing"],[6694,6835,"I can give you."],[7115,7336,"Who do you have love for?"],[7515,7674,"Your sister-in-law?"]],"47":[[20,154,"Who do you have love for?"],[291,504,"Your sister-in-law?"],[696,913,"Don't go there."],[913,1084,"If you do not cut it off with her"],[1084,1292,"right now,"],[1292,1438,"the wedding's off."],[1438,1630,"Then it's off."],[1680,1764,"Uh!"],[2068,2231,"Okay, fine."],[2231,2477,"You Markses are"],[2477,2606,"so over!"],[3465,3595,"Shane,"],[3595,3728,"—I am sorry. —Jennifer."],[3728,3820,"Did you know Isaac really..."],[3820,4041,"No, it's Isaac who sent me to you."],[4216,4287,"Your father wanted you"],[4287,4450,"to marry Ms. Anderson,"],[4450,4658,"and I, and I ruined it."],[4738,5017,"And to help Isaac,"],[5017,5288,"I even tried to seduce you. I..."],[5288,5426,"I'm such a bad person,"],[5426,5668,"and I'm no different than him."],[5668,5864,"I did so many terrible things."],[5864,5997,"So, Jennifer, just stop!"],[5997,6118,"No. Do you understand?"],[6118,6418,"He planted me next to you as a spy!"],[6523,6823,"And I did everything he asked me to."],[6948,7144,"I'm not worthy of you, Shane!"],[7290,7549,"Can we please cancel our wedding?"],[7816,7949,"Okay."],[8045,8270,"And I have one question for you."],[8341,8525,"Are you still spying on me?"],[8579,8654,"No."],[8850,9100,"How could I still work for"],[9100,9209,"the man who's responsible"],[9209,9430,"for my parents death?"],[9734,9922,"Can you give us a moment, please."],[9989,10064,"Now!"]],"48":[[275,402,"Don't be afraid."],[546,688,"If Isaac really is the culprit,"],[688,871,"then I'm going to be on your side."],[1046,1205,"The Marks family won't cover for him."],[1297,1430,"Thank you."],[1664,1735,"So, is there any word"],[1735,1885,"from your private detective?"],[1997,2056,"How did you know that"],[2056,2306,"I hired a private detective? Mr. Marks."],[2306,2485,"Oh, well,"],[2485,2652,"when I had your phone the other night,"],[2652,2794,"someone saved this"],[2794,2982,"private detective could call you."],[3123,3236,"I went to go search for you"],[3236,3378,"last night, but"],[3378,3478,"all I could find was your phone"],[3478,3611,"in the garden."],[3716,3878,"Okay."],[4041,4300,"I'm... I'm sorry, I have to..."],[4733,4808,"Hello?"],[4808,4992,"We found the culprit."],[4992,5163,"He's at Isaac Marks' mansion."],[5163,5388,"Okay. Thank you. I'm coming."],[5388,5563,"I'm really sorry. I'll..."],[5563,5613,"Where are you going?"],[5613,5743,"—I'll come with you. —No..."],[5743,5885,"This is something I have to handle myself."],[5885,6101,"Okay, well, just let me know that you're safe,"],[6101,6197,"or I'm going to call the police, okay?"],[6197,6356,"Sure. Thank you..."],[8087,8204,"Isaac?"],[8420,8525,"Isaac!"],[9142,9246,"Jennifer?"],[9409,9622,"Why are you here?"],[9743,9922,"Listen. Listen to me!"]],"49":[[8,137,"The security camera caught"],[137,337,"this man wandering around your house"],[337,442,"before the fire."],[442,654,"He's likely the culprit."],[838,988,"Isaac!"],[1372,1530,"Jennifer?"],[1701,1856,"Why are you here?"],[1993,2035,"Listen..."],[2035,2131,"Listen to me..."],[2202,2293,"This..."],[2323,2535,"this man set up the fire"],[2535,2669,"that detective just found out,"],[2669,2919,"and you killed him"],[2919,3103,"to cover your tracks?"],[3103,3324,"He was already dying when he came here."],[3403,3574,"I didn't kill him. You..."],[3574,3732,"I'm being framed. You have to believe me!"],[3732,4033,"No, stop getting closer. I call the police."],[4108,4187,"No. We have to leave."],[4187,4371,"—Come with me. —No!"],[4391,4533,"Or you're gonna kill me"],[4533,4692,"right here, right now,"],[4692,4838,"or you let me go."],[5188,5447,"The baby!"],[5530,5684,"Oh, Isaac."],[5684,5968,"How does it feel to kill your own child?"]],"50":[[1005,1255,"Jennifer, are you okay?"],[1255,1497,"I'm sorry I'm late. I..."],[1680,1838,"Don't be scared."],[1922,2056,"Even though Isaac got away,"],[2056,2164,"the police are searching for him,"],[2164,2251,"and he will pay"],[2251,2360,"for what he did to our baby."],[2644,2762,"How would you know"],[2762,2944,"that I lost the baby?"],[3015,3165,"The doctor told me."],[3303,3532,"I told you to be more careful."],[3532,3757,"Thank God, baby's safe."],[3757,3962,"Let's keep this between me and you,"],[4070,4200,"okay, doctor?"],[4200,4283,"Okay."],[4550,4696,"Shane,"],[4871,4975,"now that I lost the baby,"],[4975,5234,"why you're still being so good to me?"],[5372,5526,"Weren't you going to be marrying me"],[5526,5643,"for the baby?"],[5680,5822,"Don't overthink it."],[5926,6106,"We just need to focus on you right now,"],[6106,6214,"okay?"],[6448,6510,"Okay."]],"51":[[900,1146,"My phone's been dying a lot lately."],[1276,1338,"What if someone"],[1338,1576,"installed surveillance software in it?"],[1639,1881,"He was already dying when he came here."],[1947,2118,"I didn't kill him. You..."],[2118,2193,"I'm being framed."],[2193,2277,"You have to believe me!"],[2277,2464,"No, stop getting closer."],[2464,2581,"I call the police!"],[2677,2869,"Jennifer, I got drunk."],[2973,3274,"I woke up, and he was here."],[3328,3541,"If I wanted to kill him,"],[3541,3812,"I wouldn't've done it in my own house."],[3812,4037,"That knife is the murder weapon."],[4037,4195,"But there's no missing knife"],[4195,4396,"in the set in the kitchen."],[4396,4608,"If it really is Isaac,"],[4608,4867,"then where did that knife come from?"],[5467,5605,"I'm being listened in."],[5668,5809,"Stop getting closer,"],[5809,5955,"or I'll call the police."],[6352,6473,"The police will be here soon,"],[6473,6602,"you should leave now."]],"52":[[58,145,"The police will be here soon,"],[145,291,"you should leave now."],[426,558,"You... We should leave."],[558,625,"No!"],[850,1030,"I have to stay here to draw him out."],[1030,1259,"Otherwise, it's all for nothing."],[1259,1409,"Or you're going to kill me"],[1409,1572,"right here, right now,"],[1609,1714,"or you let me go."],[2552,2681,"The police has issued"],[2681,2932,"an arrest warrant for Isaac Marks"],[2932,3090,"of Marks International,"],[3111,3407,"the suspect in the 616 arson case"],[3407,3632,"and murderer of an accomplice..."],[3670,3800,"Nonsense!"],[3820,4049,"My son is not a criminal."],[4112,4270,"Dad, you need to calm down."],[4312,4421,"The first priority right now"],[4421,4587,"needs to be the project."],[4637,4688,"And now that"],[4688,4888,"Isaac's pissed off the Andersons,"],[4888,4954,"What are we going to do"],[4954,5125,"if they pull funding?"],[5180,5505,"Dad, this project needs a new manager."],[5551,5663,"What do you mean?"],[5689,5809,"Dad!"],[5889,6043,"Give the project to me!"],[6289,6502,"We don't even know where your brother is."],[6502,6648,"And all you can think about"],[6648,6794,"is grabbing more power?"],[6911,7157,"How did I raise a son like you?"],[7344,7436,"Dad."],[7507,7657,"You don't need to attack Tyler like that."],[7657,7803,"He's just thinking big picture."],[8028,8108,"Shane,"],[8212,8391,"you take over the project."],[8487,8704,"I gotta clear Isaac's name."]],"53":[[58,226,"I can't believe this."],[246,383,"Even though Isaac is a wanted criminal,"],[383,533,"Dad is still on his side!"],[533,754,"Don't, Tyler, shut up."],[754,1005,"Look, with Isaac out of the picture,"],[1005,1142,"Mark International is gonna be ours"],[1142,1263,"sooner or later."],[1263,1438,"Why you gotta piss off Dad like that?"],[1438,1543,"You destroyed all the evidence"],[1543,1668,"about that dead man, right?"],[1668,1951,"Yes. Don't worry."],[1951,2064,"Died in Isaac's house."],[2064,2323,"So, all the evidence is going to point to Isaac"],[2323,2527,"and Isaac alone."],[2527,2634,"But what if he escapes abroad"],[2634,2852,"and never comes back?"],[2852,3098,"We need to make sure he disappears forever"],[3098,3286,"before the police find him."],[3632,3703,"Look,"],[3703,3858,"if Isaac wanna come to the wedding,"],[3858,4054,"he's going to have to go down this road"],[4054,4229,"that's under construction."],[4229,4383,"And we're just gonna have to make sure"],[4383,4575,"that his tiny little car"],[4575,4863,"just meets the right construction truck."],[5947,6043,"What's this?"],[6043,6126,"My bride?"]],"54":[[112,379,"What's this? My bride?"],[379,483,"What!"],[704,788,"Shane..."],[855,1046,"It was you"],[1046,1301,"who installed the surveillance software"],[1301,1401,"in my phone."],[1614,1826,"And it was you"],[1826,2002,"who paid off my private detective"],[2002,2139,"to frame Isaac!"],[2139,2214,"Why?"],[2314,2464,"You devil!"],[2464,2736,"How could you do that to your own brother?"],[2736,2865,"I even thought you were a good man!"],[2865,3040,"He's not my brother!"],[3040,3328,"If it weren't for him and his dirty mother,"],[3328,3453,"would my mother still be around"],[3453,3578,"if I was born?"],[3578,3695,"And my Dad wants to make him"],[3695,3787,"a member of the Marks."],[3787,3883,"No!"],[3883,4054,"No way."],[4054,4225,"He disgusts me"],[4225,4396,"every time I I lay eyes on him."],[4396,4504,"So, you listen to me,"],[4504,4683,"Jennifer Sullivan."],[4775,4984,"From now on,"],[4984,5130,"if you wanna make me happy, you..."],[5130,5347,"you'll have a place in the Marks family."],[5347,5497,"But if you do anything out of place,"],[5497,5668,"anything at all,"],[5668,6056,"and you can just kiss your sister goodbye."]],"55":[[204,358,"All done."],[529,775,"Congratulations, Mr. Marks!"],[863,1071,"Your beautiful bride."],[1071,1197,"Thank you."],[1197,1426,"Could you give us a moment?"],[1426,1555,"Yeah, sure."],[2064,2256,"It's your wedding."],[2385,2527,"Isaac wouldn't miss it for the world,"],[2527,2656,"would he?"],[2848,3098,"Even if he knows it's a trap,"],[3098,3182,"he wouldn't want to see"],[3182,3244,"the woman he loves"],[3244,3440,"gets married to someone else."],[3578,3883,"No, he won't be back."],[3883,4037,"He has to."],[4137,4279,"Sweetheart,"],[4279,4608,"this is the funeral I've so carefully prepared."],[4921,5146,"Isaac's helicopter just crashing the ocean!"],[5351,5463,"Helicopter?"]],"56":[[4,175,"We need to find Isaac,"],[175,362,"no matter what it takes!"],[567,771,"Dad, why even bother?"],[771,896,"He's a wanted criminal!"],[896,996,"Our stocks are plummeting"],[996,1092,"because of him."],[1092,1284,"You shut up!"],[1351,1409,"Dad,"],[1447,1680,"give me his position."],[1793,2077,"Even if I were to give it to someone,"],[2077,2318,"it wouldn't be you!"],[2706,2932,"If not me, then who? Dad!"],[2932,2982,"I'm doing this"],[2982,3232,"for Marks International's sake!"],[3307,3516,"You might find out he's dead tomorrow."],[3536,3837,"You... you..."],[4229,4337,"Dad?"],[5363,5434,"Doctor,"],[5434,5547,"how's my dad?"],[6339,6519,"Hey, Dad."],[6519,6744,"Here's the will we drew up for you."],[6744,6856,"We just need you to sign here."],[6856,7007,"Okay?"],[7286,7586,"No, no sign..."],[7786,7945,"You said yes, but your hands too shaky?"],[7945,8095,"Here. It's okay."],[8095,8433,"Let me just help you there."],[8762,8900,"Tyler,"],[8963,9138,"you should be more gentle with Dad."],[9138,9331,"Just have himself a stroke."],[9496,9617,"Drop the act."],[9617,9709,"I'm the bad cop,"],[9709,9868,"and you get all the good cop parts."],[9972,10147,"But Shane,"],[10147,10318,"out of the three of us,"],[10318,10518,"you are the most sly and cunning one."],[10677,10827,"Well, I'm the nicer looking one."],[10827,10960,"Yeah."],[10960,11240,"It's ours. It's ours!"]],"57":[[1155,1326,"Isaac,"],[1451,1543,"you promised that"],[1543,1801,"you were gonna give me my justice..."],[1906,2089,"So, you don't want it anymore?"],[2540,2694,"Isaac!"],[2898,3224,"You... You're alive!"],[3507,3616,"Wait!"],[3616,3933,"Did you fake the helicopter crash?"],[3933,4153,"There was no helicopter crash."],[4183,4346,"I told my guys to send Tyler"],[4346,4538,"some stock footage."],[4558,4704,"It wasn't real."],[4763,4821,"Then..."],[4821,5000,"then what's real?"],[5109,5309,"The attempted murder."],[5397,5572,"And I have to thank you,"],[5572,5751,"otherwise, I would be"],[5822,5930,"crushed."],[6001,6072,"Look,"],[6072,6227,"if Isaac wants to come to the wedding,"],[6227,6423,"he's going to have to go down this road"],[6423,6598,"that's under construction."],[6598,6752,"And we're just gonna have to make sure"],[6752,6936,"that his tiny little car"],[6936,7232,"just meets the right construction truck."],[7307,7524,"But I know the truck like Shane planned."]],"58":[[137,262,"Well."],[262,471,"You... you don't have to thank me,"],[471,621,"Isaac, okay?"],[721,975,"I still couldn't find who the culprit is..."],[1197,1497,"That's why I couldn't let you die."],[1597,1743,"Jennifer, I'm..."],[1743,1901,"I'm sorry."],[1901,2012,"About what?"],[2081,2381,"Marks International and..."],[2464,2677,"corporation partners."],[2677,2932,"And they said you had dirt on them."],[2932,3157,"So I sent someone to steal the files"],[3157,3390,"from your house, and it turned into arson,"],[3390,3561,"and the guy ran away."],[3595,3699,"Look,"],[3824,3991,"I didn't tell you anything about that,"],[3991,4179,"because I'm not even sure"],[4179,4429,"if it's my guys set the fire."],[4491,4683,"What about now?"],[4683,4892,"Could you find the culprit of the arson?"],[5355,5438,"Hello, Jennifer."],[5438,5605,"Jennifer, today's the day I took over"],[5605,5801,"as the CEO of Marks International."],[5872,6097,"I need my wife by my side."],[6756,6835,"Hey, why don't you stop"],[6835,6915,"standing around looking pretty"],[6915,7011,"and why don't you..."],[7011,7198,"go on work on my tie?"],[7338,7452,"Sure."],[7486,7657,"Is this what you decide to wear?"],[7807,7873,"Yeah."],[7873,8120,"Not as sexy as I'd like."],[8150,8204,"Why do you look like"],[8204,8391,"you're here against your will?"],[8462,8500,"Come on!"],[8500,8550,"Don't tell me"],[8550,8787,"it's because you're not with Isaac."],[8850,9042,"What are you talking about?"],[9079,9200,"Well."],[9200,9430,"You know he can't save you now, right?"],[9430,9513,"Mr. Shane,"],[9513,9634,"the ceremonial news about..."],[9634,9693,"Mr. Shane?"],[9693,9934,"No, it's Mr. Marks to you!"],[9934,10097,"Yes, Mr. Marks."],[10272,10377,"Shall we?"],[10462,10585,"Sure."]],"59":[[487,551,"Oh, thank you all"],[551,771,"for coming out this evening."],[925,1126,"Tody is a day."],[1126,1317,"There is a day I take over as"],[1317,1518,"CEO of Marks International."],[1643,1846,"So, I wanna thank you for coming out here"],[1846,2069,"and taking time out of your busy schedules."],[2118,2264,"Let's take some questions."],[2352,2456,"Yeah."],[2519,2669,"Is Isaac Marks really to blame"],[2669,2848,"for the 616 arson case?"],[2848,2940,"Did anyone in the family"],[2940,3065,"already know about it?"],[3194,3432,"And we also don't cover for criminals."],[3732,3949,"I have a question, too."],[4187,4542,"The man who allegedly set the fire,"],[4688,5100,"why did he die at Isaac Marks' house?"],[5184,5342,"If you keep saying things you shouldn't,"],[5342,5572,"today will be the day to say goodbye."],[5689,5935,"It's just a question."],[6252,6379,"What?"],[6424,6539,"How?"],[6731,6861,"Stop it!"],[6861,7040,"Someone call security!"],[7040,7162,"Call the police!"],[7182,7278,"Yeah, right."],[7278,7528,"Someone call the police!"],[7557,7820,"Listen to this, my friends."],[7870,7966,"Look,"],[7966,8133,"if Isaac wants to come to the wedding,"],[8133,8304,"he's gonna have to go down this road"],[8304,8491,"that's under construction."],[8491,8650,"And we're just gonna have to make sure"],[8650,8817,"that his tiny little car"],[8817,9114,"just meets the right construction truck."],[9114,9177,"It's fake."],[9177,9406,"It's all fake, I promise you."],[9471,9642,"I was so wrong what about you..."],[9642,9793,"Dad! I... Listen."],[9793,9922,"it's not what it looks like."],[9922,10030,"It's Tyler."],[10030,10168,"This is all Tyler's idea!"],[10214,10326,"What?"],[10326,10452,"How can you say that?"],[10506,10668,"Shane thought everything!"],[10668,10906,"You two are the same!"],[11090,11336,"When I pretended to have a stroke,"],[11336,11528,"I heard everything you said."],[11528,11724,"I saw everything you did."],[11724,11899,"Loud and clear!"]],"60":[[162,346,"Rosen..."],[875,1113,"The head of the Rosen Corporation,"],[1113,1272,"accomplice to Tyler Marks"],[1272,1393,"and Shane Marks"],[1393,1497,"in the arson case."],[1497,1634,"I was just gonna..."],[1634,1901,"scare Ms. Sullivan, so she would back down,"],[1901,2110,"but Tyler and Shane told me"],[2110,2239,"to burn everything down,"],[2239,2452,"then frame Isaac for it."],[2635,2773,"Okay, okay."],[2773,2898,"Alright."],[2898,3007,"Isaac!"],[3211,3386,"Isaac,"],[3386,3570,"you may have won this time but,"],[3570,3661,"you have to look at the fact that"],[3661,3795,"you killed your own kid!"],[3895,4100,"How you feel about that?"],[4229,4450,"This is... my child?"],[4450,4587,"No! The baby's not dead?"],[4587,4707,"How is that possible?"],[4707,4832,"No, how is that possible?"],[4832,5017,"Hey!"],[5447,5668,"I've lost my love once."],[6001,6160,"Your mother."],[6160,6373,"And I don't wanna lose you now."],[6373,6623,"I've entrusting Marks International to you."],[6623,6856,"I believe you'll make it better."],[7340,7535,"Well, what are you waiting for?"],[7565,7786,"Go find her and tell her how you feel!"],[8397,8485,"Dad,"],[8641,8758,"I've finally found"],[8758,8938,"who is responsible for your death."],[9004,9255,"I brought you justice."],[9325,9609,"You can finally rest in peace."],[10614,10769,"Jennifer..."],[10839,11190,"Is it... Is it really our baby?"],[11190,11382,"Mr. Marks,"],[11382,11461,"I am really thankful"],[11461,11569,"because you've been for helping me"],[11569,11786,"finding the culprit for my family."],[11920,11974,"But that doesn't mean"],[11974,12116,"that I'm gonna be with you."],[12116,12295,"No, Jennifer, I'm..."],[12587,12775,"I'm so sorry."],[12846,13146,"I've done things I can't make up for."],[13146,13425,"And I know that the Marks family and I,"],[13425,13738,"we've done irreversible harm to you. So..."],[13797,13893,"Look, what I'm trying to say is"],[13893,14130,"I'm really sorry for everything."],[14230,14368,"Everything you've been through."],[14368,14706,"For all, I reclaim that, I just regret it so much."],[14977,15048,"Yeah."],[15311,15518,"Um, Jennifer."],[15640,15786,"Are you willing to"],[15874,16203,"forget about the past and start over again?"],[18193,18373,"I'm Jennifer Sullivan."],[18373,18560,"Nice to meet you."],[18744,18902,"Isaac Marks."],[18922,19056,"Nice to meet you."]]}