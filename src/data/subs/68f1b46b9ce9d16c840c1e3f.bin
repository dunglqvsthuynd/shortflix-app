{"1":[[50,96,"Cheater!"],[170,341,"This is the National Spacecraft"],[341,523,"Elite Modeling Competition"],[553,653,"hosted by NAA."],[727,907,"This is what you call a straight A student?"],[940,1041,"You despicable cheater!"],[1091,1257,"No! No, no, no, I didn't."],[1257,1305,"Didn't?"],[1391,1594,"Your answers are identical to Camilla's."],[1634,1814,"Do you really expect us to believe"],[1814,1899,"that you didn't cheat?"],[2008,2173,"I didn't plagiarize! Okay?"],[2173,2297,"I did it myself!"],[2305,2479,"Do you expect us to believe you?"],[2535,2642,"Actually, your scores"],[2642,2774,"are always the same as Camilla's."],[2774,2919,"You must be copying her."],[3150,3276,"We know this competition"],[3276,3574,"gets a direct offer from NAA HQ."],[3643,3767,"I know you're my sister,"],[3783,4064,"but did you really have to stoop this low?"],[4099,4162,"Huh?"],[4250,4476,"You have humiliated yourself"],[4476,4628,"and the Selivis family."],[5230,5322,"You idiot!"],[5362,5518,"You disgraced the Selivis name!"],[5525,5696,"Dad, I didn't cheat! I swear!"],[5710,5804,"I know you hate me"],[5804,5952,"because I'm an adopted daughter,"],[5979,6136,"but cheating to win?"],[6162,6249,"That's just a shame."],[6285,6423,"I always knew she was trouble."],[6428,6617,"But this? Unforgivable."],[7257,7417,"How is this for cheating, huh?"],[7427,7564,"No, I didn't!"],[8398,8471,"Shut up, Ada!"],[8478,8673,"Your past recklessness was bad enough!"],[8675,8790,"But this competition?"],[8802,8995,"The whole world is watching on live stream!"],[9029,9172,"And you thought you could cheat your way in?"],[9179,9279,"No, no, it wasn't me!"],[9279,9389,"Camilla's the one!"],[9602,9693,"Still lying?"],[9783,9904,"Dad, stop."],[9913,10013,"You're going to kill her."],[10056,10160,"Why defend her?"],[10263,10515,"A disgrace like this deserves worse!"],[10589,10670,"Why?"],[10677,10860,"Why won't anyone believe me?"],[10864,10997,"Why? Why?"],[11044,11449,"An orphan raised like you, stealing my parents' love?"],[11521,11791,"Even if you are their real daughter, look at you now,"],[11858,11996,"beaten to death."],[12739,12866,"Take your seats, everyone."],[12866,13011,"The competition is beginning."],[13036,13148,"Competition?"],[13303,13505,"Am I... back?"]],"2":[[3,192,"Am I... back?"],[274,387,"Are you listening to me?"],[480,641,"Don't you dare ruin this for Camilla."],[820,878,"Ada."],[1061,1293,"Since God gave me a second chance,"],[1317,1511,"I'll deal with each of you."],[1611,1835,"Nice and slow."],[1855,1992,"Dad, ever since we brought her back,"],[1992,2177,"she's done nothing but be against Camilla."],[2185,2318,"We're lucky if she hasn't attack her."],[2352,2542,"Should have just left this orphan where she was."],[2592,2799,"Would have saved us all a lot of trouble."],[2859,2929,"You're right."],[2966,3026,"You should have."],[3036,3163,"I would have been a lot happier."],[3193,3519,"Ada, you're breaking Mom and Dad's heart."],[3970,4037,"Camilla."],[4134,4274,"Drop the act, Camilla."],[4300,4438,"We all know what you're really like."],[4491,4609,"Ada, how dare you?"],[4661,4764,"It's okay, Jacob."],[4764,4847,"I'm fine."],[4874,4981,"She's your little sister!"],[5011,5130,"How could you be so cruel?"],[5148,5242,"Cruel?"],[5258,5415,"Ever since the day I came back,"],[5415,5644,"this adopted sister has set me up,"],[5665,5802,"beaten me and none of you noticed."],[5802,6079,"Look, Ada, I know I'm an adopted daughter"],[6079,6243,"and you don't have to like me."],[6312,6506,"But why just slander me like that?"],[6596,6646,"You know what?"],[6646,6754,"It is my fault."],[6806,6966,"If hitting me makes you happy,"],[6986,7105,"then go ahead, do it again."],[7230,7300,"Gladly."],[7652,7721,"Ada!"]],"3":[[72,188,"How dare you?"],[226,352,"Apologize to Camilla!"],[373,471,"For what?"],[479,724,"Brat, I'll beat an apology out of you."],[1331,1378,"Why?"],[1421,1601,"Why won't anyone believe me?"],[1601,1730,"Why? Why?"],[1928,2238,"I have paid my life's debt to the Salivis family already."],[2238,2479,"You have no right to discipline me."],[2759,2839,"How you..."],[2999,3169,"I came back for family."],[3186,3353,"Nothing I did was ever right."],[3356,3478,"Nothing ever made me equal"],[3478,3661,"to your precious adopted daughter."],[3690,3788,"So you know what?"],[3840,4049,"I think it's time we all cut ties."],[4110,4337,"Ada, don't say that."],[4374,4552,"If anyone's to blame, it's me."],[4574,4661,"If you really want it,"],[4661,4784,"then fine, take it all."],[4861,4931,"Just go."],[4994,5089,"You should've quit already."],[5111,5335,"Yeah, you're a disgrace to the Salivis family."],[5408,5472,"Ada,"],[5602,5785,"you worked so hard for this."],[5825,5966,"Why'd you quit now?"],[5992,6102,"She's panicking,"],[6139,6282,"which means she's guilty."],[6329,6496,"No, I can't leave now."],[6523,6646,"I have to clear my name."],[6690,6746,"You're right."],[6763,6982,"You know, maybe I shouldn't give it up so easily."],[7217,7347,"Don't make me laugh, Ada."],[7404,7500,"You winning?"],[7550,7745,"That'll be the day that pigs fly."],[7774,7821,"Oh?"],[7837,8006,"Well, see what I can do."],[8141,8214,"This time,"],[8238,8411,"I'll take back what's mine."]],"4":[[96,283,"There's something different about her now."],[380,563,"She never dared to fight Dad back,"],[577,726,"and now she's cutting ties?"],[870,992,"Just empty threats."],[1024,1147,"After the competition,"],[1147,1254,"I'll deal with her myself."],[1254,1368,"What if she ends up messing things up"],[1368,1506,"for Camilla in the competition?"],[1604,1676,"Don't worry."],[1701,1901,"The winner's spot is mine."],[2028,2118,"Ladies and gentlemen,"],[2155,2311,"our competition is beginning."],[2395,2515,"If you are not a participant,"],[2515,2667,"please clear the area"],[2686,2798,"and return to your seats."],[3316,3420,"Last time,"],[3440,3609,"they framed me for cheating."],[3697,3797,"This time,"],[3840,4119,"I'm taking control of my own fate."],[4447,4654,"This competition concerns the future"],[4654,4861,"of top-tier NAA techs."],[4938,5038,"You are all elites."],[5175,5431,"Two versions of the tests have been provided."],[5485,5633,"Choose one to answer."],[5852,5979,"Challenge set B"],[5979,6222,"is the decade-old unsolved problems."],[6266,6451,"Well, I'll try this."],[6469,6554,"Actually,"],[6596,6706,"I'm choosing set B."]],"5":[[43,229,"Actually, I'm gonna choose set B."],[383,604,"No one's ever dared to try the set B before."],[633,704,"Are you sure?"],[747,797,"Yeah."],[844,889,"Why not?"],[990,1231,"I'm only wondering which one my sister will pick."],[1251,1376,"Set A or set B?"],[1474,1648,"I can bet you it's going to be the same as mine."],[2075,2217,"Wouldn't be the first time."],[2232,2415,"Yeah, she's totally copying you again."],[3460,3656,"Well, good luck then, Camilla."],[3893,4038,"According to the rules,"],[4040,4341,"scoring is based on multiple methods of solving."],[4367,4519,"I'll triple path it,"],[4524,4736,"using algebraic manipulation,"],[4748,4868,"geometric proof"],[4878,5051,"and enumeration."],[5065,5165,"Final confirmation."],[5238,5409,"Once you click confirm,"],[5409,5555,"you can no longer change your answers."],[5655,5785,"On a second thought,"],[5849,6041,"I think I'm just gonna play it safe."],[6119,6522,"And I want to use three methods to solve problem set A,"],[6619,6980,"Algebraic manipulation, geometric proof, and..."],[7080,7160,"enumeration."],[7347,7407,"Oh!"],[7440,7624,"Oh, how good is she."],[7797,8029,"How does she know my exact plan?"]],"6":[[16,73,"Oops!"],[93,317,"Did I just say my entire plan out loud?"],[397,470,"Silly me."],[533,653,"What about you, Ada?"],[724,804,"What's your plan?"],[1021,1222,"Since when do I report to you?"],[1351,1504,"What's with the attitude?"],[1518,1760,"Camilla's being generous, sharing her solution."],[1768,1941,"Yeah, not like some people."],[2025,2225,"Always borrowing other people's work, huh?"],[2402,2585,"Well, for it to be plagiarism,"],[2652,2915,"the solution steps have to be identical."],[3039,3292,"But my sister would never do that, right, sis?"],[3403,3462,"Never."],[3503,3753,"How does she know my exact plan?"],[3993,4070,"You idiot!"],[4120,4274,"You disgraced the Selivis name!"],[4294,4464,"Dad, I didn't cheat! I swear!"],[4497,4588,"I know you hate me"],[4588,4750,"because I'm an adopted daughter,"],[4771,4922,"but cheating to win?"],[4940,5053,"That's just a shame."],[5068,5189,"I always knew she was trouble."],[5211,5409,"But this? Unforgivable."],[5475,5625,"How is this for cheating, huh?"],[5655,5835,"I don't know what tricks you are using."],[5912,6006,"I'll stop answering."],[6082,6206,"Let's see what you can copy."],[6292,6566,"Excuse me, I'm ready to hand in my test."]],"7":[[16,183,"I'm ready to hand in my test."],[300,380,"What's going on?"],[420,598,"Ada still hasn't started answering."],[610,739,"Guess she realized she couldn't copy"],[739,820,"Camilla this time."],[857,987,"So she decided to give up."],[1234,1379,"She's not answering at all?"],[1451,1541,"What about me?"],[1738,1931,"But time isn't up."],[3149,3302,"If I turn in nothing like her,"],[3346,3484,"they will think I copied her."],[3576,3645,"Excuse me?"],[3760,3861,"I need to use the restroom."],[3953,4007,"Hurry."],[5155,5258,"This is my chance."],[5288,5496,"I have to finish before she comes back."]],"8":[[37,122,"So hard..."],[122,245,"So hard to figure out."],[614,762,"I simplify expressions,"],[804,924,"isolate unkowns,"],[924,1081,"and factor strategically."],[1121,1331,"The structure begins to reveal itself."],[1371,1657,"But algebra alone won't uncover the full picture."],[1701,1905,"Step two, geometric proof."],[1951,2135,"Now I shift perspectives."],[2165,2300,"A diagram clarifies"],[2300,2511,"the relationships hidden in symbols."],[2545,2926,"I draw lines, mark angles, look for symmetry."],[2969,3239,"Theorems like Pythagoras, Congruency,"],[3263,3459,"or similar triangles come into play."],[3496,3721,"Visual logic supports the algebra."],[3747,3873,"They align perfectly."],[3927,3985,"Step three,"],[4027,4097,"enumeration."],[4140,4501,"To verify, I enumerate all valid cases."],[4531,4788,"One by one, I count possibilities,"],[4808,5080,"ruling out overlaps and redundancies."],[5128,5246,"Each path is checked."],[5275,5407,"Every condition met."],[5472,5695,"Game over, Camilla."],[6760,6820,"Camilla,"],[6896,7068,"your answers are perfect."],[7173,7233,"How did you do it?"],[7347,7514,"Camilla, why are you here?"],[7544,7664,"I came in five minutes ago."],[7744,7887,"You were just too busy to notice, sis."],[8044,8317,"The years of hard work finally shining through."],[8378,8504,"You're the best, Camilla."],[8545,8655,"Dad's proud of you."],[8675,8852,"The solutions just came to me naturally."],[8992,9077,"Although this time,"],[9077,9549,"I chose to innovate beyond conventional approaches."],[9549,9622,"Amazing."],[9646,9848,"If anyone's answers match now,"],[9852,10076,"it's obvious who copied."],[10443,10742,"Oh no, it's happening again."],[10787,10948,"Time is almost up, Ada."],[11047,11269,"Uh, there's something wrong."],[11311,11424,"I want to fix it."],[11534,11606,"What?"],[11718,11866,"Why didn't you say it sooner?"],[11961,12112,"What's the panic, Camilla?"],[12142,12325,"I mean, unless your answers"],[12342,12509,"need to have the same correction."]],"9":[[33,132,"Yeah, Camilla."],[132,315,"Why do you care if she messed up?"],[326,423,"Yeah, why do you care?"],[800,1049,"I just care about my little sister, that's all."],[1111,1215,"I got carried away."],[1338,1644,"Aww, she's smart and sweet."],[1668,1784,"It's rare these days."],[1838,1958,"How touching."],[2012,2105,"Allow me."],[2559,2699,"I need to amend my answers too."],[2856,3141,"But Camilla, your answers are flawless."],[3219,3396,"She's hiding a better solution."],[3466,3707,"No way I'll let her outshine me."],[3707,3870,"Camilla, Ada's stupid."],[3897,3977,"Ignore her."],[4110,4204,"Rest assured."],[4267,4474,"I just thought of a better solution, that's all."],[4611,4768,"Alright, well, make it quick."],[4884,5164,"Ada, only I can be the winner."],[5238,5356,"Why isn't Camilla editing?"],[5412,5458,"Easy."],[5495,5687,"Geniuses think through things in their heads first."],[5722,5797,"Maybe."],[5835,5993,"She looks a bit nervous."],[6272,6401,"What the hell is she up to?"],[6596,6718,"Three minutes left."],[6750,6883,"If I revise now,"],[6883,7043,"she won't have time to copy."],[7427,7615,"No matter how low a time is left,"],[7660,7849,"I'll revise it the same time as you."],[9240,9281,"Done!"],[9299,9331,"Done!"],[9599,9784,"Yes, Camilla!"],[9986,10098,"An X-equation."],[10170,10292,"Even top mathematicians"],[10292,10397,"haven't been able to solve this."],[10430,10543,"Camilla, how did you do it?"],[10633,10757,"That's impossible."],[10800,11027,"Camilla solved the unsolvable?"],[11067,11234,"But she's only a high school student."],[11254,11481,"That's because she's the genius."],[11638,11815,"What did you do, lil sis?"],[11835,12032,"Don't tell me it's X-equation, too."],[12369,12522,"Totally same?"],[12572,12714,"How is this possible?"]],"10":[[36,166,"Totally same?"],[230,375,"How is this possible?"],[907,1055,"Time is up, Ada."],[1558,1664,"Oh my god!"],[1725,2006,"Her solutions are exactly like mine!"],[2582,3009,"Holy, these solution steps are the exact same."],[4074,4167,"Ada, I'm sorry."],[4247,4374,"But Camilla submitted first,"],[4374,4631,"so we have no choice but to suspect you of plagiarism."],[4721,4850,"No, I didn't."],[4998,5225,"Just let me try set B one more time"],[5225,5348,"to prove my innocence."],[5395,5637,"And I want a seat far away from Camilla."],[5685,5811,"Over there in that corner."],[5879,5968,"Why the corner?"],[6012,6307,"Duh, less eyes on her, easier to cheat."],[6339,6539,"Ugh, stay away from me, cheater."],[6676,6733,"Cheater!"],[6733,6924,"-Come on! Like really? -She's a cheater."],[7183,7414,"No, I need to stay close to her."],[7550,7623,"You know what?"],[7691,7879,"Set B is super complicated,"],[7907,8067,"and I feel like proving myself too."],[8161,8462,"So how about we actually solve it on the stage,"],[8485,8775,"in front of everyone, under full supervision?"],[10784,10850,"You can begin."],[12230,12392,"As long as I don't write a word,"],[12392,12530,"your tricks are useless."],[12592,12792,"The truth will reveal itself."],[14361,14431,"Wow!"],[14447,14612,"She's not even hesitating!"],[14654,14904,"Looks like the set B is a piece of cake for Camilla."],[16576,16800,"Identical again? Why?"]],"11":[[83,311,"Ada, why aren't you typing?"],[387,585,"Are you waiting for my answers again?"],[800,864,"Why?"],[890,1070,"Why won't anyone believe me?"],[1077,1225,"Why? Why?"],[1264,1427,"Oh, I believe you."],[1461,1564,"Sure I do."],[1688,2065,"But within six feet, I can read your mind."],[2215,2335,"She meant it."],[2395,2462,"Literally,"],[2472,2700,"this bitch can read my mind."],[2732,2866,"But only within six feet."],[2866,2916,"What happened?"],[3259,3426,"Look, if you're struggling, that's okay."],[3473,3626,"I can share my methods with you."],[3683,4008,"But don't copy my exact answers."],[4060,4194,"That's just disgraceful."],[4607,4694,"Plagiarism?"],[4748,4910,"You stole my methods."],[4951,5124,"You thieving bitch."],[5208,5295,"You're the b..."]],"12":[[633,818,"You're the best, Ada."],[887,950,"I get it."],[970,1188,"You're just trying to make Mom and Dad proud"],[1188,1277,"just like I am."],[1331,1402,"But cheating?"],[1464,1599,"That's just not the way."],[1644,1899,"That will only make them embarrassed."],[1905,2025,"Cut the act."],[2098,2313,"You stole my parents,"],[2322,2414,"my brothers,"],[2414,2598,"my spot as a Selivis."],[2599,2827,"And now you're stealing my talents, too?"],[3273,3572,"Camilla, are you OK?"],[3636,3702,"How dare you?"],[3773,3892,"Are you hurt, Camilla?"],[3897,4007,"No, no, I'm fine."],[4007,4123,"Thank you so much. I..."],[4129,4329,"If this makes my little sister happy,"],[4329,4441,"I can endure it."],[4441,4824,"But I won't let her keep disgracing herself like that."],[4921,5068,"She's the one copying me."],[5098,5438,"And she's also accusing me of stealing her solutions"],[5438,5538,"and her family?"],[5638,5784,"Does she hate me so much?"],[5789,5853,"Don't worry."],[5865,5966,"Don't worry."],[6002,6202,"You are our daughter."],[6202,6360,"No one can replace you."],[6523,6679,"Ada, apologize now!"]],"13":[[140,324,"Ada, apologize now!"],[420,560,"Mom, Dad, I..."],[560,620,"Save it."],[727,817,"If we hadn't stepped in,"],[857,997,"who knows what you would have done to Camilla."],[1071,1172,"I didn't! I..."],[1172,1301,"She's the one who's copying me."],[1301,1577,"Mom, Dad. Guys, please, trust me."],[1631,1835,"We know exactly what kind of person you are."],[1898,2080,"And the things you learned on the streets."],[2102,2217,"So are you saying..."],[2315,2489,"I'm the one who's cheating?"],[2569,2740,"Harry and I are top of our fields."],[2816,3057,"And we've raised Camilla ourselves."],[3159,3433,"She has no reason to cheat off anyone."],[3516,3583,"That's right."],[3633,3949,"Camilla represents years of Selivis-standard excellence."],[3959,4114,"And you? An orphanage girl"],[4114,4321,"dreaming of solving world-class problems?"],[4351,4419,"Get real."],[4504,4624,"Stay in your lane."],[4671,4905,"Even mediocrity is better than being a cheap fake."],[4991,5197,"How dare you compare yourself to Camilla?"],[5248,5425,"If anyone should be cast out, it's you."],[5482,5782,"It took us 18 years to prepare Camilla to win"],[5822,5973,"an international gold."],[6002,6071,"And you?"],[6162,6458,"A nobody claiming genius."],[6493,6918,"In my last life, they only brought me home at 18."],[7016,7125,"And before that,"],[7140,7517,"Camilla never won a single math award."],[7517,7941,"The truth is so obvious if they wanted to see it."],[8051,8187,"No matter what I do,"],[8187,8424,"I'll never belong in my own family."],[8555,8824,"Then... I give it up."]],"14":[[166,380,"Mom, she's just trying to impress you."],[453,579,"Even if she cheated,"],[647,850,"please, let's be easy on her."],[867,1051,"Wow, you hear that, Ada?"],[1097,1237,"Camilla still defends you."],[1277,1369,"And what did you do?"],[1491,1698,"How could I have a daughter like you?"],[1745,2008,"Always fighting Camilla and..."],[2068,2311,"ruining her crucial competition?"],[2622,2682,"Me?"],[2772,3170,"She took my family, my grades, my entire life!"],[3209,3366,"You ran away from your family."],[3386,3554,"You're lucky we took you back at all."],[3633,3773,"I was lost."],[3817,3949,"And I was a child."],[4027,4184,"Why didn't you find me sooner?"],[5280,5345,"Ada!"],[5552,5807,"I can leave the Selivis family if you want"],[5829,5991,"and you'll get back their love."],[6016,6119,"No, no!"],[6179,6303,"You shouldn't leave."],[6303,6481,"If anyone's leaving, it's her."],[6863,6945,"Oh."],[7143,7320,"I can give your family back to you,"],[7374,7719,"but math is the only thing that is still mine."],[7827,8024,"And I beg you, please,"],[8024,8264,"stop copying my solutions!"],[8511,8605,"I beg you."],[8762,8978,"Cami, you will always be our family."],[9045,9427,"Hey, you are my only daughter."],[9456,9652,"-Our only sister. -Our only sister."],[9939,10072,"Ada, leave."],[10133,10443,"You would rather kick out your biological daughter"],[10467,10663,"and keep this adopted one?"],[10704,10891,"A daughter that cheats and steals?"],[11017,11109,"We don't need that."]],"15":[[40,140,"We don't need that."],[530,927,"I am so done with this screwed up family."],[927,989,"Enough!"],[1057,1207,"Apologize to Camilla, now."],[1364,1458,"Don't touch me."],[1561,1715,"I will never apologize to her."],[1715,1795,"Disgusting."],[1831,1970,"I will not allow you to tarnish"],[1970,2138,"this family name any longer."],[2195,2285,"Are you kidding?"],[2359,2548,"Get out of this competition now!"],[2592,2736,"Jacob, don't let her go."],[2772,3029,"She's just starving for your attention."],[3416,3506,"Jacob, stop."],[3513,3618,"You want the whole country to see"],[3618,3751,"a man handling trash like her?"],[4037,4156,"Don't worry Ada,"],[4170,4296,"I'll help you persuade them."],[4541,4655,"If she leaves..."],[4684,4802,"who will I copy from?"],[4871,5010,"I have to crush you here,"],[5058,5148,"permanently."],[5195,5353,"Oh, my Camilla."],[5412,5605,"You are too soft-hearted."],[5755,6129,"I know that Ada prepared so hard for this competition,"],[6186,6439,"and it would kill me to see her leave halfway."],[6486,6542,"Funny."],[6593,6790,"Since when has she ever prepared?"],[6873,6953,"Exactly."],[6990,7123,"All she did was wait for a chance"],[7123,7260,"to steal from your answers."],[7293,7417,"A thief like her competing?"],[7454,7637,"What a disgrace to the Selivis family."]],"16":[[30,224,"So this is my family."],[330,614,"Maybe I was lucky to be separated from you after all."],[764,837,"Don't worry."],[867,1045,"No matter how much shame I bring,"],[1045,1241,"it will never affect the Selivis family."],[1281,1366,"What do you mean?"],[1491,1554,"Tell me,"],[1568,1728,"have you ever heard them mention"],[1728,1881,"that I'm part of this family?"],[2062,2126,"You!"],[2222,2399,"You ungrateful little snake!"],[2425,2610,"Ada, how can you say that?"],[2652,2769,"They didn't mean it."],[2819,2896,"Oh?"],[2922,3056,"Have you ever heard them mention"],[3056,3179,"that I'm part of this family?"],[3229,3321,"Or are they just..."],[3333,3456,"hiding to the world"],[3456,3690,"and afraid to show their true colors?"],[3727,3988,"Selfish, careless parents!"],[4024,4254,"The more I once craved their love,"],[4287,4472,"the more I despised them now."],[4494,4918,"Last life, I exhausted myself trying to earn their love."],[4991,5194,"Only to be met with scorn."],[5258,5311,"To them,"],[5362,5482,"it's always been Camilla."],[5542,5814,"I'm not making the same mistake."],[5932,6142,"You scheming parasite."],[6219,6566,"I see now all you want is our legacy."],[6826,6940,"Our status."],[7030,7160,"You can't even stand on your own."],[7177,7294,"So now you blame us?"],[7320,7497,"We didn't claim you because we knew"],[7524,7625,"you're not worthy."],[7827,7890,"Enough!"],[7911,8074,"I won't use the Selivis name."],[8098,8254,"Not now, not ever."],[8381,8491,"I've said it once,"],[8501,8625,"and I'll say it again."],[8752,9153,"I am cutting ties with the Selivis family."],[9209,9325,"I am Ada,"],[9376,9554,"just Ada."]],"17":[[23,171,"Ada, have you lost your mind?"],[266,475,"Is that how you treat your own mother?"],[617,720,"That's cute."],[757,1069,"Have you ever referred to me as your own daughter?"],[1121,1184,"Face it."],[1217,1354,"You don't even acknowledge me."],[1364,1554,"Ada, I know you crave their love,"],[1554,1718,"but you can't threaten them."],[1918,2075,"So that's your game, Ada."],[2185,2277,"Threaten us?"],[2322,2537,"How creative."],[2629,2742,"With that attitude,"],[2742,2822,"you'll die waiting."],[2979,3152,"Until you stop lying,"],[3203,3444,"you won't get one word of recognition."],[3506,3552,"Good."],[3593,3668,"Leave me."],[3713,3866,"Enjoy your family."],[3970,4114,"Don't blame them, Ada."],[4144,4306,"They only kept quiet..."],[4387,4474,"for my sake,"],[4507,4652,"to spare my feelings."]],"18":[[23,160,"They only kept quiet..."],[266,337,"for my sake,"],[383,523,"to spare my feelings!"],[734,863,"Okay, how about this?"],[910,1115,"I'll make sure that Mom and Dad"],[1115,1248,"acknowledge you sooner."],[1301,1467,"But you can't stay angry."],[1534,1771,"Oh, the rightful heir needs her replacement"],[1771,1963,"to beg for scraps of recognition?"],[1995,2140,"What a joke!"],[2145,2194,"Ada!"],[2272,2608,"Camilla defends you at every turn and..."],[2615,2812,"and this is how you treat her?"],[2856,3076,"Insult her again and again?"],[3076,3198,"She didn't mean it, Mom."],[3216,3503,"I know that deep inside she just wants to come home."],[3573,3715,"I just need to keep you close"],[3715,3922,"to crush you here in this final round."],[3970,4064,"And after that,"],[4104,4240,"rot wherever you want,"],[4240,4324,"like I care."],[4354,4485,"How kind Camilla is."],[4485,4617,"Apologize to Camilla,"],[4621,4689,"right now!"],[4731,4827,"Apologize."],[4931,5243,"If only you'd just focused on the competition,"],[5325,5492,"and earned a decent ranking,"],[5492,5666,"even second to Camilla,"],[5732,5880,"we'd have thrown you a banquet."],[5945,6120,"Announce you to the world."],[6222,6348,"But you blew it."],[6369,6518,"Mom, Mom, calm down."],[6566,6870,"I'm sure she only said cutting ties"],[6870,7043,"because she wanted your attention."],[7087,7268,"Don't take it so serious."]],"19":[[83,266,"Yes, she copied my answers,"],[276,520,"but only because she wanted your love."],[533,657,"A vain girl,"],[704,794,"who lies,"],[847,924,"cheats,"],[977,1278,"and tried to use the Selivis name for her own gain."],[1408,1693,"She won't do anything but disgrace this family."],[1815,1875,"Listen, Ada."],[1898,2011,"Withdraw now."],[2052,2168,"We'll never allow a fraud to use"],[2185,2402,"our family's name to con her way into academia."],[2452,2529,"Enough!"],[2615,2819,"Camilla's competition is not over, so..."],[2832,3073,"stop wasting your breath on her."],[4187,4324,"There goes my family,"],[4381,4516,"turning their backs."],[4611,4715,"Like always."],[5021,5111,"You idiot!"],[5151,5323,"You disgraced the Selivis name!"],[5342,5453,"Dad, stop."],[5462,5565,"You're going to kill her."],[5585,5695,"Why defend her?"],[5759,6002,"A disgrace like this deserves worse!"],[6106,6266,"How is this for cheating, huh?"],[6419,6551,"No, I didn't!"],[6890,7084,"I'll never let you hurt me again."],[7127,7235,"Not now."],[7260,7371,"Not ever."]],"20":[[16,162,"There goes my family,"],[206,353,"turning their backs,"],[433,551,"like always."],[1157,1250,"Proctor-Sansa."],[1461,1527,"Yes."],[1588,1653,"Got it."],[2140,2218,"Attention, everyone."],[2305,2552,"The prestigious Hardin Research Institute"],[2552,2652,"will be tuning in live."],[2779,2837,"Camilla."],[2892,2949,"Ada."],[2999,3083,"Bring your A-game."],[3213,3418,"Wait, Hardman's picking winners from this?"],[3430,3566,"Yes, the chairperson"],[3603,3723,"declared that the winner"],[3733,3843,"will get a spot on the team."],[4364,4531,"Camilla's victory is inevitable."],[4577,4706,"If only she were our blood."],[4706,4860,"Nonsense, honey."],[4921,5109,"Blood or not,"],[5125,5311,"Camilla is our daughter."],[5348,5471,"Notify the press."],[5498,5580,"Draft."],[5612,5745,"Genius girl story."],[5799,5902,"Once Camilla wins,"],[5945,6061,"the world will witness"],[6072,6220,"the Selivis's true genius."],[6232,6402,"Kevin and I already lined everything up."],[6413,6489,"The article is written,"],[6503,6631,"just waiting for the results."],[7180,7287,"Ironic."],[7330,7407,"Isn't it?"],[8702,8798,"That's my girl."],[9175,9270,"You see that, Ada?"],[9282,9446,"That's what a real Selivis looks like."],[9512,9731,"Ah, so much faith in Camilla."],[9806,9929,"I can't wait"],[9929,10053,"to see your faces"],[10053,10268,"when it all comes crashing down."]],"21":[[4554,4593,"Done."],[4711,4794,"That's my answer."],[5175,5258,"That's my girl,"],[5278,5511,"solving set B in a record time."],[5518,5827,"Honey, forget about the celebrity endorsements."],[5852,5994,"We've got Camilla."],[6016,6096,"Good idea."],[6116,6312,"I heard Hardman's project cadre is recruiting."],[6356,6500,"We should send them Cami's resume."],[6536,6683,"And a national lecture tour."],[6683,6836,"People need to know how brilliant she is."],[6876,7017,"All excellent ideas."],[7404,7470,"Ada."],[7570,7690,"Why aren't you typing?"],[7901,8101,"Oh, you must have cracked a better method."],[8168,8314,"I can't wait to see it."],[8355,8565,"Ah, so much faith in Camilla."],[8645,8892,"I can't wait to see your faces"],[8892,9099,"when it all comes crashing down."],[9165,9265,"Come on, Ada."],[9359,9449,"Took you long enough."],[9759,9879,"It must be brilliant."],[9969,10026,"Show us!"],[10270,10430,"I have to come up with something new."],[10453,10580,"Otherwise I'm screwed."],[10643,10800,"Your method's mine now."],[10900,10984,"What else you got?"],[11084,11271,"Game's over, Ada."]],"22":[[316,536,"So what if you're their biological daughter?"],[587,837,"I've always been the one they really wanted."],[1017,1189,"Please, Ada solving that?"],[1201,1275,"What a joke."],[1331,1451,"It's all garbage anyway."],[1488,1634,"A waste of time to even look at it."],[1905,2235,"Ada, I'm seeing you be destroyed today."],[2288,2415,"What can I do?"],[2479,2666,"Camilla first used my solution."],[2729,3017,"There's no time to think of a new method from scratch."],[3323,3446,"She's out of options."],[3520,3895,"After today, I'll be the undisputed genius."],[3943,4007,"Come on, Ada."],[4204,4354,"Start typing, I believe in you."],[4404,4487,"Take it easy."],[4604,4891,"A proven cheater dares to take on set B?"],[5001,5141,"She's really embarrassing herself."],[5188,5331,"Exactly, she's more than that."],[5331,5498,"She's embarrassing the whole school."],[5552,5652,"She should get out of here."],[5702,5832,"Yeah, get her out!"]],"23":[[115,200,"Hey, everyone."],[337,650,"My sister was preparing so hard for this competition."],[670,875,"Let's just give her a little bit more time."],[982,1130,"An orphanage education"],[1130,1311,"versus a world class competition?"],[1430,1549,"Right, Camilla."],[1549,1766,"Your kindness is doomed to be wasted."],[1790,2055,"First place was always Camilla's."],[2148,2474,"Let's plan your victory banquet."],[2474,2557,"Excellent."],[2557,2718,"We'll throw a grand party."],[2718,2944,"Invite top professors."],[3016,3166,"We'll introduce you early."],[3207,3525,"Daddy, Mommy, thank you so much."],[3925,4179,"The Selivis family shines through you, baby girl."],[4224,4422,"I won't let anything get in your way."],[4456,4757,"Unlike somebody who deserves nothing."],[4949,5364,"We've always been so proud of you, Camilla."],[5381,5526,"Camilla is the best."],[5526,5634,"Always."],[5665,5819,"Alright, enough waiting."],[5819,5907,"Let's go."],[5966,6058,"Wait."],[6111,6220,"Ada's writing?"]],"24":[[1227,1294,"What?"],[1408,1478,"What's that?"],[1511,1634,"This is a brand new method."],[1725,1808,"Oh my gosh."],[2421,2528,"Oh."],[2605,2722,"To be so young."],[2849,3099,"And already able to use such methods."],[3163,3247,"Remarkable."],[3283,3396,"Simply remarkable."],[3580,3779,"There's no way she came up with that herself."],[3973,4040,"What?"],[4077,4250,"How did she come up with a new solution"],[4250,4381,"in such a short time?"],[4667,4964,"You just stole one method, Camilla."],[5011,5178,"Not all of them."],[6439,6476,"Enough."],[6543,6680,"I can't let her keep going."],[6770,6810,"Ada."],[6900,7086,"You promised an original work."],[7170,7400,"Why do you keep stealing my solutions?"]],"25":[[200,340,"Plagiarising again?"],[780,1097,"I knew you'd crack before I took first place."],[1121,1705,"Camilla, are you saying that Ada stole your solution?"],[1755,1825,"That's right,"],[1868,1991,"I came up with it."],[2055,2222,"I don't know why she took my work."],[2649,2709,"Stop!"],[3023,3124,"Wow!"],[3177,3299,"-That's really beaconing. -Alright."],[3299,3406,"Is that professor Hedro?"],[3460,3560,"Holy sh...!"],[3620,3783,"He shows up for an NAA match?"],[3843,3903,"How do I look?"],[3980,4067,"Well, fix the tie."],[4084,4124,"Okay."],[4143,4227,"You're looking great."],[4227,4280,"Aw, thanks."],[4394,4554,"You say it's your idea."],[4647,4695,"Yet..."],[4751,4864,"You didn't write it down?"],[4911,5248,"Now, we all saw Ada solve it live on camera."],[5311,5445,"That's mine."],[5465,5547,"Do you have any proof?"],[5849,5892,"I..."],[6329,6508,"Camilla, show proof directly."],[6556,6764,"Don't worry, sweetie."],[6764,6973,"If Ada stole your work,"],[7013,7198,"we'll make sure she pays."],[7696,8058,"Camilla, let's see how you lie your way out of this one."],[8448,8495,"Kevin?"],[8598,8845,"Don't you remember me solving it at home?"],[8888,8928,"Right?"],[8978,9047,"Me?"],[9215,9399,"If Camilla said she did it,"],[9422,9496,"then she did."],[9592,9713,"Oh, I remember."],[9733,9839,"Camilla solved it at home."],[9866,10011,"Ada must have seen her notes."]],"26":[[230,797,"Kevin, in this life or the last, you never change."],[887,1304,"Always backing Camilla, no matter what the truth says."],[1461,1755,"Ada, Camilla claims you plagiarized her."],[1818,1881,"Is that true?"],[1955,2078,"She's lying, okay?"],[2122,2295,"I came up with that method right here."],[2365,2612,"He's your brother, so of course,"],[2632,2746,"he's going to stick up for you."],[2779,2836,"You..."],[3173,3309,"Their words mean nothing."],[3386,3642,"They're family, biased and unreliable."],[3740,3781,"Camilla."],[3970,4053,"Do you have any proof?"],[4337,4491,"Of course I do!"],[4738,4981,"I'll finish the remaining steps right now."],[5435,5618,"Keep thinking, Ada."],[5749,6006,"The moment I'm within six feet of you,"],[6039,6303,"every thought in your head becomes mine."]],"27":[[617,740,"Why did she back away?"],[850,900,"Did she..."],[980,1157,"figure out I can read minds?"],[1277,1438,"Nobody knows I have that ability."],[1528,1731,"No way this nobody figured it out."],[1958,2088,"Didn't you want to finish it?"],[2315,2585,"The stage is all yours."],[2726,2882,"Last chance, Ada."],[2979,3156,"Admit that you stole my methods,"],[3203,3313,"and we'll go easy on you."],[3573,3743,"Hmm, interesting."],[3787,3920,"A thief crying:"],[3937,4050,"\"Stop thief!\""],[4144,4377,"My brother saw me solving it."],[4454,4594,"I didn't write it down because..."],[4718,4891,"I didn't want to show off too much."],[5098,5218,"I didn't think I need to."],[5281,5350,"I didn't know"],[5350,5532,"you're going to steal it from me again, Ada."],[5852,6022,"Copycat trash like Ada"],[6022,6248,"should be banned from academia."],[6279,6483,"Get out, you plagiarism bitch."],[6636,6776,"No wonder she was able to do it."],[6820,6923,"She stole it from Camilla."],[7020,7170,"And she's still denying it."],[7233,7375,"Disgusting to have her as family."],[7444,7762,"Thank God we never made her identity public."]],"28":[[23,146,"Why is she still here?"],[146,213,"Get her out!"],[236,323,"Plagiarist!"],[347,453,"Disqualify her!"],[463,497,"Ada!"],[513,663,"Why so eager, Camilla?"],[760,997,"If you can really prove that you can finish it,"],[1027,1184,"I'll admit that I copied you."],[1264,1384,"Ada the Cheater!"],[1441,1561,"Caught red-handed?"],[1588,1728,"In front of Professor Hedro?"],[1815,1958,"Oh, we need a headline now!"],[1965,2058,"This'll go viral!"],[2095,2275,"You dumb fool."],[2342,2574,"The longer you hold out, the harder you'll fall."],[2782,2909,"Still denying!"],[3003,3330,"I refuse to believe she's my blood."],[3516,3740,"Hardman tolerates no fraud, Ada."],[4024,4110,"Prove yourself."],[4290,4357,"Why bother?"],[4384,4580,"She's always been a plagiarist."],[4581,4652,"Exactly."],[4704,4867,"Ada's always been a copycat."],[4964,5145,"Always cheating."],[5175,5299,"I've seen potatoes"],[5299,5492,"with better problem-solving skills."],[5825,5929,"Cheater out!"],[5949,6673,"Cheater out!"],[6686,6820,"Just like before,"],[6873,7140,"these sheep believing Camilla's narrative..."],[7230,7470,"They helped the Selivises..."],[7470,7550,"Cheater out!"],[7570,7670,"Kill me."],[7674,8224,"Cheater out!"],[8224,8398,"Last chance to confess, Ada."],[8635,8858,"The only cheater here is you."],[9089,9139,"Fine then."],[9359,9452,"I'll finish it."]],"29":[[43,326,"Within six feet, I can read every thought."],[417,520,"So come on, Ada."],[590,700,"What are you thinking now?"],[1778,1991,"Liars like you with noses like trees."],[2222,2439,"Pinocchio clowns with a talent to tease."],[2535,2605,"I'll jab,"],[2605,2819,"I'll swing till your nose breaks loose."],[3299,3530,"Truth hits harder than any excuse."],[3787,3853,"What was that?"],[3903,3960,"Hm?"],[3967,4089,"I'm just standing here."],[4170,4326,"Camilla, what's wrong?"],[4367,4493,"Just expose her already."],[4590,4674,"I..."],[4761,4934,"Nothing, I just..."],[5248,5358,"Oh, go on..."],[5398,5500,"We're all ears."],[5652,5712,"Ada."],[5802,6009,"I'm giving you one last mercy."],[6082,6219,"For the sake of sisterhood."],[6489,6649,"I did not lie."],[6763,6946,"And you can't prove it if you didn't write it."],[6996,7080,"So what now?"],[7173,7347,"Are you going to confess the truth?"],[7454,7681,"I've given you every chance I could."],[7727,7824,"But you missed it."],[7844,8011,"Now I have to expose you myself."],[8488,8538,"So..."],[8598,8935,"to solve the equation, you need to first break it down..."],[8998,9476,"and then use factorization to..."],[9779,9843,"Got you."],[9903,10063,"Now that I've primed your brain,"],[10086,10283,"you'll unconsciously think of the rest."]],"30":[[90,170,"Factorization?"],[587,684,"Factorization."],[767,870,"Factorization."],[984,1114,"Factorization."],[1264,1404,"Factorization."],[1514,1618,"Factorization."],[1931,2078,"Camilla is a copycat."],[2852,3056,"So tell me, Copy Cami,"],[3079,3276,"how long will you last?"],[3303,3367,"Ow!"],[3646,3883,"Oh, Cami, why the scream?"],[3910,4084,"Aren't you going to show us the next steps?"],[4210,4409,"No way you can keep thinking that shit."],[4781,5075,"Brainless brutes who aged never grew."],[5128,5368,"You might as well be puppets, you fools."],[5702,5783,"What the hell?"],[5845,6092,"How is she thinking of that stuff during a competition?"],[6312,6363,"Did she..."],[6446,6633,"figure out I can read minds?"],[6913,7219,"Selfish hypocrites in divine garments."],[7330,7627,"You don't deserve to be called parents."],[7727,7984,"Loyal to lies, blind to the truth."],[8007,8150,"You are both idiots."],[8575,8709,"Has she noticed something?"],[8782,8898,"No, no way."],[8985,9089,"It's impossible."],[10043,10133,"Miss Selivis."],[10230,10313,"Don't waste time."],[10347,10400,"Please..."],[10470,10660,"finish the remaining calculations."],[10677,10750,"Now."],[11067,11301,"Maybe Camilla's still hoping Ada will confess."],[11468,11737,"Just admit you cheated, you wretched girl."],[12015,12425,"Even now, they still refuse to believe me."],[12729,12842,"Cat got your tongue?"],[12882,13078,"Are you finally ready to admit that"],[13078,13199,"you're the plagiarist?"]],"31":[[60,196,"All those years,"],[213,617,"you stole from me, my identity, my family,"],[767,1041,"and even all of my greatest achievements."],[1177,1404,"I have won several competitions"],[1448,1825,"and you dare accuse me of plagiarism?"],[1955,2055,"I never did that."],[2252,2382,"Well, then enlighten us"],[2425,2562,"with the next steps."],[2639,2722,"Genius."],[3056,3196,"Camilla, what are you waiting for?"],[3206,3269,"Just say it."],[3286,3373,"I get it now."],[3440,3570,"How kind Camilla is."],[3636,3843,"She knows that if she finishes this proof,"],[3867,4040,"Ada's academic career will be dead."],[4134,4234,"She's trying to protect her."],[4277,4481,"Ada, you're despicable."],[4561,4788,"Camilla's been nothing but kind to you, yet you-"],[4801,4982,"You dare corner her like this?"],[5011,5195,"You're digging your own grave."],[5328,5432,"Brainwashed."],[5455,5522,"All of you."],[5802,5969,"If I'm the plagiarist, Camilla,"],[6026,6106,"then prove it."],[6139,6299,"Show us the damn steps."],[6596,6690,"Miss Selivis."],[6753,6883,"We need a clear answer."],[6953,7094,"Is this solution yours?"],[7187,7330,"Sure, it is mine."],[7537,7614,"Then show us."],[8014,8141,"Well, if you can't speak it,"],[8141,8294,"then show us the draft from home."],[8334,8411,"That'll be fine."],[8758,8875,"Camilla's stalling."],[9005,9229,"What if we've been wrong this whole time?"]],"32":[[106,236,"Camilla's being too soft."],[276,487,"She should've never gone easy on someone like Ada."],[734,1007,"Camilla, you said you had proof."],[1037,1227,"Well, where is it?"],[1728,1801,"Yeah, go on."],[1855,1998,"Come on, speak up."],[2574,2657,"I...."],[2862,2942,"It's simple."],[2952,3069,"If Camilla can prove it,"],[3069,3315,"I'll call myself a cheat and never compete again."],[3423,3536,"That brat cornered you."],[3653,3753,"Stop protecting her."],[3807,3866,"Speak."],[3917,3970,"Do it!"],[4027,4200,"Come on. Prove it."],[5570,5729,"-Camilla. -Camilla."],[6042,6166,"Attention, everyone."],[6242,6449,"Due to Camilla's condition,"],[6493,6627,"the competition will be postponed."],[6646,6830,"Boooo!"]],"33":[[924,1031,"Camilla, Camilla!"],[1344,1448,"Attention, everyone."],[1541,1735,"Due to Camilla's condition,"],[1765,1895,"the competition will be postponed."],[1985,2179,"Well, since Camilla failed to explain,"],[2355,2485,"doesn't that prove I win?"],[2736,2880,"She just passed out."],[2889,3030,"And this is what you care about,"],[3030,3166,"the damn competition."],[3239,3428,"You are absolutely heartless."],[3593,3727,"Why are you so ruthless?"],[3727,3900,"Does her life mean nothing to you?"],[4177,4380,"I win and I'm ruthless, huh?"],[4484,4567,"Be honest."],[4587,4865,"If I were collapsing, you'd be throwing Camilla a party."],[4938,4989,"You!"],[5515,5757,"Look, I can just finish the Set B"],[5757,5879,"and then I can prove myself."],[5995,6052,"Enough."],[6439,6559,"This ends now."],[6796,6890,"But please, sir."],[7507,7744,"The competition will resume in seven days."],[7804,8121,"In which time, I'm sure the truth will surface."],[8234,8318,"This isn't over."]],"34":[[273,343,"Professor Hedro!"],[410,460,"Oh."],[460,527,"Excuse me."],[570,630,"Miss Ada."],[704,1000,"If I want to rewrite my fate from the past life,"],[1077,1211,"he might just be the key."],[1301,1378,"Something wrong?"],[1458,1518,"Professor,"],[1558,1820,"I heard you're assembling a research team"],[1820,1954,"to work with NAA,"],[1958,2187,"and I'd like to recommend myself."],[2230,2470,"Well, it's a bold request"],[2470,2585,"coming from someone who's"],[2632,2816,"under suspicions of plagiarism."],[2982,3313,"My team is comprised of flawless geniuses."],[3373,3476,"And why would we want to go and"],[3520,3778,"risk tarnishing our reputation for..."],[3863,3948,"uncertainty?"],[4010,4267,"Well, bringing me on is only upside, no risk."],[4364,4641,"Besides, in seven days, your greatest offer"],[4664,4834,"might not tempt me."],[4968,5021,"Really?"],[5221,5453,"You're that confident that you can defeat Camilla."],[5498,5618,"Not to defeat."],[5635,5763,"Camilla is always a loser."],[5869,5975,"But if you bring me on,"],[5975,6156,"I'll take us all the way to the top."],[6189,6267,"No question."],[6309,6384,"Very well."],[6649,6743,"Prove your innocence,"],[6826,7007,"take first place in seven days,"],[7063,7142,"and then we'll talk."],[7187,7270,"No problem."],[7300,7431,"Just keep your podium ready."]],"35":[[877,927,"Sansa."],[1124,1217,"Draw up an offer."],[1297,1598,"Notify the team that we'll be adding a new member."],[1658,1705,"Okay."],[1755,1846,"Will it be for Camilla?"],[1925,1983,"No."],[2108,2194,"No, it's for Ada."],[2385,2441,"What?"],[2505,2639,"But she's still under suspicion."],[2899,3187,"My gut tells me that she is no plagiarist."],[3303,3677,"In fact, she very well might be..."],[3783,3889,"a genius."],[4047,4105,"Really?"],[4148,4210,"Her?"],[4681,4729,"Oh, there she is."],[4751,4808,"Ada! Ada!"],[4874,5079,"Camilla has accused you of plagiarizing."],[5121,5337,"How does it feel to be a serial copycat?"],[5398,5590,"If you're so sure I plagiarized,"],[5590,5716,"show me the evidence."],[5742,5912,"Or your slander earns you a lawsuit."],[5929,5990,"Each of you."],[5995,6189,"Camilla herself exposed you."],[6216,6404,"First, I never plagiarized."],[6426,6674,"And second, Camilla didn't even complete the steps."],[6723,6806,"On the contrary,"],[6806,6945,"she made false accusations"],[6945,7146,"that seriously damaged my reputation."],[7200,7424,"And if you continue to echo those claims,"],[7454,7650,"expect a cease and desist."],[7697,7869,"One by one."]],"36":[[23,223,"Well, sources from your class say that"],[223,309,"this isn't the first time"],[309,443,"that you've been caught plagiarizing,"],[443,680,"that you've actually copied Camilla's answers before"],[680,800,"with identical results."],[850,937,"Do you still deny that?"],[955,1040,"The academic world"],[1040,1207,"takes intellectual property seriously."],[1251,1414,"Aren't you afraid that Camilla might too?"],[1624,1735,"Let's give it seven days."],[1775,2082,"If Camilla beats me fairly, I'll admit to plagiarism live."],[2218,2504,"So what if you can solve a few problems, Ada?"],[2572,2737,"You will never be the golden girl."],[2886,3206,"Even if I fail, they will still choose to believe me."],[3229,3430,"So consider this my challenge."],[3453,3611,"Prove I stole your work, Camilla."],[3640,3771,"Or admit that you're the fraud."],[4824,5017,"Professor, it's chaos."],[5075,5141,"What's wrong?"],[5251,5321,"It's Ada."],[5382,5604,"She's got ten hashtags and they're all top trending."],[5675,5738,"Really?"],[5829,5894,"That fast?"],[5902,6064,"She's clearing her name already?"],[6169,6309,"I knew I wasn't wrong about her."],[6309,6559,"No, the internet is roasting her."],[6599,6726,"They're calling her a shameless cheat"],[6726,6872,"for making that public challenge."],[6893,6973,"They're cooking her!"],[6996,7053,"What?"]],"37":[[754,944,"Yeah, so she's toxic now."],[990,1090,"If you put her on the team,"],[1090,1197,"she's just gonna drag us down."],[1221,1384,"So you can't possibly still want her."],[1444,1647,"No apologies, no excuses."],[1675,1887,"So we cannot have her on our team."],[1924,2001,"No, no, no, no."],[2001,2313,"She's orchestrating this."],[2495,2731,"She truly is a genius."],[2731,2882,"Wait, what?"],[2882,3118,"She's using the backlash as fuel."],[3209,3387,"Let the entire public watch."],[3483,3622,"And when she wins,"],[3710,3963,"all the lies will fall apart."],[4064,4137,"And she..."],[4384,4481,"will rise..."],[4567,4691,"like a star."],[5055,5348,"Yeah, but what if she loses?"],[5348,5415,"She won't."],[6089,6292,"How can I beat her in the following competition"],[6322,6514,"if she still thinks like a lunatic?"],[6696,6766,"Miss Selivis."],[6793,6889,"Miss Selivis."],[6920,7106,"Ada just said you fabricated the evidence."],[7123,7177,"Where's your proof?"],[7330,7457,"Bullshit proof."],[7464,7639,"Can't even get to her methods."],[7670,7741,"Miss Selivis,"],[7741,7937,"are you confident about the rematch in seven days?"],[7947,8041,"Or was she right?"],[8064,8206,"You're the one copying her."]],"38":[[176,280,"My daughter needs rest."],[303,520,"Please, everyone leave the room."],[583,664,"-Guys. -Let go!"],[664,737,"Do you have any final comments?"],[737,834,"-Come on. -It's stupid!"],[937,1073,"The fans deserve to know!"],[1094,1131,"Shut up!"],[1164,1231,"Shut up!"],[1355,1555,"Oh, Daddy, Mommy!"],[1565,1689,"Oh, poor girl."],[1689,1798,"Mommy's here."],[2155,2284,"Those reporters are so stupid."],[2312,2491,"Everyone knows it was Ada who copied you."],[2515,2617,"How can they say that?"],[2642,2712,"Damn Ada!"],[2789,2949,"It's her fault that Camilla's like this."],[3126,3533,"Dad, I've been preparing so much for this competition."],[3626,3910,"I just didn't know my own sister would do this to me."],[4230,4606,"I feel so weak and I feel so bad that I've fainted."],[4838,4998,"I'm sorry, I'm sorry, I just got emotional."],[5108,5297,"Camilla, what's the rest of the solution?"],[5485,5567,"Enough!"],[5648,5805,"Can't you see how pale she looks?"],[5855,5995,"Why do you have to bring that up now?"],[6116,6346,"I just thought if she released the full solution,"],[6353,6556,"then everyone would know that Camilla really solved it."],[6659,6750,"That makes sense."],[6826,7017,"Camilla's been under a lot of scrutiny right now."],[7103,7412,"If we shared the solution, it might calm the public down."],[7554,7630,"Camilla, honey,"],[7697,7846,"everyone's on your side."],[7984,8244,"Maybe you could just tell us the solution"],[8244,8425,"and we'll handle the rest."],[8708,8921,"Ada's thoughts are totally a mess."],[8968,9142,"I can read anything clearly."],[9205,9456,"I have no clue how the rest of that solution goes."],[9572,9630,"Camilla?"]],"39":[[113,260,"The rest of the solution..."],[580,653,"is..."],[1161,1211,"Ah!"],[1211,1357,"Oh, sweetheart!"],[1357,1508,"Ow, my head, my head, my head."],[1508,1755,"Ow, my head, my head hurts."],[1771,1940,"-Sweetheart, what is it? -Get the doctor."],[1971,2076,"-Doctor! Get doctor. -Ow, my head."],[2098,2173,"My head."],[2178,2318,"Doctor, doctor."],[2806,3010,"Doctor, what's the matter with my daughter?"],[3076,3236,"Oh, physically, she appears to be fine"],[3236,3363,"and all of her vitals are normal."],[3436,3619,"Then why does she keep getting headaches?"],[3687,3803,"Yes, doctor."],[3860,4167,"Why does my head hurt every time I try to do math?"],[4240,4382,"It could be stress induced."],[4382,4645,"It could be neurological trauma"],[4645,4771,"from an emotional shock."],[4818,4956,"Further examinations require"],[4956,5145,"for a precise diagnosis."],[5190,5241,"Excuse me."],[5515,5569,"It's Ada."],[5605,5727,"If she had performed well,"],[5752,5845,"Camilla wouldn't have fainted."],[5900,6005,"Now Camilla gets the headaches"],[6005,6088,"just from thinking."],[6186,6295,"Camilla's so gifted,"],[6306,6484,"that elite competition was her dream."],[6536,6753,"Now it's all destroyed by that bitch."],[6856,7278,"Boys, look, even if I can't do math ever again,"],[7300,7691,"as long as you're here with me, I'm happy."],[7887,8140,"This is all Ada's fault."],[8188,8314,"That little wretched girl."],[8405,8547,"Where is she, anyway?"],[8558,8766,"Get her here right now to apologize."],[8852,9098,"As long as I can get within six feet of Ada,"],[9109,9212,"I can try again."],[9265,9488,"I will fry her brain to get the solution."],[9522,9622,"And I'll make it mine."]],"40":[[113,370,"Mom, Dad, guys,"],[513,623,"don't blame Ada."],[760,939,"Since I'm all useless now,"],[947,1212,"maybe she can win the competition on my behalf."],[1360,1485,"Camilla, we've seen"],[1485,1624,"how much you've sacrificed for math."],[1758,1968,"Your time and energy, everything."],[2085,2268,"You are the most talented one."],[2312,2539,"I'm not going to let Ada steal your destiny."],[2552,2773,"But the competition resumes in seven days."],[2786,2976,"In Cami's condition, what should she do?"],[3033,3328,"Even if she competes, the pain will block her thoughts."],[3360,3546,"Camilla, I'll get you that title."],[3610,3796,"I'll make that bitch return what's yours."],[3830,4041,"Kevin, let her go."],[4524,4591,"Daddy's here."],[4624,4705,"Daddy's here."],[5018,5302,"Ada, get your ass to the hospital, now!"],[5420,5493,"Who-"],[5575,5730,"Who do you think you are?"],[5759,5932,"I told you, I am just Ada."],[5932,6146,"I have cut ties with the Selivis family."]],"41":[[16,190,"I told you, I am just Ada."],[190,413,"I have cut ties with the Selivis family."],[467,597,"She's suffering because of you."],[620,709,"Where's your remorse?"],[874,990,"I made her suffer?"],[1017,1159,"What about my years in hell?"],[1204,1257,"Cut the crap."],[1307,1374,"Get here now,"],[1388,1552,"or I will make sure the entire Selivis family"],[1552,1628,"makes your life hell."],[1651,1798,"My own brother."],[1821,2052,"Truth screams in his face."],[2098,2369,"And still, he blindly defends her."],[2439,2539,"Ugh, fine."],[2545,2650,"Wait, I'll be there."],[3353,3486,"Let's see what your game is."],[3623,3783,"Cami, rest assured."],[3823,4014,"Kevin's bringing Ada to apologize."],[4084,4233,"She put you through hell."],[4287,4487,"An apology is the least she can do."],[5525,5565,"Me?"],[5592,5859,"I think she's the one who owes me an apology."],[5909,6147,"Ada, apologize to Camilla. Now!"],[6179,6368,"Me? Apologize to a copycat?"],[6423,6490,"It's okay."],[6526,6750,"Oh, Mom, I'm fine."],[6813,7154,"Doctor said it's just some shock-induced nerve pain."],[7207,7407,"So every time I try to think of"],[7480,7667,"hard math solutions,"],[7704,7827,"I get a headache."],[7951,8128,"But it's nothing serious, Ada."],[8194,8296,"Oh gosh."],[8318,8598,"How will our precious genius claim my trophy?"],[8635,8770,"Are you saying you're a waste?"],[8898,9046,"You've ruined Camilla's future."],[9125,9222,"And you dare mock her?"],[9289,9409,"What kind of viper are you?"],[9719,10052,"A-p-o-l-o-g-i-z-e."],[10070,10206,"Apologize!"]],"42":[[36,344,"Mom, you know how my sister is."],[420,617,"If she doesn't want to apologize,"],[617,794,"just let her go."],[844,927,"So that's your game?"],[1024,1216,"Trying to play the victim to get sympathy?"],[1281,1515,"I thought you were just using it as an excuse"],[1515,1695,"to get out of the math competition."],[1755,2080,"But, you know, just instead, you're just trying to"],[2080,2408,"get people to not realize you're actually a dumbass."],[2650,2726,"It's okay."],[3039,3270,"Cami, after everything she's done to you,"],[3276,3423,"you're still defending her."],[3893,3980,"Dear sis..."],[4120,4287,"we're all family after all."],[4364,4553,"So no matter who wins in the competition,"],[4641,4904,"it will bring honor to all of us."],[5151,5272,"Are you kidding me?"],[5328,5512,"You can't even solve the problem"],[5512,5699,"and you frame me for plagiarism?"],[5789,6062,"And here you are, just trying to pretend to be a victim."],[6102,6178,"Bullshit!"],[6189,6309,"How much more do you want to hurt her?"],[6379,6521,"I'm the one who's being hurt!"]],"43":[[23,379,"People like you with no shame, no morals,"],[379,501,"deserve worse!"],[590,637,"It's okay."],[727,910,"You don't have to fight her for me."],[1014,1264,"I can't just keep watching her bully you like this."],[1568,1612,"Ada."],[2182,2369,"I am resigning from the competition."],[2509,2821,"And I'm not even going to blame you for copying me."],[2916,3335,"All I'm asking for is you to apologize to Kevin."],[3390,3426,"That's it."],[3476,3800,"And we can put all of this behind us once and for all."],[4501,4562,"Okay."],[4724,4804,"I'm sorry."],[4871,5160,"I'm sorry for not letting her steal my answers."],[5171,5279,"And I'm sorry for not letting her"],[5279,5466,"cheat her way to get first place."],[5482,5675,"I'm sorry for disappointing all of you!"],[5709,5818,"You bitch!"],[6700,6830,"I will never"],[6903,7097,"let any of you hurt me ever again."],[7253,7307,"Ada!"],[7500,7816,"Ada, we've poured years into Camilla's education."],[7874,8002,"You grew up in an orphanage"],[8002,8135,"with hardly any schooling."],[8234,8467,"You think genius just happens overnight?"],[8595,8762,"You really think that you can solve"],[8762,9015,"international-level competition problems?"],[9015,9062,"Right."],[9135,9250,"Camilla couldn't solve it."],[9279,9420,"There's no way that you could."],[9662,9872,"Oh, so that's why you trust her so much?"],[9959,10065,"Well, how about this?"],[10156,10300,"Give Camilla the most complex"],[10300,10438,"mathematical equation,"],[10438,10633,"and if she can solve it and prove that,"],[10677,10945,"I'll publicly admit to plagiarism."]],"44":[[50,320,"I'll publicly admit to plagiarism."],[370,463,"Camilla, you can do it."],[487,560,"Pick any problem."],[560,684,"Prove her wrong once and for all."],[830,1057,"Ah! It hurts, it hurts so much!"],[1077,1122,"Camilla!"],[1171,1235,"Are you okay?"],[1361,1488,"Camilla, drop the act."],[1568,1743,"Ada, have you no shame?"],[1771,1980,"You know thinking math gives Camilla headaches."],[1998,2148,"Yet you come up with this cruel scheme"],[2148,2380,"to try to get her to force her to prove herself."],[2425,2582,"A pack of fools."],[2629,2856,"Can't even see through this pathetic act?"],[2926,3144,"How could I expect you to believe me"],[3144,3282,"in my previous life?"],[3353,3497,"You're the ones who are demanding"],[3497,3616,"proof of plagiarism,"],[3636,3797,"but she's too guilty to try"],[3797,4087,"and instead is fake illnesses instead."],[4637,4808,"A filthy liar."],[4844,4991,"Always slandering Camilla."],[5035,5167,"I should have left you rotting"],[5167,5309,"where you came from."],[5658,5865,"Well, maybe you should never have had me."],[6106,6269,"Camilla is your real family."],[6332,6604,"Did you ever see me as your real daughter?"],[6810,6868,"I..."],[6940,6985,"It's..."],[7027,7223,"It's only because you keep targeting Camilla."],[7320,7513,"I only hit you because I was angry."],[7670,7828,"Camilla is your real family."],[7914,7981,"That's all."],[8355,8398,"Mom."]],"45":[[260,347,"Mom, don't blame yourself."],[400,620,"All she does is steal from Camilla and frame her."],[663,835,"Someone like that deserves to be hit."],[1004,1272,"She's just so eager to earn your approval."],[1371,1502,"She got over zealous."],[1691,1735,"Ada?"],[1948,2324,"Look, I might not be able to compete anymore,"],[2452,2596,"but I can help tutor you."],[2766,2962,"That way, you'll get a better shot at winning."],[3096,3194,"Within six feet."],[3266,3476,"As long as she thinks about that problem,"],[3493,3757,"I'll make it mine and crush her completely."],[3843,4160,"Making sure this Selivis family discards her forever."],[4270,4470,"Still trying to read my mind?"],[4534,4631,"Keep dreaming."],[4681,4834,"After all Camilla's suffered because of you,"],[4868,4981,"she's still trying to help you."],[5045,5105,"What do you do?"],[5161,5318,"Steal from her, frame her,"],[5348,5547,"and now you won't even admit your guilt."],[5588,5682,"Have you no shame at all?"],[5749,5862,"She wants to tutor me?"],[5892,6027,"Please, she's about to faint."]],"46":[[83,273,"Ada, I'm just trying to help you."],[323,747,"This idiot actually thinks she can solve those problems?"],[747,926,"Ugh, what a joke."],[927,1145,"Who said I can't solve problems?"],[1234,1411,"Oh, are your brain problems gone?"],[1431,1555,"No more headaches?"],[1571,1726,"Camilla, are you okay?"],[1798,1834,"Perfect."],[1875,1993,"Now Camilla can still compete."],[2092,2178,"Camilla's headaches are gone."],[2252,2423,"First place is in the bag."],[2472,2655,"Yeah, yeah."],[2669,2752,"I should be fine."],[2862,2938,"Damn, Ada."],[2989,3160,"How dare she insult me in her thoughts."],[3239,3405,"Well, now that your brain is back,"],[3410,3623,"and you mentioned you did want to tutor me,"],[3656,3756,"perfect timing."],[3820,4007,"I brought an unsolved set,"],[4007,4210,"so let's see if you can solve one."],[4487,4560,"Right here."],[4617,4661,"Shit!"],[4721,4844,"Even she couldn't solve this."],[4881,4945,"How would I?"],[6072,6122,"What?"],[6142,6222,"You can't do it?"],[6239,6375,"Aren't you a genius?"]],"47":[[3,229,"If I mess up in front of the Selivis family,"],[266,367,"I am done."],[1087,1327,"Enough Ada, these problems are not easy."],[1327,1478,"Of course she needs time to think."],[1524,1760,"So now we're making excuses up about time?"],[1791,2019,"You're making excuses up in order to protect her?"],[2195,2412,"Ada, Camilla just started recovering"],[2422,2526,"and you're already pushing her."],[2555,2692,"What the hell is wrong with you?"],[2742,2809,"Exactly."],[2886,3092,"Camilla needs rest, not stress."],[3113,3369,"If she relapses because of you, you'll pay."],[3426,3480,"Guys."],[3540,3847,"If my sister is asking me to do it, then I have to do it."],[5075,5296,"How far will you push her?"],[5572,5745,"Mom, Dad, guys."],[5819,6011,"Mom, she just wants to win..."],[6049,6126,"your love"],[6139,6282,"and win in the competition"],[6282,6466,"and be called a genius."],[6576,6797,"And honestly, I totally get her pain."],[6843,6909,"Oh."],[6986,7222,"What an exquisite performance."],[7233,7456,"Tell me, when is your Oscar campaign starting?"],[7530,7705,"Ada, have you lost your mind?"],[7787,7994,"Having you as my sister is a disgrace."],[8041,8271,"You think stolen answers make you a genius?"],[8318,8515,"Talent isn't copycat."]],"48":[[3,303,"I'll use the full reach of the Selivis family to expose you."],[413,593,"You think you could cheat your way to success?"],[704,847,"Not in this academic world."],[854,954,"Not anymore."],[1031,1274,"My poor academic father."],[1348,1533,"All those degrees."],[1584,1842,"Yet you'd rather trust a fraud"],[1842,1982,"more than your own daughter."],[2155,2298,"So what if you're smart?"],[2385,2506,"As long as I'm here,"],[2545,2699,"they will never believe you."],[2782,2856,"Last warning."],[2876,2986,"Apologize to Camilla."],[3363,3456,"You hit me!"],[3513,3639,"Damn right I did."],[3730,3825,"I'm your brother!"],[3973,4140,"You think you're my brother?"],[4167,4421,"Have you ever showed me any ounce of kindness?"],[4431,4451,"What?"],[4451,4561,"Do you want me to grovel?"],[4591,4631,"You-"],[4637,4681,"You!"],[4741,4874,"Only care about Camilla."],[5001,5298,"Your real daughter means nothing to you."],[5311,5458,"Yes, yes."],[5472,5674,"Keep digging your grave, you fool."],[5712,5949,"Every word drags your family farther from you"],[5979,6123,"and closer to me."]],"49":[[60,126,"Look at you."],[303,468,"Do you even respect your family anymore?"],[730,780,"Ow!"],[2195,2278,"You've gone mad!"],[2369,2439,"I have!"],[2439,2582,"You all led me to it!"],[2600,2704,"You- You-"],[2719,2807,"You suck!"],[2920,3106,"I regret ever bringing you back."],[3106,3246,"You've ruined this family!"],[3380,3514,"If I could turn back time,"],[3536,3690,"I'd smother you at birth!"],[3757,3800,"Fine."],[3863,4014,"Your words, not mine."],[4014,4218,"I don't want to be a part of this family either."],[4267,4320,"Ada!"],[4414,4537,"What new scheme is this?"],[4591,4781,"Ada, just apologize."],[4844,5058,"It's not that big of a deal to bow your head"],[5058,5168,"to your own family."],[5238,5368,"And once you do that,"],[5435,5535,"I'll plead for you."],[5652,5792,"You're the poison in this family."],[5792,5966,"Everything went to hell because of you."],[6066,6439,"Mom, Dad, you know, I can't have this anymore."],[6479,6676,"I'll just leave for Ada's sake."],[6676,6750,"No!"],[6773,6853,"Don't bother."],[7474,7538,"Here."],[7624,7781,"Sign these severance papers and..."],[7854,7944,"as of today..."],[8278,8416,"We will be strangers."]],"50":[[30,146,"Do you realize what you're doing?"],[193,344,"Do you want the entire Selivis family"],[344,513,"to be humiliated at all city?"],[610,757,"Fine. Isn't this what you wanted?"],[800,1041,"Once I'm gone, you'll have your little precious Camilla."],[1041,1217,"I'll be gone and no one will even notice."],[1348,1611,"Does anyone even know you have another daughter?"],[1728,2012,"Ada, stop saying such things."],[2098,2252,"You're a real Selivis."],[2442,2495,"Fine."],[2529,2705,"If you hate me so much,"],[2762,2823,"I'll leave."],[2896,2974,"No."],[3033,3112,"Go ahead."],[3229,3442,"Oh, was that just another performance?"],[3516,3585,"No."],[3683,3903,"I just can't bear to part with them."],[4467,4581,"You're going nowhere, Camilla."],[4631,4694,"I won't allow it."],[4724,4826,"This is all a ploy."],[4834,5105,"She's manipulating Camilla's guilt to force her out."],[5211,5328,"You are twisted, Ada."],[5635,5727,"Want me to sign this?"],[5835,6004,"I'm going to sever ties gladly."],[6166,6272,"Somebody give me a pen."],[9062,9167,"As of today,"],[9212,9604,"Ada is no longer part of the Selivis family."]],"51":[[16,105,"As of today,"],[166,551,"Ada is no longer part of the Selivis family."],[874,983,"Ada, wait!"],[983,1153,"No, let her go, good riddance."],[1241,1437,"Kevin, she's used to all the luxury"],[1437,1574,"provided by Selivis family."],[1604,1738,"How's she gonna survive out there?"],[1815,1891,"Relax. Camilla."],[1941,2115,"Ada's been living off our wealth for years."],[2158,2327,"Out there, she's nothing."],[2382,2515,"She brought this on herself."],[2535,2609,"Let her go."],[2696,2800,"Only then will she understand"],[2800,2916,"how much we spoiled her."],[2952,3233,"Sweetie, she is not worthy of your concern."],[3299,3733,"When she begs to return, that's when she'll apologize."],[3870,3944,"John,"],[4032,4160,"cancel all the elite tutors"],[4160,4257,"that we arranged for Ada."],[4337,4612,"And revoke her access to academic databases"],[4612,4747,"from our connections."],[4754,4927,"Well, the Selivis family never hired"],[4927,5065,"any tutors for Miss Ada,"],[5088,5440,"nor did we grant her any academic access."],[5482,5735,"What? That can't be."],[5885,6026,"In fact, over the years,"],[6026,6252,"you've secured 18 world class tutors"],[6252,6563,"and over 100 institutional accesses for Miss Camilla."],[6589,6971,"As for Miss Ada, there are no records."],[6983,7037,"How..."],[7137,7273,"How is it possible we didn't give her"],[7273,7390,"anything over the years?"]],"52":[[166,267,"Dad, relax."],[303,727,"She had everything, money, lifestyle, the education."],[850,895,"Exactly."],[950,1163,"We've got million dollar allowances for each kid."],[1214,1368,"Normal families don't see that much money"],[1368,1448,"in a decade."],[1480,1590,"If she wants out,"],[1609,1808,"fine, but we want our investment back."],[1838,2177,"Actually, we never gave her anything."],[2245,2435,"We brought her back junior year."],[2442,2830,"You're really saying we didn't give her anything?"],[2916,3018,"That's impossible."],[3083,3196,"How'd she pay for college?"],[3273,3443,"Even if we didn't like her, she'd still Selivis."],[3563,3914,"Multiple jobs, flyers, dishwashing, waitressing,"],[3927,4389,"sometimes three shifts a day that I know of."],[4454,4573,"That's why she was never around."],[4621,4748,"She would always come home after midnight,"],[4748,4831,"looking like hell."],[4831,4999,"I thought she was just embarrassing us."],[5045,5191,"Why would she work tables?"],[5235,5382,"She's got food in the fridge."],[5405,5502,"She doesn't have to pay rent."],[5508,5679,"And she's got a room upstairs."],[5802,6158,"But sir, upstairs is Miss Camilla's domain."],[6289,6512,"But there are plenty of rooms upstairs."],[6526,6623,"Camilla can't use them all."],[6830,7285,"She has the study, music room and dance studio."],[7390,7767,"Plus, tea room, flower room, game room and arcade."],[7834,8024,"All for your service."],[8201,8308,"Then where did she sleep?"]],"53":[[2986,3176,"She lived here?"],[3443,3583,"I can't even breathe in here."],[3590,3733,"How did she survive this?"],[3797,3945,"No AC, no heat."],[3997,4140,"It's been an oven in the summer."],[4474,4615,"What was all this?"],[4671,5009,"Miss Ada used those as curtains."],[5158,5351,"Newspapers for curtains?"],[5398,5530,"We're worth millions."],[5568,5826,"And our own daughter uses newspapers for curtains?"],[5862,6059,"She lived like this and we didn't even know?"],[6249,6444,"We have dozens of rooms."],[6529,6717,"Who put her in this hellhole?"],[6796,7021,"Mom, can we make it into a dance studio?"],[7063,7133,"Oh."],[7340,7528,"Mom, can I have a room too?"],[7570,7775,"Why are you always competing with Camilla?"],[7817,7921,"Yours is fine."],[7964,8162,"Better than that damn orphanage."],[8194,8370,"Act your age, would you?"],[8922,9051,"Just one dance studio?"],[9069,9125,"OK."],[9289,9368,"I did."],[9466,9601,"I made her stay here."]],"54":[[210,431,"I thought she was just jealous of Camilla."],[523,718,"That's why I didn't let her move."],[777,1119,"Actually, Miss Ada didn't live here long."],[1171,1506,"She moved out and rented her own domicile."],[1614,1748,"Why didn't she just ask me?"],[1791,1930,"We have dozens of properties."],[1998,2151,"She could have lived wherever she wanted."],[2308,2498,"Oh God, I remember."],[2852,2939,"What happened, Dad?"],[3293,3506,"Miss Ada had a cat."],[3510,3759,"When it supposedly scratched Miss Camilla,"],[3759,3837,"the cat was..."],[3843,4097,"I heard it... scratch Camilla, so I..."],[4214,4347,"She begged me to spare that cat."],[4501,4676,"I thought she loved it more than her own family."],[4734,5120,"Sir, that cat was Miss Ada's family."],[5161,5448,"She had it since she was a child."],[5632,5728,"What happened to the cat?"],[5829,6264,"Suffice to say, it didn't make it."],[6272,6359,"Oh God!"],[7153,7253,"All these years,"],[7404,7523,"we failed her."],[7770,7974,"No wonder she cut us off so decisively."],[8141,8198,"Don't worry."],[8264,8463,"The competition restarts in a few days."],[8525,8782,"Once she apologizes, we'll bring her home."],[8815,8992,"Right. We'll make it all up to her."]],"55":[[387,629,"Competition's in less than two hours."],[744,928,"Wouldn't your time be better spent prepping"],[928,1097,"instead of bothering me?"],[1121,1328,"Camilla? She's no threat."],[1361,1503,"I could beat her in my sleep."],[1678,1814,"Well, that's a bold statement."],[1938,2080,"I hope you can back it up."],[2272,2607,"Well, actually, I have to show you something first."],[2607,2674,"Mm-hmm."],[3533,3776,"This has been stumping NAA for years."],[3803,3911,"You solved them all?"],[3990,4096,"Every single one."],[4194,4335,"Are you still worried about today?"],[4567,4707,"Well, if this is accurate,"],[4751,4904,"this competition shouldn't even be"],[4904,5077,"a proper warmup for you."],[5368,5430,"Um,"],[5799,5979,"this information could..."],[6092,6337,"could shake up the entire field."],[6463,6576,"Why share it now?"],[6633,6707,"What's the catch?"],[6776,6951,"I knew you'd see right through me."],[7013,7363,"I just have one tiny favor."],[8101,8448,"After today, the name Camilla will be erased"],[8448,8622,"from the academic world."],[9015,9365,"Ladies and gentlemen, our championship continues."],[9396,9697,"Please welcome Ada to the stage."],[10263,10392,"See our girl?"],[10493,10798,"I can't believe I left her stuck up in the attic"],[10798,10980,"all those years without a dime."],[11110,11311,"We weren't perfect, but..."],[11442,11564,"She didn't compromise either."],[11641,11799,"This is it."],[11802,12040,"When here clear my name,"],[12049,12238,"the world will be my oyster."]],"56":[[23,134,"Seriously?"],[150,355,"The plagiarism case gets to compete?"],[373,447,"Shameless."],[457,563,"She doesn't belong here."],[617,716,"Throw her out!"],[1104,1161,"Do you hear that?"],[1247,1334,"They're out of line."],[1381,1552,"She had to put up with this the whole time?"],[1938,1971,"Wait!"],[3416,3553,"I thought you got cold feet."],[3653,3716,"Oh."],[3817,3970,"Math is my everything."],[4067,4454,"Besides, I've got my entire family behind me."],[4507,4833,"They've convinced me to fight to my full potential."],[5015,5111,"Full potential?"],[5178,5423,"You struggled to get to the pre-liminaries."],[5488,5538,"Oh."],[5605,5795,"Maybe I was just being polite."],[5862,6000,"Since you've distanced yourself."],[6052,6134,"Oh really?"],[6146,6237,"Then try me."],[6269,6331,"Oh."],[6353,6443,"See for yourself."],[6459,6549,"But just a heads-up."],[6616,6790,"Another plagiarism controversy"],[6790,6917,"would be awkward."],[6960,7156,"I never plagiarized."],[7287,7350,"Oh sure."],[7414,7698,"Well then, observe my methodology first."]],"57":[[1344,1404,"Done."],[1438,1548,"This is my solution"],[1548,1802,"to the optimal spacecraft trajectory."],[1885,1995,"Your turn, Sis."],[2265,2397,"Oh, that's impossible."],[2409,2562,"How did you steal my work?"],[2829,2939,"Here we go again."],[2966,3046,"The cheat's at it."],[3126,3268,"She's blaming Camilla again."],[3343,3410,"Seriously?"],[3760,3897,"Some people never learn."],[4020,4107,"We all saw it."],[4147,4252,"Camilla finished first."],[4297,4444,"Now Ada's crying foul."],[4644,4819,"God, this moron."],[4941,5187,"Why are we cursed like this?"],[5502,5747,"Whoa there, that's a serious accusation."],[5795,6001,"We haven't even seen each other today yet."],[6006,6202,"Ada, tell me they're wrong about you."],[6463,6691,"I didn't cheat, she stole my solution."],[6830,7019,"Game over, Ada."],[7537,7761,"I let bygones be bygones."],[7837,8127,"But stop doing this to me."],[8812,8986,"You all saw my work."],[9075,9181,"Have I cheated?"],[9259,9448,"Can you fake details like this?"]],"58":[[93,283,"Please, just clear my name."],[326,467,"That's all I ask."],[650,850,"Nobody can copy at that level of precision."],[980,1094,"Ada's lost it."],[1184,1358,"Fine, we screwed up before,"],[1358,1593,"but why drag Camilla down?"],[1598,1770,"Why keep targeting her?"],[1858,2105,"Ada, even I can't save you this time."],[2218,2415,"Looks like we got ourselves a winner."],[2682,2912,"No matter how hard you try, Ada,"],[2972,3283,"every award you chase will have my name on it."],[3356,3418,"Today,"],[3486,3606,"I'll crush you for good."],[3606,3713,"No, no."],[3807,3903,"Well, Ada,"],[3950,4133,"if you're stuck, just ask."],[4270,4384,"I don't mind sharing."],[4491,4641,"I don't need your charity."],[4661,4757,"I've got it."],[4888,4961,"Oh, really?"],[5035,5134,"Then prove it."],[5662,5715,"Camilla,"],[5765,5922,"this win is in the bag."],[6016,6201,"Let's plan your victory party."],[6332,6465,"Mom, that's so sweet."],[6546,6629,"But shouldn't we wait?"],[6659,6800,"The competition is not over."]],"59":[[280,496,"What, are we just supposed to wait around here all day?"],[587,702,"Look at this mess!"],[770,915,"She's not gonna pull off a miracle."],[937,1071,"It's a total waste of time."],[1114,1302,"Hey guys, check out Ada."],[2145,2319,"How is she solving this so fast?"],[2679,2946,"Wait, that looks exactly like Camilla's work."],[3289,3453,"Oh my sis, Ada,"],[3496,3727,"you're digging your own grave now."],[3783,4064,"Ada, you're literally stealing Camilla's solutions."],[4110,4199,"Shame on you!"],[4254,4404,"This cheater's gone too far."],[4404,4488,"Get her out!"],[4501,4654,"Cheater, get out!"]],"60":[[670,823,"These are my solutions."],[874,997,"What are you talking about?"],[1054,1202,"That's literally my work."],[1281,1517,"Oh, are you still playing the victim card?"],[1601,1698,"Are you crazy?"],[1748,1836,"Facts don't lie."],[1868,2010,"Everyone saw what happened."],[2208,2322,"You've crossed a line, Ada."],[2432,2527,"We're not blind."],[2589,2759,"Cheater, go to hell!"],[2999,3127,"Oh, you can see."],[3163,3419,"Squint real hard, these are my solutions."],[3573,3637,"She's right."],[3710,3835,"Ada's methodology is"],[3835,4100,"significantly different than Camilla's."],[5245,5462,"Hedro, you're the authority here."],[5548,5689,"Can you please tell us what's going on?"],[5752,5822,"Patience."],[6022,6293,"I've reviewed both solutions thoroughly."],[6399,6553,"The winner of this competition..."],[6890,6959,"is Ada."]],"61":[[50,314,"And the winner of this competition is"],[453,493,"Ada."],[744,893,"How is this possible?"],[954,1082,"She cheated."],[1658,1755,"Listen to me, everyone."],[1815,2010,"Last week's plagiarism scandal"],[2010,2174,"made global headlines."],[2222,2430,"So, we decided to conduct"],[2430,2620,"our own covert investigation."],[2699,2949,"And thanks to Ada's cooperation,"],[3016,3109,"we were in fact..."],[3176,3306,"able to uncover..."],[3370,3496,"the real perpetrator."],[3593,3770,"Professor, what happened?"],[3920,4213,"Yesterday, Ada gave me a flash drive"],[4213,4344,"containing her solutions."],[4424,4721,"She wanted me to drop it in front of Camilla's room,"],[4764,5045,"and make it look like she lost it by accident."],[5098,5198,"I don't believe it."],[5278,5478,"Camilla would never cheat."],[5662,5780,"We hoped you were right,"],[5785,6202,"but the steps were tweaked with two planted mistakes."],[6239,6684,"Camilla's answers matched Ada's decoy draft perfectly."],[6753,6906,"You set me up."],[7347,7587,"Mind reading can only get you so far."],[7620,7899,"Without the real skill, you'll always lose."],[7934,8198,"You! You knew everything."],[8595,8826,"Turns out Camilla's been the cheater this whole time."],[8885,9129,"We owe Ada a massive apology."],[9192,9337,"She's the real genius."],[9379,10734,"Cheater! Cheater! Cheater! Cheater!"],[11431,11731,"You earned every last drop."],[11835,12122,"Honey, I'm so sorry."],[12178,12350,"We shouldn't have doubted you."],[12415,12639,"Yeah, come home with us, sis."],[12682,12849,"We got a big comfy room."],[12912,13012,"We feel so bad."],[13103,13315,"If you're still angry, beat me with this."],[13957,14218,"Oh, you finally figured it out."],[14351,14527,"Sorry, it's too late."],[14660,14717,"Ada."],[14778,14997,"Your NAA shuttle has arrived."],[15225,15453,"Goodbye, Copy Camilla."]]}