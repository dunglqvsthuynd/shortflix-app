{"1":[[1167,1230,"Sorry."],[1234,1393,"This is closed for a private meeting."],[1455,1576,"That's all right. I'm the gardener."],[1601,1693,"I have clearance."],[1835,1876,"Again."],[1876,1997,"This is closed."],[2035,2118,"Anyone coming through"],[2118,2206,"here will be shot."],[2260,2494,"Even high ranking gardeners"],[2494,2602,"such as yourself."],[2698,2815,"I appreciate your concern,"],[2886,3007,"but I'll take my chances."],[3015,3090,"Those geraniums"],[3090,3165,"really need watering."],[3420,3545,"I don't think you're hearing me."],[3636,3762,"You got some dirt in your ears?"],[3820,3920,"I'm going to go back there."],[4362,4483,"Pretty strong for a gardener."],[4533,4654,"All that wheelbarrowing."],[4713,4783,"Nice."],[4846,5017,"Too bad I don't date"],[5017,5130,"below my pay grade."],[5926,6051,"You don't have to do this, you know."],[6139,6260,"Just trying to get to work."],[6293,6377,"It's a shame all the"],[6377,6502,"hot ones are so dumb."],[6673,6848,"Dispatch, this is Bianca."],[6852,7073,"Security code AX426."],[7115,7215,"We have a problem at the"],[7215,7399,"grounds gate with a potentially"],[7399,7674,"irate lower level employee."],[7807,7928,"You're so screwed."],[7987,8233,"You know that was a bad move."]],"2":[[283,354,"You should have stuck to"],[354,446,"your little flowers."],[583,800,"You need to know your place."],[1213,1334,"Let her go."],[1409,1518,"Dispatch."],[1522,1643,"Rescind the previous offer."],[1659,1780,"On whose authority?"],[1789,1843,"On mine."],[1843,2031,"Security code GR534."],[2068,2206,"I don't know that security code."],[2214,2302,"Look it up."],[2377,2527,"You are so screwed."],[2581,2715,"Oh my God!"],[2719,2786,"Stand down."],[2790,2886,"Stand down!"],[2890,3053,"Do you have any idea who that is?"],[3061,3307,"Sir, I am so sorry for any inconvenience."],[3319,3399,"Let me say it."],[3403,3549,"It was such an honor to..."],[3549,3745,"That will be all. Back to work."],[4279,4350,"Wait."],[4379,4542,"Who are you really?"],[4979,5067,"I'm the gardener."]],"3":[[375,500,"You have any idea"],[525,646,"what the head of syndicate"],[646,717,"looks like?"],[792,905,"No one does."],[905,1063,"I wasn't even sure he existed"],[1063,1234,"until I got the call to meet him here."],[1255,1422,"Why does he want to meet us now?"],[1447,1514,"He can't know"],[1514,1685,"we're plotting to take over."],[1697,1768,"Shhh!"],[2002,2185,"Who cares if the gardener hear us."],[2206,2268,"Hey, you!"],[2569,2723,"If you repeat anything,"],[2748,3003,"I will kill you, your family,"],[3003,3115,"and your dog."],[3186,3278,"You got me?"],[3474,3595,"Sound very powerful."],[3816,3945,"Look at me, farm boy,"],[3945,4066,"when I'm talking to you."],[4333,4612,"Oh, I don't think he likes you."],[4650,4758,"We got a problem,"],[4758,4850,"farm boy?"],[5125,5246,"No problems here, sir."],[5680,5976,"One word, and you’re dead."],[6364,6514,"Can I get you guys anything else?"],[6790,6952,"You can get me a lot of things,"],[6981,7094,"dollface."],[7474,7590,"How about you, handsome?"],[7607,7728,"Can I get you anything?"],[7766,7870,"I'm okay."],[7874,7957,"Thanks, though."],[8074,8220,"How about a bottle of Dom"],[8220,8370,"for our esteemed guest?"],[8387,8604,"And maybe, maybe some caviar?"],[8888,9154,"Why you never call us handsome?"],[9267,9346,"Oh, it's because"],[9346,9459,"you two are ugly as shit."],[9580,9701,"The fuck did you just say?"],[9784,9918,"Take your hand off her"],[9918,9989,"right now."],[10101,10168,"Or I break it."]],"4":[[4,200,"Did he just say what I thought he said?"],[266,387,"I think he did."],[425,567,"Go back inside."],[571,667,"Okay. Please don't hurt him."],[667,725,"He was just..."],[725,784,"Now!"],[784,850,"Okay."],[1230,1351,"You really don't want to do that."],[1739,1951,"Why? What are you going to do?"],[1981,2102,"Mulch us to death?"],[2127,2356,"I say we make him dig"],[2402,2523,"his own grave."],[2644,2765,"Should just do yourselves a favor."],[2806,2973,"Put the guns away, right now."],[3073,3194,"I got a better idea."],[3299,3440,"Let's make him shit himself."],[3511,3674,"Then use it as fertilizer"],[3678,3858,"for his little flowers."],[4245,4371,"You think we're joking?"],[4458,4592,"Drop your pants."],[4596,4738,"Shit on your flowers,"],[4738,4879,"or we shoot you."],[5038,5159,"Sorry, boys,"],[5196,5317,"but I did warn you."],[5630,5751,"What's going on?"],[6181,6302,"You see that guy?"],[6339,6477,"You’re gonna wish we’d shot you."],[6706,6823,"Mr. Brazzo,"],[6915,7036,"it's an honor to see you."],[7248,7403,"What the fuck is going on?"],[7444,7545,"While we were waiting"],[7545,7745,"for our mysterious leader to show up."],[7782,8020,"This piece of shit insulted us."],[8058,8191,"What are you talking about?"],[8299,8508,"Our leader is already here."],[9676,9722,"So"],[9818,9868,"tell me more about"],[9868,10018,"how you're plotting to take over."]],"5":[[809,1155,"Sir, I am so honored that you"],[1167,1313,"decided finally to"],[1313,1459,"reveal yourself to me."],[1522,1764,"And in the Vault Room, no less."],[1906,2085,"This vault contains the wealth"],[2085,2243,"of our entire organization."],[2373,2694,"Can only be opened by five unique keys."],[2823,2952,"Whoever controls the keys,"],[3073,3194,"controls the vault."],[3228,3403,"And whoever controls the vault,"],[3461,3645,"controls the entire Syndicate."],[3837,3958,"The keys are traditionally held"],[3958,4087,"by five family leaders."],[4212,4325,"Until I killed them all."],[4387,4696,"One by one."],[7207,7328,"Boris,"],[7374,7503,"it's time to announce myself."],[7582,7724,"I want you to call a summit"],[7724,7824,"of all senior members."],[7912,8183,"But of course, the men will be thrilled."],[8270,8391,"Even your nephew,"],[8466,8537,"Ivan?"],[8683,8967,"Ivan is ruthless and ambitious."],[9063,9230,"But you have the five keys,"],[9280,9505,"and he will respect your authority."],[9547,9667,"Good to hear."],[9726,9818,"You can go."]],"6":[[12,87,"Niko."],[229,300,"I want you to invite my wife"],[300,371,"to the summit."],[458,579,"Let her know she's become"],[579,692,"Queen of The Syndicate."],[792,913,"But make it anonymous."],[1034,1159,"She doesn’t know who I really am."],[1326,1388,"It's time to give her"],[1388,1484,"the life she deserves."],[1868,2043,"This would be a good start."],[2306,2464,"The Five Nation's Pendant."],[2648,2869,"Traditionally only worn by"],[2869,2977,"Syndicate royalty."],[4491,4763,"Hey, you can't go in there."],[4921,5042,"It's my house."],[5046,5163,"Sorry. Who are you?"],[5180,5367,"This is Vanessa Russo's house,"],[5405,5538,"and I'm her assistant."],[5638,5772,"This is my house"],[5772,5880,"that I own with my wife,"],[5918,6035,"Vanessa Rodgers."],[6039,6243,"She's going by her maiden name, now."],[6339,6727,"Oh, and she is actually"],[6727,6819,"divorcing you."],[6819,6936,"Finally."],[7011,7132,"What?"],[7178,7236,"This is real?"]],"7":[[12,133,"She wants a divorce?"],[237,358,"She couldn’t even say it to my face?"],[404,525,"She's outgrown you."],[642,788,"You know, she recently received"],[788,1038,"a very lucrative offer,"],[1155,1493,"with an extremely influential group."],[1589,1739,"So now I have to deal with"],[1739,1851,"the things that"],[1976,2097,"don't matter."],[2260,2356,"Where is she?"],[2360,2481,"Inside."],[2548,2669,"But you can't go in."],[2719,2798,"Move!"],[2802,2919,"You can't go in."],[2961,3103,"Hey! I'm talking to you."],[3178,3353,"Hello? Hey!"],[3695,3778,"Vanessa."],[3841,3883,"Hey."],[3945,4066,"We need to talk."],[4120,4208,"Marcy wasn't supposed to"],[4208,4262,"let you in."],[4304,4354,"What's going on?"],[4354,4433,"What is this?"],[4546,4625,"I'm moving on."],[4625,4700,"Grayson."],[4775,4896,"Look at me."],[4996,5113,"Now look at you."],[5226,5351,"I deserve a real man."],[5355,5513,"Not some poor, pathetic gardener"],[5513,5634,"that comes home smelling like"],[5634,5743,"cow shit every day."],[5764,5885,"Are you serious?"],[5935,5968,"You know,"],[5968,6085,"I've given you everything"],[6085,6143,"that you own."],[6214,6468,"This house, your car, your clothes."],[6506,6631,"This house is a dump."],[6702,6852,"My car is shit,"],[6890,6998,"and I'm about to burn my"],[6998,7140,"entire ratty ass wardrobe."],[7248,7411,"I don't need you anymore."],[7486,7578,"I met a man."],[7636,7778,"One who could take care of me."]],"8":[[37,141,"You're cheating on me?"],[221,342,"Upgrading."],[383,542,"He treats me the way I deserve."],[596,700,"In fact, he's making me the queen"],[700,855,"of the Five Nation's Syndicate."],[984,1084,"Oh, is he?"],[1088,1167,"That's him?"],[1238,1393,"Sure as fuck wasn’t you."],[1468,1576,"Oh, unless the Syndicate's"],[1576,1659,"gardeners have more pull"],[1659,1743,"than I thought."],[1797,1889,"Okay."],[1906,2014,"So this all meant nothing."],[2081,2173,"Four years together,"],[2173,2268,"because I don't have money"],[2268,2348,"meant nothing?"],[2398,2527,"Grayson, it was four years of me"],[2527,2627,"waiting around for you to get your"],[2627,2727,"shit together."],[2802,2936,"I'm not waiting anymore."],[3040,3161,"You'e a delusional,"],[3161,3307,"pathetic loser."],[3641,3712,"Yeah."],[3774,3820,"You're right."],[3903,4024,"Maybe I am a"],[4024,4170,"delusional pathetic loser."],[4308,4429,"But you know what?"],[4525,4575,"I'm also one of the"],[4575,4675,"richest men on Earth."]],"9":[[796,867,"Really?"],[905,1030,"This was your big plan?"],[1088,1217,"Buy me some knock off of"],[1217,1359,"the Five Nation Pendant?"],[1438,1484,"Don't."],[1793,1951,"You know something smaller"],[1951,2110,"I totally would have bought."],[2193,2277,"But this?"],[2335,2431,"You wouldn't be able to afford"],[2431,2640,"something like this in 15 lifetimes."],[2656,2802,"You have no idea the mistake"],[2802,2869,"you just made."],[2944,3015,"Get out!"],[3053,3161,"I think I'll stay."],[3165,3328,"And you can't do shit about it."],[3328,3445,"Because you're a weak little man."],[3628,3749,"I'm warning you."],[3753,3816,"Get out!"],[4062,4145,"Nah."],[4250,4346,"I think we'll stay."],[4371,4433,"We?"],[4471,4696,"Babe, can you come in here?"],[4696,4813,"He's here now?"],[5697,5784,"Grayson."],[5947,6064,"Meet my lover."],[6085,6206,"Ivan Kalichnov."],[6619,6948,"Ivan is ruthless and ambitious."]],"10":[[0,221,"Both of you need to leave, now."],[262,371,"I think we're good here."],[467,671,"In fact, I think we'll go up to"],[671,855,"the bedroom and fuck on your bed."],[1063,1217,"Again and again."],[1255,1330,"Ivan, tell him..."],[1330,1468,"Don't ever fucking interrupt me."],[1659,1780,"Don't talk to her like that."],[1830,1918,"I'll talk to her however"],[1918,2035,"the fuck I want,"],[2097,2202,"and she'll like it."],[2577,2673,"Turn around."],[2844,2965,"You see your wife?"],[3019,3144,"She wants a real man."],[3232,3370,"Not some fucking gardener."],[3415,3561,"Don't you, dirty bitch?"],[3561,3632,"Yeah, baby."],[3766,3903,"This is the trash you're married to?"],[3966,4087,"Until you saved me."],[4250,4400,"I tried to save you, didn't I?"],[4400,4458,"Baby."],[4896,5080,"They have no idea who I really am."],[5188,5309,"You want to see real power?"],[5442,5559,"I'll show you real power."],[6348,6468,"You like it, don't you?"],[6548,6690,"You like thinking of a man,"],[6723,6898,"a real man with her, don't you?"],[7486,7607,"Look at this little bitch."],[7628,7757,"He can't even speak."],[7757,7928,"159 Silverline Boulevard."],[8270,8291,"What?"],[8291,8458,"159 Silverline Boulevard."],[8458,8579,"Penthouse Suite, eighth floor."],[8737,8808,"How the fuck do you know"],[8808,8883,"where I live?"],[8883,8996,"You have two guards on duty,"],[9000,9121,"8 am to 9 pm."],[9150,9271,"You got a third during the night."],[9338,9526,"All carry standard issue Beretta M9s."],[9601,9722,"You sleep in the master suite."],[9818,9939,"Enter through the main entrance,"],[9964,10085,"turn left,"],[10105,10222,"two doors down."],[10289,10410,"What the fuck?"],[10439,10623,"You want to know what real power is?"],[10798,10898,"I may not know"],[10898,11002,"you're screwing my wife."],[11086,11353,"But I have known for a very long time,"],[11423,11565,"exactly how to kill you."],[11695,11811,"Any time I want."],[11878,12103,"Just like that."]],"11":[[75,216,"Go wait for me upstairs, baby."],[1009,1076,"Go ahead."],[1188,1309,"Make the first move."],[2827,2961,"I don't know how you know this."],[3053,3253,"Frankly, I don't care."],[3357,3482,"Normally, for a man says something"],[3482,3561,"like this to me,"],[3636,3753,"they'd be dead."],[3883,3970,"But I need you."],[4099,4220,"There's a summit tomorrow"],[4266,4441,"of all the leaders of the Five Nations."],[4517,4713,"While there, the security in the rest of"],[4713,4817,"the building will be loose."],[4909,5030,"As the gardener,"],[5071,5201,"you have access to the grounds."],[5263,5422,"I need you to let my men in."],[5839,5951,"Once there,"],[5955,6076,"they'll break into the vault."],[6172,6293,"Aren't you forgetting something?"],[6360,6448,"How do you get into the vault"],[6448,6548,"without the keys?"],[6715,6819,"Who needs the keys when you"],[6819,6911,"have blowtorches"],[6911,7002,"and a bunch of time?"],[7086,7186,"Do this for me."],[7344,7465,"And I'll let you live."],[7511,7599,"Refuse,"],[7745,7937,"and I'll feed pieces of you to my dogs."],[8287,8391,"We're not done here."],[8554,8633,"I'm done."],[8696,8888,"Unless you want my sloppy seconds."],[8888,8996,"But I..."],[8996,9104,"I have warmed your wife up for you."],[9184,9230,"Oh."],[9313,9376,"Ex-wife."],[9680,9797,"You want to kill me, huh?"],[9922,10235,"No. Killing you is not enough."],[10414,10464,"I'm going to take"],[10464,10552,"everything from you."],[10664,10785,"Humiliate you."],[10885,11006,"Destroy your family."],[11106,11223,"Destroy your legacy."],[11365,11536,"And when you're praying for death,"],[11720,11828,"then maybe I'll kill you."]],"12":[[625,675,"Sir."],[796,880,"What are you still doing"],[880,996,"dressed as a gardener?"],[1130,1251,"Change of plans."],[1292,1438,"I need to see my men's true colors."],[1526,1584,"Can't do that"],[1584,1705,"if they're always sucking up to me."],[2002,2122,"What's the plan?"],[3766,4066,"One Macallan 25 neat."],[4408,4583,"And one strawberry daiquiri."],[5834,5876,"What?"],[5918,6051,"You drink like a 14 year old"],[6051,6164,"girl with diabetes."],[6231,6331,"Fuck you."],[6544,6685,"You excited to find out who the new"],[6685,6835,"real Syndicate Leader is?"],[6856,6994,"I already know. Think about it."],[6994,7144,"This guy comes out of nowhere,"],[7144,7328,"kills five of the most powerful men"],[7328,7449,"in the Syndicate,"],[7457,7595,"and takes their five gold keys."],[7649,7824,"Has to be Ivan Kalichnov."],[7824,7991,"He's the only one that can pull it off."],[8024,8174,"I have to get on his good side."],[8204,8291,"I already have."],[8375,8466,"My sister's sleeping with him."],[8537,8575,"What?"],[8587,8708,"Yeah, she just left her husband."],[8842,8975,"A tall pile of shit."],[8979,9142,"Really. A gardener."],[9146,9238,"Can you believe it?"],[9242,9363,"Jesus Christ."],[9897,10005,"Speaking of."],[10026,10181,"What the fuck is he doing here?"]],"13":[[33,225,"Well, well, well, look who it is."],[287,404,"Glad to see you survived."],[450,517,"Barely."],[588,663,"I'm Grayson."],[742,821,"Sarah."],[880,988,"Can I get you a drink?"],[1013,1063,"Sure."],[1109,1184,"Surprise me."],[1238,1334,"I'd love to."],[1568,1689,"Look, it's the"],[1735,1881,"secret leader of the Syndicate."],[1939,2064,"Oh wait, no."],[2118,2285,"No, it's just a dirty gardener"],[2285,2414,"who doesn't belong here."],[2606,2677,"You know,"],[2681,2752,"I'm really going to miss"],[2752,2844,"being your brother in law."],[2898,2977,"Jesus Christ, it looks like"],[2977,3073,"you just got"],[3073,3219,"done having sex with a goat."],[3269,3445,"Hey, hey, hey, leave this guy alone."],[3561,3678,"Yeah, I like your vest."],[3678,3799,"Is that cashmere?"],[4070,4112,"Nope."],[4112,4187,"Rayon."],[4200,4295,"I was close."],[4462,4608,"It’s O’Reilly, isn't it?"],[4658,4846,"Wow. I'm famous."],[4879,4959,"Recognized by"],[4959,5117,"an obvious man of wealth."],[5288,5459,"Is that the new Armani Cologne?"],[5467,5580,"Eau de Cow Shit."],[5722,5834,"Bold of you to call out"],[5834,5964,"somebody for the way they smell,"],[5968,6035,"O’Reilly."],[6081,6202,"What the fuck does that mean?"],[6252,6331,"Your breath."],[6368,6477,"You need to get those carcasses"],[6477,6635,"you call teeth removed."],[6785,6931,"Don't talk to me like that, bitch."],[7461,7578,"Take one more step and I'll paint"],[7578,7724,"the doorway with your brains."]],"14":[[20,200,"Leave her alone."],[241,371,"Oh, shit."],[371,513,"My sister breaks up with him,"],[513,617,"and now he's in love with"],[617,734,"a waitress."],[846,1026,"Is that true, big guy?"],[1030,1209,"You have a crush on this girl?"],[1255,1409,"You shouldn't hit women."],[1409,1589,"You do like her."],[1622,1768,"Looks she's a little out of your league."],[1768,1830,"Yeah, body."],[1830,1981,"I know how you can impress her."],[1981,2160,"Dance for her."],[2318,2481,"I think I'll pass."],[2481,2594,"While we're waiting for our"],[2594,2723,"mysterious leader"],[2723,2902,"with the five keys."],[2911,3090,"We might as well help you get laid."],[3328,3432,"You two done?"],[3432,3474,"Yeah."],[3474,3616,"Do a little sexy little dance"],[3616,3778,"for your new little girlfriend."],[3778,3828,"Yeah."],[3849,3974,"Dance, bitch."],[3974,4462,"Dance, dance, dance, bitch."],[4462,4642,"Stop being assholes!"],[4654,4833,"Shut the fuck up!"],[5130,5296,"Start dancing now."],[5351,5447,"Or I'll blow her head off"],[5447,5543,"and have you bury her"],[5543,5718,"by your rosebush."],[5768,6022,"Put your gun away."],[6093,6218,"Sure."],[6218,6352,"Show us your dance."],[6352,6527,"Make sure it's super sexy."],[6852,7036,"Okay."],[7065,7248,"I'll dance for you."],[7374,7540,"At least let me take off my vest."],[7540,7661,"Yeah. Take it off."],[7661,7795,"Take it off, bitch."],[7795,7987,"Let's see that sexy farmer's tan."],[8562,8808,"It's time to see you dance now, bitch."]],"15":[[120,321,"Oh my God."],[675,880,"Whoever controls the keys"],[1001,1234,"controls the entire syndicate."],[1276,1451,"Shit!"],[1451,1651,"I didn't know."],[1976,2177,"You okay?"],[2548,2748,"I am now."],[2977,3103,"What are you morons doing?"],[3103,3215,"He's a fucking gardener."],[3215,3382,"I know this guy."],[3382,3520,"He's got the five keys."],[3520,3678,"They're obviously fake."],[3678,3903,"He's just my sister's"],[3903,4104,"pathetic ex-husband."],[4191,4383,"I knew that."],[4383,4521,"I can see they're fakes from here."],[4521,4662,"They're obviously spray painted."],[4662,4821,"Hey,"],[4821,5021,"you willing to bet your life on that?"],[5121,5305,"How dare you talk to me like that?"],[5305,5559,"You worthless dirt fucker!"],[5605,5697,"He's not even a member"],[5697,5805,"of the Syndicate."],[5839,6039,"He comes in and acts like that,"],[6060,6260,"I say we string him up by the balls."],[6539,6681,"Come on."],[6681,6852,"Do it!"],[6852,6961,"I'm just a humble gardener."]],"16":[[325,458,"What are you waiting for?"],[458,658,"Come on. Do it!"],[717,863,"I could totally destroy"],[863,1063,"this filthy dirt hopper."],[1076,1242,"Even touching him is beneath me."],[1242,1359,"Yeah, I can fuck the bitch up."],[1359,1505,"No problem."],[1505,1626,"But I'm not going to get my suit"],[1626,1826,"dirty over strunz."],[1830,1972,"What about you?"],[1972,2118,"Or did she destroy whatever manhood"],[2118,2239,"you have left?"],[2239,2364,"Why would I bruise my knuckles?"],[2364,2469,"I just call the leaders"],[2469,2565,"right hand man,"],[2644,2844,"Nico Brazzo."],[2877,3078,"He's a close personal friend."],[3499,3645,"What's wrong?"],[3645,3787,"He's not answering?"],[3787,3924,"Shut the fuck up."],[3924,4062,"Here,"],[4062,4262,"let me try."],[4371,4571,"Here's the deal."],[4608,4671,"Get on your knees"],[4671,4854,"in the next five seconds"],[4854,5055,"or you lose your knees."],[5180,5359,"Five."],[5359,5518,"Four."],[5518,5680,"Three."],[5680,5880,"Two."],[6523,6594,"One."]],"17":[[4,70,"What the fuck is"],[70,229,"going on here?"],[362,567,"Excuse me, honey,"],[567,875,"but this is a closed meeting here."],[1034,1284,"Hey, sis."],[1447,1564,"This is your..."],[1564,1735,"Exactly."],[1735,1960,"And if you will like Ivan Kalichnov"],[1960,2206,"to personally rip out your throat,"],[2256,2389,"then keep touching her."],[2752,2869,"What is this thing doing here?"],[2869,2936,"Kick him out."],[2936,3028,"Same with the whore."],[3028,3228,"You can serve your own drinks."],[3228,3407,"We were just about to kick him out,"],[3407,3486,"ma'am."],[3486,3787,"But he claims he's got the five keys."],[3899,4149,"I promise you, this man has nothing."],[4191,4308,"I used to be married to him"],[4308,4471,"until I upgraded."],[4471,4567,"Marcy, what was that thing"],[4567,4817,"that he got me last year for Christmas?"],[4817,5017,"That would've been..."],[5125,5347,"a cheap Airbnb"],[5347,5551,"at some riverfront."],[5580,5680,"He told me one day"],[5680,5901,"he'll get me a house on the ocean."],[5901,6151,"But until then, this is just a preview."],[6193,6339,"Pathetic."],[6339,6489,"That's enough. Vanessa."],[6489,6585,"This man can't handle"],[6585,6706,"the Syndicate."],[6706,6794,"He can't even handle"],[6794,6852,"his own wife."],[6852,6923,"Watch this."],[7645,7895,"Do something."],[8003,8066,"See? I told you."],[8066,8308,"He won't do shit."],[8308,8495,"I'm going to do something."],[8495,8692,"But not just to you."],[8692,8808,"It's going to be your piece of shit"],[8808,9000,"Russian boyfriend."],[9000,9159,"The fuck you just say?"]],"18":[[12,95,"Oh, shit."],[95,271,"It's Ivan."],[271,371,"Look at that badass."],[371,596,"Ten grand says he's the secret leader"],[596,796,"that set up this whole summit."],[1284,1368,"Who lets a gardener"],[1368,1468,"into this meeting?"],[1468,1668,"Ivan,"],[1705,1755,"he claims"],[1755,1956,"he's got the five keys."],[2231,2423,"Look at him."],[2423,2623,"You think he has the real keys?"],[2665,2865,"He's not even a real man."],[3123,3236,"Is he, babe?"],[3236,3299,"Yeah, baby."],[3299,3499,"He's just a poor, pathetic loser."],[3657,3807,"But..."],[3807,3995,"we tried to call Niko Brazzo,"],[3995,4162,"and he wouldn't answer the phone."],[4162,4362,"Oh, no."],[5201,5359,"Oh my God."],[5359,5518,"Niko didn't answer."],[5518,5668,"Now, the way I look at it"],[5668,5814,"is that this pathetic"],[5814,6010,"nothing is our leader"],[6010,6210,"and has the respect of Niko Brazzo,"],[6222,6272,"one of the most"],[6272,6473,"powerful men in the world,"],[6510,6585,"Or Nico is away"],[6585,6781,"from his fucking phone!"],[7228,7428,"Now, I don't know what you're up to,"],[7453,7590,"but I'll forget the last comment"],[7590,7749,"if you leave."],[7749,7903,"Or, I gut you in front of everyone."],[9171,9371,"Hey, boss."],[9818,9984,"Niko,"],[9984,10176,"it's Grayson."],[10176,10352,"It's time to reign down hell."]],"19":[[75,275,"Nico."],[483,725,"I want Borris Kalichnov here now."],[750,913,"Consider it done."],[913,1109,"Good."],[1476,1647,"Comrade."],[1647,1847,"Nico, comrade."],[1860,2047,"What do I owe this pleasure?"],[2047,2248,"Tell me about your family legacy."],[2314,2515,"My family's legacy?"],[2585,2756,"Well, the Kalichnovs"],[2756,2894,"were one of the most"],[2894,3073,"influential factions"],[3090,3319,"of the syndicate since..."],[3319,3478,"since I can remember."],[3478,3582,"So"],[3624,3795,"you value your family?"],[3795,3966,"Yes."],[3966,4108,"Of course."],[4108,4308,"Good to hear."],[4320,4521,"Be at the summit in three minutes."],[4542,4725,"Or I personally guarantee"],[4725,4829,"that your entire bloodline"],[4829,5030,"is wiped off the face of the earth."],[5046,5201,"Got it,"],[5201,5401,"comrade?"],[6443,6531,"You think getting"],[6531,6664,"one of your little gardener buddies"],[6664,6777,"to pretend to be Nico"],[6777,6940,"is going to scare us?"],[6940,7048,"What a fucking joke."]],"20":[[58,254,"Weren't you married to him?"],[271,471,"Marcy?"],[475,567,"The help is no longer"],[567,763,"permitted to talk to Ms. Russo."],[838,946,"You might want to get back"],[946,1146,"to selling your tits for tips."],[1380,1580,"Leave her alone."],[1634,1755,"Or what?"],[1755,1830,"You're going to call another"],[1830,2031,"one of your fake hitmen?"],[2039,2173,"Vanessa,"],[2173,2373,"you were my wife for four years."],[2373,2548,"I'm giving you one last chance."],[2548,2640,"Get out of here now,"],[2640,2727,"while you still can."],[2727,2898,"Careful."],[2898,2977,"Everything you've done"],[2977,3178,"so far is forgivable."],[3186,3357,"But keep pushing,"],[3357,3432,"and we're going to have to"],[3432,3557,"take you out."],[3599,3649,"So you're saying"],[3649,3841,"if I walk out of here right now,"],[3841,3991,"I'll be forgiven?"],[3991,4158,"No, what I said was"],[4158,4287,"if you leave now,"],[4287,4479,"we'll let you live."],[4479,4575,"Let's see if you feel the same way"],[4575,4775,"in 30 seconds."],[5634,5793,"What the hell is he doing?"]],"21":[[58,258,"That's the stage of the five leaders."],[308,433,"Just getting close to it"],[433,617,"is punishable by death."],[642,842,"If getting close to is a death penalty,"],[875,938,"what's the punishment"],[938,1076,"for doing this?"],[1322,1514,"Stop that!"],[1514,1651,"You know,"],[1655,1735,"there's really no need for"],[1735,1910,"five chalices anymore."],[2310,2510,"You're insane."],[2965,3090,"Five chalices were necessary"],[3090,3290,"when there were five family leaders."],[3395,3595,"Until I killed them all"],[3603,3803,"one by one."],[5067,5267,"Now it's just me."],[5296,5497,"And I have no queen."],[5584,5784,"So bow before your leader"],[5826,6026,"or prepare to suffer the consequences"],[6118,6318,"right about..."],[6377,6493,"Okay, fuck this."],[6493,6627,"You want to die?"],[6627,6823,"We can make that happen."],[6898,7098,"Now."],[7419,7557,"My leader!"]],"22":[[87,241,"My leader."],[241,350,"This is not the leader."],[350,550,"He's just some fucking gardener."],[567,767,"This must be what Nico wanted."],[829,1067,"For me to take care of this fake."],[1146,1443,"Boy, get away from the stage!"],[1751,1989,"No, I think I'm good where I'm at."],[1989,2122,"Boy,"],[2122,2406,"you are too low on the totem pole"],[2439,2781,"to even know who I am."],[2798,2940,"But let me assure you,"],[2940,3324,"I am very, very powerful."],[3453,3591,"Congratulations."],[3591,3899,"Disrespecting me will"],[3899,4116,"bring grave consequences"],[4116,4237,"for you."],[4258,4387,"I'll keep that in mind."],[4387,4696,"Listen here, you worthless peon!"],[4708,4942,"If you had any idea"],[4967,5171,"who I was,"],[5171,5288,"you wouldn't"],[5288,5563,"even imagine speaking to me"],[5563,5764,"like that."],[5789,5860,"The thing is I know"],[5860,5989,"exactly who you are,"],[6039,6235,"Boris Kalichnov."],[6235,6297,"Head council"],[6297,6498,"of the Five Nation Syndicate."],[6514,6627,"But it seems you've forgotten me"],[6627,6848,"since the last time we saw each other."],[7157,7244,"How dare you"],[7244,7419,"turn your back on me?"],[7424,7599,"This is how we first met"],[7599,7799,"outside of the vault."],[8141,8287,"Sir,"],[8287,8425,"I am so honored"],[8425,8562,"that you decided"],[8562,8854,"finally to reveal yourself to me."]],"23":[[196,312,"You were kneeling"],[312,513,"and your head was bowed in respect."],[600,792,"How dare you pretend"],[792,992,"to be the leader?"],[1009,1201,"I've met him."],[1201,1401,"He is much bigger than you."],[1468,1614,"Older."],[1614,1793,"Wiser."],[1793,2110,"I could tell he was a man of power"],[2110,2223,"the second"],[2223,2410,"I stepped into the room."],[2464,2644,"You though,"],[2644,2844,"less than nothing."],[2873,3073,"Get off the stage this instant!"],[3107,3307,"He still doesn't realize I'm his boss."],[3336,3520,"You pathetic"],[3520,3720,"fuck of a peasant!"],[3737,3953,"With the smallest gesture"],[4037,4237,"I could end your life."],[4642,4833,"Then why haven't you?"],[4833,4954,"Of course"],[4954,5021,"you wouldn't want to"],[5021,5142,"spill my peasant blood"],[5142,5263,"all over the sacred stage,"],[5263,5367,"would you?"],[5367,5568,"Take him away!"],[5834,5989,"Yeah, come on up here."],[5989,6131,"Take me away."],[6131,6256,"But before you do, I'm"],[6256,6418,"sure you've thought of this."],[6418,6502,"Being up on this stage"],[6502,6610,"without your leader's permission"],[6610,6769,"is the death penalty."],[6769,6890,"And I'm sure you know that"],[6890,7023,"as Legal Counsel"],[7023,7198,"to the Five Nation Syndicate."],[7198,7494,"I'll call the real leader"],[7590,7828,"and get permission to"],[7849,8141,"drag you away and rip you apart"],[8141,8324,"with my bare hands."],[8341,8521,"Oh, no."],[8521,8675,"You have the real leader's number?"],[8675,8863,"Of course I do."],[8863,9113,"Oh, please don't call the real leader."],[9129,9309,"You gave me no choice."]],"24":[[50,400,"Just remember I gave you a chance."],[504,804,"What happens next is on you."],[825,955,"Just do it."],[955,1088,"Show this fake what happens when you"],[1088,1176,"mess with The Syndicate."],[1242,1372,"Look at the fool."],[1372,1576,"Shaking like a little girl."],[1576,1693,"This is what happens"],[1693,1864,"when a peasant thinks he's smart."],[1960,2077,"You should have just left."],[2377,2523,"Any last words?"],[2606,2823,"Oh, please don't call the real leader."],[2986,3165,"Pathetic."],[4154,4304,"Where's that coming from?"],[4654,4900,"The leader is already here."],[5839,5926,"Shouldn't you be kneeling?"]],"25":[[821,1121,"I said, shouldn't you be kneeling?"],[1330,1680,"How dare you steal the leader's phone?"],[1739,1885,"Don't you see?"],[1993,2164,"The real leader"],[2239,2431,"set his phone down outside."],[2431,2727,"And this horrible guy took it."],[2756,3028,"Then thinks he can use it to"],[3028,3411,"convince us all that he's in charge."],[3549,3724,"Of course."],[3724,3883,"I knew it."],[3883,3987,"This guy was married"],[3987,4062,"to my sister."],[4062,4220,"Probably stole shit from me all the time."],[4316,4617,"We need to kill the thief."],[4662,4900,"Interesting choice of words, Boris."],[4900,4975,"Because I went through"],[4975,5084,"some security footage,"],[5234,5413,"and I found this."],[5522,5730,"This stupid leader still hasn't"],[5730,5822,"revealed himself."],[5822,6043,"Now's your time. Make your move."],[6043,6151,"Take the vault."],[6151,6268,"Once you have the vault,"],[6268,6418,"the Syndicate is yours."],[6435,6606,"How do I get in?"],[6606,6881,"The gardener. Use him to gain access"],[6881,7065,"when everyone else is occupied."],[7111,7411,"Perfect. He's got an Achilles heel."],[7419,7570,"His wife."],[7570,7753,"That dumb ass doesn't even realize"],[7753,7941,"what a gold digging slut she is."],[8003,8158,"I'll seduce her to get to him."],[8287,8383,"Perfect."]],"26":[[125,241,"You know, it's amazing what you'll"],[241,321,"have access to"],[321,425,"whenever you're in charge."],[454,621,"You piece of shit."],[621,804,"It's clearly fake."],[804,930,"It doesn't even sound like me."],[930,1026,"Come on, baby."],[1142,1443,"How dare you try to set us up?"],[1493,1747,"I would never, never betray"],[1747,1943,"the Syndicate."],[1947,2260,"I am still the legal counsel"],[2260,2473,"for this organization."],[2602,2861,"Until the new leader decides"],[2861,3161,"to reveal himself,"],[3211,3661,"that makes me your de facto boss."],[3716,3870,"You know,"],[3870,4170,"you were the de facto boss."],[4183,4379,"But now,"],[4379,4500,"you're nothing."],[4500,4654,"That’s it."],[4654,4846,"Somebody"],[4846,5125,"put this arrogant son of a bitch"],[5125,5305,"out of his misery."],[5305,5584,"Gladly."]],"27":[[116,254,"It’s Nico Brazzo,"],[254,408,"the red right hand of the Syndicate."],[483,517,"Damn!"],[517,638,"Someone's going to die."],[855,934,"Niko."],[1184,1405,"I'm so glad you're here, my friend."],[1405,1547,"What is going on?"],[1626,1864,"This peon has disgraced us all."],[1951,2085,"He disobeyed orders"],[2085,2231,"from his betters."],[2231,2506,"He defiled the sacred chalices"],[2506,2619,"of the key holders"],[2619,2715,"and even had someone"],[2715,2836,"impersonate you."],[2836,2986,"It's true, Niko."],[3069,3290,"This is what happens when we"],[3290,3591,"let the poor have too much leeway."],[3599,3753,"You need to take care of it."],[3753,3953,"The disrespect he’s showing."],[3953,4254,"This is unacceptable."],[4295,4525,"It is."],[4525,4683,"So what are you going to do about it?"],[4758,4838,"Nico."],[4975,5075,"Even though he was married to my"],[5075,5267,"sister, I had nothing to do with this."],[5271,5505,"The Russo family has all respect"],[5505,5655,"for everything..."],[5655,5885,"Oh shut up, Tommy!"],[5885,6006,"Niko knows I'm going to be"],[6006,6143,"the queen of the Five Nations."],[6143,6289,"Obviously, he's on our side."],[6427,6727,"Niko, if you will allow it."],[6756,6881,"I can take care of this"],[6881,7048,"overreaching trash..."]],"28":[[0,271,"Ivan, apologize to Niko"],[271,558,"for disrespecting him."],[579,804,"You were way out of line."],[804,896,"There's a lot of people"],[896,1167,"out of line right now."],[1167,1230,"How can you show"],[1230,1530,"disrespect to your leader?"],[1622,1751,"And you two"],[1797,1985,"go behind the Syndicate's back"],[1985,2260,"to take everything."],[2260,2556,"Tell me why I shouldn't kill you now."],[2715,2898,"Niko,"],[2898,3119,"it would be unwise for you"],[3119,3420,"to make such an accusation"],[3420,3720,"with no proof, even for you."],[3799,4099,"Surely you have some evidence."],[4145,4546,"Is it just the word of some Gardener?"],[4683,4917,"As you had been plotting with him"],[4917,5067,"all along!"],[5976,6239,"Kill him and his little gardener."],[6239,6414,"As your future queen of the Five Nations,"],[6414,6539,"I demand it."],[6539,6840,"This is mutiny."],[6873,6981,"I can't let you do that."],[6981,7090,"Not against my sister."]],"29":[[25,112,"They're going to kill each"],[112,308,"other before I can unite them."],[308,433,"Plus,"],[433,508,"I need to find a way"],[508,771,"to catch Ivan in the act."],[771,1071,"Niko."],[2802,2994,"You're a fake."],[2994,3265,"I knew it the first time I saw you."],[3265,3336,"Any pretender"],[3336,3616,"would be dealt with like this."],[3616,3807,"And now,"],[3807,3870,"while we wait"],[3870,4154,"for the real leader to arrive,"],[4154,4421,"someone deals with this trash."],[4421,4721,"My man would be happy to."],[5305,5372,"While you're at it,"],[5372,5672,"take care of the skunk to."],[5747,5901,"She's on his side."],[5901,6043,"Hey, wait! Leave her out of this."]],"30":[[250,367,"Who are you listening to?"],[367,604,"The soon to be dead gardener"],[604,905,"or the future queen of the Five Nations?"],[988,1234,"Chop, chop."],[1234,1380,"Good boy."],[1380,1422,"Oh, wait."],[1422,1609,"I didn't even do anything!"],[1609,1780,"Well, we'll see about that."],[1780,1914,"You have my permission to"],[1914,2193,"interrogate her, thoroughly."],[2339,2640,"I have a special place for you."],[3053,3265,"You are a dead man,"],[3265,3486,"so you might as well let my men in."],[3486,3691,"Or that bitch joins you."],[3712,3903,"And her death will be much,"],[3903,4066,"much slower."]],"31":[[442,525,"What the hell was that?"],[525,704,"Do you have some kind of a death wish?"],[704,825,"I'm sorry,"],[825,888,"but I promise"],[888,1063,"I'm going to get you out of here."],[1063,1255,"You have to trust me."],[1255,1434,"Yeah, I 100%"],[1434,1551,"do not trust you."],[2118,2268,"You, come now."],[2268,2385,"You need to let the men in before"],[2385,2627,"word gets around about what you did."],[2736,2869,"No."],[2869,3036,"What?"],[3036,3190,"Not going."],[3190,3294,"Gonna have to kill me."],[3294,3461,"Grayson."],[3461,3712,"Come on, do it."],[3712,3891,"Kill me."],[4325,4625,"Yeah, that's what I thought."],[4658,4867,"So your boss needs me,"],[4867,4992,"and I'll do what he wants."],[4992,5109,"But under my conditions."]],"32":[[45,208,"First things first,"],[208,316,"if he wants me to let his men"],[316,479,"in, she comes with me."],[542,600,"No, you can..."],[600,775,"You can actually just leave me out of it."],[775,934,"It's too late."],[934,1038,"He already talked about the plan"],[1038,1176,"in front of you."],[1176,1263,"He's about to kill you"],[1263,1564,"the moment that I left."],[1593,1893,"And if I refuse?"],[1901,2068,"Then you can tell your boss, Ivan,"],[2068,2193,"how you failed"],[2193,2494,"your very simple yet very important task."],[2556,2857,"I'm sure he'll be really understanding."],[2932,3132,"All right, you!"],[3132,3290,"Go with him."],[3290,3436,"Any funny business, though,"],[3436,3657,"and you're both dead."],[3657,3958,"You have ten minutes."],[4141,4291,"Trust me."],[4291,4441,"Yeah, I don't,"],[4441,4637,"but it doesn't look like I have a choice."]],"33":[[1017,1263,"I can't believe they're not following us."],[1263,1418,"They don't need to."],[1418,1647,"Ivan has his men posted at every exit."],[1647,1722,"Be shot as soon as"],[1722,1885,"we stepped out of the property."],[2097,2152,"Over here."],[2152,2198,"Wait."],[2198,2260,"Where are you going?"],[2260,2473,"We only have, like, ten minutes."],[2473,2602,"Sarah,"],[2602,2802,"you can't work the grounds in that."],[3190,3370,"Come on."],[3670,3732,"Let’s tell the security"],[3732,3820,"you are the new gardener."],[3820,3966,"Just haven't gotten your pass yet."],[4517,4654,"Here."],[4654,4796,"Maybe a little big."],[4796,4900,"Beautiful."],[4992,5180,"Feels like Cinderella before the ball."],[5359,5484,"Oh!"],[5484,5630,"Turn around."],[6060,6289,"Is the big bad boss of the Five Nations"],[6289,6423,"afraid of seeing women undressing?"]],"34":[[166,467,"Am I making you nervous?"],[479,713,"You're making me something."],[892,1059,"I don't know if it's nervous."],[1434,1543,"Good."],[2118,2214,"You know,"],[2214,2281,"probably could have fit"],[2281,2431,"that on over your cloth."],[2431,2473,"Yeah."],[2473,2652,"Any chance to remove a corset."],[2823,2961,"And the skirt?"],[2961,3053,"Well..."],[3132,3232,"You are trapped in a marriage"],[3232,3345,"with Vanessa Russo."],[3345,3503,"So I thought"],[3503,3803,"you deserved a little bit of a show."],[3891,3999,"Okay."],[3999,4116,"So how did a guy like"],[4116,4329,"you end up with a girl like her, anyway?"],[4329,4567,"I mean, how did a gardener end up with"],[4567,4758,"Five Nation royalty?"],[4888,5017,"No."],[5092,5238,"How did a human being end up"],[5238,5476,"with a sociopath-like she-wolf?"],[5476,5714,"She wasn't always like that."],[5714,5885,"As a matter of fact,"],[5885,6139,"when we first met,"],[6139,6222,"she saved my life."]],"35":[[83,183,"I was almost through taking"],[183,350,"over the entire Syndicate."],[350,567,"I have one last keyholder to kill."],[633,825,"He was supposed to be alone that night,"],[825,1126,"but he wasn't."],[2635,2806,"[Russian] Good night."],[6197,6352,"As I laid there on the ground,"],[6352,6531,"losing blood,"],[6531,6731,"I heard footsteps."],[6731,6961,"I expected the last thing I'd see was"],[6961,7261,"some goon with a gun pointed at my head."],[7261,7328,"Instead..."]],"36":[[45,229,"Instead,"],[229,321,"woke up in the hospital"],[321,533,"being treated for my wounds."],[533,684,"Eventually,"],[684,763,"I found out that there's"],[763,846,"only one other woman"],[846,963,"at the compound that night."],[963,1205,"The sister of a high ranking member,"],[1205,1468,"Vanessa Russo."],[1468,1605,"She saved my life."],[1605,1710,"So I made a vow to give her"],[1710,1901,"the perfect life."],[2181,2394,"You stupid,"],[2394,2627,"stupid man."],[2890,3007,"You know, Vanessa Russo"],[3007,3136,"actually wasn't the only woman"],[3136,3303,"on the compound that night."],[3403,3607,"There was also the maid."],[4863,4984,"So you're saying Vanessa didn't save"],[4984,5146,"me that night. You did?"]],"37":[[50,100,"Well,"],[100,400,"I actually think that we saved each other."],[404,550,"The key holder canceled that night,"],[550,846,"and a nasty faction took over the club."],[1272,1447,"Hey,"],[1447,1576,"where are you going?"],[1697,1885,"Just to deliver these drinks."],[2022,2131,"I'm thirsty."],[2227,2264,"Yeah."],[2264,2510,"I think you should stick to water."],[2510,2694,"The fuck did you just say to me?"],[2694,2869,"I think you've had enough."],[3390,3524,"You think you can talk back to me, bitch?"],[3524,3699,"Get off me!"],[3699,3774,"Keep struggling."],[3774,3895,"I like it."],[4145,4254,"Somebody, please, help!"],[4254,4316,"Somebody?!"]],"38":[[425,583,"You were still breathing,"],[646,763,"but barely."],[1935,2081,"And so I dragged you to my car,"],[2081,2189,"and I dropped you off"],[2189,2289,"in front of a hospital."],[2289,2560,"And..."],[2560,2615,"Well, actually,"],[2615,2815,"I didn't know that you survived until"],[2873,3003,"now."],[3411,3570,"You saved my life."],[3753,3887,"Yeah, well, you saved me"],[3887,4029,"from something far worse than death."],[4029,4329,"You just didn't know it at the time."],[4408,4604,"When I get us out of here,"],[4683,4825,"I'll protect you."],[4867,5034,"I have a plan."],[5034,5205,"Just need to trust me."],[5305,5605,"Well, as I said before,"],[5668,5968,"I hundred percent don't."],[7178,7265,"Where the fuck"],[7265,7403,"do you think you're going?"]],"39":[[91,216,"What do you think?"],[216,375,"That's the grounds."],[375,675,"The ground access door is that way."],[763,955,"We need to be led through by security,"],[955,1092,"over there."],[1092,1222,"Or, you could go straight"],[1222,1522,"to the parking lot, access door, now."],[1680,1981,"And what if he doesn't let us through?"],[2014,2231,"Then I shoot all three of you"],[2231,2381,"on the spot."],[2381,2506,"Go!"],[3315,3511,"Tim and I should get this Chihuahua,"],[3511,3699,"bitch keeps shitting everywhere."],[4095,4200,"Whoa!"],[4200,4346,"Where's your badge?"],[4346,4521,"It’s her first day."],[4521,4637,"It's my new apprentice."],[4637,4859,"She doesn't have a badge yet, so."],[4859,5046,"Gotcha. One second."],[5046,5276,"Think I'm a fucking idiot?"],[5276,5355,"What?"],[5355,5484,"You think I'm a fucking idiot?"]],"40":[[179,262,"Okay."],[262,454,"You caught us."],[454,567,"When I found out that he works"],[567,804,"at the Five Nation compound, I..."],[804,984,"I forced him to sneak me in here"],[984,1105,"because I"],[1105,1205,"just wanted to see"],[1205,1505,"if it was as amazing as people say it is."],[1543,1614,"Yeah. Yeah."],[1614,1755,"I mean, I told her it was a bad idea."],[1755,1843,"So..."],[2494,2673,"So this is your boyfriend."],[2673,2848,"Yeah, we've been dating for few months."],[2848,2907,"Oh, yeah?"],[2907,2965,"Where did you meet?"],[2965,3144,"The Walmart fertilizer section?"],[3274,3370,"Excuse me?"],[3370,3486,"Oh, I know."],[3486,3657,"You picked him up outside a Home Depot,"],[3657,3895,"and it was love at first sight, huh?"],[3895,4037,"Dude, what is your problem?"],[4037,4116,"My problem is,"],[4116,4225,"there's no way a piece of shit"],[4225,4462,"like him gets a girl like you."],[4462,4763,"Unless you like small dicks."],[4934,5080,"You got something to say, mom boy?"],[5230,5447,"Can my girlfriend and I go through or not?"],[5447,5513,"Yeah, sure."],[5513,5580,"Once you prove to me"],[5580,5709,"she's your girlfriend."],[5880,6076,"How do you want us to do that?"],[6076,6264,"Kiss."],[6264,6393,"What?"],[6393,6510,"I'm not buying it."],[6510,6748,"I'm gonna need to see you two kiss."],[7328,7449,"Nah, this is bullshit."],[7449,7578,"I'm calling this off."],[7578,7665,"Wait wait wait wait wait."],[7665,7870,"Just give us a second."],[7870,7970,"He just gets nervous"],[7970,8158,"sometimes in front of people."],[8158,8333,"Just relax. Please."]],"41":[[1201,1288,"Okay."],[1288,1509,"Nice! Well done, bro."],[1509,1584,"So tell me how it is,"],[1584,1701,"how’d a nothing like you"],[1701,2014,"bag a fine piece of ass-meat like you?"],[2089,2235,"Well, for starters, he didn't refer to me"],[2235,2360,"as a piece of ass-meat."],[2360,2602,"That was kind of big."],[2602,2727,"So can we go? Or..."],[2727,2932,"Yeah, sure. In a second."],[2932,3023,"First, Tim, what’s"],[3023,3199,"you gonna do out there?"],[3199,3307,"What?"],[3307,3449,"What are you gonna to do?"],[3449,3566,"You gonna get your knees all"],[3566,3691,"grassstained sucking him off?"],[3691,3803,"All right, man, that's enough."],[3803,3824,"Oh, no."],[3824,4033,"We're just getting started, lawn boy."],[4033,4266,"How’d you like to be with a real man?"],[4266,4383,"One that won’t get lawn clippings"],[4383,4521,"down your panties?"],[4521,4642,"I think I'll pass."],[4642,4817,"Come on, girl."],[4817,4946,"We don’t wanna be a McDonald's here"],[4946,5025,"when we can have"],[5025,5196,"a big old piece of prime rib."],[5196,5388,"I think you're confusing yourself for"],[5388,5559,"lunch meat, but that's okay."],[5676,5768,"How about you show me what"],[5768,6068,"you get underneath that jumpsuit?"],[6235,6373,"Oh..."],[6373,6468,"Don't fucking touch her."]],"42":[[33,250,"Who's a big man all of a sudden?"],[250,379,"News flash, bitch."],[379,483,"I'm a member of the Syndicate,"],[483,642,"so take your hands off me right the fuck"],[642,784,"now, or very bad"],[784,900,"things are going to happen to you."],[900,934,"Yeah."],[934,996,"Like what?"],[996,1038,"Like,"],[1038,1217,"I will personally use my power"],[1217,1272,"to ensure"],[1272,1472,"that the rest of your pathetic life"],[1472,1593,"is a living hell."],[1814,1926,"That's what I thought."],[1926,2102,"Fucking gardener."],[2102,2248,"Yeah,"],[2248,2318,"maybe I’m a gardener,"],[2318,2556,"but at least I don't suck at my job."],[2556,2748,"What's that supposed to mean?"],[2748,2915,"You are security, Right?"],[2915,3003,"Aren't you at least supposed"],[3003,3111,"to secure your keycard?"]],"43":[[604,905,"What the fuck are you doing?"],[913,1213,"I'm in, aren't I?"],[2606,2819,"Hey, wait wait wait wait."],[2819,2994,"Are you sure you want to do this?"],[2994,3061,"Once they get in,"],[3061,3219,"they're going to kill you."],[3219,3520,"Trust me."],[3849,4149,"Yeah, I 100% don't."],[4429,4583,"Door’s open."],[4583,4884,"Roll out."],[6231,6531,"Are you sure about this?"],[6698,6977,"You've been a good boy."],[6977,7169,"You can go."],[7169,7290,"Just like that?"],[7340,7469,"Just like that?"],[7586,7774,"Get the fuck out of here!"],[7903,8083,"Great."]],"44":[[79,379,"I really wouldn't do that if I were you."],[404,525,"Even a simpleton like you"],[525,750,"should have known this was coming."],[750,955,"We can't let you go."],[955,1167,"Nothing personal."],[1167,1397,"See, for me it is personal."],[1397,1618,"Your boss fucked my wife."],[1618,1801,"You should consider it an honor"],[1801,1960,"to have someone like Ivan Kalichnov"],[1960,2143,"fuck your wife."],[2143,2260,"It's not often royalty"],[2260,2560,"associates with peasants."],[2648,2844,"That's the thing right there."],[2844,2940,"Because if your boss"],[2940,3028,"would have associated"],[3028,3199,"with me a little more,"],[3199,3261,"you would have known that"],[3261,3370,"every member of the grounds crew"],[3370,3611,"was given an emergency alarm."],[3611,3912,"If I released this button for any reason,"],[4074,4325,"I get shot, right?"],[4325,4429,"Then every security member"],[4429,4500,"of the Five Nation"],[4500,4587,"Syndicate will descend"],[4587,4692,"upon your little group long"],[4692,4921,"before you ever reach the vault."],[4921,5080,"Remind me, how does"],[5080,5380,"the Syndicate treat traitors?"],[5384,5684,"I'm going to fucking kill you."],[5709,5826,"Sure."],[5826,6101,"But for now, you're going to do as I say."]],"45":[[41,229,"What do you want?"],[229,479,"First, you let her go."],[479,529,"Wait. What?"],[529,829,"I'm not leaving here without you."],[905,1030,"It's the only way."],[1030,1130,"No."],[1130,1197,"Venture in that vault,"],[1197,1292,"they're going to kill you."],[1292,1380,"You need to go."],[1380,1659,"Grayson, I'm not just gonna let you die."],[1659,1956,"Hey, trust me."],[1956,2160,"I don't."],[2160,2460,"100%?"],[2494,2677,"100%."],[2677,2756,"What is that, tear?"],[2756,2840,"No."],[2890,2944,"It's not what that is."],[2944,3007,"Are you crying?"],[3007,3128,"No!"],[3261,3370,"Look,"],[3370,3507,"I'll be okay"],[3507,3774,"as long as nothing happens to you."],[3774,4074,"Go."],[4537,4838,"Wait."],[7478,7582,"Let's do this."]],"46":[[58,358,"Let's do this."],[2131,2264,"You know,"],[2385,2573,"once we’re in the vault,"],[2573,2765,"it won't matter if you push that button"],[2765,2898,"or not."],[2986,3144,"Actually,"],[3144,3286,"I never did."],[3299,3457,"What?"],[3457,3541,"Yeah."],[3541,3607,"You know,"],[3607,3716,"why would they give me"],[3716,3870,"an emergency alarm?"],[3870,4066,"I'm just the gardener."],[4066,4237,"All that happens if I press this,"],[4300,4425,"my garage opens."]],"47":[[496,721,"Wait wait wait."],[721,863,"Put the gun down."],[921,1142,"We are going to fucking kill you."],[1142,1259,"You first."],[1380,1530,"Okay. Okay."],[1530,1755,"Lower your guns."],[1755,1960,"Do it!"],[2122,2268,"Get the key card."],[3870,4129,"So what’s the plan now, genius?"],[4129,4212,"That door will hold them"],[4212,4437,"for all of three minutes."],[4437,4558,"Three minutes is all I need."]],"48":[[621,809,"What the fuck"],[809,1046,"happened here?"],[1584,1701,"He..."],[1701,1885,"He tricked us!"],[1885,2118,"You fucking idiot!"],[2118,2281,"Where is he?"],[2281,2410,"What do you mean?"],[2410,2711,"I mean, where is he?"],[2727,2890,"He's here."],[2890,3169,"He's in here somewhere."],[3169,3490,"If you screw this up, Ivan kills us both."],[3586,3787,"Calm down."],[3787,4070,"Gardener does not matter."],[4070,4291,"We have that."],[4884,5167,"Ivan won't care about the gardener"],[5167,5367,"once he knows he has full control"],[5367,5609,"of the Five Nations Syndicate."],[5864,6164,"No. More. Fuckups!"],[6544,6740,"Who the fuck is the gardener?"]],"49":[[342,442,"How much longer are we gonna"],[442,521,"have to wait for the leader"],[521,658,"reveal himself?"],[729,850,"We're going to give him the time"],[850,946,"he needs."],[1067,1184,"Hey, we're busy man."],[1197,1359,"Nico, we can’t just be waiting around."],[1564,1735,"Are you saying that I'm not busy?"],[1789,1922,"That your time is more valuable"],[1922,2072,"than mine?"],[2164,2285,"No, we can give him"],[2285,2369,"some more time."],[3870,3958,"Gentlemen,"],[4104,4258,"I have a very pressing matter"],[4258,4366,"to attend to."],[4608,4788,"You're one of the leaders here,"],[4846,5067,"surely not gonna leave the summit?"],[5146,5284,"I'll be back in a few minutes."],[5555,5709,"And when I get back,"],[5743,6043,"I'll show you how real I love this."],[7065,7152,"Ma’am."],[7344,7494,"I need you to come with me."]],"50":[[988,1121,"Almost through, Boss."],[1247,1363,"Very good."],[1434,1543,"Now,"],[1580,1718,"where's the gardener's body?"],[1801,1856,"Uh..."],[1918,2010,"Why?"],[2035,2139,"I wanna piss on it."],[2335,2523,"We have taken the gardener's body"],[2523,2823,"to be disposed of already, sir."],[3019,3153,"Fine, but get his head."],[3244,3353,"He's head?"],[3470,3545,"Why?"],[3566,3703,"I don't even want to socket fuck it."],[3703,3778,"I don't care. Just give me"],[3778,3878,"the fucking head!"],[3916,4033,"Sorry, sir."],[4066,4229,"We will get the head."],[4617,4800,"Good boy."],[5271,5347,"Boss,"],[5388,5492,"it's done."],[5609,5726,"You're now in control"],[5726,5885,"of the Five Nations Syndicate."]],"51":[[838,971,"Get it together."],[1343,1505,"Gentlemen,"],[1739,1893,"I have an announcement."],[1956,2173,"The true leader of the Five Nations"],[2173,2385,"Syndicate will be arriving"],[2402,2535,"shortly."],[3682,3870,"For too long, has our organization"],[3870,4070,"allowed for weakness to thrive."],[4104,4350,"Every decision a compromise,"],[4400,4692,"every plan of action, endlessly debated."],[4775,4959,"All of that ends today."],[4996,5080,"Today,"],[5109,5226,"a man of real strength"],[5226,5347,"takes control of the Syndicate."],[5480,5693,"A man no covert, hiding in shadows,"],[5693,5814,"could ever take down."],[7194,7349,"Hello, Ivan."]],"52":[[571,709,"I thought you were dead."],[796,946,"Sorry to disappoint."],[1109,1251,"How did you get in here?"],[1906,2002,"No."],[2089,2210,"No fucking way."],[2314,2489,"So those are the real golden keys?"],[2510,2619,"Oh, they're real."],[2811,2902,"Wow."],[3065,3169,"You really fooled us all,"],[3169,3253,"didn't you?"],[3353,3570,"Pretty impressive for a gardener."],[3691,4079,"But unfortunately, it was all for nothing."],[4162,4283,"My men will be chopping you up"],[4283,4458,"into pieces any minute now."],[4558,4646,"Shhhh."],[4742,4796,"Listen."],[7486,7599,"You know what that was?"],[7691,7816,"That was the sound of everything"],[7816,7970,"that you've worked for"],[7982,8095,"crashing down."],[8208,8383,"Now kneel, bitch!"]],"53":[[16,145,"I said kneel."],[617,729,"You're going to kill me?"],[850,925,"No."],[992,1071,"Like I said,"],[1138,1263,"killing you is not enough."],[1322,1409,"I'm gonna march you into"],[1409,1564,"the summit, chained like a dog."],[1680,1826,"And humiliate you in front of"],[1826,1972,"everybody that you care about,"],[1972,2022,"including"],[2131,2252,"my ex-wife."],[2364,2515,"And destroy your entire"],[2515,2635,"branch of the Syndicate."],[2706,2819,"The Kalichnov name"],[2819,3007,"will be nothing more than a sad joke,"],[3040,3132,"and a warning"],[3157,3265,"to anybody foolish enough"],[3265,3378,"to go against me."],[3424,3499,"And then"],[3524,3670,"after all that,"],[3724,3895,"if you asked me real nicely,"],[3920,4029,"then maybe I'll kill you."],[4166,4346,"Please, okay?"],[4371,4458,"I promise."],[4500,4587,"I'll be your bitch."],[4587,4725,"I'll be a good little soldier."]],"54":[[642,771,"[Russian] Bitch！"],[1092,1205,"Gentlemen,"],[1263,1397,"it's time to take control."],[1743,2089,"The true leader of the Five Nations"],[2089,2389,"Syndicate is about to arrive."],[2481,2781,"And it is my nephew, Ivan."],[2869,2990,"I knew it."],[3123,3224,"Boris,"],[3340,3749,"could you please let Ivan know that"],[3812,3924,"any disrespect"],[3924,4099,"earlier was just a total"],[4099,4187,"misunderstanding, and..."],[4187,4333,"Ha. You're screwed."],[4333,4454,"Gentlemen,"],[4525,4738,"our new leader will show"],[4738,5050,"all who bend the knee mercy."],[5230,5292,"Aren't you all"],[5292,5417,"forgetting something?"],[5467,5759,"Vanessa Russo is to be crowned the"],[5759,5947,"Queen of the Five Nations."],[6018,6156,"You should all be bowing to her"],[6156,6252,"already."],[6289,6385,"Now!"],[7469,7770,"You dare disrespect"],[7778,7991,"the new Queen of the Five Nations?"],[7991,8128,"On the contrary,"],[8174,8370,"I did most respect for the new queen."],[8441,8521,"In fact,"],[8566,8675,"my men are escorting"],[8675,8750,"her in now."]],"55":[[579,754,"What the fuck is she doing here?"],[754,934,"Show some respect."],[971,1126,"You are speaking to the new Queen"],[1126,1222,"of the Syndicate."],[1463,1543,"The hell she is!"],[1543,1739,"She's just a waitress."],[1739,1868,"She's nothing."],[2022,2160,"Go get me a glass of champagne,"],[2160,2210,"bitch."],[2377,2489,"Oh, I don't do that anymore."],[2489,2752,"I don't know if you've heard, but"],[2769,2877,"I got a new job."],[2923,3090,"Complete with fake jewelry, I see."],[3090,3174,"Did you get that from my"],[3174,3332,"ex-husband to give you that?"],[3636,3774,"Put your gun down!"],[3774,3966,"Sorry, Ms. Russo,"],[3966,4108,"we can't allow you touch"],[4108,4266,"the Five Nations Pendant."],[4354,4575,"It's worth more than your life."],[4779,4913,"Is this some kind of fucking joke?"],[4967,5159,"Some disrespect to my family?"],[5226,5413,"What's going on, Nico?"],[5455,5601,"What's going on"],[5601,5780,"is the actual leader has chosen"],[5780,5922,"this new queen."],[5922,6006,"And it’s her."]],"56":[[50,233,"I’ve already told you,"],[233,446,"the new leader is Ivan!"],[446,554,"Really?"],[554,767,"Does he have the Five Keys?"],[829,1130,"He didn't need the keys."],[1255,1497,"While you were all bickering"],[1497,1826,"and waiting for your mysterious leader"],[1826,1943,"to come,"],[1943,2214,"Ivan and his men break in,"],[2214,2410,"take over the vault."],[2464,2802,"And they did it the old fashioned way"],[2802,3003,"with a blowtorch."],[3023,3232,"Ivan controls the vault."],[3232,3482,"He is now the new leader of the"],[3482,3586,"Syndicate."],[3603,3757,"Seriously?"],[3799,3999,"That is an offense punishable"],[3999,4112,"by death"],[4112,4337,"when the actual leader arrives."],[4383,4713,"When the actual leader arrives,"],[4713,5013,"he will be shot in the head."],[5042,5246,"You traitorous bastard!"]],"57":[[809,909,"Oh,"],[1005,1326,"that is a text from your new leader."],[1455,1755,"He and his men are on their way in."],[1922,2089,"Lower your gun, Brazzo."],[2289,2356,"See?"],[2406,2706,"And that wasn't too difficult now, was it?"],[2811,3111,"And as for you,"],[3157,3470,"trying to pass yourself off"],[3470,3636,"as the new queen."],[3657,3741,"Oh."],[3895,3966,"Well,"],[4020,4229,"maybe there is some way"],[4229,4517,"that you can make up for your"],[4517,4650,"disrespect."],[4959,5059,"I'd rather die."],[5964,6302,"That can definitely be arranged."],[6352,6423,"Boris. Let me."]],"58":[[70,141,"You don't think I know"],[141,254,"what's going on, do you?"],[358,533,"You're trying to steal Ivan from me."],[771,963,"Oh, I'm not into Russians."],[1059,1213,"I saw the way you looked at him"],[1213,1347,"when he walked in the room."],[1388,1518,"But it's not gonna work."],[1534,1584,"You see?"],[1584,1705,"He's never gonna leave me"],[1760,1872,"for a peasant whore."],[1914,2289,"It looks like you're gonna have to..."],[2302,2469,"What?"],[2473,2848,"Looks like you're gonna have to..."],[2861,2915,"What?"],[2961,3019,"Oh!"],[3453,3574,"Kill her!"],[3674,3974,"She is as loud as that dress."],[4291,4512,"Last chance."],[4512,4708,"Bend the knee or die!"],[4738,4950,"Yeah, I think I'll take the second option,"],[4950,5046,"but thank you."],[5555,5709,"Ivan, about time!"]],"59":[[392,554,"What are you doing here?"],[617,746,"Where's Ivan?"],[846,988,"This is all that's left of him."],[1939,2022,"Oh,"],[2068,2177,"and here."],[2398,2527,"Don't wanna lose that."],[2581,2744,"Lots of important contacts in there."],[2944,3094,"Took you long enough."],[3161,3319,"You pack a really mean left hook."],[3349,3461,"There to make it look real."],[3591,3695,"Is it time?"],[3828,3920,"It's time."],[4533,4654,"I have been calm."],[4750,4867,"I've been patient."],[4967,5080,"And I've been merciful."],[5251,5355,"But that ends now."],[5789,6001,"I'm the sole owner of the Five Keys."],[6081,6247,"And that makes me your leader."],[6619,6835,"I would demand unquestioning,"],[6835,7136,"unflinching loyalty"],[7228,7411,"and respect."],[7486,7774,"This is ridiculous!"],[7774,8137,"Are we really going to let a gardener"],[8158,8391,"and a waitress take over the"],[8391,8625,"Five Nations Syndicate?"],[8787,8913,"Speaking of."],[9626,9926,"Oh, look at you."],[9947,10210,"You think that you can steal"],[10210,10360,"a rich man's suit,"],[10360,10543,"and we don't know the difference?"],[10673,10977,"I know a whore when I see one."],[11886,11974,"Anyone else?"]],"60":[[204,392,"You gotta be fucking kidding me."],[437,571,"You're going to let this weakling"],[571,863,"of a man tell you what to do?"],[942,1034,"Marcy!"],[1292,1384,"Um..."],[1576,1851,"I think I'm gonna go ahead and quit."],[2135,2218,"Fine!"],[2227,2348,"You were shit anyway!"],[2515,2677,"He just killed your leader,"],[2711,2869,"you're not gonna do anything?"],[3445,3591,"Fucking cowards!"],[3732,3908,"You're going to let this gardener"],[3908,3983,"bend you over"],[3983,4149,"and make you his bitch?"],[4408,4512,"Tommy!"],[4587,4717,"I'm your sister."],[4717,4838,"You're flesh and blood,"],[4838,4975,"and you're going to let this dirty ass"],[4975,5201,"waitress whore take my rightful"],[5201,5292,"place as queen?"],[5326,5434,"Hey, Vanessa?"],[5455,5568,"Shut the fuck up!"]],"61":[[58,166,"Vanessa,"],[321,462,"bend the knee."],[496,579,"Grayson,"],[621,759,"don't be ridiculous."],[825,984,"Bend the knee."],[1117,1330,"But, I'm in a gown"],[1330,1447,"and that's demeaning."],[1488,1609,"Now."],[1664,1789,"After all the time we've spent"],[1789,1893,"together?"],[1981,2110,"Last chance."],[2619,2740,"You're gonna leave town."],[2848,3007,"And you're not gonna come back."],[3057,3315,"But, I was your wife!"],[3415,3561,"Was."],[3912,4004,"Russo,"],[4133,4262,"I want you out of here."],[4262,4387,"Take your sister with you."],[4421,4646,"Yes, sir."],[4646,4879,"No no no no no, you can't do this."],[4879,4988,"You can't do this."],[4988,5142,"I was supposed to be queen."],[5184,5296,"I have a new queen now."]],"62":[[375,513,"What's he doing now?"],[550,700,"Don't question the leader."],[700,875,"It's disrespectful."],[1514,1609,"Sarah."],[1680,1805,"I still don't trust you."],[1976,2131,"I guess you don't need this."],[2231,2398,"Touch it and you lose a finger."],[4800,4909,"It's time we take control."]]}