,"Edie or Luna again."],[3941,4074,"Careful, Trent."],[4079,4245,"You don't wanna make a scene"],[4245,4408,"and lose custody of"],[4408,4604,"precious Luna, do you?"],[4788,4954,"Oh, poor Trent."],[5030,5230,"Look at Edie having fun with"],[5230,5397,"guys her own age."],[5476,5563,"She's just so young."],[5563,5697,"She just doesn't get it."],[5847,5905,"But..."],[6143,6206,"I do."],[6252,6489,"Trent, don't let them take me."],[6531,6619,"Help!"]],"55":[[120,279,"Don't touch me, Val."],[763,838,"Edie?"],[905,996,"Where did Edie go?"],[1105,1222,"Isn't Edie supposed to be"],[1222,1317,"watching Luna?"],[1405,1509,"Where is my daughter?"],[1526,1605,"I'm gonna find them."],[1605,1672,"And when I get back,"],[1672,1826,"you get the fuck out of my house."],[2623,2731,"I promise to Trent I'd-"],[3028,3153,"Don't worry about Trent."],[3186,3253,"Once he finds out"],[3253,3361,"you almost killed his daughter,"],[3361,3516,"he'll skin you alive."],[3757,3841,"Where's Luna?"],[3899,4004,"I have to find her."],[4099,4229,"Luna's in danger."],[4733,4842,"Let me go, I have to-"],[4879,4934,"Let me go!"],[4934,5050,"Hey, shut up, bitch!"],[5743,5805,"Wait, wait."],[7136,7240,"Luna!"],[8458,8666,"Oh, oh my God, Luna!"]],"56":[[492,617,"Hey, it's ok, Luna."],[633,684,"I got you."],[809,892,"Hey, hey, hey."],[946,1021,"Hey, are you ok?"],[1021,1084,"Edie!"],[1142,1305,"You left my baby out here alone"],[1305,1388,"to die?"],[1388,1509,"Baby, baby."],[1655,1760,"Trent, I would never do that."],[1760,1843,"You have to believe me."],[1885,1985,"Believe you?"],[1997,2093,"You were supposed to take"],[2093,2248,"care of my baby girl!"],[2264,2360,"How dare you?"],[2360,2515,"She could have died!"],[2556,2719,"We both saw you drinking"],[2719,2873,"and flirting with those men."],[2894,2990,"I had one drink."],[3057,3236,"And then you took Luna away."],[3249,3432,"I don't remember exactly"],[3432,3524,"what happened after that,"],[3536,3657,"but I would never leave her alone."],[3657,3837,"Oh, stop trying to guilt-trap Trent"],[3837,4012,"into forgiving you, you sly snake-"],[4012,4104,"That..."],[4416,4487,"is enough."],[4717,4967,"Luna will tell us who did this to her."],[5180,5284,"Okay sweetheart, you point to"],[5284,5401,"who did this to you, alright?"]],"57":[[0,158,"Alright, sweetheart, you point to Daddy,"],[158,271,"tell us who did this to you."],[1051,1105,"No, uh."],[1163,1292,"No, no, Luna's confused,"],[1292,1422,"Edie's been manipulating her."],[1430,1668,"Trent, you saw it with your own eyes."],[1668,1814,"She was there stone drunk"],[1814,1964,"with three men when she was supposed"],[1964,2093,"to be watching Luna!"],[2093,2156,"I'm glad that you"],[2156,2252,"brought up those men."],[2339,2431,"Bring them over here!"],[2640,2731,"...hands off me."],[3361,3415,"So who did it?"],[3432,3561,"It was her, Mr. Rexroth."],[3616,3699,"Ms. Vasquez,"],[3699,3845,"she paid us to drug the nanny!"],[3895,4054,"That's right, Mr. Rexroth."],[4066,4229,"She gave us the drug and the money."],[4229,4371,"Look, it's right here."],[4621,4746,"Trent, this is not what it looks like-"],[4746,4971,"No, it is exactly what it looks like!"],[5017,5100,"You lied to me."],[5130,5276,"You drugged an innocent girl,"],[5276,5363,"and you put my daughter's"],[5363,5430,"life at risk,"],[5430,5576,"all just to get Edie out of my life!"],[5576,5739,"Trent, she is using you!"],[5764,5947,"She is only after your money."],[5947,6122,"She's, she's stolen from you."],[6177,6373,"Go ahead, search her right now!"],[7144,7340,"I can't lie to you anymore, Trent."],[7424,7582,"Go on, search me,"],[7615,7766,"then you'll have a reason to hate me."]],"58":[[725,884,"I don't need to search Edie."],[980,1080,"She has my trust."],[1080,1247,"She would never steal from me."],[1276,1413,"She saved Luna."],[1434,1664,"Thanks to her, my daughter is alive."],[1747,1776,"No, Trent,"],[1776,1864,"you've got to listen to me-"],[1864,2002,"No, no, no, you listen to me!"],[2047,2218,"Now, everyone here is witness"],[2218,2348,"to what you did here today."],[2381,2481,"You will never"],[2481,2623,"get custody of my daughter"],[2631,2815,"and you will never get a cent out of me."],[2848,3098,"And if I ever see you near Edie again,"],[3098,3215,"I will make sure every"],[3228,3361,"dirty tabloid in this city"],[3361,3520,"runs your picture front page."],[3570,3737,"Now, get this dirty witch"],[3737,3841,"out of my house! - Trent,"],[3866,4070,"Trent, you, you can't do this!"],[4124,4200,"Trent!"],[4245,4312,"God!"],[4875,4996,"Edie, good."],[5914,6006,"That's the first time that"],[6006,6181,"my daughter has spoken in 2 years."],[6272,6385,"Edie, you did this."],[6464,6569,"This is all thanks to you."],[6569,6694,"You saved my daughter, I..."],[6848,6952,"I knew you were special to her."],[6952,7023,"Trent."],[7065,7123,"Edie?"],[7123,7207,"Hey, Edie."],[7207,7286,"Hey, hey."]],"59":[[475,579,"Uh, where am I?"],[621,684,"Hey."],[771,850,"You passed out."],[934,1013,"You were drunk."],[1092,1180,"Trent, I'm sorry."],[1184,1297,"I never should've let"],[1297,1380,"Luna leave my side."],[1380,1468,"And I, and I"],[1468,1526,"never should've - Oh, no no."],[1526,1605,"had that drink."],[1618,1718,"Look, Luna is safe."],[1826,1922,"You saved her."],[1960,2143,"And by doing that, you saved me,"],[2243,2414,"in ways that you don't even know."],[2519,2644,"You wouldn't say that if you knew that"],[2644,2869,"I stole from you to save my brother."],[3319,3382,"Mm, no."],[3503,3599,"Trent, you're my boss"],[3599,3749,"and my dad's biggest enemy."],[3749,3908,"We'll ruin everything."],[4020,4237,"Okay, I don't care, Edie."],[4350,4446,"Now, tell me, do you?"],[4583,4708,"What kind of choice is this?"],[5255,5384,"Betray the man I love"],[5413,5526,"or lose my brother?"],[5668,5776,"No, you're not understanding."],[5776,5922,"My dad won't let us be together."],[5922,6068,"And everyone else will think that"],[6068,6277,"you're just some boss who seduced"],[6277,6481,"his 21-year-old assistant."],[6485,6531,"Don't you see?"],[6531,6660,"The world does not want us"],[6660,6748,"to be together."],[6748,6873,"Forget the world."],[6977,7119,"Tell me what you want, kid."]],"60":[[70,225,"Tell me what you want, kid."],[404,642,"Don't call me that."],[767,959,"I'll call you what you really are then,"],[1130,1272,"the only woman that I've ever"],[1326,1434,"really loved."],[1468,1514,"No."],[1514,1622,"And if that's scandalous,"],[1622,1701,"then so be it."],[1897,2077,"Something that feels so damn right"],[2077,2168,"can never be wrong."],[2168,2314,"You told me that, remember?"],[2327,2439,"I love you too,"],[2473,2635,"but I can't be with you."],[2690,2857,"Okay, if you don't feel the same,"],[2857,3036,"then tell me and I'll stop."],[3057,3140,"Once Trent finds out"],[3140,3236,"that I stole from him,"],[3236,3403,"he'll never wanna see my face again."],[3511,3570,"Maybe this is our"],[3570,3716,"last memory together."],[3870,4041,"Maybe just for this one night,"],[4079,4187,"we get to be..."],[4316,4387,"us."]],"61":[[1409,1530,"I'm your boss, Edie."],[1655,1814,"But I can't control myself"],[1814,1906,"when I'm around you."],[1906,2077,"I don't want you to control yourself."],[2168,2289,"I want you to have me,"],[2289,2394,"every part of me."],[2427,2560,"I'm not a boy you can play with."],[2873,3057,"I'm a man who takes what he wants,"],[3057,3199,"and claims what he needs,"],[3933,4045,"and never lets go."],[4692,4842,"I wasn't supposed to fall for you,"],[4884,4984,"Mr. Rexroth."],[5138,5196,"But,"],[5309,5492,"falling's never felt this good."]],"62":[[1163,1213,"Trent,"],[1393,1564,"why did you stand up for me back there?"],[1659,1830,"What if I did steal your drive?"],[1947,2018,"You wouldn't."],[2102,2281,"The only thing I'd ever let you steal"],[2281,2364,"is my heart."],[3082,3282,"And I can't lie to him anymore."],[3315,3449,"I have to confess something."],[3649,3803,"Something you might not forgive me for."],[4191,4258,"I did"],[4383,4450,"take your drive,"],[4558,4754,"the one with your business plans on it."],[4871,4946,"I'm sorry."],[5105,5205,"You betrayed me?"]],"63":[[79,183,"I'm sorry."],[900,1001,"You listen to me."],[1042,1197,"I did it to save Theo,"],[1259,1338,"my brother."],[1451,1597,"When my mom was dying,"],[1597,1668,"I promised her"],[1668,1760,"I would take care of him."],[1760,1805,"Your brother?"],[1805,1889,"I thought you were"],[1901,2089,"Jordan Van Der Zee's only child."],[2227,2369,"My brother Theo's"],[2369,2515,"always had a weak heart."],[2619,2798,"And my dad never"],[2798,2948,"really cared about him."],[3128,3215,"And then he"],[3215,3336,"threatened Theo's life"],[3411,3582,"to make me betray you."],[3928,4170,"I always knew Jordan Van Der Zee"],[4170,4279,"was a despicable man,"],[4279,4366,"I just never thought"],[4366,4466,"that he'd use his daughter"],[4466,4587,"against me like this."],[4617,4746,"Well, he never loved us."],[4863,4959,"Trent, what you have with"],[4959,5084,"Luna's really special."],[5176,5317,"You are really special."],[5593,5768,"I'm so sorry I did that to you."],[6539,6648,"You have 1 hour."],[6673,6781,"Bring Trent's drive"],[6781,6969,"or it's goodbye Theo forever."],[6969,7107,"He might actually kill him."],[7486,7628,"You need to leave, Edie."],[7732,7778,"Now."],[7982,8095,"This is the end of us."],[8166,8299,"He's never forgiving me,"],[8370,8495,"and there's nothing I can do"],[8495,8583,"to make him stay."]],"64":[[0,79,"Take this."],[216,287,"Save your brother."],[404,604,"Look, if losing my empire"],[633,779,"is the price to keep you safe"],[779,859,"and your brother alive,"],[859,938,"then I'll pay it."],[1013,1113,"The only thing I care about"],[1113,1234,"is Luna and you."],[1234,1330,"You protected her."],[1372,1509,"It's my turn to protect you."],[1680,1776,"Thank you."],[2848,2965,"There she is."],[2990,3169,"Daddy's little thief."],[3249,3507,"You're a true Van Der Zee today, Edie."],[3553,3803,"Everything I need to destroy"],[3828,4225,"billionaire CEO, the Trent Rexroth."],[4300,4383,"Is right here"],[4383,4600,"in my daughter's pretty little hands."],[4671,4742,"Where's Theo?"],[4821,4888,"The hospital said"],[4888,5009,"you had him discharged."],[5050,5171,"I brought you the drive,"],[5221,5351,"I want to see my brother,"],[5367,5655,"Not until I verify your loyalty, sweetie."],[5868,6072,"Trent thinks he's unstoppable, huh?"],[6143,6268,"I'm gonna bring down his"],[6268,6460,"billion-dollar empire"],[6485,6706,"one goddamn byte at a time."],[7720,7953,"You brought me a fucking empty shell?"],[7995,8108,"You're trying to trick me, huh?"]],"65":[[0,91,"You're trying to trick me?"],[91,166,"I didn't know."],[187,279,"You bitch!"],[475,563,"Thought you could bring me"],[563,650,"a hollow toy"],[650,729,"and walk away with"],[729,838,"your worthless brother?"],[838,930,"I didn't know."],[930,1071,"I did not know"],[1071,1180,"that the drive was empty."],[1180,1338,"I just wanted to see Theo."],[1388,1655,"Well, let's go see him then."],[1960,2047,"Oh, my God."],[2060,2173,"Theo, honey."],[2189,2235,"Hey."],[2243,2373,"Okay, stay with me now."],[2394,2460,"Stay!"],[2577,2681,"How could you?"],[2744,2936,"You know he needs surgery to survive."],[2977,3136,"We're your kids, Dad."],[3136,3274,"You did this to your own children."],[3274,3353,"You're nothing but a"],[3353,3595,"warm body Trent Rexroth used."],[3603,3732,"And now you'll die with your"],[3732,3862,"precious brother."],[3862,4120,"Unless you call your sugar daddy"],[4120,4225,"and beg him to show up with the"],[4225,4312,"real thing."]],"66":[[0,150,"The minute I pull this cord,"],[150,296,"your brother dies."],[312,487,"If you want Theo to live,"],[538,642,"call Trent."],[688,784,"If he doesn't walk"],[784,913,"through that door with it,"],[942,1034,"you both die!"],[1067,1259,"Okay, okay, stop, stop!"],[1359,1447,"I'll do it."],[2344,2535,"Trent, where are you?"],[2548,2631,"I need you."],[2794,2957,"Your lover is not coming!"],[2977,3065,"He's probably"],[3065,3249,"screwing some other spoiled brat"],[3249,3374,"in his penthouse."],[3766,4087,"I have no use for you, baby girl."],[4129,4333,"You know all my secrets."],[4362,4525,"It's time for you to go."],[4892,5142,"Step away from my girl."]],"67":[[513,658,"He's all yours, officers."],[1534,1664,"I always knew you were a lousy"],[1664,1789,"businessman, Jordan."],[1789,2002,"But you are a far worse human being."],[2047,2156,"You disgust me."],[2189,2348,"You're nothing without me, Edie!"],[2348,2464,"I made you!"],[2464,2665,"You'll always be a Van Der Zee!"],[2694,2890,"You think Trent cares about you?"],[2890,3019,"That's bullshit!"],[3040,3199,"Men like him can never love!"],[3199,3349,"Your daughter is nothing like you."],[3390,3732,"She's smart, and kind, and perfect."],[3778,3887,"And I'll spend the rest of my life"],[3887,4020,"showing her that I can love,"],[4066,4162,"because of her."]],"68":[[216,354,"I'm so sorry that I'm late."],[354,404,"No, it's okay."],[404,492,"When you got hurt,"],[492,646,"the, the tracker in the drive"],[646,804,"stopped working and we lost signal."],[804,859,"It's okay."],[942,1071,"I had to get hurt for us"],[1071,1197,"to get rid of him for good."],[1255,1409,"Now, stop apologizing"],[1409,1509,"and kiss me."],[1664,1730,"No!"],[1818,1897,"No, Rexroth!"],[1897,2085,"You'll die before you get my daughter!"],[2773,2819,"Hey..."],[2848,2915,"Oh my God."],[2940,3082,"Hey, hey, hey, hey."],[3094,3219,"Hey, hey, listen to me."],[3253,3361,"You have to take, take Theo"],[3361,3474,"to the hospital, okay?"],[3486,3603,"No, I'm not leaving you."],[3620,3661,"Please."],[3661,3766,"No, no!"],[3791,3870,"Please, go."],[3887,4058,"No, stay, stay with me."],[4166,4283,"Please."]],"69":[[721,796,"Oh my God."],[821,988,"Hey, you're awake."],[1042,1146,"Oh my God."],[1247,1434,"Oh, I'm sorry, I'm sorry, I'm sorry."],[1434,1493,"Hey."],[1530,1655,"How long have you been here?"],[1714,1780,"Uh."],[1918,2047,"4 days."],[2118,2298,"But it felt like forever."],[2339,2489,"Wait, what about Luna and Theo?"],[2489,2540,"Are they okay?"],[2540,2673,"Oh, they're fine, they're fine."],[2702,2827,"Luna's waiting for you at home"],[2827,3207,"and, Theo's surgery was a success."],[3244,3395,"The hospital wouldn't take money"],[3395,3674,"from Trent Rexroth's family."],[3745,3866,"What can I say?"],[3924,4045,"Helps to be charming."],[4316,4441,"There's something else."],[4600,4742,"That day when you brought the drive"],[4742,4833,"to your dad,"],[4913,5025,"I called my lawyer."],[5226,5284,"Lawyer?"],[5296,5380,"For, for what?"],[5438,5663,"Um, check your inbox."],[6051,6281,"Change of legal guardianship,"],[6331,6468,"Theo Van Der Zee."]],"70":[[4,145,"Trent, what's this about?"],[221,446,"You're Theo's legal guardian now."],[546,671,"You're in charge now, Edie."],[709,821,"Of your life and Theo's,"],[821,950,"no one can ever take that away"],[950,1042,"from you again."],[1063,1238,"Oh, how can I ever repay you?"],[1380,1514,"Well, I think I have an idea."],[2456,2527,"Hey."],[2631,2723,"Hi."],[2877,2973,"I thought you'd be"],[2973,3111,"preparing for the party,"],[3140,3215,"we gotta celebrate"],[3215,3357,"you getting custody of Luna."],[3395,3528,"Well, I was hoping we might"],[3528,3724,"have 2 reasons to celebrate."],[3928,4054,"Edie Van Der Zee,"],[4108,4245,"the minute you walked into my life,"],[4245,4404,"you stole my wallet,"],[4521,4587,"my peace,"],[4825,4909,"and my heart."],[5038,5163,"So will you finish the heist,"],[5447,5543,"by marrying me?"],[6131,6247,"If I say yes,"],[6327,6418,"does that mean I get to"],[6418,6519,"keep your heart?"],[6519,6731,"Only if you promise to keep it forever."],[6790,6848,"Yes!"]]}