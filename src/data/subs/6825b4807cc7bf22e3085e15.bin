{"1":[[91,200,"Three years ago,"],[200,375,"I lost my parents in an accident."],[446,646,"It was Sandra Miller, my godmother,"],[646,738,"who took me in."],[842,950,"She gave me a home,"],[980,1105,"with her golden boys,"],[1105,1209,"the Miller brothers."],[1272,1447,"I felt loved in their kindness."],[1526,1639,"We were inseparable."],[1718,1856,"They felt like big brothers,"],[1906,2143,"and sometimes more than that."],[2173,2273,"Sandra used to joke"],[2273,2419,"I'd marry one of them someday."],[2502,2598,"And honestly,"],[2627,2765,"part of me hoped she was right."],[2811,2915,"Happy birthday, Daisy."],[2961,3028,"What are you waiting for?"],[3028,3078,"Come on in."],[3828,4037,"Caleb, Dylon, you got me a birthday cake?"],[4037,4120,"But everything changed"],[4120,4250,"the moment Lola moved in."],[4333,4571,"Happy birthday, Lola!"],[4629,4846,"Everyone thinks she's innocent,"],[4846,4975,"but I see her true colors."],[4975,5067,"Happy birthday, Lola."],[5271,5355,"What are you doing here?"],[5401,5518,"What's she doing here?"],[5559,5680,"You promised we'd always"],[5680,5822,"spend our birthdays together."],[5880,6006,"It's my birthday, too."],[6031,6206,"Can't we just celebrate"],[6239,6302,"a little?"],[6302,6398,"Seriously?"],[6435,6581,"So you're crashing Lola's party"],[6581,6669,"just because we didn't"],[6669,6765,"plan anything for you?"],[6819,6944,"Grow up, Daisy."],[6944,7032,"Lola's never had"],[7032,7144,"anything like this before."],[7161,7286,"Can you just let her have her day"],[7307,7390,"for once?"],[7457,7691,"Caleb, Dylon, it's okay."],[7691,7757,"I get it."],[7757,7887,"I'm just the maid's daughter."],[7887,7991,"She's doing it again. - Daisy's hated me"],[7991,8041,"from day one"],[8041,8133,"and if it really bothers her"],[8133,8258,"that much, I'll just cancel."],[8258,8445,"No, no, you're not the problem, okay?"],[8445,8525,"She is."],[8525,8654,"Not everything is about you."],[8679,8846,"You weren't invited."],[8879,8946,"Leave."],[9722,9838,"Wait, that's Daisy."],[9838,9922,"Lola told me"],[9922,10018,"she stole the school's"],[10018,10118,"donation money."],[10151,10239,"She's the worst."],[10239,10301,"Caleb!"],[10368,10431,"Dylon!"],[10556,10702,"I can't breathe."]],"2":[[684,746,"Caleb."],[888,959,"Dylon."],[1055,1146,"You guys came."],[1280,1347,"Thank you."],[1409,1593,"Unbelievable."],[1651,1843,"One decent thing happens for Lola"],[1843,2027,"and you pull a fake asthma attack?"],[2027,2093,"I can't believe you tried"],[2093,2223,"to ruin her special day."],[2273,2473,"I tried to ruin her special day?"],[2548,2652,"You locked me out"],[2652,2790,"so she could have her moment."],[2811,3065,"I collapsed and you didn't even flinch."],[3144,3278,"How am I the bad guy?"],[3303,3528,"Always twist things."],[3528,3636,"You haven't had an asthma attack"],[3636,3724,"in months."],[3753,3845,"Hell, you probably don't even"],[3845,3974,"have asthma anymore."],[4045,4200,"You have an inhaler."],[4258,4325,"Lola, well,"],[4325,4441,"she's never had a birthday party"],[4441,4529,"in her life."],[4546,4637,"She deserved today"],[4637,4721,"and you ruined it."],[4721,4829,"Hey, you know,"],[4921,4975,"Lola couldn't even"],[4975,5046,"eat her birthday cake"],[5046,5167,"she was so worried about you,"],[5167,5267,"I mean, that's the kind of person"],[5267,5326,"that she is."],[5334,5588,"I understand that maybe you're used to"],[5588,5709,"being the center of attention."],[5722,5872,"Or maybe you look down on Lola"],[5872,5997,"because she's just the maid's daughter."],[5997,6043,"No."],[6043,6131,"Because she's a better person"],[6131,6227,"than you'll ever be."],[6243,6456,"Lola is genuine and kind."],[6535,6844,"You're so fake and we are so sick of it-"],[6844,6936,"That's not true."],[6936,7073,"I, I've never been-"],[7073,7165,"Cut the crap!"],[7219,7340,"God, did you not think"],[7340,7453,"we'd see through it?"],[7453,7782,"All the fake smiles and nice gestures."],[7782,7924,"All for a damn payout."],[7924,7995,"Neither one of us"],[7995,8149,"would ever choose to like you anymore."],[8212,8508,"God, you are so impossible to love."],[10189,10368,"What happened to us?"]],"3":[[354,437,"Hey, Daisy."],[467,583,"I'm just calling to let you know"],[583,930,"that your bed is super comfy"],[930,1121,"and your clothes,"],[1134,1326,"well, I think we can both agree"],[1326,1451,"that they look better on me."],[1505,1697,"I hope you don't mind that from now on,"],[1697,1939,"everything of yours will be mine."],[2056,2160,"Oh, and don't forget"],[2160,2302,"to check my story, okay?"],[2327,2498,"I posted it just for you."],[3795,4058,"You are so impossible to love."],[4758,4892,"So much for forever."],[5030,5117,"Three years,"],[5234,5334,"thrown away for somebody"],[5334,5538,"they've only known for six months."],[6327,6389,"Daisy?"],[6414,6519,"Aunt Hailey,"],[6544,6673,"you were right about New York."],[6710,6856,"I wanna move back to LA"],[6936,7027,"with you and Owen."],[7027,7215,"Oh, that is wonderful, sweetheart."],[7273,7361,"There's nothing..."],[7707,7857,"and nobody left for me here."]],"4":[[104,279,"I'm sorry it didn't work out, sweetie,"],[325,629,"but Owen is going to lose his mind"],[629,788,"when he finds out you're coming back."],[884,1076,"That boy has been head over heels"],[1076,1146,"in love with you"],[1146,1280,"since you two were kids."],[1380,1509,"He's always had your back."],[1543,1743,"Not like those Miller boys ever did."],[1785,1835,"And you know"],[1835,1956,"your mom was like a sister to me,"],[1956,2064,"so you always have a home"],[2064,2168,"here with me and Owen."],[2189,2281,"Thanks, Aunt Hailey."],[2314,2498,"So I will book a first-class ticket."],[2498,2602,"Everything will be ready"],[2602,2702,"by the time you get back."],[3307,3399,"Well, don't just stand there."],[3399,3516,"Get the guest room ready."],[3591,3762,"My darling Daisy is coming home."],[4729,4988,"Three days from now, they'll be gone."],[5196,5321,"Will they even care?"],[7219,7369,"Oh my god."],[7432,7532,"Are you okay?"],[7645,8049,"Actually, serves you right."]],"5":[[241,392,"What the hell is wrong with you?"],[412,492,"Caleb and Dylon"],[492,604,"gifted me these clothes."],[604,775,"You can't just steal my stuff."],[775,884,"Oh, relax."],[913,1151,"So I borrowed a few of your things."],[1213,1376,"Didn't I already tell you?"],[1376,1743,"Everything you have will be mine."],[1785,1914,"Even the Miller boys."],[1939,2206,"And they'll hand it all over to me"],[2239,2502,"with a smile on their face."],[2502,2619,"Don't touch me!"],[2673,2744,"Learn about March,"],[2744,2836,"everything in February..."],[2932,3094,"Daisy, please, please don't hit me."],[3094,3294,"I'm sorry for messing up your clothes."],[3541,3682,"What the hell do you think you're doing?"],[3737,3849,"Lola, are you okay?"],[3849,3924,"I'm sorry."],[3924,4016,"I didn't mean to mess up"],[4016,4108,"your clothes."],[4108,4183,"My mom asked me to"],[4183,4283,"help her wash them."],[4320,4362,"Please don't be mad."],[4362,4466,"I'll fix it I promise - Hey."],[4466,4542,"It's not your fault."],[4542,4612,"Ok, you shouldn't be washing"],[4612,4733,"her damn clothes."],[4767,4900,"I mean, Daisy, what the hell?"],[4900,5046,"Her mom is the maid."],[5046,5105,"But that doesn't mean"],[5105,5217,"you can walk all over her."],[5217,5330,"It's not what it looks like."],[5330,5405,"I didn't."],[5405,5576,"God, why are you so evil?"],[5576,5705,"Apologize to Lola."],[5705,5751,"Now."],[6160,6272,"I did nothing wrong."],[6360,6489,"Why should I apologize?"]],"6":[[20,125,"It's okay, guys."],[125,216,"It, It's my fault."],[216,346,"I only wanted to help my mom"],[346,538,"and I ended up making Daisy mad."],[571,709,"I can't do anything right."],[784,880,"You're too hard on yourself, Lola"],[975,1217,"But Daisy, if you don't apologize,"],[1234,1343,"you can pack your shit"],[1343,1455,"and get the hell out of here."],[1455,1501,"Hey."],[3048,3161,"Welcome home, Daisy."],[3161,3282,"I'm so glad you're finally here."],[3303,3432,"You can stay with us forever."],[3453,3611,"Okay, this is your home now, princess."],[4316,4408,"So that's it, huh?"],[4596,4704,"Do you guys remember"],[4758,4938,"when I first came here three years ago"],[4938,5005,"what you said?"],[5025,5180,"You said I'd always have a home here."],[5180,5347,"Yes, and I'm giving you a choice."],[5409,5555,"You can either apologize to Lola"],[5593,5714,"or get the fuck out."],[5714,5764,"Dylon!"],[6360,6523,"Everything's ready, sweetheart."],[6539,6681,"Owen will pick you up at the airport"],[6681,6773,"in three days."],[6802,6881,"And don't forget,"],[6881,7027,"make sure your transfer papers"],[7027,7115,"are squared away."],[7132,7190,"Transfer?"],[7328,7394,"Transfer?"],[7607,7707,"Where are you going, Daisy?"]],"7":[[41,150,"I mean, did I hear that right?"],[171,237,"Airport."],[279,350,"Transfer."],[367,467,"Are you leaving us?"],[525,613,"Also, who the hell is Owen?"],[613,663,"Oh, come on."],[721,809,"It's probably some actor"],[809,963,"she's paying to play her new man."],[1030,1071,"She's probably"],[1071,1188,"planning a dramatic stunt"],[1188,1284,"to get our attention."],[1326,1422,"It's pathetic."],[1543,1614,"See these?"],[1730,1872,"You don't deserve any of them."],[1872,1951,"Daisy, come on."],[1951,2047,"Don't make a scene."],[2227,2477,"Just apologize and we'll forgive you."],[2727,2986,"It's okay, Caleb, Dylon."],[3098,3211,"Daisy can have her room back."],[3211,3365,"I'll just move back into the basement."],[3365,3415,"It's fine."],[3432,3503,"Wait."],[3607,3749,"You moved into my room?"],[4863,4938,"You got it."],[4938,5000,"Okay."],[5005,5238,"And right over here."],[5238,5284,"Here?"],[5292,5355,"And..."],[5355,5422,"Tell me when."],[5534,5605,"Ta-da!"],[5647,5739,"Surprise!"],[5976,6093,"It's beautiful!"],[6164,6406,"Is, is this really my room?"],[6406,6544,"Hoping you'd like the pink."],[6685,6740,"Do you?"],[6952,7040,"We got you something."],[7161,7236,"Hope you like it."],[7453,7549,"Oh my God!"],[7603,7703,"I love it!"]],"8":[[37,150,"They really did it."],[362,429,"Daisy."],[884,1017,"She could have any room."],[1017,1096,"Why mine?"],[1176,1292,"Wake up, Daisy."],[1351,1463,"You're a parasite!"],[1476,1655,"Everything you eat, wear, touch,"],[1655,1780,"we gave you!"],[1780,1893,"Lola, on the other hand,"],[1922,2085,"she actually earned a place here."],[2168,2331,"This is what you get for bullying Lola."],[2452,2552,"Okay, I'm your godbrother."],[2552,2727,"It is my job to teach you"],[2727,2823,"right from wrong."],[2852,3086,"Caleb, Dylon, maybe this has gone too far."],[3086,3194,"I don't wanna get in between"],[3194,3269,"what you three have-"],[3269,3395,"No, it's okay, Lola."],[3395,3516,"You deserve the bigger room."],[3516,3620,"You hear that, Daisy?"],[3674,3874,"You trashed Lola behind our backs."],[3899,4041,"And she still tries to protect you."],[4074,4175,"We spoiled you,"],[4212,4421,"and it turned you into an entitled brat."],[4462,4542,"Starting today,"],[4596,4704,"you're moving to the basement."],[4771,4863,"So pack your shit."],[4904,5050,"And when you finally start learning"],[5050,5201,"how to treat people right,"],[5276,5351,"then we can talk about"],[5351,5459,"moving you back upstairs."],[5459,5580,"That won't be necessary."],[5872,5993,"She can have my room."],[6114,6239,"Along with all my stuff."],[6239,6339,"I'm giving it all back."],[6523,6644,"I've known for a long time"],[6644,6740,"there's no place for me"],[6740,6831,"in this home anymore."],[6902,6998,"You hear that, bro?"],[7082,7323,"She still doesn't get it!"],[7369,7424,"We're not gonna"],[7424,7570,"put up with your attitude anymore!"],[7599,7857,"As far as harassing Lola is concerned,"],[7966,8112,"there better not be it next time."],[8337,8675,"There won't be a next time."],[9025,9088,"And ,uh,"],[9209,9300,"what's that supposed to mean?"],[10039,10201,"Daisy, what the hell are you doing?"],[11232,11348,"Here's everything you thought"],[11348,11457,"I wanted from you."],[11478,11786,"All the money, the gifts, the legacy."],[11832,11970,"I'm giving it all back."],[12024,12303,"I don't want anything from you."]],"9":[[16,204,"God, you're so fucking dramatic!"],[229,354,"Just because you give that back,"],[354,454,"you think we can call it even?"],[454,550,"Hey, that's enough!"],[608,750,"Okay, we don't need your theatrics."],[775,934,"This whole act,"],[1121,1217,"it's pathetic."],[1664,1726,"Come on."],[1805,1868,"Let's go."],[4179,4316,"I got your room ready."],[4341,4471,"I recreated everything"],[4471,4587,"from when you were little."],[4621,4829,"Oh, and see these flowers?"],[4829,4963,"They're from Owen."],[4975,5080,"He insisted on"],[5080,5213,"picking them out himself."],[5213,5384,"I have never seen him get flowers"],[5384,5497,"for any girl before."],[5597,5680,"Daisies."],[5847,5935,"You remembered."],[6260,6489,"Caleb, Dylon,"],[6744,6827,"I'm done."],[6923,7073,"Just like you wanted."],[8608,8921,"Aww, what a cute picture!"],[9334,9405,"Give it back."],[9797,9905,"It's just a picture."],[9993,10085,"What's the problem?"]],"10":[[254,329,"These happy memories"],[329,429,"mean a lot to me."],[450,546,"Even if they don't mean"],[546,675,"anything to you anymore."],[871,1034,"Lola just wanted to see the picture."],[1092,1163,"Hey, why do you have to be"],[1163,1309,"so dramatic about everything?"],[1384,1555,"I'm so sorry, Daisy."],[1555,1605,"I..."],[1714,1835,"I guess I was just..."],[1918,2002,"jealous?"],[2018,2064,"The three of you"],[2064,2231,"have so many memories together."],[2231,2381,"And Caleb, Dylon, and I,"],[2381,2548,"we don't even have one photo together."],[2573,2706,"We can take some now if you want."],[2752,2811,"Really? - Yeah."],[3666,3770,"Oh my god!"],[3870,3987,"A Polaroid?"],[4258,4337,"Is this for me?"],[4441,4554,"Who else would it be for?"],[4596,4704,"You said you always wanted to decorate"],[4704,4842,"the locker pictures or something..."],[4963,5005,"You know."],[5159,5238,"Just remember"],[5271,5484,"this camera is just for the three of us."],[5509,5597,"Nobody else."],[5676,5730,"Come on,"],[5730,5789,"let's take one now. - Let's go."],[6214,6435,"We took this on the day I moved in."],[6740,6785,"And this,"],[6785,6990,"right after I had that asthma attack."],[7282,7428,"You stayed by my hospital bed"],[7428,7557,"for two nights."],[7966,8033,"Daisy."],[8316,8466,"Now I'm just the girl you hate."],[9146,9280,"You said we were family."],[9313,9463,"You said this meant something."],[9634,9751,"But it was all a lie."],[9897,10001,"Every word."],[10114,10210,"Every promise."],[10210,10372,"That's Daisy and the Miller Boys."],[10372,10452,"I thought they were tight."],[10452,10664,"Are they finally gonna cut Daisy off?"],[10664,10748,"I tried."],[10919,11061,"God, I tried."],[11282,11423,"But I can't keep screaming"],[11423,11590,"so that you might hear me cry."],[11891,12041,"Daisy, stop."],[12178,12328,"Daisy, stop."]],"11":[[588,663,"Daisy!"],[809,946,"I had no idea"],[946,1071,"that taking a photo with them"],[1071,1226,"would trigger you that much."],[1317,1443,"If it makes you feel better,"],[1589,1685,"you can slap me."],[2218,2356,"Let go of my hand!"],[3061,3115,"Lola!"],[3249,3357,"I'm so sorry!"],[3357,3432,"I had no idea"],[3432,3599,"I would upset her that much!"],[3920,3966,"I..."],[4371,4450,"Did he just..."],[4500,4633,"No freaking way."],[4863,4975,"Holy fuck."],[4975,5105,"Wait what, what the fuck?"],[5105,5221,"I thought those three were like,"],[5259,5330,"super tight."],[5330,5459,"I mean, you can't tell?"],[5522,5697,"Obviously Daisy had fallen out"],[5697,5784,"with the Miller Brothers"],[5784,5955,"and now Lola is the new it girl."],[6031,6093,"Daisy, I..."],[6164,6272,"Did you just hit me?"],[6781,7036,"You, you, you pushed Lola first."],[7061,7107,"I..."],[7203,7349,"If you hadn't gone so overboard,"],[7349,7515,"you know, I just, I wouldn't have lost it."],[7770,7866,"Just apologize to Lola,"],[7866,7962,"and then, and then we can"],[7962,8078,"call it a day, okay?"],[8287,8420,"I'm not apologizing."],[8445,8562,"Whoa, don't push it!"],[8604,8712,"If it wasn't for our family,"],[8712,8863,"you'd still be rotting on the streets."],[8921,9054,"Maybe that would have been better."],[9063,9175,"You ungrateful little-"],[9175,9259,"Hey that's enough!"],[9330,9409,"That's enough."],[9667,9776,"I'll apologize first."],[10018,10097,"I shouldn't have done that."],[10130,10268,"Okay, that was on me, really."],[10385,10439,"I'm sorry."],[10502,10539,"Okay?"],[10564,10735,"Just please, just let it go."],[10848,10985,"Lola's been through a lot."],[11136,11353,"You always wanted a cat, right?"],[11353,11461,"How about I get you a cat?"],[11498,11657,"Okay, I can get you any kind you want."],[11703,11795,"A cat?"]],"12":[[525,633,"You wanna take it home?"],[784,917,"We'll find her a better home."],[967,1076,"I'm allergic to cats."],[1405,1468,"Funny."],[1593,1697,"You don't even remember"],[1697,1835,"I'm allergic to cats."],[1860,2035,"That wasn't me that wanted a cat, Caleb."],[2210,2327,"You got me and somebody else"],[2327,2385,"mixed up."],[2435,2556,"Jesus, enough!"],[2581,2727,"God, what are you trying to prove?"],[2786,2948,"Quit testing our patience!"],[2957,3119,"Then stop talking to me!"],[3674,3803,"I'm done being anyone's"],[3803,3883,"second choice."],[3958,4074,"Why does this feel like"],[4074,4266,"I'm losing something I'll never get back?"],[4662,4725,"Caleb,"],[5009,5084,"Dylon."],[5359,5559,"I loved you both so much."],[5651,5751,"I would have taken a bullet"],[5751,5830,"for either of you."],[5901,6056,"Yet you still think of me as a villain."],[6285,6427,"I think it's time we all wake up."],[6489,6602,"What we had is gone."],[6806,6940,"And we're never getting it back."],[7465,7607,"Classic drama queen!"],[7640,7699,"Keep this up and we'll be"],[7699,7799,"gone for good."],[8229,8308,"She'll be back."],[8358,8404,"Yeah."]],"13":[[446,521,"Aunt Sandra!"],[771,896,"I thought you were gonna be in Europe"],[896,1063,"on a business trip for the next month."],[1063,1151,"Daisy, honey."],[1280,1363,"Your aunt called me"],[1363,1413,"and told me that"],[1413,1522,"you were moving back to LA"],[1522,1664,"so I got the first flight back."],[1710,1835,"Are you really leaving us?"],[2239,2406,"This is about Caleb and Dylon, isn't it?"],[2406,2502,"God, I knew something"],[2502,2669,"was off with you three when I left."],[2731,2869,"This is all my fault."],[2982,3107,"I promised your mom"],[3107,3203,"that I would take care of you"],[3203,3303,"like my own."],[3319,3499,"And I just let so much slide."],[3499,3557,"No."],[3578,3674,"No, no, no."],[3674,3862,"You are the best godmother"],[3862,3983,"I could ever ask for."],[4016,4141,"You've treated me like family"],[4141,4216,"since day one."],[4216,4312,"I'll never forget that."],[4717,4846,"Here's a little something"],[4846,4921,"I saved up."],[5005,5130,"It's not much,"],[5130,5288,"but I want you to have it"],[5288,5367,"as a thank you."],[5417,5605,"Sweetheart, don't do that."],[5697,5851,"You're not gonna cut ties"],[5851,5968,"with me altogether, right?"],[5980,6093,"Just keep the money."],[6118,6268,"You know, I always, always dreamed"],[6268,6339,"that you would end up with"],[6339,6418,"one of my sons,"],[6418,6556,"but now I see."],[6581,6794,"Those two idiots don't deserve you."],[6881,7048,"You were always too good for them."],[7094,7265,"You sweet Daisy princess."],[7340,7478,"You deserve something better."],[8270,8383,"Before you give anyone"],[8383,8500,"your heart, sweet,"],[8600,8700,"make sure you've given it"],[8700,8800,"to yourself first."],[8900,9000,"I promise."],[9726,9797,"Here,"],[9834,10001,"It's 50 grand for you."],[10001,10135,"Don't argue."],[10135,10214,"Just take it."],[10239,10406,"Use it to start the life you deserve."],[10414,10485,"You, uh..."],[10485,10539,"have somebody"],[10539,10677,"waiting for you in LA, don't you?"],[10698,10814,"Owen Gray?"],[10948,11015,"Maybe someday"],[11015,11211,"you'll forget my idiot sons altogether."],[11269,11357,"And who knows?"],[11373,11599,"You and Owen might even start dating."],[11682,11749,"Dating who?"]],"14":[[367,421,"Mom."],[496,558,"What are you talking about?"],[558,650,"Who's Daisy dating?"],[650,759,"It's none of your business."],[859,930,"It's not like you two"],[930,1059,"care about Daisy anyways."],[1092,1238,"Running your mouth to Mom again?"],[1255,1284,"Huh?"],[1284,1376,"Trying to play victim?"],[1438,1555,"Mom, don't listen to a word"],[1555,1701,"she says, alright?"],[1701,1785,"The birthday party,"],[1785,1926,"that's because she deserved it."],[1947,2031,"And the room?"],[2035,2210,"Well, I mean, that was a punishment."],[2239,2356,"Daisy put that on herself."],[2356,2498,"Yeah, I mean, Lola's a good girl."],[2498,2631,"We're just trying to look after her."],[2631,2694,"That's all."],[2769,2902,"You really don't believe everything"],[2902,3015,"that Daisy's telling you, right?"],[3040,3199,"Daisy didn't say anything."],[3219,3399,"God, you two are so stupid."],[3399,3553,"Daisy, I never meant to come"],[3553,3749,"between you and Caleb or Dylon."],[3795,3974,"Please don't say things to Mrs. Miller"],[3974,4037,"just to make me look like-"],[4037,4149,"Shut your mouth!"],[4229,4329,"Letting your mom bring you here"],[4329,4437,"was a big mistake."],[4437,4592,"Mom, that's not fair."],[4637,4700,"Okay, I don't know"],[4700,4859,"what Daisy has been telling you,"],[4888,5000,"but you're wrong about Lola."],[5038,5201,"Okay, I know, she's the maid's daughter,"],[5201,5317,"but she's honest with us."],[5317,5593,"She actually cares about this family."],[5618,5714,"She cares?"],[5818,5980,"I'm not blind like the both of you."],[6018,6214,"Daisy is the only one that actually"],[6214,6327,"cares about you both."],[6981,7032,"Really?"],[7182,7311,"Because she's only after our money."],[7349,7415,"I mean, look at her,"],[7415,7540,"taking another check from you?"]],"15":[[37,87,"Exactly."],[87,154,"And let's not forget"],[154,304,"about the tantrums, alright?"],[304,483,"And all the lies she's fed to us."],[483,675,"Not to mention the way she bullied Lola."],[675,796,"I don't care what she says."],[867,992,"She's no sister of mine."],[1009,1205,"What the hell is wrong with you two?"],[1205,1405,"Have you completely lost your minds?"],[1405,1584,"Mom, Lola isn't the villain here."],[1593,1751,"Please don't let Daisy get in your head."],[1751,1960,"God, you ungrateful bastards!"],[1960,2097,"Do not call me mom."],[2097,2302,"I do not have stupid sons like you."],[2423,2489,"And her?"],[2610,2802,"You get the snake out of my house."],[2836,2915,"Mrs. Miller-"],[2915,3044,"Get out!"],[3395,3440,"Come on."],[3891,3970,"Watch your back."],[4020,4124,"This isn't over, Daisy."],[4738,4825,"Daisy, honey."],[4854,5146,"I am so, so sorry."],[5192,5501,"Those two idiots treated you so bad."],[5501,5643,"You didn't deserve any of it."],[5676,5784,"It's not your fault."],[5830,6006,"Now you see why I have to leave."],[6076,6264,"I can't stay here anymore."],[6297,6389,"I know, honey."],[6406,6485,"You promised me"],[6485,6623,"that you'll take care of yourself"],[6623,6715,"when you get to LA."],[6781,6890,"And call me often."],[6927,6994,"I will."],[7048,7148,"I'll come visit too."],[7198,7328,"Today is my last day at school."],[7399,7478,"The transfer has already"],[7478,7553,"been approved."],[7682,7803,"I'll be gone after this."]],"16":[[525,592,"Daisy!"],[829,984,"I already said I was sorry."],[1026,1155,"Why did you have to go to Mrs. Miller?"],[1155,1284,"What more do you want from me?"],[1317,1397,"Can we just stop?"],[1497,1584,"I'm tired."],[1584,1680,"Just leave me alone."],[1680,1801,"Didn't I warn you?"],[1801,1922,"You fuck with Lola again,"],[1922,2027,"and you'll regret it."],[2047,2106,"Alright?"],[2106,2260,"We let shit slide last time."],[2260,2389,"And you had to go running to mom"],[2389,2506,"behind our backs."],[2552,2719,"That's low, Daisy."],[2756,2890,"Real low."],[3382,3457,"Daisy!"],[5372,5438,"My leg."],[5480,5588,"Oh my leg."],[5868,5951,"Oh my God."],[5989,6110,"Daisy, are you okay?"],[6297,6414,"You deserved it."],[6706,6760,"Lola!"],[6760,6827,"What the hell?"],[6827,6898,"Why would you push her?"],[6898,7019,"She was trying to help you."],[7119,7190,"Daisy!"],[7223,7311,"I know you hate me,"],[7311,7570,"but did it really have to come to this?"],[7590,7811,"Do you really want me gone that badly?"],[7874,8041,"Maybe I should just disappear."],[8187,8445,"I can't believe I fell for it again."],[8470,8579,"I mean, even now."],[8579,8717,"You're twisting everything around."],[8717,8842,"I, I'm sorry."],[8842,8958,"I shouldn't have fell for it."],[9167,9296,"Get up and apologize to Lola!"],[9363,9609,"I'm gonna say it one last time."],[9655,9926,"I will never apologize to Lola."],[10055,10118,"Ever!"],[10431,10489,"Oh yeah?"],[11094,11207,"Take that as a lesson,"],[11207,11332,"and don't ever forget it!"]],"17":[[33,112,"Hey, that's enough."],[162,291,"Okay, I think class is about to start,"],[291,437,"so let's just, just get out of here."],[500,550,"Let's go."],[963,1067,"Take that as a lesson,"],[1067,1201,"and don't ever forget it!"],[1292,1380,"Don't worry."],[1514,1659,"I won't ever forget"],[1659,1768,"what happened today."],[1972,2097,"Neither one of us would ever choose"],[2097,2202,"someone like you anymore."],[2214,2469,"You are so impossible to love."],[2502,2627,"You're a parasite!"],[2627,2811,"Everything you eat, wear, touch,"],[2811,2915,"we gave you!"],[3799,3874,"You deserved it."],[3874,3928,"Even now,"],[3928,4095,"you're still just twisting things."],[5276,5347,"Finally."],[5430,5622,"Another minute and I was gonna call 911."],[5705,5943,"Thank you, Ms. Stirling."],[6177,6222,"What the hell"],[6222,6322,"happened to you, kid?"],[6343,6393,"Huh?"],[6464,6585,"You're covered in bruises,"],[6585,6719,"that leg's a mess,"],[6748,6956,"and your blood sugar's way too low."],[6990,7082,"Are you even eating?"],[7115,7173,"I'm fine."],[7545,7661,"Look, I don't know what's going on"],[7661,7728,"with your friends."],[7761,7832,"But this?"],[7857,7962,"This isn't okay."],[8158,8337,"You're lucky that leg isn't broken."],[8437,8504,"But if you don't start"],[8504,8596,"looking after yourself,"],[8596,8708,"things will get worse."],[8837,8888,"You got it?"],[8929,8992,"Yes."],[9129,9230,"Thank you, Ms. Stirling."],[9388,9434,"Okay."],[9459,9563,"I'm gonna look for some crutches."],[10915,10985,"What do you want?"]],"18":[[16,100,"What do you want?"],[454,546,"I just came to see"],[546,671,"how pathetic you look."],[846,988,"But you look even worse"],[988,1113,"than I expected."],[1659,1726,"Stop!"],[1847,2002,"What the hell is wrong with you?"],[2002,2085,"Oh, are you sad?"],[2085,2239,"Because I have Caleb and Dylon"],[2239,2385,"wrapped around my fingers."],[2410,2519,"Just leave me alone."],[2606,2761,"I'll be leaving soon anyways."],[2761,2907,"And you'll never see me again."],[2923,2994,"Oh yeah?"],[3036,3132,"Where are you going?"],[3190,3315,"Where can you go?"],[3340,3403,"Anywhere."],[3449,3645,"As long as I never see your face again."],[3645,3732,"So you admit it."],[3807,3887,"I win."],[3887,4108,"And you lose."],[4204,4371,"Don't celebrate just yet, Lola."],[4491,4567,"Dylon and Caleb"],[4567,4683,"aren't as dumb as you think."],[4729,4838,"One day they'll see you"],[4838,4950,"for who you really are."],[5034,5155,"And when that day comes,"],[5176,5301,"it'll be the end for you."],[5447,5601,"You bitch!"],[5747,5905,"Let go."],[5926,5989,"You don't get to"],[5989,6097,"pretend to be the victim"],[6097,6256,"when you've had everything"],[6256,6331,"handed to you."],[6331,6477,"Everything I wanted!"],[6760,6898,"Oh, this?"],[6931,7115,"Your magic little breath maker."],[7624,7757,"Give it, back-"],[7757,7882,"Oh, you want it?"],[7953,8133,"Then beg, Daisy."],[8183,8308,"Show me how desperate"],[8308,8416,"you really are."],[9200,9351,"Please."],[9488,9542,"Please."],[9713,9918,"Oh, look at you,"],[9918,10126,"all wheezing and desperate"],[10126,10335,"like some sad little stray."],[10427,10560,"You should have just died"],[10560,10710,"along with your parents."],[10906,10969,"No!"]],"19":[[20,95,"Don't!"],[667,804,"You've never really had a shot"],[804,942,"at Caleb and Dylon's love."],[1017,1176,"They're mine, okay?"],[1242,1409,"All mine."],[1685,1747,"Lola!"],[1897,2081,"Daisy, why did you push me?"],[2081,2143,"I was just trying to"],[2143,2268,"get your inhaler for you."],[2298,2369,"Are you okay?"],[2464,2573,"Daisy, what the hell?"],[2673,2823,"I mean, Lola was just trying to come see"],[2823,2957,"how you were doing and you attack her"],[2957,3019,"again."],[3019,3153,"God, after all this time"],[3153,3261,"and you still haven't learned"],[3261,3353,"your damn lesson."],[3386,3528,"I mean, I just, I really didn't think"],[3528,3628,"you could stoop any lower."],[3661,3732,"I mean, Daisy,"],[3816,3945,"when did you turn so cruel?"],[4008,4133,"I mean, who even are you anymore?"],[4149,4195,"I..."],[4362,4642,"I have nothing left to say."],[4758,4929,"Please, just go."],[6068,6126,"Yeah."],[6285,6364,"I'm evil."],[6431,6523,"Are you happy?"],[6577,6869,"I pushed Lola that hard"],[6869,7011,"with a fractured ankle."],[7173,7499,"And my inhaler fell to the floor"],[7520,7811,"in broken pieces on its own."],[7949,8066,"Oh, wait."],[8283,8412,"I don't have asthma."],[8475,8625,"Is that what you guys said?"],[8662,8767,"Wait, why was her inhaler"],[8767,8842,"in two pieces?"],[9004,9146,"What's going on in here?"],[9296,9421,"Are you okay?"],[9513,9730,"If you three are not hurt or sick,"],[9730,9859,"then get out of my office"],[9859,10001,"and head back to class."],[10001,10139,"I'm gonna to talk to your teachers."],[10356,10418,"Go!"],[11382,11498,"Hey, Owen."],[11519,11586,"Daisy,"],[11682,11799,"l don't know what it is, but,"],[11899,12024,"I can't shake off this bad feeling"],[12024,12099,"in my stomach."],[12191,12303,"So I flew to New York."],[12366,12433,"I'm coming to pick you up"],[12433,12483,"from school now."],[12483,12570,"Thank you, Owen."]],"20":[[475,546,"Why are you parked?"],[583,684,"Because Daisy's hurt."],[809,925,"Let's just pick her up today"],[925,996,"and take her home."],[2018,2060,"There you are."],[2060,2135,"We were waiting for you."],[2585,2677,"Please don't touch me."],[3378,3532,"Rude much. Let's just go."],[3712,3849,"She can't ride the bus like this."],[3949,4004,"Don't worry."],[4041,4154,"I'll go talk to her."],[4212,4270,"Okay."],[4863,4992,"Listen, bitch."],[5071,5255,"You better not get in that car with me,"],[5276,5609,"or I will make your life a living hell."],[5784,6022,"Hey, I'm talking to you."],[6022,6122,"Just go."],[6252,6514,"Don't you think you're being pathetic?"],[6915,7065,"You bitch."]],"21":[[671,804,"Daisy, when are you gonna"],[804,942,"stop abusing Lola?"],[1176,1284,"I can't believe I spent three years"],[1284,1368,"trying to protect you."],[1455,1518,"I mean, I should have just known"],[1518,1634,"I was feeding a monster."],[1697,1835,"It's okay, Caleb."],[1835,2039,"I just fell by accident."],[2039,2139,"You're too sweet, Lola."],[2198,2306,"That's exactly why this bully"],[2306,2419,"keeps walking all over you."],[2548,2690,"Oh shit!"],[2702,2777,"What did I say."],[2815,2948,"What did I say."],[3132,3199,"See, I told you we should"],[3199,3303,"have let her take the bus."],[3620,3762,"You have to stop feeling sorry for her."],[3962,4216,"Daisy, if you do this one more time,"],[4258,4320,"you're done"],[4412,4471,"for good."]],"22":[[1113,1192,"Woah,"],[1192,1326,"that car is sick!"],[1326,1430,"Holy shit!"],[1451,1534,"Yeah, there's no way they"],[1534,1618,"go to our school."],[1634,1789,"They definitely do not go to our school."],[2944,3128,"Daisy, what happened?"],[3215,3307,"Owen,"],[3349,3699,"please take me away from here."],[4462,4558,"Goodbye, Caleb."],[4658,4754,"Goodbye, Dylon."],[4879,5017,"Don't miss me when I'm gone."]],"23":[[1835,1910,"Who was that guy?"],[1968,2060,"Wait, here, I'm gonna go see"],[2060,2152,"who these people were."],[2356,2419,"Wait a minute."],[2473,2598,"No, no, I know him."],[2623,2690,"I've, I've seen him"],[2690,2815,"on a magazine or something."],[2815,2877,"Really?"],[2969,3032,"Who is it?"],[3032,3274,"I think that was Owen Gray."],[3336,3457,"The heir of the Gray family."],[3478,3653,"But he lives in LA"],[3653,3774,"and we're in New York."],[3774,3858,"And why would he know"],[3858,3949,"Daisy of all people?"],[3974,4095,"The Gray family heir?"],[4179,4245,"No way."],[4375,4421,"The Grays are one of"],[4421,4529,"the most powerful families"],[4529,4587,"in the country,"],[4587,4654,"what the hell would they"],[4654,4754,"be looking for in Daisy?"],[4829,4913,"It's probably someone else."],[5910,6177,"Owen, is it really you?"],[6277,6406,"What the hell happened here?"],[6464,6606,"I mean, how did things get this bad?"],[6819,6981,"Was that the Miller brothers back there?"],[7094,7127,"I should have"],[7127,7215,"punched someone's face."],[7215,7319,"There's no need."],[7436,7524,"I'm over it."],[7774,7857,"Are you really?"],[8041,8108,"Or you just"],[8108,8208,"pretending to be strong?"],[8750,8933,"Grief isn't a pause button, Owen."],[9013,9079,"It's a door."],[9167,9288,"And I closed it behind me."]],"24":[[896,984,"Morning, Caleb."],[1130,1188,"Where's Daisy?"],[1372,1472,"She not come home last night?"],[1559,1651,"I mean, at this rate, she'll..."],[1755,1864,"yeah she'll be late for school."],[1864,1960,"Who cares, bro?"],[1993,2081,"I mean she's probably out"],[2081,2160,"sulking somewhere"],[2160,2235,"like she usually does."],[2252,2327,"Maybe she went home"],[2327,2452,"with that guy from last night."],[2590,2694,"No fucking way. - No fucking way."],[2861,2969,"Daisy might throw a tantrum"],[2969,3032,"every now and then"],[3032,3082,"but that doesn't mean"],[3082,3186,"that she stays out all night."],[3186,3290,"And she definitely does not"],[3290,3370,"have a boyfriend."],[3461,3511,"So"],[3545,3620,"she's probably in her room."],[3632,3720,"I'll just go check her room."],[3757,3828,"I'll come with you."],[3870,3970,"And if she's not here,"],[3970,4049,"we need to send someone"],[4049,4116,"to get her back"],[4116,4179,"because we can't"],[4179,4262,"have her running around"],[4262,4366,"tarnishing the Miller name."],[4529,4683,"Wait, guys, look at this."],[4725,4833,"Breaking news."],[4846,5063,"The Gray family heir was spotted"],[5063,5255,"getting cozy with Daisy Evans,"],[5255,5417,"daughter of the late legendary"],[5417,5630,"jewelry designer Leonora Evans."],[5655,5830,"We've reached out to the Gray family"],[5830,5918,"for comment."],[5935,6043,"They say an announcement"],[6043,6135,"will be made soon."],[6172,6335,"Will the Evans and Gray family"],[6335,6435,"join hands?"],[6460,6552,"Daisy? - Daisy."]],"25":[[37,154,"I mean, it's just a, it's a bullshit"],[154,225,"news article."],[287,392,"I mean, there's no way in hell"],[392,500,"that Owen will be dating Daisy."],[538,704,"Yeah, the paparazzi is probably"],[704,834,"just stirring up drama."],[875,1138,"I mean, the Gray family is top tier."],[1138,1197,"What would they"],[1197,1297,"even want with Daisy?"],[1305,1376,"Yeah, exactly."],[1376,1543,"It's just clickbait garbage."],[1630,1689,"There's no way in hell"],[1689,1822,"he'd even get close to Daisy."],[1864,1922,"Yeah."],[2068,2181,"And it was a mistake."],[2268,2360,"It has to be, right?"],[2402,2469,"Susan!"],[2469,2573,"Is Daisy in her room?"],[2627,2752,"I checked on her earlier."],[2752,2827,"She wasn't there."],[2827,2936,"Her bed was made."],[2936,3061,"Her room looked untouched."],[3090,3190,"She clearly didn't sleep there"],[3190,3257,"last night."],[3257,3457,"No fucking way."],[3545,3703,"We call her out a couple of times"],[3703,3795,"and she runs away?"],[3874,4004,"I mean, what's her plan here?"],[4058,4120,"Guilt trip us"],[4120,4237,"into kissing her ass again?"],[4279,4383,"No, no, no."],[4383,4450,"You get someone"],[4450,4558,"to bring her back right now."],[4571,4738,"We can't show her that this flies"],[4738,4829,"in the Miller household."],[5067,5121,"Hello?"],[5188,5288,"Yeah, can I get somebody"],[5288,5484,"to track Daisy Evans and go get her?"],[5647,5747,"Yes, I want her back"],[5747,5847,"in this house pronto."]],"26":[[771,834,"Caleb!"],[1714,1772,"Caleb!"],[1901,1976,"Are you okay?"],[2018,2085,"I was calling you,"],[2085,2256,"but you're totally spaced out."],[2339,2385,"Yeah."],[2456,2506,"Yeah."],[2573,2648,"Yeah, I'm all good."],[2686,2794,"Come on, let's hit the cafeteria."],[2794,2898,"We can go grab a bite to eat."],[2948,3044,"I'm starved."],[3057,3140,"You're the best."],[3236,3336,"So, this weekend,"],[3336,3457,"I thought we could go to the ball,"],[3457,3553,"because I want to..."],[4095,4208,"Let's go, baby!"],[4479,4537,"Dylon!"],[4637,4879,"D-Y-L-O-N!"],[4950,5205,"If we've got him, we're gonna win!"],[5205,5313,"Woo!"],[5313,5405,"Dylon!"],[5885,5976,"Dude, you good?"],[5976,6068,"You just spaced out"],[6068,6185,"right in the middle of the play."],[6264,6339,"Yeah, I know."],[6410,6464,"I'm good."],[6594,6673,"Oh, Daisy."],[6790,6973,"How did things get like this between us?"]],"27":[[112,254,"Bro, it's been three days."],[308,446,"We got our best people on this,"],[446,542,"and still nothing."],[588,738,"I mean, she hasn't even been to school."],[775,842,"What do you know?"],[842,992,"She finally got some guts, huh?"],[1088,1180,"Just forget it."],[1197,1292,"Hey, she's doing this"],[1292,1418,"to try to get a rise out of us."],[1551,1780,"Yeah, I mean, yeah, you got a point."],[2556,2686,"What is this soggy crap?"],[2736,2790,"You know, I swear,"],[2790,2836,"breakfast has been"],[2836,2936,"getting worse and worse"],[2936,3053,"around here every day."],[3065,3153,"I mean, you guys are basically"],[3153,3244,"asking to get fired."],[3261,3319,"I'm sorry."],[3319,3415,"It's, um..."],[3465,3578,"Well, Miss Evans used to"],[3578,3712,"make breakfast every morning."],[3712,3820,"You must have developed a taste"],[3820,3908,"for her cooking."]],"28":[[29,100,"Wait, what?"],[200,312,"Daisy has been cooking us"],[312,425,"breakfast every day?"],[588,713,"That's your job."],[713,863,"I mean, what are we even paying you for?"],[884,1017,"It's not her fault."],[1117,1251,"And don't tell her I said this,"],[1251,1472,"but she wanted to keep it a secret."],[1589,1659,"Whatever."],[1659,1868,"I mean, she's just playing savior,"],[1906,1997,"as per usual."],[2314,2485,"Bro, do we really have no idea"],[2510,2602,"where she is?"],[2635,2756,"No leads?"],[2923,2973,"No."],[3103,3299,"The investigator I hired just said"],[3299,3490,"it's like she disappeared"],[3490,3599,"into thin air."],[3653,3737,"She's just gone."],[3807,3891,"Goddammit!"],[3966,4083,"God, where is she?"],[4354,4404,"Wait."],[4450,4512,"Wait, wait, wait."],[4512,4575,"Her room."],[4696,4817,"What if there's a clue in her room?"],[4904,4963,"Oh my God."],[5092,5176,"Let's go look."],[5455,5555,"They never appreciated her"],[5555,5659,"when she was here."],[5709,5880,"And now they want to act like they care."],[6014,6106,"It's too late for that."]],"29":[[588,679,"She took all her clothes with her."],[679,754,"Where the hell did she go?"],[992,1046,"Wait."],[1092,1184,"Her jewelry box."],[1247,1434,"I mean, that gold digger wouldn't leave"],[1434,1539,"without her precious jewelry."],[2281,2335,"Wait."],[2506,2552,"No."],[2640,2815,"I mean, Daisy's always had"],[2815,2936,"dollar signs in her eyes."],[2961,3111,"I mean, she even tried to steal"],[3111,3274,"the school's donation money."],[3357,3428,"Why would she leave her"],[3428,3599,"most expensive possessions here?"]],"30":[[58,271,"My mom left me $450,000"],[271,342,"when she died,"],[342,475,"and I'm giving it all to you."],[550,658,"Consider it a reimbursement"],[658,759,"for the past three years"],[759,934,"of food, shelter, and kindness."],[975,1117,"However fake it all was."],[1197,1301,"The remaining $50,000"],[1301,1388,"is from Sandra."],[1426,1530,"I don't have a need for it."],[1693,1747,"Dylon,"],[1822,1876,"Caleb,"],[2022,2081,"I'm leaving."],[2235,2314,"From now on,"],[2431,2556,"we owe each other nothing."],[2932,3123,"Uh, she, she, uh..."],[3436,3536,"She really left us."],[4004,4133,"No did she really leave us?"],[4233,4275,"No, no, no,"],[4275,4446,"this is just one of her tricks."],[4446,4567,"She's just gaslighting us."],[4629,4808,"I mean, Daisy loves money."],[4829,4888,"Remember when she stole"],[4888,4979,"the donation money?"],[5355,5426,"Lola!"],[5463,5526,"Lola!"],[5789,5939,"That's Dylon and Caleb's donation"],[5939,6097,"to the school fundraising event."],[6097,6202,"It's not yours to take."],[6202,6281,"Give it back!"]],"31":[[1372,1514,"Daisy, please don't kill me!"],[1514,1685,"I won't rat you out, I swear!"],[1810,1947,"Daisy, what the hell? - Daisy!"],[2281,2389,"That's not what happened!"],[2389,2489,"I , I didn't!"],[2506,2715,"Daisy, I know you're always trying to"],[2715,2815,"chase a quick buck."],[2815,2944,"But stealing Dylon and Caleb's"],[2944,3140,"donation money is seriously"],[3140,3236,"messed up!"],[3299,3407,"The money was supposed to be"],[3407,3453,"lunch money"],[3453,3620,"for disadvantaged students!"],[4500,4667,"First you try to steal from us,"],[4725,4788,"and then you try to"],[4788,4929,"throw Lola out the window."],[5009,5084,"I mean, you're..."],[5221,5330,"You're actually insane."]],"32":[[196,283,"What happened to the Daisy"],[283,362,"we used to know?"],[396,467,"You're a thief,"],[508,579,"and a murderer too"],[579,667,"if we hadn't stop you!"],[800,925,"I, I didn't!"],[946,1034,"That was Lola,"],[1034,1184,"I was trying to stop her!"],[1397,1522,"Don't try to pull that crap again,"],[1522,1672,"I just saw it with my own eyes!"],[1755,1872,"You know, if you're gonna,"],[1872,1972,"gonna steal from us,"],[2031,2193,"the right thing to do is just come clean."],[2310,2389,"But I guess that wouldn't occur"],[2389,2494,"to a psycho like you."],[2560,2923,"Daisy, I've always been so nice to you"],[2923,2990,"and you've never"],[2990,3123,"even given me a chance."],[3203,3340,"I know you hate me, but..."],[3449,3520,"I never thought"],[3520,3695,"you'd actually try to kill me, I..."],[3782,4004,"Dylon, Caleb, I, I'm scared."],[4004,4129,"I really don't feel safe"],[4129,4245,"around her anymore."],[4270,4450,"You're lucky we don't press charges!"],[4625,4683,"Let's go."],[4817,4884,"Let's go."],[5021,5080,"Please."],[5184,5242,"We're done here."],[5547,5668,"I didn't do this."],[5759,5914,"Why don't you believe me?"],[5914,5989,"That's when she showed us"],[5989,6068,"her true colors."],[6151,6260,"Daisy wanted the donation money"],[6260,6310,"so badly,"],[6310,6385,"she almost pushed Lola"],[6385,6473,"out the window for it."],[6531,6602,"But I mean, look."],[6744,6831,"Not only did she leave,"],[6831,6923,"she left us her jewelry,"],[6923,7069,"she even left her mom's inheritance."],[7190,7240,"I don't know."],[7240,7357,"What, what if we were wrong,"],[7357,7415,"you know?"]],"33":[[20,187,"No, this is classic Daisy, man."],[225,379,"I mean, we saw her get in"],[379,487,"some random dude's car"],[487,596,"like the other night."],[613,671,"I mean..."],[742,809,"I mean, she probably stole"],[809,955,"this 500 grand from that guy."],[1076,1188,"I mean, she's a con artist!"],[1593,1647,"Daisy!"],[1889,1951,"Susan."],[2072,2164,"What's up with the bag?"],[2173,2289,"Boys, I am leaving."],[2348,2444,"Your mother hired me"],[2444,2573,"to look after Miss Evans."],[2573,2698,"And now that she's gone,"],[2744,2886,"it's time for me to move on too."],[2911,2998,"Wait, no."],[3019,3107,"I mean, she's gone right now,"],[3107,3215,"but she'll be back any day."],[3274,3382,"You really don't know."],[3449,3570,"Miss Evans said goodbye"],[3570,3712,"to the maids three days ago."],[3778,3962,"She moved, changed schools,"],[3962,4045,"she even transferred"],[4045,4179,"her legal guardianship."],[4179,4262,"What? - What?"]],"34":[[37,162,"She, she left her stuff here,"],[162,229,"she can't have moved out"],[229,287,"three days ago."],[287,412,"I mean did she really transfer schools?"],[450,513,"I know she hasn't been to"],[513,608,"class all week, but-"],[608,721,"I mean, either way,"],[721,850,"it's just her royal highness"],[850,984,"crying out for attention again."],[1063,1284,"But this time, she took it too far."],[1343,1463,"Alright, does she really think that"],[1463,1526,"this is going to make us"],[1526,1605,"want her again?"],[1605,1718,"Susan, look."],[1793,1939,"I know that you and Daisy were close,"],[1939,2097,"but if you're planning on conspiring"],[2097,2218,"some kind of scheme with her,"],[2243,2339,"I mean, you do realize"],[2339,2464,"that could cost you your job."],[2464,2694,"Daisy's parents died three years ago."],[2727,2861,"Alright, she's got no family"],[2861,2969,"and no one to take her in."],[3028,3140,"She needs us!"],[3140,3249,"I mean, that's how I know"],[3249,3365,"that she'll be back any day."],[3365,3687,"Boys, everything I've said is true."]],"35":[[29,296,"Miss Evans never lied to us maids."],[296,454,"She never treated us like staff."],[475,654,"She saw us as human beings"],[654,921,"who deserved kindness, respect."],[1017,1167,"And since I'm leaving anyway,"],[1167,1334,"I might as well speak from the heart."],[1401,1730,"You two have been terrible to Daisy."],[1793,2018,"She's not the girl you think she is."],[2056,2256,"She's a thousand times better."],[2281,2448,"I couldn't take it seeing the way"],[2448,2552,"you two treated her."],[2552,2669,"You could barely take it?"],[2752,2831,"Well, what about the way"],[2831,2948,"she treated Lola?"],[2948,3103,"I mean, she used her"],[3103,3299,"as a human punching bag."],[3390,3570,"We didn't treat Daisy horribly."],[3570,3687,"We were simply standing up"],[3687,3749,"to a bully."],[3966,4108,"You two are so dead set"],[4108,4216,"on siding with Lola,"],[4216,4362,"there's nothing I can do about that."],[4416,4583,"But let me say one last thing."],[4654,4909,"Lola Pierce is exactly"],[4909,5067,"what you think Daisy is."],[5150,5347,"One day that truth is gonna to hit you."],[5422,5609,"I just hope it doesn't happen too late."]],"36":[[8,87,"Good riddance."],[120,291,"You know, it's just another one"],[291,367,"of Daisy's puppets"],[367,421,"trying to make her out"],[421,504,"to be a good person."],[546,679,"Don't worry, she'll come back"],[679,842,"in a couple of days crawling."],[896,984,"Bro, where are you going?"],[1272,1359,"Susan, wait!"],[1718,1793,"I need to ask you a question"],[1793,1872,"about Daisy."],[1935,2006,"You mean, am I..."],[2264,2406,"Are we really wrong about her?"],[2448,2531,"Okay, well..."],[2577,2706,"Do you remember what it was like"],[2706,2823,"when she first moved in?"],[2907,3065,"She was so kind."],[3094,3294,"So eager for you to accept her."],[3649,3782,"Daisy, sweetheart."],[3812,3891,"You're one of us now."],[3891,4020,"You don't need to do any of this."],[4020,4187,"Miss Evans, I'll take care of the dishes."],[4187,4279,"That's what I'm here for."],[4287,4387,"I don't mind."],[4387,4562,"I really enjoy helping out."],[4617,4804,"Plus, I'm really good at household chores."],[4817,4979,"Washing dishes, vacuuming,"],[4979,5134,"you name it, I can do it."],[5780,5834,"Hey."],[5972,6014,"Can you keep it down?"],[6014,6072,"I'm trying to read."],[6118,6206,"Sorry, Caleb."],[6239,6373,"I didn't know it was bothering you."],[6502,6552,"I won't play"],[6552,6635,"when you're home anymore."],[6881,6990,"Sorry about the noise."]],"37":[[79,141,"Right, that's why"],[141,225,"she stopped playing piano,"],[225,279,"cause she didn't want to"],[279,408,"bother me, I..."],[496,613,"And all this time she's been trying to"],[613,767,"accommodate my needs before hers."],[842,1067,"You always said that Lola had it hard here"],[1101,1209,"as a maid's daughter"],[1209,1309,"with no home of her own."],[1309,1534,"But what about Miss Evans?"],[1676,1885,"She lost both her parents."],[1906,2060,"She moved into a new house,"],[2060,2168,"a new family,"],[2193,2306,"and did everything she could"],[2306,2444,"to accommodate you,"],[2444,2540,"to belong."],[2569,2719,"Did that not count for anything?"],[2744,2840,"When Lola moved in,"],[2840,2973,"you and Dylon haven't given Daisy"],[2973,3107,"a single day of peace."],[3107,3199,"Okay, but still..."],[3303,3474,"I mean, she tried to steal from us."],[3549,3691,"She tried to kill Lola."],[3691,3770,"Did she?"],[3849,4004,"Caleb, things aren't always"],[4004,4158,"what they seem on the surface."],[4245,4354,"The truth is"],[4400,4621,"your eyes have been deceiving you."]],"38":[[50,258,"Daisy could have lived an easy life."],[316,442,"But no, she cooked."],[483,571,"She cleaned."],[613,696,"She took care of you"],[696,800,"when you two were sick."],[863,963,"All just to show you"],[963,1134,"how grateful she was."],[1205,1288,"Could someone like that"],[1288,1413,"just wake up one day"],[1413,1564,"and turn into a monster?"],[1584,1651,"A killer?"],[1906,2056,"I'll let you answer that yourself."],[2882,2965,"I heard the whole thing."],[3057,3165,"Bro, you're not seriously"],[3165,3328,"gonna buy her story, are you?"],[3345,3507,"She's clearly manipulating us."],[3507,3570,"Maybe."],[3703,3795,"I don't think I'm gonna know"],[3795,3912,"until I find out for myself."]],"39":[[241,342,"So remind me,"],[408,529,"who are you asking about again?"],[583,663,"Daisy Evans."],[692,763,"Oh, Daisy."],[813,992,"Yes, she was one of our best."],[1021,1134,"Top of her class."],[1159,1359,"Real Ivy League potential."],[1426,1618,"We had such high hopes for her."],[1655,1797,"And did she really transfer schools"],[1797,1881,"three days ago?"],[1881,2031,"Well, I tried to talk her out of it."],[2031,2093,"Believe me, but..."],[2185,2394,"But yes, she insisted"],[2394,2531,"that we give her a transfer."],[2731,2831,"Susan was right."],[3036,3140,"She really left."],[3140,3232,"Wait a minute."],[3299,3520,"Isn't your mother her legal guardian?"],[3545,3737,"And to tell me you didn't even know?"],[3824,3995,"I thought you two were close."],[4024,4137,"Like siblings."],[4225,4358,"You're a parasite."],[4358,4537,"Everything you eat, wear, touch,"],[4537,4646,"we gave you!"],[4683,4758,"Starting today,"],[4796,4925,"you're moving to the basement."],[4963,5080,"She can have my room."],[5113,5234,"Along with all my stuff,"],[5234,5359,"I'm giving it all back."],[5397,5513,"I've known for a long time"],[5513,5609,"there's no place for me"],[5609,5705,"in this home anymore."],[5868,5910,"Wait."],[5926,5964,"Wait."],[5968,6047,"Mr. Thompson."],[6047,6185,"You're the dean of the students."],[6243,6339,"So you have access"],[6339,6468,"to the classroom security cameras,"],[6468,6510,"right?"],[6544,6602,"Yes."],[6631,6677,"Why?"],[6831,6894,"Please sir."],[6894,6944,"Please."],[6944,7032,"I need you to blow up"],[7032,7127,"some security footage."],[7127,7228,"Like, right now."]],"40":[[91,279,"This is the exact time"],[279,475,"and classroom you asked me for."],[771,842,"Lola."],[950,1113,"That's Dylon and Caleb's donation"],[1113,1259,"for the school fundraiser."],[2039,2181,"Daisy, please don't kill me!"],[2181,2352,"I swear I won't rat you out."],[2381,2510,"Daisy, what the hell are you doing?"],[2510,2598,"What the hell?"],[3165,3265,"Jesus, kid."],[3336,3449,"What the hell was that all about?"],[3449,3549,"I fucked up."],[3549,3607,"Oh God."],[3653,3749,"I didn't."],[3749,3849,"That was Lola."],[3849,3999,"I was trying to stop her."],[4058,4141,"When are you going to stop"],[4141,4241,"abusing Lola?"],[4262,4375,"I can't believe I spent three years"],[4375,4471,"trying to protect you."],[4471,4525,"I mean, I should have just known"],[4525,4654,"I was feeding a monster."],[4904,4950,"I fucked up."],[4950,5025,"I was wrong."],[5025,5121,"This is all my fault."],[5121,5159,"I just, I..."],[5401,5526,"I drove her away."],[5526,5759,"I'm the reason that she, she left."],[5759,5839,"I just..."],[5864,6051,"I loved you both so much."],[6076,6197,"What we had is gone."],[6247,6381,"And we're never getting it back."],[6443,6519,"She's gone."],[6535,6631,"She just, she doesn't want to"],[6631,6735,"be with us anymore."]],"41":[[41,112,"Yo, Caleb."],[150,254,"What the hell are you doing here?"],[492,575,"You look like shit."],[700,767,"We were wrong."],[767,913,"I mean, we were, we were wrong"],[913,1067,"about, about everything."],[1076,1192,"Bro, what are you talking about?"],[1192,1263,"Daisy."],[1305,1405,"I'm talking about Daisy, man."],[1505,1605,"I have to go find her."],[1605,1776,"We have to go get her back, right now."],[1851,1906,"Um..."],[2060,2114,"Mom."],[2156,2243,"Mom, that's right."],[2243,2344,"Mom might know where she is."],[2965,3007,"Mom!"],[3011,3065,"Mom!"],[3086,3257,"Mom, where is Daisy?"],[3257,3420,"What school is she transferring to?"],[3440,3520,"If you weren't so busy"],[3520,3624,"fawning over Lola,"],[3624,3757,"you wouldn't have to ask."],[3849,3912,"Why are you pretending"],[3912,4070,"to care about Daisy now anyways?"],[4104,4187,"It's a little late for that,"],[4187,4275,"don't you think?"],[4320,4533,"Mom, you know how much"],[4533,4625,"we care about her."],[4704,4817,"Okay, we love her."],[5084,5134,"Love?"],[5259,5518,"Beating and bullying someone non-stop"],[5534,5676,"is certainly a strange way"],[5676,5793,"to show your love for them."],[5868,6010,"And if you really loved her,"],[6010,6089,"why did you believe"],[6089,6252,"every lie out of Lola's mouth?"],[6318,6410,"Why didn't you ever"],[6410,6552,"listen to Daisy's side of the story?"],[6552,6702,"I didn't want it to turn out like this."],[6702,6794,"I just..."],[6919,7073,"I thought that she was after our money."],[7265,7332,"I thought that's why"],[7332,7474,"she was so nice to us."],[7474,7524,"I-"],[7524,7590,"Exactly."],[7615,7703,"I mean, are you really going to"],[7703,7887,"defend Daisy over your own sons?"],[7887,7974,"She's been using us."],[7974,8095,"She's been a fake from the start."],[8095,8174,"And not to mention,"],[8174,8229,"she's been bullying Lola"],[8229,8283,"behind our back."],[8283,8441,"Just shut the fuck up, Dylon!"]],"42":[[8,229,"Did you just hit me over Daisy?"],[300,504,"You were on my side two days ago!"],[504,588,"Silence!"],[725,905,"Do you understand what you've done?"],[955,1126,"God, I can't believe"],[1126,1255,"my sons are so stupid."],[1343,1564,"Her mother entrusted her to us."],[1601,1718,"You swore to me that"],[1718,1826,"you would embrace her,"],[1826,1956,"treat her like family."],[2027,2097,"Did that promise"],[2097,2227,"mean anything to you at all?"],[2510,2681,"You know how crazy"],[2681,2790,"my work schedule is."],[2790,3003,"I had no choice but to trust"],[3003,3140,"that you two idiots"],[3140,3244,"would watch over Daisy."],[3244,3332,"And look what you did."],[3474,3549,"You teamed up"],[3549,3707,"with that venomous tramp, Lola."],[3828,4029,"You two were always going on and on"],[4029,4291,"about how poor Lola had it so hard."],[4325,4437,"Rushing to protect her"],[4437,4554,"every chance you got."],[4612,4708,"What about Daisy?"],[4754,4904,"You treated her like garbage!"],[4904,4979,"That's not fair to Lola,"],[5009,5084,"and you know it."],[5105,5192,"You're treating Daisy"],[5192,5309,"like she's some angel."],[5309,5584,"But in reality, she's a spoiled, entitled rat."],[5584,5626,"Alright?"],[5626,5739,"And you're the adult here."],[5747,5905,"So you're responsible for this."],[5905,6031,"You created this little monster."],[6031,6118,"Dylon Miller!"],[6414,6656,"Did you just slap me for Daisy?"],[6656,6769,"You're damn right I did!"],[6802,6911,"That's what you get for turning into"],[6911,7119,"this blind, arrogant bully"],[7119,7228,"that doesn't know the concept"],[7228,7328,"between right and wrong!"]],"43":[[25,141,"Mom, why did you do that?"],[141,271,"That was for acting like"],[271,442,"an ungrateful punk!"],[475,604,"Don't think I haven't noticed."],[750,950,"For three years, I have watched you"],[950,1055,"bring your loser friends"],[1055,1138,"into this house."],[1159,1368,"Stirring up crap wherever you can."],[1413,1493,"And who was there"],[1493,1634,"to clean it up every time?"],[1818,1872,"Daisy."],[1943,2081,"She took the fall for you."],[2106,2323,"She covered for you."],[2364,2565,"And now you want to talk trash about her?"],[2623,2727,"How dare you!"],[2907,2965,"Yeah."],[3724,3853,"Party!"],[4821,4946,"Oh, shit."]],"44":[[62,287,"Oh, my mom's new antique vase."],[316,425,"She's going to kill me."],[504,592,"Oh my God!"],[592,713,"Are you okay?"],[738,850,"Did you hurt yourself?"],[992,1105,"Wait, Dylon, are you..."],[1163,1292,"Are you partying?"],[1292,1426,"Shh, Daisy, Daisy."],[1438,1609,"Please, please don't tell mom."],[1651,1801,"She's gonna actually kill me."],[2035,2089,"I won't."],[2152,2344,"I'll say it was me."],[2406,2527,"If someone's gonna get in trouble,"],[2527,2660,"it's better me than you."],[2761,2986,"Oh, you're the best."],[3057,3203,"Oh, I knew you had my back."],[4304,4462,"Maybe I can piece it back together."],[4546,4850,"Daisy covered for you so many times."],[4850,5055,"She did everything she could do for you."]],"45":[[0,175,"And you, Dylon Miller."],[229,375,"What the hell did you do to her?"],[642,692,"You want to know"],[692,829,"who's really spoiled in this house?"],[829,942,"Look in the damn mirror!"],[942,992,"Mom."],[992,1192,"And you, Caleb Miller!"],[1251,1380,"That's for being blind."],[1455,1614,"Too blind to notice the difference"],[1614,1705,"between right and wrong."],[1780,1922,"You were my firstborn."],[1968,2135,"The one I trusted the most."],[2189,2285,"I thought you were going to"],[2285,2402,"take care of Daisy,"],[2402,2573,"stand by her no matter what."],[2573,2715,"You promised"],[2715,2844,"that you would be there for her."],[2844,2957,"But were you, Caleb?"],[2994,3065,"Did you?"],[3253,3691,"You let Lola Pierce, that little snake,"],[3691,3816,"come between you."],[3837,3983,"You forgot everything"],[4024,4129,"that you ever promised."],[4170,4320,"Everything Daisy ever did for you."],[4496,4596,"Until she walked away."],[4813,4913,"She left you."],[5050,5196,"Left us."],[5246,5363,"And honestly,"],[5492,5572,"good for her."]],"46":[[50,221,"Mom, please,"],[241,392,"just tell me where did Daisy go?"],[437,579,"You don't deserve to know."],[684,784,"Mom, please."],[946,1163,"I am begging you."],[1359,1463,"Just tell me where she is."],[2531,2585,"I know."],[2585,2702,"I know I messed up."],[2744,2802,"But I,"],[3032,3161,"I can't live without her."],[3190,3282,"I just can't."],[3432,3528,"So please,"],[3586,3749,"please just give me one more chance."],[3945,4033,"Just give me one more chance"],[4033,4141,"to please say I'm sorry."]],"47":[[1543,1847,"Oh, sweetheart, you're finally home!"],[1914,2160,"Oh, you have no idea how long it's been"],[2160,2306,"since I waited to see you."],[2344,2494,"And we're here for you now, honey."],[2494,2627,"Okay, so don't worry."],[2660,2748,"You've got us."],[2902,3048,"I'm sorry, Auntie Hailey."],[3048,3307,"I should have come back to LA sooner."],[3328,3470,"But my health hasn't been great"],[3470,3586,"over the past few years."],[3586,3774,"No, honey don't be sorry."],[3824,3920,"We're family."],[4008,4179,"And Owen and I are here for you now."],[4250,4346,"So no more pain."],[4404,4596,"Just peace, happiness,"],[4650,4771,"every single day."],[4863,5092,"And this one, he has not slept a full night"],[5092,5159,"since he found out"],[5159,5246,"you were coming back."],[5246,5326,"He has cleaned the house"],[5326,5405,"from top to bottom,"],[5405,5480,"even your room."],[5513,5626,"Mom, seriously."],[5680,5776,"Can we just go inside?"],[5864,5910,"Didn't you say"],[5910,6010,"you had a gift or something?"],[6081,6118,"Yes."],[6185,6264,"A gift?"],[6281,6318,"Mhm!"]],"48":[[58,183,"Auntie Haley, this is,"],[246,383,"is this really all for me?"],[471,567,"This is too much."],[579,654,"Sweetheart, it's just"],[654,788,"a little welcome home gift."],[825,892,"If I could give you"],[892,996,"the whole Gray estate right now,"],[996,1055,"I would."],[1109,1222,"Including Owen."],[1238,1297,"Mom."],[1488,1539,"Okay, okay,"],[1539,1630,"I'll stop."],[2147,2273,"Oh, hey."],[2327,2427,"No tears."],[2515,2660,"That's all behind you now."],[2806,2994,"And if Owen ever hurts you,"],[3015,3169,"I will kick his ass myself."],[3199,3290,"Mom, I would never"],[3290,3395,"do something like that."],[3541,3770,"So, you ready for a new beginning?"]],"49":[[379,446,"Daisy."],[821,950,"Where the hell are you?"],[1130,1188,"Caleb."],[1393,1518,"The storm is getting really bad."],[1518,1634,"I'm, I'm scared."],[1851,1964,"You get out."],[2022,2072,"What?"],[2239,2389,"You get the hell out of here."],[2389,2531,"Caleb, what's wrong?"],[2652,2731,"Are you okay?"],[2940,3090,"What the hell is wrong with you?"],[3119,3194,"You haven't been the same"],[3194,3299,"since Daisy left."],[3299,3495,"And now, you're just being reckless."],[3528,3661,"Are you trying to kill yourself?"],[3728,3837,"You don't know shit."],[3949,4024,"We messed it up."],[4079,4166,"You know, all of it."],[4237,4304,"Everything."],[4341,4400,"We were..."],[4521,4592,"You're wrong."],[4713,4833,"You're dead wrong."],[4892,5025,"Caleb, what are you saying?"],[5025,5113,"You're not yourself."],[5113,5192,"I said,"],[5455,5568,"I said get out."],[5568,5676,"What the hell, man?"],[5697,5834,"You don't care about Lola anymore?"],[5834,5947,"Only care about Daisy?"],[5972,6122,"Have you lost your mind?"]],"50":[[254,321,"You found her."],[362,442,"You found her?"],[479,538,"Where is she?"],[575,700,"Miss Evans has transferred"],[700,809,"to Sage Hill School."],[850,996,"Also, there's talk"],[996,1146,"she's dating Owen Gray."],[1167,1288,"Book the next flight there"],[1288,1363,"right now."],[1405,1488,"Okay, I'm gonna get her back"],[1488,1568,"no matter what."],[2344,2423,"You see her?"],[2523,2677,"That's Daisy Evans."],[2702,2786,"The transfer."],[2823,3032,"Word is, she's dating Owen Gray."],[3032,3123,"Yeah, right."],[3186,3328,"Who knows if that rumor's even true."],[3657,3732,"What the fuck?"],[3849,3941,"What the fuck?"],[4195,4270,"Daisy, let's go home."],[4496,4567,"Let's go home."]],"51":[[20,120,"Oh my God."],[179,250,"Why does Daisy"],[250,379,"always get the hot guys?"],[517,646,"I'm so jealous."],[688,775,"Are you really just gonna leave"],[817,942,"everything behind?"],[1038,1155,"Ok, we're your family."],[1384,1447,"Family?"],[1501,1647,"Is, is that what you call people"],[1647,1739,"who turn on me?"],[1785,1901,"Humiliate me?"],[1939,2068,"When I'm falling apart?"],[2314,2444,"Real family doesn't make you"],[2444,2531,"fight for love."],[2690,2806,"You're not my family."],[2861,2944,"Not anymore."],[2986,3073,"I know I messed up."],[3103,3153,"Okay?"],[3219,3415,"But, but transferring schools?"],[3415,3628,"Moving in with, with some guy?"],[3653,3778,"Ok, you're not thinking straight."],[3778,3862,"Some guy?"],[3970,4116,"Owen's my best friend."],[4308,4412,"And now,"],[4496,4587,"he's my boyfriend."]],"52":[[212,333,"You know, people like Owen,"],[425,517,"they're on a whole"],[517,629,"different level than us."],[721,796,"Okay, I just..."],[930,1055,"I don't want you getting hurt."],[1084,1163,"Oh yeah?"],[1259,1359,"So what was everything"],[1359,1463,"you two did to me before?"],[1539,1630,"Just a warm up?"],[1747,1814,"Alright, you know what?"],[1814,1914,"Screw this."],[1935,2039,"Let's just grab her and go."],[2573,2677,"Did you just hit me?"],[2677,2761,"I swear,"],[2761,2915,"if you lay a hand on Daisy again,"],[2915,3036,"I won't hold back."],[3036,3153,"So now you're defending her?"],[3194,3307,"She's a gold digging bitch!"],[3307,3365,"No!"],[3365,3415,"Okay?"],[3415,3536,"We were the fools."],[3591,3770,"Lola has been playing us"],[3791,3949,"like fucking idiots."],[4145,4212,"Okay, Daisy."],[4412,4629,"I know, I know I screwed up."],[4733,4863,"But we were family."],[4934,5105,"I mean, does, doesn't that mean"],[5105,5213,"anything to you now?"]],"53":[[66,246,"I used to care so much."],[671,700,"No,"],[867,959,"not anymore."],[1146,1234,"But why?"],[1276,1393,"Why Owen Gray?"],[1430,1572,"When I'm the one that has..."],[1793,2060,"I am the one that has loved you all along."],[2168,2323,"Because he chose me."],[2444,2594,"Without hesitation,"],[2594,2748,"without condition."],[2902,2936,"No."],[3073,3169,"No, I can't."],[3207,3357,"I, I, I can't just let you go."],[3357,3457,"Let go of me."],[3457,3511,"Hey!"],[3511,3591,"Now!"],[3591,3720,"Touch my girlfriend again,"],[3741,3820,"I'll kill you."],[3891,3991,"Is that Owen Gray?"]],"54":[[20,112,"Did you hear that?"],[221,433,"Owen just admitted to dating Daisy."],[521,608,"Sorry I'm late."],[667,750,"You're right on time."],[1338,1447,"Let me make it official."],[1634,1735,"This is my boyfriend."],[1889,1968,"Owen Gray."],[2085,2135,"No."],[2160,2277,"This is crazy, okay,"],[2277,2381,"I cannot allow this."],[2381,2510,"Nobody asked for your permission."],[2606,2740,"God, you didn't wait a second"],[2740,2827,"before hopping into"],[2827,2986,"the next rich guy's bed, did you?"],[3023,3107,"Gold digging, bitch!"],[3107,3174,"Watch your mouth!"],[3924,4008,"You abuse her."],[4066,4141,"Humiliated her."],[4183,4262,"All while you're cozying up"],[4262,4379,"to your fucking maid's daughter?"],[4421,4500,"And now you show up here"],[4500,4567,"acting like you actually"],[4567,4625,"give a damn."],[4742,4808,"Security!"],[4959,5021,"Wait."],[5213,5276,"There's one thing"],[5276,5397,"I've always wanted to ask you."],[5480,5755,"You guys say I'm lazy, selfish,"],[5818,5972,"that I mess around with guys."],[5993,6156,"Where did all of that come from?"]],"55":[[254,354,"Bro, we said three thirty."],[354,446,"Where the hell is Daisy?"],[479,767,"Um, I just saw her with Johnson."],[788,846,"They went into"],[846,963,"the boys' locker room and..."],[2364,2431,"Daisy?"],[2515,2594,"What is this?"],[2635,2719,"You're better than this."],[2719,2852,"Why would you make a cheat sheet?"],[2882,2952,"All right, let's go."],[2952,3015,"Follow me."],[3174,3249,"Wow."],[3265,3449,"Miss Evans really has it all."],[3503,3687,"She gets whatever she wants."],[3728,3828,"I can't even get my hands"],[3828,3937,"on one good outfit."],[4583,4671,"So that's how it is."],[4808,4929,"I was never anything"],[4929,5071,"more than what Lola said I was."],[5071,5347,"Daisy, I swear I'll make this right."],[5484,5576,"Please, just,"],[5705,5784,"just come home."],[5784,5864,"It's too late."],[6031,6097,"So that's it?"],[6210,6322,"You're really choosing him,"],[6352,6498,"over everything that we had?"],[6560,6627,"Yes."]],"56":[[129,241,"Hey, I'm sorry that things"],[241,354,"got out of hand earlier."],[392,554,"So I, kind of blurted out"],[554,646,"that I was your boyfriend"],[738,813,"without asking."],[813,913,"Don't worry about it."],[984,1063,"You jumped in right"],[1063,1184,"when I needed you the most."],[1263,1418,"And besides, I told people"],[1418,1589,"you were my boyfriend too, so,"],[1751,1864,"I guess we're even now."],[1931,2035,"Even if I said it"],[2035,2143,"in the heat of the moment,"],[2369,2435,"I meant"],[2519,2619,"every word of it."],[2898,3007,"I've loved you"],[3094,3249,"for as long as I can remember, Daisy."],[3303,3465,"And not a single day has gone by"],[3465,3582,"without you on my mind."],[3695,3812,"Daisy Evans..."],[3962,4083,"will you be my girlfriend?"]],"57":[[200,254,"Yes."],[362,437,"I'd love to."],[533,621,"Wait, seriously?"],[955,1055,"Oh my God!"],[1776,1847,"She's gone."],[1893,2064,"She's really gone."],[2118,2277,"I thought family was forever."],[2335,2452,"But all it took was Owen Gray"],[2452,2594,"and his fancy-ass name."],[2619,2727,"She didn't betray us."],[2727,2815,"Oh, come on,"],[2815,2877,"that bitch-"],[3036,3144,"You still don't get it."],[3165,3361,"You are the one that drove her away."],[3361,3432,"I mean, you pushed her"],[3432,3570,"down the goddamn stairs."],[3678,3728,"Oh, yeah?"],[3745,3841,"Well, you?"],[3841,3962,"You threw her out of the room"],[3962,4070,"like she was trash."],[4095,4175,"And you."],[4175,4275,"You're the one who slapped her."],[4275,4346,"Again,"],[4346,4429,"and again,"],[4433,4500,"and again."],[4512,4721,"So don't talk to me about guilt."],[4796,4842,"No."],[5038,5121,"You know, it's us."],[5296,5492,"I mean, we keep fucking it up."],[5559,5659,"I mean, we ruined her,"],[5659,5830,"probably ruined us in the process."],[5968,6060,"And now she's gone."],[6135,6272,"And she's never coming back."],[6377,6481,"What are you talking about?"],[6544,6594,"Here."],[6681,6781,"Watch it for yourself."]],"58":[[150,208,"No."],[354,421,"No way."],[467,567,"No fucking way."],[567,663,"Daisy wasn't the one"],[663,784,"who stole the donation money."],[905,975,"It was Lola."],[1021,1142,"She's been pinning it on her"],[1142,1230,"this whole time."],[1230,1463,"We've been wrong about everything."],[1468,1530,"No, no, no."],[1530,1659,"Why didn't Daisy just tell us?"],[1659,1714,"She did."],[1743,1818,"Okay, but we didn't want to"],[1818,1910,"fucking believe her."],[1914,1997,"I didn't!"],[2052,2118,"That was Lola!"],[2118,2260,"I was trying to stop her!"],[2485,2711,"And that's, that's just one thing, okay?"],[2711,2798,"Lola has been doing this"],[2798,2961,"to Daisy for months."],[2973,3186,"Big things, small things, all of it."],[3186,3395,"And we held on to every fucking word"],[3395,3470,"that she said."],[3482,3561,"No, no, no."],[3561,3678,"I blamed Daisy"],[3678,3953,"over and over and over again."],[3995,4124,"You're a parasite!"],[4124,4316,"Everything you eat, wear, touch,"],[4316,4412,"we gave you!"],[4433,4517,"You're a thief?"],[4554,4633,"And a murderer too if we"],[4633,4713,"hadn't stopped you!"],[4921,5000,"What are we gonna do?"],[5071,5159,"I pushed her away."],[5159,5309,"I pushed her out of our lives."],[5347,5472,"She's never gonna forgive me."],[5488,5609,"I deserve this."],[5630,5814,"I deserve worse!"],[5839,5889,"Hey!"],[5889,5989,"Hey, that's enough!"],[6118,6210,"Mom was right."],[6260,6348,"We were blind."],[6414,6556,"No wonder Daisy cut us off."],[6660,6815,"But there's still one thing that we can do."],[6948,7057,"Let's make Lola Pierce"],[7057,7215,"pay for everything"],[7236,7344,"that she fucking did."],[7378,7499,"I swear on my life."],[7561,7682,"I'll make her wish she never met us."]],"59":[[41,246,"You are so funny!"],[246,337,"Oh my God!"],[571,654,"Oh my God!"],[654,729,"Caleb, Dylon!"],[729,784,"You're back-"],[888,988,"Caleb, what are you doing?"],[1038,1113,"I'm scared!"],[1113,1201,"You're scared?"],[1201,1326,"Feels familiar, doesn't it?"],[1680,1785,"The donation money."],[1785,1885,"The seat at the window."],[1885,2043,"It was all set up to frame Daisy."],[2127,2248,"Oh, what's wrong, Lola?"],[2248,2385,"Are you forgetting how this all started?"],[2444,2515,"What?"],[2677,2765,"No, no."],[2765,2865,"That's not what happened."],[2865,3040,"Miss Evans stole the money."],[3224,3299,"And I caught her"],[3299,3386,"and she freaked out"],[3386,3478,"and she tried to throw me"],[3478,3541,"out the window"],[3541,3674,"before I could tell anyone."],[3895,3983,"You guys were there,"],[3983,4029,"you saw it."],[4029,4120,"You have to believe me."],[4237,4400,"You're still gonna lie to my face."]],"60":[[0,100,"No, I'm not,"],[100,187,"I swear I'm not!"],[371,487,"She said if, if she made it"],[487,608,"look like an accident"],[633,888,"and, and she just cried in front of you,"],[888,1009,"everybody would believe her"],[1009,1113,"and take her side."],[1509,1589,"You're still lying to me."],[1722,1801,"This look familiar?"],[2047,2097,"What..."],[2118,2189,"No way."],[2189,2264,"Where did you get that?"],[2264,2373,"How long have you had that?"],[2373,2460,"Holy shit."],[2494,2577,"It was her."],[2615,2711,"I knew it didn't make sense"],[2711,2865,"how fast everyone turned on Daisy."],[2923,3007,"You snake!"],[3040,3178,"Manipulative witch!"],[3194,3420,"You fake ass backstabbing bitch."],[3445,3541,"You deserve everything"],[3541,3641,"that's coming your way."],[3641,3699,"Ugh!"]],"61":[[25,83,"Please."],[145,312,"I'm just the maid's daughter."],[354,629,"I grew up on scraps and hand-me-downs"],[629,725,"and I fought like hell"],[725,800,"to have a better life."],[800,905,"How is that a crime?"],[1117,1172,"No."],[1234,1438,"Stealing is one thing, okay?"],[1438,1664,"But manipulating us against Daisy?"],[1664,1805,"Making us turn against her?"],[1805,1914,"I mean, you've lost your mind."],[1939,2006,"Please."],[2043,2118,"I know."],[2118,2239,"I know I screwed up,"],[2239,2402,"but please don't take everything away."],[2402,2464,"Without you,"],[2523,2602,"I have nothing,"],[2602,2694,"I am nothing!"],[2694,2852,"Please just give me one more chance."],[3148,3219,"Does that hurt?"],[3503,3561,"Good."],[3632,3712,"Now imagine everything"],[3712,3807,"you put Daisy through."],[3841,3953,"What you're feeling right now?"],[3987,4087,"It's not even close."],[4141,4304,"Your punishment is just getting started."],[4304,4446,"Okay, for the rest of your life,"],[4475,4612,"you're going to wish that you were dead."],[4646,4767,"But I'm not going to let you die."],[4808,4867,"I'm going to make sure"],[4867,5046,"that your life is a living hell."],[5109,5167,"What?"],[5271,5388,"What, what are you doing?"],[5388,5463,"Let me go!"],[5463,5584,"Lola,"],[5584,5689,"you're expelled."],[5722,5843,"Effective immediately, okay?"],[5843,6026,"The Miller family is cutting you off."],[6064,6352,"Every damn cent that we gave you,"],[6439,6552,"you're gonna pay it all back."],[6560,6614,"What?"],[6652,6790,"You, you can't do that!"],[6790,6915,"I don't have that kind of money!"],[6940,7015,"Even better."],[7069,7207,"Make sure she has the worst job"],[7207,7311,"Miller Corp has to offer."],[7403,7465,"And don't let her leave"],[7465,7582,"until every cent's repaid."],[7582,7695,"Make sure she's taken care of."],[7736,7816,"Let me go, you can't"],[7816,7995,"do this to me, please!"]],"62":[[8,87,"Oh my God."],[87,166,"Look at this."],[187,404,"Daisy and Owen Gray just made it official."],[425,588,"It's all over the news."],[650,846,"Look, the Millers are my boys but,"],[875,1042,"honestly, I'm happy for Daisy."],[1042,1138,"She's a good person,"],[1138,1272,"she deserves a fresh start,"],[1272,1405,"and someone better."],[1468,1543,"Exactly."],[1614,1726,"Oh, and guess what?"],[1743,1826,"The Grays are throwing her"],[1826,1951,"a coming-of-age party tonight."],[1951,2022,"What time?"],[2160,2298,"Uh, tonight."],[2298,2348,"Why?"],[3048,3161,"They've been walking around like ghosts"],[3161,3282,"ever since they lost her."],[3282,3507,"But, hey they did it to themselves."],[4283,4416,"Alright, SHS!"],[4416,4646,"Let's give it up for our golden couple,"],[4646,4967,"Daisy Evans and Owen Gray!"],[4967,5117,"Woo!"],[5117,5176,"Yeah!"],[5259,5409,"Woo!"]],"63":[[104,421,"Owen, thank you so much."],[471,600,"I thought my 18th birthday"],[600,767,"was just going to be another dark day."],[863,959,"But you,"],[1080,1213,"you made it so special."],[1213,1322,"No, you did,"],[1368,1501,"with that brave heart of yours."],[1689,1814,"Happy 18th, Daisy."],[1906,2093,"May you rise, may you shine,"],[2135,2218,"may your life be nothing"],[2218,2306,"short of brilliance."],[3691,4062,"Daisy, in the end, I lost you."],[4112,4216,"And I'll carry that regret"],[4216,4325,"for the rest of my life."],[4400,4579,"Daisy, even if we're not"],[4579,4679,"in your life anymore,"],[4738,4909,"I hope you smile every day,"],[4950,5025,"no matter what."],[7098,7161,"What's wrong?"],[7215,7282,"Nothing."],[7378,7503,"I was just thinking that"],[7707,7857,"even wilted flowers"],[8074,8191,"will bloom again someday."]]}