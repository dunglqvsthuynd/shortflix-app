{"1":[[0,150,"Every fifty years,"],[150,283,"a she-wolf is sacrificed"],[283,387,"to the Moon Goddess."],[408,629,"Frozen in an eternal slumber."],[846,1092,"We must select another innocent girl"],[1092,1159,"this year."],[1159,1238,"But who?"],[1284,1488,"Nobody ever wants to be the sacrifice."],[1568,1693,"I will be the tribute."],[2398,2535,"Are you sure about this, Luna?"],[2569,2660,"You will die."],[2723,2794,"Yes."],[2894,2944,"I'm sure."],[2998,3169,"The most noble Luna we've ever had."],[4124,4270,"When these marks turn black"],[4270,4391,"in seven days,"],[4454,4608,"the curse will be activated."],[4642,4746,"Our men will pick you up."],[4825,5080,"This is your will of the deceased."],[5130,5317,"A message for you to leave behind."],[5326,5447,"After your sacrifice"],[5584,5701,"What you record"],[5805,5968,"will be spoken to your loved ones."],[6026,6185,"I don't have any loved ones."],[7198,7349,"Alpha Ashton has a big annoucement"],[7349,7428,"for the pack."],[7678,7853,"It will be the third year"],[7853,7987,"marking my anniversary"],[7987,8170,"to your Luna in just seven days."],[8216,8475,"So I'm throwing a giant party"],[8475,8562,"to commemorate"],[8562,8725,"my everlasting love to her."],[8808,9075,"Snow, baby, I am still so madly,"],[9134,9267,"madly in love with you."],[9321,9484,"The Alpha has never been shy"],[9484,9705,"with showering you with love, Luna."],[9738,9847,"Why would you leave him?"],[10005,10147,"That was what I thought."],[10147,10281,"Until I find out he had been"],[10281,10377,"cheating on me"],[10377,10485,"while I was pregnant."],[11594,11861,"Because of that, I lost our child."],[12374,12579,"In seven days, I will join our"],[12579,12812,"unborn child in the afterlife."],[13029,13225,"In seven days, I will disappear"],[13225,13467,"from your life forever, Ashton."]],"2":[[792,892,"I'm home, Babe."],[950,1067,"Hi, come here."],[1213,1301,"I'm sorry I'm late."],[1301,1451,"I was checking up on your ball gown"],[1451,1609,"the designers are making for that gala."],[1981,2135,"Or busy ripping dresses off"],[2135,2218,"your mistress."],[2289,2456,"God, you have such a sick body."],[2957,3224,"Here look, they made it just for you."],[3395,3574,"You're gonna be the star of our party."],[3645,3832,"What a beautiful anniversary gift."],[4179,4383,"I actually have a little something"],[4383,4458,"for you too."],[4579,4650,"Oh really?"],[4725,4800,"What is it?"],[5259,5330,"You have to wait"],[5363,5518,"until our anniversary to open it."],[5576,5805,"It'll be your little surprise."],[6164,6218,"Yeah."],[6289,6381,"It would be more special"],[6381,6506,"to open on our anniversary."],[6694,6781,"I love you, Snow."],[6873,6994,"Till death do us part, right?"],[7069,7127,"Yes,"],[7190,7336,"till death do us part."]],"3":[[312,529,"Funny, Ashton once filled my life"],[529,784,"with gifts, tokens of his love..."],[834,955,"but I was fooled."],[1847,2122,"Snow, six days left."],[2156,2227,"Are you sure"],[2227,2394,"you want to sacrifice yourself?"],[2531,2694,"Hey Bree, you're my best friend,"],[2694,2898,"but I just want to make sure"],[2898,3015,"you're not gonna tell anyone."],[3015,3269,"I won't, but what about Ashton?"],[3440,3574,"Snow, let's go."],[5238,5363,"Oh Snow, you look"],[5405,5584,"beautiful in that ball gown."],[5668,5864,"Alpha Ashton poured over every detail"],[5864,5968,"with the designers."],[6043,6181,"You're so lucky to have him."],[6560,6627,"Oh!"],[6823,6898,"Oops."],[6940,7144,"I'm sorry, I didn't see you there."],[7169,7244,"Aren't you the Luna"],[7244,7357,"of the Blackwood Pack?"],[7357,7524,"Have we met before?"],[7895,8078,"Colleen, Ashton's model"],[8078,8170,"during the day,"],[8170,8304,"mistress at night."],[8395,8479,"Shit, I can't have them"],[8479,8571,"in the same room."],[8662,8858,"Colleen, what are you doing here?"],[8971,9209,"Mrs. Blackwood, you should definitely"],[9209,9351,"watch my interview today."],[9417,9534,"They're gonna start without you."],[9576,9622,"You should go."],[9826,9876,"Fine."],[10105,10247,"I'll be seeing you shortly though."],[10456,10589,"Just ignore her, okay?"],[10589,10744,"She's, she's a nobody."],[11023,11161,"When these marks turn black"],[11161,11286,"in seven days,"],[11302,11448,"the curse will be activated."],[11544,11640,"You will die."],[11853,11978,"Useless Snow,"],[11978,12149,"you already lost your baby."],[12178,12324,"Seven days from now,"],[12345,12479,"Ashton will be mine."]],"4":[[0,225,"Snow, you look stunning"],[225,329,"in this dress."],[412,575,"I got it made just in time"],[608,713,"for you to wear at the gala."],[746,859,"It is a little loose though"],[859,1013,"because it was made for maternity."],[1772,1951,"There used to be a baby here."],[2385,2439,"You know what?"],[2519,2627,"I think it needs a necklace."],[2660,2752,"Okay, I'm gonna go get one."],[3107,3332,"Snow, look at this dress."],[3378,3486,"Doesn't this make you believe"],[3486,3628,"how much Ashton loves you?"],[3699,3878,"Why would you want to freeze yourself"],[3878,3995,"and never see him again?"],[4129,4250,"You don't understand."],[4783,4996,"Isn't that Alpha Ashton's Luna?"],[5167,5426,"She's so pure and elegant."],[6081,6197,"What a pleasure it is"],[6197,6339,"to meet the new brand ambassador"],[6339,6519,"for the Blackwood Pack."],[6556,6644,"Who do you have to thank"],[6644,6731,"for your success?"],[6731,6856,"Is it Alpha Ashton?"],[6856,6944,"Of course."],[6944,7069,"The person that I want to"],[7069,7265,"give my thanks the most to is"],[7298,7407,"my boyfriend."]],"5":[[0,183,"Wooh, who's your boyfriend?"],[229,417,"Oh, he's a very special someone"],[417,483,"to me."],[492,817,"He gives me snow lilies every Sunday."],[871,934,"Wait,"],[967,1197,"doesn't Alpha Ashton do that for you too?"],[1814,1939,"He says,"],[1960,2214,"snow lilies symbolize purity."],[2252,2344,"And eternal love."],[2344,2448,"It's just like us, babe."],[2515,2619,"Just like us!"],[2902,3132,"He doesn't even realize I'm watching."],[3282,3470,"He also gives me surprises"],[3470,3603,"all the time."],[3620,3807,"A diamond ring on a toothbrush"],[3807,3891,"when I wake up."],[3949,4012,"A ball gown"],[4012,4120,"underneath the blanket"],[4120,4220,"when I go to bed."],[4220,4433,"Wait, hasn't Alpha Ashton done"],[4433,4617,"all that stuff for you before too?"],[4642,4884,"Mansions, cars..."],[4979,5292,"Oh, he even named a star after me."],[5355,5576,"Ashton named a star after you before too."],[5693,5943,"So you just recycled your tricks on her?"],[6172,6260,"When I'm gone,"],[6297,6514,"regret is going to be your only mate."]],"6":[[8,108,"What a love story."],[129,237,"It sure does seem to match"],[237,392,"our notoriously romantic"],[392,500,"Alpha Ashton."],[533,788,"I feel so special."],[1105,1222,"Hey, whoa, whoa, whoa, whoa."],[1222,1288,"No, no, no."],[1297,1401,"I don't think so."],[1413,1539,"I remember when the Alpha"],[1539,1680,"proposed to our Luna,"],[1718,1889,"he lined up the Golden Gate Bridge"],[1889,2047,"with ten thousand roses"],[2047,2335,"and had fireworks go on for five hours."],[2335,2686,"Alpha Ashton really loves Luna Snow."],[2740,2877,"That was three years ago."],[3953,4133,"Well, my boyfriend just messaged me"],[4133,4225,"that he's gonna prepare"],[4225,4571,"20,000 roses and fireworks"],[4571,4838,"for 10 hours tonight at 7pm."],[4867,5059,"He loves me more."],[5217,5367,"Nobody can question my love"],[5367,5451,"for my babydoll."],[5784,5868,"Show me how you love"],[5868,6031,"fucking me over your Luna."],[6189,6389,"Wow, that's a winner."],[6427,6523,"I told you so."],[6569,6710,"Five more days,"],[6731,6890,"and I will leave this behind."]],"7":[[175,287,"Here's your necklace."],[450,521,"And I do think that"],[521,600,"maybe we should,"],[688,846,"get the belly of your dress trimmed up."],[913,1084,"I'll go talk to the designer and,"],[1113,1242,"maybe Bree can take you home, yeah?"],[1313,1418,"So you can't wait to be"],[1418,1530,"all over your mistress,"],[1589,1693,"can you Ashton?"],[1922,1997,"Where's Ashton?"],[2143,2223,"Let me show you."],[2402,2569,"I knew you'd ditch your Luna for me."],[2610,2669,"Why don't you show me"],[2669,2794,"what type of animal you are"],[2794,2873,"in the sheets?"],[4283,4325,"What the-"],[4838,4896,"What are you-"],[4967,5096,"I can't let them know that we know."],[5130,5205,"Why?"],[5263,5397,"How could he do this to you?"],[5467,5593,"But you've never loved anyone else"],[5593,5651,"but him."],[5680,5818,"And that's exactly why I've decided"],[5818,5914,"to leave him forever."],[5976,6076,"But I can't let him know"],[6076,6277,"until he receives my deceased notice."],[6352,6560,"I'll never forgive him."],[6660,6756,"He's lost me."],[6873,7007,"And he's gonna regret it"],[7019,7178,"when he sees our mate bond"],[7178,7319,"break on my deathbed."]],"8":[[216,271,"When are you gonna"],[271,346,"break your mate bond"],[346,404,"with Snow, baby-"],[404,538,"Don't even think about it, Colleen."],[558,646,"Okay, my mate bond"],[684,792,"is not up for discussion."],[913,1092,"But you told me that I'm better in bed."],[1138,1397,"What I told you is that all this is,"],[1468,1543,"is pounding meat."],[1543,1601,"That's it."],[1659,1805,"We've been together for over a year."],[1805,1922,"I'm sure that I'm more than"],[1922,2002,"just a thrill."],[2022,2268,"This arrangement consists of you"],[2268,2389,"fulfilling my needs"],[2423,2602,"and you get whatever you want, okay?"],[2602,2819,"But I will never love you."],[2848,3119,"And I will never mark you as my mate."],[3207,3307,"How can you not love me"],[3307,3403,"after all the time"],[3403,3511,"that we spent together?"],[3511,3687,"Snow is the one I love, okay?"],[3687,3824,"She's my one and only."],[3824,3933,"And she's my Luna."],[4133,4329,"But Snow, you still have 5 days"],[4329,4441,"to change your mind."],[4688,4758,"Snow?"],[4825,4884,"Snow?"],[4884,4975,"Someone help!"],[5063,5155,"Someone help! - But I'm pregnant."],[5355,5401,"Snow!"],[5484,5543,"What happened?"],[5563,5622,"What happened?"],[5622,5759,"She's having an asthma attack."],[5784,5947,"I, I can't find her inhaler."],[5947,6043,"It's not here."],[6064,6143,"It's okay."],[6206,6339,"I always keep one on me just in case."],[6448,6514,"Come on, baby."],[6539,6585,"Come on."],[6936,6990,"There you go."],[7169,7286,"Bree, call an ambulance."],[8199,8345,"Snow, are you gonna sacrifice yourself"],[8345,8433,"in five days?"]],"9":[[87,337,"I want your forever mate bond, Ashton."],[396,592,"I will replace Snow as your Luna"],[592,738,"no matter what it takes."],[950,1021,"It's just"],[1142,1355,"body paint from the festival."],[1363,1418,"Snow."],[1501,1580,"Snow, come on, baby."],[1580,1639,"Snow!"],[1668,1743,"Snow!"],[2852,2982,"Oh, babe, you're awake."],[3132,3294,"Ashton was actually watching over you"],[3294,3370,"the whole night."],[3820,3937,"You broke my heart."],[3974,4149,"Our child is dead."],[4258,4379,"It's all too late."],[4654,4783,"I think I want to go home."],[4808,4900,"I'll get the doctor."],[5672,5755,"I used my magic"],[5755,5914,"to hide the curse's mark for you."],[6348,6523,"He seems to actually care about you."],[6585,6690,"There are still four days"],[6690,6827,"before you freeze yourself."],[6852,6952,"Do you want to reconsider?"],[7019,7194,"Don't forget that we just saw him"],[7194,7344,"banging another woman"],[7365,7511,"right in front of us."],[7549,7670,"I'm not even gonna say goodbye"],[7670,7749,"when I leave him."]],"10":[[8,250,"If you hate him, you could just leave."],[304,458,"You don't have to sacrifice yourself"],[458,575,"to save the pack."],[650,834,"I might not have any love for him left,"],[834,1013,"but I'm still the Luna of the pack."],[1013,1272,"But what if Ashton changes his ways?"],[1280,1409,"What if he stops cheating?"],[1488,1551,"Will he?"],[1918,2060,"I'm gonna spend the whole day with you."],[2072,2143,"Hi."],[2252,2394,"I'm looking for my boyfriend."],[2548,2669,"What the hell are you doing here?"],[2711,2811,"Your butler let me in."],[2869,3023,"You see, my boyfriend lives"],[3023,3140,"in this neighborhood, too."],[3203,3336,"I think you got the wrong place."],[3336,3465,"My boyfriend tells me that"],[3465,3549,"he can't sleep"],[3549,3720,"unless I'm in his arms."],[3720,3891,"So I came to alleviate him."],[3891,3970,"You see,"],[4024,4175,"what he can't get from home,"],[4175,4337,"well, he gets it from me."],[4379,4462,"Excuse me."],[4496,4633,"My Luna is still recovering."],[4692,4829,"So please be mindful and leave."],[4859,4984,"Oh, I heard that you fainted."],[5034,5238,"I hope you don't have another miscarriage."],[5459,5643,"What if I was to have babies-"],[5643,5730,"Are you deaf?"],[5893,6101,"Miss Wickham, my husband has spoken."],[6122,6289,"Please leave so I can rest."],[6802,6861,"Ashton?"],[7169,7365,"And don't you ever come back here."],[7716,7870,"Everything that you have, Snow,"],[7870,7982,"is gonna be mine."],[8041,8287,"Your wardrobe, your bed, your husband."],[8337,8500,"It's all gonna be mine."]],"11":[[517,738,"Snow, I am so sorry"],[738,850,"that she disturbed you, okay?"],[850,971,"I already fired the butler."],[984,1126,"She will not disturb you again."],[1197,1272,"Here, sit down."],[1643,1785,"I'm gonna go get your medicine, okay?"],[2907,3057,"Quit faking it, Snow."],[3103,3240,"You already know your Alpha husband"],[3240,3440,"is cheating on you with me."],[3520,3632,"You think playing dumb"],[3674,3778,"will keep him around?"],[3862,4070,"I'll let you in on a little secret."],[4850,5000,"I'm pregnant."],[5050,5263,"You're too useless to keep your baby"],[5313,5597,"so give Ashton to me and my baby"],[5630,5980,"because he doesn't love you."],[6477,6694,"Snow, why are all your things gone?"],[6694,6790,"Are you going somewhere?"]],"12":[[171,221,"Are you okay?"],[221,387,"I'm worried about you."],[387,825,"Yeah, I just wanted some new things."],[942,1184,"But those are all your favorite brands."],[1276,1413,"Even if I like something,"],[1413,1468,"that doesn't mean"],[1468,1659,"I won't get sick of it eventually."],[1747,1885,"And then I want something new."],[1947,2122,"Because it's more fun and exciting,"],[2160,2193,"right?"],[2456,2565,"Look, did I do something wrong?"],[2565,2806,"Because if I did, you have to tell me."],[2911,3032,"Why would you assume that?"],[3194,3278,"Is it because"],[3299,3445,"you're guilty about something?"],[3591,3641,"Look."],[3745,3807,"I'm sorry"],[3841,4054,"that I neglected your needs."],[4112,4254,"Okay, I didn't realize"],[4254,4308,"you were sick of"],[4308,4379,"You would tell me - all your stuff."],[4450,4612,"if you did something wrong, right?"],[5059,5146,"Come on, Ashton,"],[5146,5317,"show me I don't have to leave."],[5538,5593,"All that stuff"],[5593,5730,"didn't suit you anyways, okay?"],[5755,5880,"I'm gonna buy you new ones."],[6035,6218,"I won't be needing new things anymore."],[6277,6423,"In 4 days, Ashton,"],[6473,6610,"I'm leaving for good."]],"13":[[25,204,"Hey, it is our anniversary"],[262,383,"in three days."],[383,467,"Okay, it's gonna be great."],[467,596,"I am excited."],[646,738,"Okay, there's gonna be"],[738,871,"big champagne towers."],[871,913,"There's gonna be"],[913,1105,"thousands and thousands of roses."],[1130,1234,"And you are gonna"],[1234,1380,"make a grand entrance."],[1380,1476,"You betrayed me,"],[1476,1701,"but your lies is what breaks my heart."],[1701,1805,"Our anniversary..."],[1805,1993,"that's when you lose me forever."],[1993,2118,"Wearing that custom ball gown"],[2118,2218,"I got made for you,"],[2252,2385,"and dazzle everybody."],[2494,2740,"And then I am gonna tell everyone"],[2740,2882,"just how much I love you."],[2932,3057,"I would never do anything"],[3128,3224,"to make you leave me."],[3832,3949,"Show time, Snow!"],[3978,4166,"Watch me take away your Alpha"],[4166,4245,"with just"],[4245,4425,"one phone call."],[5188,5276,"It's just my Beta."],[5951,6014,"I'm sorry, Snow."],[6014,6122,"I have to go."],[6122,6227,"It's a pack emergency."],[6564,6619,"Okay."],[6865,6952,"Rest up, okay?"],[7065,7140,"I'll be back."],[7640,7770,"When these marks turn black"],[7770,7899,"in seven days,"],[7953,8083,"the curse will be activated."],[8095,8362,"And you will die, Luna Snow."],[8475,8579,"Three more days."]],"14":[[967,1034,"Snow,"],[1076,1205,"if you've made up your mind"],[1205,1330,"to freeze yourself,"],[1372,1488,"our men will pick you up"],[1488,1618,"tomorrow at noon."],[1676,1805,"This is your last day"],[1805,1906,"to reconsider."],[2072,2181,"You're my first love."],[2248,2360,"And my only mate."],[2456,2602,"Please, never break my heart."],[2602,2711,"Never betray me."],[2836,3007,"I will not hesitate to leave you."],[3048,3128,"Don't worry."],[3194,3415,"I would never love another woman"],[3415,3495,"besides you."],[3586,3741,"You betrayed our love, Ashton,"],[3770,3970,"and now, you'll lose me forever."],[4020,4083,"I'm determined"],[4083,4187,"to go through with the ritual."],[4195,4366,"Tomorrow is your third-year"],[4366,4546,"mating anniversary with the Alpha."],[4562,4667,"He invited the whole pack"],[4667,4788,"to your celebration."],[4846,4917,"Are you sure"],[4917,5017,"you want to leave him?"],[5017,5246,"To freeze yourself in eternal slumber?"],[5680,5805,"If I wake up, then that means"],[5805,5893,"the Goddess has given me"],[5893,6006,"a second chance at life."],[6193,6281,"The pack will remember"],[6281,6431,"your sacrifice, Luna."],[7015,7111,"Did Ashton tell you"],[7111,7261,"he was traveling for pack business"],[7261,7411,"for the past two days?"],[7486,7603,"You big dummy."],[7628,7811,"Your Alpha husband was with me"],[7828,7912,"the whole time."],[7920,8003,"In fact,"],[8003,8187,"we only just finished this morning."],[8208,8391,"Look, we ran out of condoms."],[9313,9359,"I didn't think"],[9359,9467,"you have the guts to answer."],[9501,9676,"You're nothing to be afraid of, Colleen."],[9755,9905,"Don't think so highly of yourself."]],"15":[[20,104,"Oh, yeah?"],[104,266,"Well then, look at this."],[709,888,"Ashton had to redesign"],[888,1026,"your anniversary gown"],[1026,1217,"because you lost the baby."],[1222,1380,"Well, I had him remake it"],[1380,1568,"to my liking instead."],[1614,1914,"Doesn't it look so much better on me?"],[2335,2456,"Hey, what's this?"],[2460,2715,"That's my mother's old wedding dress."],[2761,2831,"She shredded it"],[2831,2969,"when she found my dad cheating."],[3103,3286,"I've always wanted to fix it for her,"],[3286,3586,"but I mean, what's the point?"],[3774,3912,"Hey, if it's your mom's,"],[3945,4062,"then it matters."],[4091,4170,"I'm gonna send it"],[4170,4329,"to our pack's best designer"],[4329,4454,"and get it redesigned for you."],[4475,4587,"It'll have a fresh start."],[4713,4767,"Where there's a will,"],[4767,4850,"there's a way, right?"],[5317,5484,"If only you hadn't lost the baby!"]],"16":[[3478,3674,"Oh, did my package for you arrive?"],[3762,3903,"Did you know Ashton made"],[3903,4124,"a matching outfit for his newborn?"],[4124,4279,"This isn't gonna go for you now"],[4279,4454,"because your baby is dead!"],[4525,4633,"This is for my baby."],[4633,4779,"He loves me now."]],"17":[[258,433,"Colleen, if Ashton really loved you,"],[508,629,"you wouldn't have to harass me"],[629,784,"trying to convince me that he does."],[1463,1609,"I know you were right, Mom."],[1735,1881,"I should have broken our mate bond"],[1881,2035,"as soon as we met."],[2089,2193,"It's not too late for me"],[2193,2302,"to fix my mistakes."],[2915,3036,"Hey babe, I'm almost done"],[3036,3136,"with that business trip."],[3165,3282,"I'll be back tomorrow just in time"],[3282,3378,"for our anniversary."],[3516,3603,"Tomorrow?"],[3707,3762,"I won't be here"],[3762,3899,"by the time you come back."]],"18":[[41,95,"Alright."],[287,354,"Love you."],[709,792,"Ashton!"],[884,975,"There's a fashion show"],[975,1109,"in New York City tomorrow"],[1109,1317,"and I just got an invite."],[1380,1476,"Could we go together?"],[1689,1835,"Tomorrow's my wedding anniversary."],[1835,1972,"I'll be spending it with Snow"],[1972,2056,"and you know that."],[2056,2235,"But it's just a stupid anniversary."],[2293,2444,"You can do that at any time."],[2444,2585,"The fashion show tomorrow"],[2585,2686,"is the biggest of the year"],[2686,2806,"and it would really"],[2806,2940,"boost my career and-"],[2940,3057,"Non-negotiable!"],[3194,3294,"End of story."],[3382,3457,"But I'm..."],[3787,4066,"Snow, you will not have him"],[4066,4225,"for your anniversary tomorrow."],[4225,4375,"I will make sure of it."],[4421,4550,"In one day's time,"],[4600,4821,"I will be Ashton's one and only."],[5038,5238,"I'm not waiting for you again, Ashton."],[5288,5405,"Tomorrow I'll be frozen."],[5488,5622,"And you'll never see me again."],[5776,5876,"I'm back, Snow!"],[6252,6452,"He actually came home early?"]],"19":[[204,271,"I thought you said that"],[271,433,"you were coming home tomorrow."],[475,650,"Yeah, and you fell for it."],[650,734,"But I only said that"],[734,867,"because I wanted to surprise you."],[917,1034,"Surprise me?"],[1101,1172,"That ball gown"],[1172,1330,"got all botched up on accident."],[1343,1447,"There wasn't enough time"],[1447,1580,"for the designer to make a new one."],[1614,1693,"But I"],[1801,1918,"bought you a new one."],[2064,2122,"Take a look."],[2122,2452,"It is exclusive, limited edition Gucci."],[2473,2590,"It's just a dress."],[2694,2765,"You know I don't really"],[2765,2869,"care about those things."],[3103,3244,"She's really not mad at all?"],[3511,3670,"I won't be wearing it anyways"],[3732,3874,"because I'll be gone by then."],[3991,4087,"Okay, and what about"],[4087,4279,"your anniversary gift to me?"],[4783,4833,"Wait."]],"20":[[62,233,"You still have to wait for tomorrow."],[450,513,"Remember?"],[871,1046,"Well, I cannot wait"],[1046,1146,"to see what's inside."],[1413,1514,"I'm gonna go wash up."],[1835,2097,"It will only h