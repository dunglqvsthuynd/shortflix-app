{"1":[[1155,1305,"Evening, Don Franconi."],[1522,1597,"We took care of"],[1597,1868,"the Torelli's and the Capaldi's,"],[1868,2006,"per your request."],[2168,2373,"The rest should fall in line, surely."],[2577,2623,"Good."],[2727,2852,"You've always been capable, Donny."],[2894,3007,"And loyal to the family."],[3044,3123,"I am."],[3194,3332,"I would die for the family."],[3382,3420,"Yeah."],[3499,3591,"See, that's the problem."],[3878,3978,"Wait, Matteo!"],[4099,4375,"I have served this family for ten years!"],[4375,4454,"Exactly."],[4521,4629,"You're loyal to my father."],[4717,4792,"Not to me."],[5747,5834,"Cut off his head."],[5926,6047,"Deliver it to my father."],[6131,6231,"Don, they're coming after you."],[6268,6368,"Let them try."],[6890,7002,"Okay, l'll see you soon."],[7152,7232,"Love you too."],[7257,7374,"Hey, watch it!"],[7682,7745,"He's injured."],[7745,7845,"He couldn't have gotten far."],[7853,8041,"Let's get the Franconi bastard."],[8812,8892,"Shh."],[8938,9009,"No cops."]],"2":[[83,129,"Shh."],[129,246,"Hey, hey, I'm not gonna"],[246,367,"hurt you, okay?"],[492,621,"You're, you're bleeding."],[696,821,"I'm, I'm gonna call an ambulance."],[821,938,"I said no cops."],[980,1071,"Check over here!"],[1113,1213,"I think he went that way."],[1468,1530,"Help me."],[1906,2014,"Hey, who's that?"],[2548,2665,"You asshole!"],[2719,2781,"You got drunk"],[2781,2927,"and slept with her again, didn't you?"],[2961,3032,"How could you?"],[3032,3219,"I'm pregnant with your baby!"],[3374,3465,"Check another direction."],[3465,3582,"I hate you!"],[3591,3657,"I hate you!"],[3657,3824,"I want to break up!"],[3924,3995,"You done?"],[4087,4154,"Sorry."],[4258,4337,"Did I hurt you?"],[4433,4479,"No."],[4633,4871,"She only kissed me to help me..."],[4871,5196,"So why do I want to kiss her again?"],[5380,5442,"What's your name?"],[5488,5555,"Shelby."],[5684,5789,"Okay, hold on."],[6623,6710,"Snap out of it!"],[6752,6861,"I'm not your girlfriend."],[6881,6994,"I'm calling 911."],[6994,7090,"I said no cops."],[7102,7219,"You need an ambulance."],[7219,7298,"Why do you care?"],[7323,7399,"I'm starting to ask myself"],[7399,7474,"the same thing."],[7540,7628,"Give me my phone."],[8149,8266,"Our first kiss was because"],[8266,8375,"I needed your help."],[8466,8704,"The second one, I was curious."],[8808,9046,"And this time, it's because"],[9046,9192,"I can't get enough of you."]],"3":[[625,709,"Get your own help."],[938,1051,"My assistant is around here."],[1146,1213,"Come with me."],[2052,2181,"I'll take that as a rain check."],[2298,2348,"Don."],[2456,2523,"Don!"],[2615,2702,"Oh, thank God."],[2736,2806,"Thank God."],[3123,3299,"Amos, I need you to do a favor for me."],[3453,3545,"Yeah, what's that?"],[3545,3620,"I need you to find out"],[3620,3687,"everything you can"],[3687,3757,"about that girl."],[3916,4004,"I think I'm in love."],[4938,4984,"Oh my God,"],[4984,5113,"who is he?"],[5576,5684,"Shelby Yates,"],[5684,5843,"senior at Standyne University."],[5901,6068,"And the future Mrs. Franconi."],[6473,6581,"Shelby..."],[6606,6748,"Why is your dad's class so hard?"],[6748,6923,"I literally don't get anything."],[6990,7048,"Don't worry,"],[7048,7132,"we'll go over it together"],[7132,7215,"after class, okay?"],[7261,7319,"Thank you."],[8992,9109,"What's he doing here?"]],"4":[[112,304,"Excuse me, I'm in the middle of a class."],[304,404,"I just need to speak to your daughter"],[404,467,"for a minute."],[467,521,"What?"],[558,663,"Who do you think you are?"],[905,1001,"Yo, chill."],[1151,1230,"Come in peace."],[1372,1459,"Everybody sit down."],[1493,1547,"What the hell?"],[1547,1609,"What kind of trouble"],[1609,1722,"did you get yourself into?"],[2932,3036,"Shelby Yates."],[3211,3353,"I don't think I introduced myself."],[3549,3678,"I'm Matteo Franconi."],[3841,3903,"Wait."],[3953,4191,"He's the leader of the Standyne Mafia."],[4225,4383,"He shot two dozen men yesterday."],[4383,4504,"Isn't he a wanted man?"],[5392,5651,"He's wearing the band-aid I gave him?"],[5651,5755,"Mr. Franconi,"],[5755,5926,"I'd have to kindly ask you to leave."],[6556,6694,"Please don't hurt my dad."],[6777,6844,"Gregory."],[6961,7094,"Is it okay if I call you Gregory?"],[7211,7323,"I'm here to ask out..."],[7365,7432,"No."],[7520,7703,"I'm here to take your daughter's hand"],[7703,7770,"in marriage."]],"5":[[37,87,"What?"],[162,237,"Mr. Franconi,"],[237,392,"I don't know how you know my daughter,"],[425,579,"but that is not possible."],[675,809,"The exit is that way."],[1055,1209,"I wasn't asking."],[1343,1472,"Why would I marry a man"],[1472,1618,"who has a gun pointed at my head?"],[1801,1881,"My Don!"],[1935,2131,"Miss Yates, I need you to comply"],[2168,2356,"before Don Franconi hurts himself."],[2385,2477,"Are you serious?"],[2540,2694,"Okay, this is very childish."],[2694,2798,"You saved me once."],[2852,2957,"You're not going to let me die"],[2957,3103,"because of you, right?"],[3140,3224,"That's enough!"],[3269,3478,"This school is no place for gangsters."],[3887,3953,"Ah."],[4300,4421,"Don Franconi."],[4517,4654,"You should have told me you were coming."],[4733,4871,"To what do we owe this pleasure?"],[4992,5201,"Dr. Yates, this is Mr. Franconi."],[5271,5355,"He just became"],[5355,5655,"the most important member to our board."],[5697,5926,"And he just funded ten labs"],[5926,6031,"towards your research."],[6085,6381,"Call it a preemptive family gift, Dad."],[6427,6589,"Shelby, is it all right if I call him Dad?"],[6589,6652,"No."],[6652,6744,"No, it's not."],[6815,6902,"This is ridiculous."],[6902,6948,"I'm leaving."],[6948,7007,"Wait."],[7102,7265,"I don't think you understand, Shelby."],[7323,7524,"What I want, I take."],[7570,7670,"And what I want..."],[7820,7882,"is you."],[8037,8124,"I have a boyf-"]],"6":[[588,696,"I let that slide once"],[696,792,"in the alley, sweetheart."],[900,1042,"But I will not have you disrespect me"],[1042,1117,"in front of my men."],[1180,1280,"You will marry me."],[1376,1564,"You can't bribe me into marrying you."],[1580,1697,"I don't even know you."],[1718,1801,"But you want to."],[1981,2097,"What the fuck is happening?"],[2264,2373,"Who is this guy, Shelbs?"],[2489,2544,"Nobody."],[2606,2702,"I'm her future husband."],[3157,3269,"This is Harry Lawrence,"],[3269,3428,"my boyfriend since high school."],[3432,3561,"He's the one I'll marry, not you."],[3670,3787,"Harry Lawrence?"],[3816,3958,"I know that name."],[3958,4012,"Hey man, I don't know"],[4012,4170,"what your issue is,"],[4191,4350,"but I will die before-"],[4350,4446,"Yo, woah."],[4504,4637,"Woah, woah, I wasn't being literal."]],"7":[[29,158,"This is Matteo Franconi"],[158,246,"you're talking to."],[262,467,"The Matteo Franconi?"],[625,763,"Oh shit."],[804,917,"Does this mean he knows about"],[917,1067,"my gambling debts with the mafia?"],[1180,1272,"This is a boy."],[1397,1468,"Not a man."],[2027,2168,"What are you doing?"],[2185,2264,"Are you hurt?"],[2264,2364,"I have a feeling your Harry is not"],[2364,2448,"who he acts out to be."],[2544,2677,"Maybe I'll spare him long enough for you"],[2677,2740,"to find out."],[2806,2948,"You're a fucking psychopath."],[3107,3161,"Yeah."],[3274,3357,"I'll be there in ten."],[3674,3837,"And I'll be back to claim you."],[3899,4029,"With no resistance."],[4592,4742,"I want you to give me everything you can"],[4742,4846,"on Harry Lawrence."],[4871,4959,"If I remember correctly,"],[4959,5071,"he's a big baller"],[5071,5234,"and in deep with the Franconis."],[5267,5367,"You got it, boss."],[5534,5684,"Why the hell would Matteo Franconi want"],[5684,5755,"to marry you?"],[5755,5839,"How long have you two"],[5839,5905,"known each other?"],[5922,6110,"I told you, I met him yesterday"],[6110,6222,"when I saved his life."],[6247,6389,"God, he's delusional."],[6556,6656,"Do you think I'm lying?"],[6656,6810,"I just want to know if you love me."],[6810,6919,"I love you, Harry."],[6977,7048,"I love you."],[7278,7357,"Then marry me."],[7411,7582,"Make me the luckiest guy in the world."]],"8":[[158,446,"Oh my god, that's literally so romantic."],[462,654,"He's literally risking his life for her."],[654,984,"Say yes! Say yes! Say yes!"],[984,1138,"I know I don't have a lot of money,"],[1138,1247,"but give me a few years"],[1247,1409,"and I can be the man you deserve."],[1576,1722,"And I'll be back to claim you."],[1805,1860,"Shelby?"],[1981,2135,"Yes, yes, of course."],[2986,3174,"If Matteo Franconi bothers you again,"],[3186,3286,"I'll kick his ass."],[3365,3457,"I'm not scared of him."],[3682,3816,"I should be happy..."],[3816,3933,"but why do I keep"],[3933,4079,"thinking about Matteo?"],[4162,4308,"I can't believe she's stupid enough"],[4308,4512,"to reject Matteo Franconi for me."],[4608,4704,"Now she'll help me pay off"],[4704,4842,"all of my gambling debt."]],"9":[[100,179,"Why am I here?"],[204,450,"Because I received a head?"],[521,633,"One of our own?"],[746,905,"Nothing wrong with taking out the trash."],[905,1092,"How dare you bring heat down"],[1092,1242,"on the Franconi family."],[1251,1405,"Now we need a distraction"],[1405,1555,"to calm things down."],[1555,1985,"Dad, Matteo, can we pretty please"],[1985,2160,"cut the business talk?"],[2277,2423,"I've missed you, Matteo."],[2423,2540,"Tell me you've missed me too."],[2540,2740,"Matteo, you're the head"],[2740,2831,"of the family now."],[2890,3169,"Francesca's always liked you."],[3207,3353,"She's practically my sister."],[3353,3599,"Ew, I'm not your sister."],[3653,3820,"You will marry Francesca."],[3845,4008,"That will calm things down"],[4037,4262,"and bring some stability"],[4262,4412,"back to the Franconi family."],[4537,4763,"Yeah, hell will freeze over first."]],"10":[[16,145,"Plus, I've already proposed"],[145,237,"to somebody else."],[304,487,"Enough of your lies."],[513,759,"I've raised you since you were a child."],[800,950,"You think I don't know you?"],[1005,1267,"You've never had a serious girlfriend"],[1267,1426,"and now you expect me to believe"],[1426,1555,"you're engaged."],[1555,1755,"It's true, so yeah,"],[1768,1901,"I expect you to believe it."],[1926,2127,"Just forget about her."],[2143,2239,"You know I can give you"],[2239,2348,"everything you want."],[2627,2752,"You need to go back to Paris."],[2877,3023,"Before you receive another head,"],[3128,3194,"the next one will be"],[3194,3315,"your own flesh and blood."],[3507,3657,"Fucking bastard."],[3845,3908,"Papa."],[3991,4049,"Why?"],[4108,4312,"I was only in Paris for one year"],[4312,4454,"and he found someone else."],[4454,4583,"Don't worry, mi amore."],[4692,4867,"Papa will find that whore"],[4963,5088,"and we will kill her."]],"11":[[4,158,"I need to show you something."],[337,437,"I was right."],[479,684,"Harry Lawrence is in huge debt"],[684,817,"to the Franconi family."],[880,1217,"This girl, Shelby Yates, she's taken."],[1292,1589,"Francesca is a much better choice for you."],[1589,1680,"She's family."],[1680,1797,"I don't love your daughter."],[1814,1972,"I never have and I never will."],[2060,2423,"And you love this common school girl?"],[2577,2677,"She intrigues me."],[2677,2902,"Did you fall and hit your head?"],[2923,3153,"You're directly disobeying the man"],[3153,3370,"who raised you for some pussy?"],[3370,3490,"Shut your fucking mouth."],[3490,3791,"I'm ordering you to marry Francesca."],[3858,3945,"Are you saying no?"],[4270,4471,"Yeah, I am."],[4608,4892,"And you remember the punishment"],[4954,5267,"for disobeying a family elder."],[5326,5426,"Thirty lashes."],[5522,5605,"Yeah."],[5743,5839,"I've been wanting to feel something"],[5839,5910,"for a while."]],"12":[[70,400,"You stupid, ungrateful bastard."],[400,504,"Thirty lashes."],[513,654,"Get to it, old man."],[1092,1347,"I would do anything for you, Shelby."],[3253,3361,"You're doing great."],[3616,3749,"Where's my reward, Angel?"],[5734,5847,"You're a fool."],[6368,6594,"Shelby, I want to see you now."],[6894,7194,"Is Matteo Franconi really that powerful?"],[7223,7399,"Mom, who cares if he's powerful?"],[7436,7528,"He's a criminal."],[7549,7691,"No criminal is above the law."],[7761,7878,"And Shelby would never be"],[7878,8012,"with someone like him anyways."],[8149,8237,"Of, of course."],[8391,8575,"I need to get rid of Matteo."],[8575,8762,"If he takes Shelby from me..."],[8762,8888,"l'll drown in debt."],[9154,9221,"Excuse me."],[9384,9534,"Hello, Shelby Yates speaking."],[9551,9722,"Shelby, I want to see you now."]],"13":[[266,350,"Babe, what's wrong?"],[442,500,"Nothing."],[500,583,"It was just a scam."],[642,846,"Matteo Franconi is a ticking time bomb."],[884,1009,"The faster Harry and Shelby"],[1009,1134,"get married, the better."],[1146,1234,"Exactly."],[1263,1393,"Once they tie the knot,"],[1393,1647,"Shelby is officially off limits."],[1668,1818,"You're going to marry our daughter off"],[1818,1906,"just like that?"],[1947,2106,"My law office looked into you."],[2156,2252,"You have a huge amount of"],[2252,2339,"gambling debt."],[2373,2498,"How did that old hag find out"],[2498,2606,"about my gambling debt?"],[2694,2823,"This could ruin everything."],[2886,3090,"Mrs. Yates, you got me."],[3123,3219,"I made a mistake."],[3294,3399,"But I learned from it."],[3495,3586,"I'm debt free now."],[3616,3762,"I know you make Shelby happy."],[3787,3891,"But if you want my blessing"],[3891,3958,"to marry her,"],[3958,4129,"I want to see financial statements."],[4141,4404,"Mom, Harry and I love each other."],[4433,4517,"He makes me happy."],[4517,4617,"You said so yourself."],[4879,5155,"Okay, I'm not asking for a lot here."],[5155,5230,"I just want proof"],[5230,5422,"that Harry has no more gambling debt."],[5422,5555,"I'll fake the papers"],[5555,5689,"and this decrepit harpy"],[5689,5780,"will never know."],[5876,5955,"Of course."],[6093,6214,"I completely understand."],[6252,6289,"Ah."],[6293,6352,"See?"],[6385,6485,"He's a good boy."],[6514,6673,"He's got a good head on his shoulders."],[7178,7257,"Excuse me."],[7857,7932,"What do you want?"],[8003,8103,"How did you get my number?"],[8299,8387,"Come on out,"],[8429,8529,"or I'm coming in."]],"14":[[50,120,"I'm definitely changing"],[120,200,"my number tomorrow."],[525,658,"Sorry, I, I'm just gonna"],[658,742,"step out for a second."],[1455,1534,"What do you want?"],[1534,1651,"Are you stalking me?"],[1797,1868,"Stop!"],[1943,2139,"Jesus Christ, you smell like whiskey."],[2139,2252,"Were you drinking and driving?"],[2252,2356,"Oh, you care about me?"],[2673,2736,"Oh my God!"],[2781,2894,"Oh my God, you're bleeding!"],[3036,3136,"I didn't even notice."],[3691,3766,"What happened?"],[3787,3916,"My adoptive father didn't like"],[3916,4029,"that I won't marry his daughter."],[4254,4316,"I told him I'm marrying"],[4316,4383,"you instead."],[4633,4721,"Mr. Franconi."],[4721,4775,"Matteo."],[4775,5030,"Mr. Franconi, Harry's family is in there"],[5030,5105,"with my parents"],[5105,5276,"discussing our marriage."],[5292,5613,"So, please, whatever obsession you have,"],[5613,5764,"just, just stop."],[5764,5826,"Okay?"],[5872,5930,"For me."],[5989,6076,"And for yourself."],[6314,6431,"Harry is using you."],[6435,6502,"Stop."],[6502,6548,"Okay?"],[6589,6681,"You know, everyone says"],[6681,6831,"that you're this dangerous man,"],[6831,6977,"but really you're just"],[6977,7090,"a lost little puppy."],[7223,7332,"A lost little puppy?"],[7419,7494,"Just grow up."],[7507,7549,"Okay?"],[7645,7786,"And stop injuring yourself."],[7999,8137,"And stop following me around."],[8700,8796,"My Don."],[8963,9075,"You don't want us to interfere?"],[9280,9492,"No. I don't want to scare her off."],[9505,9676,"She did call you a lost puppy."],[9909,10026,"We're gonna do this my way."],[10206,10285,"Let me go!"],[10285,10477,"Shelby will never forgive you for this-"],[10523,10560,"Ow!"]],"15":[[4,116,"Where's the Franconi's"],[116,191,"money, huh?"],[362,554,"You owe us five million dollars!"],[583,688,"I'm getting married next week."],[688,838,"My wife's family can pay for it."],[838,892,"Please."],[913,1042,"Married to a woman"],[1042,1217,"so she can repay your debts?"],[1217,1272,"Huh?"],[1305,1430,"What kind of man are you?"],[1960,2160,"I'll pay you back, I swear."],[2256,2406,"You're already ten days late."],[2552,2623,"Ciao."],[2811,2861,"Amos."],[3086,3249,"It's your lucky day, chump."],[3407,3616,"Looks like the Don has an offer for you."],[4688,4796,"Break up with Shelby."],[4859,4904,"And I'll let you"],[4904,5021,"walk out of here alive."],[5080,5217,"She loves me, not you."],[5447,5559,"Well then, why don't I cut you up"],[5559,5751,"into five million little pieces?"],[5772,5926,"One for each dollar that you owe me."],[6022,6068,"No."],[6068,6126,"Don't worry."],[6139,6243,"I'll take my time."],[6285,6427,"I like doing things slow."],[7132,7219,"Harry, where are you?"],[7219,7307,"Are you okay?"],[7361,7411,"No."],[7486,7557,"He's not."],[7628,7703,"Matteo, what have you"],[7703,7795,"done to Harry?"],[7978,8108,"Nothing he doesn't deserve."],[8145,8220,"Come to the warehouse"],[8220,8312,"on 18 Maple Street"],[8312,8383,"and find out."],[8412,8558,"You've got 30 minutes."],[8558,8687,"You're a monster, you-"],[8871,8921,"Nah."],[8983,9059,"She's gonna find out"],[9059,9184,"who the real monster is."]],"16":[[225,433,"Harry, I'm so sorry."],[433,521,"You're in this situation"],[521,604,"because of me."],[788,888,"You asshole!"],[888,1084,"I told you to stop acting like a..."],[1393,1472,"Like a what?"],[1497,1597,"Like a lost puppy?"],[1672,1764,"Call me that again."],[1789,1889,"See what happens."],[2823,2886,"Just..."],[3032,3098,"let him go."],[3161,3224,"Please."],[3461,3570,"What do you willing to give up?"],[3624,3737,"He didn't do anything."],[3745,3878,"Nah, I wouldn't say that."],[3949,4179,"This guy owes five million dollars"],[4179,4266,"in gambling debts"],[4266,4400,"to the Franconi family."],[4433,4592,"The only reason he's still breathing"],[4592,4692,"is because of you."],[4708,4796,"No, that can't be right."],[4796,4904,"You said you paid them back."],[4950,5013,"You ever think that"],[5013,5138,"maybe he's lying to you,"],[5138,5280,"so he can get a marriage out of you,"],[5280,5384,"so he can pay off his debts?"],[5384,5442,"No."],[5459,5559,"Harry loves me."],[5588,5689,"More than anyone."],[5705,5801,"If that's the case, Shelby,"],[5801,5914,"then he won't mind choosing."],[6110,6193,"Choosing what?"],[6356,6564,"I'll let you go, debt free, on the house."],[6794,6894,"You give up Shelby."],[6956,7023,"Or..."],[7136,7265,"I'll cut off your fingers."],[7282,7328,"What?"],[7328,7407,"No!"],[7536,7574,"No."]],"17":[[29,100,"Marry me."],[321,412,"You're sick."],[575,746,"Ten days late, ten fingers."],[796,888,"Get to counting."],[1021,1217,"For fuck's sakes, please don't do this."],[1217,1351,"No, please."],[1372,1472,"You can still save him."],[1564,1722,"No, no, not my fingers."],[1722,1776,"No."],[1776,1901,"Shelby, do something."],[1901,2018,"Just do whatever the sicko wants!"],[2018,2156,"I'll marry you, okay?"],[2185,2235,"I'll marry you."],[2235,2306,"Just stop."],[2523,2802,"Nah, I want you to watch."],[3332,3478,"I already said I would marry you."],[3478,3582,"Why would you do that?"],[3582,3674,"Because words are cheap."],[3674,3766,"I need you to show me."]],"18":[[1472,1551,"That's my girl."],[1664,1735,"Happy now?"],[1822,1922,"Will you let him go?"],[1935,2106,"Well, the debt's been repaid."],[2344,2464,"And if you move fast enough,"],[2464,2623,"you could probably get it reattached."],[2669,2786,"Five million cleared with"],[2786,2927,"just a kiss with Shelby?"],[3061,3232,"I'd be a fool if I don't milk this."],[3328,3449,"You can't get rid of me that easy,"],[3449,3524,"Franconi."],[3636,3803,"My love for Shelby's priceless."],[3845,3899,"Harry."],[3899,3958,"Really?"],[3958,4049,"How about an additional"],[4049,4133,"five million dollars"],[4133,4258,"for your priceless love?"],[4308,4396,"Isn't it already enough"],[4396,4487,"that he lost me?"],[4562,4654,"What do you say, Lawrence?"],[4692,4767,"He would never."],[4767,4817,"Cool."],[4988,5075,"Shelby's all yours."]],"19":[[16,95,"What did you say?"],[112,150,"What?"],[150,254,"Do you want me to die?"],[287,433,"I already gave my finger for you."],[433,646,"Just marry him so I can get paid."],[1305,1368,"Pathetic."],[1818,1897,"I'm debt-free..."],[1922,2093,"I'm debt-free, and two million richer."],[2185,2364,"Could Matteo be right about Harry?"],[2927,3036,"I'll wire you your money tonight."],[3178,3278,"Now get the fuck out."],[3507,3549,"Harry?"],[3582,3645,"Harry?"],[3849,3983,"Wedding in two days."],[4029,4166,"Future Mrs. Franconi."],[4913,5021,"You little slut!"]],"20":[[20,183,"Celia, what is the meaning of this?"],[183,425,"Harry got home traumatized,"],[425,600,"telling us the wedding is off."],[646,796,"Then the feds come out of nowhere"],[796,909,"and arrest him."],[921,980,"What?"],[1030,1126,"Arrested for what?"],[1126,1259,"This is all your fault."],[1292,1480,"Your digging into his finances"],[1480,1655,"must have caused a federal review."],[1664,1772,"Do you know what they're saying?"],[1772,1881,"That he must have borrowed money"],[1881,1981,"from the mafia."],[2022,2214,"I only have one son."],[2252,2348,"He can't go to prison."],[2385,2556,"You have ruined his life."],[2556,2635,"He has to pay"],[2635,2790,"a twenty million dollar fine"],[2806,2940,"or else he goes to jail"],[2940,3078,"for at least ten years."],[3119,3274,"Are you happy now?"],[3274,3399,"Now wait a goddamn minute."],[3445,3595,"It is not Shelby's fault"],[3595,3774,"that your son has an addiction"],[3774,3828,"to gambling."],[3849,3928,"The judge said"],[3928,4062,"they will lighten his sentence"],[4062,4195,"if we pay the money now."],[4233,4396,"You need to pay the money."],[4433,4529,"This is on you."],[4529,4621,"Are you out of your mind?"],[4621,4696,"Why would we pay?"],[4696,4825,"Mom, Dad, stop."],[4925,5013,"It is my fault."],[5184,5263,"I'll get the money."],[5280,5367,"I'll figure out a way."],[5601,5668,"Shelby."],[5676,5764,"Father in heaven,"],[5818,6035,"I was born in sin and bloodshed."],[6076,6214,"And for that, I repent."],[6252,6356,"Just this once,"],[6356,6535,"please, send an angel"],[6535,6619,"to watch over me."],[7436,7503,"Couldn't wait to see me"],[7503,7590,"until the wedding day?"],[7703,7849,"I came to ask for your help."],[10276,10343,"Help you with what?"],[10706,10781,"Harry, he-"],[10781,10835,"Harry."],[10944,11090,"I'll pay you back every cent."],[11373,11519,"Do you think I need the money?"],[11720,11778,"No."],[12816,12933,"But you've convinced yourself"],[12933,13004,"you need me."]],"21":[[8,145,"You're willing to give yourself to me"],[145,233,"for that asshole?"],[233,350,"I'll give you whatever you want."],[350,550,"Just help him."],[638,759,"Please, he doesn't deserve it."],[1572,1676,"Anything I want?"],[1805,1960,"I'm just doing this for..."],[2156,2444,"What I want is you screaming my name."],[2769,2865,"Your legs shaking like"],[2865,2944,"they can barely walk."],[4441,4567,"But what I want most"],[4637,4804,"is you begging me inside of you"],[4929,5042,"to never leave you."],[5163,5326,"I shouldn't feel like this."],[5367,5518,"This shouldn't feel good."],[5559,5651,"But it does."],[5722,5885,"Am I really gonna do this?"],[5930,6043,"Lose my virginity"],[6043,6206,"to this devil in a church?"]],"22":[[70,296,"How can something so bad feel so good?"],[542,654,"This is not the first time"],[654,754,"I always imagined."],[1259,1313,"Nope."],[1368,1459,"I told you."],[1514,1622,"I want to save our first time"],[1622,1714,"for something special."],[1760,1856,"Like our wedding night."],[2873,2952,"I'm sorry, I'm..."],[3048,3123,"I'm trying."],[3228,3332,"Isn't this what you want?"],[3332,3378,"You-"],[3378,3424,"No."],[3703,3770,"I told you."],[3849,4024,"I want you to want me."],[4133,4241,"I'm not gonna force you."],[5447,5593,"I'll wire your ex the 20 million."],[5705,5826,"And tomorrow we'll get married"],[5826,5972,"and you can forget about him."],[6172,6293,"Or have you changed your mind?"],[6377,6502,"No, I, I haven't."],[6702,6798,"I'll marry you, Matteo."],[6948,7002,"Okay."],[7119,7203,"I'll see you tomorrow."],[8683,8875,"Shelby, are you absolutely sure"],[8875,8971,"you want to do this?"],[9100,9259,"Say the word and we'll get out of here."]],"23":[[33,120,"Don't worry, Dad."],[208,300,"I'm gonna be fine."],[354,467,"I know what I signed up for."],[654,704,"I'll take care of"],[704,821,"your daughter now, Dr. Yates,"],[942,1051,"even if you don't think I will."],[1856,1956,"What do you think of the wedding?"],[2056,2181,"I wanted everything to be perfect."],[2243,2385,"I even got you your favorite flowers."],[2473,2569,"How did you know?"],[2602,2706,"I know everything about you."],[2727,2869,"I know your favorite color is red."],[2911,3057,"You have to sleep with a nightlight on."],[3161,3286,"And you're afraid of snakes."],[3307,3507,"That's creepy, not romantic."],[3553,3691,"Look, you pretend to know me,"],[3691,3791,"but that doesn't actually mean"],[3791,3891,"that you understand me."],[3912,4033,"I want to know you"],[4033,4158,"more than anything in this world."],[4187,4295,"Will you give me that chance?"],[4625,4700,"Start the wedding."],[4859,5034,"Matteo Franconi, do you..."],[5034,5092,"I do."],[5196,5296,"Shelby Yates,"],[5359,5513,"do you take Matteo Franconi"],[5543,5726,"to be your lawfully wed husband?"],[5809,5930,"This should have been Harry"],[5930,6035,"standing here with me,"],[6035,6177,"not Matteo Franconi."],[6231,6310,"Miss Yates,"],[6439,6594,"do you take Matteo Franconi"],[6594,6740,"to be your lawfully wedded husband?"],[6815,6919,"I... I..."],[7511,7603,"I object!"]],"24":[[304,454,"You smug bastard."],[487,608,"You couldn't get your own woman,"],[608,713,"so you went after mine."],[746,896,"I won't let you marry Shelby,"],[930,1084,"even if it kills me."],[1167,1247,"Here to squeeze me"],[1247,1338,"for more money, are you?"],[1388,1614,"If I can score just one last time,"],[1614,1805,"I'll be set for life."],[1856,2160,"Shelby, your heart belongs with me."],[2160,2331,"You know it as well as I do."],[2331,2456,"Let's go somewhere"],[2498,2631,"where we can be together."],[3069,3182,"Marry me instead."],[3411,3611,"I signed a contract to marry Matteo."],[3632,3728,"Forget the contract."],[3741,3853,"My debt is cleared"],[3853,3958,"and I already moved the money"],[3958,4133,"he gave me into offshore accounts."],[4204,4291,"Look, I don't want to force you"],[4291,4408,"to do anything you don't want to do."],[4450,4579,"Even if that means leaving you?"],[4604,4700,"What kind of husband would I be"],[4700,4896,"if I forced my wife to marry me?"],[5005,5109,"What a sucker."],[5130,5201,"I'd lock her up"],[5201,5347,"if I spent this much money on her."],[5380,5467,"But just one thing."],[5543,5714,"Harry, if I offered you thirty million dollars"],[5714,5851,"to walk out those doors"],[5851,5993,"and leave Shelby behind forever,"],[6114,6189,"would you do it?"]],"25":[[191,279,"Thirty million?"],[279,392,"He's insane!"],[412,621,"Thirty million dollars?"],[675,738,"Not a penny more."],[738,850,"I'm not playing these games."],[909,1080,"Matteo, you only understand money."],[1155,1301,"You'll never understand the love"],[1301,1393,"between Harry and I."],[2431,2560,"All I gotta do is press send."],[2798,2902,"Come on, Harry, let's go."],[2902,2961,"Send it."],[3136,3224,"What are you doing?"],[3607,3674,"Send it."]],"26":[[54,312,"I never expected your gambling"],[312,425,"to come to any good."],[467,684,"But you've restored the family fortune."],[754,905,"My amazing son."],[959,1146,"Now you can find a real woman to love,"],[1180,1338,"instead of that pathetic whore."],[1493,1668,"Harry, I only did this for you!"],[1914,1985,"Harry!"],[2356,2489,"Harry was just using you for money."],[2531,2769,"To me, you're priceless."],[2902,3119,"This whole time, Harry lied to me."],[3144,3240,"How could he?"],[3261,3390,"I won't be a liar."],[3390,3536,"I gave my word to Matteo."],[3645,3720,"I'll marry you."],[3795,3883,"Not if you feel like"],[3883,3978,"you owe me anything."],[3978,4087,"I'm going to marry you."],[4087,4187,"I gave you my word."],[4304,4525,"Shelby, you don't have to do it."],[4571,4788,"Shelby, honey, you're heartbroken."],[4788,4909,"Don't rush yourself."],[4917,5046,"Look, I don't wanna force you."],[5046,5163,"Are you a man of your word?"],[5201,5342,"You said you were going to marry me,"],[5342,5405,"so do it!"],[5634,5855,"I, Shelby Yates, take Matteo Franconi"],[5855,6010,"to be my lawfully wedded husband."]],"27":[[29,300,"Welcome home, Mr. and Mrs. Franconi."],[325,412,"Mrs. Franconi,"],[412,583,"please allow me to help you."],[784,934,"We want you to be comfortable."],[1192,1422,"Thank you, but no need."],[1459,1605,"I really don't want anything right now."],[1772,1818,"These are keys"],[1818,1931,"to your catamaran yacht,"],[1931,2047,"your Lamborghini Veneno,"],[2047,2235,"and your Gulfstream G550."],[2235,2381,"Crews are all on standby as well."],[2644,2727,"Mrs. Franconi,"],[2727,2977,"stocks of over 18 billion dollars"],[2977,3048,"have been transferred"],[3048,3119,"to your name."],[3228,3399,"And lastly, Mrs. Franconi,"],[3399,3566,"these are deeds done in your name"],[3566,3774,"to property resorts in Monaco,"],[3774,3937,"the Bahamas, and Paris."],[3937,4037,"If there's anything else you need,"],[4037,4104,"just name it."],[4104,4262,"I told you, you're priceless."],[4391,4562,"I said I don't want anything!"],[4842,4892,"No."],[5071,5167,"You've had a long day."],[5251,5326,"Come with me."]],"28":[[321,458,"I'll have the maids clear this all out."],[513,563,"No."],[596,700,"No, I married you."],[729,859,"I want to do my duty as a good wife."],[859,955,"Do your duty?"],[988,1134,"What, like I'm an obligation?"],[1222,1376,"No, no, no, I told you already."],[1376,1526,"I want you to want me."],[1897,1989,"Your gifts."],[2068,2181,"You're so generous to me."],[2348,2481,"And they're nothing compared to you."],[2744,2852,"I never felt this way"],[2852,2977,"when Harry touched me."],[3053,3219,"Maybe because he never wanted me"],[3219,3332,"like Matteo wants me."],[4095,4149,"Good night."],[6373,6473,"And I'll be back for you."],[6510,6623,"With no resistance."],[6785,6902,"Have I just not wanted"],[6902,7011,"to admit to myself"],[7011,7169,"that I've obsessed over him too?"]],"29":[[1768,1826,"Shelby!"],[2911,3007,"Am I gonna die?"]],"30":[[8,175,"No, no, absolutely not."],[191,333,"Listen, I have to"],[333,496,"suck out this venom, okay?"],[709,759,"Come on."],[2118,2189,"Did that hurt?"],[2298,2410,"It feels better."],[2581,2740,"I gotta get all the venom out."],[2798,2831,"But-"],[2831,2923,"Spead you legs."],[3457,3507,"Yeah."],[3853,3895,"No."],[4124,4233,"Matteo, I..."],[4508,4583,"Matteo."],[4683,4921,"Oh, that feels different."],[6222,6381,"I think I'm okay now."],[6477,6573,"Matteo, I..."]],"31":[[1901,1989,"If I don't stop,"],[2185,2335,"I don't think I can control myself."],[2431,2502,"Then don't."],[3516,3586,"I'm the only snake"],[3586,3741,"that can be in your bed, okay?"],[3895,4058,"But you're just a lost little puppy."],[4179,4304,"You trying to piss me off?"],[4375,4466,"What if I am?"],[4529,4633,"What are you gonna do about it?"],[5380,5501,"What was I doing?"],[5501,5659,"It has to be the venom."],[5676,5830,"There's no way that was me."],[5868,6010,"Someone planted a snake in here."],[6018,6243,"I need you to find out who tonight."],[6760,6806,"I..."],[6894,7023,"I don't wanna sleep in here tonight."],[7152,7248,"You can sleep in my bed."],[7390,7540,"And we can finish what you started."]],"32":[[212,287,"You promise you didn't"],[287,379,"put the snake in my room"],[379,525,"just so I can sleep in your bed?"],[588,759,"You think I would stoop that low?"],[825,917,"Sometimes I don't know"],[917,1005,"what to think of you."],[1297,1455,"So what if I did, Mrs. Franconi?"],[1539,1618,"What are you gonna do?"],[1726,1881,"If I put a snake in your bed,"],[2031,2135,"I would let you die."],[2594,2736,"No, I don't think you would."],[2844,2969,"But I kinda like that idea."],[3086,3228,"You like that I would kill you?"],[3286,3365,"I like that you're becoming"],[3365,3436,"more like me."],[3970,4087,"Well, you should watch your back."],[5305,5351,"Wait."]],"33":[[58,120,"I get it."],[158,229,"You're not ready."],[333,383,"No."],[454,508,"I am."],[508,563,"It's just..."],[688,834,"Just let me shower first."],[888,1071,"I just wanna get off all the snake stuff."],[1776,1989,"Oh my God, what is wrong with me?"],[2018,2185,"That man is a criminal."],[2786,2923,"Oh, but why do I want him?"],[3207,3278,"Okay."],[3370,3428,"Okay."],[4258,4325,"Matteo?"]],"34":[[775,880,"Does that still hurt?"],[1317,1422,"You took that for me?"],[1776,1956,"Harry abandoned me for money."],[1989,2077,"And Matteo,"],[2097,2206,"who already has everything"],[2206,2360,"anyone could possibly want,"],[2360,2448,"chose me."],[2481,2648,"Despite the pain it would cause him."],[3478,3657,"I know I'm supposed to fear him,"],[3657,3883,"but he makes me feel safe."]],"35":[[58,129,"Good morning."],[166,296,"Do you know how hard it was"],[296,387,"to not wake you,"],[400,513,"knowing you wearing this?"],[608,684,"Oh my God!"],[1434,1497,"Yeah."],[1589,1755,"No, I told you I'm on my honeymoon."],[2052,2102,"Hello?"],[2135,2223,"ShellBell?"],[2223,2381,"Thank God, you're alive!"],[2402,2510,"What are you wearing today?"],[2510,2560,"Today?"],[2590,2673,"What's today?"],[2694,2802,"The grad party."],[2802,2998,"I can't believe you forgot."],[2998,3178,"9am at the CMS Hotel."],[3178,3269,"It's a pool party,"],[3269,3395,"so wear a cute swimsuit."],[3395,3536,"Wait, I can't."],[3536,3582,"I'm..."],[3582,3641,"See you."],[4112,4183,"Grad party?"],[4400,4617,"Yeah, but I won't go"],[4617,4721,"because it's our honeymoon."],[4733,4825,"No, you should go."],[4846,4975,"To celebrate your achievements."],[4979,5121,"We got some work to do anyways,"],[5121,5305,"so I'll meet you later."],[6635,6731,"Hey, Francesca."],[6869,7061,"She's going to that pool party today."],[7440,7486,"Yeah."],[7774,7882,"So you're the snake."],[8141,8199,"Please."],[8254,8341,"It wasn't me."],[8387,8475,"It was Ms. Francesca."],[8475,8562,"She made me do it."]],"36":[[675,955,"Matteo, you finally remembered."],[1080,1247,"Out of respect for our father,"],[1247,1476,"this is your first and last warning."],[1518,1743,"If you pull this shit again, you're next."],[1897,1956,"What?"],[3349,3482,"You kids are gonna"],[3482,3578,"do me a little favor."],[3578,3716,"Anything you need, Francesca."],[3716,3858,"Please just don't kill us!"],[4454,4654,"Drown her at your little party today."],[4683,4792,"Isn't, isn't Shelby married to"],[4792,4859,"to your brother?"],[4859,5046,"Matteo's not my brother."],[5125,5267,"But if Matteo Franconi knows"],[5267,5372,"that we killed his bride..."],[5372,5601,"Matteo is just rebelling."],[5601,5755,"She's just a toy to him."],[5755,5855,"He won't care."],[5889,5985,"He'll find another one."],[6014,6147,"I think he's going to care a lot"],[6147,6306,"and I'm too scared to find out."],[6398,6464,"I'll give you something"],[6464,6564,"to be scared of more."]],"37":[[354,625,"Last chance, yes or no?"],[646,725,"We'll do it!"],[763,850,"Okay, okay."],[1639,1726,"Congrats."],[1772,1872,"You get to live."],[1964,2022,"For now."],[2110,2223,"Do this right."],[2277,2385,"Or else..."],[2802,2865,"Bang."],[2965,3057,"Don't worry!"],[3057,3194,"We'll take care of her!"],[3232,3299,"Good."],[3382,3478,"That's what I like to hear."],[3762,4074,"Matteo, you're all mine."]],"38":[[342,421,"Shelby!"],[571,667,"It's a pool party!"],[667,779,"What on earth are you wearing?"],[779,921,"Okay, it sounds kind of stupid,"],[921,1038,"but I never actually learned"],[1038,1088,"how to swim."],[1305,1426,"Well, well."],[1438,1801,"If it isn't Standyne U's beauty queen."],[1830,1893,"Yeah, didn't you"],[1893,1985,"dump our friend Harry"],[1985,2135,"to just marry some rich prick?"],[2218,2310,"I'm still surprised"],[2310,2439,"you're showing your face at the school."],[2452,2585,"What the hell are you guys talking about?"],[2590,2756,"Are you guys literally brain-dead?"],[2790,2911,"You all saw what happened."],[2911,3065,"Shelby was clearly being forced"],[3065,3132,"by Matteo."],[3249,3382,"Forced?"],[3407,3511,"Please."],[3541,3745,"Everybody knows Matteo Franconi"],[3745,3983,"is the hottest bachelor in town."],[4066,4341,"The only hard thing to understand is"],[4341,4825,"why he would want you by his side."],[4859,5021,"Yeah, he's like really out of your league."],[5021,5117,"Why the hell are you guys"],[5117,5226,"picking on Shelby?"],[5242,5338,"Come on, Shelby."],[5417,5522,"What'd I ever do to you?"],[5643,5759,"Where do you think you're going?"],[5780,5864,"Get out of my way."],[5943,6031,"Ow!"],[6072,6114,"Hey!"],[6147,6264,"She hit me!"],[6285,6385,"No, I didn't."],[6452,6527,"Oh my God!"],[6527,6623,"Are you back-talking?"],[6623,6873,"Back-talkers get punished, bitch!"]],"39":[[50,141,"Hey, everybody!"],[141,204,"Come here!"],[375,446,"Did you guys know"],[446,571,"that Shelby's responsible"],[571,771,"for sending the best student in the school"],[771,1001,"to jail and ruining his life?"],[1030,1234,"She's got a real talent for that."],[1263,1447,"Seducing men."],[1447,1634,"Destroying their lives."],[1634,1735,"If you keep running your mouth"],[1735,1826,"then I'm gonna report you."],[2031,2077,"You know what?"],[2077,2227,"I'm gonna report you."],[2227,2402,"Report us for what?"],[2402,2673,"Pointing out that you're a skank?"],[2706,2777,"Go ahead."],[3299,3432,"You bitch!"],[3453,3549,"How dare you?"],[3616,3674,"Grab her!"],[4500,4617,"Anybody else want some?"],[4721,4838,"You assholes!"],[4850,4942,"Grab her!"],[5213,5251,"Stop!"],[5288,5372,"Please!"],[5380,5597,"You like the rich life now, huh?"],[5751,6072,"You like the taste of rich things, huh?"],[6977,7077,"How is it?"],[7077,7219,"Good enough for you?"]],"40":[[25,95,"Cold?"],[162,333,"It's all those wet layers."],[362,475,"Take them off."],[500,650,"It is a pool party."],[1693,1889,"Now you're really dressed for a swim."],[1918,1960,"Stop!"],[1960,2072,"She can't swim!"],[2143,2248,"Exactly."],[2548,2660,"Get off!"]],"41":[[33,125,"Shelby!"],[742,855,"You assholes!"],[855,971,"Let her go!"],[1005,1172,"Aw, don't be mad."],[1330,1480,"Let us help you chill out."],[1947,2072,"What is going on here?"],[2381,2606,"Nothing, Mr. Travis."],[2669,2811,"You should get out of here."],[2811,2990,"I don't take orders from you."],[3011,3182,"I will ask you one more time."],[3182,3336,"What the hell is going on?"],[3336,3499,"They're trying to drown Shelby!"],[3720,3832,"What if I told you"],[3832,4058,"this is Franconi business?"],[4304,4379,"I see."],[4546,4658,"You all be careful now."],[4708,4850,"I don't want any accidents"],[4850,4979,"that I'm responsible for."],[5121,5180,"Wait!"],[5205,5259,"Wait!"]],"42":[[2915,3007,"Secure the premises."],[3007,3123,"Don't let anyone get away."],[3257,3307,"Shelby."],[3345,3407,"Shelby!"]],"43":[[1092,1142,"Shelby."],[1163,1213,"Shelby."],[2627,2711,"Take Shelby home."],[2752,2865,"Make sure she gets warm."],[2919,3003,"I'll be there soon."],[3086,3161,"I have some unfinished"],[3161,3236,"business here."],[3315,3365,"I'm sorry-"],[3365,3453,"What's going on here?"],[3453,3516,"I'm sorry."],[3541,3595,"Weren't you in charge"],[3595,3695,"of the grad party?"],[3720,3820,"What happened?"],[3887,4099,"She told me it was Franconi business."],[4099,4204,"You idiot!"],[4204,4379,"You had one damn job."],[4379,4479,"How the hell did you sit back"],[4479,4612,"and let something like this happen?"],[4633,5009,"Mr. Franconi, I am deeply sorry."],[5009,5221,"Get out before I kill both of you."],[5221,5284,"Yes, sir."],[5309,5376,"Let's go."],[5492,5676,"We had nothing to 