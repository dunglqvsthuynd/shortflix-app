orry-"],[1426,1480,"I'm sorry."],[1514,1609,"I won't do it again."],[1718,1830,"When she comes to dinner,"],[1830,1926,"what are you gonna say?"],[2127,2252,"Welcome to the family,"],[2327,2444,"Mrs. Franconi."],[2560,2640,"Good girl."],[2681,2781,"Enjoy your bath."],[3261,3403,"I'll say it at her grave."],[3445,3641,"Matteo, you forgot."],[3670,3916,"Franconis always get what they want."],[3937,4183,"Even if death tries to stop us."]],"48":[[462,592,"Harry, you already"],[592,696,"had your chance with me."],[1830,1960,"Why are you calling me?"],[1960,2097,"Shelby, I'm in real trouble."],[2097,2193,"I need your help."],[2214,2264,"What?"],[2264,2381,"What are you talking about?"],[2406,2510,"It's about Matteo."],[2510,2610,"He set me up."],[2723,2786,"No."],[2786,2961,"No, you were the one who was lying."],[2982,3119,"I can explain everything in person."],[3140,3211,"Please."],[3211,3395,"Matteo said I can't leave because..."],[3395,3536,"You can't go anywhere?"],[3570,3703,"He can't tell you what to do."],[3724,3795,"No, Harry."],[3795,3920,"It's not like that."],[3920,4058,"It's exactly like that."],[4074,4279,"He's ordering you around like a child."],[4279,4450,"It fits into exactly what I'm saying."],[4600,4683,"What happened?"],[4717,4854,"I can't say more on the phone."],[4879,4992,"Meet me at that warehouse"],[4992,5159,"by the school in half an hour."]],"49":[[909,1030,"Why would you want to meet here?"],[1080,1197,"Because Matteo wouldn't expect me"],[1197,1288,"to hide out in the place"],[1288,1409,"he basically tortured me."],[1497,1572,"What's going on?"],[1622,1772,"Matteo set me up, Shelby."],[1851,1901,"You heard him."],[1901,2056,"He set up a gambling trap for me."],[2056,2223,"Yeah, no, I don't care about that."],[2223,2302,"I'm not gonna help you"],[2302,2402,"collect the money you got"],[2402,2510,"by selling me off."],[2510,2565,"No, no, no."],[2565,2673,"Wait, wait, wait."],[2686,2806,"My goal was always"],[2806,2936,"to get as much money from him"],[2936,3094,"so you and I could run off together."],[3140,3249,"He told you he wouldn't force you"],[3249,3319,"to marry him."],[3319,3424,"I don't believe you."],[3457,3486,"Okay?"],[3486,3632,"I'm sure your parents were very happy"],[3632,3720,"when we broke up."],[3728,3866,"To hell with my parents."],[3895,3999,"It's you."],[4008,4212,"It's always been you."]],"50":[[25,179,"If you ask Matteo for the money,"],[196,275,"he'll give it to you."],[275,421,"And then you and I can run off together."],[421,487,"I mean, anywhere."],[487,638,"Switzerland, Thailand, the moon."],[638,721,"I don't care."],[721,942,"Harry, Matteo and I are married."],[1051,1142,"I gave him my promise"],[1142,1297,"and I don't break my promises."],[1526,1664,"You only promised him"],[1710,1805,"because he promised"],[1805,1922,"to give me my money."],[1951,2077,"And then he took my finger."],[2097,2214,"Then why are you still alive?"],[2248,2406,"The Franconis always collect."],[2548,2690,"Did I really mean nothing to you?"],[2744,2865,"You forget me that easily?"],[2886,2940,"I'm the one"],[2940,3053,"who meant nothing to you."],[3107,3186,"You broke my heart"],[3186,3303,"when you gambled it away."],[3319,3520,"What a touching comeback, Shelby."]],"51":[[275,375,"Harry, who is she?"],[433,529,"Where's my money?"],[571,750,"I said I'd pay you if you got her"],[750,905,"to squeeze money out of Matteo."],[955,1030,"You didn't."],[1076,1209,"That wasn't the deal."],[1242,1317,"New deal."],[1380,1447,"You get to keep"],[1447,1676,"the rest of your fingers and toes"],[1676,1897,"if you leave right now."],[2085,2248,"That wasn't what-"],[2665,2736,"What was that?"],[2961,3119,"That wasn't what we-"],[3349,3595,"Every five seconds you stick around"],[3611,3895,"is another finger smashed."],[3983,4120,"You truly are the world's"],[4120,4254,"best worst gambler."],[4283,4554,"How does one lose 30 million dollars"],[4554,4683,"in two days?"],[4892,5088,"And you, Shelby."],[5213,5559,"I'm Francesca