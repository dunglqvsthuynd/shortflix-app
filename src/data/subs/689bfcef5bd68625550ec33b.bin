{"1":[[834,917,"Ms. Watson!"],[917,1076,"No, Dad, I already told you,"],[1076,1188,"you can't make me go to that"],[1188,1276,"dinner tonight!"],[1292,1434,"I'm sick of those..."],[1472,1680,"Nepo baby politician kids!"],[1680,1785,"Plus, Marc is throwing a"],[1785,1839,"party tonight"],[1839,1943,"at Maple Mansion."],[1951,2010,"It's not about"],[2010,2168,"the dinner, Bella."],[2168,2318,"It's about your boyfriend."],[2398,2523,"Marc got recruited"],[2523,2723,"by Harvard Crimson."],[2781,2952,"Oh my God!"],[2994,3157,"All those years of tutoring him,"],[3157,3307,"all the strings I pulled"],[3307,3482,"with the Harvard and the NFL"],[3482,3586,"coaches to even get them"],[3586,3787,"to consider his application."],[3820,3945,"They paid off."],[3958,4062,"Marc and I are going to"],[4062,4220,"Harvard together!"],[4266,4354,"Oh my God, he must be"],[4354,4475,"throwing this party for me."],[4475,4600,"He wants to thank me for all"],[4600,4704,"the help I gave him."],[4704,4821,"He should thank you."],[4821,4925,"He never would have made the"],[4925,5005,"team without you."],[5005,5125,"I can't wait to see what"],[5125,5213,"surprises he has"],[5213,5321,"planned for me!"],[5321,5401,"Now that he's accepted,"],[5401,5534,"at least you can stop hiding"],[5534,5659,"your identity."],[5659,5889,"I mean, dressed like this."],[5889,5930,"Dad."],[5930,6081,"You are my daughter after all."],[6139,6247,"You're the heiress"],[6247,6385,"to the richest family"],[6385,6485,"in the country!"],[6535,6664,"Here."],[6664,6794,"I've bought you some gifts."],[6806,6927,"Dior dress,"],[6927,7082,"Chanel bag, Prada shoes-"],[7082,7298,"Dad, I told you, I've been"],[7298,7407,"dressing like this because I"],[7407,7520,"wanted to find someone who"],[7520,7711,"didn't want me for my money."],[7795,7907,"And I found him."],[7991,8137,"Marc's not like those other"],[8174,8337,"rich kid, Nepo babies,"],[8337,8500,"clout-chasers."],[8558,8687,"He likes me for me."],[8712,8787,"Bella, we are so"],[8787,8946,"perfect together."],[8975,9029,"You know, there's nothing"],[9029,9142,"wrong with being"],[9209,9300,"fat, or"],[9313,9384,"not meeting other"],[9384,9597,"people's beauty standards."],[9680,9751,"I like you just"],[9751,9889,"the way you are."],[10276,10381,"Wait, wait."],[10397,10464,"Can I at least"],[10464,10560,"give you a ride?"],[10560,10618,"You know I don't like you"],[10618,10664,"going anywhere"],[10664,10769,"without bodyguards."],[10769,10806,"No!"],[10806,10885,"I already told you."],[10885,10919,"For now,"],[10919,11077,"I'm still just the maid of"],[11077,11190,"Maple Mansion."],[11248,11298,"I'll tell him"],[11298,11398,"after the party."],[11440,11582,"I can't wait to see the look"],[11582,11715,"on his face when he finds out"],[11715,11820,"that I'm"],[11820,11953,"the Watson heiress."]],"2":[[863,942,"Wow."],[942,1151,"Marc, you are so humble."],[1151,1226,"You didn't tell us you lived"],[1226,1401,"at the Maple Mansion."],[1401,1576,"I mean, the biggest grandest"],[1576,1718,"house in town."],[1718,1805,"Isn't this owned by the"],[1805,1910,"Watson family?"],[1964,2077,"So does that mean..."],[2077,2185,"I know that the Watsons have"],[2185,2356,"a kid in our grade."],[2356,2473,"The secret heir of the"],[2473,2656,"multi-billion dollar fortune."],[2719,2794,"Is that you?"],[2923,3032,"I'm no Watson."],[3061,3165,"Bella's just a maid here and"],[3165,3307,"she gave me the passcode."],[3307,3541,"But if these idiots think I'm royalty,"],[3541,3682,"then why not milk it?"],[3695,3828,"I'll be king of the school!"],[3999,4104,"Keep it quiet and I'll take you a"],[4104,4233,"ride in my Lambo later."],[5150,5242,"There’s Marc."],[6031,6151,"Hey everybody,"],[6151,6285,"this party is for someone"],[6285,6427,"really, really special to me."],[6464,6560,"Without her I wouldn't be"],[6560,6710,"headed to Harvard this fall."],[6735,6852,"And that person..."],[6986,7098,"is Jessie!"]],"3":[[204,342,"I mean..."],[346,504,"Yeah, he’s fat and ugly."],[529,646,"But who cares?"],[667,771,"One kiss,"],[771,863,"and now I’ve got"],[863,1051,"my foot in the Watson Family."],[1051,1213,"Totally worth it!"],[1267,1351,"Marc?"],[1443,1555,"You're cheating on me?"],[1605,1697,"Bella? What,"],[1697,1797,"what are you doing here?"],[1797,1931,"Who even invited you?"],[1947,2110,"What am I doing here?"],[2135,2177,"Do you know"],[2177,2264,"what I did for you?"],[2264,2348,"Do you know all"],[2348,2456,"the help I gave you?"],[2456,2585,"You should be thanking me!"],[2602,2723,"Calm down, Bella, or you"],[2723,2836,"might bust right out of that"],[2836,2973,"little maid outfit."],[2973,3115,"I mean, you really thought"],[3115,3382,"Marc threw a party for you?"],[3470,3741,"Aww, and you wrote a card."],[3762,3949,"Let's see what it says."],[4049,4158,"Dear Marc,"],[4191,4396,"you are the most wonderful,"],[4396,4625,"amazing person I know."],[4692,4846,"I'm so lucky..."],[4879,5021,"to be your"],[5030,5092,"girlfriend!"],[5113,5196,"Haha."],[5196,5280,"Since when?"],[5288,5367,"I mean, have you"],[5367,5438,"looked in a mirror?"],[5438,5518,"You would completely"],[5518,5613,"crush Marc."],[5876,5918,"You've been"],[5918,5980,"cheating on me"],[5980,6110,"this entire time."],[6160,6243,"You lied to me."],[6243,6322,"Bella..."],[6727,6835,"I think your uniform's"],[6835,6919,"a little too..."],[7036,7123,"tight."],[7273,7357,"It's cutting off circulation"],[7357,7507,"to your brain."],[7628,7899,"This party's for Jessie."],[8062,8145,"So get the hell"],[8145,8308,"out of here, okay?"],[8308,8445,"You're nothing but a"],[8445,8533,"poor,"],[8575,8666,"desperate,"],[8717,8842,"fat little maid."],[9171,9351,"So you're dumping me for Jessie"],[9351,9446,"because you're this,"],[9534,9697,"big, bad Harvard man now?"],[9880,9993,"I am the one"],[10030,10118,"who got you in."],[10147,10222,"Ugh."],[10222,10293,"It's no wonder you're"],[10293,10427,"so fat and insecure."],[10427,10477,"I mean,"],[10506,10602,"you're just lazy."],[10631,10727,"Taking credit for something"],[10727,10844,"you could never make happen?"],[10869,11061,"I mean, it was my dad who"],[11061,11140,"connected to him with the"],[11140,11211,"Harvard coach and"],[11211,11327,"the NFL president."]],"4":[[33,187,"I mean, look at you."],[187,300,"A poor, desperate little"],[300,458,"piggy trying to hide herself"],[458,525,"from the world in"],[525,696,"those big, ugly clothes."],[696,784,"But I mean, who"],[784,888,"could blame you?"],[896,1063,"There's nothing you could"],[1063,1205,"even possibly help Marc with"],[1205,1309,"except for,"],[1330,1451,"finishing his leftovers."],[1451,1564,"Your insults are as"],[1564,1751,"weak as your lies."],[1751,1885,"God, you're asking me what I could"],[1885,2102,"have done to help Marc with?"],[2252,2394,"How about helping"],[2394,2573,"you study for the SATs?"],[2756,2890,"How about getting the Harvard"],[2890,3015,"football coach"],[3053,3111,"and the NFL"],[3111,3236,"president to write"],[3269,3395,"your rec letters?"],[3607,3728,"How about lending you the"],[3728,3837,"money for your-"],[3837,3953,"Shut the hell up!"],[4112,4291,"And this mansion."],[4325,4429,"The only reason you're all"],[4429,4500,"here today is"],[4500,4667,"because I gave Marc the-"],[6360,6477,"Oh my god,"],[6477,6623,"there's a whale in our pool!"],[6748,6856,"You're gonna let them speak"],[6856,6965,"to me like that?"],[6990,7115,"You're going to treat me like"],[7115,7152,"that after"],[7152,7282,"everything I've done for you?"],[7282,7374,"Everything?"],[7390,7486,"It's nothing compared"],[7486,7603,"to what Jessie's done."],[7670,7770,"You really think anyone would"],[7770,7870,"believe that I got into"],[7870,8062,"Harvard because of you?"],[8112,8241,"Don't be stupid, Bella."],[8333,8487,"Anybody can study, but a broke"],[8487,8696,"girl like you with no talent"],[8696,8867,"and no connections can never"],[8867,8979,"get into Harvard."],[9150,9200,"But hey,"],[9242,9371,"have fun at community college."],[9401,9538,"He has no idea I"],[9538,9638,"already got in."],[10214,10276,"Funny,"],[10331,10402,"because I got into"],[10402,10552,"Harvard last week."]],"5":[[41,100,"Funny,"],[162,233,"because I got into"],[233,367,"Harvard last week."],[417,546,"Marc, how stupid are you"],[546,658,"gonna feel when you see me on"],[658,742,"campus next fall?"],[742,850,"Oh please,"],[850,988,"all you will ever be"],[988,1151,"is a little desperate mutt"],[1151,1263,"who won't leave Marc alone."],[1317,1430,"Bella, I'm going to"],[1430,1564,"Harvard in the fall."],[1564,1730,"And soon I'll be an NFL star."],[1868,2006,"I deserve someone better."],[2260,2327,"You used to say"],[2327,2398,"I was perfect."],[2585,2656,"That we were"],[2656,2740,"perfect together-"],[2740,2898,"You actually believed that?"],[3011,3103,"Bella,"],[3119,3274,"you're an insecure nerd"],[3324,3457,"who hides behind ugly"],[3457,3636,"old rags and clings to me for"],[3636,3741,"dear life because,"],[3799,3832,"you know"],[3832,3945,"that without me,"],[4012,4112,"you'd be nothing."],[4220,4475,"I am far out of your league."],[4867,4971,"Look at yourself."],[5292,5397,"Do you understand how hard it"],[5397,5442,"was for me to"],[5442,5605,"pretend to like you?"],[6143,6206,"Now get the hell"],[6206,6331,"out of my house!"],[6552,6744,"Three years of"],[6744,6923,"hiding my identity."],[6977,7152,"Transferring schools, moving towns,"],[7152,7269,"I did everything to"],[7269,7424,"get him into Harvard."],[7424,7732,"And this is what I get."],[7774,7891,"Sorry Bella,"],[7891,7957,"only girls like"],[7957,8058,"Jessie deserve to be with"],[8058,8183,"someone elite like Marc."],[8233,8350,"How is Marc elite?"],[8350,8466,"Everybody knows that"],[8466,8596,"Maple Mansion is home to the"],[8596,8704,"Watson family"],[8704,8879,"and if this is Marc's house,"],[8879,9029,"then he is the heir."],[9050,9196,"That dirty liar."],[9196,9392,"I'm the Watson heiress!"],[9426,9505,"Marc told you"],[9505,9659,"that he's a Watson?"],[9684,9868,"He told you that this place"],[9868,9993,"belongs to him?"],[9993,10101,"If it's not his house,"],[10101,10172,"then what?"],[10172,10260,"It's yours?"]],"6":[[158,271,"You're just the maid."],[279,417,"Are you so obsessed with Marc"],[417,513,"that you actually think"],[513,567,"you'll become"],[567,671,"lady of the Mansion?"],[688,792,"Well you could..."],[838,975,"be the pet elephant"],[975,1105,"if you try hard enough."],[1217,1430,"But this is my house."],[1430,1597,"I gave Marc the passcode."],[1597,1714,"I let him throw this party"],[1714,1810,"here, and now he's"],[1810,1972,"claiming to be a Watson?"],[1976,2056,"Come on."],[2077,2264,"Marc can date 10s now."],[2264,2414,"A star linebacker going to"],[2414,2573,"Harvard isn't going to date a"],[2573,2777,"pathetic fat nerd like you."],[2998,3123,"Well, without this pathetic"],[3123,3224,"fat nerd, none of you would"],[3224,3319,"be here right now."],[3319,3370,"So."],[3415,3545,"Is she for real?"],[3545,3687,"Are you saying Marc needs the"],[3687,3816,"maid's permission to throw a"],[3816,4004,"party at his own house?"],[4149,4366,"Marc, I hid my identity."],[4387,4533,"I did everything for you."],[4533,4658,"Three years of helping you"],[4658,4721,"get into Harvard"],[4721,4850,"and you used me?"],[4875,4996,"My money, my house,"],[4996,5067,"my life"],[5067,5163,"to play rich and"],[5163,5313,"chase other girls?"],[5522,5638,"Falling for you."],[5651,5868,"Believing your lies."],[5872,5997,"That's the dumbest"],[5997,6168,"thing I've ever done."],[6202,6285,"Bella, you keep"],[6285,6348,"clinging to me."],[6348,6385,"You're starting"],[6385,6468,"to give me the ick."],[6477,6539,"Seriously,"],[6539,6619,"let's get the hell-"],[7219,7265,"You want to"],[7265,7336,"talk about the ick?"],[7478,7632,"I can't believe I ever had"],[7632,7745,"feelings for you."],[7882,7991,"You two are perfect together,"],[7991,8120,"a liar and a bully."],[8141,8266,"How dare you?"],[8700,8837,"Hey, how dare you push Jessie?"],[8863,9021,"Marc, why do you let this"],[9021,9196,"fat-faced, charity case"],[9196,9305,"work for you?"],[9325,9413,"Call your dad,"],[9413,9492,"Mr. Watson, right now and tell"],[9492,9588,"him to fire her!"],[9588,9638,"Yeah, Marc."],[9659,9755,"You're a Watson, right?"],[9755,9809,"Why don't you call"],[9809,9959,"your dad up right now?"]],"7":[[0,95,"You're a Watson, right?"],[95,154,"Why don't you call"],[154,321,"your dad up right now?"],[346,471,"My dad's not a billionaire."],[487,642,"He's a security guard."],[646,742,"I can't call him."],[821,980,"My dad's a very busy man."],[980,1034,"Alright?"],[1034,1109,"I'm not going to waste his"],[1109,1205,"time on an"],[1205,1330,"insignificant maid."],[1388,1509,"You're going to regret this."],[1534,1672,"Oh, the only person who's"],[1672,1793,"gonna regret this is you,"],[1793,1910,"Marc Pierce."],[2072,2143,"I quit."],[2473,2598,"We're over!"],[2802,2894,"I was never"],[2894,3007,"really a maid anyway."],[3028,3182,"Soon they'll all see that I'm"],[3182,3340,"the true Watson heiress,"],[3340,3486,"and Marc is nothing but a"],[3486,3632,"desperate fraud."],[3649,3712,"Wow."],[3749,3795,"Bella's actually"],[3795,3899,"kind of badass."],[3908,4020,"Didn't expect the future"],[4020,4124,"Harvard grad to be"],[4124,4241,"dumped by a nerd."],[4312,4412,"No way."],[4433,4558,"Bella's been clinging on to"],[4558,4729,"Marc for three years."],[4763,4892,"I bet she's going to come"],[4892,5096,"crawling back to Marc in"],[5096,5184,"ten seconds."],[5201,5259,"Ten?"],[5288,5405,"Yeah, I give it five."],[5497,5613,"You know, matter of fact,"],[5613,5684,"if you come back in the"],[5684,5789,"next five seconds,"],[5789,5951,"maybe I'll take you back!"],[6014,6122,"Four,"],[6122,6239,"three,"],[6239,6356,"two,"],[6356,6485,"one!"],[7394,7511,"Okay, that was dramatic,"],[7511,7657,"but she'll be back."],[7732,7853,"She always comes back."],[8546,8708,"Three years,"],[8729,8971,"and this is how you repay me?"],[9046,9163,"Marc, if you say it was all"],[9163,9246,"just a game, then"],[9309,9496,"then it's time to play."]],"8":[[112,271,"Look at you, a poor, desperate"],[271,433,"little piggy hiding herself"],[433,542,"from the world in those"],[542,717,"big old ugly clothes."],[809,1051,"You're an insecure nerd who"],[1051,1301,"hides behind ugly old rags"],[1301,1438,"and clings to me for dear"],[1438,1601,"life because you know,"],[1655,1835,"without me you'd be nothing."],[1885,2131,"I am far out of your league."],[2227,2406,"I hid my true self for you, Marc,"],[2435,2690,"but I never hated who I am."],[2777,2865,"It's time for me to show"],[2865,3040,"everyone the real me."],[4208,4329,"I hear the Harvard Freshman"],[4329,4441,"parties are insane."],[4529,4650,"Maybe I can get you guys in."],[4804,5042,"Babe, I have a great idea."],[5109,5196,"Why don't you just really"],[5196,5309,"focus on like,"],[5351,5509,"losing a little more weight,"],[5526,5634,"until then, and then"],[5693,5797,"we'll look so good together."],[5834,5930,"Oh yeah, no,"],[5985,6047,"I'm trying."],[6101,6218,"Look, who's that?"],[6247,6377,"She's gorgeous, is she new?"]],"9":[[346,400,"Who's that?"],[475,521,"Bella?"],[579,734,"No fucking way."],[763,817,"Bella?"],[842,963,"When did she get so..."],[1005,1096,"Hot?"],[1543,1697,"Earthquake alert!"],[1760,1968,"Oops, it's just Bella."],[2043,2156,"Oh, looks like you finally"],[2156,2314,"got some clothes that fit you"],[2314,2398,"but it doesn't matter"],[2398,2502,"what you're wearing, Bella."],[2519,2731,"You're still a poor maid."],[2940,3044,"Hey, give that back!"],[3069,3261,"Wait, you actually"],[3261,3474,"got into Harvard?"],[3536,3582,"No."],[3603,3645,"No."],[3678,3753,"What am I talking about?"],[3753,3824,"You probably just printed"],[3824,3920,"this out at the library."],[3966,4104,"Harvard doesn't give degrees"],[4104,4200,"in um,"],[4300,4400,"over-eating"],[4400,4525,"or housekeeping."],[4546,4617,"The only two"],[4617,4688,"things you're good at."],[4742,4850,"Did you do this for me, Bella?"],[4900,4942,"It's actually"],[4942,5017,"kind of touching."],[5088,5184,"See, guys, I tell you Bella"],[5184,5251,"would come back?"],[5305,5388,"She's chasing me all the way"],[5388,5488,"to Harvard now."],[5555,5693,"She's a total simp."],[5743,5847,"Following Marc all"],[5847,5905,"the way to Harvard."],[5926,6026,"Too bad she'll never get in."],[6097,6177,"Bella, you do know Harvard"],[6177,6314,"only accepts, like,"],[6335,6548,"really smart people, right?"],[6614,6710,"Do you want me to show"],[6710,6890,"everyone what your test scores were"],[6890,6927,"before I"],[6927,7032,"started tutoring you?"],[7032,7111,"It's not important."],[7132,7228,"Okay, Harvard looks at the"],[7228,7357,"entire profile."],[7378,7482,"You know, you can have good"],[7482,7553,"test scores,"],[7570,7649,"cause you never have"],[7649,7716,"something that we do."],[7766,7937,"Powerful families backing us up."],[8083,8162,"Oh, really?"],[8191,8395,"What makes you think I don't?"],[8466,8646,"Bella, I have the perfect"],[8646,8758,"opportunity for you."],[8783,8858,"Harvard is"],[8858,8983,"looking for a janitor."],[9013,9150,"You should totally apply."],[9192,9334,"Might be your only shot of getting"],[9334,9438,"near Marc again."],[9480,9605,"Yeah, you can clean the"],[9605,9697,"toilets while he's"],[9697,9788,"earning his degree."],[9943,10064,"I will be going to Harvard,"],[10085,10118,"but it has"],[10118,10247,"nothing to do with Marc!"],[10293,10372,"With your background,"],[10372,10447,"you really think you're going to"],[10447,10556,"get into Harvard?"],[10593,10685,"Come on, Bella."],[10685,10748,"This again?"],[10789,10910,"You just want me back."],[11111,11198,"Say you're sorry."],[11232,11348,"Maybe I'll throw you a bone."]],"10":[[0,37,"Marc?"],[133,208,"Dream on."],[254,392,"I'd rather die than be with a"],[392,579,"liar and a cheater like you."],[617,717,"Bella!"],[729,834,"You can't speak to a"],[834,925,"classmate like that."],[1001,1113,"I hear you starting drama"],[1113,1272,"one more time."],[1272,1363,"It's detention."],[1413,1472,"No, Ms. Keller,"],[1472,1526,"it's not like that."],[1526,1601,"They were the ones-"],[1601,1714,"Ms. Keller, its, it's fine."],[1722,1793,"She doesn't mean it."],[1793,1918,"She's just jealous and"],[1918,2022,"regretting everything."],[2043,2122,"I mean,"],[2122,2289,"I am going to Harvard."],[2314,2389,"Well, she hasn't even gotten"],[2389,2585,"to a community college yet."],[2606,2660,"That's very"],[2660,2819,"mature of you, Marc."],[2848,2898,"You should learn"],[2898,2994,"from him, Bella."],[2994,3107,"Bella, it's okay."],[3107,3186,"If it doesn't work out with college,"],[3186,3307,"you can still get a"],[3307,3436,"part-time job."],[3470,3574,"I mean, I heard that"],[3574,3782,"Walmart's hiring."],[4154,4304,"Wow, I'm so touched by how"],[4304,4404,"much you're all worrying"],[4404,4504,"about my future."],[4537,4617,"But trust me,"],[4617,4700,"there's no need."],[4725,4833,"If you're so confident,"],[4833,4892,"why don't you show us your"],[4892,5042,"Harvard acceptance letter?"],[5084,5330,"Oh, you don’t have one,"],[5380,5447,"do you?"],[5572,5726,"Don't be embarrassed, Bella."],[5768,5851,"We can set you up an"],[5851,5972,"appointment with Ms. Keller,"],[5997,6168,"and she can teach you how to"],[6168,6356,"apply to community college."],[6377,6527,"Yeah, or you can come back"],[6527,6656,"and work for me as a maid."],[6710,6827,"What'll it be, Bella?"],[7870,8003,"Wait, what was that?"],[8933,8979,"Who the hell"],[8979,9084,"are these people?"],[9142,9300,"Ms. Bella! Ms. Bella!"],[10181,10360,"Ms. Bella! Ms. Bella!"],[10360,10422,"Your Harvard"],[10422,10581,"acceptance letter is here."],[10593,10660,"What?"],[10660,10735,"Thank you, Daniel."],[10735,10839,"You're welcome."],[11340,11411,"No, there's no way"],[11411,11561,"you got into Harvard."],[11736,11790,"What?"],[11790,11903,"Like, it's hard?"]],"11":[[0,83,"It's real."],[100,225,"It's a real Harvard"],[225,329,"acceptance letter!"],[342,542,"She really got into Harvard."],[542,700,"This cannot be happening."],[725,959,"Bye, losers!"],[1176,1401,"There is no fucking way"],[1434,1497,"a girl like Bella"],[1497,1593,"got into Harvard."],[1593,1722,"That letter has to be fake."],[1722,1843,"Then how'd she get that black"],[1843,1993,"car convoy and those guards"],[1993,2189,"and that bodyguard?"],[2231,2285,"I mean, she looks"],[2285,2373,"like a damn princess."],[2402,2535,"She probably rented it."],[2535,2694,"Used all her salary so she"],[2694,2844,"could flex on us."],[2902,3111,"But matter of fact, Marc, why"],[3111,3207,"don't you have a black car"],[3207,3370,"picking you up from school?"],[3382,3470,"You are the"],[3470,3607,"Watson heir, right?"],[3628,3707,"Yeah, Marc."],[3707,3753,"Just have one of"],[3753,3883,"your cars pick us up."],[4166,4371,"I don't like to show off."],[4466,4537,"Come on, it's"],[4537,4679,"so corny, right?"],[4696,4859,"I mean, my parents always"],[4859,5067,"told me to be a Watson is to"],[5067,5134,"be classy and"],[5134,5330,"humble, no matter what."],[5563,5764,"That is so hot."],[5964,6181,"Bella, you really go that far"],[6181,6327,"just to make me regret"],[6327,6481,"breaking up with you?"],[6489,6610,"Well, guess what?"],[6639,6773,"I won't let you win."]],"12":[[291,392,"I love you."],[471,571,"I love you, too."],[642,759,"Dad, I didn't expect Marc to"],[759,871,"change like that the moment"],[871,1009,"he got his Harvard offer."],[1013,1117,"He didn't change."],[1151,1213,"He showed you"],[1213,1334,"who he really was."],[1438,1551,"I told you,"],[1589,1664,"hard work is the"],[1664,1726,"one thing that"],[1726,1926,"will never betray you."],[2118,2168,"Right."],[2327,2477,"Queens never cry."],[2585,2715,"The only boy who should be"],[2715,2777,"crying is the one"],[2777,2852,"who betrayed me."],[2873,3094,"Now, that's my daughter."],[3174,3278,"And I'll always"],[32