{"1":[[546,667,"Logan, please pick up."],[688,821,"It hurts so much,"],[821,988,"the baby's coming again."],[1059,1192,"I can't do it alone."],[2260,2381,"My baby."],[3003,3140,"Nice to see you, sis."],[3140,3315,"Mom, Selina."],[3374,3474,"How?"],[3516,3812,"We put a tracker on your car, dumbass."],[4437,4650,"Stay away from my baby."],[4825,4888,"See?"],[4925,5150,"Logan will always believe me"],[5192,5284,"over you."],[5342,5455,"And it didn't take that much"],[5455,5580,"to get Logan out of the house"],[5580,5801,"since he's, like, obsessed with me."],[5851,6068,"Did you like the photo I sent you?"],[6231,6410,"I told you, sis."],[6443,6652,"I'm gonna take everything"],[6652,6769,"away from you."],[6827,7036,"A fake photo and a few little tricks."],[7036,7136,"That's all it took"],[7136,7290,"to tear a loving couple apart."],[7315,7436,"Come on, let's go."],[7469,7578,"Let her die here."],[7778,7878,"Please, don't go."],[7907,8041,"Please, don't go."],[8041,8158,"Please, my baby."],[8216,8291,"No, my baby."],[8733,8888,"My baby!"],[9192,9300,"Ah, thank God, you're awake."],[9451,9526,"I was so worried"],[9526,9634,"when the cops called me."],[9642,9743,"It's a good thing you have me"],[9743,9897,"listed as your emergency contact."],[9918,10076,"God, my head hurts."],[10114,10243,"Do you remember what happened?"],[10243,10397,"The doctor said you have a concussion."],[10418,10543,"Yeah, I was sitting there and,"],[10568,10698,"and, and my water broke"],[10698,10814,"and it was raining outside."],[10814,10931,"And then Selina and,"],[10931,11073,"wait, where's my baby, Andy?"],[11073,11140,"It's okay."],[11152,11198,"It's okay,"],[11198,11282,"she's right here."],[11636,11774,"See, she's beautiful."],[11932,12028,"Then last night,"],[12066,12203,"it must've been a horrible nightmare."],[12203,12358,"I, I dreamt Selina and Margaret"],[12358,12454,"took my baby."],[12796,12925,"Logan's been cheating on me"],[12925,13004,"with Selina."],[13067,13179,"I want a divorce."],[13759,13913,"Any update on where my wife is, huh?"],[14030,14143,"I'm sorry, boss."],[14168,14272,"She's alone"],[14293,14389,"and pregnant."],[14485,14660,"And I'm the one that drove her away."],[14731,14873,"If anything happens to her,"],[14873,15015,"I could never forgive myself."],[15094,15231,"I'm gonna take my daughter"],[15231,15377,"and I'm never coming back."],[15377,15448,"Don't worry,"],[15482,15540,"I'll help you."],[15540,15686,"I'll make sure he never finds you."],[15957,16045,"Logan!"],[16107,16224,"I'm so sorry."],[16224,16358,"Winnie left the baby out"],[16358,16499,"by herself in the rain."],[16595,16695,"Call the best doctor."],[16766,16937,"You make sure they can save my child."],[17075,17275,"I thought you loved me, Winnie Cullen."],[17275,17413,"Abandoning our child?"],[17446,17559,"You better stay gone."],[17559,17688,"And don't let me find you."]],"2":[[279,446,"I can't believe it's been six years"],[446,554,"since I've been back."],[575,742,"If it weren't for the medical convention,"],[742,942,"I'd never step foot in LA again."],[963,1184,"Mommy, isn't Daddy in the city?"],[1209,1355,"Are we finally going to meet him?"],[1372,1580,"Abby, sweetie, we've talked about this."],[1630,1801,"We're only gonna be here for one month"],[1801,1922,"for Mommy's work, okay?"],[1956,2060,"We'll be back in England"],[2060,2177,"just in time for Christmas."],[2189,2356,"But I kind of wanted to see him"],[2356,2494,"just once in person."],[2581,2769,"I'm sick of only looking at this photo."],[2840,3040,"But if Logan finds out about Abby"],[3040,3186,"and fights me for custody,"],[3211,3382,"I don't stand a chance."],[3511,3641,"Daddy has a new life"],[3641,3845,"and probably a new family."],[3874,3995,"We shouldn't bother him."],[4054,4204,"Besides, he hates Mommy."],[4204,4291,"Remember?"],[4312,4446,"Then he's a bad person,"],[4446,4579,"and I don't want him either."],[5347,5430,"Wait."],[5480,5684,"Isn't that the man on this photo?"],[5684,5784,"My daddy?"],[5784,5993,"Baby, not every man is your daddy-"],[5993,6101,"Stop!"],[6160,6302,"Honey, slow down, slow down."],[6994,7094,"Impossible."],[7140,7223,"I gotta go."],[7223,7407,"No, please don't leave me alone."],[7428,7615,"Hey, I could give birth at any time."],[7615,7728,"Do you think I'm doing this"],[7728,7816,"to spite you?"],[7816,8008,"You violently attacked Selina,"],[8008,8149,"and she's gonna press charges."],[8162,8266,"I'm nine months pregnant."],[8266,8454,"You think I pushed her down the stairs?"],[8454,8591,"Your sister has a broken arm"],[8591,8687,"for crying out loud."],[8687,8762,"Your own stepmother"],[8762,8850,"saw you do it."],[8850,8983,"What more proof do I need?"],[9793,9889,"Hannah!"],[9909,9993,"Sweetheart."],[10022,10189,"It's time for you to go back to school."],[10189,10335,"Vacation's over."],[10343,10485,"I don't want to go back to school."],[10506,10739,"I want to look for my real mommy."],[10752,10894,"Then this snake"],[10894,11086,"can leave my daddy alone."],[11106,11403,"Santa, please bring mommy back to me."],[11824,11936,"It can't be."]],"3":[[258,342,"I must be jet-lagged"],[342,408,"and confused someone"],[408,513,"else for Winnie"],[571,746,"Daddy, I'm not going back to school."],[746,896,"I'm going to look for Mommy!"],[900,1009,"Wait, sweetheart, wait!"],[1051,1209,"Honey, let her go."],[1276,1443,"It's been six years."],[1480,1668,"Why is my heart beating so fast?"],[1685,1785,"Where's Uncle Henry?"],[1797,1847,"I'm hungry."],[1847,1956,"Can I get something from the"],[1956,2072,"vending machine first?"],[2102,2293,"Um, yeah, yeah, of course."],[2335,2439,"Here, just,"],[2485,2615,"hurry back, okay?"],[2648,2781,"Uncle Henry's almost here!"],[2936,3015,"Logan and Selina"],[3015,3094,"must have gotten married"],[3094,3290,"after I left and had a child together."],[3319,3541,"He cheated on me, abandoned me,"],[3541,3670,"and left me to die."],[3695,3853,"How could I expect anything less"],[3853,4033,"from a man like him?"],[5376,5459,"Interesting."],[5476,5668,"This girl wears the same clothes as me."],[5718,5789,"Hmm."],[6181,6389,"Mommy, I'm coming to find you."],[6756,6835,"Abby?"],[7007,7115,"Abby, over here."],[7232,7349,"Gosh, what took you so long?"],[7349,7461,"I was starting to worry."],[7632,7741,"Earth to Abby?"],[7836,7907,"Wait, did you,"],[7953,8028,"change your hair?"],[8028,8112,"What happened to your hat?"],[8149,8254,"I'm not Abby."],[8266,8320,"Oh,"],[8370,8487,"I'm sorry, I forgot."],[8541,8646,"You're the genius hacker"],[8646,8812,"that goes by Princess A, right?"],[8846,8917,"Wait,"],[8975,9063,"this woman!"],[9088,9209,"She looks just like"],[9209,9342,"the photo of mommy!"],[9384,9430,"Are you,"],[9430,9542,"are you my mommy?"]],"4":[[279,342,"Henry?"],[367,492,"Yeah, we're just waiting on the curb."],[521,613,"Great, just hurry up, okay?"],[613,717,"Abby's getting hungry."],[754,817,"Great."],[934,1071,"Of course I'm your mommy."],[1071,1188,"Who else could I be?"],[1292,1484,"Santa must have heard my prayers."],[1509,1639,"He brought Mommy to me."],[1705,1856,"Mommy, where are we going?"],[1856,2035,"Honey, I told you already."],[2089,2218,"Look, I know we're only here"],[2218,2268,"for a month,"],[2268,2427,"but you have to start school tomorrow."],[2452,2527,"A month?"],[2527,2711,"Does that mean mommy is leaving?"],[2715,2865,"She's, she's a little girl"],[2865,2944,"I know but she's..."],[3132,3199,"Mommy!"],[3286,3445,"You got the wrong kid!"],[3490,3745,"Sweetheart, hey, it is dangerous"],[3745,3878,"to run around LAX."],[3920,3999,"Come on, let's go."],[4033,4225,"I've seen this face on photograph"],[4225,4396,"countless times before."],[4416,4533,"Thanksgiving is over."],[4533,4646,"It's time for school now."],[4646,4808,"Um, sir, does your name"],[4808,4946,"happen to be Logan Walton?"],[5021,5071,"Sir?"],[5180,5305,"Why yes, Mademoiselle."],[5305,5422,"I am Logan Walton."],[5422,5684,"It really is him, my Daddy!"],[5684,5789,"Alright, enough stalling."],[5847,5955,"We really gotta get you to school,"],[5955,6022,"honey, come on."],[6181,6243,"Daddy?"],[6322,6452,"Yeah, it's me, Hannah."],[6506,6619,"Who is Hannah?"],[6835,6906,"Hannah."],[7048,7248,"If you agree to go back to school,"],[7282,7457,"then I will take you to Disneyland."],[7536,7615,"In Paris."],[7615,7686,"Come on."],[7732,7816,"Hannah?"],[7816,7962,"Why is he mistaking me"],[7962,8037,"for someone else?"],[8696,8829,"There she is!"],[8954,9063,"Who is he?"],[9063,9129,"Is he,"],[9159,9317,"Mommy's boyfriend?"],[9317,9542,"Sorry, you know how traffic can LA gets."],[9580,9730,"Oh, there's my little munchkin."],[9730,9843,"How are you?"],[10089,10235,"Look, I think she's just hungry."],[10251,10347,"Let's just go get her something to eat."],[10347,10472,"It is a school night."],[10497,10614,"To the restaurant we go."]],"5":[[1213,1368,"This must be the bad woman."],[1368,1493,"who stole Daddy from Mommy."],[1543,1714,"Have a good day at school, sweetie."],[1743,1868,"OK Logan, I think we should go."],[1876,1976,"We have some work to do."],[2027,2089,"Daddy,"],[2110,2210,"are you married to this woman?"],[2235,2389,"Is she my evil stepmother?"],[2456,2598,"Oh, so that's why"],[2598,2777,"you've been acting weird, sweetheart."],[2836,2911,"There's nothing,"],[2927,3082,"between me and Auntie Selina."],[3128,3282,"Okay, that's Daddy's work colleague"],[3311,3395,"and your aunty."],[3453,3520,"My aunt?"],[3582,3661,"Oh, right."],[3661,3795,"Mommy has a half-sister."],[3795,3908,"Come on, Daddy will walk you in."],[4391,4542,"It's so nice having you, Mommy."],[4583,4783,"You know, why are you so cringy today?"],[4829,5005,"You know you don't like holding my hand."],[5109,5276,"Look, I know we're only here"],[5276,5334,"for a month,"],[5334,5476,"but I don't want you to be shy today."],[5518,5618,"Okay, I really want you"],[5618,5726,"to make some friends."],[5759,5860,"Don't be scared."],[5876,6051,"This is one of the best schools in LA."],[6051,6139,"And your mom has worked"],[6139,6268,"so hard for you to be here."],[6297,6477,"But I've been going here for two years."],[6656,6744,"What'd you just say?"]],"6":[[8,204,"But I've been going here for two years."],[233,316,"What'd you just say?"],[362,533,"Hannah, did you have fun"],[533,650,"over Thanksgiving break?"],[717,796,"Here, have some chocolate"],[796,892,"to celebrate your return."],[892,992,"But, I'm allergic to"],[992,1055,"chocolate -What?"],[1105,1230,"He just called you Hannah."],[1397,1459,"He must have gotten you"],[1459,1593,"mixed up with another kid."],[1901,1981,"One second."],[1993,2114,"Listen, uh, I think you should"],[2114,2227,"go back to the office."],[2243,2306,"No, no, no."],[2306,2460,"I want to hang out with Hannah."],[2510,2610,"Hannah?"],[2660,2823,"I thought I just saw you"],[2823,2932,"on the other side."],[2948,3073,"You've already eaten all your chocolate."],[3073,3203,"Here, have some more."],[3691,3799,"Hannah, what are you doing?"],[3858,4024,"You're allergic to chocolate."],[4024,4074,"You know that."],[4087,4233,"But, I'm not."],[4358,4425,"Here you go."],[4446,4554,"Have half for now."],[4567,4671,"There's too much chocolate right now."],[4671,4775,"It would be bad for you, okay?"],[4796,4942,"I'm allergic to chocolate."],[5005,5080,"What?"],[5125,5205,"Since when?"],[5296,5459,"Something Feels off today..."],[6051,6172,"What is going on? -What is going on?"],[6172,6235,"Adding up. -Adding up."],[6769,6902,"We look the same! -We look the same!"]],"7":[[817,917,"Oh my gosh! -Oh my gosh!"],[917,1067,"We really are twins! -We really are twins!"],[1134,1213,"That would explain"],[1213,1363,"why they mixed us up at the airport."],[1413,1514,"Mommy once told me that she had"],[1514,1664,"a dream that I had a twin,"],[1664,1797,"but Selina took one away."],[1901,2027,"What if it wasn't a dream?"],[2060,2252,"What if that evil half-sister of hers"],[2252,2344,"really did it?"],[2485,2652,"Selina said Mommy didn't want me."],[2673,2765,"She left me to die"],[2765,2886,"right after I was born."],[2902,2998,"I met Mommy."],[2998,3086,"And she's..."],[3182,3286,"perfect!"],[3507,3574,"I get it."],[3591,3716,"Maybe Selina stole you"],[3716,3853,"while Mommy was unconscious,"],[3853,3970,"then lied to Daddy,"],[3970,4137,"and said she didn't want you."],[4137,4279,"But really, none of them"],[4279,4391,"even knew we existed."],[4433,4604,"But, why would Selina do this?"],[4633,4750,"Isn't she our aunt?"],[4750,4900,"You don't know her like I do."],[4929,5105,"She's evil and fake."],[5180,5259,"I hate her."],[5276,5359,"Mommy said that"],[5359,5513,"Daddy's in love with Selina,"],[5513,5651,"but I don't think it's true."],[5668,5722,"Ew,"],[5722,5826,"definitely not."],[5905,6047,"Daddy has good taste."],[6064,6206,"Selina is not it."],[6206,6343,"That means there's some huge"],[6343,6431,"misunderstanding"],[6431,6539,"between Mommy and Daddy."],[6539,6623,"We have to fix it,"],[6623,6769,"and then we'll all live together."],[6790,6977,"Since we already switched places,"],[7002,7144,"let's just keep it this way,"],[7144,7273,"so we can spend more time"],[7273,7382,"with our other parents."],[7440,7553,"I have an idea."],[7553,7661,"Do you have a smartwatch?"],[7766,7874,"Switch watches with me."],[7974,8166,"We can use these to communicate"],[8195,8287,"and take out the truth"],[8287,8470,"about what really happened."],[8529,8708,"Can't we just tell them we exist?"],[8742,8863,"Wouldn't they believe us?"],[8892,8983,"But then we'll never know"],[8983,9088,"what actually happened,"],[9088,9188,"and Selina might get away"],[9188,9338,"with all the bad things she did."],[9359,9446,"You're right."],[9471,9642,"Let's get to the bottom of this."],[9680,9780,"We have untill Christmas"],[9780,9872,"to fix everything."],[9872,9955,"That's when Mommy and I"],[9955,10055,"fly back to England."],[10101,10251,"Let's call this,"],[10289,10377,"Operation -Operation"],[10377,10510,"Christmas trap! -Christmas trap!"],[10885,10977,"Hi baby,"],[10977,11148,"how was your first day at school?"],[11148,11386,"Mommy, I miss you so much."],[11507,11665,"What has gotten into you today?"],[12049,12212,"Oh no, I can't let Daddy"],[12212,12387,"see me with Mommy just yet."],[12466,12629,"Okay, let's go home, sweetie."],[13021,13133,"Wait, is that Hannah?"],[13234,13342,"Mommy, I really really"],[13342,13484,"need a few minutes to myself."],[13484,13646,"Um, can you please just wait here?"],[13688,13763,"What?"],[13838,13901,"Baby, I-"],[14197,14322,"Wait, honey, what's going on?"],[14656,14756,"Really is you."]],"8":[[25,108,"Logan, what are you,"],[150,254,"what are you doing here?"],[296,446,"I could ask you the same question."],[600,717,"No, you got some nerve,"],[717,892,"coming back here after what you did."],[917,1030,"After what I did?"],[1051,1222,"How about after what you did?"],[1238,1493,"All I did was try to clean up your mess."],[1522,1626,"But, for a second,"],[1626,1785,"I thought we could just let the past go."],[1805,1947,"I thought I could let you meet"],[1947,2060,"our child, but,"],[2106,2206,"clearly I was wrong."],[2243,2352,"What child?"],[2352,2494,"Does he know about Abby?"],[2523,2594,"No."],[2598,2727,"No, he must be talking about"],[2727,2844,"his child with Selina."],[2932,3103,"Why would I want to meet your child?"],[3144,3328,"That has nothing to do with me."],[3328,3486,"She's your blood too, you know."],[3499,3582,"My blood?"],[3624,3766,"I guess he's not wrong."],[3766,3958,"Selina and I are half-sisters."],[3978,4079,"What happened to the Winnie"],[4079,4154,"that I knew?"],[4183,4312,"You're so heartless now."],[4658,4804,"That girl is dead and gone."],[4854,4963,"You killed her."],[5059,5113,"Fine."],[5176,5251,"You want nothing"],[5251,5359,"to do with my daughter?"],[5409,5492,"Then after today,"],[5513,5618,"you'll never see her again."],[6018,6160,"Quick, cause a distraction."],[6160,6247,"I'm in trouble."]],"9":[[8,266,"I can't let Logan take Abby away."],[617,671,"Stop!"],[671,742,"Winnie?"],[775,913,"How dare she come back."],[955,1026,"Logan."],[1130,1238,"Hannah's crying."],[1238,1347,"She wants to go home."],[1434,1564,"I must have seen wrong."],[1618,1718,"I thought I saw Hannah"],[1718,1801,"go into this room."],[1830,1901,"Daddy!"],[1901,2018,"I want my daddy!"],[2481,2669,"How dare you come back here"],[2669,2777,"after six years?"],[2794,2940,"Why didn't you just die?"],[2973,3098,"Six years and your face"],[3098,3232,"aged twice as fast."],[3232,3315,"I guess being a homewrecker"],[3315,3445,"wrecked your face too."],[3445,3566,"I guess karma is a mirror."],[3616,3732,"How dare you."],[4404,4562,"You really think after all this time,"],[4562,4721,"I'll still let you walk all over me?"],[4754,5005,"Well, think again, you bitch."],[5034,5171,"Did you just hit me?"],[5259,5321,"Guards."],[5355,5426,"Get her."],[5513,5701,"I can't let them find Abby."],[6318,6510,"Abby, the evil witch is trying to"],[6510,6623,"hurt mommy again."],[6644,6719,"Get daddy."],[6719,6777,"Quick."]],"10":[[855,1038,"You say you have changed?"],[1038,1167,"I don't think so."],[1167,1368,"I broke you once, I can do it again."],[1472,1559,"How was that?"],[1559,1622,"Yeah?"],[1622,1714,"Does that make you remember?"],[1714,1847,"Does that jog your memory"],[1847,1943,"or do you need it again?"],[2002,2131,"Get away from her!"],[2293,2373,"Sweetheart."],[2489,2623,"This isn't what it looks like."],[2660,2915,"I'm just dealing with this mean old lady."],[2915,2990,"Liar."],[3015,3098,"Snake."],[3161,3307,"I'm telling daddy everything."],[3307,3357,"Wait."],[3357,3440,"Why did Selina"],[3440,3570,"just call Abby sweetheart?"],[3687,3824,"What are you trying to do?"],[4487,4583,"Get in here!"],[4612,4713,"You little rat!"],[4733,4788,"Stop it."],[4992,5055,"No, stop!"],[5055,5150,"Let her go!"],[5150,5280,"Do not touch my daughter!"],[5534,5626,"Wait, wait, wait."],[5651,5747,"You said Selina's trying to"],[5747,5805,"hurt your mom?"],[5805,5868,"Yes we heard-"],[5868,5976,"How did Winnie find out"],[5976,6039,"that she was your mom?"],[6039,6143,"When did you two even meet?"],[6143,6327,"Less talking, more saving mommy!"],[6589,6660,"Winnie?"],[6731,6844,"Are you in there?"],[7152,7253,"Winnie, is that you?"],[7269,7357,"Are you in there?"],[7432,7545,"Come on, say something!"],[7640,7774,"Say something?"],[7816,7966,"And I can make him hurt her."],[7982,8224,"I can't let Selina hurt my baby."],[8337,8375,"Here!"],[8375,8458,"Now say something!"],[8550,8629,"Winnie!"],[8933,9009,"Hannah."],[9054,9184,"Are you messing with daddy again?"],[9184,9230,"Huh."],[9246,9371,"No daddy, I promise!"],[9430,9509,"Please!"],[9509,9597,"Save Mommy!"],[9597,9776,"That sounds like Abby."],[9776,9997,"But Abby is right here in front of me."],[10072,10185,"Okay, stand back, honey."],[10272,10372,"That's it."],[10835,10944,"Oh baby, are you okay?"],[10944,11027,"You okay?"]],"11":[[296,375,"No! No!"],[400,458,"No!"],[1001,1192,"I can't let Daddy see both of us!"],[1368,1463,"What the hell is wrong with you?"],[1463,1568,"Let that child go!"],[1668,1835,"I can't let Daddy see me."],[2043,2147,"That's my daughter!"],[2147,2277,"How dare you let them touch her!"],[2339,2423,"Your daughter?"],[2648,2740,"You have a daughter?"],[2848,2998,"I'd like to see for myself."],[3182,3265,"Hannah?"]],"12":[[25,162,"Well, I'd like to see for myself."],[700,809,"No, don't, don't touch her!"],[1159,1267,"Alright, everybody out!"],[1680,1797,"Wait, where did she go?"],[1985,2072,"Let me go!"],[2106,2210,"We need to talk."],[2281,2439,"Okay, you at least owe me that."],[3048,3219,"This is because of you."],[3307,3428,"My daughter was only hurt"],[3428,3528,"because of you."],[3528,3653,"Who did you sleep with"],[3682,3787,"to make that kid?"],[3820,3962,"She's about the same age as mine."],[3962,4191,"Which means that you cheated on me."],[4229,4358,"Cheating on you?"],[4358,4437,"God, do you even"],[4437,4529,"hear yourself right now?"],[4529,4725,"You abandoned me to be with Selina!"],[4738,4846,"Me abandon you?"],[4879,4984,"Six years."],[4984,5217,"No texts, no calls, no explanation."],[5217,5430,"You erased me from your life"],[5430,5555,"like I was nothing."],[5555,5714,"I almost died that night."],[5751,5985,"I saw it with my own two eyes!"]],"13":[[600,825,"You were the biggest mistake I ever made."],[825,934,"Just stay the hell away"],[934,1038,"from me and my daughter."],[1993,2072,"Mommy!"],[2122,2268,"Oh, there you are, sweetheart."],[2302,2369,"Are you okay?"],[2369,2464,"You're not hurt, are you?"],[2485,2560,"I'm fine."],[2594,2640,"Were you,"],[2640,2773,"were you talking to Daddy?"],[2844,2932,"Yes."],[2973,3169,"But we are not telling Dad"],[3169,3286,"about you, alright?"],[3307,3395,"Why not?"],[3457,3574,"It's complicated."],[3628,3799,"I can tell you another time, okay?"],[3920,3991,"Look."],[3999,4116,"Uncle Henry's here."],[4120,4241,"He's gonna take us home, okay?"],[4558,4671,"Hi."],[4871,4988,"Thanks for coming."],[5088,5138,"Of course."],[5246,5430,"You left me and our child for him?"]],"14":[[684,850,"Daddy, what are you looking at?"],[967,1021,"Hey!"],[1021,1121,"Let me see!"],[1151,1230,"Hannah."],[1309,1459,"No matter what happens,"],[1505,1664,"you know that Daddy loves you, right?"],[1726,1814,"Daddy?"],[1851,1947,"Are you crying?"],[1947,2072,"I just want to make sure"],[2152,2231,"that you know"],[2243,2327,"Daddy,"],[2385,2464,"loves you,"],[2464,2660,"and I will always love you, okay?"],[2660,2819,"Even if your mother doesn't."],[3073,3211,"I love you too, Daddy."],[3303,3411,"Oh, Santa."],[3411,3495,"If you can hear me,"],[3495,3620,"please help Mommy and Daddy"],[3620,3762,"get back together soon."]],"15":[[412,575,"I can't believe that Logan and Selina"],[575,688,"have a daughter together."],[738,804,"Good for them."],[900,1021,"Couldn't care less."],[1021,1142,"You know, the medical mixer"],[1142,1247,"starts tomorrow."],[1272,1413,"Every top tier hospital"],[1413,1493,"is going to be there"],[1493,1593,"trying to recruit you."],[1601,1797,"Dr. M, the world's best surgeon."],[1826,1939,"Including the hospital"],[1939,2060,"run by Logan's family."],[2060,2198,"Alright, well then I'm not going."],[2260,2302,"I don't,"],[2302,2427,"I don't want to see him again."],[2427,2565,"Logan won't be there."],[2623,2794,"They just send their recruitment team."],[2794,2902,"It'll be fine."],[3908,3995,"I don't get it."],[4041,4187,"What is she even doing back here?"],[4187,4320,"And with a kid too."],[4350,4533,"I was hoping she died already."],[4600,4750,"I didn't get a clear look."],[4850,4946,"But I think those kids"],[4946,5100,"actually look kind of similar."],[5121,5288,"Could it be Logan's kid?"],[5305,5413,"There's no way."],[5422,5630,"Winnie hasn't seen Logan since she left."],[5630,5789,"She hasn't seen anyone actually."],[5822,5935,"It would make no sense"],[5935,6064,"for that kid to be his."],[6068,6143,"Then you have nothing"],[6143,6252,"to worry about, darling."],[6281,6427,"We defeated her once."],[6427,6548,"We can do it again."],[6598,6752,"Can I give you some advice?"],[6777,6927,"Go to Logan's house."],[7052,7173,"Talk to his mother."],[7311,7428,"And tell her this."]],"16":[[792,871,"Hi, every one."],[871,1021,"Hi, so good to see you all."],[1534,1730,"Miss Hannah's in a good mood today."],[1764,1951,"She's normally not this bubbly."],[2110,2198,"Hannah."],[2214,2344,"How many times"],[2344,2510,"have I told you no sugar?"],[2510,2648,"It will make you fat"],[2648,2748,"and give you cavities."],[2786,2961,"That must be the grandma"],[2961,3082,"Hannah warned me about."],[3136,3282,"She really is scary."],[3282,3349,"Mother."],[3382,3532,"It is the Holidays."],[3591,3749,"Let Hannah eat her candy in peace."],[3770,3866,"It's okay."],[3866,4029,"Grammy, I'll throw this away."],[4049,4124,"Weird."],[4179,4358,"Hannah never calls me Mom Grammy."]],"17":[[79,145,"Hey, Hannah,"],[216,291,"why don't you go to your room"],[291,383,"and do your homework, okay?"],[704,871,"So, Logan."],[946,1059,"When were you planning on"],[1059,1130,"telling me"],[1130,1276,"that Winnie is back in town?"],[1326,1426,"You told my Mom?"],[1543,1735,"Logan, I'm so sorry."],[1755,1960,"I was just worried and it slipped out."],[1976,2127,"You can't blame Selina"],[2127,2360,"for caring about your child, Logan."],[2381,2502,"Someone has to."],[2502,2761,"Which reminds me, it's about time"],[2761,3069,"that you two settle your engagement."],[3157,3315,"Mother, for the hundredth time,"],[3315,3486,"I'm not interested in another marriage."],[3545,3732,"We'll table this discussion."],[3757,3953,"Oh, Logan, by the way."],[3953,4179,"The mysterious surgeon Dr. M"],[4179,4258,"is in town."],[4258,4450,"All the top hospitals"],[4450,4658,"are dying to court her."],[4658,4917,"You need to be at that mixer tomorrow."],[4917,5084,"Mom, I've got a lot of work to do."],[5138,5238,"Okay, you can't expect me"],[5238,5317,"to waste time"],[5317,5547,"searching for this Dr. M in England."],[5563,5905,"That was an order, not a request."],[5926,6172,"Our hospitals need a talent like her."],[6172,6389,"Besides, Selina is head"],[6389,6556,"of the talent acquisition."],[6573,6760,"This will be great for her career."],[6794,6931,"I worked hard"],[6952,7148,"to make the special arrangement"],[7148,7415,"so that both you and Selina could go."],[7453,7678,"I really appreciate that, Victoria."],[7749,8037,"Logan, remember all she's done for you."],[8037,8208,"If it weren't for Selina,"],[8208,8345,"Hannah would have frozen to death"],[8345,8420,"in the street."],[8420,8591,"I must tell Hannah about this!"],[8591,8654,"Okay, fine."],[8654,8767,"I'll help you look for her."],[8850,9034,"But with all these other hospitals"],[9034,9138,"competing for her,"],[9138,9246,"I doubt we'll have a shot."],[9459,9597,"I already have Victoria"],[9597,9755,"wrapped around my finger."],[9755,9922,"Now I just need Logan."],[9951,10126,"I can't let this go on any longer."],[10126,10322,"I'm going to marry him,"],[10322,10443,"one way or another."]],"18":[[162,396,"What, engaged with that witch?"],[433,684,"And Dad's taking Selina to the mixer?"],[721,834,"This is not good."],[850,996,"We've only gone until Christmas"],[996,1084,"before you and Mommy"],[1084,1192,"go back to England."],[1192,1309,"We have to hurry."],[1326,1418,"Here's the plan."],[1418,1501,"I'm going to hack into"],[1501,1618,"their surveillance system"],[1618,1768,"and make sure no one bullies Mom."],[1768,1876,"You stay home tomorrow."],[1876,1989,"If Mom needs help, I'll-"],[1989,2106,"No, I've already promised"],[2106,2227,"Mom that I'll go with her."],[2243,2389,"How about you just stay home?"],[2389,2456,"Abby?"],[2527,2631,"Who are you talking to?"]],"19":[[8,87,"Abby?"],[145,237,"Who are you talking to?"],[408,487,"No one."],[508,579,"Just, just a friend"],[579,650,"I met at school."],[650,763,"You made a new friend?"],[763,888,"Oh, what's their name?"],[917,1026,"Not important."],[1084,1343,"Mommy, I miss you so much."],[1363,1459,"I love you."],[1622,1726,"Wow."],[1726,1922,"Okay, what's with all the sweetness?"],[1951,2031,"You trying to get"],[2031,2156,"an extra Christmas present?"],[2198,2314,"Well, that's working."],[2527,2627,"Surprise!"],[2648,2798,"It's custom made."],[2882,2994,"Merry Christmas."],[3115,3282,"You know, I thought"],[3282,3382,"maybe you could wear it"],[3382,3507,"to the mixer tomorrow night?"],[3545,3620,"What do you say?"],[3620,3741,"You want to be my date?"],[3741,3799,"Yes!"],[3799,3945,"You want to be my date?"],[3945,4024,"Yes!"],[6018,6097,"Wow."],[7040,7119,"Wow."],[7215,7340,"Beautiful, Mommy."],[7474,7695,"Daddy won't be able to take his eyes"],[7695,7761,"off of you."]],"20":[[50,133,"Wow."],[191,387,"You look beautiful, Mommy."],[387,467,"Are you ready?"],[487,604,"It's time to go downs..."],[684,754,"stairs."],[788,959,"Uh, is it too much?"],[980,1088,"No, no."],[1088,1359,"You, you look absolutely beautiful."],[1359,1447,"You both do."],[1872,1960,"Let's go, Mommy."],[2010,2239,"Sorry Uncle Henry, you're great too"],[2239,2439,"but this hand is reserved"],[2460,2577,"for Daddy only."],[2606,2673,"After you."],[3536,3599,"Weird."],[3678,3828,"Why isn't Mommy here yet?"],[4341,4454,"I need to make sure"],[4454,4621,"Daddy doesn't see me all night."]],"21":[[187,329,"Hannah, you weren't supposed"],[329,462,"to go downstairs."],[483,654,"What if people see both of us?"],[692,788,"Jesus, Hannah."],[788,921,"How did you sneak your way over here?"],[955,1138,"It is way past your bedtime."],[1284,1443,"What is he doing here?"],[1488,1568,"Guards, can we please"],[1568,1701,"escort my princess home?"],[1822,1872,"Hey."],[2047,2181,"Oh no, I forgot to tell"],[2181,2327,"Abby I was coming down."],[2327,2502,"Mommy, I really need to potty."],[2502,2640,"Can I go upstairs to potty?"],[2640,2711,"Okay."],[2723,2861,"Uh, Henry, can you take her?"],[2861,2969,"Yeah, of course."],[3053,3182,"Are you too fast?"],[3199,3290,"Don't run!"],[3395,3516,"You heard your mother, Abby."],[3516,3595,"Slow down."],[4462,4646,"Is that Logan Walton?"],[4729,4921,"I didn't realize the CEO of Maple Group"],[4921,5063,"was attending tonight's event."],[5063,5242,"Those two look amazing together."],[5251,5388,"And I bet they'd be married by now"],[5388,5547,"if it wasn't for his ex wife."],[5547,5605,"Hi."],[5697,5755,"Hi."],[5930,6135,"You looks amazing, darling."],[6147,6281,"You know, with Logan here"],[6281,6423,"backing you, you have a real shot"],[6423,6535,"at making a deal with Dr. M."],[6581,6685,"I know, right?"],[6685,6869,"The most powerful man in medicine"],[6869,6961,"on my arm."],[6990,7094,"How could she resist?"],[7198,7340,"I'm afraid I'll be disappointing you."],[8416,8516,"I'm Dr. M."],[8587,8662,"And you got one thing"],[8662,8758,"wrong about me."],[8775,9034,"I will never work the likes of you."]],"22":[[16,116,"I would never"],[141,266,"work with someone like you."],[383,475,"Now, Winnie,"],[517,746,"I know we've never quite gotten along,"],[763,988,"but that wasn't a very kind thing to say."],[1009,1088,"Dr. M is"],[1088,1201,"a world-renowned surgeon,"],[1201,1488,"and you, well, you're not that."],[1488,1609,"That's Dr. M?"],[1655,1776,"She's gorgeous."],[1776,1997,"Seriously? That's not Dr. M."],[1997,2189,"That's Winnie, Selina's half-sister."],[2189,2273,"She was disowned"],[2273,2423,"by the McGuire family."],[2448,2660,"She abandoned her family years ago."],[2660,2865,"I heard she pushed Selina down"],[2865,3003,"a flight of stairs."],[3003,3082,"Pure evil."],[3178,3432,"Winnie, it's okay."],[3495,3595,"I understand what happened"],[3595,3720,"back then was an accident,"],[3720,3883,"and I'm so glad you came here"],[3883,4008,"to make things right."],[4033,4141,"But you crossed a line"],[4141,4308,"pretending to be Dr. M."],[4371,4550,"You owe everyone here an apology."],[4750,4934,"You came to a mixer to recruit Dr. M"],[4934,5113,"and you don't even know who she is."],[5134,5246,"It's a little disrespectful,"],[5246,5342,"don't you think?"],[5342,5488,"Oh, please."],[5488,5597,"Who knows which shady tricks"],[5597,5739,"you pulled to sneak in here."],[5759,5864,"You should apologize,"],[5864,5930,"otherwise you won't be"],[5930,6051,"leaving here tonight."],[6064,6210,"Yeah, apologize!"],[6210,6314,"Apologize!"],[6314,6381,"Apologize!"],[6381,6493,"Apologize now, liar!"],[6493,6639,"Come on, apologize."],[6639,6727,"Apologize."],[6798,6894,"Apologize now."],[6894,6956,"Hey!"],[7032,7115,"That's enough."]],"23":[[41,112,"That's enough."],[179,337,"Why is Logan defending her?"],[575,650,"Oh, wow."],[679,788,"She's even more beautiful"],[788,900,"than when I first met her."],[909,1101,"That witch is framing Mommy again!"],[1101,1209,"Not for long."],[1217,1313,"Watch this."],[2064,2147,"It's an honor"],[2147,2344,"to be invited by Oxford University"],[2344,2527,"to share my research with you all today."],[2619,2715,"Dr. M?"],[2773,3007,"Winnie, my daughter's mother!"],[3040,3261,"Finally, I wasn't the only one"],[3261,3440,"who saw her genius."],[3440,3549,"That's impossible."],[3620,3687,"To those of you"],[3687,3874,"that wanted me to apologize,"],[3874,4070,"you can forget about ever working for me."],[4116,4408,"And you, I am going to make sure"],[4408,4525,"that no doctor"],[4525,4729,"ever wants to work with you."]],"24":[[58,166,"I am going to make sure"],[166,283,"that no doctor"],[283,479,"ever wants to work with you."],[546,754,"Winnie, don't you remember?"],[771,905,"It was these hands"],[905,1017,"that pushed me down the stairs"],[1017,1142,"six years ago."],[1272,1334,"Me,"],[1343,1426,"who pushed you down"],[1426,1593,"when I was 10 months pregnant?"],[1664,1835,"Bravo, Selina."],[1876,1918,"You know,"],[1918,2035,"you're a much better actor now"],[2035,2168,"than you were back then."],[2202,2369,"Could have made a career out of it."],[2406,2510,"Bummer that you chose to be"],[2510,2648,"a gold digger instead."],[2731,2844,"I heard Selina got hurt"],[2844,2961,"pretty badly by her."],[3023,3148,"And that she left her husband"],[3148,3257,"after giving birth?"],[3257,3324,"That's enough."],[3474,3566,"From all of you."],[3616,3707,"Stop gossiping"],[3707,3837,"and digging up old rumors"],[3837,3962,"like a bunch of high schoolers."],[4016,4170,"Why is Logan defending her?"],[4216,4421,"Isn't she the one who bullied Selina?"],[4496,4667,"Six years and she's still got Logan"],[4667,4804,"rushing to her defense?"],[4838,5055,"Fine, Winnie, two can play that game."],[5226,5317,"Logan's right."],[5376,5518,"You all have the wrong idea"],[5518,5626,"about Winnie."],[5643,5839,"She didn't abandon this family."],[5897,6197,"She's been abroad with her new lover"],[6235,6398,"and their beautiful child"],[6398,6535,"that they have together."],[6644,6765,"So that's why you did it?"],[6848,7032,"A new life, a new kid,"],[7219,7319,"a new lover?"]],"25":[[58,233,"We are divorced, Logan."],[275,417,"You made sure of that."],[454,533,"My personal life"],[533,696,"is none of your business."],[863,1034,"So this kid you had with someone else,"],[1134,1242,"you love her, right?"],[1255,1405,"Of course I do."],[1434,1497,"So then I guess"],[1497,1593,"we can just pick and choose"],[1593,1739,"who gets a mom and who doesn't."],[1747,1897,"What are you talking about?"],[1897,2010,"Did you ever think about"],[2039,2210,"my daughter growing up"],[2210,2356,"without a mother that'll love her?"],[2410,2494,"Look at her."],[2560,2665,"She didn't get a mom"],[2665,2823,"because you abandoned her."],[2852,3090,"Why is he showing me a photo of Abby?"],[3153,3353,"How does he even know she exists?"],[3524,3645,"I, I, I don't, I don't understand."],[3645,3728,"Why are you showing me"],[3728,3832,"a photo of my daughter?"],[4037,4116,"So now you admit"],[4116,4233,"that she's yours."],[4266,4350,"What is going on?"],[4350,4483,"Are you threatening me?"],[4583,4662,"Threatening you?"],[4662,4817,"Oh, please, Winnie."]],"26":[[25,191,"Now, Winnie, please."],[191,404,"Bringing in a bastard child"],[404,542,"into a broken family,"],[542,671,"that's another story."],[671,863,"No class whatsoever."],[1184,1297,"Shut your mouth!"],[2122,2248,"You wanna talk trashy about me,"],[2248,2306,"that's fine,"],[2306,2481,"but you keep my child's name"],[2481,2602,"out of your mouth."],[2602,2698,"One more word about her"],[2698,2886,"and I will rip you a new one."],[2957,3094,"This is deplorable."],[3094,3249,"Guards, get this crazy woman"],[3249,3328,"out of here."],[3353,3470,"Hey, wait, let me go."],[3470,3574,"I'm Dr. M."],[3782,3912,"Let go of Mommy."]],"27":[[0,137,"Abby, I thought you were upstairs"],[137,225,"with Uncle Henry."],[287,358,"Hannah?"],[383,487,"Oh, honey, I thought Tom already"],[487,592,"took you home."],[759,817,"Come on, sweetie,"],[817,942,"we gotta go right now."],[1213,1280,"Hey!"],[1539,1685,"Please help me watch over Hannah."],[2256,2406,"Same height, same build."],[2464,2585,"Exactly like Hannah."],[2665,2806,"Something is off here."],[2861,2961,"Hey, stop her!"],[3073,3174,"Hey, what are you doing?"],[3174,3261,"I just wanna go home"],[3261,3357,"with my daughter."],[3507,3603,"Winnie, is she mine?"],[3924,4024,"Is that my daughter?"],[4024,4254,"Jesus, Logan, get over yourself."],[4254,4320,"She is not your-"],[4320,4450,"Enough, Winnie."],[4683,4863,"I need to see her, okay?"],[4963,5046,"That's my daughter."],[5096,5159,"Then I, I need to know-"],[5159,5230,"No, stop!"]],"28":[[0,83,"That's my daughter."],[145,212,"Then I, I need to know-"],[212,271,"No, stop!"],[291,362,"Logan!"],[487,621,"What the hell is going on here?"],[621,700,"You're not gonna touch Winnie"],[700,759,"or her daughter,"],[759,880,"not while I'm around."],[905,1188,"The kid, she's yours, isn't she?"],[1238,1363,"It doesn't matter, but no, she's-"],[1363,1430,"Yes."],[1868,2127,"Yes, Henry's the father."],[2143,2477,"Winnie, six years, I waited for you."],[2519,2585,"Wow."],[2702,2819,"Well, you got really busy"],[2819,3040,"really quickly, didn't you?"],[3169,3349,"Is she six, huh?"],[3436,3561,"Well, I guess the divorce"],[3561,3632,"didn't deter you"],[3632,3728,"from throwing yourself"],[3728,3807,"onto other men."],[3807,3920,"Yeah, well, at least I waited"],[3920,4091,"until the divorce papers were signed."],[4091,4225,"Winnie, there is nothing"],[4225,4354,"between Selina and I, okay?"],[4354,4450,"Our relationship is"],[4450,4592,"strictly professional."]],"29":[[0,116,"Winnie, there is nothing"],[116,246,"between Selina and I, okay?"],[246,346,"Our relationship is"],[346,475,"strictly professional."],[475,621,"I thought the two were married."],[671,804,"Looks like they're not?"],[884,1055,"Is he telling the truth?"],[1126,1276,"Then what about the kid he has?"],[1276,1463,"This doesn't make any sense."],[1463,1760,"Listen, I don't care"],[1760,1860,"about the relationship"],[1860,1939,"you have with her."],[1939,2189,"I just, I want you to leave us alone."],[2285,2381,"Please."],[2548,2640,"Come on, sweetie."],[3023,3115,"Damn it, Winnie."],[3353,3415,"Winnie."],[3420,3628,"Mommy, are you okay?"],[3649,3753,"I'm fine."],[3795,3887,"I'm fine, but your dad,"],[3887,4079,"he chose Selina over you, over us,"],[4079,4183,"and now he wants to make me out"],[4183,4300,"to be the bad mother?"],[4350,4487,"God, well, shame on him,"],[4487,4675,"he is a liar and a cheater."],[4696,4984,"Mommy, you're wrong about Daddy."],[4984,5171,"You're wrong about Selina too."],[5221,5276,"I..."],[5355,5484,"I have something to tell you."]],"30":[[16,279,"Mommy, you're wrong about Daddy."],[279,433,"Do not call that man your daddy."],[433,579,"He is not your father."],[658,829,"She hates him so much."],[867,1071,"What if she finds out I was raised by him"],[1071,1272,"and doesn't want me in her life anymore?"],[1347,1438,"All right, sweetie."],[1501,1551,"I just want you"],[1551,1705,"to head back upstairs, okay?"],[1726,1830,"I don't want you down here"],[1830,1947,"with that man around."],[1989,2093,"Mommy will be up soon."],[2093,2281,"I just have some stuff"],[2281,2448,"I need to figure out first, okay?"],[2498,2736,"Oh no, I can't let Mommy leave yet."],[3107,3307,"Oops, so sorry, Mommy."],[4379,4475,"What am I supposed to do?"],[4475,4637,"The banquet's not even over."],[4671,4896,"You should go upstairs"],[4896,5071,"and shower and get changed."],[5138,5347,"Okay, um, okay,"],[5347,5668,"just stay with Uncle Henry, all right?"]],"31":[[1530,1668,"My part here is done."],[1689,1851,"Now it's Daddy's turn."],[2131,2210,"I just sent Daddy"],[2210,2318,"Mommy's room number"],[2318,2481,"and made it look like it came from her."],[2602,2681,"Let's talk."],[2706,2819,"Room 888."],[2965,3307,"Three, two, one!"],[4713,4771,"Winnie?"],[5530,5689,"Surprise, Mommy - Surprise Mommy"],[5689,5780,"and Daddy. - and Daddy."]],"32":[[108,233,"Oh relax, it's nothing"],[233,362,"I haven't seen before."],[709,863,"What are you even doing in here?"],[888,984,"Don't act so surprised."],[984,1142,"You're the one that text me, remember?"],[1242,1472,"Did you text someone else?"],[1626,1814,"Yeah, I'm not doing this with you."],[1922,2314,"Who are you waiting for?"],[2460,2623,"Why is my heart racing?"],[5597,5764,"I think our job here is done."]],"33":[[646,779,"We're divorced, Logan!"],[817,980,"Logan, I'm not doing this with you."],[1001,1380,"Hey, I never agreed to a divorce."],[1380,1526,"What are you even talking about?"],[2114,2227,"Why does he have to be"],[2227,2360,"so damn attractive?"],[3165,3424,"Must I remind you, wifey,"],[3490,3641,"how our last child was made?"],[3908,4145,"This man is the father of my child."],[4220,4396,"I can't stop wanting him."],[4788,5080,"Oh, damn it, Winnie, this is not right."]],"34":[[91,212,"Oh, don't try to resist me,"],[212,321,"I know you want this."],[600,738,"His touch."],[738,842,"You want me"],[842,1013,"to put another baby in you, don't you?"],[1363,1497,"You naughty girl."],[2114,2193,"Good girl."],[2235,2406,"You still know how to please your man."],[4404,4617,"I miss you, baby."]],"35":[[54,171,"We did it, Mommy and Daddy"],[171,333,"are finally back together."],[350,437,"That means you and Mommy"],[437,583,"won't have to go back to London."],[608,759,"Everything in that room is proof"],[759,880,"that they belong together."],[896,1071,"Tomorrow, we'll tell them the truth"],[1071,1292,"and clear up all the misunderstandings."],[2940,3078,"Logan, I couldn't find Hannah,"],[3078,3194,"where are you?"],[3807,3866,"I almost fell"],[3866,4016,"for your stupid trap again."],[4049,4170,"Just go home to your woman"],[4170,4295,"and your sweet child."],[4934,5130,"You are a liar and a cheat,"],[5167,5309,"but I guess I knew that already."],[5309,5426,"Why do you keep"],[5426,5563,"twisting the narrative?"],[5563,5793,"All right, Selina and I, we're nothing."],[5793,5976,"This was a big mistake."],[6143,6448,"I let my guard down for one second"],[6448,6635,"and this is what happens."],[7515,7561,"Yeah, Tom,"],[7561,7728,"get me all of Winnie's company info."],[7786,7932,"I don't care, just do it."],[8312,8441,"Oh my gosh - Oh my gosh"],[8441,8625,"Daddy's so stupid. - Daddy's so stupid."]],"36":[[141,279,"Boss, that's not the way"],[279,392,"to win a girl back."],[437,513,"I'm not!"],[571,650,"I'm doing this"],[650,750,"for Hannah's mother, let's go."],[1401,1509,"What are you doing here?"],[2085,2310,"Miss McGuire, Mr. Walton came here"],[2310,2485,"with the utmost sincerity."],[2723,2865,"Listen, my family's company,"],[2865,2965,"the Maple Group,"],[3015,3165,"dominates 90%"],[3165,3332,"of the domestic medical market."],[3353,3440,"Look, it could be"],[3490,3724,"a massive opportunity for you."],[3787,4129,"If you blow it, it's gone forever."],[4191,4304,"If I was you, I would take"],[4304,4441,"their recruitment offer seriously."],[4763,4850,"Mr. Walton,"],[4850,4984,"there has been nothing between us"],[4984,5176,"since you left me six years ago."],[5263,5451,"I didn't come back here to win you over."],[5518,5655,"In fact, I'd rather die"],[5676,5772,"than work for you."]],"37":[[41,187,"In fact, I'd rather die"],[216,321,"than work for you."],[417,517,"What happened last night"],[517,667,"was because I drank too much."],[688,792,"Nothing more."],[1551,1764,"Did you hear the tone she was using?"],[1764,1835,"It's like every word"],[1835,2018,"was laced with venom."],[2064,2210,"Nobody expected your ex-wife"],[2210,2344,"to be Dr. M. either,"],[2344,2519,"but there are plenty of"],[2519,2656,"other great surgeons out there,"],[2686,2911,"and the salary our company can offer,"],[2911,3061,"we can easily recruit others."],[3094,3165,"Do you want to just go over"],[3165,3257,"the list again?"],[3274,3403,"What is wrong with me?"],[3465,3616,"Why am I going out of my way"],[3616,3749,"to give her this opportunity?"],[3791,3841,"She's the one"],[3841,3999,"who left Hannah and me behind."],[4024,4091,"Aren't you scared"],[4091,4254,"Mommy's gonna catch us"],[4254,4404,"showing up together like this?"],[4404,4567,"Nope, she's out with a client."],[4579,4746,"She won't even be in the office."],[4775,4921,"Maybe we can find some clues"],[4921,5000,"about the past"],[5000,5109,"in Mommy's office."],[5609,5718,"What?"],[5805,5872,"Sweetie?"]],"38":[[237,312,"Sweetie?"],[725,800,"Hi Mommy."],[846,971,"Honey, what are you doing here?"],[1001,1167,"I just missed you."],[1213,1334,"I missed you too."],[1701,1872,"Hannah, what are you doing here?"],[1914,2118,"I came to find you because I..."],[2173,2235,"missed you."],[2435,2498,"Come here."],[2673,2752,"Guess it's time - Guess it's time"],[2752,2831,"to switch back. - to switch back."],[3098,3269,"Okay, there we go, get comfy."],[3507,3728,"Daddy, I love you."],[3778,4004,"I love you no matter what happens."],[4058,4245,"I love you too, sweetheart."],[4408,4466,"Daddy,"],[4662,4725,"there's something"],[4725,4863,"I need to tell you."],[5121,5180,"What is it?"],[5397,5467,"Well..."],[5805,6093,"Logan, a word."]],"39":[[108,300,"I know you went to see Winnie today."],[350,517,"You need to stop focusing on Winnie"],[517,696,"and start focusing on Selina."],[696,867,"I'm not focused on Winnie, Mom."],[867,930,"Good."],[930,1163,"Then pick up a date and marry Selina"],[1163,1326,"or I'll arrange it myself"],[1326,1430,"with the McGuire family."],[1430,1501,"When will you get it"],[1501,1589,"through your head, Mom?"],[1589,1805,"I'm never marrying Selina."],[1805,1918,"And this is the last time"],[1918,2014,"I want to have this conversation"],[2014,2089,"with you."],[2364,2494,"Goddamn that Winnie"],[2494,2606,"and her child, Hannah."],[2631,2781,"They're about to find out what happens"],[2781,2848,"when you get in"],[2848,2994,"Selina McGuire's way."],[3123,3190,"Miss McGuire,"],[3190,3303,"your father and your stepmother,"],[3303,3399,"they're here to see you."],[4254,4429,"How dare you come back to LA?"]],"40":[[0,162,"How dare you come back to LA?"],[542,700,"What do you want, Mr. McGuire?"],[700,796,"Mr. McGuire?"],[796,896,"Watch your tone."],[896,1005,"I'm your father."],[1005,1121,"No, I don't think so."],[1121,1247,"What did you say?"],[1263,1459,"Would a real father cheat on his wife"],[1459,1589,"and marry his secretary?"],[1751,1868,"Or did you forget"],[1906,2056,"what you did to me and my mother?"],[2173,2302,"Your mother is nothing"],[2302,2469,"but a useless housewife."],[2494,2627,"I'm the one who helped your father"],[2627,2731,"build his career."],[2748,2827,"He needed me"],[2827,2994,"more than he ever needed you"],[2994,3165,"or your pathetic mother."],[3165,3328,"Don't you dare talk about my mother."],[3349,3607,"Winnie, we are here to remind you."],[3607,3791,"You and Logan are divorced."],[3791,3953,"Stop showing up before him."],[3970,4066,"Your sister Selina"],[4066,4233,"is much better suited for him."],[4295,4400,"Oh, right."],[4458,4600,"Like mother, like daughter."],[4621,4846,"Selina perfectly inherited your talent"],[4846,5017,"for stealing other people's husbands."],[5050,5113,"You would-"],[5384,5459,"Winnie, remember."],[5505,5680,"Margaret is your legal mother as well."],[5680,5876,"And as long as you bear my last name,"],[5876,5989,"you will give me the respect"],[5989,6139,"a daughter gives to a father."],[6139,6193,"Enough."],[6218,6306,"Security?"],[6423,6527,"Get them out of here."],[6552,6719,"Leave town and don't ever come back."],[6719,6815,"You hear me, Winnie?"],[6956,7057,"It hurts, doesn't it?"],[7094,7286,"To get chewed out by your own father?"],[7361,7469,"I'd give up now."],[7507,7649,"It'll only get worse."]],"41":[[37,116,"Why is my father"],[116,308,"always taking their side?"],[308,450,"Am I not his daughter?"],[467,642,"Leave town and don't ever come back!"],[925,1021,"Oh my God."],[1555,1622,"Winnie!"],[2794,2886,"She had a panic attack"],[2886,3011,"and she's running a fever now."],[3048,3232,"We gave her meds so she'll be fine soon."],[3232,3370,"Just keep her well rested"],[3370,3486,"and well hydrated."],[3908,4020,"I hate you"],[4074,4212,"for abandoning our child."],[4279,4441,"Winnie left the baby out in the rain"],[4441,4542,"all by herself."],[5096,5255,"But I can't stop worrying about you."],[5255,5347,"What's wrong with me?"],[5530,5626,"It hurts."]],"42":[[221,371,"Hey, where, what is it hurt?"],[371,429,"Tell me."],[804,925,"I waited for you."],[1005,1242,"I waited and I waited and you never came."],[1317,1401,"I'm here now."],[1497,1634,"Everything's gonna be okay."],[1693,1939,"You need to tell me who did this to you."],[2010,2118,"I'm gonna make them pay."],[2285,2373,"You did."],[2569,2736,"You took Selina's side."],[2769,2902,"You believed her lies."],[2902,3069,"You cheated on me with her."],[3144,3303,"You left me there to die."],[3620,3724,"What happened?"],[3816,3962,"Tell me what happened, Winnie, I,"],[3987,4104,"I feel like you're hiding."],[4162,4250,"I don't know why. I, I, I,"],[4250,4383,"I'm just getting this feeling and..."],[4562,4646,"I don't even know-"]],"43":[[437,508,"Yes!"],[667,725,"Abby!"],[725,855,"Mommy and daddy meet up."],[884,971,"It's time to go into"],[971,1105,"phase two of our plan."],[1105,1322,"Teach the evil witch a lesson."],[3115,3265,"Who did this?"],[3265,3432,"I'll skin you alive!"],[3516,3707,"We did, you evil witch."],[3824,3899,"Skin us."],[3924,4083,"You look like a soggy chicken."],[4083,4137,"Wait!"],[4158,4325,"Why do you two look identical?"],[4487,4612,"Did Winnie had twins?"],[4612,4675,"Yup."],[4696,4813,"And now that Mommy and Daddy"],[4813,4904,"are back together,"],[4917,5088,"your game's over."],[6093,6285,"You fricking rats!"],[6285,6360,"Guards!"],[6523,6790,"Get rid of these little demons!"],[7469,7582,"My mommy and daddy"],[7582,7703,"will never forgive you!"],[7882,7982,"Oh, really?"],[8016,8120,"Well, I'll make sure"],[8120,8345,"you two don't make it through the day."]],"44":[[254,346,"