omebody help!"]],"47":[[183,337,"Miss McGuire's missing."],[608,696,"Get the team."],[738,821,"We leave now."],[1176,1226,"Abby!"],[1263,1313,"No."],[1647,1755,"Let's hurry, baby."],[1814,1947,"Baby, don't look at them."],[1972,2039,"It's okay."],[2331,2423,"Let my daughter go."],[2744,2857,"No, please don't hurt her."],[2857,2948,"I will do whatever you want."],[2948,3157,"Just don't, don't hurt her."],[3174,3428,"Well, I still have to get you back"],[3428,3599,"for pouring wine all over me."],[4033,4341,"Get on your knees, slap yourself,"],[4433,4629,"call yourself a skank,"],[4696,4963,"and don't stop till I tell you to stop."],[5030,5092,"What?"],[5184,5255,"Fine!"],[5301,5376,"I'll do it."],[5413,5513,"Just don't hurt her."],[5609,5701,"No, Mommy!"],[5701,5789,"Shut it."],[5809,5876,"It's okay."],[5889,6126,"Baby, just close your eyes, okay?"],[7111,7203,"Mommy!"],[7486,7561,"No!"],[7632,7707,"Now say it,"],[7745,7891,"loud!"],[8008,8120,"I'm a skank."],[8262,8333,"Mommy."],[8370,8470,"I'm a skank."],[8550,8662,"I'm a skank."]],"48":[[450,538,"What was that?"],[638,767,"Say it louder!"],[804,967,"Skank, bitch!"],[1080,1267,"You're mine now, Winnie."],[1267,1347,"You see her?"],[1347,1559,"You're going to do as I say."],[1659,1739,"Because her,"],[1739,1889,"little rashy-poo."],[1926,2118,"It's starting to get severe, isn't it?"],[2448,2527,"Mommy!"],[2594,2690,"Don't be scared, baby."],[3653,3791,"It's all my fault."],[3837,4004,"I should've never tricked Selina."],[5459,5593,"Not so fast."],[5805,5918,"But you promised."],[5976,6139,"Just let my baby go."],[6448,6544,"Oh, I will."],[6589,6865,"But which one are you gonna save?"],[7999,8074,"What?"]],"49":[[258,475,"So, it wasn't a dream."],[650,800,"I really did have twins."],[842,917,"That's right."],[938,1130,"And now you get to choose."],[1242,1564,"Which one do you want to keep alive?"],[1589,1693,"Or lose them both?"],[1714,1885,"I'll give you ten seconds to choose."],[2135,2206,"Ten."],[2339,2414,"Nine."],[2527,2615,"Eight."],[2873,2961,"Save Hannah."],[2961,3132,"She's been gone for six years."],[3269,3486,"She deserves to be with Mommy now."],[3516,3603,"It's okay."],[3724,3828,"I'm not scared."],[3828,3945,"Save Abby."],[3991,4183,"I already got a whole week with Mommy."],[4250,4366,"You brushed my hair."],[4441,4617,"You called me your princess."],[4692,4829,"You told me stories."],[4829,5034,"That's more than I ever dreamed of."],[5055,5134,"No, no."],[5142,5242,"That's not true."],[5267,5401,"You said you still wanted"],[5401,5522,"more time with Mommy."],[5676,5851,"No, I can't, I can't do this."],[5885,5955,"Three."],[6001,6076,"Two."],[6114,6197,"One!"],[6197,6356,"Save Hannah! - Save Abby!"]],"50":[[8,87,"Three."],[133,204,"Two."],[233,325,"One!"],[342,392,"Stop."],[392,462,"Just kill me."],[542,696,"Kill me instead, please."],[888,942,"Hannah."],[963,1134,"Hannah, I'm so sorry."],[1205,1401,"I, I, I don't know your favorite color"],[1401,1534,"or your favorite food."],[1593,1697,"When you were sick,"],[1697,1839,"if, if you were alone."],[1839,1956,"If when you're sad,"],[1956,2110,"was someone there to protect you?"],[2252,2377,"God, I wasn't there"],[2377,2473,"when you needed me."],[2531,2819,"I'm such a bad mom and I'm so sorry."],[3036,3165,"And Abby, I can't believe"],[3165,3315,"I couldn't tell you two apart."],[3315,3482,"How could I be so stupid?"],[3591,3661,"But, girls, hey."],[3682,3791,"Don't be scared, okay?"],[3812,3941,"Mommy's not leaving you."],[4020,4124,"I promise."],[4275,4391,"Selina, please."],[4475,4600,"Just kill me instead."],[4725,4909,"Just let the girls go, please."],[5038,5326,"What a beautiful family."],[5347,5430,"You know what?"],[5455,5543,"You're right."],[5543,5784,"Maybe you should all just die together."],[7323,7453,"No, no, no! Come on!"],[7640,7836,"Boss! They're at the East-side Warehouse!"]],"51":[[200,283,"Get out of the way!"],[625,671,"It's okay."],[671,763,"Don't be scared."],[809,871,"Don't be scared."],[871,975,"Mommy's got you, okay?"],[984,1251,"Mommy, I'm so tired."],[1267,1309,"No."],[1380,1505,"Hey, hey, no, no, no, no."],[1505,1584,"Stay with me, baby."],[1584,1685,"Don't close your eyes, okay?"],[1939,2223,"Santa, the only Christmas present"],[2223,2318,"I want is..."],[2660,2736,"Daddy?"],[2861,3157,"Mommy, I wish we were never apart"],[3157,3224,"and could spend"],[3224,3424,"every holiday together,"],[3424,3520,"all four of us."],[3636,3712,"Hannah?"],[3853,3920,"Logan!"],[3920,4079,"Logan, where are you?"],[5038,5117,"Winnie!"]],"52":[[54,187,"Hannah, honey."],[337,421,"Come on, Winnie."],[471,625,"I'm gonna get you to the hospital, okay?"],[625,704,"No, please."],[729,842,"Please save her first."],[1059,1146,"You chose the daughter"],[1146,1222,"you have with"],[1222,1338,"over our own?"],[1384,1655,"Guards, take Hannah to the hospital now."],[1676,1785,"And take this other girl too."],[2406,2502,"The cameras were wiped."],[2523,2681,"We'll need more time to find the culprit."],[3286,3415,"I'm so sorry."],[3582,3666,"If I'd gotten there sooner,"],[3666,3787,"none of this would have happened."],[3945,4104,"I'm gonna find the bastards"],[4104,4191,"who did this."],[4216,4320,"Whatever it takes,"],[4379,4496,"I'm gonna make them pay."],[4729,4783,"Winnie."],[4792,4825,"Logan."],[4825,4888,"Hey."]],"53":[[4,79,"Hey, hey, I'm here."],[79,145,"Logan?"],[145,208,"It's okay, shh."],[237,342,"No, Logan, I..."],[417,563,"we have to talk to our daughters."],[621,700,"Please listen- - Logan,"],[725,930,"The doctors wanna discuss her injuries."],[984,1076,"Hannah's awake."],[1088,1201,"She's been asking for you."],[1217,1267,"No."],[1359,1463,"I'll be right back, okay?"],[1463,1514,"No."],[1555,1655,"Please, Logan, I have to talk to you."],[1655,1739,"Please don't go!"],[2318,2515,"You hurt our twins."],[2544,2648,"When Logan finds out"],[2648,2815,"what you did to them, I swear."],[2865,3073,"You and Logan are divorced."],[3090,3265,"He's gonna fight for custody."],[3282,3482,"And then once I get both the girls,"],[3516,3757,"imagine what I'll do."],[3974,4099,"You wouldn't dare."],[4145,4279,"Let's make a deal."],[4475,4654,"I'll sneak out Hannah,"],[4750,4871,"and then you take both girls"],[4871,5021,"and never come back."]],"54":[[4,179,"I'll sneak out Hannah,"],[179,325,"and then you take both girls"],[325,467,"and never come back."],[934,1021,"Next week."],[1071,1230,"I will leave with them next week."],[1263,1380,"But if you hurt them again,"],[1380,1543,"I will take you down with me."],[1618,1768,"Stay away from Logan."],[1835,1976,"And the little brats will be safe."],[2018,2160,"She will do everything"],[2160,2189,"to get Logan."],[2189,2293,"to get to Logan."],[2293,2398,"I will protect the girls"],[2398,2581,"even if it breaks me and Logan apart."],[2598,2673,"Please."],[2673,2802,"He's just something I used"],[2802,2902,"and tossed aside."],[2948,3115,"But if you keep yapping at me,"],[3144,3215,"I'll take him back"],[3215,3378,"just to prove to you that I can."],[3461,3574,"That was just a lie?"],[3695,3770,"Logan!"],[3803,3974,"How long have you been standing there?"]],"55":[[4,70,"Logan!"],[91,271,"How long have you been standing there?"],[291,375,"So last night,"],[462,654,"when you held me in your arms"],[654,767,"and you told me that you loved me-"],[767,925,"Did you find out who hurt our kids?"],[1247,1422,"The camera system got destroyed, so-"],[1422,1526,"So nothing."],[1534,1668,"Are you even trying?"],[1897,1951,"Fine."],[1951,2189,"Last night, I was just curious."],[2277,2394,"I wanted to see"],[2427,2590,"if my loyal dog still knew"],[2590,2711,"who its master was."],[2873,2998,"Turns out he does."],[3190,3345,"So you can let it go,"],[3390,3495,"and get out."],[3678,3799,"You really let me down,"],[3878,3937,"Winnie."],[3999,4108,"But if you really mean that,"],[4170,4216,"then I don't want to"],[4216,4316,"see your face again."],[4817,4996,"I won't tell Logan about the twins."],[4996,5201,"But you better stay out of our sight."],[5409,5509,"Well, don't worry."],[5643,5747,"Because in two weeks,"],[5747,5918,"you'll never see any of us ever again."]],"56":[[471,542,"Oh, no."],[579,721,"Mommy and Daddy hate each other"],[721,821,"even more now."],[846,950,"It's just getting worse."],[1076,1176,"What should we do?"],[2298,2494,"You can, you can come in here, babies."],[2823,2915,"Mommy? - Mommy?"],[3345,3420,"Hannah,"],[3486,3616,"what do you think about coming back"],[3616,3766,"to London with Mommy and Abby."]],"57":[[37,95,"Mommy,"],[166,308,"can't we just stay here?"],[308,467,"Baby, London is our home."],[467,713,"And Selina, she's dangerous."],[725,884,"I can't let her hurt you again."],[1009,1151,"We have to go back."],[1355,1547,"But Hannah, what do you think about"],[1547,1685,"coming back with us?"],[1714,1818,"I want to."],[1876,1989,"But what about Daddy?"],[2089,2227,"He doesn't have to know."],[2260,2356,"I've already bought the tickets"],[2356,2477,"back for Christmas."],[2540,2656,"But until then,"],[2656,2794,"I need you two to promise me"],[2794,2861,"you're not gonna let him"],[2861,2994,"see you two together."],[3053,3115,"Okay?"],[3332,3399,"Thank you."]],"58":[[129,246,"I finally have a dad,"],[291,433,"I don't want to lose him."],[517,667,"I know he still loves me."],[700,809,"He fixes my toys."],[809,934,"He sneaks me snacks."],[934,1001,"And I know"],[1021,1172,"he still loves Mommy too."],[1267,1534,"But why can't people who love each other"],[1568,1730,"just, just stay together?"],[2369,2473,"If, if we share with them"],[2473,2623,"the truth about their past,"],[2623,2723,"then Mommy and Daddy"],[2723,2844,"will be together again."],[2844,2973,"And we'll all be together."],[3103,3224,"Surveillance footage."],[3628,3782,"Oh, this might be what we need."],[3920,3999,"Mommy. - Daddy"],[4029,4212,"The National Fencing Championship"],[4212,4350,"is on Christmas Day."],[4350,4504,"You're coming to my fencing finals"],[4504,4629,"next Saturday, right?"],[4650,4767,"Of course."],[4767,4950,"I wouldn't miss my girl's match."],[4950,5059,"I will always be there"],[5059,5188,"to watch my Hannah win."],[5814,6001,"Mommy and Daddy are right up front."],[6001,6172,"And Selina's got her whole crew here."],[6202,6381,"Abby, this is it."],[6381,6498,"Our last shot."],[6531,6656,"Then let's end it today,"],[6656,6835,"clear things up for Mommy and Daddy,"],[6835,7061,"and teach the evil witch a lesson."]],"59":[[41,300,"And now for the final match of the day."],[367,563,"Let's meet our finalists."],[729,821,"Come on, Abby."],[1042,1134,"Let's go, Hannah."],[2394,2502,"Abby's on fire today."],[2502,2686,"Look, her footwork looks amazing."],[2686,2815,"God, she's amazing."],[2844,2990,"I just hope she can bring it home."],[2990,3132,"Hannah's amazing."],[3148,3399,"That aura definitely takes after you."],[3436,3549,"Yeah, she's determined."],[3699,3803,"Just like her mother."],[4433,4542,"Yeah, Hannah!"],[4717,4783,"Logan?"]],"60":[[191,275,"What am I supposed to do"],[275,433,"if he finds out about the twins?"],[521,650,"What are you doing here?"],[725,909,"She can't even stand to see me, huh?"],[1013,1084,"If I weren't here,"],[1084,1163,"I wouldn't have to watch you"],[1163,1301,"cozy up to some new man."],[1330,1426,"Let's be honest."],[1426,1576,"My daughter's gonna win this match."],[1593,1814,"Especially if it's against his."],[1814,2014,"Mate, fencing's about skill,"],[2014,2147,"not about trash talk."],[2260,2435,"Also, your daughter looks too aggressive."],[2435,2640,"She's generally lacking in finesse."],[2665,2769,"Like her father."],[2798,2865,"Winnie, can you please"],[2865,2986,"keep this man in check?"],[3011,3086,"He doesn't get to talk about"],[3086,3203,"our daughter like that."],[3228,3374,"What makes you think that you can?"],[3945,4049,"It's a draw!"],[4533,4779,"Mask off and salute your opponent!"]],"61":[[20,262,"Mask off and salute your opponent!"],[579,633,"Mommy! - Daddy!"],[633,742,"We both won! - We both won!"],[1334,1451,"How's this possible?"],[1843,2014,"They look exactly the same."],[2047,2206,"Isn't that beautiful?"],[2235,2460,"Two sisters perfectly matched."],[2894,2973,"Twins?"],[3028,3119,"Logan's gonna take my daughter"],[3119,3224,"away from me."]],"62":[[8,145,"Mommy, Daddy,"],[145,287,"we need to tell you something."],[325,412,"It's about us."],[433,579,"About why we look the same."],[625,804,"Mommy didn't just have one kid."],[804,892,"She had two."],[917,1063,"But Selina stole Hannah away"],[1063,1192,"from her six years ago."],[1388,1626,"But, thanks to Abby's hacking skills,"],[1643,1776,"now we can prove it."],[1818,1981,"I hacked into the traffic cam,"],[1981,2081,"found the broken footage,"],[2081,2164,"but I fixed it."],[2181,2306,"Let's take a look."],[3378,3449,"See, Daddy?"],[3449,3603,"That witch framed Mommy."],[3636,3741,"Mommy never pushed her"],[3741,3832,"down the stairs."],[3862,3970,"It was all fake."],[4008,4195,"She stole me and lied to everyone."],[4212,4379,"She also tried to kill us."],[4625,4754,"That's not true!"],[4775,4913,"Shut your mouths!"],[4975,5163,"You think you can wipe the footage?"],[5163,5355,"Well, nothing gets past me."],[5359,5492,"Just wait and see."],[5901,6197,"Oh my God, that's horrible."],[6197,6439,"How can someone be so vile?"],[6539,6756,"She tried to kill the children."],[6756,6831,"There's more."],[6831,7023,"We also have this text message"],[7023,7144,"Selina sent to Mommy."],[7228,7315,"That's right."],[7315,7461,"After some tech magic,"],[7461,7615,"we can prove it's AI."],[8345,8575,"I never cheated on you, Winnie."],[8600,8800,"Selina lied to you."],[8825,8971,"That photo is a deep fake."],[9092,9171,"It was you."],[9305,9405,"You were behind all of this"],[9405,9496,"the whole time."]],"63":[[41,141,"You were behind all of this"],[141,237,"the whole time."],[237,329,"No, no."],[346,558,"It's not true. I'm being set up!"],[579,713,"Set up?"],[713,834,"Please!"],[863,1080,"We all saw your face."],[1121,1347,"Six years of playing the victim,"],[1347,1655,"and all along, you were the snake."],[1768,1939,"No, I'm not!"],[1939,2035,"No?"],[2202,2339,"I defended you."],[2339,2481,"Called you my family."],[2494,2623,"I even turned against Winnie"],[2623,2731,"because of you."],[2744,2836,"And all this time,"],[2836,3069,"you've been nothing but poison."],[3169,3374,"You're done for, Selina."],[3374,3490,"Mark my words."],[3582,3670,"Oh, Daddy!"],[3670,3862,"Daddy, say something, please!"],[3878,3991,"Don't call me that."],[4012,4162,"You're no daughter of mine."],[4195,4258,"You betrayed Winnie."],[4258,4471,"You, you, you turned me against her."],[4491,4708,"God, I let a devil in my house."],[4725,4979,"Winnie, I was blind."],[4979,5130,"I said things I shouldn't have."],[5163,5276,"No."],[5321,5413,"It's over."],[5463,5630,"Logan and I are over."],[6114,6389,"And it's all because of you little brats!"],[6389,6527,"Don't touch my kids!"],[6669,6781,"That's for stealing my daughter"],[6781,6902,"six years ago."],[6927,7123,"That's for every time you came after her."],[7232,7486,"Six years I lost with my daughter!"]],"64":[[29,271,"Six years I lost with my daughter!"],[462,567,"And now you pay."],[600,692,"The kidnapping?"],[692,825,"That was her doing too?"],[825,909,"It was!"],[909,1109,"She forced Hannah to eat chocolate"],[1109,1263,"and dumped ice water on me!"],[1263,1372,"And she ordered the guards"],[1372,1505,"to hurt Mommy's legs!"],[1534,1618,"Logan!"],[1618,1730,"They're lying!"],[1747,1906,"Please, please save me!"],[1976,2122,"No one's saving you tonight."],[2160,2318,"Oh baby."],[2356,2535,"Mom, please help me!"],[2619,2731,"Not another step."],[2731,2827,"For every vile thing"],[2827,2927,"you've done to Winnie,"],[2927,3015,"I'm gonna make you"],[3015,3082,"answer for it!"],[3303,3490,"How does it feel, Selina,"],[3561,3703,"to be the one abandoned?"],[3745,3937,"To finally be the one left all alone."],[4133,4229,"I just,"],[4250,4508,"I just wanted what she had!"],[4537,4742,"I was just so jealous!"],[4779,4979,"Jealous that Logan loved her,"],[4979,5142,"and not me!"],[5413,5580,"And spend the rest of your life jealous."],[5618,5701,"In prison."],[6093,6156,"Take them."],[6156,6227,"Both of them."],[6227,6306,"Make sure they never see"],[6306,6414,"the light of day again."],[6427,6510,"Get away from me!"],[6510,6602,"Don't touch me!"],[6623,6698,"Get off!"],[6698,6752,"Get off!"],[6752,6886,"Logan, I love you!"],[6956,7136,"Please help me! You little rats!"],[7273,7357,"Get off!"]],"65":[[200,296,"Alright, come on girls."],[296,408,"Wait, Winnie, stop."],[487,558,"You're really just gonna"],[558,654,"run away again?"],[654,713,"Why don't you tell me"],[713,829,"that Abby was my daughter?"],[829,980,"Do you not trust me at all?"],[1071,1172,"Trust?"],[1309,1551,"Logan, trust is what tore us apart."],[1626,1726,"Not Selina."],[1743,1951,"It was you refusing to believe me"],[1951,2106,"when I told you the truth."],[2135,2293,"It was me choosing to believe her"],[2293,2419,"because I didn't trust you."],[2452,2669,"Selina didn't break us apart, Logan."],[2706,2852,"We did that to ourselves."],[2965,3015,"Winnie."],[3015,3186,"I'm taking the girls back to London."],[3411,3486,"Please,"],[3545,3678,"don't make me fight for them."],[3770,3824,"Hey,"],[3899,4020,"I'm gonna wait outside okay?"],[4049,4195,"You can say goodbye to your daddy."],[4404,4483,"Wait!"]],"66":[[0,58,"Wait!"],[79,225,"Go after her, Daddy!"],[316,387,"I think Mommy's mad"],[387,487,"at me right now, I,"],[538,654,"I should give her some space."],[658,771,"Don't be stupid."],[784,892,"She needs you."],[892,1059,"We can show you how to win her back."],[1076,1134,"Oh yeah?"],[1176,1259,"And what do you two know"],[1259,1372,"about marital problems, huh?"],[1401,1539,"More than you, apparently."],[1597,1805,"Our flight to London leaves at 8 tonight."],[1814,1926,"If you don't do something,"],[1993,2289,"you will lose us and Mommy for good."],[2352,2627,"Alright, I'm listening."],[2748,2861,"What's our first move?"]],"67":[[450,546,"Mommy, you need to"],[546,696,"eat at least something."],[738,859,"I'm not hungry, sweetheart."],[1597,1672,"Hey, what do you want now?"],[1672,1739,"Are you going to follow us"],[1739,1860,"all the way to London?"],[1860,1926,"Look, I know you don't want to"],[1926,2047,"see me right now."],[2064,2189,"But if you give me a chance,"],[2214,2339,"I want to clear things up."],[2531,2656,"All those years you were gone,"],[2656,2777,"I searched for you."],[2894,3003,"I wrote you letters."],[3128,3236,"I just never sent them."],[3561,3716,"Why are you telling me this?"],[4087,4270,"Hannah and Abby drew this yesterday."],[4429,4542,"They need their dad."],[4804,4925,"Winnie, please."],[4975,5100,"Just give me a chance."]],"68":[[4,137,"Winnie, can you, can you please"],[137,262,"just give me a chance?"],[625,750,"The divorce papers."],[796,917,"I never signed them."],[992,1213,"And I know you may never forgive me,"],[1213,1384,"but legally we're still married."],[1505,1614,"Please, Mommy."],[1630,1772,"Daddy knows he was wrong."],[1830,1972,"Can't you just forgive him?"],[2027,2168,"He still loves you."],[2193,2281,"He keeps a photo of you"],[2281,2410,"on his nightstand."],[2410,2494,"I've seen it."],[2577,2669,"Abby, how did you-"],[2990,3065,"It's true."],[3261,3445,"Come on, let's give them some space."],[3687,3953,"I can't force you to forgive me."],[4033,4166,"But I'm not gonna stop trying."],[4191,4446,"Logan, after all these years."],[4529,4729,"I can't believe how wrong we got it."],[4771,4854,"All the pain,"],[4854,4959,"the confusion."],[4959,5163,"I mean, we were drowning in it."],[5242,5463,"We couldn't stop hurting each other."],[5588,5734,"I never gave myself permission"],[5734,5880,"to fall in love with you."],[5922,5989,"Because I, I thought"],[5989,6118,"you'd gotten over me."],[6247,6335,"But I have been in love"],[6335,6477,"with you all along."],[6556,6723,"God, I still love you."],[6898,6994,"Is that a yes?"],[7390,7499,"Can I go to London with you?"],[7586,7636,"No."],[7857,7945,"I'm saying yes"],[7945,8045,"to staying home,"],[8145,8254,"with you."],[8692,8779,"Yay!"],[8779,9000,"This is the best Christmas ever!"]]}