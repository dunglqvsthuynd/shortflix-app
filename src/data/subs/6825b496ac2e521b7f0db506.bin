{"1":[[33,175,"Billionaire international"],[175,279,"lawyer Jack Kline"],[279,375,"returns to the States"],[375,425,"after yet"],[425,633,"another win overseas."],[633,863,"The pride of Yale law has never lost"],[863,967,"a single case,"],[967,1159,"and continues his streak."],[1159,1326,"There he is! Mr. Kline."],[1326,1518,"-Mr. Kline! -Attorney Kline."],[1518,1584,"What brings you back to"],[1584,1693,"New York City?"],[1693,1856,"I'm here for someone."],[1889,1997,"Ah, mysterious!"],[1997,2093,"A lover?"],[2252,2385,"No, I'm here"],[2385,2548,"for the person I loathe."],[2548,2748,"Mister. Mister Kline!"],[2748,2844,"Attorney Kline!"],[2844,2973,"Can I get another word?"],[2973,3036,"Mr. Kline,"],[3036,3224,"can I get another word?"],[3474,3603,"Mr. Kline."],[3603,3791,"It's me. Bobbi."],[3791,3941,"Do you remember me?"],[3941,4241,"I'm Lottie's mother,"],[4258,4354,"Lottie..."],[4412,4487,"That's right."],[4487,4608,"We met when you dated her"],[4608,4713,"in college."],[4775,4963,"Can you please help us?"],[4963,5100,"My family."],[5100,5263,"We're struggling."],[5263,5347,"You and Lottie"],[5347,5509,"once loved each other."],[5509,5630,"Can you please"],[5630,5930,"help us, with some money?"],[5955,6093,"How much?"],[6093,6281,"Ten grand."],[6281,6489,"100 grand."],[6489,6623,"A million."],[6623,6865,"A million? Yes!"],[6865,7019,"A million would be fantastic."],[7069,7240,"It's pocket change to me now."],[7528,7665,"But, Lottie Alcott"],[7665,7828,"has to ask for the money"],[7845,7999,"herself."],[8237,8295,"Hey!"],[8295,8558,"You wasted $500,000"],[8558,8671,"on online gambling?"],[8671,8746,"This dress"],[8746,8942,"you're wearing cost 20 grand."],[8942,9046,"Who are you to preach?"],[9046,9138,"Give me the rest of it."],[9138,9196,"I can't."],[9196,9250,"It's mine."],[9250,9371,"-It’s mine! -I need it,"],[9371,9438,"it's mine."],[9438,9592,"-It's mine! -It's mine."],[9592,9672,"Here!"],[9672,9718,"Take this."],[9763,9855,"It’s what I made in tips."]],"2":[[116,250,"These are all ones!"],[250,283,"What am I"],[283,400,"gonna do with this shit?"],[400,500,"You little jinx?"],[500,696,"Disgusting!"],[796,921,"By the way,"],[921,1113,"did you know Jack Kline is back?"],[1113,1176,"He sure did"],[1176,1309,"make something of himself."],[1309,1384,"Everyone thought"],[1384,1514,"you were the perfect couple."],[1514,1659,"The genius lawyer,"],[1659,1797,"the hot designer with"],[1797,1956,"the endless potential."],[2039,2127,"Oh, how the"],[2127,2264,"mighty have fallen."],[2289,2352,"And look at you"],[2352,2414,"now."],[2464,2544,"You're not even fit"],[2544,2610,"to shine his"],[2610,2740,"fucking shoes."],[2765,2898,"You little bitch!"],[3524,3649,"Oh, Lottie!"],[3649,3841,"You won the Red Dot award!"],[3841,3941,"Let's take a picture."],[3941,4037,"Okay."],[4354,4525,"Hey. Taking a picture"],[4525,4587,"without permission"],[4587,4654,"is a violation"],[4654,4775,"of my image rights."],[5601,5734,"Is that even, like,"],[5734,5864,"really a thing?"],[5864,6043,"Oh, it absolutely is."],[6043,6185,"But I'll let it slide"],[6185,6327,"if you give me your number."],[8366,8450,"Jack..."],[8591,8671,"I hope you never"],[8671,8758,"see me this way."]],"3":[[112,208,"I met Jack when"],[208,408,"everything was golden."],[442,496,"Back then,"],[496,554,"I thought I had"],[554,754,"the best thing in this world."],[796,955,"The boy I loved."],[955,1109,"Loving me back."],[1109,1309,"Did you do all of this for me?"],[2431,2640,"Tell me about your future, Jack."],[2686,2877,"Oh, I become the best lawyer"],[2877,2944,"in this world"],[2944,3044,"has ever seen."],[3174,3253,"And your husband."],[3432,3561,"And I become"],[3561,3628,"the best"],[3628,3724,"fashion designer"],[3724,3924,"in all of New York City."],[3970,4170,"And your wife."],[5313,5509,"Let's get married"],[5509,5593,"after we graduate"],[5593,5793,"next week."],[6097,6293,"I thought that was it."],[6293,6343,"We live a"],[6343,6573,"happy, normal lives together."],[6677,6723,"But"],[6781,6906,"life doesn't always work out"],[6906,6981,"the way we planned."]],"4":[[0,108,"Oh my God."],[108,208,"Really?"],[613,684,"Oh!"],[896,980,"Hi."],[1042,1130,"I'm looking to drop off"],[1130,1230,"some clothes to my daughter."],[1230,1338,"Her name's Lottie."],[1338,1447,"Last name Alcott."],[1447,1534,"Oh. Okay."],[1534,1810,"You’re Lottie Alcott's father?"],[1843,1922,"All this time,"],[1922,1956,"I thought the"],[1956,2047,"design star"],[2047,2085,"was some"],[2085,2285,"sort of a legit princess."],[2289,2369,"But her dad is"],[2369,2569,"a pizza delivery dude."],[2602,2798,"And a fucking cripple?"],[2965,3165,"Hey, give this back, please."],[3165,3249,"What is this?"],[3249,3340,"Rags?"],[3340,3382,"You get this"],[3382,3465,"from Goodwill?"],[3465,3599,"Please. Those are clothes."],[3599,3699,"-For Lottie. -Over here!"],[3699,3899,"-Come get it! -No!"],[3908,3991,"Give them back, please."],[3991,4116,"Please! Stop!"],[4116,4245,"Stop!"],[4245,4446,"Give it! Hey!"],[4487,4688,"Hey! Give that back!"],[5217,5288,"Dad!"],[5388,5534,"What are you doing to my dad?"],[5534,5605,"Lottie."],[5843,5989,"What are you..?"],[6126,6235,"Lottie!"],[7036,7236,"Boring!"],[7845,7978,"Girls!"],[7978,8179,"Let's jam."],[8224,8337,"Dad, are you okay?"],[8337,8521,"Lottie."],[8521,8612,"Did I embarrass you?"],[8612,8729,"No, of course"],[8729,8858,"not. What is there to be"],[8858,8925,"embarrassed about?"],[8925,9046,"You're my dad."],[9046,9134,"I will love you"],[9134,9309,"no matter what."],[9309,9459,"To the moon and back."]],"5":[[400,529,"You know,"],[529,642,"all this time"],[642,825,"I thought you were rich."],[863,996,"But your dad's a cripple"],[996,1155,"and a delivery guy."],[1155,1351,"I can't believe we treated you"],[1351,1459,"like royalty."],[1501,1647,"You're nothing."],[2577,2744,"You know,"],[2744,2861,"people thought I was the most"],[2861,3061,"talented designer here."],[3115,3232,"Until you showed up"],[3232,3390,"with your pretty little face."],[3390,3445,"and everyone"],[3445,3645,"rushed to put you on a pedestal."],[3766,3941,"Well, I'm pulling"],[3941,4141,"you off now, bitch."],[5605,5747,"Let’s see you design anything"],[5747,5947,"with a ruined right hand."],[6560,6735,"Oh! That is fucked up."],[6735,6886,"Leave some of her for us,"],[6886,7007,"you psycho!"],[7152,7353,"Fine, cousin."],[7399,7599,"Your turn."],[7603,7736,"She's the campus belle,"],[7736,7828,"after all."],[7828,8145,"And tonight, she's all yours."],[8933,8983,"Where do you think"],[8983,9150,"you're going, Lottie?"],[9196,9392,"You're hot when you scream."],[9522,9597,"Isn't she Jack"],[9597,9705,"Kline’s girlfriend?"],[9705,9905,"Yeah. Fuck Jack!"],[9926,10089,"Cocky prick."],[10089,10176,"Let’s see what his girlfriend"],[10176,10285,"tastes like."],[10335,10481,"Someone help me!"],[10481,10664,"Please! Please.."]],"6":[[12,162,"Please, mom."],[162,275,"Call the police."],[275,421,"Are you serious?"],[421,525,"Those guys are rich"],[525,625,"and powerful."],[625,725,"Look!"],[729,859,"They already compensated us,"],[859,1009,"$500,000."],[1009,1188,"They raped me!"],[1188,1330,"I'm calling the police."],[1330,1438,"Probably because you dress"],[1438,1526,"like a whore!"],[1559,1668,"Why else would they pick on you,"],[1668,1801,"if you didn’t deserve it? Huh?"],[1835,2035,"I didn't do anything wrong!"],[2152,2252,"Don't talk back to me,"],[2252,2385,"you dirty-"],[2423,2510,"Sit."],[2585,2690,"Down."],[2744,2831,"What?"],[2831,2944,"Have you no heart?"],[3816,3870,"What?"],[4079,4179,"What are you doing?"],[4216,4387,"Though my family was poor."],[4446,4604,"I was never ashamed."],[4667,4846,"I was proud of my father."],[4921,5121,"He became crippled, saving"],[5121,5321,"someone else when he was young."],[5355,5472,"Bastards!"],[5501,5597,"I’ll kill each and everyone of who"],[5597,5693,"had hurt my baby girl!"],[5718,5847,"Dad!"],[6093,6339,"My entire world collapsed."],[6410,6644,"Dad! Daddy! Dad-"]],"7":[[41,125,"Dad!"],[171,300,"Daddy!"],[371,454,"Lottie..."],[679,859,"Have a good life for me."],[1213,1309,"No, no!"],[1338,1401,"No!"],[1634,1735,"You did this!"],[1735,1805,"You are the one that"],[1805,1951,"wanted them arrested."],[1981,2110,"You couldn’t just let it go"],[2110,2243,"and now he’s dead."],[2556,2831,"Daddy! Dad! No, please!"],[2844,2944,"Please, wake up!"],[2944,3090,"This is all your fault."],[3090,3240,"Get out."],[3399,3653,"This is your fault."],[4216,4337,"Lottie, what's wrong?"],[4337,4433,"Where are you?"],[4433,4587,"Jack..."],[4587,4721,"Something terrible,"],[4721,4917,"I’m- I’m at the hospital."],[4917,5063,"I'm on my way."],[5063,5130,"I'll be there soon."]],"8":[[120,321,"Jack! Jack?"],[738,900,"Lottie Alcott?"],[900,1059,"I'm Jack's grandfather."],[1059,1242,"I assume he hasn't told you."],[1242,1393,"I'm taking him abroad soon."],[1393,1543,"But before we leave,"],[1543,1618,"you're going to"],[1618,1764,"break up with him."],[1764,1918,"Why would I do that?"],[1918,2097,"Jack has a tumor in his brain,"],[2097,2239,"and I could fix that."],[2239,2439,"Best Swiss medical team."],[2494,2719,"But only if you leave him"],[2761,2961,"for good!"],[3044,3224,"Jack never said anything."],[3253,3420,"He didn’t want to burden you."],[3420,3557,"I mean, let's be real."],[3557,3670,"You never deserved him."],[3670,3807,"And you never will!"],[3862,3958,"You look like you rolled out"],[3958,4066,"of the gutter."],[4066,4237,"If he stayed with you,"],[4237,4433,"you'll drag him down."],[4471,4671,"It's not my fault that my family-"],[4725,4867,"Broke people always think it's"],[4867,4946,"not their fault."],[4946,5030,"Truth is,"],[5030,5230,"they don't work hard enough."],[5730,5814,"Lottie. What are"],[5814,5885,"you doing on the ground?"],[6698,6810,"I'm breaking up with you."]],"9":[[37,221,"What did you just say?"],[221,408,"I said I want to break up."],[408,475,"What about that"],[475,604,"do you not understand?"],[604,663,"Why?"],[850,996,"Look at you."],[996,1096,"You can't even afford"],[1096,1209,"a real diamond"],[1209,1347,"for the proposal."],[1397,1443,"I don't want"],[1443,1547,"a shitty life with you."],[1547,1659,"I want to marry rich."],[1659,1810,"I want money!"],[1810,1943,"Lottie!"],[1943,2068,"I know you,"],[2114,2235,"you are not like this."],[2339,2402,"What happened?"],[2402,2569,"Did something happen?"],[2569,2711,"You can tell me about it."],[2711,2769,"I love you,"],[2769,2932,"you can tell me anything."],[2932,3078,"Jack."],[3182,3328,"The only thing that I have left"],[3328,3524,"to say to you is that"],[3524,3724,"I'm done with you."],[3732,3828,"Stop pestering me"],[3828,3887,"like a dog"],[3887,4062,"and leave me alone."],[4062,4154,"Lottie,"],[4154,4250,"please."],[4266,4425,"I don't believe it."],[4500,4683,"Just- Just let me go!"],[4683,4884,"Never!"],[6694,6810,"Do you believe it now?"],[6869,7057,"I don't"],[7082,7282,"love you anymore."],[7323,7474,"Now, get lost!"],[7474,7653,"And stay away from me."]],"10":[[4,158,"I let Jack go."],[158,262,"Too broken to"],[262,404,"hold on to anything."],[404,542,"Even myself."],[542,742,"I lost my beloved father."],[746,946,"I lost my beloved Jack."],[967,1146,"I got really sick."],[1146,1359,"Most of the time I was depressed."],[1363,1480,"Jack!"],[1480,1676,"I was told by everyone left"],[1676,1901,"and my sad, pathetic life"],[1972,2173,"that everything was my fault."],[2281,2435,"I was in the mental institute"],[2435,2560,"for seven years."],[3003,3215,"During that time, I often"],[3215,3415,"saw news about Jack on TV."],[3490,3691,"Jack's first year abroad,"],[3732,3933,"his surgery was successful."],[3991,4137,"He was asked to join the Kline"],[4137,4225,"legal practice"],[4225,4429,"with offices on every continent."],[4508,4708,"He went to France."],[4721,4875,"He took a big case protecting"],[4875,5000,"women's rights."],[5000,5088,"He was praised"],[5088,5288,"by many famous lawyers."],[5317,5488,"There was even a movie"],[5488,5689,"about one of his trials."],[5968,6039,"Through the years,"],[6039,6168,"he handled the most high"],[6168,6385,"profile cases and never lost."],[6439,6531,"His name became a"],[6531,6639,"household brand."],[6852,7052,"Jack opened up his own law firm"],[7061,7140,"and earned a spot"],[7140,7269,"on the Forbes World's"],[7269,7469,"Billionaires list."],[7620,7749,"Mommy!"],[7999,8199,"Jack,"],[8241,8370,"as always,"],[8370,8575,"was a shining star in the spotlight."],[8637,8812,"He got engaged to the Foster"],[8812,8913,"family heiress."],[9855,10010,"Congrats,Jack."],[10093,10181,"I’ve missed so many"],[10181,10406,"beautiful things in this life."],[10523,10819,"Please, live them all for me."]],"11":[[41,187,"How did I give birth to you?"],[229,329,"Trash."],[362,517,"You’re such a loser."],[650,792,"Completelly useless."],[888,992,"Stop being a drama queen,"],[992,1184,"I’m sick of your tears."],[1238,1334,"Mommy!"],[1468,1647,"All you are doing is cry."],[1668,1797,"Stop hurting my mommy!"],[1805,2014,"You little bastard. Who let you in?"],[2060,2173,"Don’t touch her!"],[2277,2423,"The money from the settlement,"],[2423,2523,"the $500 grand."],[2523,2648,"Did you spend it all?"],[2706,2861,"Sis, you know that wasn’t enough"],[2861,2952,"to cover our debt."],[2990,3040,"Hey!"],[3053,3165,"Why don’t you go fuck your ex,"],[3165,3349,"Mr. Big Shot Kline for some money?"],[3349,3395,"Huh?"],[3470,3607,"If he’ll even have you."],[3716,3870,"That guy is loaded now."],[3899,4062,"What are you talking about?"],[4099,4275,"We broke up a long time ago."],[4295,4450,"I’m not gonna go bother him now"],[4450,4583,"just because you two are such"],[4583,4654,"screwups!"],[4692,4871,"If you hadn’t caused your father’s death,"],[4871,4984,"your life would had end up"],[4984,5100,"totally different!"],[5176,5334,"You’re this family’s downfall."],[5351,5488,"And whether you like it or not,"],[5522,5655,"we are going to get that money"],[5655,5743,"by Jack Kline."],[5822,5880,"No!"],[5880,6039,"We’re going now!"],[6364,6464,"Everyone,"],[6464,6614,"let’s raise our glasses to Jack."],[6652,6756,"Welcome back, man."],[6923,6981,"To Jack!"],[6998,7123,"Jack!"],[7182,7390,"You’re that eager to face me in court?"],[7540,7628,"See if you can hold on to"],[7628,7736,"that winning streak."],[7832,8003,"And, success is in everything."],[8003,8162,"You know what they say"],[8220,8495,"“lucky in work, unlucky in love”."],[8529,8683,"Yeah. Didn’t your college girlfriend"],[8683,8804,"stab you, Jack?"],[8804,8979,"Oh, I bet she regrets that now."],[8979,9213,"Losing you and all that money."],[9213,9271,"Miss you can’t get in there."],[9271,9396,"-Please! -You can’t go"],[9396,9471,"in there!"],[9471,9634,"-Mr. Kline! -Please, Mr. Kline!"],[9634,9697,"Please!"]],"12":[[0,125,"-Mr. Kline! -Please, Mr Kline!"],[125,196,"You can’t go in there!"],[196,258,"Please!"],[337,437,"Let them in."],[825,934,"I told you,"],[934,1063,"you wouldn't see a dime"],[1063,1176,"unless Lottie came here"],[1176,1376,"and begged for it herself."],[1409,1534,"My daughter's too shy"],[1534,1659,"to come over,"],[1659,1755,"so she sent me"],[1755,1956,"and my son to see you."],[1993,2068,"You wouldn't want to"],[2068,2227,"turn us down."],[2268,2469,"Think of your reputation."],[3445,3586,"That's $1 million."],[3870,3924,"Wait!"],[3924,4033,"What are you doing?"],[4145,4262,"You're blackmailing me"],[4262,4458,"for money in public."],[4458,4658,"A large sum of money."],[4767,4946,"You're looking at jail time."],[4946,5184,"No, you can't do this."],[5242,5363,"Call Lottie."],[5426,5555,"Tell her to come over."],[5976,6089,"I wanna have fun with her."],[7219,7365,"I thought she was supposed to be"],[7365,7565,"a gifted designer."],[7728,7870,"Looks like she rejected Jack"],[7870,8020,"to become a cleaner."],[8020,8128,"Talk about karma."],[8262,8366,"Don't just stand there,"],[8366,8462,"help us."],[8495,8562,"Sis,"],[8591,8683,"Mr. Kline"],[8683,8771,"is gonna have us arrested"],[8771,8854,"for blackmail."],[9121,9238,"Mr. Kline."],[9363,9496,"I'm sorry."],[9534,9688,"On behalf of my family."],[9759,9968,"If you let them go, I promise"],[9968,10114,"they will never"],[10114,10231,"bother you again."],[10268,10439,"Why should I let them go?"],[10439,10518,"Please."],[10518,10648,"Are you begging?"],[10781,11065,"Yes, I'm begging you."],[11140,11307,"Most people aren’t standing"],[11307,11507,"when they ask for forgiveness."],[11632,11886,"So I suggest you get on your knees"],[11924,11999,"and beg me."]],"13":[[625,658,"What are you"],[658,838,"waiting for, bitch?"],[838,980,"You need to get on your knees"],[980,1109,"and beg Jack."],[1109,1209,"Now."],[1209,1309,"Hurry up!"],[1317,1413,"Hurry up!"],[1413,1576,"Get on your knees, brat!"],[1576,1776,"Kneel down! Sis!"],[1881,1997,"Sure you all know,"],[1997,2114,"Lottie here,"],[2114,2198,"broke up with Jack."],[2239,2419,"She said he was too poor back then."],[2439,2640,"So she broke up with him."],[2648,2869,"But she gave him an unforgettable"],[2877,2998,"breakup gift."],[3048,3207,"She..."],[3207,3353,"stabed him."],[3420,3507,"Lottie Alcott,"],[3507,3707,"you are disgusting."],[3737,3791,"You don't"],[3791,3883,"even deserve to"],[3883,4062,"breathe the same air"],[4062,4195,"as Jack."],[4195,4233,"Hope you"],[4233,4320,"suffered for what"],[4320,4421,"you've done."],[4421,4562,"Look at you,"],[4562,4788,"become a laughing stock."],[6247,6448,"This is all your fault."],[6635,6740,"You need to get"],[6740,6831,"on your knees."],[6831,6923,"This is all your fault."],[6923,7048,"Stay on your knees!"],[7048,7178,"It's all your fault!"],[7449,7649,"You’re such a loser."],[7665,7816,"You little whore."],[7816,7912,"Get her!"],[7912,8028,"Oh my God!"],[8587,8704,"Mr. Kline."],[8704,8900,"I'm sorry."],[8900,9025,"It’s- It's all my fault."],[9951,10080,"Get back down"],[10080,10281,"on your knees!"],[10285,10456,"Please,"],[10456,10614,"let my mom and brother go."],[10948,11090,"You think that’s it?"],[11090,11257,"Lottie?"],[11257,11461,"The game is just getting started."]],"14":[[196,392,"What do you say we do to her, Jack?"],[392,521,"Man, she stabbed you,"],[521,613,"think any punishment"],[613,813,"you choose is justified."],[875,1076,"Pick a guy in this room."],[1080,1146,"You'll kiss them for"],[1146,1284,"three minutes."],[1284,1484,"What do you say?"],[1522,1589,"Ew,"],[1589,1655,"you better keep her"],[1655,1747,"away from me."],[1797,2118,"Lottie, oh Lottie. What will you do?"],[2185,2385,"None of us will kiss you."],[2385,2460,"Wait!"],[2460,2598,"There’s a janitor."],[2598,2715,"What if you kiss him?"],[2715,2902,"It's what she deserves."],[2948,3119,"-Kiss! -Kiss!"],[3119,3194,"What are you doing?"],[3194,3311,"Just kiss him already!"],[3315,3465,"Lottie, you owe us."],[3465,3561,"This is nothing."],[3561,3762,"Just get over yourself."],[4170,4341,"We're waiting."],[4350,4429,"Do it on!"],[4892,4963,"Fine."],[5167,5255,"I’ll kiss him."]],"15":[[16,200,"Dad, you wanted me to live my"],[200,400,"best life in this world."],[550,738,"Have a good life for me."],[884,971,"But it's broken"],[971,1172,"me instead."],[1201,1459,"Do you really want to kiss me?"],[2544,2744,"Get out."],[2802,2873,"But, Jack."],[2873,3073,"Get lost."],[3115,3286,"Leave!"],[3286,3486,"All of you!"],[4033,4133,"Let go of me."],[4133,4204,"Wait."],[4204,4275,"What did-"],[4458,4612,"Mr. Kline, did I"],[4612,4750,"do something wrong? I’m-"],[4750,4913,"I'm sorry."],[4913,5100,"Lottie Alcott."],[5100,5263,"You get down on your knees"],[5263,5459,"and you're told to."],[5484,5751,"You're almost kissing a janitor"],[5751,5864,"beacause you were asked."],[5968,6168,"You’re more obedient than a dog."],[6235,6297,"Back then you said"],[6297,6485,"you wanted a rich man"],[6485,6681,"and I thought by now you'd be"],[6681,6823,"doing great."],[6856,6990,"But look at you now."],[7119,7282,"You’re pathetic."]],"16":[[125,233,"You like rich guys."],[233,296,"Right?"],[337,433,"Well, now"],[5