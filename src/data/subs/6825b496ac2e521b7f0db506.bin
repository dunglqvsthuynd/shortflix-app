ere have you"],[2010,2210,"been all these years?"],[2227,2456,"I..."],[2556,2748,"Bailey is"],[2748,2948,"your daughter?"],[3103,3269,"I'm so sorry."],[3269,3470,"She has leukemia."],[3682,3787,"Leukemia?"],[3787,3945,"No, no, no. That that-"],[3945,4116,"That can't be."],[4116,4250,"She's been having"],[4250,4450,"frequent nosebleeds."],[4462,4546,"It's a textbook"],[4546,4688,"sign of leukemia."],[4688,4804,"Nosebleeds? No-"],[4804,5005,"Bailey never said anything."],[5388,5505,"Hi Bailey."],[6660,6886,"Do you get nosebleeds often?"],[6886,7011,"Yes."],[7499,7699,"Why didn't you tell your mom?"],[7711,7895,"My mommy got really sick."],[7895,8028,"Her hand got injured,"],[8028,8120,"and she gave up"],[8120,8308,"her dream to be a designer."],[8541,8742,"She has to have a hearing aid."],[8775,8942,"My mommy works really hard."],[8942,9079,"Did't want to make her worried."]],"29":[[25,225,"Your dad, is he?"],[258,379,"I don't have a daddy."],[379,496,"Ever since I was born,"],[496,696,"I haven't met him."],[829,913,"All these years,"],[913,1113,"everyone said it's my fault."],[1272,1447,"So punish me then."],[1447,1639,"Don't punish Bailey."],[1639,1714,"She's just an"],[1714,1914,"innocent little girl."],[1968,2202,"She's my baby girl."],[2615,2769,"Jack!"],[2769,2969,"Jack, wait for me!"],[3015,3090,"Jack!"],[3090,3157,"Thank you for coming to"],[3157,3303,"the hospital with me."],[3303,3370,"The doctor says"],[3370,3553,"it's a sprained ankle."],[3553,3682,"I don't want to walk."],[3682,3883,"Carry me."],[4012,4104,"Jack's already"],[4104,4266,"found his happiness."],[4266,4466,"Your life's a disaster."],[4504,4637,"Leave him alone and don't"],[4637,4838,"drag him down with you."],[4888,4992,"Please don't forget."],[4992,5071,"This is just a"],[5071,5276,"fake engagement for our families."],[5430,5530,"But what if I want-"],[5530,5726,"I'll go get the car."],[5964,6010,"Mommy!"],[6010,6114,"Mommy, where are you?"],[6114,6314,"Oh, kiddo."],[6348,6402,"You okay?"]],